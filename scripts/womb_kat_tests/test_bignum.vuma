// KAT test for bignum
// Bignum 1+1=2
// Expected exit code: 2
fn main() -> i32 {
    a = allocate(32); b = allocate(32); r = allocate(32);
    i: u32 = 0;
    while i < 32 { *(a + i) = 0; *(b + i) = 0; *(r + i) = 0; i = i + 1; }
    *(a + 0) = 1; *(b + 0) = 1;
    av: u32 = *(a + 0); bv: u32 = *(b + 0);
    rv: u32 = (av + bv) & 255;
    *(r + 0) = rv;
    return *(r + 0);
}
