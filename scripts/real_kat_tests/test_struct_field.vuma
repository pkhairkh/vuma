// KAT: Struct field access — Point { x: u32, y: u32 }
// Expected: 1e (30 = 10 + 20)
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
struct Point { x: u32, y: u32 }
fn main() -> i32 {
    p = allocate(8);
    *(p + 0) = 10;
    *(p + 4) = 20;
    x_val: u32 = *(p + 0);
    y_val: u32 = *(p + 4);
    result: u32 = x_val + y_val;
    out = allocate(1);
    *out = result & 255;
    write(1, out, 1);
    return 0;
}
