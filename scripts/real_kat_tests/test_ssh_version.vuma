// KAT: SSH-2 identification 'SSH-'
// Expected: 5353482d
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // SSH-2: "SSH-2.0-..."
    // First 4 bytes: S S H - = 83 83 72 45
    out = allocate(4);
    *(out+0)=83; *(out+1)=83; *(out+2)=72; *(out+3)=45;
    write(1, out, 4);
    return 0;
}
