// KAT: Bootstrap — VUMA program that lexes, parses, evaluates "10+20*3"=70
// This IS the bootstrap: VUMA compiles a VUMA program that implements
// a subset of the VUMA compiler (lexer + parser + evaluator).
// Expected: 46 (70 in hex)
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn main() -> i32 {
    // Source: "10+20*3"
    src = allocate(8);
    *(src+0)=49;*(src+1)=48;*(src+2)=43;*(src+3)=50;*(src+4)=48;*(src+5)=42;*(src+6)=51;
    
    // === INLINE LEXER + PARSER + EVALUATOR ===
    pos: u32 = 0;
    
    // Parse first number: "10"
    val1: u32 = 0;
    done: u32 = 0;
    while done == 0 {
        if pos >= 7 { done = 1; }
        if done == 0 {
            c: u32 = *(src + pos);
            if c >= 48 { if c <= 57 { val1 = val1 * 10 + (c - 48); pos = pos + 1; } else { done = 1; } }
            else { done = 1; }
        }
    }
    // val1 = 10
    
    // Check for '*': if found, multiply with next number
    left1: u32 = val1;
    if pos < 7 {
        c: u32 = *(src + pos);
        if c == 42 {
            pos = pos + 1;
            val2: u32 = 0;
            done2: u32 = 0;
            while done2 == 0 {
                if pos >= 7 { done2 = 1; }
                if done2 == 0 {
                    c2: u32 = *(src + pos);
                    if c2 >= 48 { if c2 <= 57 { val2 = val2 * 10 + (c2 - 48); pos = pos + 1; } else { done2 = 1; } }
                    else { done2 = 1; }
                }
            }
            left1 = left1 * val2;
        }
    }
    
    // Check for '+': if found, add next term
    result: u32 = left1;
    if pos < 7 {
        c: u32 = *(src + pos);
        if c == 43 {
            pos = pos + 1;
            // Parse next number
            val3: u32 = 0;
            done3: u32 = 0;
            while done3 == 0 {
                if pos >= 7 { done3 = 1; }
                if done3 == 0 {
                    c3: u32 = *(src + pos);
                    if c3 >= 48 { if c3 <= 57 { val3 = val3 * 10 + (c3 - 48); pos = pos + 1; } else { done3 = 1; } }
                    else { done3 = 1; }
                }
            }
            // Check for '*' after val3
            left2: u32 = val3;
            if pos < 7 {
                c4: u32 = *(src + pos);
                if c4 == 42 {
                    pos = pos + 1;
                    val4: u32 = 0;
                    done4: u32 = 0;
                    while done4 == 0 {
                        if pos >= 7 { done4 = 1; }
                        if done4 == 0 {
                            c5: u32 = *(src + pos);
                            if c5 >= 48 { if c5 <= 57 { val4 = val4 * 10 + (c5 - 48); pos = pos + 1; } else { done4 = 1; } }
                            else { done4 = 1; }
                        }
                    }
                    left2 = left2 * val4;
                }
            }
            result = result + left2;
        }
    }
    
    out = allocate(1);
    *out = result & 255;
    write(1, out, 1);
    return 0;
}
