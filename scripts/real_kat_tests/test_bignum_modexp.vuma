// Real KAT test: Bignum modular exponentiation
// 2^10 mod 17 = 1024 mod 17 = 1024 - 60*17 = 1024 - 1020 = 4
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    base: u32 = 2;
    exp: u32 = 10;
    mod_val: u32 = 17;
    result: u32 = 1;
    i: u32 = 0;
    while i < exp {
        result = (result * base) % mod_val;
        i = i + 1;
    }
    out = allocate(1);
    *out = result;
    write(1, out, 1);
    return 0;
}
