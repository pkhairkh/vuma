// KAT: ELF writer — magic bytes 0x7f 0x45 0x4c 0x46
// Expected: 7f454c46
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn main() -> i32 {
    out = allocate(4);
    *(out + 0) = 127;  // 0x7f
    *(out + 1) = 69;   // 'E'
    *(out + 2) = 76;   // 'L'
    *(out + 3) = 70;   // 'F'
    write(1, out, 4);
    return 0;
}
