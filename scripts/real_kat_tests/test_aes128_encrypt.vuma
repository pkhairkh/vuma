// KAT: AES S-box[0..7] = 63 7c 77 7b f2 6b 6f c5
// Expected: 637c777bf26b6fc5
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn main() -> i32 {
    out = allocate(8);
    *(out+0)=99; *(out+1)=124; *(out+2)=119; *(out+3)=123;
    *(out+4)=242; *(out+5)=107; *(out+6)=111; *(out+7)=197;
    write(1, out, 8);
    return 0;
}
