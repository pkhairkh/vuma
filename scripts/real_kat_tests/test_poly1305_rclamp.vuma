// KAT: Poly1305 r[0] clamp
// Expected: 05
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // Poly1305: r[3], r[7], r[11], r[15] have top 4 bits cleared
    // r[4], r[8], r[12] have bottom 2 bits cleared
    // Test: r[0] = 0x85, clamp: r[0] &= 0x0f -> 0x05
    r0: u32 = 133;  // 0x85
    r0 = r0 & 15;   // 0x0f
    out = allocate(1);
    *out = r0;
    write(1, out, 1);
    return 0;
}
