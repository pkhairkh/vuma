// KAT: AES-XTS tweak GF(2^128) double(0x01)=0x02
// Expected: 02
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // XTS: tweak is multiplied by 2 in GF(2^128) for each sector
    // Same as GCM doubling
    x: u32 = 1;  // 0x01
    msb: u32 = x >> 7;
    r: u32 = x << 1;
    if msb == 1 { r = r ^ 225; }
    r = r & 255;
    out = allocate(1);
    *out = r;
    write(1, out, 1);
    return 0;
}
