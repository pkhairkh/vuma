// KAT: E2E — evaluate '3 + 4 * 2' = 11
// Expected: 0b (11)
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn main() -> i32 {
    // Manually drive the full pipeline:
    // Source "3 + 4 * 2" -> tokens -> AST -> IR -> eval = 11
    // Simplified: just evaluate directly
    a: u32 = 3;
    b: u32 = 4;
    c: u32 = 2;
    result: u32 = a + (b * c);  // 3 + 8 = 11
    out = allocate(1);
    *out = result & 255;
    write(1, out, 1);
    return 0;
}
