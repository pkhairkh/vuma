// KAT: Recursive descent parser — evaluates "10+20*3" = 70
// Tests full call chain: parse_expr -> parse_term -> parse_factor -> lex_number -> is_digit
// Expected: 46 (70 in hex)
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn is_digit(c: u32) -> u32 { if c >= 48 { if c <= 57 { return 1; } } return 0; }
fn lex_number(src: Address, pos: u32, src_len: u32) -> u32 { val: u32 = 0; p: u32 = pos; done: u32 = 0; while done == 0 { if p >= src_len { done = 1; } if done == 0 { c: u32 = *(src + p); d: u32 = is_digit(c); if d == 1 { val = val * 10 + (c - 48); p = p + 1; } else { done = 1; } } } return val * 10000 + p; }
fn parse_factor(src: Address, state: Address, src_len: u32) -> u32 { pos: u32 = load_u32(state, 0); result: u32 = lex_number(src, pos, src_len); store_u32(state, 0, result % 10000); return result / 10000; }
fn parse_term(src: Address, state: Address, src_len: u32) -> u32 { left: u32 = parse_factor(src, state, src_len); done: u32 = 0; while done == 0 { pos: u32 = load_u32(state, 0); if pos >= src_len { done = 1; } if done == 0 { c: u32 = *(src + pos); if c == 42 { store_u32(state, 0, pos + 1); right: u32 = parse_factor(src, state, src_len); left = left * right; } else { done = 1; } } } return left; }
fn parse_expr(src: Address, state: Address, src_len: u32) -> u32 { left: u32 = parse_term(src, state, src_len); done: u32 = 0; while done == 0 { pos: u32 = load_u32(state, 0); if pos >= src_len { done = 1; } if done == 0 { c: u32 = *(src + pos); if c == 43 { store_u32(state, 0, pos + 1); right: u32 = parse_term(src, state, src_len); left = left + right; } else { if c == 45 { store_u32(state, 0, pos + 1); right: u32 = parse_term(src, state, src_len); left = left - right; } else { done = 1; } } } } return left; }
fn store_u32(ptr: Address, offset: u32, val: u32) { *(ptr + offset) = val & 255; *(ptr + offset + 1) = (val >> 8) & 255; *(ptr + offset + 2) = (val >> 16) & 255; *(ptr + offset + 3) = (val >> 24) & 255; }
fn load_u32(ptr: Address, offset: u32) -> u32 { b0: u32 = *(ptr + offset); b1: u32 = *(ptr + offset + 1); b2: u32 = *(ptr + offset + 2); b3: u32 = *(ptr + offset + 3); return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24); }
fn main() -> i32 {
    src = allocate(7); *(src+0)=49;*(src+1)=48;*(src+2)=43;*(src+3)=50;*(src+4)=48;*(src+5)=42;*(src+6)=51;
    state = allocate(4); store_u32(state, 0, 0);
    result: u32 = parse_expr(src, state, 7);
    out = allocate(1); *out = result & 255; write(1, out, 1); return 0;
}
