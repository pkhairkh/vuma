// KAT: IR — compile 3+4 to IR, evaluate = 7
// Expected: 07
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn store_u32(ptr: Address, offset: u32, val: u32) {
    *(ptr + offset) = val & 255;
    *(ptr + offset + 1) = (val >> 8) & 255;
    *(ptr + offset + 2) = (val >> 16) & 255;
    *(ptr + offset + 3) = (val >> 24) & 255;
}
fn load_u32(ptr: Address, offset: u32) -> u32 {
    b0: u32 = *(ptr + offset); b1: u32 = *(ptr + offset + 1);
    b2: u32 = *(ptr + offset + 2); b3: u32 = *(ptr + offset + 3);
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
}
fn main() -> i32 {
    // IR for "3 + 4":
    //   0: Const vreg1 = 3
    //   1: Const vreg2 = 4
    //   2: Add vreg3 = vreg1 + vreg2
    //   3: Ret vreg3
    ir = allocate(64);  // 4 instructions × 16 bytes
    // Instruction 0: Const vreg1 = 3
    store_u32(ir, 0, 1); store_u32(ir, 4, 1); store_u32(ir, 8, 3); store_u32(ir, 12, 0);
    // Instruction 1: Const vreg2 = 4
    store_u32(ir, 16, 1); store_u32(ir, 20, 2); store_u32(ir, 24, 4); store_u32(ir, 28, 0);
    // Instruction 2: Add vreg3 = vreg1 + vreg2
    store_u32(ir, 32, 2); store_u32(ir, 36, 3); store_u32(ir, 40, 1); store_u32(ir, 44, 2);
    // Instruction 3: Ret vreg3
    store_u32(ir, 48, 14); store_u32(ir, 52, 0); store_u32(ir, 56, 3); store_u32(ir, 60, 0);
    
    // Interpret
    vregs = allocate(16);  // 4 vregs
    store_u32(vregs, 0, 0); store_u32(vregs, 4, 0); store_u32(vregs, 8, 0); store_u32(vregs, 12, 0);
    
    result: u32 = 0;
    // Execute instruction 0: vreg[1] = 3
    store_u32(vregs, 4, 3);
    // Execute instruction 1: vreg[2] = 4
    store_u32(vregs, 8, 4);
    // Execute instruction 2: vreg[3] = vreg[1] + vreg[2] = 7
    v1: u32 = load_u32(vregs, 4);
    v2: u32 = load_u32(vregs, 8);
    store_u32(vregs, 12, v1 + v2);
    // Execute instruction 3: return vreg[3]
    result = load_u32(vregs, 12);
    
    out = allocate(1);
    *out = result & 255;
    write(1, out, 1);
    return 0;
}
