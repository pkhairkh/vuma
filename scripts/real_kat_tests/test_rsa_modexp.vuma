// KAT: RSA 2^10 mod 17 = 4
// Expected: 04
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // RSA: c = m^e mod n
    // Test: 2^10 mod 17 = 4
    m: u32 = 2; e: u32 = 10; n: u32 = 17;
    result: u32 = 1;
    i: u32 = 0;
    while i < e { result = (result * m) % n; i = i + 1; }
    out = allocate(1);
    *out = result;
    write(1, out, 1);
    return 0;
}
