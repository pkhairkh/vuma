// KAT: BLAKE3 IV[0]
// Expected: 6a
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // BLAKE3 IV = SHA-256 IV
    // IV[0] = 0x6a09e667 >> 24 = 106
    v: u32 = 1779033703;
    out = allocate(1);
    *out = (v >> 24) & 255;
    write(1, out, 1);
    return 0;
}
