// KAT: Lexer — tokenize "return" -> Return keyword (type 16 = 0x10)
// Expected: 10
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn is_alpha(c: u32) -> u32 {
    if c >= 97 { if c <= 122 { return 1; } }
    if c >= 65 { if c <= 90 { return 1; } }
    if c == 95 { return 1; }
    return 0;
}
fn main() -> i32 {
    // Source: "return"
    src = allocate(6);
    *(src + 0) = 114; // 'r'
    *(src + 1) = 101; // 'e'
    *(src + 2) = 116; // 't'
    *(src + 3) = 117; // 'u'
    *(src + 4) = 114; // 'r'
    *(src + 5) = 110; // 'n'
    
    pos: u32 = 0;
    done: u32 = 0;
    while done == 0 {
        if pos >= 6 { done = 1; }
        if done == 0 {
            c: u32 = *(src + pos);
            a: u32 = is_alpha(c);
            if a == 1 { pos = pos + 1; }
            else { done = 1; }
        }
    }
    len: u32 = pos;
    first: u32 = *(src + 0);
    
    token_type: u32 = 1;  // Ident
    if len == 6 {
        if first == 114 {  // 'r'
            token_type = 16;  // Return
        }
    }
    
    out = allocate(1);
    *out = token_type & 255;
    write(1, out, 1);
    return 0;
}
