// KAT: math abs(-42) = 42 = 0x2A
// Expected: 2a
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // math: abs(-42) = 42
    x: i32 = -42;
    r: i32 = x;
    if x < 0 { r = 0 - x; }
    out = allocate(1);
    *out = r & 255;
    write(1, out, 1);
    return 0;
}
