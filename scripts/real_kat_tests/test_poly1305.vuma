// Real KAT test: Poly1305 r-clamp (RFC 8439)
// r = 0x85d6be7857556d337f4452fe42d506a5
// clamped r = 0x05061405543102145543102145543105 (wrong, let me compute)
// Actually: r &= 0x0ffffffc0ffffffc0ffffffc0fffffff
// First byte of clamped r: 0x05
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }

fn main() -> i32 {
    // r[0] = 0x85, clamp: r[0] &= 0x0f -> 0x05
    r0: u32 = 133;  // 0x85
    r0 = r0 & 15;   // 0x0f
    out = allocate(1);
    *out = r0;
    write(1, out, 1);
    return 0;
}
