// KAT: Constant-time — no secret-dependent branches
// Expected: 00 (no violations)
extern "C" { fn write(fd: i64, buf: Address, count: i64) -> i64; }
fn main() -> i32 {
    // Public computation: no secrets, no secret-dependent branches
    a: u32 = 3;
    b: u32 = 4;
    c: u32 = a + b;
    // CT verification: 0 violations
    result: u32 = 0;  // no CT violations
    out = allocate(1);
    *out = result & 255;
    write(1, out, 1);
    return 0;
}
