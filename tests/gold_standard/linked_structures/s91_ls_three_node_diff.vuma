// s91_ls_three_node_diff.vuma — three nodes, diff = 40 (250 - 180 - 30)
// Expected exit code: 40
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 250/180/30 via `*ptr = literal`, load all three,
// a - b - c -> 40. Uses `*ptr = literal` form (no offsets). Distinct
// from s90_ls_three_node_diff (26), s86_ls_three_node_diff (60) and
// s82_ls_three_node_diff (110).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 180;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 40
    free(n1);
    free(n2);
    free(n3);
    return r;
}
