// s27_ls_three_node_diff.vuma — three nodes, diff = 60 (100 - 30 - 10)
// Expected exit code: 60
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 100/30/10 via `*ptr = literal`, load all three, diff -> 60. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s26_ls_three_node_sum (sum, 30+40+50=120) and s22_ls_single_load
// (single load).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 100;
    *n2 = 30;
    *n3 = 10;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a - b;       // 70
    r: u64 = s - c;       // 60
    free(n1);
    free(n2);
    free(n3);
    return r;
}
