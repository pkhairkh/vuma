// s16_ls_two_node_sum.vuma — two nodes, sum = 150 (50 + 100)
// Expected exit code: 150
//
// Two 8-byte allocations treated as two independent "nodes". Store 50/100
// via `*ptr = literal`, load both, sum -> 150. Uses `*ptr = literal` form
// (no offsets). Distinct from s13_ls_two_node_sum (values 20/40 = 60) and
// s9_ls_two_node_sum (values 15/25 = 40).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 50;
    *n2 = 100;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
