// s52_ls_two_node_sum.vuma — two nodes, sum = 250 (130 + 120)
// Expected exit code: 250
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 130/120 via `*ptr = literal`, load both, sum -> 250. Uses
// `*ptr = literal` form (no offsets). Distinct from s50_ls_two_node_
// sum (255) and s46_ls_two_node_diff (120).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 130;
    *n2 = 120;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 250
    free(n1);
    free(n2);
    return s;
}
