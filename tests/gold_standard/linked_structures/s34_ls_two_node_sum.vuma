// s34_ls_two_node_sum.vuma — two nodes, sum = 125 (55 + 70)
// Expected exit code: 125
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 55/70 via `*ptr = literal`, load both, sum -> 125. Uses
// `*ptr = literal` form (no offsets). Distinct from s30_ls_two_
// node_sum (110) and s27_ls_two_node_sum (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 55;
    *n2 = 70;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
