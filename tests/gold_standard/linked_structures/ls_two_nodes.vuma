// ls_two_nodes.vuma — create 2 nodes, link via small offset marker
// Expected exit code: 42
//
// Creates two nodes inside a single 24-byte allocation. node1 stores
// a value (0) and an offset marker (16) pointing to node2; node2
// stores 42. main reads node1's next_offset, dereferences node2 via
// (block + next_offset), and returns node2's value (42).
//
// Uses a small offset marker (16, ≤ 255) instead of a raw 64-bit
// address to avoid the known U8-truncation bug on stored Addresses.
// The semantic intent — "node1 links to node2, walk to node2" — is
// preserved.
//
// Memory layout (single 24-byte allocation):
//   node1 { val: u64 @ 0 = 0 }
//   node1 { next_offset: u64 @ 8 = 16 }  // offset of node2
//   node2 { val: u64 @ 16 = 42 }

fn main() -> i32 {
    block = allocate(24);
    // node1.val = 0 (placeholder)
    *(block + 0) = 0;
    // node1.next_offset = 16 (offset of node2 within block)
    *(block + 8) = 16;
    // node2.val = 42
    *(block + 16) = 42;

    // Traverse: read node1.next, then dereference node2.val
    off: u64 = *(block + 8);
    val: u64 = *(block + off);

    free(block);
    return val;
}
