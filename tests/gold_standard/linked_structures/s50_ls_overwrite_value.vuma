// s50_ls_overwrite_value.vuma — overwrite node to 185, load = 185
// Expected exit code: 185
//
// Single 8-byte allocation treated as one "node". Store 45 via
// `*ptr = literal`, then overwrite with 185. Load and return 185.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_ls_
// overwrite_value (160) and s43_ls_overwrite_value (180).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 45;
    *n1 = 185;
    a: u64 = *n1;
    free(n1);
    return a;
}
