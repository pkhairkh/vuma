// s73_ls_two_node_sum.vuma — two nodes, sum = 114 (76 + 38)
// Expected exit code: 114
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 76/38 via `*ptr = literal`, load both, sum -> 114.
// Uses `*ptr = literal` form (no offsets). Distinct from s70_ls_
// two_node_sum (90), s69_ls_two_node_sum (145) and s66_ls_two_
// node_diff (125).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 76;
    *n2 = 38;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 114
    free(n1);
    free(n2);
    return s;
}
