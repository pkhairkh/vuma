// s95_ls_overwrite_value.vuma — overwrite n1 to 48, load = 48
// Expected exit code: 48
//
// Single 8-byte "node". Store 5, then overwrite to 48, load -> 48
// (the overwritten value). Uses `*ptr = literal` form. Distinct from
// s94_ls_overwrite_value (73), s90_ls_overwrite_value (32) and
// s82_ls_overwrite_value (215).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 48;
    v: u64 = *n1;          // 48
    free(n1);
    return v;
}
