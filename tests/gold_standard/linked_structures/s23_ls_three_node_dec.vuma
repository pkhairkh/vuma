// s23_ls_three_node_dec.vuma — three nodes descending, sum = 180 (90 + 60 + 30)
// Expected exit code: 180
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 90/60/30 (descending) in n1/n2/n3. Load all three, sum -> 180. Uses
// `*ptr = literal` form (no offsets). Distinct from s22_ls_two_node_sum
// (37 + 53 = 90) and s20_ls_three_node_diff (40/30/20 = 90 - sub).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 90;
    *n2 = 60;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;       // 180
    free(n1);
    free(n2);
    free(n3);
    return s;
}

