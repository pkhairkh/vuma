// s58_ls_two_node_sum.vuma — two nodes, sum = 220 (120 + 100)
// Expected exit code: 220
// 
// Two 8-byte allocations treated as two independent "nodes".
// Store 120/100 via `*ptr = literal`, load both, sum -> 220. Uses
// `*ptr = literal` form (no offsets). Distinct from s51_ls_two_node_
// diff (70), s51_ls_three_node_sum (235) and s51_ls_overwrite_value
// (195).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 120;
    *n2 = 100;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 220
    free(n1);
    free(n2);
    return s;
}
