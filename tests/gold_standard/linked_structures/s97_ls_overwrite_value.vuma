// s97_ls_overwrite_value.vuma — overwrite n1 to 37, load = 37
// Expected exit code: 37
//
// Single 8-byte "node". Store 5, then overwrite to 37,
// load -> 37 (the overwritten value). Uses `*ptr =
// literal` form.
// Distinct from s94_ls_overwrite_value (73), s90_ls_overwrite_value (32), s86_ls_overwrite_value (225).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 37;
    v: u64 = *n1;          // 37
    free(n1);
    return v;
}
