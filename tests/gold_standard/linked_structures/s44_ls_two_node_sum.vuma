// s44_ls_two_node_sum.vuma — two nodes, sum = 190 (75 + 115)
// Expected exit code: 190
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 75/115 via `*ptr = literal`, load both, sum -> 190. Uses `*ptr =
// literal` form (no offsets). Distinct from s42_ls_two_node_sum (200)
// and s38_ls_two_node_sum (175).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 75;
    *n2 = 115;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 190
    free(n1);
    free(n2);
    return s;
}
