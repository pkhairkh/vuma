// s89_ls_overwrite_value.vuma — store 1, overwrite with 11, load = 11
// Expected exit code: 11
//
// One 8-byte allocation treated as a single "node". Store 1 via
// `*ptr = literal`, overwrite with 11 via `*ptr = literal`,
// load, return 11. Uses `*ptr = literal` form. Distinct from
// s86_ls_overwrite_value (215), s82_ls_overwrite_value (210) and
// s78_ls_overwrite_value (3).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 1;
    *n1 = 11;
    v: u64 = *n1;          // 11
    free(n1);
    return v;
}
