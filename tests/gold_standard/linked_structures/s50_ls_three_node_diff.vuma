// s50_ls_three_node_diff.vuma — three nodes, diff = 130 (200 - 50 - 20)
// Expected exit code: 130
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 200/50/20 via `*ptr = literal`, load all three, subtract
// the second and third from the first -> 130. Uses `*ptr = literal`
// form (no offsets). Distinct from s46_ls_three_node_sum (180) and
// s43_ls_three_node_diff (100).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 50;
    *n3 = 20;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;        // 130
    free(n1);
    free(n2);
    free(n3);
    return d;
}
