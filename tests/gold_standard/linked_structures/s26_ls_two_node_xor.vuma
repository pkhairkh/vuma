// s26_ls_two_node_xor.vuma — two nodes, xor = 255 (0xF0 ^ 0x0F)
// Expected exit code: 255
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 240/15 via `*ptr = literal`, load both, XOR -> 255. Uses `*ptr =
// literal` form (no offsets). All operands loaded into typed locals
// before the XOR. Distinct from s22_ls_two_node_sum (37+53=90) and
// s18_ls_two_node_sum (19+61=80).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 240;           // 0xF0
    *n2 = 15;            // 0x0F
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a ^ b;       // 0xFF = 255
    free(n1);
    free(n2);
    return s;
}
