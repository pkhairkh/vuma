// s63_ls_three_node_diff.vuma — three nodes, diff = 130 (240 - 70 - 40)
// Expected exit code: 130
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 240/70/40 via `*ptr = literal`, load all three,
// 240 - 70 - 40 = 130. Uses `*ptr = literal` form (no offsets).
// Distinct from s51_ls_three_node_sum (235), s58_ls_three_node_diff
// (100) and s55_ls_three_node_diff (110).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 240;
    *n2 = 70;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    r: u64 = t - c;        // 130
    free(n1);
    free(n2);
    free(n3);
    return r;
}
