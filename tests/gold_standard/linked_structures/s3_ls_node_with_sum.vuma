// s3_ls_node_with_sum.vuma — sum value fields across 3 linked nodes
// Expected exit code: 60  (10 + 20 + 30)
//
// Three nodes laid out in a 48-byte allocation. Each holds a value
// (10, 20, 30) plus a next_offset field. The next_offset field of
// node1 points to node2 (offset 16), the next_offset field of node2
// points to node3 (offset 32). main walks the chain accumulating
// values.

fn main() -> i32 {
    block = allocate(48);
    // node1.val @ 0 = 10
    *(block + 0) = 10;
    // node1.next_offset @ 8 = 16
    *(block + 8) = 16;
    // node2.val @ 16 = 20
    *(block + 16) = 20;
    // node2.next_offset @ 24 = 32
    *(block + 24) = 32;
    // node3.val @ 32 = 30
    *(block + 32) = 30;

    v1: u64 = *(block + 0);
    off1: u64 = *(block + 8);
    v2: u64 = *(block + off1);
    off2: u64 = *(block + off1 + 8);
    v3: u64 = *(block + off2);

    s1: u64 = v1 + v2;
    s2: u64 = s1 + v3;

    free(block);
    return s2;
}
