// s93_ls_three_node_diff.vuma — three nodes, diff = 21 (250 - 200 - 29)
// Expected exit code: 21
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 250/200/29 via `*ptr = literal`, load all three,
// a - b - c -> 21. Uses `*ptr = literal` form (no offsets). Distinct
// from s90_ls_three_node_diff (26), s82_ls_three_node_diff (140) and s78_ls_three_node_diff (147).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 200;
    *n3 = 29;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 21
    free(n1);
    free(n2);
    free(n3);
    return r;
}
