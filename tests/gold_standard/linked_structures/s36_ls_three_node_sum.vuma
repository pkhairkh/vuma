// s36_ls_three_node_sum.vuma — nodes 30/60/90, sum = 180
// Expected exit code: 180
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 30/60/90 via `*ptr = literal`, load all
// three, sum -> 180. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s30_ls_three_node_sum (sum, 0) and s27_ls_three_node_sum (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 30;
    *n2 = 60;
    *n3 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;    // 180
    free(n1);
    free(n2);
    free(n3);
    return s;
}
