// s51_ls_three_node_sum.vuma — three nodes, sum = 235 (90 + 75 + 70)
// Expected exit code: 235
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 90/75/70 via `*ptr = literal`, load all three, sum -> 235.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_ls_
// three_node_diff (130) and s47_ls_three_node_diff (110).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 90;
    *n2 = 75;
    *n3 = 70;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;        // 235
    free(n1);
    free(n2);
    free(n3);
    return s;
}
