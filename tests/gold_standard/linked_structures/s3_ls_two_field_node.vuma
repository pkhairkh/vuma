// s3_ls_two_field_node.vuma — node with val field and marker field
// Expected exit code: 17
//
// Single 16-byte allocation holding two fields: a value (17) and a
// marker byte (99). main reads both fields and returns only the value
// field. Tests that adjacent fields in a node don't interfere.

fn main() -> i32 {
    node = allocate(16);
    // node.val = 17
    *(node + 0) = 17;
    // node.marker = 99
    *(node + 8) = 99;

    val: u64 = *(node + 0);
    marker: u64 = *(node + 8);
    // Confirm we read the right slot (marker is read but ignored)
    ignore: u64 = marker + 0;
    free(node);
    return val;
}
