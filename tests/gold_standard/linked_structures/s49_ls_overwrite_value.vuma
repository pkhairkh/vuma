// s49_ls_overwrite_value.vuma — overwrite node to 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as one "node". Store 25 via
// `*ptr = literal`, then overwrite with 175. Load and return 175.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_ls_
// overwrite_value (160) and s42_ls_overwrite_value (140).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 25;
    *n1 = 175;
    v: u64 = *n1;
    free(n1);
    return v;
}
