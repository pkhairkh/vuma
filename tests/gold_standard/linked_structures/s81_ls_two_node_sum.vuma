// s81_ls_two_node_sum.vuma — two nodes, sum = 175 (115 + 60)
// Expected exit code: 175
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 115/60 via `*ptr = literal`, load both, sum -> 175.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s78_ls_two_node_sum (2), s77_ls_two_node_sum (163) and
// s76_ls_two_node_sum (153).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 115;
    *n2 = 60;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 175
    free(n1);
    free(n2);
    return s;
}
