// s56_ls_three_node_diff.vuma — three nodes, diff = 120 (200-30-50)
// Expected exit code: 120
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 200/30/50 via `*ptr = literal`, load all three, diff -> 120.
// Uses `*ptr = literal` form (no offsets). Distinct from s54_ls_three_
// node_diff (180) and s50_ls_three_node_diff (130).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 30;
    *n3 = 50;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;        // 120
    free(n1);
    free(n2);
    free(n3);
    return d;
}
