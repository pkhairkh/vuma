// s52_ls_overwrite_value.vuma — store 80, overwrite to 220, load = 220
// Expected exit code: 220
//
// Single 8-byte allocation treated as a one-field "node". Store 80
// via `*p = literal`, then overwrite the value with 220. Load and
// return 220. Uses `*p = literal` form. Distinct from
// s50_ls_overwrite_value (185) and s46_ls_overwrite_value (180).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 80;
    *n1 = 220;
    v: u64 = *n1;          // 220
    free(n1);
    return v;
}
