// s67_ls_overwrite_middle.vuma — overwrite n2 to 215, load = 215
// Expected exit code: 215
//
// Three 8-byte allocations treated as three "nodes". Store
// 100/50/80 then overwrite n2 to 215 via `*ptr = literal`.
// Load n2 -> 215 (the overwritten value). Uses `*ptr =
// literal` form. Distinct from s66_ls_overwrite_value (230),
// s62_ls_overwrite_value (175) and s58_ls_overwrite_value
// (180).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 100;
    *n2 = 50;
    *n3 = 80;
    *n2 = 215;
    v: u64 = *n2;          // 215
    free(n1);
    free(n2);
    free(n3);
    return v;
}
