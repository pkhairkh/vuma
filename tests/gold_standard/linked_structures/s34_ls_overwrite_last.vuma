// s34_ls_overwrite_last.vuma — overwrite last node to 150, sum with 40 = 190
// Expected exit code: 190
//
// Two 8-byte allocations treated as two nodes. Store 40 in n1;
// store 60 then overwrite to 150 in n2; load both, sum -> 190.
// Uses `*ptr = literal` form (no offsets). Distinct from s30_ls_
// overwrite_last (different values) and s27_ls_overwrite_last.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 40;
    *n2 = 60;
    *n2 = 150;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
