// s29_ls_three_node_sum.vuma — three nodes, sum = 135 (35 + 45 + 55)
// Expected exit code: 135
//
// Three 8-byte allocations treated as three independent "nodes". Store 35/45/55 via `*ptr = literal`, load all three, sum -> 135. Uses `*ptr = literal` form (no offsets). Distinct from s26_ls_three_node_sum (30+40+50=120) and s22_ls_two_node_sum (37+53=90).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 35;
    *n2 = 45;
    *n3 = 55;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
