// s102_ls_overwrite_value.vuma — overwrite n1 to 1, load = 1
// Expected exit code: 1
//
// Single 8-byte "node". Store 5, then overwrite to 1, load -> 1 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_ls_overwrite_value (41), s101_ls_three_node_sum (150), s101_ls_two_node_sum (205).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 1;
    v: u64 = *n1;          // 1
    free(n1);
    return v;
}
