// s74_ls_overwrite_value.vuma — overwrite node to 149, load = 149
// Expected exit code: 149
//
// Single 8-byte allocation treated as one "node". Store 100 then
// 149 via `*ptr = literal` (overwrite), load and return 149.
// Uses `*ptr = literal` form (no offsets). Distinct from s70_ls_
// overwrite_value (210), s66_ls_overwrite_value (220) and s62_ls_
// overwrite_value (230).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 100;
    *n1 = 149;
    a: u64 = *n1;          // 149
    free(n1);
    return a;
}
