// s83_ls_three_node_diff.vuma — three nodes, diff = 196 (240 - 30 - 14)
// Expected exit code: 196
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 240/30/14 via `*ptr = literal`, load all three,
// a - b - c -> 196. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ls_three_node_diff (147), s74_ls_three_node_
// diff (40) and s72_ls_three_node_diff (20).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 240;
    *n2 = 30;
    *n3 = 14;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 196
    free(n1);
    free(n2);
    free(n3);
    return r;
}
