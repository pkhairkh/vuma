// s84_ls_three_node_diff.vuma — three nodes, diff = 20 (30 - 6 - 4)
// Expected exit code: 20
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 30/6/4 via `*ptr = literal`, load all three,
// a - b - c -> 20. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_ls_three_node_diff (140), s78_ls_three_node_
// diff (147) and s74_ls_three_node_diff (34).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 30;
    *n2 = 6;
    *n3 = 4;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 20
    free(n1);
    free(n2);
    free(n3);
    return r;
}
