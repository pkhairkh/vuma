// s79_ls_two_node_sum.vuma — two nodes, sum = 13 (5 + 8)
// Expected exit code: 13
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 5/8 via `*ptr = literal`, load both, sum -> 13. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s78_ls_two_node_sum (2), s77_ls_two_node_sum (3) and
// s76_ls_two_node_sum (2).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 5;
    *n2 = 8;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 13
    free(n1);
    free(n2);
    return s;
}
