// s64_ls_two_node_diff.vuma — two nodes, diff = 135 (230 - 95)
// Expected exit code: 135
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 230/95 via `*ptr = literal`, load both, diff -> 135. Uses
// `*ptr = literal` form (no offsets). Distinct from s62_ls_overwrite_
// value (175), s62_ls_three_node_diff (120) and s62_ls_two_node_sum
// (225).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 230;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 135
    free(n1);
    free(n2);
    return d;
}
