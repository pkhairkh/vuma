// s47_ls_two_node_sum.vuma — two nodes, sum = 225 (130 + 95)
// Expected exit code: 225
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 130/95 via `*ptr = literal`, load both, sum -> 225. Uses
// `*ptr = literal` form (no offsets). Distinct from s46_ls_two_
// node_diff (120) and s42_ls_two_node_sum (200).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 130;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
