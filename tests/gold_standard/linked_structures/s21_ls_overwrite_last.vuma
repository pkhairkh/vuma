// s21_ls_overwrite_last.vuma — two nodes, overwrite last, sum = 102 (12 + 90)
// Expected exit code: 102
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 12/65 in n1/n2, then overwrite n2 with 90. Load both, sum -> 102.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s18_ls_overwrite_first (overwrites FIRST node, 90/50 = 140) and
// s14_ls_overwrite_first (80/40 = 120).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 12;
    *n2 = 65;
    *n2 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
