// s74_ls_three_node_diff.vuma — three nodes, diff = 34 (200 - 100 - 66)
// Expected exit code: 34
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 200/100/66 via `*ptr = literal`, load all three, diff
// -> 34. Uses `*ptr = literal` form (no offsets). Distinct from
// s70_ls_three_node_diff (150), s66_ls_three_node_diff (115) and
// s62_ls_three_node_sum (195).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 100;
    *n3 = 66;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 100
    r: u64 = t - c;        // 34
    free(n1);
    free(n2);
    free(n3);
    return r;
}
