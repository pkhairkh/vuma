// s39_ls_overwrite_middle.vuma — overwrite middle node to 90, sum = 180 (40 + 90 + 50)
// Expected exit code: 180
//
// Three 8-byte allocations treated as three nodes. Store 40/60/50
// via `*ptr = literal`, then overwrite the middle node with 90.
// Load all three, sum -> 180. Uses `*ptr = literal` form (no
// offsets). Distinct from s38_ls_overwrite_first (165) and s34_ls_
// overwrite_last (190).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 40;
    *n2 = 60;
    *n3 = 50;
    *n2 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
