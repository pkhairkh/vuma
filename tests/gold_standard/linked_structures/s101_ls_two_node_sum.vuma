// s101_ls_two_node_sum.vuma — two nodes, sum = 205 (130 + 75)
// Expected exit code: 205
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 130/75 via `*ptr = literal`, load both, a + b -> 205. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s98_ls_two_node_sum (53), s97_ls_two_node_sum (37) and
// s94_ls_two_node_sum (145).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 130;
    *n2 = 75;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 205
    free(n1);
    free(n2);
    return s;
}
