// s72_ls_overwrite_value.vuma — overwrite node to 170, load = 170
// Expected exit code: 170
//
// Single 8-byte allocation treated as one "node". Store 55 then
// 170 via `*ptr = literal` (overwrite), load and return 170.
// Uses `*ptr = literal` form. Distinct from s70_ls_overwrite_
// value (210), s69_ls_overwrite_value (105) and s66_ls_overwrite_
// high (230).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 55;
    *n1 = 170;
    v: u64 = *n1;          // 170
    free(n1);
    return v;
}
