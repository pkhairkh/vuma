// s40_ls_two_node_sum.vuma — two nodes, sum = 200 (115 + 85)
// Expected exit code: 200
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 115/85 via `*ptr = literal`, load both, sum -> 200. Uses
// `*ptr = literal` form (no offsets). Distinct from s38_ls_two_
// node_sum (175) and s34_ls_two_node_sum (125).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 115;
    *n2 = 85;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 200
    free(n1);
    free(n2);
    return s;
}
