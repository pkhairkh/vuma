// s12_ls_two_node_diff.vuma — two nodes, diff = 40 (70 - 30)
// Expected exit code: 40
//
// Two independent 8-byte allocations treated as two "nodes". Store
// 70/30 via `*ptr = literal`, load both, compute the difference
// (a - b) -> 40. Distinct from s9_ls_two_node_sum (sum, not diff)
// and s7_ls_two_blocks_sum (sum, not diff).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 70;
    *n2 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;       // 40
    free(n1);
    free(n2);
    return d;
}
