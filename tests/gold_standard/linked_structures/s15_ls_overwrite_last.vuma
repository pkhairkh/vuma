// s15_ls_overwrite_last.vuma — two nodes, overwrite last, sum = 100 (20 + 80)
// Expected exit code: 100
//
// Two 8-byte allocations treated as two independent "nodes". Store 20/40
// in n1/n2, then overwrite n2 (the last node) with 80. Load both, sum ->
// 100. Uses `*ptr = literal` form (no offsets). Distinct from
// s14_ls_overwrite_first (overwrites the first node, 80/40 = 120) and
// s10_ls_overwrite_last (overwrites last, different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 20;
    *n2 = 40;
    *n2 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
