// ls_node_create.vuma — create single node, store val=42, load, return
// Expected exit code: 42
//
// Simplest linked-structure test: allocate a 16-byte node, store 42 at
// offset 0 (the value field), load it back, and return it. Tests the
// basic create-store-load-free cycle for a single node. All stored
// values are ≤ 255 to avoid the known U8 truncation bug.

fn main() -> i32 {
    node = allocate(16);
    *(node + 0) = 42;
    val: u64 = *(node + 0);
    free(node);
    return val;
}
