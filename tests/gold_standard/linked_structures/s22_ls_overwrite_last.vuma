// s22_ls_overwrite_last.vuma — overwrite last node, sum = 95 (22 + 73)
// Expected exit code: 95
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 22/45 via `*ptr = literal`, then overwrite the last node with 73.
// Load both, sum -> 95. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_ls_overwrite_first (overwrites the first node) and
// s14_ls_overwrite_first (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 22;
    *n2 = 45;
    *n2 = 73;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
