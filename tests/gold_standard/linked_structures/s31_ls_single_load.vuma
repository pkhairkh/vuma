// s31_ls_single_load.vuma — store 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as a one-"node" structure. Store 175
// via `*ptr = literal`, load and return 175. Uses `*ptr = literal` form
// (no offsets). Distinct from s30_ls_two_node_sum (sum, 110) and
// s28_ls_single_load (different value).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 175;
    a: u64 = *n1;
    free(n1);
    return a;
}
