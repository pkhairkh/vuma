// s23_ls_overwrite_middle.vuma — overwrite middle node, sum = 156 (14 + 100 + 42)
// Expected exit code: 156
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 14/28/42, then overwrite the middle node (n2) with 100. Load all
// three, sum -> 156. Uses `*ptr = literal` form (no offsets). Distinct
// from s22_ls_overwrite_last (overwrites the last node) and s24_ls_overwrite_first
// (overwrites the first node).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 14;
    *n2 = 28;
    *n3 = 42;
    *n2 = 100;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;       // 156
    free(n1);
    free(n2);
    free(n3);
    return s;
}

