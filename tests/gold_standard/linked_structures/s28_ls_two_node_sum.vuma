// s28_ls_two_node_sum.vuma — two nodes, sum = 150 (70 + 80)
// Expected exit code: 150
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 70/80 via `*ptr = literal`, load both, sum -> 150. Uses `*ptr =
// literal` form (no offsets). All operands loaded into typed locals
// before the add. Distinct from s26_ls_two_node_xor (xor, 255) and
// s22_ls_two_node_sum (sum, 90).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 70;
    *n2 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;       // 150
    free(n1);
    free(n2);
    return s;
}
