// s78_ls_three_node_diff.vuma — three nodes, diff = 147 (150 - 1 - 2)
// Expected exit code: 147
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 150/1/2 via `*ptr = literal`, load all three,
// a - b - c -> 147. Uses `*ptr = literal` form (no offsets).
// Distinct from s74_ls_three_node_diff (40), s73_ls_three_node_diff
// (60) and s72_ls_three_node_diff (20).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 150;
    *n2 = 1;
    *n3 = 2;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 147
    free(n1);
    free(n2);
    free(n3);
    return r;
}
