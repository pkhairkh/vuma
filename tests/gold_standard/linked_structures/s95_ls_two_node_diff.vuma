// s95_ls_two_node_diff.vuma — two nodes, diff = 57 (90 - 33)
// Expected exit code: 57
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 90/33 via `*ptr = literal`, load both, a - b -> 57. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s94_ls_two_node_sum (145), s90_ls_two_node_diff (24) and
// s82_ls_two_node_sum (180).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 90;
    *n2 = 33;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 57
    free(n1);
    free(n2);
    return d;
}
