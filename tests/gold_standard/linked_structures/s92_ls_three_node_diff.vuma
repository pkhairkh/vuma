// s92_ls_three_node_diff.vuma — three nodes, diff = 38 (250 - 190 - 22)
// Expected exit code: 38
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 250/190/22 via `*ptr = literal`, load all three,
// a - b - c -> 38. Uses `*ptr = literal` form (no offsets). Distinct
// from s90_ls_three_node_diff (26), s86_ls_three_node_diff (60) and
// s82_ls_three_node_diff (110).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 190;
    *n3 = 22;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 38
    free(n1);
    free(n2);
    free(n3);
    return r;
}
