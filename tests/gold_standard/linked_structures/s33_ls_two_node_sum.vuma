// s33_ls_two_node_sum.vuma — two nodes, sum = 50 + 95 = 145
// Expected exit code: 145
//
// Deterministic test in the linked_structures category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_ls_two_node_sum (45+65=110) and s26_ls_two_node_xor (xor, 255).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 50;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;         // 145
    free(n1);
    free(n2);
    return s;
}
