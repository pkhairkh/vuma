// s75_ls_two_node_diff.vuma — two nodes, diff = 85 (200 - 115)
// Expected exit code: 85
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 200/115 via `*ptr = literal`, load both, diff -> 85.
// Uses `*ptr = literal` form (no offsets). Distinct from s74_ls_
// two_node_sum (213), s70_ls_two_node_sum (90) and s66_ls_two_
// node_diff (125).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 115;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a - b;        // 85
    free(n1);
    free(n2);
    return s;
}
