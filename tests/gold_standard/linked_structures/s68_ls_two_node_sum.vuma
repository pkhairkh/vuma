// s68_ls_two_node_sum.vuma — two nodes, sum = 245 (140 + 105)
// Expected exit code: 245
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 140/105 via `*ptr = literal`, load both, sum -> 245.
// Uses `*ptr = literal` form (no offsets). Distinct from s66_ls_
// two_node_diff (125), s62_ls_two_node_sum (225) and s58_ls_two_
// node_sum (220).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 140;
    *n2 = 105;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 245
    free(n1);
    free(n2);
    return s;
}
