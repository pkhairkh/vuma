// s82_ls_two_node_sum.vuma — two nodes, sum = 180 (95 + 85)
// Expected exit code: 180
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 95/85 via `*ptr = literal`, load both, sum -> 180.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s78_ls_two_node_sum (2), s74_ls_two_node_sum (130) and
// s72_ls_two_node_sum (225).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 95;
    *n2 = 85;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 180
    free(n1);
    free(n2);
    return s;
}
