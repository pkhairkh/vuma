// s65_ls_three_node_sum.vuma — three nodes, sum = 160 (50 + 55 + 55)
// Expected exit code: 160
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 50/55/55 via `*ptr = literal`, load all three, sum -> 160.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_ls_
// three_node_sum (235), s58_ls_three_node_diff (100), s62_ls_three_
// node_diff (120) and s64_ls_two_node_diff (135).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 50;
    *n2 = 55;
    *n3 = 55;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;        // 160
    free(n1);
    free(n2);
    free(n3);
    return s;
}
