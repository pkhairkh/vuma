// s3_ls_independent_allocs.vuma — 4 separate allocs, store and sum
// Expected exit code: 200  (40 + 50 + 60 + 50)
//
// Allocates four separate 8-byte nodes (no links between them), stores
// a distinct value in each, loads each back and returns the sum.
// Verifies independent allocations don't alias each other.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    n4 = allocate(8);
    *(n1 + 0) = 40;
    *(n2 + 0) = 50;
    *(n3 + 0) = 60;
    *(n4 + 0) = 50;

    a: u64 = *(n1 + 0);
    b: u64 = *(n2 + 0);
    c: u64 = *(n3 + 0);
    d: u64 = *(n4 + 0);
    s1: u64 = a + b;
    s2: u64 = s1 + c;
    s3: u64 = s2 + d;

    free(n1);
    free(n2);
    free(n3);
    free(n4);
    return s3;
}
