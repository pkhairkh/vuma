// s10_ls_four_node_chain.vuma — 4 nodes, sum = 100 (10 + 20 + 30 + 40)
// Expected exit code (correct): 100
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// 32-byte allocation treated as four 8-byte "nodes" at offsets
// 0/8/16/24. Stores 10/20/30/40, loads all four, sums, returns 100.
// Distinct from s5_ls_four_node_chain (different values 5/15/25/35)
// and s6_ls_three_node_chain (3 nodes).

fn main() -> i32 {
    block = allocate(32);
    *(block + 0) = 10;
    *(block + 8) = 20;
    *(block + 16) = 30;
    *(block + 24) = 40;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    d: u64 = *(block + 24);
    t1: u64 = a + b;
    t2: u64 = t1 + c;
    s: u64 = t2 + d;
    free(block);
    return s;
}
