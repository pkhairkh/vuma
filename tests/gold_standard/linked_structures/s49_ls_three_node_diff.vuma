// s49_ls_three_node_diff.vuma — three nodes, diff = 110 (180 - 40 - 30)
// Expected exit code: 110
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 180/40/30 via `*ptr = literal`, load all, subtract -> 110.
// 180 - 40 = 140; 140 - 30 = 110. Uses `*ptr = literal` form (no
// offsets). Distinct from s46_ls_three_node_sum (180, sum) and s42_
// ls_three_node_diff (120, diff).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 180;
    *n2 = 40;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;        // 110
    free(n1);
    free(n2);
    free(n3);
    return d;
}
