// s48_ls_overwrite_value.vuma — store 50, overwrite 190, load = 190
// Expected exit code: 190
//
// Single 8-byte allocation treated as one "node". Store 50 via
// `*ptr = literal`, then overwrite with 190. Load and return 190.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_ls_
// overwrite_value and s42_ls_overwrite_last.

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 190;
    a: u64 = *n1;
    free(n1);
    return a;
}
