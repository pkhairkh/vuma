// s96_ls_overwrite_value.vuma — overwrite n1 to 188, load = 188
// Expected exit code: 188
//
// Single 8-byte "node". Store 1 via `*ptr = literal`, then overwrite
// to 188. Load -> 188 (the overwritten value). Uses `*ptr = literal`
// form. Distinct from s94_ls_overwrite_value (73),
// s90_ls_overwrite_value (32) and s86_ls_overwrite_value (225).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 1;
    *n1 = 188;
    v: u64 = *n1;          // 188
    free(n1);
    return v;
}
