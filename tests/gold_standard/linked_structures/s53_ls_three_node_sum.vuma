// s53_ls_three_node_sum.vuma — three nodes, sum = 195 (65 + 85 + 45)
// Expected exit code: 195
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 65/85/45 via `*ptr = literal`, load all three, sum -> 195.
// Uses `*ptr = literal` form (no offsets). Distinct from s49_ls_
// two_node_sum (200) and s50_ls_two_node_sum (255).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 65;
    *n2 = 85;
    *n3 = 45;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;        // 195
    free(n1);
    free(n2);
    free(n3);
    return s;
}
