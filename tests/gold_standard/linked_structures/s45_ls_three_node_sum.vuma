// s45_ls_three_node_sum.vuma — three nodes, sum = 180 (70 + 80 + 30)
// Expected exit code: 180
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 70/80/30 via `*ptr = literal`, load all, sum -> 180.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_ls_
// three_node_diff (diff, 120) and s38_ls_three_node_sum (sum, 185).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 70;
    *n2 = 80;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
