// s21_ls_single_load.vuma — single 8-byte node, load = 53
// Expected exit code: 53
//
// 8-byte allocation treated as a single "node". Store 53 via
// `*p = 53`, load it back, return 53. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s18_ls_single_load (value 42) and s14_ls_single_load (value 27).

fn main() -> i32 {
    node = allocate(8);
    *node = 53;
    v: u64 = *node;
    free(node);
    return v;
}
