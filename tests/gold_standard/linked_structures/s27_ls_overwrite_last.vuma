// s27_ls_overwrite_last.vuma — overwrite last node, sum = 220 (5 + 15 + 200)
// Expected exit code: 220
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 5/15/25, then overwrite the last node with 200. Load all three, sum
// -> 220. Uses `*ptr = literal` form (no offsets). Distinct from
// s26_ls_overwrite_first (overwrites the first node) and
// s22_ls_overwrite_last (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 5;
    *n2 = 15;
    *n3 = 25;
    *n3 = 200;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;   // 220
    free(n1);
    free(n2);
    free(n3);
    return s;
}
