// s72_ls_three_node_diff.vuma — three nodes, diff = 205 (250 - 30 - 15)
// Expected exit code: 205
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 250/30/15 via `*ptr = literal`, load all
// three, diff -> 250 - 30 - 15 = 205. Uses `*ptr = literal`
// form (no offsets). Distinct from s70_ls_three_node_diff (150),
// s69_ls_three_node_diff (185) and s66_ls_three_node_diff (90).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 30;
    *n3 = 15;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 220
    d: u64 = t - c;        // 205
    free(n1);
    free(n2);
    free(n3);
    return d;
}
