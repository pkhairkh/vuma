// s35_ls_overwrite_value.vuma — overwrite last node to 140, sum with 50 = 190
// Expected exit code: 190
//
// Two 8-byte allocations treated as two nodes. Store 50 in n1;
// store 80 then overwrite to 140 in n2; load both, sum -> 190.
// Uses `*ptr = literal` form (no offsets). Distinct from s34_ls_
// overwrite_last (150+40 = 190, different operands) and s30_ls_
// overwrite_last (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 50;
    *n2 = 80;
    *n2 = 140;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 190
    free(n1);
    free(n2);
    return s;
}
