// s88_ls_three_node_diff.vuma — three nodes, diff = 145 (245 - 80 - 20)
// Expected exit code: 145
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 245/80/20 via `*ptr = literal`, load all
// three, a - b - c -> 145. Uses `*ptr = literal` form (no
// offsets). Distinct from s86_ls_three_node_diff (130),
// s82_ls_three_node_diff (140) and s78_ls_three_node_diff
// (147).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 245;
    *n2 = 80;
    *n3 = 20;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 145
    free(n1);
    free(n2);
    free(n3);
    return r;
}
