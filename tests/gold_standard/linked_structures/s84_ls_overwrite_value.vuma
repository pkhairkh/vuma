// s84_ls_overwrite_value.vuma — store 5, overwrite with 28, load = 28
// Expected exit code: 28
//
// Single 8-byte allocation treated as a "node". Store 5 via
// `*ptr = literal`, overwrite with 28 via `*ptr = literal`,
// load and return 28. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_ls_overwrite_value (215), s78_ls_overwrite_
// value (3) and s74_ls_overwrite_value (149).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 28;
    r: u64 = *n1;          // 28
    free(n1);
    return r;
}
