// s56_ls_two_node_sum.vuma — two nodes, sum = 255 (95 + 160)
// Expected exit code: 255
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 95/160 via `*ptr = literal`, load both, sum -> 255. Uses
// `*ptr = literal` form (no offsets). Distinct from s54_ls_two_node_
// sum (255) and s50_ls_two_node_sum (255).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 95;
    *n2 = 160;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 255
    free(n1);
    free(n2);
    return s;
}
