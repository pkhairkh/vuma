// s69_ls_two_node_sum.vuma -- two nodes, sum = 145 (65 + 80)
// Expected exit code: 145
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 65/80 via `*ptr = literal`, load both, sum -> 145. Uses `*ptr =
// literal` form (no offsets). Distinct from s66_ls_two_node_diff
// (125), s65_ls_two_node_diff (140) and s64_ls_two_node_sum (195).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 65;
    *n2 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 145
    free(n1);
    free(n2);
    return s;
}
