// s98_ls_overwrite_value.vuma — overwrite n1 to 55, load = 55
// Expected exit code: 55
//
// Single 8-byte allocation treated as a "node". Store 5 via
// `*ptr = literal`, then overwrite to 55, load -> 55 (the
// overwritten value). Uses `*ptr = literal` form. Distinct from
// s94_ls_overwrite_value (73), s90_ls_overwrite_value (32) and
// s86_ls_overwrite_value (225).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 55;
    v: u64 = *n1;          // 55
    free(n1);
    return v;
}
