// s20_ls_three_node_diff.vuma — three nodes, 200 - 60 - 40 = 100
// Expected exit code: 100
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 200/60/40 via `*ptr = literal`, load all three, subtract sequentially
// -> 100. Uses `*ptr = literal` form. Distinct from s18_ls_single_load
// (single node) and s14_ls_three_node_sum (three-node sum).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 60;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;   // 100
    free(n1);
    free(n2);
    free(n3);
    return r;
}
