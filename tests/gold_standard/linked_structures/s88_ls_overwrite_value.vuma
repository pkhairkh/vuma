// s88_ls_overwrite_value.vuma — store 25, overwrite with 205, load = 205
// Expected exit code: 205
//
// Single 8-byte allocation treated as a "node". Store 25
// via `*ptr = literal`, overwrite with 205 via `*ptr =
// literal`, load and return 205. Uses `*ptr = literal` form
// (no offsets). Distinct from s86_ls_overwrite_value (225),
// s82_ls_overwrite_value (215) and s78_ls_overwrite_value
// (3).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 25;
    *n1 = 205;
    r: u64 = *n1;          // 205
    free(n1);
    return r;
}
