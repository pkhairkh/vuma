// s55_ls_three_node_diff.vuma — three nodes, diff = 115 (240-70-55)
// Expected exit code: 115
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 240/70/55 via `*ptr = literal`, load all three, subtract
// sequentially -> 115. Uses `*ptr = literal` form (no offsets).
// Distinct from s54_ls_three_node_diff (100) and s53_ls_two_node_
// diff (145).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 240;
    *n2 = 70;
    *n3 = 55;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    s: u64 = t - c;        // 115
    free(n1);
    free(n2);
    free(n3);
    return s;
}
