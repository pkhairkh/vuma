// s76_ls_two_node_sum.vuma — two nodes, sum = 153 (101 + 52)
// Expected exit code: 153
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 101/52 via `*ptr = literal`, load both, sum -> 153.
// Uses `*ptr = literal` form (no offsets). Distinct from s74_ls_
// two_node_sum (213), s73_ls_two_node_sum (114) and s72_ls_two_
// node_sum (155).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 101;
    *n2 = 52;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 153
    free(n1);
    free(n2);
    return s;
}
