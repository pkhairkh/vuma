// s30_ls_overwrite_middle.vuma — overwrite middle node, sum = 80 (5+50+25)
// Expected exit code: 80
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 5/15/25, then overwrite the middle node with 50. Load all three, sum
// -> 80. Uses `*ptr = literal` form (no offsets). Distinct from
// s26_ls_overwrite_first (overwrites the first node, 150) and
// s22_ls_overwrite_last (overwrites the last node).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 5;
    *n2 = 15;
    *n3 = 25;
    *n2 = 50;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
