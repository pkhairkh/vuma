// s38_ls_two_node_sum.vuma — two nodes, sum = 175 (80 + 95)
// Expected exit code: 175
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 80/95 via `*ptr = literal`, load both, sum -> 175. Uses
// `*ptr = literal` form (no offsets). Distinct from s34_ls_two_
// node_sum (125) and s30_ls_two_node_sum.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 80;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
