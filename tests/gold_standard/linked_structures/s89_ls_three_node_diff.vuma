// s89_ls_three_node_diff.vuma — three nodes, diff = 10 (70 - 40 - 20)
// Expected exit code: 10
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 70/40/20 via `*ptr = literal`, load all three,
// a - b - d -> 10. Uses `*ptr = literal` form. Distinct from
// s86_ls_three_node_diff (175), s82_ls_three_node_diff (215) and
// s78_ls_three_node_diff (155).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 70;
    *n2 = 40;
    *n3 = 20;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = *n3;
    r: u64 = a - b - d;    // 10
    free(n1);
    free(n2);
    free(n3);
    return r;
}
