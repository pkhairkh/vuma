// s70_ls_overwrite_value.vuma — overwrite node to 210, load = 210
// Expected exit code: 210
//
// Single 8-byte allocation treated as one "node". Store 50 then
// 210 via `*ptr = literal` (overwrite), load and return 210.
// Uses `*ptr = literal` form. Distinct from s66_ls_overwrite_
// value (230), s65_ls_overwrite_value (165) and s62_ls_overwrite_
// value (175).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 210;
    v: u64 = *n1;          // 210
    free(n1);
    return v;
}
