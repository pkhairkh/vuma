// s5_ls_four_node_chain.vuma — four 8-byte nodes, sum = 100
// Expected exit code: 100  (10 + 20 + 30 + 40)
//
// 32-byte allocation treated as four 8-byte "nodes" at offsets
// 0, 8, 16, 24. Stores 10/20/30/40, loads all four, sums, returns
// 100. Distinct from s4_ls_three_nodes (3 nodes) and
// s3_ls_four_node_chain (different values).

fn main() -> i32 {
    block = allocate(32);
    *(block + 0) = 10;
    *(block + 8) = 20;
    *(block + 16) = 30;
    *(block + 24) = 40;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    d: u64 = *(block + 24);
    t1: u64 = a + b;
    t2: u64 = c + d;
    s: u64 = t1 + t2;
    free(block);
    return s;
}
