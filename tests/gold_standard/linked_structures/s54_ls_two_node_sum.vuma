// s54_ls_two_node_sum.vuma — two nodes, sum = 255 (115 + 140)
// Expected exit code: 255
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 115/140 via `*ptr = literal`, load both, sum -> 255. Uses
// `*ptr = literal` form (no offsets). Distinct from s50_ls_two_
// node_sum (255) and s49_ls_two_node_sum (230).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 115;
    *n2 = 140;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 255
    free(n1);
    free(n2);
    return s;
}
