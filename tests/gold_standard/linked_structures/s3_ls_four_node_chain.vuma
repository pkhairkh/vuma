// s3_ls_four_node_chain.vuma — 4 nodes inside one allocation, sum values
// Expected exit code: 100  (10 + 20 + 30 + 40)
//
// Four independent nodes laid out in a single 32-byte allocation, each
// holding an 8-byte value. Stores 10, 20, 30, 40 in successive nodes,
// loads each back and returns their sum. All stored values are <= 255.

fn main() -> i32 {
    block = allocate(32);
    // node1.val = 10
    *(block + 0) = 10;
    // node2.val = 20
    *(block + 8) = 20;
    // node3.val = 30
    *(block + 16) = 30;
    // node4.val = 40
    *(block + 24) = 40;

    v1: u64 = *(block + 0);
    v2: u64 = *(block + 8);
    v3: u64 = *(block + 16);
    v4: u64 = *(block + 24);
    s1: u64 = v1 + v2;
    s2: u64 = s1 + v3;
    s3: u64 = s2 + v4;

    free(block);
    return s3;
}
