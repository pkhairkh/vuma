// s91_ls_overwrite_value.vuma — overwrite n1 to 33, load = 33
// Expected exit code: 33
//
// Single 8-byte "node". Store 5, then overwrite to 33, load -> 33
// (the overwritten value). Uses `*ptr = literal` form. Distinct
// from s90_ls_overwrite_value (32), s86_ls_overwrite_value (245)
// and s82_ls_overwrite_value (242).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 33;
    v: u64 = *n1;          // 33
    free(n1);
    return v;
}
