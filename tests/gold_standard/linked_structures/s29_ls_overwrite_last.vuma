// s29_ls_overwrite_last.vuma — overwrite last node, sum = 130 (20 + 30 + 80)
// Expected exit code: 130
//
// Three 8-byte allocations treated as three independent "nodes". Store 20/30/40, then overwrite the last node with 80. Load all three, sum -> 130. Uses `*ptr = literal` form (no offsets). Distinct from s26_ls_overwrite_first (overwrites the first node, 150) and s22_ls_overwrite_last (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 20;
    *n2 = 30;
    *n3 = 40;
    *n3 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
