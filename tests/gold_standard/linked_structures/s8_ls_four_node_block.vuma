// s8_ls_four_node_block.vuma — four 8-byte nodes, sum = 80 (5 + 15 + 25 + 35)
// Expected exit code: 80
//
// 32-byte allocation treated as four 8-byte "nodes" at offsets
// 0/8/16/24. Stores 5/15/25/35, loads all four, sums, returns 80.
// Distinct from s5_ls_four_node_chain (different values).

fn main() -> i32 {
    block = allocate(32);
    *(block + 0) = 5;
    *(block + 8) = 15;
    *(block + 16) = 25;
    *(block + 24) = 35;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    d: u64 = *(block + 24);
    s: u64 = a + b + c + d;
    free(block);
    return s;
}
