// s69_ls_overwrite_value.vuma -- overwrite node to 105, load = 105
// Expected exit code: 105
//
// Single 8-byte allocation treated as a one-field "node". Store 60
// then 105 via `*ptr = literal` (overwrite), load and return 105.
// Uses `*ptr = literal` form (no offsets). Distinct from s66_ls_
// overwrite_value (230), s65_ls_overwrite_value (165) and s64_ls_
// overwrite_value (235).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 60;
    *n1 = 105;
    v: u64 = *n1;          // 105
    free(n1);
    return v;
}
