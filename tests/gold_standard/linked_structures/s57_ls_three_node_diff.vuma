// s57_ls_three_node_diff.vuma — three nodes, diff = 110 (220 - 80 - 30)
// Expected exit code: 110
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 220/80/30 via `*ptr = literal`, load each, subtract
// sequentially -> 110. Uses `*ptr = literal` form (no offsets).
// Distinct from s54_ls_three_node_diff (100) and s50_ls_three_node_
// diff (90).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 220;
    *n2 = 80;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a - b;        // 140
    r: u64 = s - c;        // 110
    free(n1);
    free(n2);
    free(n3);
    return r;
}
