// s89_ls_two_node_sum.vuma — two nodes, sum = 9 (5 + 4)
// Expected exit code: 9
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 5/4 via `*ptr = literal`, load both, sum -> 9.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s86_ls_two_node_sum (185), s82_ls_two_node_sum (180) and
// s78_ls_two_node_sum (2).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 5;
    *n2 = 4;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 9
    free(n1);
    free(n2);
    return s;
}
