// s87_ls_three_node_diff.vuma — three nodes, diff = 125 (235 - 80 - 30)
// Expected exit code: 125
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 235/80/30 via `*ptr = literal`, load all three,
// a - b - c -> 125. Uses `*ptr = literal` form (no offsets).
// Distinct from s86_ls_three_node_diff (130), s82_ls_three_node_
// diff (140) and s78_ls_three_node_diff (147).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 235;
    *n2 = 80;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 125
    free(n1);
    free(n2);
    free(n3);
    return r;
}
