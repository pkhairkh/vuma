// s99_ls_two_node_sum.vuma — two nodes, sum = 126 (80 + 46)
// Expected exit code: 126
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 80/46 via `*ptr = literal`, load both, a + b -> 126. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s95_ls_two_node_diff (57), s91_ls_two_node_diff (23) and
// s87_ls_two_node_sum (170).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 80;
    *n2 = 46;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 126
    free(n1);
    free(n2);
    return s;
}
