// s105_ls_three_node_diff.vuma — store 210, 12, 5 in 3 nodes, 210-12-5 = 193
// Expected exit code: 193
// 
// Three 8-byte "nodes". Store 210, 12, 5; load each, return 210 - 12 - 5 = 193. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_three_node_sum (5), s101_ls_three_node_sum (150), s100_ls_three_node_sum (58).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 210;
    *n2 = 12;
    *n3 = 5;
    a: u64 = *n1;          // 210
    b: u64 = *n2;          // 12
    c: u64 = *n3;          // 5
    d: u64 = a - b - c;    // 193
    free(n1);
    free(n2);
    free(n3);
    return d;
}
