// s19_ls_three_node_sum.vuma — three nodes, sum = 49 (7 + 14 + 28)
// Expected exit code: 49
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 7/14/28 (doubling) via `*ptr = literal`, load all, sum -> 49.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s18_ls_two_node_sum (two nodes) and s14_ls_three_node_sum
// (11/22/33 = 66).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 7;
    *n2 = 14;
    *n3 = 28;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
