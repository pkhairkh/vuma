// s14_ls_overwrite_first.vuma — two nodes, overwrite first, sum = 120 (80 + 40)
// Expected exit code: 120
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 10/40 in n1/n2, then overwrite n1 with 80. Load both, sum ->
// 120. Uses `*ptr = literal` form (no offsets). Distinct from
// s9_ls_two_node_sum (no overwrite, values 15/25 = 40) and
// s9_ls_overwrite_node (single-node overwrite).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 10;
    *n2 = 40;
    *n1 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
