// s20_ls_two_node_sum.vuma — two nodes, sum = 90 (37 + 53)
// Expected exit code: 90
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 37/53 via `*ptr = literal`, load both, sum -> 90. Uses `*ptr =
// literal` form (no offsets). Distinct from s18_ls_two_node_sum
// (19+61=80) and s14_ls_three_node_sum (three nodes).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 37;
    *n2 = 53;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
