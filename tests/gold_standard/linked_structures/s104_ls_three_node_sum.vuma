// s104_ls_three_node_sum.vuma — store 11+22+28 in 3 nodes, load and sum = 61
// Expected exit code: 61
//
// Three 8-byte "nodes". Store 11, 22, 28; load each and return the sum (61). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_overwrite_value (1), s102_ls_three_node_sum (5), s102_ls_two_node_sum (4).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 11;
    *n2 = 22;
    *n3 = 28;
    a: u64 = *n1;          // 11
    b: u64 = *n2;          // 22
    c: u64 = *n3;          // 28
    s: u64 = a + b + c;    // 61
    free(n1);
    free(n2);
    free(n3);
    return s;
}
