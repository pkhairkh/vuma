// s80_ls_two_node_sum.vuma — two nodes, sum = 29 (14 + 15)
// Expected exit code: 29
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 14/15 via `*ptr = literal`, load both, sum -> 29.
// Uses `*ptr = literal` form (no offsets). Distinct from s78_ls_
// two_node_sum (2), s74_ls_two_node_sum (90) and s73_ls_two_node_
// sum (114).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 14;
    *n2 = 15;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 29
    free(n1);
    free(n2);
    return s;
}
