// s33_ls_three_node_diff.vuma — three nodes, diff = 200 - 50 - 30 = 120
// Expected exit code: 120
//
// Deterministic test in the linked_structures category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_ls_three_node_diff (different values) and s26_ls_three_node_sum (sum).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 50;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    d: u64 = a - b - c;     // 120
    free(n1);
    free(n2);
    free(n3);
    return d;
}
