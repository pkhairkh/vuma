// s51_ls_two_node_diff.vuma — two nodes, diff = 70 (180 - 110)
// Expected exit code: 70
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 180/110 via `*ptr = literal`, load both, subtract -> 70.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_ls_two_
// node_sum (255) and s47_ls_two_node_sum (225).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 180;
    *n2 = 110;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 70
    free(n1);
    free(n2);
    return d;
}
