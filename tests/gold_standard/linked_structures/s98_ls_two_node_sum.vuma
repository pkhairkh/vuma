// s98_ls_two_node_sum.vuma — two nodes, sum = 53 (30 + 23)
// Expected exit code: 53
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 30/23 via `*ptr = literal`, load both, a + b -> 53. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s94_ls_two_node_sum (145), s90_ls_two_node_diff (24) and
// s86_ls_two_node_sum (185).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 30;
    *n2 = 23;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 53
    free(n1);
    free(n2);
    return s;
}
