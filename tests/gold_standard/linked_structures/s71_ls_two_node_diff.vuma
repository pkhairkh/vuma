// s71_ls_two_node_diff.vuma — two nodes, diff = 155 (245 - 90)
// Expected exit code: 155
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 245/90 via `*ptr = literal`, load both, diff -> 155.
// Uses `*ptr = literal` form (no offsets). Distinct from s69_ls_
// two_node_sum (145), s70_ls_two_node_sum (90) and s66_ls_two_
// node_diff (125).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 245;
    *n2 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 155
    free(n1);
    free(n2);
    return d;
}
