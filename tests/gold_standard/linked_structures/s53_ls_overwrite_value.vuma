// s53_ls_overwrite_value.vuma — overwrite node to 195, load = 195
// Expected exit code: 195
//
// Single 8-byte allocation treated as one "node". Store 55 via
// `*ptr = literal`, then overwrite with 195. Load and return 195.
// Uses `*ptr = literal` form (no offsets). Distinct from s49_ls_
// overwrite_value (175) and s50_ls_overwrite_value (185).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 55;
    *n1 = 195;
    a: u64 = *n1;
    free(n1);
    return a;
}
