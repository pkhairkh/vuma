// s77_ls_three_node_diff.vuma — three nodes, diff = 132 (220 - 70 - 18)
// Expected exit code: 132
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 220/70/18 via `*ptr = literal`, load all three, diff
// -> 132. Uses `*ptr = literal` form (no offsets). Distinct from
// s70_ls_three_node_diff (150), s66_ls_three_node_diff (115) and
// s74_ls_three_node_diff (34).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 220;
    *n2 = 70;
    *n3 = 18;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 150
    r: u64 = t - c;        // 132
    free(n1);
    free(n2);
    free(n3);
    return r;
}
