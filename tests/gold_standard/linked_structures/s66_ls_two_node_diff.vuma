// s66_ls_two_node_diff.vuma — two nodes, diff = 125 (200 - 75)
// Expected exit code: 125
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 200/75 via `*ptr = literal`, load both, diff -> 125.
// Uses `*ptr = literal` form (no offsets). Distinct from s62_ls_
// two_node_sum (225), s58_ls_two_node_sum (220) and s55_ls_two_
// node_sum (240).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 75;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 125
    free(n1);
    free(n2);
    return d;
}
