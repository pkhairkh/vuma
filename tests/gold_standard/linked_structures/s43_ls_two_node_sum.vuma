// s43_ls_two_node_sum.vuma — two nodes, sum = 215 (85 + 130)
// Expected exit code: 215
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 85/130 via `*ptr = literal`, load both, sum -> 215. Uses
// `*ptr = literal` form (no offsets). Distinct from s42_ls_two_
// node_sum (200) and s38_ls_two_node_sum (175).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 85;
    *n2 = 130;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 215
    free(n1);
    free(n2);
    return s;
}
