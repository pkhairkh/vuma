// s8_ls_overwrite_last.vuma — overwrite last node, sum = 129 (10 + 20 + 99)
// Expected exit code: 129
//
// 24-byte allocation, three 8-byte nodes. Stores 10/20/30 at offsets
// 0/8/16, then overwrites the last node (offset 16) with 99. Loads
// all three, sums, returns 10 + 20 + 99 = 129. Distinct from
// s6_ls_overwrite_first (overwrites first node).

fn main() -> i32 {
    block = allocate(24);
    *(block + 0) = 10;
    *(block + 8) = 20;
    *(block + 16) = 30;
    *(block + 16) = 99;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    s: u64 = a + b + c;
    free(block);
    return s;
}
