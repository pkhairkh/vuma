// s55_ls_two_node_sum.vuma — two nodes, sum = 240 (95 + 145)
// Expected exit code: 240
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 95/145 via `*ptr = literal`, load both, sum -> 240. Uses
// `*ptr = literal` form (no offsets). Distinct from s54_ls_two_node_
// sum (255) and s53_ls_three_node_sum (195).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 95;
    *n2 = 145;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 240
    free(n1);
    free(n2);
    return s;
}
