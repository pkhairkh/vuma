// s94_ls_three_node_sum.vuma — three nodes, sum = 100 (40 + 35 + 25)
// Expected exit code: 100
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 40/35/25 via `*ptr = literal`, load all three,
// a + b + c -> 100. Uses `*ptr = literal` form (no offsets).
// Distinct from s90_ls_three_node_diff (26), s86_ls_three_node_diff
// (130) and s82_ls_three_node_diff (140).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 40;
    *n2 = 35;
    *n3 = 25;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a + b + c;    // 100
    free(n1);
    free(n2);
    free(n3);
    return r;
}
