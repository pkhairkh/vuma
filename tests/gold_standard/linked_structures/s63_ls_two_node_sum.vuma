// s63_ls_two_node_sum.vuma — two nodes, sum = 210 (115 + 95)
// Expected exit code: 210
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 115/95 via `*ptr = literal`, load both, sum -> 210. Uses
// `*ptr = literal` form (no offsets). Distinct from s51_ls_two_node_
// diff (70), s58_ls_two_node_sum (220) and s55_ls_two_node_sum (235).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 115;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 210
    free(n1);
    free(n2);
    return s;
}
