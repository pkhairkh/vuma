// s75_ls_overwrite_value.vuma — overwrite node to 178, load = 178
// Expected exit code: 178
//
// Single 8-byte allocation treated as one "node". Store 100 then
// 178 via `*ptr = literal` (overwrite), load and return 178.
// Uses `*ptr = literal` form (no offsets). Distinct from s74_ls_
// overwrite_value (149), s70_ls_overwrite_value (210) and s66_ls_
// overwrite_value (220).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 100;
    *n1 = 178;
    a: u64 = *n1;          // 178
    free(n1);
    return a;
}
