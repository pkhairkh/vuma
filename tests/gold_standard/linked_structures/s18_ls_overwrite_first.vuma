// s18_ls_overwrite_first.vuma — two nodes, overwrite first, sum = 140 (90 + 50)
// Expected exit code: 140
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 10/50 in n1/n2, then overwrite n1 with 90. Load both, sum -> 140.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s14_ls_overwrite_first (10/40 -> 80/40 = 120) and
// s9_ls_overwrite_node (single-node overwrite).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 10;
    *n2 = 50;
    *n1 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
