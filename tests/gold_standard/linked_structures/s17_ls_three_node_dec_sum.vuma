// s17_ls_three_node_dec_sum.vuma — three nodes, 100 + 60 + 20 = 180
// Expected exit code: 180
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 100/60/20 (descending by 40) via `*ptr = literal`, load all
// three, sum -> 180. Uses `*ptr = literal` form. Distinct from
// s14_ls_three_node_sum (11/22/33 = 66) and s9_ls_two_node_sum (2 nodes).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 100;
    *n2 = 60;
    *n3 = 20;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;       // 160
    s: u64 = t + c;       // 180
    free(n1);
    free(n2);
    free(n3);
    return s;
}
