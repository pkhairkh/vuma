// s106_ls_overwrite_value.vuma — overwrite n1 to 69, load = 69
// Expected exit code: 69
//
// Single 8-byte "node". Store 5, then overwrite to 69, load -> 69 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_overwrite_value (1), s101_ls_overwrite_value (41), s100_ls_overwrite_value (51).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 69;
    v: u64 = *n1;          // 69
    free(n1);
    return v;
}
