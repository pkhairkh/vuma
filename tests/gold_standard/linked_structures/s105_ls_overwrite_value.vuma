// s105_ls_overwrite_value.vuma — overwrite n1 to 191, load = 191
// Expected exit code: 191
// 
// Single 8-byte "node". Store 50, then overwrite to 191, load -> 191 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_overwrite_value (1), s101_ls_overwrite_value (41), s100_ls_overwrite_value (51).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 191;
    v: u64 = *n1;          // 191
    free(n1);
    return v;
}
