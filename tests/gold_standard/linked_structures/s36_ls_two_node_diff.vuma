// s36_ls_two_node_diff.vuma — nodes 250 and 25, diff = 225
// Expected exit code: 225
//
// Two 8-byte allocations treated as two independent
// "nodes". Store 250/25 via `*ptr = literal`, load both,
// subtract -> 225. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s30_ls_two_node_diff (diff, 0) and s27_ls_two_node_diff (different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 250;
    *n2 = 25;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 225
    free(n1);
    free(n2);
    return d;
}
