// s9_crypto_nibble_clear.vuma — 0xAB & 0xF0 = 0xA0 = 160
// Expected exit code: 160
//
// Mask off the low nibble of 0xAB (171), keeping only the high
// nibble -> 0xA0 = 160. All operands loaded into variables first.
// Distinct from s5_crypto_nibble_extract (extracts low nibble)
// and s6_crypto_nibble_swap (swaps nibbles).

fn main() -> i32 {
    v: u64 = 171;     // 0xAB
    m: u64 = 240;     // 0xF0
    r: u64 = v & m;   // 0xA0 = 160
    return r;
}
