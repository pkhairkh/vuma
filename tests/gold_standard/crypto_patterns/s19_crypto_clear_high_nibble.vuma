// s19_crypto_clear_high_nibble.vuma — 0xE7 & 0x0F = 0x07 = 7
// Expected exit code: 7
//
// Mask off the high nibble, keeping only the low nibble. 231 & 15 =
// 7. The mask is loaded into a variable first to dodge the
// immediate-RHS bitwise drop bug. Distinct from
// s18_crypto_high_nibble_extract (extract high nibble via & 0xF0 then
// shr) and s14_crypto_low_nibble (mask low nibble, different value).

fn main() -> i32 {
    v: u64 = 231;         // 0xE7
    m: u64 = 15;          // 0x0F
    r: u64 = v & m;       // 0x07 = 7
    return r;
}
