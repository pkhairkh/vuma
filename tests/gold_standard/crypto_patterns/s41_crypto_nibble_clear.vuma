// s41_crypto_nibble_clear.vuma - 0xB7 & 0xF0 = 0xB0 = 176
// Expected exit code: 176
//
// Clear the low nibble. 183 (0xB7) & 240 (0xF0) = 176 (0xB0). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s38_crypto_nibble_clear
// (0xCD & 0xF0 = 0xC0 = 192) and s34_crypto_nibble_clear.

fn main() -> i32 {
    a: u64 = 183;          // 0xB7
    b: u64 = 240;          // 0xF0
    r: u64 = a & b;        // 0xB0 = 176
    return r;
}
