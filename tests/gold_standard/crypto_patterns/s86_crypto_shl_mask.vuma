// s86_crypto_shl_mask.vuma — (0x07 << 4) & 0xF0 = 0x70 & 0xF0 = 0x70 = 112
// Expected exit code: 112
//
// Shift 0x07 left by 4 -> 0x70, then mask with 0xF0 -> 0x70 =
// 112. All operands loaded into u32 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s82_crypto_
// shl_then_xor (120), s78_crypto_shl_mask (176) and s74_crypto_
// shl_mask (180).
fn main() -> i32 {
    a: u32 = 7;            // 0x07
    b: u32 = 4;            // shift amount
    c: u32 = 240;          // 0xF0
    x: u32 = a << b;       // 0x70 = 112
    r: u32 = x & c;        // 0x70 = 112
    return r;
}
