// s33_crypto_shl_xor.vuma — (0x07 << 4) ^ 0x0F = 0x70 ^ 0x0F = 0x7F = 127
// Expected exit code: 127
//
// Deterministic test in the crypto_patterns category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_crypto_shl_then_mask (shl-then-mask) and s26_crypto_shl_xor (shl-then-xor).
fn main() -> i32 {
    a: u64 = 7;            // 0x07
    b: u64 = 4;
    c: u64 = 15;           // 0x0F
    x: u64 = a << b;       // 0x70 = 112
    r: u64 = x ^ c;        // 0x7F = 127
    return r;
}
