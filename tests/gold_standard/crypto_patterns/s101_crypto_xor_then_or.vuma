// s101_crypto_xor_then_or.vuma — (0xC0 ^ 0x30) | 0x01 = 0xF0 | 0x01 = 0xF1 = 241
// Expected exit code: 241
//
// Two-stage crypto mix: XOR then OR. (192 ^ 48) = 240 (0xF0);
// 240 | 1 = 241 (0xF1). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s98_crypto_xor_then_shr (40), s97_crypto_xor_then_and (86) and
// s94_crypto_xor_then_or (255).
fn main() -> i32 {
    a: u32 = 192;          // 0xC0
    b: u32 = 48;           // 0x30
    c: u32 = 1;            // 0x01
    x: u32 = a ^ b;        // 0xF0 = 240
    r: u32 = x | c;        // 0xF1 = 241
    return r;
}
