// s73_crypto_xor_pair.vuma — 0x5C ^ 0x37 = 0x6B = 107
// Expected exit code: 107
//
// Two-byte XOR. 92 ^ 55 = 107 (0x6B). All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s70_crypto_xor_pair (42), s69_crypto_xor_pair
// (163) and s66_crypto_xor_pair (249).
fn main() -> i32 {
    a: u64 = 92;           // 0x5C
    b: u64 = 55;           // 0x37
    r: u64 = a ^ b;        // 0x6B = 107
    return r;
}
