// s90_crypto_shl_then_or.vuma — (2 << 3) | 0x02 = 0x10 | 0x02 = 0x12 = 18
// Expected exit code: 18
//
// Two-stage crypto mix: shift-left then OR. 2 << 3 = 16 (0x10);
// 16 | 2 = 18 (0x12). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_crypto_shl_mask (231), s82_crypto_shl_then_xor (45) and
// s78_crypto_or_then_xor (4).
fn main() -> i32 {
    a: u32 = 2;
    s: u32 = 3;
    c: u32 = 2;            // 0x02
    x: u32 = a << s;       // 0x10 = 16
    r: u32 = x | c;        // 0x12 = 18
    return r;
}
