// s14_crypto_low_nibble.vuma — 0x9E & 0x0F = 14
// Expected exit code: 14
//
// Mask out all but the low nibble of 0x9E (158). (158 & 15) = 14.
// The mask is loaded into a variable first to dodge the
// immediate-RHS bitwise drop bug. Distinct from
// s10_crypto_high_nibble_only (extracts high nibble via >>) and
// s9_crypto_nibble_clear (clears low nibble via & 0xF0).

fn main() -> i32 {
    v: u64 = 158;         // 0x9E
    m: u64 = 15;          // 0x0F
    r: u64 = v & m;       // 0x0E = 14
    return r;
}
