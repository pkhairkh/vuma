// s66_crypto_or_mask.vuma — 0x0D | 0xF0 = 0xFD = 253
// Expected exit code: 253
//
// OR the low-nibble constant 0x0D with the high-nibble mask 0xF0
// to build the byte 0xFD. 13 | 240 = 253 (0xFD). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s62_crypto_or_then_and (170),
// s58_crypto_or_then_xor (127) and s55_crypto_xor_pair (255).
fn main() -> i32 {
    a: u64 = 13;           // 0x0D
    b: u64 = 240;          // 0xF0
    r: u64 = a | b;        // 0xFD = 253
    return r;
}
