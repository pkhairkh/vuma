// s14_crypto_shl_then_xor.vuma — (1 << 4) ^ 0x10 = 16 ^ 16 = 0
// Expected exit code: 0
//
// Shift left then XOR. (1 << 4) = 16; 16 ^ 16 = 0 (XOR with self
// cancels). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s9_crypto_shl_mask_byte (shift then AND-mask) and
// s10_crypto_xor_inverse (XOR-self inverse framing).

fn main() -> i32 {
    v: u64 = 1;
    sh: u64 = 4;
    k: u64 = 16;          // 0x10
    s: u64 = v << sh;     // 16
    r: u64 = s ^ k;       // 0
    return r;
}
