// s11_crypto_xor_then_shl.vuma — (0x55 ^ 0xAA) << 1 & 0xFF = 254
// Expected exit code: 254
//
// XOR-then-shift mix. (85 ^ 170) = 255 (0xFF); 255 << 1 = 510;
// 510 & 255 = 254 (0xFE). All operands loaded into u64 variables first.
// Distinct from s10_crypto_xor_chain_4 (4-way XOR, no shift) and
// s9_crypto_shl_mask_byte (shift-then-mask, no XOR).

fn main() -> i32 {
    a: u64 = 85;          // 0x55
    b: u64 = 170;         // 0xAA
    sh: u64 = 1;
    mask: u64 = 255;      // 0xFF
    x: u64 = a ^ b;       // 0xFF = 255
    s: u64 = x << sh;     // 510
    r: u64 = s & mask;    // 0xFE = 254
    return r;
}
