// s16_crypto_xor_pair.vuma — 0xA5 ^ 0x5A = 0xFF = 255
// Expected exit code: 255
//
// Single-stage XOR of two complementary nibble-swapped bytes. 165 ^ 90 =
// 255 (0xFF). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s13_crypto_xor_pair
// (different operands) and s14_crypto_xor_two_keys (two-stage XOR).

fn main() -> i32 {
    v: u64 = 165;          // 0xA5
    k: u64 = 90;           // 0x5A
    r: u64 = v ^ k;        // 0xFF = 255
    return r;
}
