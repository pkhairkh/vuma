// s65_crypto_shl_mask.vuma — (0x09 << 4) & 0xF0 = 0x90 & 0xF0 = 0x90 = 144
// Expected exit code: 144
//
// Shift the low-nibble constant 0x09 left by 4, then mask with 0xF0
// to keep only the high nibble. (9 << 4) = 144 (0x90); 144 & 240 =
// 144 (0x90). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_
// crypto_shl_mask (176), s58_crypto_shr_extract (12) and s62_crypto_
// shr_extract (11).

fn main() -> i32 {
    a: u64 = 9;            // 0x09
    b: u64 = 4;            // shift amount
    c: u64 = 240;          // 0xF0
    x: u64 = a << b;       // 0x90 = 144
    r: u64 = x & c;        // 0x90 = 144
    return r;
}
