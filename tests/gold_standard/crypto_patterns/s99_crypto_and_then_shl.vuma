// s99_crypto_and_then_shl.vuma — (0xFF & 0x33) << 2 = 0x33 << 2 = 0xCC = 204
// Expected exit code: 204
//
// Two-stage crypto-style bitwise: AND then shift-left.
// (255 & 51) = 51 (0x33); 51 << 2 = 204 (0xCC). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s95_crypto_shl_then_or (62),
// s91_crypto_and_then_shr (56) and s87_crypto_shl_mask (176).
fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    b: u64 = 51;          // 0x33
    s: u64 = 2;
    x: u64 = a & b;       // 0x33 = 51
    r: u64 = x << s;      // 0xCC = 204
    return r;
}
