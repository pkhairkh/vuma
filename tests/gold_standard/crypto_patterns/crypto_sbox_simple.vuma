// crypto_sbox_simple.vuma — simple S-box lookup (4-entry table)
// Expected exit code: 42
//
// S-boxes (substitution boxes) are the only non-linear element of
// AES, DES, and most block ciphers. This test materialises a 4-entry
// S-box in heap memory (each entry is a single byte), then loads the
// entry at index 2. The expected value at index 2 is 42. Index lookups
// via `*(table + idx)` with a variable idx work correctly in the
// current codegen (only the immediate-RHS-bitwise bug affects lookups,
// and there are no bitwise ops in the address computation here).
//
// Note: every value stored into the table is a decimal literal (the
// codegen drops hex literals stored through `*ptr = 0xNN`).

fn main() -> i32 {
    table = allocate(8);
    *(table + 0) = 16;             // 0x10
    *(table + 1) = 32;             // 0x20
    *(table + 2) = 42;             // 0x2A  <- target
    *(table + 3) = 64;             // 0x40
    idx: i32 = 2;
    val: i32 = *(table + idx);
    free(table);
    return val;
}
