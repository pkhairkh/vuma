// s83_crypto_xor_then_or.vuma — (0x20 ^ 0x0F) | 0x80 = 0x2F | 0x80 = 0xAF = 175
// Expected exit code: 175
//
// Two-stage crypto-style bitwise: XOR then OR. (32 ^ 15) =
// 47 (0x2F); 47 | 128 = 175 (0xAF). All operands loaded
// into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_crypto_xor_then_shr (1),
// s74_crypto_xor_then_or (98) and s72_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 32;           // 0x20
    b: u64 = 15;           // 0x0F
    c: u64 = 128;          // 0x80
    x: u64 = a ^ b;        // 0x2F = 47
    r: u64 = x | c;        // 0xAF = 175
    return r;
}
