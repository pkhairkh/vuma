// s34_crypto_shl_then_xor.vuma — (1 << 4) ^ 0xAA = 16 ^ 170 = 186
// Expected exit code: 186
//
// Shift-then-XOR byte mix. (1 << 4) = 16 (0x10); 16 ^ 170 = 186
// (0xBA). All operands loaded into u64 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s30_crypto_shl_
// then_mask (shl-then-mask) and s27_crypto_shl_xor (different
// values).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 170;          // 0xAA
    s: u64 = a << b;       // 0x10 = 16
    r: u64 = s ^ c;        // 0xBA = 186
    return r;
}
