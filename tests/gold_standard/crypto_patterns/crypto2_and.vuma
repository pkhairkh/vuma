// crypto2_and.vuma — AND: 0xFF & 0x0F = 0x0F
// Expected exit code: 15
//
// Bitwise-AND is the standard mask operation: extract the low nibble
// of a byte. Both operands are loaded into named variables first
// because VUMA codegen drops bitwise ops with an immediate RHS.
// 255 & 15 = 15.

fn main() -> i32 {
    a: u64 = 0xFF;
    b: u64 = 0x0F;
    c: u64 = a & b;       // 0xFF & 0x0F = 0x0F
    return c;
}
