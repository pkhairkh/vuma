// s104_crypto_and_then_or.vuma — (0x05 & 0x07) | 0x40 = 0x05 | 0x40 = 0x45 = 69
// Expected exit code: 69
//
// Two-stage crypto mix: AND then OR. (5 & 7) = 5 (0x05); 5 | 64 = 69 (0x45). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_crypto_or_then_shl (68), s102_crypto_shr_then_xor (59), s102_crypto_xor_then_and (55).
fn main() -> i32 {
    a: u32 = 5;          // 0x05
    b: u32 = 7;          // 0x07
    c: u32 = 64;          // 0x40
    n: u32 = a & b;        // 0x05 = 5
    r: u32 = n | c;        // 0x45 = 69
    return r;
}
