// s47_crypto_shl_extract.vuma — 0x09 << 4 = 0x90 = 144
// Expected exit code: 144
//
// Left-shift of a low nibble into the high nibble position. 9 << 4 =
// 144 (0x90). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s46_
// crypto_shr_extract (11) and s42_crypto_shl_xor (47).

fn main() -> i32 {
    a: u64 = 9;            // 0x09
    b: u64 = 4;
    r: u64 = a << b;       // 0x90 = 144
    return r;
}
