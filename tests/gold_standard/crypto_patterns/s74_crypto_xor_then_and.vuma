// s74_crypto_xor_then_and.vuma — (0xE7 ^ 0x18) & 0xCB = 0xFF & 0xCB = 0xCB = 203
// Expected exit code: 203
//
// Two-stage crypto op: XOR then AND. 231 ^ 24 = 255 (0xFF);
// 255 & 203 = 203 (0xCB). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s70_crypto_xor_then_and (99), s66_crypto_xor_pair (249) and
// s62_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 231;          // 0xE7
    b: u64 = 24;           // 0x18
    c: u64 = 203;          // 0xCB
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0xCB = 203
    return r;
}
