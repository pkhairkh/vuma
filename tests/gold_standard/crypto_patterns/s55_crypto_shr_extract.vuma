// s55_crypto_shr_extract.vuma — 0xF0 >> 4 = 0x0F = 15
// Expected exit code: 15
//
// Extract the high nibble by shifting right 4 bits. 240 >> 4 = 15
// (0x0F). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s54_crypto_shl_xor
// (211) and s53_crypto_shl_xor (21).

fn main() -> i32 {
    a: u64 = 240;           // 0xF0
    b: u64 = 4;
    r: u64 = a >> b;        // 0x0F = 15
    return r;
}
