// s100_crypto_shr_then_or.vuma — (0xF0 >> 2) | 0x01 = 0x3C | 0x01 = 0x3D = 61
// Expected exit code: 61
//
// Two-stage crypto mix: shift-right then OR. (240 >> 2) =
// 60 (0x3C); 60 | 1 = 61 (0x3D). All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_crypto_or_then_shl (86), s94_crypto_and_then_shr (30), s90_crypto_and_then_xor (27).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    s: u32 = 2;
    b: u32 = 1;            // 0x01
    x: u32 = a >> s;       // 0x3C = 60
    r: u32 = x | b;        // 0x3D = 61
    return r;
}
