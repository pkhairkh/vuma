// s56_crypto_shl_mask.vuma — (1 << 3) & 0x7F = 8 & 127 = 8
// Expected exit code: 8
//
// Shift-then-mask mix. 1 << 3 = 8; 8 & 127 = 8. All operands loaded
// into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s54_crypto_shl_xor (211) and
// s50_crypto_shr_extract (15).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 3;
    c: u64 = 127;          // 0x7F
    x: u64 = a << b;       // 8
    r: u64 = x & c;        // 8
    return r;
}
