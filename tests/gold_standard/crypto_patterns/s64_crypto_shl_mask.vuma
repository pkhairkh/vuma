// s64_crypto_shl_mask.vuma — (0x05 << 4) & 0x7F = 0x50 & 0x7F = 0x50 = 80
// Expected exit code: 80
//
// Shift a low nibble up then mask to one byte. (5 << 4) = 80 (0x50);
// 80 & 127 = 80 (0x50). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s62_crypto_
// xor_pair (204), s62_crypto_shr_extract (11) and s62_crypto_or_then_
// and (170).

fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 4;
    c: u64 = 127;          // 0x7F
    x: u64 = a << b;       // 0x50 = 80
    r: u64 = x & c;        // 0x50 = 80
    return r;
}
