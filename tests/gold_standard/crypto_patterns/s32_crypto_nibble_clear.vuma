// s32_crypto_nibble_clear.vuma - 0xAB & 0x0F = 0x0B = 11
// Expected exit code: 11
//
// 0xAB & 0x0F = 0x0B = 11. All operands loaded into typed variables before
// any bitwise op (immediate-RHS drop workaround where applicable); stores
// use the `*ptr = literal` (or `*ptr = variable + 0`) form with no `*(ptr +
// offset)` indexing. Distinct from s30_crypto_nibble_clear (different value)
// and s26_crypto_nibble_swap (nibble swap).

fn main() -> i32 {
    a: u64 = 171;         // 0xAB
    b: u64 = 15;          // 0x0F
    r: u64 = a & b;       // 0x0B = 11
    return r;
}
