// s98_crypto_xor_then_shr.vuma — (0xCC ^ 0x6C) >> 2 = 0xA0 >> 2 = 0x28 = 40
// Expected exit code: 40
//
// Two-stage crypto-style bitwise: XOR then shift-right.
// (204 ^ 108) = 160 (0xA0); 160 >> 2 = 40 (0x28). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s94_crypto_xor_then_or (255),
// s90_crypto_xor_then_shr (17) and s86_crypto_xor_pair (153).
fn main() -> i32 {
    a: u64 = 204;         // 0xCC
    b: u64 = 108;         // 0x6C
    s: u64 = 2;
    x: u64 = a ^ b;       // 0xA0 = 160
    r: u64 = x >> s;      // 0x28 = 40
    return r;
}
