// s53_crypto_xor_pair.vuma — 0x5A ^ 0x3C = 0x66 = 102
// Expected exit code: 102
//
// Two-byte XOR. 90 ^ 60 = 102 (0x66). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s49_crypto_xor_pair (153) and s50_crypto_xor_pair
// (255).

fn main() -> i32 {
    a: u64 = 90;           // 0x5A
    b: u64 = 60;           // 0x3C
    r: u64 = a ^ b;        // 0x66 = 102
    return r;
}
