// s6_crypto_rotate_right_4.vuma — rotate 0xB2 right by 4 = 0x2B = 43
// Expected exit code: 43
//
// Rotate right by 4 of an 8-bit value 0xB2 (178). High nibble 0xB
// moves to low, low nibble 0x2 moves to high -> 0x2B = 43.
// Computed as ((v >> 4) | (v << 4)) & 0xFF. All operands loaded into
// variables first. Distinct from s5_crypto_rotate_left_4 (rotate left).

fn main() -> i32 {
    v: u64 = 178;       // 0xB2
    four: u64 = 4;
    mask: u64 = 255;    // 0xFF
    lo_part: u64 = v >> four;           // 0x0B
    hi_part: u64 = v << four;           // 0xB20
    combined: u64 = lo_part | hi_part;  // 0xB2B
    r: u64 = combined & mask;           // 0x2B = 43
    return r;
}
