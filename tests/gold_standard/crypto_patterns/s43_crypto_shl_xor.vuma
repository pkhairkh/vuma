// s43_crypto_shl_xor.vuma — (0x0F << 4) ^ 0xCC = 0xF0 ^ 0xCC = 0x3C = 60
// Expected exit code: 60
//
// Two-stage: shift-left then XOR. (15 << 4) = 240 (0xF0);
// 240 ^ 204 = 60 (0x3C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_crypto_shl_xor (240 ^ 0xAA = 170) and s38_crypto_shl_xor.

fn main() -> i32 {
    a: u64 = 15;           // 0x0F
    b: u64 = 4;
    c: u64 = 204;          // 0xCC
    x: u64 = a << b;       // 0xF0 = 240
    r: u64 = x ^ c;        // 0x3C = 60
    return r;
}
