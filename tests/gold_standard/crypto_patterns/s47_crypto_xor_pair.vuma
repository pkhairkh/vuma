// s47_crypto_xor_pair.vuma — 0x96 ^ 0x69 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 150 ^ 105 = 255 (0xFF). Bit-complement-style pair
// (0x96 / 0x69 are bitwise complements within a byte) produces an
// all-ones bit pattern. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_crypto_xor_pair (0x66 ^ 0x99 = 255) and s42_crypto_xor_pair
// (0xC3 ^ 0x3C = 255).

fn main() -> i32 {
    a: u64 = 150;          // 0x96
    b: u64 = 105;          // 0x69
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
