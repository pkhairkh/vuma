// crypto2_shift.vuma — left shift: 1 << 2 = 4
// Expected exit code: 4
//
// The single-bit-set mask generator: shift 1 left by n to produce
// 2^n. Both operands are loaded into named variables first because
// VUMA codegen drops bitwise ops with an immediate RHS. 1 << 2 = 4.

fn main() -> i32 {
    a: u64 = 1;
    n: u64 = 2;
    c: u64 = a << n;      // 1 << 2 = 4
    return c;
}
