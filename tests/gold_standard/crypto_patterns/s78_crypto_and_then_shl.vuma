// s78_crypto_and_then_shl.vuma — (0x01 & 0x01) << 2 = 0x01 << 2 = 0x04 = 4
// Expected exit code: 4
//
// Two-stage crypto op: AND then shift left. (1 & 1) = 1
// (0x01); 1 << 2 = 4 (0x04). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s74_crypto_and_then_or (170),
// s73_crypto_and_then_or (200) and s72_crypto_and_then_shl (96).
fn main() -> i32 {
    a: u64 = 1;            // 0x01
    b: u64 = 1;            // 0x01
    c: u64 = 2;
    x: u64 = a & b;        // 0x01 = 1
    r: u64 = x << c;       // 0x04 = 4
    return r;
}
