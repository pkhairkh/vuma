// s76_crypto_xor_then_shr.vuma — (0xB4 ^ 0x4B) >> 3 = 0xFF >> 3 = 0x1F = 31
// Expected exit code: 31
//
// Two-stage crypto op: XOR then shift right. 180 ^ 75 = 255
// (0xFF); 255 >> 3 = 31 (0x1F). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s74_crypto_xor_then_shr (39), s73_crypto_shl_
// then_xor (65) and s72_crypto_and_then_xor (52).
fn main() -> i32 {
    a: u64 = 180;          // 0xB4
    b: u64 = 75;           // 0x4B
    c: u64 = 3;
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x >> c;       // 0x1F = 31
    return r;
}
