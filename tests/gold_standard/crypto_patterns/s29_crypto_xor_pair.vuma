// s29_crypto_xor_pair.vuma — 0x6F ^ 0x90 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 111 ^ 144 = 255 (0xFF). Complementary-bit bytes XOR to all ones. All operands loaded into u64 variables first (immediate-RHS bitwise drop bug workaround). Distinct from s26_crypto_xor_pair (0xA5^0x5A=255) and s22_crypto_xor_three (three-byte xor, 105).

fn main() -> i32 {
    a: u64 = 111;         // 0x6F
    b: u64 = 144;         // 0x90
    r: u64 = a ^ b;       // 0xFF = 255
    return r;
}
