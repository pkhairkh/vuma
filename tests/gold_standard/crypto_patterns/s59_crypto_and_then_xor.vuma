// s59_crypto_and_then_xor.vuma — (0xF0 & 0x80) ^ 0x40 = 0x80 ^ 0x40 = 0xC0 = 192
// Expected exit code: 192
//
// Two-stage crypto mix: AND the high-bit mask out of 0xF0, then XOR
// the next bit in. (240 & 128) = 128 (0x80); 128 ^ 64 = 192 (0xC0).
// All operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s58_crypto_xor_pair (255),
// s58_crypto_shr_extract (12) and s58_crypto_or_then_xor (127).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 128;          // 0x80
    c: u64 = 64;           // 0x40
    x: u64 = a & b;        // 0x80 = 128
    r: u64 = x ^ c;        // 0xC0 = 192
    return r;
}
