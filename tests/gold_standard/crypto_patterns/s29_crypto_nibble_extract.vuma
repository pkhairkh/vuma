// s29_crypto_nibble_extract.vuma — 0xAB & 0x0F = 0x0B = 11
// Expected exit code: 11
//
// Extract low nibble of 0xAB. (171 & 15) = 11 (0x0B). Demonstrates the canonical low-nibble-mask crypto pattern. All operands loaded into u64 variables first. Distinct from s26_crypto_nibble_swap (nibble swap, 195) and s22_crypto_shl_mask_high (shl-mask high).

fn main() -> i32 {
    v: u64 = 171;         // 0xAB
    lo_mask: u64 = 15;    // 0x0F
    r: u64 = v & lo_mask; // 0x0B = 11
    return r;
}
