// s36_crypto_nibble_swap.vuma — swap nibbles of 0x3C -> 0xC3 = 195
// Expected exit code: 195
//
// Classic nibble-swap of a byte: extract low and high
// nibbles, shift them to the opposite end, OR them back
// together. 0x3C -> 0xC3 = 195. All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s30_crypto_nibble_swap (swap, 0) and s27_crypto_nibble_swap (different values).

fn main() -> i32 {
    v: u64 = 60;           // 0x3C
    lo_mask: u64 = 15;     // 0x0F
    hi_mask: u64 = 240;    // 0xF0
    shift: u64 = 4;
    lo: u64 = v & lo_mask; // 0x0C
    hi: u64 = v & hi_mask; // 0x30
    lo_shl: u64 = lo << shift;  // 0xC0
    hi_shr: u64 = hi >> shift;  // 0x03
    r: u64 = lo_shl | hi_shr;   // 0xC3 = 195
    return r;
}
