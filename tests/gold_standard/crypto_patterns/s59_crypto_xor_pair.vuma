// s59_crypto_xor_pair.vuma — 0xA5 ^ 0x3C = 0x99 = 153
// Expected exit code: 153
//
// Two-byte XOR. 165 ^ 60 = 153 (0x99). Non-complementary pair chosen
// to produce a mid-range byte (distinct from the all-ones 0xFF pair
// in s58). All operands loaded into u64 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s58_crypto_xor_pair
// (255), s58_crypto_shr_extract (12) and s58_crypto_or_then_xor (127).

fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 60;           // 0x3C
    r: u64 = a ^ b;        // 0x99 = 153
    return r;
}
