// s71_crypto_and_then_shl.vuma — (0xC3 & 0x1E) << 3 = 0x02 << 3 = 0x10 = 16
// Expected exit code: 16
//
// Two-stage crypto op: AND then shift left. (195 & 30) = 2
// (0x02); 2 << 3 = 16 (0x10). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s69_crypto_shl_mask (192), s70_crypto_xor_pair
// (99) and s66_crypto_shl_mask (153).
fn main() -> i32 {
    a: u64 = 195;          // 0xC3
    b: u64 = 30;           // 0x1E
    s: u64 = 3;
    x: u64 = a & b;        // 0x02 = 2
    r: u64 = x << s;       // 0x10 = 16
    return r;
}
