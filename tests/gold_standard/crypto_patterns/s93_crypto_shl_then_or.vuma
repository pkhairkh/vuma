// s93_crypto_shl_then_or.vuma — (3 << 4) | 0x01 = 0x30 | 0x01 = 0x31 = 49
// Expected exit code: 49
//
// Two-stage crypto mix: shift-left then OR. 3 << 4 = 48 (0x30);
// 48 | 1 = 49 (0x31). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_crypto_shl_then_or (18), s82_crypto_shl_then_xor (65) and s78_crypto_or_then_xor (9).
fn main() -> i32 {
    a: u32 = 3;
    s: u32 = 4;
    c: u32 = 1;            // 0x01
    x: u32 = a << s;       // 0x30 = 48
    r: u32 = x | c;        // 0x31 = 49
    return r;
}
