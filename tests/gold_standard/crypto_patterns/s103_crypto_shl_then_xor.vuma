// s103_crypto_shl_then_xor.vuma — (0x01 << 5) ^ 0x28 = 0x20 ^ 0x28 = 0x08 = 8
// Expected exit code: 8
//
// Two-stage crypto mix: shift-left then XOR. (1 << 5) = 32 (0x20); 32 ^ 40 = 8 (0x08). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
fn main() -> i32 {
    a: u32 = 1;           // 0x01
    b: u32 = 5;
    c: u32 = 40;          // 0x28
    x: u32 = a << b;      // 0x20 = 32
    r: u32 = x ^ c;       // 0x08 = 8
    return r;
}
