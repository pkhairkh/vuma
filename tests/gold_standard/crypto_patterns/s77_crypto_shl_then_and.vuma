// s77_crypto_shl_then_and.vuma — (0x09 << 2) & 0x3C = 0x24 & 0x3C = 0x24 = 36
// Expected exit code: 36
//
// Two-stage crypto op: shift left then AND. 9 << 2 = 36 (0x24);
// 36 & 60 = 36 (0x24). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_crypto_shr_xor (231), s66_crypto_xor_then_and (99)
// and s74_crypto_xor_then_shr (39).

fn main() -> i32 {
    a: u64 = 9;            // 0x09
    b: u64 = 2;
    c: u64 = 60;           // 0x3C
    x: u64 = a << b;       // 0x24 = 36
    r: u64 = x & c;        // 0x24 = 36
    return r;
}
