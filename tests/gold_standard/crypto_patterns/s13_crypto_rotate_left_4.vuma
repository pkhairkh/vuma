// s13_crypto_rotate_left_4.vuma — ROL(0x0F, 4) in 8 bits = 0xF0 = 240
// Expected exit code: 240
//
// 8-bit rotate-left by 4 of 0x0F: ((0x0F << 4) | (0x0F >> 4)) & 0xFF
// = (0xF0 | 0x00) & 0xFF = 0xF0 = 240. The mask collapses any bits
// shifted past bit 7. All operands loaded into u64 variables first.
// Distinct from s10_crypto_rotate_left_2 (rotate by 2) and
// s6_crypto_rotate_right_4 (rotate right, not left).

fn main() -> i32 {
    v: u64 = 15;          // 0x0F
    s: u64 = 4;
    m: u64 = 255;         // 0xFF
    lo: u64 = v << s;     // 0xF0
    hi: u64 = v >> s;     // 0x00
    t: u64 = lo | hi;     // 0xF0
    r: u64 = t & m;       // 0xF0 = 240
    return r;
}
