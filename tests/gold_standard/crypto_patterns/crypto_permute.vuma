// crypto_permute.vuma — bit permutation (rotate-left-1 of 21 -> 42)
// Expected exit code: 42
//
// A bit permutation reorders the bits of a word without changing their
// values. The simplest cryptographically relevant permutation is a
// 1-bit left rotation within a byte: rol(v, 1) = ((v << 1) | (v >> 7))
// & 0xFF. With v = 21 (= 0b00010101), rol(21, 1) = 0b00101010 = 42.
// All shift amounts and the final byte mask are loaded into named
// variables per the bitwise-immediate-RHS workaround.

fn main() -> i32 {
    v: u64 = 21;                   // 0b00010101
    one: u64 = 1;
    seven: u64 = 7;
    mFF: u64 = 0xFF;
    shl: u64 = v << one;           // 0b00101010 = 42
    shr: u64 = v >> seven;         // 0 (no high bit to wrap)
    rotated: u64 = shl | shr;      // 42
    result: u64 = rotated & mFF;   // 42 (low byte)
    return result;
}
