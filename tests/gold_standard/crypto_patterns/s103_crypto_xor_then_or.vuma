// s103_crypto_xor_then_or.vuma — (0x01 ^ 0x50) | 0x20 = 0x51 | 0x20 = 0x71 = 113
// Expected exit code: 113
//
// Two-stage crypto mix: XOR then OR. (1 ^ 80) = 81 (0x51); 81 | 32 = 113 (0x71). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_crypto_xor_then_or (241), s99_crypto_xor_then_or (191), s94_crypto_xor_then_or (255).
fn main() -> i32 {
    a: u32 = 1;           // 0x01
    b: u32 = 80;          // 0x50
    c: u32 = 32;          // 0x20
    x: u32 = a ^ b;       // 0x51 = 81
    r: u32 = x | c;       // 0x71 = 113
    return r;
}
