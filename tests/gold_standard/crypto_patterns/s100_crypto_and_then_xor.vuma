// s100_crypto_and_then_xor.vuma — (0x3F & 0x37) ^ 0x01 = 0x37 ^ 0x01 = 0x36 = 54
// Expected exit code: 54
//
// Two-stage crypto mix: AND then XOR. (63 & 55) = 55
// (0x37); 55 ^ 1 = 54 (0x36). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_crypto_or_then_shl (86), s94_crypto_and_then_shr (30), s90_crypto_and_then_xor (27).
fn main() -> i32 {
    a: u32 = 63;           // 0x3F
    b: u32 = 55;           // 0x37
    c: u32 = 1;            // 0x01
    x: u32 = a & b;        // 0x37 = 55
    r: u32 = x ^ c;        // 0x36 = 54
    return r;
}
