// s14_crypto_xor_two_keys.vuma — 0xAB ^ 0x12 ^ 0x34 = 0x8D = 141
// Expected exit code: 141
//
// Two-stage XOR with two distinct keys. (171 ^ 18) = 189 (0xB9);
// 189 ^ 52 = 141 (0x8D). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s10_crypto_xor_chain_4 (four-way XOR chain) and
// s9_crypto_xor_with_key (single-key XOR).

fn main() -> i32 {
    v: u64 = 171;          // 0xAB
    k1: u64 = 18;          // 0x12
    k2: u64 = 52;          // 0x34
    x: u64 = v ^ k1;       // 0xB9 = 189
    r: u64 = x ^ k2;       // 0x8D = 141
    return r;
}
