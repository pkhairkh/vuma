// s68_crypto_xor_pair.vuma — 0x74 ^ 0x29 = 0x5D = 93
// Expected exit code: 93
//
// Two-byte XOR. 116 ^ 41 = 93 (0x5D). Mid-bit pair (0x74 / 0x29)
// produces the byte 0x5D. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_crypto_xor_pair (249), s62_crypto_xor_pair (204) and
// s58_crypto_xor_pair (255).
fn main() -> i32 {
    a: u64 = 116;          // 0x74
    b: u64 = 41;           // 0x29
    r: u64 = a ^ b;        // 0x5D = 93
    return r;
}
