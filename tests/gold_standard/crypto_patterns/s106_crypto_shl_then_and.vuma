// s106_crypto_shl_then_and.vuma — (0x69 << 1) & 0x7F = 0xD2 & 0x7F = 0x52 = 82
// Expected exit code: 82
//
// Two-stage crypto mix: shift-left then AND. (105 << 1) = 210 (0xD2); 210 & 127 = 82 (0x52). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_crypto_or_then_shl (68), s101_crypto_shr_then_and (25), s100_crypto_shr_then_or (61).
fn main() -> i32 {
    a: u32 = 105;         // 0x69
    b: u32 = 1;           // shift amount
    c: u32 = 127;         // 0x7F
    x: u32 = a << b;        // 0xD2 = 210
    r: u32 = x & c;        // 0x52 = 82
    return r;
}
