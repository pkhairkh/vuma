// s75_crypto_shl_then_xor.vuma — (0x09 << 3) ^ 0x68 = 0x48 ^ 0x68 = 0x20 = 32
// Expected exit code: 32
//
// Two-stage crypto op: shift left then XOR. 9 << 3 = 72 (0x48);
// 72 ^ 104 = 32 (0x20). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_crypto_xor_then_shr (39), s70_crypto_shr_xor (231) and
// s66_crypto_xor_then_and (99).
fn main() -> i32 {
    a: u64 = 9;            // 0x09
    b: u64 = 3;
    c: u64 = 104;          // 0x68
    x: u64 = a << b;       // 0x48 = 72
    r: u64 = x ^ c;        // 0x20 = 32
    return r;
}
