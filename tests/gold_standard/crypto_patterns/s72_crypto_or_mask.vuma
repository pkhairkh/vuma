// s72_crypto_or_mask.vuma — 0x5A | 0x28 = 0x7A = 122
// Expected exit code: 122
//
// Two-byte OR mask. 90 | 40 = 122 (0x7A). Mid-bit pair (0x5A /
// 0x28) produces the byte 0x7A. All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s70_crypto_xor_pair (42), s69_crypto_xor_pair
// (163) and s66_crypto_xor_pair (249).
fn main() -> i32 {
    a: u64 = 90;           // 0x5A
    b: u64 = 40;           // 0x28
    r: u64 = a | b;        // 0x7A = 122
    return r;
}
