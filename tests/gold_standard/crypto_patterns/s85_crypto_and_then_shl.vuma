// s85_crypto_and_then_shl.vuma — (0xAB & 0x70) << 2 = 0x20 << 2 = 0x80 = 128
// Expected exit code: 128
//
// Two-stage crypto-style bitwise: AND then shift left.
// (171 & 112) = 32 (0x20); 32 << 2 = 128 (0x80). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s82_crypto_and_then_or,
// s78_crypto_and_then_shl and s74_crypto_and_then_shl.
fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 112;          // 0x70
    c: u64 = 2;            // shift amount
    x: u64 = a & b;        // 0x20 = 32
    r: u64 = x << c;       // 0x80 = 128
    return r;
}
