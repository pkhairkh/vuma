// s97_crypto_or_then_shl.vuma — (0x20 | 0x0B) << 1 = 0x2B << 1 = 0x56 = 86
// Expected exit code: 86
//
// Two-stage crypto mix: OR then shift-left. (32 | 11) = 43
// (0x2B); 43 << 1 = 86 (0x56). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_crypto_and_then_shr (30), s90_crypto_and_then_xor (27), s86_crypto_and_then_xor (63).
fn main() -> i32 {
    a: u32 = 32;           // 0x20
    b: u32 = 11;           // 0x0B
    s: u32 = 1;
    x: u32 = a | b;        // 0x2B = 43
    r: u32 = x << s;       // 0x56 = 86
    return r;
}
