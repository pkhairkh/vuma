// s95_crypto_or_then_xor.vuma — (0x05 | 0x50) ^ 0x0D = 0x55 ^ 0x0D = 0x58 = 88
// Expected exit code: 88
//
// Two-stage crypto mix: OR then XOR. (5 | 80) = 85 (0x55);
// 85 ^ 13 = 88 (0x58). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_and_then_shr (74), s90_crypto_and_then_xor (27) and
// s82_crypto_and_then_or (37).
fn main() -> i32 {
    a: u32 = 5;            // 0x05
    b: u32 = 80;           // 0x50
    c: u32 = 13;           // 0x0D
    x: u32 = a | b;        // 0x55 = 85
    r: u32 = x ^ c;        // 0x58 = 88
    return r;
}
