// s35_crypto_xor_pair.vuma — 0x6C ^ 0x36 = 0x5A = 90
// Expected exit code: 90
//
// Two-byte XOR. 108 ^ 54 = 90 (0x5A). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s34_crypto_xor_pair (0x96 ^ 0x69 = 0xFF, 255) and
// s30_crypto_xor_pair (0xC3 ^ 0x3C = 0xFF, 255).

fn main() -> i32 {
    a: u64 = 108;          // 0x6C
    b: u64 = 54;           // 0x36
    r: u64 = a ^ b;        // 0x5A = 90
    return r;
}
