// s87_crypto_xor_pair.vuma — 0x5A ^ 0x3C = 0x66 = 102
// Expected exit code: 102
//
// XOR two byte constants: 90 ^ 60 = 102 (0x66). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s86_crypto_xor_pair (153),
// s82_crypto_xor_then_and (76) and s78_crypto_xor_pair (90).
fn main() -> i32 {
    a: u32 = 90;           // 0x5A
    b: u32 = 60;           // 0x3C
    r: u32 = a ^ b;        // 0x66 = 102
    return r;
}
