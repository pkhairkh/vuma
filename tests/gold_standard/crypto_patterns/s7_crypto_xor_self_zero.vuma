// s7_crypto_xor_self_zero.vuma — 0xCD ^ 0xCD = 0
// Expected exit code: 0
//
// Any value XORed with itself cancels to 0. Both operands are the
// same variable, loaded into a u64 first. Distinct from
// s5_crypto_parity_xor (4-byte fold, nonzero result) and
// s6_crypto_xor_pairs (two distinct operands).

fn main() -> i32 {
    v: u64 = 205;    // 0xCD
    r: u64 = v ^ v;  // 0
    return r;
}
