// s29_crypto_shl_then_xor.vuma — (1 << 6) ^ 0x3C = 64 ^ 60 = 0x7C = 124
// Expected exit code: 124
//
// SHL then XOR. (1 << 6) = 64 (0x40); 64 ^ 60 = 124 (0x7C). Demonstrates a typical "shift a bit into position then XOR with a mask" pattern. All operands loaded into u64 variables first. Distinct from s26_crypto_shl_then_mask (shl-then-and, 16) and s22_crypto_shl_mask_high (shl-mask high).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 6;
    c: u64 = 60;          // 0x3C
    x: u64 = a << b;      // 0x40 = 64
    r: u64 = x ^ c;       // 0x7C = 124
    return r;
}
