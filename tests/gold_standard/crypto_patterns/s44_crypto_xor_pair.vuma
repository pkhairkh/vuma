// s44_crypto_xor_pair.vuma — 0xAB ^ 0xCD = 0x66 = 102
// Expected exit code: 102
//
// Two-byte XOR. 171 ^ 205 = 102 (0x66). Complement-style pair
// produces a 0x66 bit pattern. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_crypto_xor_pair (0xC3 ^ 0x3C = 255) and s38_crypto_xor_pair
// (0xA5 ^ 0x3C = 153).

fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 205;          // 0xCD
    r: u64 = a ^ b;        // 0x66 = 102
    return r;
}
