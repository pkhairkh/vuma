// s50_crypto_high_nibble.vuma — 0xAB & 0xF0 = 0xA0 = 160
// Expected exit code: 160
//
// Mask off the low nibble to isolate the high nibble. 171 (0xAB) &
// 240 (0xF0) = 160 (0xA0). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_crypto_nibble_clear (0xCD & 0xF0 = 192) and s43_crypto_
// nibble_clear (240).

fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 240;          // 0xF0
    r: u64 = a & b;        // 0xA0 = 160
    return r;
}
