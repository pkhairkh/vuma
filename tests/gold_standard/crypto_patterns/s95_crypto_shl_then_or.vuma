// s95_crypto_shl_then_or.vuma — (1 << 5) | 0x1E = 0x20 | 0x1E = 0x3E = 62
// Expected exit code: 62
//
// Two-stage crypto mix: shift-left then OR. (1 << 5) = 32 (0x20);
// 32 | 30 = 62 (0x3E). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_or_then_and (143), s90_crypto_shl_then_or (18) and
// s82_crypto_shl_then_xor (65).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    s: u32 = 5;
    b: u32 = 30;           // 0x1E
    x: u32 = a << s;       // 0x20 = 32
    r: u32 = x | b;        // 0x3E = 62
    return r;
}
