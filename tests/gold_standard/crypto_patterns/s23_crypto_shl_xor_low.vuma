// s23_crypto_shl_xor_low.vuma — (1 << 4) ^ 0x05 = 0x10 ^ 0x05 = 0x15 = 21
// Expected exit code: 21
//
// Shift then low-byte XOR. 1 << 4 = 16 (0x10); 16 ^ 5 = 21 (0x15). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_crypto_shl_mask_high (shl-then-mask,
// value 0) and s24_crypto_shl_mask_low (shl-then-mask, value 48).

fn main() -> i32 {
    a: u64 = 1;
    sh: u64 = 4;
    b: u64 = 5;           // 0x05
    x: u64 = a << sh;     // 0x10 = 16
    r: u64 = x ^ b;       // 0x15 = 21
    return r;
}

