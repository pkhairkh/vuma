// s94_crypto_xor_then_or.vuma — (0xAA ^ 0x55) | 0x01 = 0xFF | 0x01 = 0xFF = 255
// Expected exit code: 255
//
// Two-stage crypto mix: XOR then OR. (170 ^ 85) = 255 (0xFF);
// 255 | 1 = 255 (0xFF). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_crypto_xor_then_shr (17), s86_crypto_xor_pair (153) and
// s82_crypto_xor_then_and (85).
fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 85;           // 0x55
    c: u32 = 1;            // 0x01
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x | c;        // 0xFF = 255
    return r;
}
