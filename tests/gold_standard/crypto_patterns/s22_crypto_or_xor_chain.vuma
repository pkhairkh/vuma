// s22_crypto_or_xor_chain.vuma — (0x40 | 0x03) ^ 0x10 = 0x43 ^ 0x10 = 0x53 = 83
// Expected exit code: 83
//
// OR then XOR with a high-bit base. (64 | 3) = 67 (0x43); 67 ^ 16 = 83
// (0x53). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s18_crypto_high_nibble_extract
// (extract framing) and s14_crypto_or_low_high (or low/high).

fn main() -> i32 {
    a: u64 = 64;          // 0x40
    b: u64 = 3;           // 0x03
    c: u64 = 16;          // 0x10
    x: u64 = a | b;       // 0x43 = 67
    r: u64 = x ^ c;       // 0x53 = 83
    return r;
}
