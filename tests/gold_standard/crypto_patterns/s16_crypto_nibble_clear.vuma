// s16_crypto_nibble_clear.vuma — 0xAB & 0x0F = 0x0B = 11
// Expected exit code: 11
//
// AND-mask clears the high nibble, leaving the low nibble. 171 & 15 = 11
// (0x0B). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s9_crypto_nibble_clear
// (uses 0xF0 mask, clears low nibble) and s14_crypto_low_nibble (extract
// low nibble, different operand).

fn main() -> i32 {
    v: u64 = 171;          // 0xAB
    m: u64 = 15;           // 0x0F
    r: u64 = v & m;        // 0x0B = 11
    return r;
}
