// s26_crypto_nibble_swap.vuma — swap nibbles of 0x3C -> 0xC3 = 195
// Expected exit code: 195
//
// Nibble swap. ((0x3C & 0x0F) << 4) | ((0x3C & 0xF0) >> 4) = 0xC0 | 0x03
// = 0xC3 = 195. All operands loaded into u64 variables first. Distinct
// from s22_crypto_nibble_swap (swap of 0x5A, value 0xA5) and
// s18_crypto_high_nibble_extract (extract high nibble).

fn main() -> i32 {
    v: u64 = 60;          // 0x3C
    lo_mask: u64 = 15;    // 0x0F
    hi_mask: u64 = 240;   // 0xF0
    shift: u64 = 4;
    lo: u64 = v & lo_mask;     // 0x0C
    hi: u64 = v & hi_mask;     // 0x30
    lo_shl: u64 = lo << shift; // 0xC0
    hi_shr: u64 = hi >> shift; // 0x03
    r: u64 = lo_shl | hi_shr;  // 0xC3 = 195
    return r;
}
