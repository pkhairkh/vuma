// crypto_hash_mix.vuma — simple hash mix: (val << 3) ^ (val >> 5)
// Expected exit code: 42
//
// The "hash mix" idiom (Knuth multiplicative-style xorshift mixes)
// combines a left-shift and a right-shift with XOR to diffuse bit
// locality. With val = 69 (= 0b1000101):
//   val << 3 = 552 (0x228)
//   val >> 5 = 2
//   mix = 552 ^ 2 = 554 (0x22A)
//   low byte = 0x2A = 42
//
// VUMA codegen workaround: shifts with immediate RHS are dropped, so
// the shift amounts are loaded into named variables; the final byte
// mask is also loaded into a named variable.

fn main() -> i32 {
    val: u64 = 69;
    three: u64 = 3;
    five: u64 = 5;
    mFF: u64 = 0xFF;
    shl: u64 = val << three;       // 552
    shr: u64 = val >> five;        // 2
    mixed: u64 = shl ^ shr;        // 554
    result: u64 = mixed & mFF;     // 42
    return result;
}
