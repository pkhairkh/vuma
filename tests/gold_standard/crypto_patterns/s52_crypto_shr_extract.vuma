// s52_crypto_shr_extract.vuma — 0xFF >> 2 = 0x3F = 63
// Expected exit code: 63
//
// Shift 0xFF right by 2 to extract the high 6 bits. 255 >> 2 = 63
// (0x3F). All operands loaded into u64 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s50_crypto_shr_
// extract (15) and s47_crypto_shl_extract (144).

fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 2;
    r: u64 = a >> b;       // 0x3F = 63
    return r;
}
