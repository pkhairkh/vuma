// s21_crypto_shr_extract.vuma — (0x3C >> 2) = 0x0F = 15
// Expected exit code: 15
//
// Extract the low nibble of 0x3C (60) by shifting right 2. The shift
// amount is loaded into a variable first to dodge the immediate-RHS
// bitwise drop bug. Distinct from s18_crypto_high_nibble_extract
// (high-nibble extract via >> 4 of 0xAB) and s14_crypto_low_nibble
// (low-nibble via & 0x0F).

fn main() -> i32 {
    v: u64 = 60;          // 0x3C
    s: u64 = 2;
    r: u64 = v >> s;      // 0x0F = 15
    return r;
}
