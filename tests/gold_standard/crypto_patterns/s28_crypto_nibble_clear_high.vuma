// s28_crypto_nibble_clear_high.vuma — 0xAB & 0x0F = 0x0B = 11
// Expected exit code: 11
//
// Clear high nibble. 171 & 15 = 11 (0x0B). Mask keeps only the low
// nibble of 0xAB. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s26_crypto_nibble_swap (nibble-swap, 195) and s22_crypto_high_nibble
// (high-nibble extract).

fn main() -> i32 {
    a: u64 = 171;         // 0xAB
    b: u64 = 15;          // 0x0F
    r: u64 = a & b;       // 0x0B = 11
    return r;
}
