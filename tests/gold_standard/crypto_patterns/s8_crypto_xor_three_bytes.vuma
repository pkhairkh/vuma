// s8_crypto_xor_three_bytes.vuma — 0x12 ^ 0x34 ^ 0x56 = 0x70 = 112
// Expected exit code: 112
//
// Three-byte XOR chain: 18 (0x12) ^ 52 (0x34) = 38 (0x26),
// 38 ^ 86 (0x56) = 112 (0x70). All operands loaded into variables
// first. Distinct from s6_crypto_xor_chain_3 (different operand
// values) and s6_crypto_xor_pairs (two-byte XOR).

fn main() -> i32 {
    a: u64 = 18;       // 0x12
    b: u64 = 52;       // 0x34
    c: u64 = 86;       // 0x56
    x: u64 = a ^ b;    // 0x26 = 38
    y: u64 = x ^ c;    // 0x70 = 112
    return y;
}
