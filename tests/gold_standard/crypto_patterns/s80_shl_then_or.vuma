// s80_crypto_shl_then_or.vuma — (0x00 << 0) | 0x16 = 0x00 | 0x16 = 0x16 = 22
// Expected exit code: 22
//
// Two-stage crypto op: shift left then OR. (0 << 0) = 0
// (0x00); 0 | 22 = 22 (0x16). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_crypto_and_then_shl (4),
// s74_crypto_or_then_and (180) and s73_crypto_xor_pair (220).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 0;
    c: u64 = 22;           // 0x16
    x: u64 = a << b;       // 0x00 = 0
    r: u64 = x | c;        // 0x16 = 22
    return r;
}
