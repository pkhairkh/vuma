// s20_crypto_xor_pair_mask.vuma — (0xC3 ^ 0x18) & 0xF0 = 0xDB & 0xF0 = 0xD0 = 208
// Expected exit code: 208
//
// XOR two bytes then mask to the high nibble. (195 ^ 24) = 219 (0xDB);
// 219 & 240 = 208 (0xD0). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s18_crypto_xor_pair (pure XOR, no mask) and s17_crypto_xor_pair_then_mask
// (mask to 0xFF, identity).

fn main() -> i32 {
    a: u64 = 195;         // 0xC3
    b: u64 = 24;          // 0x18
    m: u64 = 240;         // 0xF0
    x: u64 = a ^ b;       // 0xDB = 219
    r: u64 = x & m;       // 0xD0 = 208
    return r;
}
