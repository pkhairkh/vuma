// s70_crypto_xor_pair.vuma — 0x6F ^ 0x45 = 0x2A = 42
// Expected exit code: 42
//
// Two-byte XOR. 111 ^ 69 = 42 (0x2A). Mid-bit pair (0x6F / 0x45)
// produces the byte 0x2A. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_crypto_xor_pair (249), s65_crypto_xor_pair (173) and
// s62_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 111;          // 0x6F
    b: u64 = 69;           // 0x45
    r: u64 = a ^ b;        // 0x2A = 42
    return r;
}
