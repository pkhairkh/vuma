// s9_crypto_shl_mask_byte.vuma — (0x3 << 4) & 0xFF = 0x30 = 48
// Expected exit code: 48
//
// Shift 0x03 left by 4 bits -> 0x30 (48), then mask to a single
// byte with 0xFF. Exercises the "shift a nibble into the high
// half" pattern used in many byte-construction routines. All
// operands loaded into variables first. Distinct from
// s5_crypto_nibble_extract (extracts, doesn't construct).

fn main() -> i32 {
    v: u64 = 3;
    sh: u64 = 4;
    mask: u64 = 255;        // 0xFF
    shifted: u64 = v << sh; // 0x30 = 48
    r: u64 = shifted & mask;// 0x30 = 48
    return r;
}
