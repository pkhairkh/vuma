// s39_crypto_shl_then_xor.vuma — (1 << 6) ^ 0x09 = 64 ^ 9 = 73
// Expected exit code: 73
//
// Shift-then-XOR mixing step. (1 << 6) = 64 (0x40); 64 ^ 9 = 73
// (0x49). All operands loaded into u64 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s38_crypto_shl_
// xor (1<<5 ^ 0x05 = 37) and s34_crypto_shl_then_xor (186).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 6;
    c: u64 = 9;            // 0x09
    s: u64 = a << b;       // 64
    r: u64 = s ^ c;        // 73
    return r;
}
