// s94_crypto_or_then_and.vuma — (0xA0 | 0x50) & 0x33 = 0xF0 & 0x33 = 0x30 = 48
// Expected exit code: 48
//
// Two-stage crypto mix: OR then AND. (160 | 80) = 240 (0xF0);
// 240 & 51 = 48 (0x30). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_crypto_and_then_xor (27), s86_crypto_and_then_xor (63) and
// s82_crypto_and_then_or (37).
fn main() -> i32 {
    a: u32 = 160;          // 0xA0
    b: u32 = 80;           // 0x50
    c: u32 = 51;           // 0x33
    x: u32 = a | b;        // 0xF0 = 240
    r: u32 = x & c;        // 0x30 = 48
    return r;
}
