// s86_crypto_and_then_xor.vuma — (0xFF & 0x0F) ^ 0x30 = 0x0F ^ 0x30 = 0x3F = 63
// Expected exit code: 63
//
// AND 0xFF with 0x0F -> 0x0F = 15, then XOR with 0x30 -> 0x3F
// = 63. All operands loaded into u32 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s82_crypto_
// and_then_or (60), s78_crypto_and_then_xor (200) and s74_crypto_
// and_then_xor (140).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 15;           // 0x0F
    c: u32 = 48;           // 0x30
    x: u32 = a & b;        // 0x0F = 15
    r: u32 = x ^ c;        // 0x3F = 63
    return r;
}
