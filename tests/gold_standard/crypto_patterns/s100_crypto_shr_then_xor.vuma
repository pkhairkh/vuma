// s100_crypto_shr_then_xor.vuma — (0xF0 >> 2) ^ 0x05 = 0x3C ^ 0x05 = 0x39 = 57
// Expected exit code: 57
//
// Two-stage crypto mix: shift-right then XOR. (240 >> 2) =
// 60 (0x3C); 60 ^ 5 = 57 (0x39). All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_crypto_shr_then_xor (67), s94_crypto_and_then_shr (30), s90_crypto_and_then_xor (27).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    s: u32 = 2;
    b: u32 = 5;            // 0x05
    x: u32 = a >> s;       // 0x3C = 60
    r: u32 = x ^ b;        // 0x39 = 57
    return r;
}
