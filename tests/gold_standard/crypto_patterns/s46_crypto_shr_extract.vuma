// s46_crypto_shr_extract.vuma — 0xB4 >> 4 = 0x0B = 11
// Expected exit code: 11
//
// Right-shift extract of the high nibble. 180 >> 4 = 11 (0x0B). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s42_crypto_shl_xor (47) and
// s38_crypto_shl_xor.

fn main() -> i32 {
    a: u64 = 180;          // 0xB4
    b: u64 = 4;
    r: u64 = a >> b;       // 0x0B = 11
    return r;
}
