// s80_crypto_xor_then_shr.vuma — (0x08 ^ 0x10) >> 0 = 0x18 >> 0 = 0x18 = 24
// Expected exit code: 24
//
// Two-stage crypto op: XOR then shift right. (8 ^ 16) = 24
// (0x18); 24 >> 0 = 24 (0x18). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_crypto_xor_then_shr (1),
// s74_crypto_xor_then_shr (39) and s73_crypto_shl_then_xor (65).
fn main() -> i32 {
    a: u64 = 8;            // 0x08
    b: u64 = 16;           // 0x10
    c: u64 = 0;
    x: u64 = a ^ b;        // 0x18 = 24
    r: u64 = x >> c;       // 0x18 = 24
    return r;
}
