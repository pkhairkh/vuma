// s95_crypto_xor_then_and.vuma — (0xAA ^ 0x55) & 0x0E = 0xFF & 0x0E = 0x0E = 14
// Expected exit code: 14
//
// Two-stage crypto mix: XOR then AND. (170 ^ 85) = 255 (0xFF);
// 255 & 14 = 14 (0x0E). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_xor_then_or (255), s90_crypto_xor_then_shr (17) and
// s82_crypto_xor_then_and (85).
fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 85;           // 0x55
    c: u32 = 14;           // 0x0E
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0x0E = 14
    return r;
}
