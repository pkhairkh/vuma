// s4_crypto_xor_round.vuma — two-round XOR: a^k1^k2, then XOR back
// Expected exit code: 100
//
// Simulates a two-round XOR cipher round: ciphertext = a ^ k1 ^ k2,
// then decrypt = ciphertext ^ k2 ^ k1 should yield a again.
// Here a = 100, k1 = 0xAA (170), k2 = 0x55 (85).
// 100 ^ 170 ^ 85 ^ 85 ^ 170 = 100 ^ 0 = 100. All operands loaded
// into variables to dodge the immediate-RHS bitwise drop bug.

fn main() -> i32 {
    a: u64 = 100;
    k1: u64 = 170;    // 0xAA
    k2: u64 = 85;     // 0x55
    c1: u64 = a ^ k1;
    cipher: u64 = c1 ^ k2;
    d1: u64 = cipher ^ k2;
    plain: u64 = d1 ^ k1;
    return plain;
}
