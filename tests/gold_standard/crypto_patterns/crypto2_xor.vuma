// crypto2_xor.vuma — XOR: 0xFF ^ 0xFA = 0x05
// Expected exit code: 5
//
// The XOR primitive underlies every stream cipher (CTR mode, ChaCha,
// one-time pads) and every differential side-channel countermeasure.
// Both operands are loaded into named variables first because VUMA
// codegen drops bitwise ops with an immediate RHS. 255 ^ 250 = 5.

fn main() -> i32 {
    a: u64 = 0xFF;
    b: u64 = 0xFA;
    c: u64 = a ^ b;       // 0xFF ^ 0xFA = 0x05
    return c;
}
