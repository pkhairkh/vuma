// s42_crypto_shl_xor.vuma — (1 << 5) ^ 0x0F = 32 ^ 15 = 47
// Expected exit code: 47
//
// Two-stage mix: shift left then XOR. (1 << 5) = 32 (0x20);
// 32 ^ 15 = 47 (0x2F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_crypto_shl_xor and s34_crypto_shl_then_xor.

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 15;           // 0x0F
    s: u64 = a << b;       // 32
    r: u64 = s ^ c;        // 47
    return r;
}
