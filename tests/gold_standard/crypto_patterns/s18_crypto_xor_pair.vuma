// s18_crypto_xor_pair.vuma — 0xA5 ^ 0x3C = 0x99 = 153
// Expected exit code: 153
//
// Two-byte XOR with distinct high-bit-set key. (165 ^ 60) = 153
// (0x99). The mask is loaded into a variable first to dodge the
// immediate-RHS bitwise drop bug. Distinct from s14_crypto_xor_two_keys
// (three-way XOR, different values) and s13_crypto_xor_pair
// (0xC3 ^ 0x55 = 0x96 = 150).

fn main() -> i32 {
    v: u64 = 165;         // 0xA5
    k: u64 = 60;          // 0x3C
    r: u64 = v ^ k;       // 0x99 = 153
    return r;
}
