// s89_crypto_xor_pair.vuma — 0xA5 ^ 0xB8 = 0x1D = 29
// Expected exit code: 29
//
// XOR two byte constants: 165 ^ 184 = 29 (0x1D). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s86_crypto_xor_pair (153),
// s82_crypto_xor_then_and (76) and s78_crypto_xor_pair (90).
fn main() -> i32 {
    a: u32 = 165;          // 0xA5
    b: u32 = 184;          // 0xB8
    r: u32 = a ^ b;        // 0x1D = 29
    return r;
}
