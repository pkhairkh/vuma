// s104_crypto_xor_then_or.vuma — (0x1A ^ 0x08) | 0x80 = 0x12 | 0x80 = 0x92 = 146
// Expected exit code: 146
//
// Two-stage crypto mix: XOR then OR. (26 ^ 8) = 18 (0x12); 18 | 128 = 146 (0x92). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_crypto_or_then_shl (68), s102_crypto_shr_then_xor (59), s102_crypto_xor_then_and (55).
fn main() -> i32 {
    a: u32 = 26;          // 0x1A
    b: u32 = 8;          // 0x08
    c: u32 = 128;          // 0x80
    x: u32 = a ^ b;        // 0x12 = 18
    r: u32 = x | c;        // 0x92 = 146
    return r;
}
