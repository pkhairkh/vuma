// s5_crypto_parity_xor.vuma — fold 4 bytes via XOR = 0x12 ^ 0x34 ^ 0x56 ^ 0x78 = 0x08 = 8
// Expected exit code: 8
//
// Four-byte XOR fold (a simple checksum). 0x12 ^ 0x34 = 0x26.
// 0x26 ^ 0x56 = 0x70. 0x70 ^ 0x78 = 0x08. All four operands loaded
// into variables first to dodge the immediate-RHS bitwise drop bug.

fn main() -> i32 {
    a: u64 = 18;    // 0x12
    b: u64 = 52;    // 0x34
    c: u64 = 86;    // 0x56
    d: u64 = 120;   // 0x78
    t1: u64 = a ^ b;   // 0x26 = 38
    t2: u64 = t1 ^ c;  // 0x70 = 112
    r: u64 = t2 ^ d;   // 0x08 = 8
    return r;
}
