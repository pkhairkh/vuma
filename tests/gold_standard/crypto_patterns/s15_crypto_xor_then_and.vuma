// s15_crypto_xor_then_and.vuma — ((0xAB ^ 0x0F) & 0xF0) = 0xA0 = 160
// Expected exit code: 160
//
// Two-stage crypto-style mix. (171 ^ 15) = 164 (0xA4); 164 & 240 = 160
// (0xA0). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s14_crypto_xor_two_keys
// (two-key XOR chain) and s11_crypto_xor_then_shl (XOR-then-shift).

fn main() -> i32 {
    v: u64 = 171;         // 0xAB
    k: u64 = 15;          // 0x0F
    m: u64 = 240;         // 0xF0
    x: u64 = v ^ k;       // 0xA4 = 164
    r: u64 = x & m;       // 0xA0 = 160
    return r;
}
