// crypto2_or.vuma — OR: 0xF0 | 0x0F = 0xFF
// Expected exit code: 255
//
// Bitwise-OR assembles two half-byte masks into a full byte. Both
// operands are loaded into named variables first because VUMA codegen
// drops bitwise ops with an immediate RHS. 240 | 15 = 255.

fn main() -> i32 {
    a: u64 = 0xF0;
    b: u64 = 0x0F;
    c: u64 = a | b;       // 0xF0 | 0x0F = 0xFF
    return c;
}
