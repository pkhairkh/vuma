// Test: SHA-256 compression round simulation (simplified)
// Tests u32 arithmetic with memory loads/stores and function calls
// Expected: exit 79
// Expected exit code: 164

fn ch(x: u32, y: u32, z: u32) -> u32 {
    return (x & y) ^ ((!x) & z);
}

fn maj(x: u32, y: u32, z: u32) -> u32 {
    return (x & y) ^ (x & z) ^ (y & z);
}

fn rotr(x: u32, n: u32) -> u32 {
    return (x >> n) | (x << (32 - n));
}

fn sigma0(x: u32) -> u32 {
    return rotr(x, 2) ^ rotr(x, 13) ^ rotr(x, 22);
}

fn sigma1(x: u32) -> u32 {
    return rotr(x, 6) ^ rotr(x, 11) ^ rotr(x, 25);
}

fn main() -> u64 {
    // Simulate one round of SHA-256 compression with known values
    h0: u32 = 0x6a09e667;
    h1: u32 = 0xbb67ae85;
    h2: u32 = 0x3c6ef372;
    h3: u32 = 0xa54ff53a;
    h4: u32 = 0x510e527f;
    h5: u32 = 0x9b05688c;
    h6: u32 = 0x1f83d9ab;
    h7: u32 = 0x5be0cd19;

    // K[0] = 0x428a2f98, W[0] = 0x61626380 (padded "abc")
    k: u32 = 0x428a2f98;
    w: u32 = 0x61626380;

    // T1 = h7 + sigma1(h4) + ch(h4, h5, h6) + k + w
    s1: u32 = sigma1(h4);
    c: u32 = ch(h4, h5, h6);
    t1: u32 = h7 + s1 + c + k + w;

    // T2 = sigma0(h0) + maj(h0, h1, h2)
    s0: u32 = sigma0(h0);
    m: u32 = maj(h0, h1, h2);
    t2: u32 = s0 + m;

    // New state after round 0
    new_h3: u32 = t1;
    new_h0: u32 = t1 + t2;

    // Return low byte of new_h0
    // The expected new_h0 after first round of SHA-256 on "abc":
    // We'll check by returning the full value as exit code (low byte)
    result: u32 = new_h0 & 0xFF;
    return result;
}
