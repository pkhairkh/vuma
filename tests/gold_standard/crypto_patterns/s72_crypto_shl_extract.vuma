// s72_crypto_shl_extract.vuma — (0x05 << 4) ^ 0x12 = 0x50 ^ 0x12 = 0x42 = 66
// Expected exit code: 66
//
// Two-stage crypto op: shift left then XOR. (5 << 4) = 80 (0x50);
// 80 ^ 18 = 66 (0x42). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_crypto_shr_xor (231), s69_crypto_shl_mask (192) and
// s66_crypto_shr_extract (10).
fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 4;
    c: u64 = 18;           // 0x12
    x: u64 = a << b;       // 0x50 = 80
    r: u64 = x ^ c;        // 0x42 = 66
    return r;
}
