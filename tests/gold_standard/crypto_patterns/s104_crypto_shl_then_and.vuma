// s104_crypto_shl_then_and.vuma — (0x13 << 2) & 0x7C = 0x4C & 0x7C = 0x4C = 76
// Expected exit code: 76
//
// Two-stage crypto mix: shift-left then AND. (19 << 2) = 76 (0x4C); 76 & 124 = 76 (0x4C). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_crypto_or_then_shl (68), s102_crypto_shr_then_xor (59), s102_crypto_xor_then_and (55).
fn main() -> i32 {
    a: u32 = 19;          // 0x13
    b: u32 = 124;          // 0x7C
    c: u32 = 2;
    s: u32 = a << c;       // 0x4C = 76
    r: u32 = s & b;        // 0x4C = 76
    return r;
}
