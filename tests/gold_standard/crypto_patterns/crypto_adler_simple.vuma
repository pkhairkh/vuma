// crypto_adler_simple.vuma — simplified Adler-32 checksum (single value)
// Expected exit code: 42
//
// Adler-32 is Fletcher's checksum with a non-zero initial sum1 = 1 and
// a modulus of 65521 (the largest prime < 2^16). For a single byte v:
//   a = (1 + v) mod 65521
//   b = (0 + a) mod 65521 = a
//   result = (b << 16) | a
// With v = 41: a = 42, b = 42. The low byte of the result is 0x2A = 42.
// The modular reduction and high 16 bits are omitted here for clarity.

fn main() -> i32 {
    v: u64 = 41;
    one: u64 = 1;
    mFF: u64 = 0xFF;
    a: u64 = one + v;              // 1 + 41 = 42
    b: u64 = a;                    // 0 + a = 42
    result: u64 = b & mFF;         // low byte of b = 42
    return result;
}
