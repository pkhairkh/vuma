// s58_crypto_xor_pair.vuma — 0x5A ^ 0xA5 = 0xFF = 255
// Expected exit code: 255
// 
// Two-byte XOR. 90 ^ 165 = 255 (0xFF). Complementary-bit pair
// (0x5A / 0xA5) produces the all-ones 0xFF pattern. All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s51_crypto_xor_pair (85), s51_crypto_
// shl_mask (176) and s51_crypto_and_then_xor (195).

fn main() -> i32 {
    a: u64 = 90;           // 0x5A
    b: u64 = 165;          // 0xA5
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
