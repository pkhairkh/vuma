// s67_ptr_single_store_load.vuma — store 185, load 185
// Expected exit code: 185
//
// Single 8-byte cell. Store 185 via `*p = literal`, load and
// return 185. Uses `*ptr = literal` form. Distinct from s66_
// ptr_single_store_load (195), s62_ptr_single_store_load
// (165) and s58_ptr_single_store_load (155).
fn main() -> i32 {
    p = allocate(8);
    *p = 185;
    r: i32 = *p;
    free(p);
    return r;
}
