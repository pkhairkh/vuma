// s4_ptr_two_buf_roundtrip.vuma — store in buf1, load, store literal in buf2
// Expected exit code: 110  (55 + 55)
//
// Two independent allocations. Store 55 in buf1, load it, store the
// literal 55 in buf2 (avoiding `*ptr = variable`), load buf2, sum
// both loads. Tests that two allocations do not alias.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *buf1 = 55;
    v1: i32 = *buf1;
    *buf2 = 55;
    v2: i32 = *buf2;
    s: i32 = v1 + v2;
    free(buf1);
    free(buf2);
    return s;
}
