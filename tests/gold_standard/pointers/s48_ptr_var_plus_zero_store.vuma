// s48_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 185
// Expected exit code: 185
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 185 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 185 (the overwritten value).
// Distinct from s46_ptr_var_plus_zero_store (175) and s42_ptr_var_
// plus_zero_store (145).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 185;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
