// s62_ptr_two_cell_diff.vuma — two cells, diff = 140 (200 - 60)
// Expected exit code: 140
// 
// Two 8-byte cells. Store 200/60 via `*ptr = literal`, load both,
// subtract -> 140. Uses `*ptr = literal` form. Distinct from s51_ptr_
// two_cell_diff (70), s58_ptr_two_cell_sum (190) and s55_ptr_two_
// cell_sum (175).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 60;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 140
    free(p1);
    free(p2);
    return d;
}
