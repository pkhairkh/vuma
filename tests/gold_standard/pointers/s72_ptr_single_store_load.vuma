// s72_ptr_single_store_load.vuma — store 130, load 130
// Expected exit code: 130
//
// Single 8-byte cell. Store 130 via `*p = literal`, load and
// return 130. Uses `*ptr = literal` form. Distinct from s70_ptr_
// single_store_load (100), s69_ptr_single_store_load (225) and
// s66_ptr_single_store_load (195).
fn main() -> i32 {
    p = allocate(8);
    *p = 130;
    r: i32 = *p;
    free(p);
    return r;
}
