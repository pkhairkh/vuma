// s70_ptr_two_cell_sum.vuma — two cells, sum = 160 (90 + 70)
// Expected exit code: 160
//
// Two 8-byte cells. Store 90/70 via `*ptr = literal`, load both,
// sum -> 160. Uses `*ptr = literal` form. Distinct from s66_ptr_
// two_cell_sum (200), s65_ptr_two_cell_sum (220) and s62_ptr_two_
// cell_diff (140).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 70;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 160
    free(p1);
    free(p2);
    return s;
}
