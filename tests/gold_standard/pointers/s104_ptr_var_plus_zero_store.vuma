// s104_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 61
// Expected exit code: 61
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 61 into a local, then overwrite the cell via `*p = variable + 0` (the documented workaround for the silent-drop bug on `*p = variable`). Load and return 61 (the overwritten value). Straight-line code only.
// Distinct from s102_ptr_single_store_load (6), s102_ptr_two_cell_diff (127), s102_ptr_var_plus_zero_store (7).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 61;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
