// s102_ptr_single_store_load.vuma — store 6, load = 6
// Expected exit code: 6
//
// Single 8-byte cell. Store 6 via `*ptr = literal`, load and return 6. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_ptr_single_store_load (67), s101_ptr_two_cell_or (192), s101_ptr_var_plus_zero_store (88).
fn main() -> i32 {
    p = allocate(8);
    *p = 6;
    r: i32 = *p;
    free(p);
    return r;
}
