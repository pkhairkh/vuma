// s87_ptr_single_store_load.vuma — store 165, load = 165
// Expected exit code: 165
//
// Single 8-byte cell. Store 165 via `*p = literal`, load and
// return 165. Uses `*p = literal` form (no offsets). Distinct
// from s86_ptr_single_store_load (180), s82_ptr_single_store_
// load (35) and s78_ptr_single_store_load (1).
fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    v: i32 = *p;
    free(p);
    return v;
}
