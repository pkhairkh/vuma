// s56_ptr_two_cell_sum.vuma — two cells, sum = 225 (95 + 130)
// Expected exit code: 225
//
// Two 8-byte cells. Store 95/130 via `*ptr = literal`, load both,
// sum -> 225. Uses `*ptr = literal` form. Distinct from s54_ptr_two_
// cell_sum (245) and s50_ptr_two_cell_sum (215).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 130;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 225
    free(p1);
    free(p2);
    return s;
}
