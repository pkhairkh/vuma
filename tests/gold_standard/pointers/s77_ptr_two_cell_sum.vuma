// s77_ptr_two_cell_sum.vuma — two cells, sum = 176 (120 + 56)
// Expected exit code: 176
//
// Two 8-byte cells. Store 120/56 via `*p = literal`, load both,
// sum -> 176. Uses `*p = literal` form (no offsets). Distinct
// from s70_ptr_two_cell_sum (160), s66_ptr_two_cell_diff (178)
// and s74_ptr_two_cell_sum (71).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 120;
    *p2 = 56;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 176
    free(p1);
    free(p2);
    return s;
}
