// s57_ptr_single_store_load.vuma — store/load 165 via single cell
// Expected exit code: 165
//
// Single 8-byte cell. Store 165 via `*p = 165`, load via `*p`,
// return 165. Uses `*p = literal` form. Distinct from s54_ptr_
// single_store_load (175) and s50_ptr_single_store_load (155).

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    v: i32 = *p;
    free(p);
    return v;
}
