// ptr_alloc_sizes.vuma — various allocation sizes (8, 16, 32, 64)
// Expected exit code: 42
//
// Allocates buffers of sizes 8, 16, 32, and 64 bytes. Stores 42 in
// each (at offset 0 via *buf). Loads from the 64-byte buffer and
// returns it. Verifies that allocate(N) accepts varying N and that
// offset-0 stores work regardless of buffer size.

fn main() -> i32 {
    b8 = allocate(8);
    b16 = allocate(16);
    b32 = allocate(32);
    b64 = allocate(64);
    *b8 = 42;
    *b16 = 42;
    *b32 = 42;
    *b64 = 42;
    val: i32 = *b64;
    free(b8);
    free(b16);
    free(b32);
    free(b64);
    return val;
}
