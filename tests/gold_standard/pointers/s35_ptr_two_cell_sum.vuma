// s35_ptr_two_cell_sum.vuma — two cells, sum = 210 (95 + 115)
// Expected exit code: 210
//
// Two 8-byte cells. Store 95/115 via `*ptr = literal`, load both,
// sum -> 210. Uses `*ptr = literal` form (no offsets). All operands
// loaded into typed locals before the add. Distinct from s34_ptr_
// two_cell_diff (diff, 120) and s30_ptr_two_cell_xor (xor, 102).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 115;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 210
    free(p1);
    free(p2);
    return s;
}
