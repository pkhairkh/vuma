// s30_ptr_two_cell_xor.vuma — two cells, xor = 102 (0x44 ^ 0x22 = 0x66)
// Expected exit code: 102
//
// Two 8-byte cells. Store 0x44/0x22 via `*ptr = literal`, load both, XOR
// -> 102. Uses `*ptr = literal` form (no offsets). All operands loaded
// into typed locals before the XOR. Distinct from s26_ptr_two_cell_xor
// (different pair) and s22_ptr_two_cell_diff (sub).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 68;            // 0x44
    *p2 = 34;            // 0x22
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a ^ b;       // 0x66 = 102
    free(p1);
    free(p2);
    return d;
}
