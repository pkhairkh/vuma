// s51_ptr_two_cell_diff.vuma — two cells, diff = 70 (165 - 95)
// Expected exit code: 70
//
// Two 8-byte cells. Store 165/95 via `*ptr = literal`, load both,
// subtract -> 70. Uses `*ptr = literal` form. Distinct from s50_ptr_
// two_cell_sum (215) and s47_ptr_two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 165;
    *p2 = 95;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 70
    free(p1);
    free(p2);
    return d;
}
