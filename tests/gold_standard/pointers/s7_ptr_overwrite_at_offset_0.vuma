// s7_ptr_overwrite_at_offset_0.vuma — store 11, overwrite with 99, load = 99
// Expected exit code: 99
//
// Single 16-byte buffer. Store 11 via `*p`, then overwrite with 99
// via `*p`. Load via `*p` -> 99. Tests that a second store to the
// same pointer correctly overwrites the first. Distinct from
// s6_ptr_alias_two (two aliases, last-write-wins via aliasing) and
// s4_ptr_overwrite_chain (chain of overwrites).

fn main() -> i32 {
    p = allocate(16);
    *p = 11;
    *p = 99;
    v: i32 = *p;
    free(p);
    return v;
}
