// s32_ptr_var_plus_zero_store.vuma - store via *p = v + 0 = 140
// Expected exit code: 140
//
// store via *p = v + 0 = 140. All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_ptr_var_plus_zero_store
// (value 91) and s26_ptr_var_plus_zero_store (value 75).

fn main() -> i32 {
    p = allocate(8);
    *p = 12;
    v: i32 = 140;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
