// s104_ptr_single_store_load.vuma — store 34, load = 34
// Expected exit code: 34
//
// Single 8-byte cell. Store 34 via `*ptr = literal`, load and return 34. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ptr_single_store_load (6), s102_ptr_two_cell_diff (127), s102_ptr_var_plus_zero_store (7).
fn main() -> i32 {
    p = allocate(8);
    *p = 34;
    r: i32 = *p;
    free(p);
    return r;
}
