// s84_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 36
// Expected exit code: 36
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 36
// into a local, then overwrite the cell via `*p = variable + 0`
// (the documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 36 (the overwritten value).
// Distinct from s82_ptr_var_plus_zero_store (95), s78_ptr_var_
// plus_zero_store (3) and s74_ptr_var_plus_zero_store (223).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 36;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
