// s78_ptr_two_cell_diff.vuma — two cells, diff = 2 (3 - 1)
// Expected exit code: 2
//
// Two 8-byte cells. Store 3/1 via `*ptr = literal`, load both,
// a - b -> 2. Uses `*ptr = literal` form (no offsets). Distinct
// from s74_ptr_two_cell_diff (60), s73_ptr_two_cell_diff (90) and
// s72_ptr_two_cell_diff (40).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 3;
    *p2 = 1;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 2
    free(p1);
    free(p2);
    return d;
}
