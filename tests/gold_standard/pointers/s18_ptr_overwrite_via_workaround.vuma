// s18_ptr_overwrite_via_workaround.vuma — overwrite via *p = variable + 0 = 84
// Expected exit code: 84
//
// Single 8-byte cell. Store literal 13 via `*p = 13`. Load 84 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 84 (the overwritten value). Distinct from
// s14_ptr_overwrite_via_workaround (7 then 77) and
// s9_ptr_overwrite_via_workaround (10 then 20).

fn main() -> i32 {
    p = allocate(8);
    *p = 13;
    v: i32 = 84;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
