// s95_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 29
// Expected exit code: 29
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 29 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 29 (the overwritten value). Distinct
// from s94_ptr_var_plus_zero_store (117),
// s90_ptr_var_plus_zero_store (46) and s82_ptr_var_plus_zero_store
// (95).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 29;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
