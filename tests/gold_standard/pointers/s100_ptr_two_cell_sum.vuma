// s100_ptr_two_cell_sum.vuma — two cells, sum = 37 (18 + 19)
// Expected exit code: 37
//
// Two 8-byte cells. Store 18/19 via `*ptr = literal`, load
// both, a + b -> 37. Uses `*ptr = literal` form.
// Distinct from s97_ptr_single_store_load (4), s94_ptr_two_cell_sum (130), s90_ptr_single_store_load (45).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 18;
    *p2 = 19;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 37
    free(p1);
    free(p2);
    return s;
}
