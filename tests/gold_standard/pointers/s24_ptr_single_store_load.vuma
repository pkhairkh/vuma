// s24_ptr_single_store_load.vuma — store 71, load 71
// Expected exit code: 71
//
// Single 8-byte cell. Store literal 71, load back, return. Most basic
// store-load round trip via pointer. Distinct from
// s22_ptr_single_store_load (value 78) and s18_ptr_single_store_load
// (value 67).

fn main() -> i32 {
    p = allocate(8);
    *p = 71;
    v: i32 = *p;
    free(p);
    return v;
}
