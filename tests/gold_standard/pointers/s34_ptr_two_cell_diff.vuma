// s34_ptr_two_cell_diff.vuma — two cells, diff = 120 (180 - 60)
// Expected exit code: 120
//
// Two 8-byte cells. Store 180/60 via `*ptr = literal`, load both,
// subtract -> 120. Uses `*ptr = literal` form (no offsets). All
// operands loaded into typed locals before the subtract. Distinct
// from s30_ptr_two_cell_xor (xor, 102) and s27_ptr_two_cell_diff
// (different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 180;
    *p2 = 60;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 120
    free(p1);
    free(p2);
    return d;
}
