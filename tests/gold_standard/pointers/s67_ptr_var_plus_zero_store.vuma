// s67_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 240
// Expected exit code: 240
//
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 240
// into a local, then overwrite the cell via `*p = variable +
// 0` (the documented workaround for the silent-drop bug on
// `*p = variable`). Load and return 240 (the overwritten
// value). Distinct from s66_ptr_var_plus_zero_store (215),
// s62_ptr_var_plus_zero_store (188) and s58_ptr_var_plus_
// zero_store (205).
fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 240;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
