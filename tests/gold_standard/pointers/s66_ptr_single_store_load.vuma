// s66_ptr_single_store_load.vuma — store 195, load 195
// Expected exit code: 195
//
// Single 8-byte cell. Store 195 via `*p = literal`, load and
// return 195. Uses `*ptr = literal` form. Distinct from s62_ptr_
// single_store_load (165), s58_ptr_single_store_load (155) and
// s55_ptr_single_store_load (185).
fn main() -> i32 {
    p = allocate(8);
    *p = 195;
    r: i32 = *p;
    free(p);
    return r;
}
