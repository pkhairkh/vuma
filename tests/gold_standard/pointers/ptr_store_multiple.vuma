// ptr_store_multiple.vuma — store 3 values, load and sum
// Expected exit code: 3
//
// Stores the value 1 in three separate buffers (each at offset 0 via
// *buf), loads all three back, and returns their sum (1+1+1 = 3).
// Uses *buf (offset 0) per the test harness constraints, simulating
// the multi-offset pattern with one buffer per value.

fn main() -> i32 {
    b0 = allocate(8);
    b1 = allocate(8);
    b2 = allocate(8);
    *b0 = 1;
    *b1 = 1;
    *b2 = 1;
    v0: i32 = *b0;
    v1: i32 = *b1;
    v2: i32 = *b2;
    sum: i32 = v0 + v1 + v2;
    free(b0);
    free(b1);
    free(b2);
    return sum;
}
