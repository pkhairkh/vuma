// s96_ptr_two_cell_sum.vuma — two cells, sum = 148 (70 + 78)
// Expected exit code: 148
//
// Two 8-byte cells. Store 70/78 via `*ptr = literal`, load both,
// a + b -> 148. Uses `*ptr = literal` form. Distinct from
// s94_ptr_two_cell_sum (130), s90_ptr_two_cell_diff (28) and
// s86_ptr_two_cell_diff (215).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 70;
    *p2 = 78;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 148
    free(p1);
    free(p2);
    return s;
}
