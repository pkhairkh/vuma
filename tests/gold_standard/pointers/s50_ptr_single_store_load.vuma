// s50_ptr_single_store_load.vuma — store 155, load 155
// Expected exit code: 155
//
// Single 8-byte cell. Store 155 via `*p = literal`, load and return
// 155. Uses `*ptr = literal` form. Distinct from s46_ptr_single_
// store_load (165) and s43_ptr_basic_store_load (95).

fn main() -> i32 {
    p = allocate(8);
    *p = 155;
    r: i32 = *p;
    free(p);
    return r;
}
