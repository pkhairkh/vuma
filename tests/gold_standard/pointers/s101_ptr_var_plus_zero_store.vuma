// s101_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 88
// Expected exit code: 88
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 88 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 88 (the overwritten value). Distinct
// from s98_ptr_var_plus_zero_store (81),
// s97_ptr_var_plus_zero_store (13) and s94_ptr_var_plus_zero_store
// (117).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 88;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
