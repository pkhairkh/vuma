// s65_ptr_single_store_load.vuma — store 178, load = 178
// Expected exit code: 178
//
// Single 8-byte cell. Store 178 via `*p = literal`, load and return
// 178. Uses `*p = literal` form (no offsets). Distinct from s51_ptr_
// single_store_load (142), s58_ptr_single_store_load (155) and s62_
// ptr_single_store_load (165).

fn main() -> i32 {
    p = allocate(8);
    *p = 178;
    a: u64 = *p;
    free(p);
    return a;
}
