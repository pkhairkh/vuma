// s64_ptr_single_store_load.vuma — store 198, load 198
// Expected exit code: 198
//
// Single 8-byte cell. Store 198 via `*p = literal`, load and return
// 198. Uses `*ptr = literal` form. Distinct from s62_ptr_single_
// store_load (165), s62_ptr_two_cell_diff (140) and s62_ptr_var_plus_
// zero_store (188).

fn main() -> i32 {
    p = allocate(8);
    *p = 198;
    r: i32 = *p;
    free(p);
    return r;
}
