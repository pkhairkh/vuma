// s72_ptr_two_cell_sum.vuma — two cells, sum = 180 (95 + 85)
// Expected exit code: 180
//
// Two 8-byte cells. Store 95/85 via `*ptr = literal`, load both,
// sum -> 180. Uses `*ptr = literal` form. Distinct from s70_ptr_
// two_cell_sum (160), s69_ptr_two_cell_diff (145) and s66_ptr_
// two_cell_sum (200).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 85;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 180
    free(p1);
    free(p2);
    return s;
}
