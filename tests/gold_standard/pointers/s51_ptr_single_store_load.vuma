// s51_ptr_single_store_load.vuma — store 142, load 142
// Expected exit code: 142
//
// Single 8-byte cell. Store 142 via `*p = literal`, load and return
// 142. Uses `*ptr = literal` form. Distinct from s50_ptr_single_
// store_load (155) and s47_ptr_single_store_load (195).

fn main() -> i32 {
    p = allocate(8);
    *p = 142;
    r: i32 = *p;
    free(p);
    return r;
}
