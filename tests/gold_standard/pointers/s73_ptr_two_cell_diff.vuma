// s73_ptr_two_cell_diff.vuma — two cells, diff = 144 (220 - 76)
// Expected exit code: 144
//
// Two 8-byte cells. Store 220/76 via `*ptr = literal`, load
// both, diff -> 220 - 76 = 144. Uses `*ptr = literal` form.
// Distinct from s70_ptr_two_cell_sum (160), s69_ptr_two_cell_
// diff (145) and s66_ptr_two_cell_sum (200).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 220;
    *p2 = 76;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 144
    free(p1);
    free(p2);
    return d;
}
