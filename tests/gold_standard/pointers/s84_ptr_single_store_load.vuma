// s84_ptr_single_store_load.vuma — store 15, load = 15
// Expected exit code: 15
//
// Single 8-byte cell. Store 15 via `*p = literal`, load and
// return 15. Uses `*p = literal` form (no offsets). Distinct
// from s82_ptr_single_store_load (35), s78_ptr_single_store_
// load (1) and s74_ptr_single_store_load (161).
fn main() -> i32 {
    p = allocate(8);
    *p = 15;
    v: i32 = *p;
    free(p);
    return v;
}
