// s61_ptr_single_store_load.vuma — store 200, load 200
// Expected exit code: 200
// 
// Single 8-byte cell. Store 200 via `*p = literal`, load and return
// 200. Uses `*ptr = literal` form. Distinct from s58_ptr_single_
// store_load (155), s58_ptr_two_cell_sum (190) and s58_ptr_var_
// plus_zero_store (205).

fn main() -> i32 {
    p = allocate(8);
    *p = 200;
    r: i32 = *p;
    free(p);
    return r;
}
