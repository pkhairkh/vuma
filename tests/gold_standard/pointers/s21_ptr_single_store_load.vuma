// s21_ptr_single_store_load.vuma — store 57, load 57
// Expected exit code: 57
//
// Single 8-byte cell. Store literal 57, load back, return. Most basic
// store-load round trip via pointer. Distinct from s18_ptr_single_store_load
// (value 67) and s14_ptr_single_store_load (value 88).

fn main() -> i32 {
    p = allocate(8);
    *p = 57;
    v: i32 = *p;
    free(p);
    return v;
}
