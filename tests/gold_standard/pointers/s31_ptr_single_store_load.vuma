// s31_ptr_single_store_load.vuma — store 165, load = 165
// Expected exit code: 165
//
// Single 8-byte cell. Store the literal 165 via `*ptr = literal`, load
// it back, return. Uses `*ptr = literal` form (no offsets). Distinct
// from s30_ptr_single_store_load (value 145) and s26_ptr_single_store_load
// (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    r: i32 = *p;
    free(p);
    return r;
}
