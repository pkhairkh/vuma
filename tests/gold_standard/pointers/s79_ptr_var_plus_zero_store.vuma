// s79_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 39
// Expected exit code: 39
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 39
// into a local, then overwrite the cell via `*p = variable + 0`
// (the documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 39 (the overwritten value).
// Distinct from s78_ptr_var_plus_zero_store (3),
// s77_ptr_var_plus_zero_store (2) and s76_ptr_var_plus_zero_
// store (3).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 39;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
