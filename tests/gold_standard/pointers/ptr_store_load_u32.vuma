// ptr_store_load_u32.vuma — store/load low byte of u32 at offset 0
// Expected exit code: 255
//
// Stores the low byte (0xFF) of a u32 constant 0x000000FF at offset 0
// via *buf, loads it back as a u32. Verifies that a single-byte pointer
// access correctly round-trips the low byte of a wider u32 value.
// (Single-byte access at offset 0 is the only pattern supported by the
// x86_64 codegen today; storing the full 4-byte u32 would require
// *(buf + 1..3) computed-offset stores, which are buggy.)

fn main() -> i32 {
    buf = allocate(8);
    val: u32 = 0x000000FF;
    mask: u32 = 255;
    *buf = val & mask;
    loaded: u32 = *buf;
    free(buf);
    return loaded;
}
