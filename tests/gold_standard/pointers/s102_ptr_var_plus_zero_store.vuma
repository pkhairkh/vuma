// s102_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 7
// Expected exit code: 7
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 7 into a local, then overwrite the cell via `*p = variable + 0` (the documented workaround for the silent-drop bug on `*p = variable`). Load and return 7 (the overwritten value). Straight-line code only.
// Distinct from s101_ptr_single_store_load (67), s101_ptr_two_cell_or (192), s101_ptr_var_plus_zero_store (88).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 7;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
