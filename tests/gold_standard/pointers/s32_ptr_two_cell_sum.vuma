// s32_ptr_two_cell_sum.vuma - two cells, sum = 180 (85 + 95)
// Expected exit code: 180
//
// two cells, sum = 180 (85 + 95). All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_ptr_two_cell_xor (xor) and
// s26_ptr_two_cell_diff (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 85;
    *c2 = 95;
    a: i32 = *c1;
    b: i32 = *c2;
    s: i32 = a + b;        // 180
    free(c1);
    free(c2);
    return s;
}
