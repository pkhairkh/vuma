// s11_ptr_overwrite_two.vuma — store 10/50/90, load = 90
// Expected exit code: 90
//
// Single 8-byte cell. Store 10, then overwrite with 50, then overwrite
// with 90 via `*ptr` form (deterministic). Load returns 90 (last write
// wins, three writes total). Distinct from s10_ptr_overwrite_one (two
// writes) and s8_ptr_overwrite_chain (3 writes, different vals).

fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    *p = 50;
    *p = 90;
    v: i32 = *p;
    free(p);
    return v;
}
