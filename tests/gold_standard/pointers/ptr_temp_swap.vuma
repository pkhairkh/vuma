// ptr_temp_swap.vuma — temp-variable swap of two buffer values
// Expected exit code: 1
//
// Stores 1 in buf_a and 2 in buf_b (each at offset 0 via *buf). Swaps
// their contents in registers using a temp variable. Writes the
// swapped values back, then loads *b (which now holds 1) and returns.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 1;
    *b = 2;
    va: i32 = *a;
    vb: i32 = *b;
    tmp: i32 = va;
    va = vb;
    vb = tmp;
    *b = vb;
    result: i32 = *b;
    free(a);
    free(b);
    return result;
}
