// s63_ptr_two_cell_diff.vuma — two cells, diff = 155 (220 - 65)
// Expected exit code: 155
//
// Two 8-byte cells. Store 220/65 via `*ptr = literal`, load both,
// subtract -> 155. Uses `*ptr = literal` form. Distinct from s51_ptr
// _two_cell_diff (70), s58_ptr_two_cell_sum (190) and s55_ptr_two_
// cell_sum (175).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 220;
    *p2 = 65;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 155
    free(p1);
    free(p2);
    return d;
}
