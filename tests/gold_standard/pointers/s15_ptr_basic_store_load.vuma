// s15_ptr_basic_store_load.vuma — store 73, load 73
// Expected exit code: 73
//
// Single 8-byte cell. Store literal 73, load back, return. Most basic
// store-load round trip via pointer. Uses `*p = literal` form. Distinct
// from s14_ptr_single_store_load (value 88) and s13_ptr_store_load_basic
// (value 55).

fn main() -> i32 {
    p = allocate(8);
    *p = 73;
    v: i32 = *p;
    free(p);
    return v;
}
