// s69_ptr_var_plus_zero_store.vuma -- store via *p = v + 0 = 105
// Expected exit code: 105
//
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 105 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 105 (the overwritten value). Distinct from s66_ptr_
// var_plus_zero_store (215), s65_ptr_var_plus_zero_store (170) and
// s64_ptr_var_plus_zero_store (175).
fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 105;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
