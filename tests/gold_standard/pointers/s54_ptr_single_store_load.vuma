// s54_ptr_single_store_load.vuma — store 175, load 175
// Expected exit code: 175
//
// Single 8-byte cell. Store 175 via `*p = literal`, load and return
// 175. Uses `*ptr = literal` form. Distinct from s50_ptr_single_
// store_load (155) and s49_ptr_single_store_load (165).

fn main() -> i32 {
    p = allocate(8);
    *p = 175;
    r: i32 = *p;
    free(p);
    return r;
}
