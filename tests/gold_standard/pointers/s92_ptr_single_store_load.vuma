// s92_ptr_single_store_load.vuma — store 83, load = 83
// Expected exit code: 83
//
// Single 8-byte cell. Store 83 via `*ptr = literal`, load and
// return 83. Uses `*ptr = literal` form. Distinct from s90_ptr_
// single_store_load (45), s86_ptr_single_store_load (240) and
// s82_ptr_single_store_load (195).
fn main() -> i32 {
    p = allocate(8);
    *p = 83;
    r: i32 = *p;
    free(p);
    return r;
}
