// s101_ptr_two_cell_or.vuma — two cells, or = 192 (0x80 | 0x40)
// Expected exit code: 192
//
// Two 8-byte cells. Store 128/64 via `*ptr = literal`, load both,
// a | b -> 192. Uses `*ptr = literal` form. Distinct from
// s98_ptr_two_cell_sum (79), s97_ptr_two_cell_diff (9) and
// s94_ptr_two_cell_sum (130).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 128;             // 0x80
    *p2 = 64;              // 0x40
    a: i32 = *p1;
    b: i32 = *p2;
    r: i32 = a | b;        // 0xC0 = 192
    free(p1);
    free(p2);
    return r;
}
