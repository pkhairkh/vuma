// s34_ptr_single_store_load.vuma — store 145, load = 145
// Expected exit code: 145
//
// Single 8-byte cell. Store 145 via `*p = literal`, load and
// return 145. Uses `*p = literal` form (no offsets). Distinct from
// s30_ptr_single_store_load (different value) and s27_ptr_single_
// store_load (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 145;
    r: i32 = *p;
    free(p);
    return r;
}
