// s81_ptr_two_cell_diff.vuma — two cells, diff = 161 (240 - 79)
// Expected exit code: 161
//
// Two 8-byte cells. Store 240/79 via `*ptr = literal`, load both,
// a - b -> 161. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ptr_two_cell_diff (2),
// s77_ptr_two_cell_sum (176) and s76_ptr_two_cell_sum (133).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 240;
    *p2 = 79;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 161
    free(p1);
    free(p2);
    return d;
}
