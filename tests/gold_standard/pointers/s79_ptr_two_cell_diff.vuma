// s79_ptr_two_cell_diff.vuma — two cells, diff = 31 (41 - 10)
// Expected exit code: 31
//
// Two 8-byte cells. Store 41/10 via `*ptr = literal`, load
// both, a - b -> 31. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ptr_two_cell_diff (2),
// s77_ptr_two_cell_diff (3) and s76_ptr_two_cell_diff (2).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 41;
    *p2 = 10;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 31
    free(p1);
    free(p2);
    return d;
}
