// s71_ptr_single_store_load.vuma — store 114, load 114
// Expected exit code: 114
//
// Single 8-byte cell. Store 114 via `*p = literal`, load and
// return 114. Uses `*ptr = literal` form. Distinct from s69_ptr_
// single_store_load (225), s70_ptr_single_store_load (100) and
// s66_ptr_single_store_load (195).
fn main() -> i32 {
    p = allocate(8);
    *p = 114;
    r: i32 = *p;
    free(p);
    return r;
}
