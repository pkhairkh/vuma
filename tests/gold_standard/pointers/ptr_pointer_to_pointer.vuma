// ptr_pointer_to_pointer.vuma — pointer to pointer (double indirection)
// Expected exit code: 42
//
// Allocates buf1 and buf2. Stores the address of buf2 in buf1 (at
// offset 0 via *buf). Then writes 42 to **buf1 (which writes to
// buf2's first byte) and returns **buf1.
//
// NOTE: This is a gold-standard SPEC test. It exercises the
// address-of + double-deref codegen path, which is NOT yet supported
// on x86_64 (no AddressOf lowering in src/codegen/src/x86_64/mod.rs;
// the Store IR hardcodes U8 width, truncating 64-bit addresses).
// The binary will likely crash or return a non-42 value today; the
// test will turn green once the codegen for AddressOf / wider stores
// / double-deref is implemented.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *buf1 = buf2;
    **buf1 = 42;
    val: i32 = **buf1;
    free(buf1);
    free(buf2);
    return val;
}
