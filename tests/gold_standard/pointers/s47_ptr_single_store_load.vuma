// s47_ptr_single_store_load.vuma — store 195, load 195
// Expected exit code: 195
//
// Single 8-byte cell. Store 195 via `*p = literal`, load and return
// 195. Uses `*ptr = literal` form. Distinct from s46_ptr_single_
// store_load (165) and s42_ptr_basic_store_load (75).

fn main() -> i32 {
    p = allocate(8);
    *p = 195;
    r: i32 = *p;
    free(p);
    return r;
}
