// s103_ptr_single_store_load.vuma — store 10, load = 10
// Expected exit code: 10
//
// Single 8-byte cell. Store 10 via `*ptr = literal`, load and return 10. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ptr_single_store_load (6), s101_ptr_single_store_load (67), s100_ptr_single_store_load (5).
fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    r: i32 = *p;
    free(p);
    return r;
}
