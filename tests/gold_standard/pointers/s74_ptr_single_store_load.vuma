// s74_ptr_single_store_load.vuma — store 161, load = 161
// Expected exit code: 161
//
// Single 8-byte cell. Store 161 via `*p = literal`, load and
// return 161. Uses `*p = literal` form (no offsets). Distinct
// from s70_ptr_single_store_load (100), s66_ptr_single_store_
// load (195) and s62_ptr_single_store_load (155).
fn main() -> i32 {
    p = allocate(8);
    *p = 161;
    v: i32 = *p;
    free(p);
    return v;
}
