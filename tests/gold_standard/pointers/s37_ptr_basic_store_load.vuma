// s37_ptr_basic_store_load.vuma — store 145, load = 145
// Expected exit code: 145
//
// Deterministic test in the pointers category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_ptr_basic_store_load (value 88) and s30_ptr_single_store_load (value 175).
fn main() -> i32 {
    p = allocate(8);
    *p = 145;
    r: i32 = *p;
    free(p);
    return r;
}
