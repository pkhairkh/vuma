// s50_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 188
// Expected exit code: 188
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 188 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 188 (the overwritten value).
// Distinct from s46_ptr_var_plus_zero_store (175) and s43_ptr_var_
// plus_zero_store (160).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 188;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
