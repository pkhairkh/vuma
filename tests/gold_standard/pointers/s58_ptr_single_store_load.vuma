// s58_ptr_single_store_load.vuma — store 155, load 155
// Expected exit code: 155
// 
// Single 8-byte cell. Store 155 via `*p = literal`, load and return
// 155. Uses `*ptr = literal` form. Distinct from s51_ptr_single_
// store_load (142), s51_ptr_two_cell_diff (70) and s51_ptr_var_plus_
// zero_store (172).

fn main() -> i32 {
    p = allocate(8);
    *p = 155;
    r: i32 = *p;
    free(p);
    return r;
}
