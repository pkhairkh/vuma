// s57_ptr_two_cell_sum.vuma — two cells, sum = 235 (105 + 130)
// Expected exit code: 235
//
// Two 8-byte cells. Store 105/130 via `*p = literal`, load both,
// sum -> 235. Uses `*p = literal` form. Distinct from s54_ptr_two_
// cell_sum (245) and s50_ptr_two_cell_sum (215).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 105;
    *p2 = 130;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 235
    free(p1);
    free(p2);
    return s;
}
