// ptr2_clear.vuma — store 42 then store 0 (clear); load
// Expected exit code: 0
//
// Allocates an 8-byte buffer, stores 42 at offset 0 via *buf, then
// stores 0 (clearing the slot), loads the result, frees, returns.
// Verifies that storing zero over a previously-stored value yields
// zero.

fn main() -> i32 {
    buf = allocate(8);
    *buf = 42;
    *buf = 0;
    val: i32 = *buf;
    free(buf);
    return val;
}
