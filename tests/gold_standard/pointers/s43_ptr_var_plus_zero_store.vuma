// s43_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 160
// Expected exit code: 160
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 160 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 160 (the overwritten value).
// Distinct from s42_ptr_var_plus_zero_store (145) and s38_ptr_var_
// plus_zero_store (135).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 160;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
