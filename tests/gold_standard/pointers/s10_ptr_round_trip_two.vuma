// s10_ptr_round_trip_two.vuma — two cells, round-trip sum = 60 (20 + 40)
// Expected exit code: 60
//
// Two independent 8-byte cells. Store 20 in a, 40 in b via `*ptr`
// form (deterministic). Load both back, sum -> 60. Distinct from
// s4_ptr_two_buf_roundtrip (uses `*(p+offset)` form, non-det) and
// s6_ptr_store_load_basic (single cell).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 20;
    *b = 40;
    va: i32 = *a;
    vb: i32 = *b;
    s: i32 = va + vb;
    free(a);
    free(b);
    return s;
}
