// s83_ptr_single_store_load.vuma — store 228, load = 228
// Expected exit code: 228
//
// Single 8-byte cell. Store 228 via `*p = literal`, load and
// return 228. Uses `*p = literal` form (no offsets). Distinct
// from s78_ptr_single_store_load (1), s74_ptr_single_store_load
// (161) and s72_ptr_single_store_load (155).
fn main() -> i32 {
    p = allocate(8);
    *p = 228;
    v: i32 = *p;
    free(p);
    return v;
}
