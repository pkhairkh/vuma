// s67_ptr_two_cell_diff.vuma — two cells, diff = 90 (220 - 130)
// Expected exit code: 90
//
// Two 8-byte cells. Store 220/130 via `*ptr = literal`, load
// both, diff -> 90. Uses `*ptr = literal` form. Distinct from
// s66_ptr_two_cell_sum (200), s62_ptr_two_cell_diff (140) and
// s58_ptr_two_cell_sum (190).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 220;
    *p2 = 130;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 90
    free(p1);
    free(p2);
    return d;
}
