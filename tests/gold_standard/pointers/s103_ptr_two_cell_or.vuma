// s103_ptr_two_cell_or.vuma — store 1, 64 in 2 cells, load and or = 1|64 = 65
// Expected exit code: 65
//
// Two 8-byte cells. Store 1 at p1, store 64 at p2, load each, return 1 | 64 = 65. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_ptr_two_cell_or (192).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 1;
    *p2 = 64;
    a: i32 = *p1;          // 1
    b: i32 = *p2;          // 64
    r: i32 = a | b;        // 65
    free(p1);
    free(p2);
    return r;
}
