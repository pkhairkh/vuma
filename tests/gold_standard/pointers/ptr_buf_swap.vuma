// ptr_buf_swap.vuma — swap contents of two buffers (straight-line)
// Expected exit code: 1
//
// Stores 1 in buffer a and 2 in buffer b, then swaps their contents
// using a temp variable (straight-line, no loop). After the swap,
// buffer b contains 1; the program loads *b and returns it.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 1;
    *b = 2;
    tmp: i32 = *a;
    *a = *b;
    *b = tmp;
    val: i32 = *b;
    free(a);
    free(b);
    return val;
}
