// s80_ptr_single_store_load.vuma — store 40, load = 40
// Expected exit code: 40
//
// Single 8-byte cell. Store 40 via `*p = literal`, load and
// return 40. Uses `*p = literal` form (no offsets). Distinct from
// s78_ptr_single_store_load (1), s74_ptr_single_store_load (161)
// and s73_ptr_single_store_load (119).
fn main() -> i32 {
    p = allocate(8);
    *p = 40;
    v: i32 = *p;
    free(p);
    return v;
}
