// s90_ptr_single_store_load.vuma — store 45, load = 45
// Expected exit code: 45
//
// Single 8-byte cell. Store 45 via `*ptr = literal`, load and
// return 45. Uses `*ptr = literal` form. Distinct from s86_ptr_
// single_store_load (240), s82_ptr_single_store_load (195) and
// s78_ptr_single_store_load (3).
fn main() -> i32 {
    p = allocate(8);
    *p = 45;
    r: i32 = *p;
    free(p);
    return r;
}
