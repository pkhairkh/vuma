// s44_ptr_basic_store_load.vuma — store 88, load 88
// Expected exit code: 88
//
// Single 8-byte cell. Store 88 via `*p = literal`, load and return 88.
// Uses `*ptr = literal` form. Distinct from s42_ptr_basic_store_load
// (75) and s38_ptr_single_store_load (135).

fn main() -> i32 {
    p = allocate(8);
    *p = 88;
    r: i32 = *p;
    free(p);
    return r;
}
