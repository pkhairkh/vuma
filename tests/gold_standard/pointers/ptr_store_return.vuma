// ptr_store_return.vuma — function returns value stored in buffer
// Expected exit code: 55
//
// Stores 55 in a buffer at offset 0 via *buf. Calls a helper that
// loads the value from the buffer and returns it. main returns the
// helper's result. Exercises pointer load inside a function call.

fn load_val(buf: Address) -> i32 {
    val: i32 = *buf;
    return val;
}

fn main() -> i32 {
    buf = allocate(8);
    *buf = 55;
    result: i32 = load_val(buf);
    free(buf);
    return result;
}
