// s43_ptr_basic_store_load.vuma — store 95, load 95
// Expected exit code: 95
//
// Single 8-byte cell. Store 95 via `*p = literal`, load and return
// 95. Uses `*ptr = literal` form. Distinct from s42_ptr_basic_
// store_load (75) and s38_ptr_single_store_load (135).

fn main() -> i32 {
    p = allocate(8);
    *p = 95;
    r: i32 = *p;
    free(p);
    return r;
}
