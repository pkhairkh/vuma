// s14_ptr_overwrite_via_workaround.vuma — overwrite via *p = variable + 0 = 77
// Expected exit code: 77
//
// Single 8-byte cell. Store literal 7 via `*p = 7`. Load 77 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 77 (the overwritten value). Distinct from
// s9_ptr_overwrite_via_workaround (10 then 20) and
// s9_ptr_workaround_roundtrip (variable+0 only).

fn main() -> i32 {
    p = allocate(8);
    *p = 7;
    v: i32 = 77;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
