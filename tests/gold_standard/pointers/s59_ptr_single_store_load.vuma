// s59_ptr_single_store_load.vuma — store 185, load = 185
// Expected exit code: 185
//
// Single 8-byte cell. Store 185 via `*p = literal`, load it back,
// return 185. Uses `*p = literal` form. Distinct from s58_ptr_single_
// store_load (155), s58_ptr_two_cell_sum (190) and s58_ptr_var_plus_
// zero_store (205).

fn main() -> i32 {
    p = allocate(8);
    *p = 185;
    r: i32 = *p;
    free(p);
    return r;
}
