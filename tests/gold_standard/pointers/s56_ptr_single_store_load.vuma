// s56_ptr_single_store_load.vuma — store 165, load 165
// Expected exit code: 165
//
// Single 8-byte cell. Store 165 via `*p = literal`, load and return
// 165. Uses `*p = literal` form (no offsets). Distinct from s54_ptr_
// single_store_load (155) and s50_ptr_single_store_load (135).

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    a: i32 = *p;
    free(p);
    return a;
}
