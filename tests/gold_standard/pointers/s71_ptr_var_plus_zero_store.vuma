// s71_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 206
// Expected exit code: 206
//
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 206
// into a local, then overwrite the cell via `*p = variable + 0`
// (the documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 206 (the overwritten value).
// Distinct from s69_ptr_var_plus_zero_store (105), s70_ptr_var_
// plus_zero_store (235) and s66_ptr_var_plus_zero_store (215).
fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 206;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
