// s33_ptr_two_cell_xor.vuma — two cells, xor = 0xF0 ^ 0x0F = 0xFF = 255
// Expected exit code: 255
//
// Deterministic test in the pointers category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_ptr_two_cell_xor (0xAA^0x55=255) and s26_ptr_two_cell_diff (different values).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 240;             // 0xF0
    *p2 = 15;              // 0x0F
    a: i32 = *p1;
    b: i32 = *p2;
    r: i32 = a ^ b;        // 0xFF = 255
    free(p1);
    free(p2);
    return r;
}
