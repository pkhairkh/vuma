// ptr2_func_store.vuma — function stores literal 42 via Address param; main loads
// Expected exit code: 42
//
// main allocates an 8-byte buffer and passes its Address to a helper
// function. The helper stores the literal 42 at offset 0 via *p and
// returns. main then loads the stored value back. Verifies that a
// literal store executed inside a callee through a passed-in Address
// is visible to the caller.

fn store_42(p: Address) -> i32 {
    *p = 42;
    return 0;
}

fn main() -> i32 {
    buf = allocate(8);
    store_42(buf);
    val: i32 = *buf;
    free(buf);
    return val;
}
