// s5_ptr_offset_zero_load.vuma — store at multiple offsets, return offset 0
// Expected exit code: 99
//
// 16-byte buffer. Writes 99 at offset 0 and 7 at offset 8. Then
// reads only offset 0 back. Verifies that a later store at a
// different offset doesn't clobber offset 0.

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 99;
    *(p + 8) = 7;
    v: i32 = *(p + 0);
    free(p);
    return v;
}
