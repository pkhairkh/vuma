// s9_ptr_overwrite_via_workaround.vuma — overwrite via *p = variable + 0 = 20
// Expected exit code: 20
//
// Single 8-byte cell. Store literal 10 via `*p = 10`. Load 20 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 20 (the overwritten value). Distinct from
// s4_ptr_overwrite_chain (literal-only overwrites, 11/22/99) and
// s5_ptr_var_plus_zero_store (workaround store without overwrite).

fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    v: i32 = 20;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
