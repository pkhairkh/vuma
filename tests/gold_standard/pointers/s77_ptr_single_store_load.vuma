// s77_ptr_single_store_load.vuma — store 194, load = 194
// Expected exit code: 194
//
// Single 8-byte cell. Store 194 via `*p = literal`, load and
// return 194. Uses `*p = literal` form (no offsets). Distinct
// from s70_ptr_single_store_load (100), s66_ptr_single_store_
// load (195) and s74_ptr_single_store_load (161).

fn main() -> i32 {
    p = allocate(8);
    *p = 194;
    v: i32 = *p;
    free(p);
    return v;
}
