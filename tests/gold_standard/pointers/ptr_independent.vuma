// ptr_independent.vuma — two independent buffers
// Expected exit code: 42
//
// Stores 42 in buf1 and 99 in buf2 (independent buffers, each at
// offset 0 via *buf), then loads buf1 to verify the second store did
// not interfere with the first.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *buf1 = 42;
    *buf2 = 99;
    val: i32 = *buf1;
    free(buf1);
    free(buf2);
    return val;
}
