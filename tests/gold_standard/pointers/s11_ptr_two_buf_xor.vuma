// s11_ptr_two_buf_xor.vuma — two cells, xor loads = 255 (0xF0 ^ 0x0F)
// Expected exit code: 255
//
// Two independent 8-byte cells. Each gets a distinct literal at offset
// 0 (0xF0 / 0x0F) via `*ptr` form (deterministic). Both loaded back
// and XORed -> 240 ^ 15 = 255 (0xFF). Distinct from s10_ptr_round_trip_two
// (two cells, sum) and s8_ptr_store_load_two (two cells, sum).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 240;            // 0xF0
    *b = 15;             // 0x0F
    va: i32 = *a;
    vb: i32 = *b;
    r: i32 = va ^ vb;    // 0xFF = 255
    free(a);
    free(b);
    return r;
}
