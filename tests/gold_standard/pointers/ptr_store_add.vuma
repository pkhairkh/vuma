// ptr_store_add.vuma — store and sum two buffer values
// Expected exit code: 10
//
// Stores 3 in buf1 and 7 in buf2 (each at offset 0 via *buf). Loads
// both, returns their sum (3 + 7 = 10). Exercises two independent
// pointer stores/loads combined with integer addition.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *buf1 = 3;
    *buf2 = 7;
    v1: i32 = *buf1;
    v2: i32 = *buf2;
    sum: i32 = v1 + v2;
    free(buf1);
    free(buf2);
    return sum;
}
