// s38_ptr_single_store_load.vuma — store 165, load = 165
// Expected exit code: 165
//
// Single 8-byte cell. Store 165 via `*p = literal`, load and return
// 165. Uses `*p = literal` form (no offsets). Distinct from s34_ptr_
// single_store_load (145) and s30_ptr_single_store_load.

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    r: i32 = *p;
    free(p);
    return r;
}
