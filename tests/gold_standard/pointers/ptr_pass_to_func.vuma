// ptr_pass_to_func.vuma — pass buffer to function as Address parameter
// Expected exit code: 42
//
// main allocates a buffer and passes it (by Address value) to a helper
// function. The helper stores 42 at offset 0 via *buf. main then loads
// the value back from the same buffer and returns it. Exercises the
// calling convention for Address-typed parameters.

fn helper(buf: Address) -> i32 {
    *buf = 42;
    return 0;
}

fn main() -> i32 {
    buf = allocate(64);
    helper(buf);
    val: i32 = *buf;
    free(buf);
    return val;
}
