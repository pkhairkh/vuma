// s100_ptr_single_store_load.vuma — store 5, load = 5
// Expected exit code: 5
//
// Single 8-byte cell. Store 5 via `*p = literal`, load and
// return 5. Uses `*p = literal` form.
// Distinct from s97_ptr_single_store_load (4), s94_ptr_single_store_load (68), s90_ptr_single_store_load (45).
fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = *p;           // 5
    free(p);
    return v;
}
