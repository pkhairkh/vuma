// s102_ptr_two_cell_diff.vuma — store 128, 1 in 2 cells, 128-1 = 127
// Expected exit code: 127
//
// Two 8-byte cells. Store 128 at p1, store 1 at p2, load each, return 128 - 1 = 127. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_ptr_single_store_load (67), s101_ptr_two_cell_or (192), s101_ptr_var_plus_zero_store (88).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 128;
    *p2 = 1;
    a: i32 = *p1;          // 128
    b: i32 = *p2;          // 1
    d: i32 = a - b;        // 127
    free(p1);
    free(p2);
    return d;
}
