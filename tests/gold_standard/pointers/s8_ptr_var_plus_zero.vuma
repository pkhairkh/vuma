// s8_ptr_var_plus_zero.vuma — exercise the *p = variable + 0 workaround
// Expected exit code: 77
//
// Allocate a cell, load a constant into a variable, store it via
// the documented `*p = variable + 0` workaround (the plain
// `*p = variable` form is silently dropped by the current backend).
// Read back and return. Distinct from s5_ptr_var_plus_zero_store
// (different value 88).

fn main() -> i32 {
    p = allocate(8);
    v: i32 = 77;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
