// s83_ptr_two_cell_diff.vuma — two cells, diff = 231 (240 - 9)
// Expected exit code: 231
//
// Two 8-byte cells. Store 240/9 via `*ptr = literal`, load
// both, a - b -> 231. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ptr_two_cell_diff (2), s74_ptr_two_cell_
// diff (60) and s72_ptr_two_cell_diff (40).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 240;
    *p2 = 9;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 231
    free(p1);
    free(p2);
    return d;
}
