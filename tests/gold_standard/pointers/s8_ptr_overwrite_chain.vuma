// s8_ptr_overwrite_chain.vuma — single cell, overwrite 3x, last wins = 50
// Expected exit code: 50
//
// One 8-byte cell. Store 5, then 25, then 50. Load observes 50
// (last write wins). Distinct from s4_ptr_overwrite_chain
// (different values 10/20/30).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 25;
    *p = 50;
    v: i32 = *p;
    free(p);
    return v;
}
