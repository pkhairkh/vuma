// s80_bit_and_then_xor.vuma — (0x00 & 0x00) ^ 0x08 = 0x00 ^ 0x08 = 0x08 = 8
// Expected exit code: 8
//
// Two-stage bitwise: AND then XOR. (0 & 0) = 0
// (0x00); 0 ^ 8 = 8 (0x08). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_bit_and_then_xor (2),
// s74_bit_and_then_shr (28) and s73_bit_and_then_shl (72).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 0;            // 0x00
    c: u64 = 8;            // 0x08
    x: u64 = a & b;        // 0x00 = 0
    r: u64 = x ^ c;        // 0x08 = 8
    return r;
}
