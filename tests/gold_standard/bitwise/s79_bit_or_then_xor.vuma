// s79_bit_or_then_xor.vuma — (0x03 | 0x05) ^ 0x09 = 0x07 ^ 0x09 = 0x0E = 14
// Expected exit code: 14
//
// Two-stage bitwise: OR then XOR. (3 | 5) = 7 (0x07);
// 7 ^ 9 = 14 (0x0E). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_or_then_shl (1), s77_bit_or_then_xor (2) and
// s76_bit_or_then_xor (1).
fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 5;            // 0x05
    c: u64 = 9;            // 0x09
    x: u64 = a | b;        // 0x07 = 7
    r: u64 = x ^ c;        // 0x0E = 14
    return r;
}
