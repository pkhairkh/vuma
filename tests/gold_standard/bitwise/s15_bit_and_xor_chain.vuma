// s15_bit_and_xor_chain.vuma — ((0xFF & 0x0F) ^ 0xAA) = 0xA5 = 165
// Expected exit code: 165
//
// Two-stage bitwise chain. (255 & 15) = 15 (0x0F); 15 ^ 170 = 165 (0xA5).
// All operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s14_bit_xor_chain_3 (three-way XOR) and
// s11_bit_xor_and_toggle (XOR-then-AND).

fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    b: u64 = 15;          // 0x0F
    c: u64 = 170;         // 0xAA
    x: u64 = a & b;       // 0x0F = 15
    r: u64 = x ^ c;       // 0xA5 = 165
    return r;
}
