// s80_bit_xor_then_shr.vuma — (0x03 ^ 0x08) >> 0 = 0x0B >> 0 = 0x0B = 11
// Expected exit code: 11
//
// Two-stage bitwise: XOR then shift right. (3 ^ 8) = 11
// (0x0B); 11 >> 0 = 11 (0x0B). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_bit_or_then_shl (1),
// s74_bit_xor_then_or (216) and s73_bit_xor_then_and (98).
fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 8;            // 0x08
    c: u64 = 0;
    x: u64 = a ^ b;        // 0x0B = 11
    r: u64 = x >> c;       // 0x0B = 11
    return r;
}
