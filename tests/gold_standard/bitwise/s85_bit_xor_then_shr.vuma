// s85_bit_xor_then_shr.vuma — (0xAA ^ 0x55) >> 1 = 0xFF >> 1 = 0x7F = 127
// Expected exit code: 127
//
// Two-stage bitwise: XOR then shift right. (170 ^ 85) = 255
// (0xFF); 255 >> 1 = 127 (0x7F). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_bit_shr_then_and, s78_bit_xor_then_shr
// and s74_bit_xor_then_shr.
fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 1;            // shift amount
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x >> c;       // 0x7F = 127
    return r;
}
