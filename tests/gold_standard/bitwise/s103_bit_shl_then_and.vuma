// s103_bit_shl_then_and.vuma — (0x05 << 2) & 0x1F = 0x14 & 0x1F = 0x14 = 20
// Expected exit code: 20
//
// Two-stage bitwise: shift-left then AND. (5 << 2) = 20 (0x14); 20 & 31 = 20 (0x14). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
fn main() -> i32 {
    a: u32 = 5;           // 0x05
    b: u32 = 2;
    c: u32 = 31;          // 0x1F
    x: u32 = a << b;      // 0x14 = 20
    r: u32 = x & c;       // 0x14 = 20
    return r;
}
