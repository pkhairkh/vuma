// s27_bit_xor_then_shr.vuma — (0xF0 ^ 0x0F) >> 2 = 0xFF >> 2 = 63
// Expected exit code: 63
//
// XOR then SHR. 240 ^ 15 = 255 (0xFF); 255 >> 2 = 63 (0x3F). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s26_bit_shl_then_xor (shl-then-xor)
// and s22_bit_xor_or_xor (xor-or-xor).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 15;          // 0x0F
    c: u64 = 2;
    x: u64 = a ^ b;       // 0xFF = 255
    r: u64 = x >> c;      // 0x3F = 63
    return r;
}
