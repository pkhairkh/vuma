// s95_bit_and_then_shr.vuma — (0xFF & 0x44) >> 1 = 0x44 >> 1 = 0x22 = 34
// Expected exit code: 34
//
// Two-stage bitwise: AND then shift-right. (255 & 68) = 68 (0x44);
// 68 >> 1 = 34 (0x22). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_and_then_shl (140), s90_bit_or_then_xor (19) and
// s82_bit_or_then_xor (76).
fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 68;           // 0x44
    s: u64 = 1;
    x: u64 = a & b;        // 0x44 = 68
    r: u64 = x >> s;       // 0x22 = 34
    return r;
}
