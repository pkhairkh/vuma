// s88_bit_xor_then_shl.vuma — (0x33 ^ 0x0F) << 2 = 0x3C << 2 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: XOR then shift left. (51 ^ 15) = 60
// (0x3C); 60 << 2 = 240 (0xF0). All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s86_bit_shl_then_xor (56),
// s82_bit_xor_then_shl (120) and s78_bit_or_then_shl (1).
fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 15;           // 0x0F
    c: u64 = 2;            // shift amount
    x: u64 = a ^ b;        // 0x3C = 60
    r: u64 = x << c;       // 0xF0 = 240
    return r;
}
