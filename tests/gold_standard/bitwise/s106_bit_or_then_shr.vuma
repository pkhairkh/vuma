// s106_bit_or_then_shr.vuma — (0x80 | 0x16) >> 1 = 0x96 >> 1 = 0x4B = 75
// Expected exit code: 75
//
// Two-stage bitwise: OR then shift-right. (128 | 22) = 150 (0x96); 150 >> 1 = 75 (0x4B). All operands loaded into u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_bit_or_then_and (59), s101_bit_shl_then_or (55), s100_bit_or_then_and (43).
fn main() -> i32 {
    a: u64 = 128;          // 0x80
    b: u64 = 22;           // 0x16
    c: u64 = 1;            // shift amount
    x: u64 = a | b;        // 0x96 = 150
    r: u64 = x >> c;       // 0x4B = 75
    return r;
}
