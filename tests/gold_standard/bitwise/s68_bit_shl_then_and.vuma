// s68_bit_shl_then_and.vuma — (7 << 3) & 0x78 = 56 & 120 = 56
// Expected exit code: 56
//
// Two-stage bitwise: shift-left then AND. 7 << 3 = 56 (0x38);
// 56 & 120 = 56 (0x38). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_bit_shr_then_or (27), s62_bit_shl_then_and (64) and
// s58_bit_or_then_shr (48).
fn main() -> i32 {
    a: u64 = 7;
    b: u64 = 3;
    c: u64 = 120;          // 0x78
    x: u64 = a << b;       // 0x38 = 56
    r: u64 = x & c;        // 0x38 = 56
    return r;
}
