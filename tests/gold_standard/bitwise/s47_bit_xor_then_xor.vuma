// s47_bit_xor_then_xor.vuma — 0xAA ^ 0x55 ^ 0x0F = 0xFF ^ 0x0F = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: XOR then XOR. (170 ^ 85) = 255 (0xFF); 255 ^ 15 =
// 240 (0xF0). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s46_
// bit_xor_then_and (255) and s42_bit_shl_then_and (64).

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0xF0 = 240
    return r;
}
