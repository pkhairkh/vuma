// bit2_priority_encode.vuma — Find the index of the highest set bit in 0xFF.
// Expected exit code: 7
//
// 0xFF has bits 0..7 set; the highest set bit is bit 7, so the priority
// encoder returns 7. Computed as floor(log2(0xFF)) = 7 by counting non-zero
// 1-bit shifts.
fn main() -> i32 {
    n: u64 = 0xFF;
    zero: u64 = 0;
    one: u64 = 1;
    two: u64 = 2;
    three: u64 = 3;
    four: u64 = 4;
    five: u64 = 5;
    six: u64 = 6;
    seven: u64 = 7;
    eight: u64 = 8;
    sixtythree: u64 = 63;
    s1: u64 = n >> one;
    ns1: u64 = zero - s1;
    o1: u64 = s1 | ns1;
    b1: u64 = o1 >> sixtythree;
    s2: u64 = n >> two;
    ns2: u64 = zero - s2;
    o2: u64 = s2 | ns2;
    b2: u64 = o2 >> sixtythree;
    s3: u64 = n >> three;
    ns3: u64 = zero - s3;
    o3: u64 = s3 | ns3;
    b3: u64 = o3 >> sixtythree;
    s4: u64 = n >> four;
    ns4: u64 = zero - s4;
    o4: u64 = s4 | ns4;
    b4: u64 = o4 >> sixtythree;
    s5: u64 = n >> five;
    ns5: u64 = zero - s5;
    o5: u64 = s5 | ns5;
    b5: u64 = o5 >> sixtythree;
    s6: u64 = n >> six;
    ns6: u64 = zero - s6;
    o6: u64 = s6 | ns6;
    b6: u64 = o6 >> sixtythree;
    s7: u64 = n >> seven;
    ns7: u64 = zero - s7;
    o7: u64 = s7 | ns7;
    b7: u64 = o7 >> sixtythree;
    s8: u64 = n >> eight;
    ns8: u64 = zero - s8;
    o8: u64 = s8 | ns8;
    b8: u64 = o8 >> sixtythree;
    r1: u64 = b1 + b2;
    r2: u64 = r1 + b3;
    r3: u64 = r2 + b4;
    r4: u64 = r3 + b5;
    r5: u64 = r4 + b6;
    r6: u64 = r5 + b7;
    result: u64 = r6 + b8;
    return result;
}
