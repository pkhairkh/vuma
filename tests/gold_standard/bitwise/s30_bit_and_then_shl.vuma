// s30_bit_and_then_shl.vuma — (0xAA & 0x0F) << 3 = 0x0A << 3 = 0x50 = 80
// Expected exit code: 80
//
// Two-stage bitwise: AND then SHL. (170 & 15) = 10 (0x0A); 10 << 3 =
// 80 (0x50). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s26_bit_and_or_xor (and-or-xor, 25) and s22_bit_or_xor_chain
// (or-xor-chain).

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 15;           // 0x0F
    c: u64 = 3;
    x: u64 = a & b;        // 0x0A = 10
    r: u64 = x << c;       // 0x50 = 80
    return r;
}
