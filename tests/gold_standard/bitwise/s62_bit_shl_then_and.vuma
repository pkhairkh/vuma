// s62_bit_shl_then_and.vuma — (1 << 6) & 0x7F = 64 & 0x7F = 64
// Expected exit code: 64
// 
// Two-stage bitwise: shift left then AND. (1 << 6) = 64 (0x40);
// 64 & 127 = 64 (0x40). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_bit_
// and_then_shl (120), s58_bit_and_then_xor (127) and s55_bit_xor_then_
// shl (204).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 6;
    c: u64 = 127;          // 0x7F
    x: u64 = a << b;       // 0x40 = 64
    r: u64 = x & c;        // 0x40 = 64
    return r;
}
