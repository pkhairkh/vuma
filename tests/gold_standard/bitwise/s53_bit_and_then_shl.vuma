// s53_bit_and_then_shl.vuma — (0xF0 & 0x70) << 1 = 0x70 << 1 = 0xE0 = 224
// Expected exit code: 224
//
// Two-stage bitwise: AND then shift left. (240 & 112) = 112 (0x70);
// 112 << 1 = 224 (0xE0). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s49_bit_xor_then_shl (190) and s50_bit_xor_then_shr (31).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 112;          // 0x70
    c: u64 = 1;
    x: u64 = a & b;        // 0x70 = 112
    r: u64 = x << c;       // 0xE0 = 224
    return r;
}
