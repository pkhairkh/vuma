// s67_bit_shl_then_xor.vuma — (0x01 << 5) ^ 0x10 = 0x20 ^ 0x10 = 0x30 = 48
// Expected exit code: 48
//
// Two-stage bitwise: shift left then XOR. (1 << 5) = 32 (0x20);
// 32 ^ 16 = 48 (0x30). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_bit_or_then_shl (112), s62_bit_shl_then_xor (88)
// and s58_bit_shl_then_or (130).
fn main() -> i32 {
    a: u64 = 1;            // 0x01
    b: u64 = 5;
    c: u64 = 16;           // 0x10
    x: u64 = a << b;       // 0x20 = 32
    r: u64 = x ^ c;        // 0x30 = 48
    return r;
}
