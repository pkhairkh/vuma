// s13_bit_xor_chain_3.vuma — 0x0F ^ 0xF0 ^ 0x33 = 0xFF ^ 0x33 = 204
// Expected exit code: 204
//
// Three-way XOR chain. 15 ^ 240 = 255 (0xFF); 255 ^ 51 = 204 (0xCC).
// All operands loaded into u64 variables first. Distinct from
// s10_bit_xor_then_or (two-way XOR then OR) and s4_bit_xor3_chain
// (different operands).

fn main() -> i32 {
    a: u64 = 15;          // 0x0F
    b: u64 = 240;         // 0xF0
    c: u64 = 51;          // 0x33
    x: u64 = a ^ b;       // 0xFF
    r: u64 = x ^ c;       // 0xCC = 204
    return r;
}
