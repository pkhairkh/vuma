// s90_bit_xor_then_or.vuma — (0x34 ^ 0x20) | 0x01 = 0x14 | 0x01 = 0x15 = 21
// Expected exit code: 21
//
// Two-stage bitwise: XOR then OR. (52 ^ 32) = 20 (0x14);
// 20 | 1 = 21 (0x15). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_bit_xor_then_and (60), s82_bit_or_then_xor (76) and
// s74_bit_or_then_and (135).
fn main() -> i32 {
    a: u64 = 52;           // 0x34
    b: u64 = 32;           // 0x20
    c: u64 = 1;            // 0x01
    x: u64 = a ^ b;        // 0x14 = 20
    r: u64 = x | c;        // 0x15 = 21
    return r;
}
