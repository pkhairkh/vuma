// s23_bit_shr_then_or.vuma — (0xFF >> 4) | 0x10 = 0x0F | 0x10 = 0x1F = 31
// Expected exit code: 31
//
// SHR then OR. (255 >> 4) = 15 (0x0F); 15 | 16 = 31 (0x1F). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s20_bit_shr_xor_chain (shr-then-xor, value
// 45) and s21_bit_shr_then_shl (shr-then-shl).

fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    sh: u64 = 4;
    b: u64 = 16;          // 0x10
    x: u64 = a >> sh;     // 0x0F = 15
    r: u64 = x | b;       // 0x1F = 31
    return r;
}

