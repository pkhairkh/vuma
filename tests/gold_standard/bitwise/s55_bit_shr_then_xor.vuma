// s55_bit_shr_then_xor.vuma — (0xF0 >> 2) ^ 0x33 = 60 ^ 51 = 15
// Expected exit code: 15
//
// Two-stage bitwise: shift right then XOR. 240 >> 2 = 60 (0x3C);
// 60 ^ 51 = 15 (0x0F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_shl_then_xor (28) and s53_bit_and_then_shl (224).

fn main() -> i32 {
    a: u64 = 240;           // 0xF0
    b: u64 = 2;
    c: u64 = 51;            // 0x33
    x: u64 = a >> b;        // 0x3C = 60
    r: u64 = x ^ c;         // 0x0F = 15
    return r;
}
