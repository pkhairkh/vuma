// s93_bit_shl_then_and.vuma — (11 << 2) & 0xFC = 0x2C & 0xFC = 0x2C = 44
// Expected exit code: 44
//
// Two-stage bitwise: shift-left then AND. 11 << 2 = 44 (0x2C);
// 44 & 252 = 44 (0x2C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_shl_then_and (20), s82_bit_shl_then_and (??) and s78_bit_shl_then_or (4).
fn main() -> i32 {
    a: u64 = 11;
    b: u64 = 2;
    c: u64 = 252;          // 0xFC
    x: u64 = a << b;       // 0x2C = 44
    r: u64 = x & c;        // 0x2C = 44
    return r;
}
