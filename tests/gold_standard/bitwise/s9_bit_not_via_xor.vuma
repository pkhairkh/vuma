// s9_bit_not_via_xor.vuma — 0x55 ^ 0xFF = 0xAA = 170
// Expected exit code: 170
//
// XOR with 0xFF acts as a bitwise NOT for the low 8 bits. 0x55
// (0101 0101) ^ 0xFF (1111 1111) = 0xAA (1010 1010) = 170. All
// operands loaded into variables first. Distinct from
// s5_bit_xor_then_not (which cancels to 0).

fn main() -> i32 {
    a: u64 = 85;      // 0x55
    b: u64 = 255;     // 0xFF
    r: u64 = a ^ b;   // 0xAA = 170
    return r;
}
