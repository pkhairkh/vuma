// s96_bit_shl_then_or.vuma — (0x06 << 3) | 0x09 = 0x30 | 0x09 = 0x39 = 57
// Expected exit code: 57
//
// Two-stage bitwise: shift-left then OR. (6 << 3) = 48 (0x30);
// 48 | 9 = 57 (0x39). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_shr_then_or (24), s90_bit_shl_then_and (20) and
// s86_bit_shl_then_xor (56).
fn main() -> i32 {
    a: u64 = 6;            // 0x06
    s: u64 = 3;
    c: u64 = 9;            // 0x09
    x: u64 = a << s;       // 0x30 = 48
    r: u64 = x | c;        // 0x39 = 57
    return r;
}
