// s16_bit_not_xor_shr.vuma — (0xFF ^ 0x55) >> 2 = 170 >> 2 = 42
// Expected exit code: 42
//
// NOT-via-XOR then shift right. (0xFF ^ 0x55) = 0xAA (170); 170 >> 2 =
// 42 (0x2A). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s9_bit_not_via_xor
// (NOT-via-XOR only, no shift) and s13_bit_shr_then_and (shift-then-AND).

fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    b: u64 = 85;          // 0x55
    sh: u64 = 2;
    x: u64 = a ^ b;       // 0xAA = 170
    r: u64 = x >> sh;     // 0x2A = 42
    return r;
}
