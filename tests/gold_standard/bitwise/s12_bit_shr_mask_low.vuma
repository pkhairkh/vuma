// s12_bit_shr_mask_low.vuma — (0xFF >> 4) & 0x07 = 0x0F & 0x07 = 7
// Expected exit code: 7
//
// Shift right then mask low 3 bits. (255 >> 4) = 15 (0x0F);
// 15 & 7 = 7. All operands loaded into u64 variables first.
// Distinct from s13_bit_shr_then_and (240>>2 & 0x3F = 60) and
// s10_bit_shl_and_mask (shl-then-mask).

fn main() -> i32 {
    v: u64 = 255;         // 0xFF
    sh: u64 = 4;
    mask: u64 = 7;        // 0x07
    shifted: u64 = v >> sh;   // 0x0F = 15
    r: u64 = shifted & mask;  // 0x07 = 7
    return r;
}
