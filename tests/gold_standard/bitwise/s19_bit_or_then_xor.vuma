// s19_bit_or_then_xor.vuma — (0xF0 | 0x0C) ^ 0x55 = 0xFC ^ 0x55 = 0xA9 = 169
// Expected exit code: 169
//
// Three-stage bitwise: OR then XOR. (240 | 12) = 252 (0xFC);
// 252 ^ 85 = 169 (0xA9). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s18_bit_and_or_xor (AND-then-OR) and s14_bit_or_then_xor
// (different values 0xAA/0x55/0xFF).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 12;          // 0x0C
    c: u64 = 85;          // 0x55
    x: u64 = a | b;       // 0xFC = 252
    r: u64 = x ^ c;       // 0xA9 = 169
    return r;
}
