// s72_bit_and_then_or.vuma — (0x33 & 0x1F) | 0x80 = 0x13 | 0x80 = 0x93 = 147
// Expected exit code: 147
//
// Two-stage bitwise: AND then OR. (51 & 31) = 19 (0x13);
// 19 | 128 = 147 (0x93). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_and_then_xor (36), s69_bit_xor_then_or (223) and
// s66_bit_or_then_shl (120).
fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 31;           // 0x1F
    c: u64 = 128;          // 0x80
    x: u64 = a & b;        // 0x13 = 19
    r: u64 = x | c;        // 0x93 = 147
    return r;
}
