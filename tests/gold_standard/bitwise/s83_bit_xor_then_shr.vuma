// s83_bit_xor_then_shr.vuma — (0x80 ^ 0x1C) >> 1 = 0x9C >> 1 = 0x4E = 78
// Expected exit code: 78
//
// Two-stage bitwise: XOR then shift right. (128 ^ 28) = 156 (0x9C);
// 156 >> 1 = 78 (0x4E). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_xor_then_shl (2), s74_bit_xor_then_shr (55)
// and s72_bit_xor_then_and (60).
fn main() -> i32 {
    a: u64 = 128;          // 0x80
    b: u64 = 28;           // 0x1C
    c: u64 = 1;            // shift amount
    x: u64 = a ^ b;        // 0x9C = 156
    r: u64 = x >> c;       // 0x4E = 78
    return r;
}
