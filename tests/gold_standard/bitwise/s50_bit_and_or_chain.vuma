// s50_bit_and_or_chain.vuma — (0xF0 & 0x0F) | 0x30 = 0 | 0x30 = 48
// Expected exit code: 48
//
// Two-stage bitwise: AND then OR. (240 & 15) = 0; 0 | 48 = 48.
// All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s46_bit_xor_then_and
// (255) and s43_bit_xor_then_or (255).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 48;           // 0x30
    x: u64 = a & b;        // 0x00 = 0
    r: u64 = x | c;        // 0x30 = 48
    return r;
}
