// s78_bit_and_then_xor.vuma — (0x00 & 0x00) ^ 0x02 = 0x00 ^ 0x02 = 0x02 = 2
// Expected exit code: 2
//
// Two-stage bitwise: AND then XOR. (0 & 0) = 0
// (0x00); 0 ^ 2 = 2 (0x02). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s74_bit_and_then_shr (28),
// s73_bit_and_then_shl (72) and s72_bit_and_then_or (140).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 0;            // 0x00
    c: u64 = 2;            // 0x02
    x: u64 = a & b;        // 0x00 = 0
    r: u64 = x ^ c;        // 0x02 = 2
    return r;
}
