// s22_bit_xor_or_xor.vuma — (0x33 ^ 0x0F) | 0xC0 = 0x3C | 0xC0 = 0xFC = 252
// Expected exit code: 252
//
// Three-stage bitwise: XOR then OR. (51 ^ 15) = 60 (0x3C); 60 | 192 = 252
// (0xFC). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s18_bit_and_or_xor
// (and-then-or, value 202) and s14_bit_xor_then_or (xor-then-or).

fn main() -> i32 {
    a: u64 = 51;          // 0x33
    b: u64 = 15;          // 0x0F
    c: u64 = 192;         // 0xC0
    x: u64 = a ^ b;       // 0x3C = 60
    r: u64 = x | c;       // 0xFC = 252
    return r;
}
