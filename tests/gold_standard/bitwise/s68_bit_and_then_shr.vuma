// s68_bit_and_then_shr.vuma — (0xFF & 0x77) >> 2 = 0x77 >> 2 = 0x1D = 29
// Expected exit code: 29
//
// Two-stage bitwise: AND then shift-right. (255 & 119) = 119
// (0x77); 119 >> 2 = 29 (0x1D). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_bit_or_then_shl (112), s62_bit_xor_then_shr
// (31) and s58_bit_and_then_xor (127).
fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 119;          // 0x77
    c: u64 = 2;
    x: u64 = a & b;        // 0x77 = 119
    r: u64 = x >> c;       // 0x1D = 29
    return r;
}
