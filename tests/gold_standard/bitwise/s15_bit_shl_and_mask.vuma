// s15_bit_shl_and_mask.vuma — ((0x0F << 4) & 0xF0) = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise chain. (15 << 4) = 240 (0xF0); 240 & 240 = 240 (0xF0).
// All operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s14_bit_shl_then_shr (shift left then
// right) and s10_bit_shl_and_mask (shl-then-and, different operands).

fn main() -> i32 {
    a: u64 = 15;          // 0x0F
    sh: u64 = 4;
    m: u64 = 240;         // 0xF0
    x: u64 = a << sh;     // 0xF0 = 240
    r: u64 = x & m;       // 0xF0 = 240
    return r;
}
