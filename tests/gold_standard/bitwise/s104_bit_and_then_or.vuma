// s104_bit_and_then_or.vuma — (0x03 & 0x07) | 0x40 = 0x03 | 0x40 = 0x43 = 67
// Expected exit code: 67
//
// Two-stage bitwise: AND then OR. (3 & 7) = 3 (0x03); 3 | 64 = 67 (0x43). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_bit_or_then_and (59), s102_bit_shl_then_xor (52), s102_bit_xor_then_shr (46).
fn main() -> i32 {
    a: u32 = 3;          // 0x03
    b: u32 = 7;          // 0x07
    c: u32 = 64;          // 0x40
    n: u32 = a & b;        // 0x03 = 3
    r: u32 = n | c;        // 0x43 = 67
    return r;
}
