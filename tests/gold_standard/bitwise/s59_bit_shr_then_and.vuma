// s59_bit_shr_then_and.vuma — (0xF0 >> 2) & 0x3F = 60 & 63 = 60
// Expected exit code: 60
//
// Two-stage bitwise: shift right then AND. (240 >> 2) = 60 (0x3C);
// 60 & 63 = 60 (0x3C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s58_bit_
// and_then_xor (127), s58_bit_or_then_shr (48) and s58_bit_xor_then_
// and (255).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 2;
    c: u64 = 63;           // 0x3F
    x: u64 = a >> b;       // 0x3C = 60
    r: u64 = x & c;        // 0x3C = 60
    return r;
}
