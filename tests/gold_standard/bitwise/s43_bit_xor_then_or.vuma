// s43_bit_xor_then_or.vuma — (0xF0 ^ 0x0F) | 0xAA = 0xFF | 0xAA = 0xFF = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then OR. (240 ^ 15) = 255 (0xFF);
// 255 | 170 = 255. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_or_then_xor (85) and s38_bit_or_then_shl.

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 170;          // 0xAA
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x | c;        // 0xFF = 255
    return r;
}
