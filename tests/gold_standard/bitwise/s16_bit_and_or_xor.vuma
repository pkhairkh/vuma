// s16_bit_and_or_xor.vuma — ((0xCC & 0xF0) | 0x0F) ^ 0xAA = 101
// Expected exit code: 101
//
// Three-stage AND-OR-XOR. (0xCC & 0xF0) = 0xC0 (192); 0xC0 | 0x0F = 0xCF
// (207); 0xCF ^ 0xAA = 0x65 (101). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround). Distinct
// from s14_bit_and_then_or (AND-then-OR only) and s13_bit_and_or_mix
// (AND-OR mix without final XOR).

fn main() -> i32 {
    a: u64 = 204;         // 0xCC
    b: u64 = 240;         // 0xF0
    c: u64 = 15;          // 0x0F
    d: u64 = 170;         // 0xAA
    x: u64 = a & b;       // 0xC0 = 192
    y: u64 = x | c;       // 0xCF = 207
    r: u64 = y ^ d;       // 0x65 = 101
    return r;
}
