// s95_bit_xor_then_or.vuma — (0x0F ^ 0x05) | 0x25 = 0x0A | 0x25 = 0x2F = 47
// Expected exit code: 47
//
// Two-stage bitwise: XOR then OR. (15 ^ 5) = 10 (0x0A);
// 10 | 37 = 47 (0x2F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_xor_then_and (240), s90_bit_xor_then_or (21) and
// s82_bit_xor_then_shl (120).
fn main() -> i32 {
    a: u64 = 15;           // 0x0F
    b: u64 = 5;            // 0x05
    c: u64 = 37;           // 0x25
    x: u64 = a ^ b;        // 0x0A = 10
    r: u64 = x | c;        // 0x2F = 47
    return r;
}
