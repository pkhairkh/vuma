// s59_bit_xor_then_or.vuma — (0xA0 ^ 0x50) | 0x0C = 0xF0 | 0x0C = 0xFC = 252
// Expected exit code: 252
//
// Two-stage bitwise: XOR then OR. (160 ^ 80) = 240 (0xF0); 240 | 12 =
// 252 (0xFC). All operands loaded into u64 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s58_bit_and_then_xor
// (127), s58_bit_or_then_shr (48) and s58_bit_xor_then_and (255).

fn main() -> i32 {
    a: u64 = 160;          // 0xA0
    b: u64 = 80;           // 0x50
    c: u64 = 12;           // 0x0C
    x: u64 = a ^ b;        // 0xF0 = 240
    r: u64 = x | c;        // 0xFC = 252
    return r;
}
