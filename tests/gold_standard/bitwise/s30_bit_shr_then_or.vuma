// s30_bit_shr_then_or.vuma — (0xF0 >> 2) | 0x03 = 0x3C | 0x03 = 0x3F = 63
// Expected exit code: 63
//
// Two-stage bitwise: shift-right then OR. (240 >> 2) = 60 (0x3C);
// 60 | 3 = 63 (0x3F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s26_bit_or_chain_3 (or chain, 119) and s22_bit_shl_and_mask
// (shl-then-and).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 2;
    c: u64 = 3;            // 0x03
    x: u64 = a >> b;       // 0x3C = 60
    r: u64 = x | c;        // 0x3F = 63
    return r;
}
