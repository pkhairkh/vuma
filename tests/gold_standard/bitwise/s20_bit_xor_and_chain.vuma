// s20_bit_xor_and_chain.vuma — (0x55 ^ 0x0F) & 0xC0 = 0x5A & 0xC0 = 0x40 = 64
// Expected exit code: 64
//
// XOR-then-AND chain. (85 ^ 15) = 90 (0x5A); 90 & 192 = 64 (0x40). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_bit_and_or_xor (AND-OR-XOR chain)
// and s14_bit_xor_chain_3 (pure XOR chain).

fn main() -> i32 {
    a: u64 = 85;          // 0x55
    b: u64 = 15;          // 0x0F
    m: u64 = 192;         // 0xC0
    x: u64 = a ^ b;       // 0x5A = 90
    r: u64 = x & m;       // 0x40 = 64
    return r;
}
