// s75_bit_or_then_and.vuma — (0x70 | 0x88) & 0xCC = 0xF8 & 0xCC = 0xC8 = 200
// Expected exit code: 200
//
// Two-stage bitwise: OR then AND. 112 | 136 = 248 (0xF8);
// 248 & 204 = 200 (0xC8). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_bit_or_then_xor (141), s70_bit_and_then_xor (36) and
// s66_bit_shr_then_or (60).
fn main() -> i32 {
    a: u32 = 112;          // 0x70
    b: u32 = 136;          // 0x88
    c: u32 = 204;          // 0xCC
    x: u32 = a | b;        // 0xF8 = 248
    r: u32 = x & c;        // 0xC8 = 200
    return r;
}
