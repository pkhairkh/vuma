// s52_bit_xor_chain.vuma — 0xF0 ^ 0x0F ^ 0xAA = 0xFF ^ 0xAA = 0x55 = 85
// Expected exit code: 85
//
// Three-stage XOR chain. 240 ^ 15 = 255 (0xFF); 255 ^ 170 = 85 (0x55).
// All operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s50_bit_xor_then_shr (31) and
// s47_bit_xor_then_xor (240).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 170;          // 0xAA
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0x55 = 85
    return r;
}
