// s11_bit_shl_or_clear.vuma — ((1 << 3) | 0x10) & 0x1F = 24
// Expected exit code: 24
//
// Three-stage bitwise chain. (1 << 3) = 8; 8 | 16 = 24; 24 & 31 = 24.
// All operands loaded into u64 variables first. Distinct from
// s7_bit_shl_add (shift-then-add, not bitwise) and s6_bit_shl_then_shr
// (shift-left-then-shift-right).

fn main() -> i32 {
    v: u64 = 1;
    sh: u64 = 3;
    m: u64 = 16;          // 0x10
    mask: u64 = 31;       // 0x1F
    s: u64 = v << sh;     // 8
    o: u64 = s | m;       // 24
    r: u64 = o & mask;    // 24
    return r;
}
