// s63_bit_shl_then_or.vuma — (1 << 5) | 0x0A = 0x20 | 0x0A = 0x2A = 42
// Expected exit code: 42
//
// Two-stage bitwise: shift left then OR. (1 << 5) = 32 (0x20);
// 32 | 10 = 42 (0x2A). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_bit
// _shl_then_xor (79), s58_bit_or_then_shr (48) and s55_bit_or_then_
// and (204).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 10;           // 0x0A
    x: u64 = a << b;       // 0x20 = 32
    r: u64 = x | c;        // 0x2A = 42
    return r;
}
