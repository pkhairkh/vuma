// s14_bit_and_then_or.vuma — (0xCC & 0x0F) | 0x30 = 0x0C | 0x30 = 0x3C = 60
// Expected exit code: 60
//
// AND-then-OR. (204 & 15) = 12 (0x0C); 12 | 48 = 60 (0x3C). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s10_bit_and_then_xor
// (AND-then-XOR) and s9_bit_and_chain_4 (pure AND chain).

fn main() -> i32 {
    a: u64 = 204;         // 0xCC
    b: u64 = 15;          // 0x0F
    c: u64 = 48;          // 0x30
    x: u64 = a & b;       // 0x0C
    r: u64 = x | c;       // 0x3C = 60
    return r;
}
