// s82_bit_or_then_xor.vuma — (0x70 | 0x0F) ^ 0x33 = 0x7F ^ 0x33 = 0x4C = 76
// Expected exit code: 76
//
// Two-stage bitwise: OR then XOR. (112 | 15) = 127 (0x7F);
// 127 ^ 51 = 76 (0x4C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_and_then_xor (2), s74_bit_or_then_and (135)
// and s72_bit_shl_then_or (4).
fn main() -> i32 {
    a: u64 = 112;          // 0x70
    b: u64 = 15;           // 0x0F
    c: u64 = 51;           // 0x33
    x: u64 = a | b;        // 0x7F = 127
    r: u64 = x ^ c;        // 0x4C = 76
    return r;
}
