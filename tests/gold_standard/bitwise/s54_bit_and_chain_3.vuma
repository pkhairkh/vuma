// s54_bit_and_chain_3.vuma — 0xFF & 0xF0 & 0xCC = 0xC0 = 192
// Expected exit code: 192
//
// Three-way AND chain. 255 & 240 = 240; 240 & 204 = 192 (0xC0).
// All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s50_bit_and_or_
// chain (192) and s49_bit_and_then_xor (200).

fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 240;          // 0xF0
    c: u64 = 204;          // 0xCC
    x: u64 = a & b;        // 0xF0 = 240
    r: u64 = x & c;        // 0xC0 = 192
    return r;
}
