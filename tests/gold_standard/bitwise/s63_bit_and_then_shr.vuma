// s63_bit_and_then_shr.vuma — (0xFF & 0xF0) >> 2 = 0xF0 >> 2 = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: AND then shift right. (255 & 240) = 240
// (0xF0); 240 >> 2 = 60 (0x3C). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s51_bit_and_then_shl (120), s58_bit_and_then_xor
// (127) and s55_bit_xor_then_shl (204).

fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 240;          // 0xF0
    c: u64 = 2;
    x: u64 = a & b;        // 0xF0 = 240
    r: u64 = x >> c;       // 0x3C = 60
    return r;
}
