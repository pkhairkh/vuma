// s37_bit_shl_and_or.vuma — ((5 << 4) & 0x70) | 0x03 = (0x50 & 0x70) | 0x03 = 0x50 | 0x03 = 0x53 = 83
// Expected exit code: 83
//
// Deterministic test in the bitwise category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_bit_xor_shl_or (xor-shl-or, 245) and s30_bit_shl_then_and (shl-then-and).
fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 4;
    c: u64 = 112;          // 0x70
    d: u64 = 3;            // 0x03
    x: u64 = a << b;       // 0x50 = 80
    y: u64 = x & c;        // 0x50 = 80
    r: u64 = y | d;        // 0x53 = 83
    return r;
}
