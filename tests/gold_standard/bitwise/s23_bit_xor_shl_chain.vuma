// s23_bit_xor_shl_chain.vuma — (0x55 ^ 0x33) << 1 = 0x66 << 1 = 0xCC = 204
// Expected exit code: 204
//
// XOR then SHL chain. (85 ^ 51) = 102 (0x66); 102 << 1 = 204 (0xCC). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_bit_shl_and_mask (shl-then-and,
// value 16) and s14_bit_xor_chain_3 (pure xor chain).

fn main() -> i32 {
    a: u64 = 85;          // 0x55
    b: u64 = 51;          // 0x33
    sh: u64 = 1;
    x: u64 = a ^ b;       // 0x66 = 102
    r: u64 = x << sh;     // 0xCC = 204
    return r;
}

