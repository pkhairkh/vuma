// s89_bit_xor_then_or.vuma — (85 ^ 85) | 22 = 0 | 22 = 22
// Expected exit code: 22
//
// Two-stage bitwise: XOR then OR. (85 ^ 85) = 0 (a == b);
// 0 | 22 = 22. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_bit_xor_then_and (60), s82_bit_or_then_xor (76) and
// s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 85;           // 0x55
    d: u64 = 22;           // 0x16
    x: u64 = a ^ b;        // 0
    r: u64 = x | d;        // 0x16 = 22
    return r;
}
