// s97_bit_xor_then_shr.vuma — (0xAA ^ 0x32) >> 2 = 0x98 >> 2 = 0x26 = 38
// Expected exit code: 38
//
// Two-stage bitwise: XOR then shift-right. (170 ^ 50) = 152
// (0x98); 152 >> 2 = 38 (0x26). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_bit_and_then_shl (224), s90_bit_or_then_xor (19), s86_bit_or_then_shl (92).
fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 50;           // 0x32
    s: u64 = 2;
    x: u64 = a ^ b;        // 0x98 = 152
    r: u64 = x >> s;       // 0x26 = 38
    return r;
}
