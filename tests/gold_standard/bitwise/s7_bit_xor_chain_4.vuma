// s7_bit_xor_chain_4.vuma — 0x11 ^ 0x22 ^ 0x44 ^ 0x88 = 0xFF = 255
// Expected exit code: 255
//
// Four-way XOR chain. Each operand sets two non-overlapping bits
// (bit 0+4, 1+5, 2+6, 3+7) — folding them via XOR sets all 8 bits,
// giving 0xFF = 255. All operands loaded into variables first to
// dodge the immediate-RHS bitwise drop bug. Distinct from
// s5_crypto_parity_xor (4-byte incremental-nibble fold, crypto
// category) and s4_bit_xor3_chain (3-way fold).

fn main() -> i32 {
    a: u64 = 17;    // 0x11
    b: u64 = 34;    // 0x22
    c: u64 = 68;    // 0x44
    d: u64 = 136;   // 0x88
    t1: u64 = a ^ b;    // 0x33
    t2: u64 = t1 ^ c;   // 0x77
    r: u64 = t2 ^ d;    // 0xFF = 255
    return r;
}
