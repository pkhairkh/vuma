// s58_bit_and_then_xor.vuma — (0xF0 & 0x70) ^ 0x0F = 0x70 ^ 0x0F = 0x7F = 127
// Expected exit code: 127
// 
// Two-stage bitwise: AND then XOR. (240 & 112) = 112 (0x70);
// 112 ^ 15 = 127 (0x7F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s51_bit_or_then_and (204), s51_bit_shl_then_xor (79) and s51_bit_
// and_then_shl (120).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 112;          // 0x70
    c: u64 = 15;           // 0x0F
    x: u64 = a & b;        // 0x70 = 112
    r: u64 = x ^ c;        // 0x7F = 127
    return r;
}
