// s44_bit_shl_then_or.vuma — (1 << 5) | 0x0A = 32 | 10 = 42
// Expected exit code: 42
//
// Two-stage bitwise: shift left then OR. (1 << 5) = 32 (0x20);
// 32 | 10 = 42 (0x2A). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_shl_then_and (shl-then-and, 64) and s38_bit_shl_then_xor
// (shl-then-xor).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 10;           // 0x0A
    s: u64 = a << b;       // 32
    r: u64 = s | c;        // 42
    return r;
}
