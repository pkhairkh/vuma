// s23_bit_and_then_xor.vuma — (0xF0 & 0xCC) ^ 0x0F = 0xC0 ^ 0x0F = 0xCF = 207
// Expected exit code: 207
//
// AND then XOR. (240 & 204) = 192 (0xC0); 192 ^ 15 = 207 (0xCF). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_bit_xor_or_xor (xor-or-xor, value
// 252) and s20_bit_xor_and_chain (xor-then-and, value 64).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 204;         // 0xCC
    c: u64 = 15;          // 0x0F
    x: u64 = a & b;       // 0xC0 = 192
    r: u64 = x ^ c;       // 0xCF = 207
    return r;
}

