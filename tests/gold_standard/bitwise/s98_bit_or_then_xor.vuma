// s98_bit_or_then_xor.vuma — (0x10 | 0x08) ^ 0x0E = 0x18 ^ 0x0E = 0x16 = 22
// Expected exit code: 22
//
// Two-stage bitwise: OR then XOR. (16 | 8) = 24 (0x18);
// 24 ^ 14 = 22 (0x16). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_xor_then_and (240), s90_bit_or_then_xor (19) and
// s86_bit_or_then_shl (92).
fn main() -> i32 {
    a: u64 = 16;          // 0x10
    b: u64 = 8;           // 0x08
    c: u64 = 14;          // 0x0E
    x: u64 = a | b;       // 0x18 = 24
    r: u64 = x ^ c;       // 0x16 = 22
    return r;
}
