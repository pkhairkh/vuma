// s19_bit_shl_or_mask.vuma — (0x03 << 4) | 0x0A = 0x30 | 0x0A = 0x3A = 58
// Expected exit code: 58
//
// Three-stage bitwise: SHL then OR. (3 << 4) = 48 (0x30);
// 48 | 10 = 58 (0x3A). All operands (including the shift amount) loaded
// into u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s18_bit_shl_xor_shr (shl-xor-shr) and
// s14_bit_shl_then_or (shl-then-or, different values).

fn main() -> i32 {
    v: u64 = 3;           // 0x03
    s: u64 = 4;
    c: u64 = 10;          // 0x0A
    x: u64 = v << s;      // 0x30 = 48
    r: u64 = x | c;       // 0x3A = 58
    return r;
}
