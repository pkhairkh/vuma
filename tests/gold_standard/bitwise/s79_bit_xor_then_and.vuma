// s79_bit_xor_then_and.vuma — (0x03 ^ 0x06) & 0x07 = 0x05 & 0x07 = 0x05 = 5
// Expected exit code: 5
//
// Two-stage bitwise: XOR then AND. (3 ^ 6) = 5 (0x05);
// 5 & 7 = 5 (0x05). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_and_then_xor (2), s77_bit_xor_then_and (1) and
// s76_bit_xor_then_and (2).
fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 6;            // 0x06
    c: u64 = 7;            // 0x07
    x: u64 = a ^ b;        // 0x05 = 5
    r: u64 = x & c;        // 0x05 = 5
    return r;
}
