// s8_bit_toggle_chain.vuma — 170 ^ 85 ^ 170 = 85
// Expected exit code: 85
//
// XOR toggles bits: 170 (0xAA) ^ 85 (0x55) = 255 (0xFF), then XOR back
// with 170 (0xAA) returns to 85 (0x55). All operands loaded into
// variables first. Distinct from s6_bit_xor3_chain (3 distinct operands).

fn main() -> i32 {
    a: u64 = 170;      // 0xAA
    b: u64 = 85;       // 0x55
    x: u64 = a ^ b;    // 0xFF = 255
    y: u64 = x ^ a;    // 0x55 = 85
    return y;
}
