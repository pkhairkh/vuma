// s46_bit_and_then_shl.vuma — (0xF0 & 0x70) << 1 = 0x70 << 1 = 0xE0 = 224
// Expected exit code: 224
//
// Two-stage bitwise: AND then shift left. (240 & 112) = 112 (0x70);
// 112 << 1 = 224 (0xE0). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_shl_then_and (64) and s38_bit_and_then_xor.

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 112;          // 0x70
    c: u64 = 1;
    m: u64 = a & b;        // 0x70 = 112
    r: u64 = m << c;       // 0xE0 = 224
    return r;
}
