// s18_bit_xor_chain_3.vuma — 0x11 ^ 0x22 ^ 0x44 = 0x33 ^ 0x44 = 0x77 = 119
// Expected exit code: 119
//
// Three-way XOR chain. (17 ^ 34) = 51 (0x33); 51 ^ 68 = 119 (0x77).
// All operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s14_bit_xor_chain_3
// (0xAA^0x55^0xFF = 0) and s11_bit_xor_and_toggle (xor-then-toggle).

fn main() -> i32 {
    a: u64 = 17;          // 0x11
    b: u64 = 34;          // 0x22
    c: u64 = 68;          // 0x44
    x: u64 = a ^ b;       // 0x33 = 51
    r: u64 = x ^ c;       // 0x77 = 119
    return r;
}
