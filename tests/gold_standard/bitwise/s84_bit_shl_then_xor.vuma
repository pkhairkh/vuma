// s84_bit_shl_then_xor.vuma — (0x01 << 4) ^ 0x02 = 0x10 ^ 0x02 = 0x12 = 18
// Expected exit code: 18
//
// Two-stage bitwise: shift left then XOR. (1 << 4) = 16
// (0x10); 16 ^ 2 = 18 (0x12). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_bit_xor_then_shl (120), s78_bit_shl_then_or
// (4) and s74_bit_or_then_xor (141).
fn main() -> i32 {
    a: u64 = 1;            // 0x01
    b: u64 = 4;            // shift amount
    c: u64 = 2;            // 0x02
    x: u64 = a << b;       // 0x10 = 16
    r: u64 = x ^ c;        // 0x12 = 18
    return r;
}
