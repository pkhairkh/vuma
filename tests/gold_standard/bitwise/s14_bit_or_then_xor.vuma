// s14_bit_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0x0F = 0xFF ^ 0x0F = 0xF0 = 240
// Expected exit code: 240
//
// OR-then-XOR. (240 | 15) = 255 (0xFF); 255 ^ 15 = 240 (0xF0). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s10_bit_xor_then_or
// (XOR-then-OR) and s10_bit_and_then_xor (AND-then-XOR).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 15;          // 0x0F
    c: u64 = 15;          // 0x0F
    x: u64 = a | b;       // 0xFF
    r: u64 = x ^ c;       // 0xF0 = 240
    return r;
}
