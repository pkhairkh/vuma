// s100_bit_xor_then_and.vuma — (0xAA ^ 0x55) & 0x23 = 0xFF & 0x23 = 0x23 = 35
// Expected exit code: 35
//
// Two-stage bitwise: XOR then AND. (170 ^ 85) = 255 (0xFF);
// 255 & 35 = 35 (0x23). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_bit_or_then_and (41), s94_bit_xor_then_and (240), s90_bit_or_then_xor (19).
fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 35;           // 0x23
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0x23 = 35
    return r;
}
