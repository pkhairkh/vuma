// s37_bit_xor_and_shr.vuma — ((0xC3 ^ 0x3C) & 0x7F) >> 2 = (0xFF & 0x7F) >> 2 = 0x7F >> 2 = 0x1F = 31
// Expected exit code: 31
//
// Deterministic test in the bitwise category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_bit_shr_xor_and (shr-xor-and, 61) and s30_bit_xor_then_and (xor-then-and, 12).
fn main() -> i32 {
    a: u64 = 195;          // 0xC3
    b: u64 = 60;           // 0x3C
    c: u64 = 127;          // 0x7F
    d: u64 = 2;
    x: u64 = a ^ b;        // 0xFF = 255
    y: u64 = x & c;        // 0x7F = 127
    r: u64 = y >> d;       // 0x1F = 31
    return r;
}
