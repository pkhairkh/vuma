// s64_bit_xor_then_or.vuma — (0x44 ^ 0x88) | 0x11 = 0xCC | 0x11 = 0xDD = 221
// Expected exit code: 221
//
// Two-stage bitwise: XOR then OR. (68 ^ 136) = 204 (0xCC);
// 204 | 17 = 221 (0xDD). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s62_bit_
// and_then_or (63), s62_bit_shl_then_and (64) and s62_bit_xor_then_shr
// (31).

fn main() -> i32 {
    a: u64 = 68;           // 0x44
    b: u64 = 136;          // 0x88
    c: u64 = 17;           // 0x11
    x: u64 = a ^ b;        // 0xCC = 204
    r: u64 = x | c;        // 0xDD = 221
    return r;
}
