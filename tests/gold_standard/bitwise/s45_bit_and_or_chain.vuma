// s45_bit_and_or_chain.vuma — (0xF0 & 0xCC) | 0x33 = 0xC0 | 0x33 = 0xF3 = 243
// Expected exit code: 243
//
// Two-stage bitwise: AND then OR. (240 & 204) = 192 (0xC0);
// 192 | 51 = 243 (0xF3). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_or_then_xor (or-then-xor, 85) and s38_bit_and_then_xor
// (and-then-xor).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 204;          // 0xCC
    c: u64 = 51;           // 0x33
    x: u64 = a & b;        // 0xC0 = 192
    r: u64 = x | c;        // 0xF3 = 243
    return r;
}
