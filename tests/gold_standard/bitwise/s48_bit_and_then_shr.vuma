// s48_bit_and_then_shr.vuma — (0xFC & 0xF0) >> 4 = 0xF0 >> 4 = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: AND then shift right. (252 & 240) = 240
// (0xF0); 240 >> 4 = 15 (0x0F). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s46_bit_shr_then_or and s42_bit_and_then_xor.

fn main() -> i32 {
    a: u64 = 252;          // 0xFC
    b: u64 = 240;          // 0xF0
    c: u64 = 4;
    x: u64 = a & b;        // 0xF0 = 240
    r: u64 = x >> c;       // 0x0F = 15
    return r;
}
