// s40_bit_xor_then_or.vuma — (0x55 ^ 0x33) | 0x0F = 0x66 | 0x0F = 0x6F = 111
// Expected exit code: 111
//
// Two-stage bitwise: XOR then OR. (85 ^ 51) = 102 (0x66); 102 | 15 =
// 111 (0x6F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_and_then_xor (243) and s34_bit_xor_then_or (255).

fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 51;           // 0x33
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0x66 = 102
    r: u64 = x | c;        // 0x6F = 111
    return r;
}
