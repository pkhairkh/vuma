// s94_bit_and_then_shl.vuma — (0xF0 & 0x70) << 1 = 0x70 << 1 = 0xE0 = 224
// Expected exit code: 224
//
// Two-stage bitwise: AND then shift-left. (240 & 112) = 112 (0x70);
// 112 << 1 = 224 (0xE0). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_or_then_xor (19), s86_bit_or_then_shl (92) and
// s82_bit_or_then_xor (76).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 112;          // 0x70
    s: u64 = 1;
    x: u64 = a & b;        // 0x70 = 112
    r: u64 = x << s;       // 0xE0 = 224
    return r;
}
