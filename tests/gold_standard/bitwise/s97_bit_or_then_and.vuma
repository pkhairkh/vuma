// s97_bit_or_then_and.vuma — (0xF0 | 0x0F) & 0x29 = 0xFF & 0x29 = 0x29 = 41
// Expected exit code: 41
//
// Two-stage bitwise: OR then AND. (240 | 15) = 255 (0xFF);
// 255 & 41 = 41 (0x29). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_bit_xor_then_and (240), s90_bit_or_then_xor (19), s86_bit_xor_then_and (60).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 41;           // 0x29
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x & c;        // 0x29 = 41
    return r;
}
