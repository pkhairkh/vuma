// s35_bit_shl_then_or.vuma — (1 << 4) | 0x22 = 16 | 34 = 50
// Expected exit code: 50
//
// Two-stage bitwise: shift left then OR. (1 << 4) = 16 (0x10);
// 16 | 34 = 50 (0x32). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_bit_xor_then_or (xor-then-or, 255) and s30_bit_or_then_and
// (or-then-and).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 34;           // 0x22
    s: u64 = a << b;       // 0x10 = 16
    r: u64 = s | c;        // 0x32 = 50
    return r;
}
