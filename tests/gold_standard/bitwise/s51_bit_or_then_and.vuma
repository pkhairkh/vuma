// s51_bit_or_then_and.vuma — (0xF0 | 0x0F) & 0xCC = 0xFF & 0xCC = 0xCC = 204
// Expected exit code: 204
//
// Two-stage bitwise: OR then AND. (240 | 15) = 255 (0xFF);
// 255 & 204 = 204 (0xCC). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_bit_and_or_chain (48) and s47_bit_or_then_shr (63).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 204;          // 0xCC
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x & c;        // 0xCC = 204
    return r;
}
