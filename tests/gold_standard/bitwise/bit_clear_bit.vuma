// bit_clear_bit.vuma — Clear bit 7 of 128.
// Expected exit code: 0
// 128 & ~(1 << 7) = 0b10000000 & 0b01111111 = 0
//
// Workaround note: VUMA's `~` unary is silently dropped during SCG->IR
// lowering, and the literal 0xFFFFFFFFFFFFFFFF has a high-bit-set parsing
// bug. We compute all-ones as `0 - 1` and apply NOT via XOR with all-ones.
fn main() -> i32 {
    val: u64 = 128;
    one: u64 = 1;
    seven: u64 = 7;
    zero: u64 = 0;
    allones: u64 = zero - 1;
    bit: u64 = one << seven;
    inv: u64 = bit ^ allones;
    result: u64 = val & inv;
    return result;
}
