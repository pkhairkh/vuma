// s61_bit_xor_then_or.vuma — (0x33 ^ 0x0F) | 0xC0 = 0x3C | 0xC0 = 0xFC = 252
// Expected exit code: 252
// 
// Two-stage bitwise: XOR then OR. (51 ^ 15) = 60 (0x3C);
// 60 | 192 = 252 (0xFC). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_bit_and_then_xor (127), s58_bit_or_then_shr (48) and s58_bit_
// xor_then_and (255).

fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 15;           // 0x0F
    c: u64 = 192;          // 0xC0
    x: u64 = a ^ b;        // 0x3C = 60
    r: u64 = x | c;        // 0xFC = 252
    return r;
}
