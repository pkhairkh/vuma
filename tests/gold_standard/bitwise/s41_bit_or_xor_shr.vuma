// s41_bit_or_xor_shr.vuma - ((0xF0 | 0x0C) ^ 0x04) >> 1 = 0xF8 >> 1 = 124
// Expected exit code: 124
//
// OR-then-XOR-then-SHR chain. (240 | 12) = 252 (0xFC); 252 ^ 4 =
// 248 (0xF8); 248 >> 1 = 124. All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s38_bit_and_then_xor (and-then-xor, 243) and
// s34_bit_or_xor_chain (or-xor-chain).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 12;           // 0x0C
    c: u64 = 4;            // 0x04
    d: u64 = 1;
    s: u64 = a | b;        // 0xFC = 252
    t: u64 = s ^ c;        // 0xF8 = 248
    r: u64 = t >> d;       // 124
    return r;
}
