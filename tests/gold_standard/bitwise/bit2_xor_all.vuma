// bit2_xor_all.vuma — XOR all bytes of a value.
// Expected exit code: 0
//
// XOR-fold all bytes of 0xFFFF (two identical bytes 0xFF and 0xFF):
//   low_byte  = 0xFFFF & 0xFF        = 0xFF
//   high_byte = (0xFFFF >> 8) & 0xFF = 0xFF
//   result    = 0xFF ^ 0xFF          = 0
//
// Workaround note: bitwise ops with an immediate RHS are silently dropped by
// the current codegen, so all operands are loaded into variables first.
fn main() -> i32 {
    val: u64 = 0xFFFF;
    eight: u64 = 8;
    byte_mask: u64 = 0xFF;
    low: u64 = val & byte_mask;
    shifted: u64 = val >> eight;
    high: u64 = shifted & byte_mask;
    result: u64 = low ^ high;
    return result;
}
