// s102_bit_shl_then_xor.vuma — (0x01 << 1) ^ 0x36 = 0x02 ^ 0x36 = 0x34 = 52
// Expected exit code: 52
//
// Two-stage bitwise: shift-left then XOR. (1 << 1) = 2 (0x02); 2 ^ 54 = 52 (0x34). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_bit_and_then_xor (197), s101_bit_shl_then_or (55), s101_bit_xor_then_shl (204).
fn main() -> i32 {
    a: u32 = 1;          // 0x01
    b: u32 = 54;          // 0x36
    c: u32 = 1;
    s: u32 = a << c;       // 0x02 = 2
    r: u32 = s ^ b;        // 0x34 = 52
    return r;
}
