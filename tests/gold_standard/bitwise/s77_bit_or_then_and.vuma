// s77_bit_or_then_and.vuma — (0x55 | 0xAA) & 0x66 = 0xFF & 0x66 = 0x66 = 102
// Expected exit code: 102
//
// Two-stage bitwise: OR then AND. 85 | 170 = 255 (0xFF);
// 255 & 102 = 102 (0x66). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_shl_then_and (160), s66_bit_or_then_shl (180) and
// s74_bit_and_then_shr (49).

fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 170;          // 0xAA
    c: u32 = 102;          // 0x66
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x & c;        // 0x66 = 102
    return r;
}
