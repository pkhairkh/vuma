// s98_bit_xor_then_and.vuma — (0x55 ^ 0xAA) & 0x19 = 0xFF & 0x19 = 0x19 = 25
// Expected exit code: 25
//
// Two-stage bitwise: XOR then AND. (85 ^ 170) = 255 (0xFF);
// 255 & 25 = 25 (0x19). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_and_then_shl (224), s90_bit_xor_then_or (21) and
// s86_bit_xor_then_and (60).
fn main() -> i32 {
    a: u64 = 85;          // 0x55
    b: u64 = 170;         // 0xAA
    c: u64 = 25;          // 0x19
    x: u64 = a ^ b;       // 0xFF = 255
    r: u64 = x & c;       // 0x19 = 25
    return r;
}
