// s4_bit_or_then_and.vuma — (0xF0 | 0x0F) & 0xAA = 0xFF & 0xAA = 0xAA = 170
// Expected exit code: 170
//
// OR of complementary nibbles produces 0xFF, then AND with 0xAA leaves
// only the even bits → 0xAA = 170.

fn main() -> i32 {
    a: u64 = 240;   // 0xF0
    b: u64 = 15;    // 0x0F
    c: u64 = 170;   // 0xAA
    o: u64 = a | b;       // 0xFF
    r: u64 = o & c;       // 0xAA
    return r;
}
