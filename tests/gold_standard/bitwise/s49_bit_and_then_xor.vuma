// s49_bit_and_then_xor.vuma — (0xF0 & 0xC0) ^ 0x0C = 0xC0 ^ 0x0C = 0xCC = 204
// Expected exit code: 204
//
// Two-stage bitwise: AND then XOR. (240 & 192) = 192 (0xC0);
// 192 ^ 12 = 204 (0xCC). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_bit_xor_then_and (255, xor-then-and) and s42_bit_xor_chain_3
// (85, xor-chain).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 192;          // 0xC0
    c: u64 = 12;           // 0x0C
    m: u64 = a & b;        // 0xC0 = 192
    r: u64 = m ^ c;        // 0xCC = 204
    return r;
}
