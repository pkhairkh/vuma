// s102_bit_or_then_and.vuma — (0x01 | 0x3A) & 0x3B = 0x3B & 0x3B = 0x3B = 59
// Expected exit code: 59
//
// Two-stage bitwise: OR then AND. (1 | 58) = 59 (0x3B); 59 & 59 = 59 (0x3B). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_bit_and_then_xor (197), s101_bit_shl_then_or (55), s101_bit_xor_then_shl (204).
fn main() -> i32 {
    a: u32 = 1;          // 0x01
    b: u32 = 58;          // 0x3A
    c: u32 = 59;          // 0x3B
    o: u32 = a | b;        // 0x3B = 59
    r: u32 = o & c;        // 0x3B = 59
    return r;
}
