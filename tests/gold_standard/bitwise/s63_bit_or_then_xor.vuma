// s63_bit_or_then_xor.vuma — (0xC0 | 0x0C) ^ 0x55 = 0xCC ^ 0x55 = 0x99 = 153
// Expected exit code: 153
//
// Two-stage bitwise: OR then XOR. (192 | 12) = 204 (0xCC);
// 204 ^ 85 = 153 (0x99). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s51_bit_or_then_and (204), s58_bit_xor_then_and (255) and s55_
// bit_shr_then_xor (31).

fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    b: u64 = 12;           // 0x0C
    c: u64 = 85;           // 0x55
    x: u64 = a | b;        // 0xCC = 204
    r: u64 = x ^ c;        // 0x99 = 153
    return r;
}
