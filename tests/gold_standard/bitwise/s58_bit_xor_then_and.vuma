// s58_bit_xor_then_and.vuma — (0xAA ^ 0x55) & 0xFF = 0xFF & 0xFF = 0xFF = 255
// Expected exit code: 255
// 
// Two-stage bitwise: XOR then AND. (170 ^ 85) = 255 (0xFF);
// 255 & 255 = 255 (0xFF). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s51_bit_or_then_and (204), s51_bit_shl_then_xor (79) and s51_bit_
// and_then_shl (120).

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 255;          // 0xFF
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0xFF = 255
    return r;
}
