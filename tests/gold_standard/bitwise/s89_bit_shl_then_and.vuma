// s89_bit_shl_then_and.vuma — (33 << 0) & 255 = 33 & 255 = 33
// Expected exit code: 33
//
// Two-stage bitwise: shift left then AND. (33 << 0) = 33;
// 33 & 255 = 33. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_bit_shl_then_xor (180), s82_bit_shr_then_and (76) and
// s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 33;
    s: u64 = 0;
    m: u64 = 255;           // 0xFF
    x: u64 = a << s;       // 33
    r: u64 = x & m;        // 33
    return r;
}
