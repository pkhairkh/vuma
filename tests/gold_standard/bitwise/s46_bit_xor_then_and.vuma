// s46_bit_xor_then_and.vuma — (0xCC ^ 0x33) & 0xFF = 0xFF & 0xFF = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then AND. (204 ^ 51) = 255 (0xFF);
// 255 & 255 = 255. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_xor_chain_3 (240) and s38_bit_and_then_xor.

fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 51;           // 0x33
    c: u64 = 255;          // 0xFF
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0xFF = 255
    return r;
}
