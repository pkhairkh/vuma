// s69_bit_and_then_shr.vuma -- (0xFF & 0xFC) >> 1 = 0xFC >> 1 = 0x7E = 126
// Expected exit code: 126
//
// Two-stage bitwise: AND then shift right. (255 & 252) = 252 (0xFC);
// 252 >> 1 = 126 (0x7E). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s66_bit_
// or_then_shl (112), s65_bit_xor_then_and (90) and s64_bit_or_then_
// xor (221).
fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 252;          // 0xFC
    c: u64 = 1;            // shift amount
    x: u64 = a & b;        // 0xFC = 252
    r: u64 = x >> c;       // 0x7E = 126
    return r;
}
