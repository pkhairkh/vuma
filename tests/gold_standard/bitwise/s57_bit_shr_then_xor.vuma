// s57_bit_shr_then_xor.vuma — (200 >> 2) ^ 14 = 50 ^ 14 = 60
// Expected exit code: 60
//
// Two-stage bitwise: shift right then XOR. 200 >> 2 = 50 (0x32);
// 50 ^ 14 = 60 (0x3C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_and_chain_3 (192) and s50_bit_xor_then_shr (31).

fn main() -> i32 {
    a: u64 = 200;
    b: u64 = 2;
    c: u64 = 14;
    x: u64 = a >> b;       // 50
    r: u64 = x ^ c;        // 60
    return r;
}
