// s104_bit_shr_then_or.vuma — (0x80 >> 1) | 0x0A = 0x40 | 0x0A = 0x4A = 74
// Expected exit code: 74
//
// Two-stage bitwise: shift-right then OR. (128 >> 1) = 64 (0x40); 64 | 10 = 74 (0x4A). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_bit_or_then_and (59), s102_bit_shl_then_xor (52), s102_bit_xor_then_shr (46).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 10;          // 0x0A
    c: u32 = 1;
    s: u32 = a >> c;       // 0x40 = 64
    r: u32 = s | b;        // 0x4A = 74
    return r;
}
