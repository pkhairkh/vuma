// s92_bit_or_then_xor.vuma — (0xCC | 0x33) ^ 0x55 = 0xFF ^ 0x55 = 0xAA = 170
// Expected exit code: 170
//
// Two-stage bitwise: OR then XOR. (204 | 51) = 255 (0xFF);
// 255 ^ 85 = 170 (0xAA). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_or_then_xor (19), s86_bit_xor_then_and (60) and
// s82_bit_or_then_xor (76).
fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 51;           // 0x33
    c: u64 = 85;           // 0x55
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0xAA = 170
    return r;
}
