// s19_bit_xor_and_or.vuma — (0xA5 ^ 0x33) | 0x0F = 0x96 | 0x0F = 0x9F = 159
// Expected exit code: 159
//
// Three-stage bitwise: XOR then OR. (165 ^ 51) = 150 (0x96);
// 150 | 15 = 159 (0x9F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s18_bit_and_or_xor (AND-then-OR, no XOR framing) and
// s14_bit_xor_chain_3 (xor chain, no OR).

fn main() -> i32 {
    a: u64 = 165;         // 0xA5
    b: u64 = 51;          // 0x33
    c: u64 = 15;          // 0x0F
    x: u64 = a ^ b;       // 0x96 = 150
    r: u64 = x | c;       // 0x9F = 159
    return r;
}
