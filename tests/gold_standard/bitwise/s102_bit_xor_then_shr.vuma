// s102_bit_xor_then_shr.vuma — (0x01 ^ 0x5C) >> 1 = 0x5D >> 1 = 0x2E = 46
// Expected exit code: 46
//
// Two-stage bitwise: XOR then shift-right. (1 ^ 92) = 93 (0x5D); 93 >> 1 = 46 (0x2E). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_bit_and_then_xor (197), s101_bit_shl_then_or (55), s101_bit_xor_then_shl (204).
fn main() -> i32 {
    a: u32 = 1;          // 0x01
    b: u32 = 92;          // 0x5C
    c: u32 = 1;
    x: u32 = a ^ b;        // 0x5D = 93
    r: u32 = x >> c;       // 0x2E = 46
    return r;
}
