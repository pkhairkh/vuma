// s34_bit_shl_then_and.vuma — (1 << 5) & 0x3F = 32 & 63 = 32
// Expected exit code: 32
//
// Two-stage bitwise: shift left then AND. (1 << 5) = 32; 32 & 63 =
// 32. All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s30_bit_and_then_shl
// (and-then-shl) and s27_bit_shl_or_xor (shl-or-xor).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 63;           // 0x3F
    x: u64 = a << b;       // 32
    r: u64 = x & c;        // 32
    return r;
}
