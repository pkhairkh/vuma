// bit2_bit_diff.vuma — Numerical bit difference between 0xFF and 0xFD.
// Expected exit code: 2
//
// The arithmetic bit-difference: |0xFF - 0xFD| = 2.
//
// Note: the Hamming (popcount) distance of 0xFF ^ 0xFD = 0x02 is 1, not 2,
// and the existing bit_hamming_distance.vuma already covers Hamming distance
// (using 0xFF ^ 0xFC = 2). This test instead exercises the numerical
// difference interpretation, returning 2.
//
// Workaround note: VUMA does not have a builtin abs() for unsigned types,
// but since 0xFF >= 0xFD, we just subtract directly.
fn main() -> i32 {
    a: u64 = 0xFF;
    b: u64 = 0xFD;
    result: u64 = a - b;
    return result;
}
