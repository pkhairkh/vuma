// s57_bit_xor_then_and.vuma — (90 ^ 60) & 200 = 102 & 200 = 64
// Expected exit code: 64
//
// Two-stage bitwise: XOR then AND. 90 ^ 60 = 102 (0x66);
// 102 & 200 = 64 (0x40). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_xor_then_or (255) and s50_bit_xor_then_shr (31).

fn main() -> i32 {
    a: u64 = 90;
    b: u64 = 60;
    c: u64 = 200;
    x: u64 = a ^ b;        // 102
    r: u64 = x & c;        // 64
    return r;
}
