// s68_bit_xor_then_or.vuma — (0x99 ^ 0x18) | 0x04 = 0x81 | 0x04 = 0x85 = 133
// Expected exit code: 133
//
// Two-stage bitwise: XOR then OR. (153 ^ 24) = 129 (0x81);
// 129 | 4 = 133 (0x85). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_bit_xor_then_and (80), s62_bit_and_then_or (63) and
// s58_bit_xor_then_and (255).
fn main() -> i32 {
    a: u64 = 153;          // 0x99
    b: u64 = 24;           // 0x18
    c: u64 = 4;            // 0x04
    x: u64 = a ^ b;        // 0x81 = 129
    r: u64 = x | c;        // 0x85 = 133
    return r;
}
