// s48_bit_shl_then_and.vuma — (0x05 << 4) & 0xF0 = 0x50 & 0xF0 = 0x50 = 80
// Expected exit code: 80
//
// Two-stage bitwise: shift left then AND. (5 << 4) = 80 (0x50);
// 80 & 240 = 80 (0x50). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_bit_and_then_shl and s42_bit_shl_xor.

fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 4;
    c: u64 = 240;          // 0xF0
    x: u64 = a << b;       // 0x50 = 80
    r: u64 = x & c;        // 0x50 = 80
    return r;
}
