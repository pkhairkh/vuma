// s8_bit_xor_shr_combine.vuma — (15 ^ 240) >> 1 = 255 >> 1 = 127
// Expected exit code: 127
//
// XOR 15 (0x0F) with 240 (0xF0) = 255 (0xFF), then shift right 1 bit
// gives 127 (0x7F). All operands loaded into variables first. Distinct
// from s6_bit_shl_then_shr (shift chain, no XOR) and s5_bit_xor_then_not
// (double XOR self-cancel).

fn main() -> i32 {
    a: u64 = 15;       // 0x0F
    b: u64 = 240;      // 0xF0
    sh: u64 = 1;
    x: u64 = a ^ b;    // 0xFF = 255
    r: u64 = x >> sh;  // 0x7F = 127
    return r;
}
