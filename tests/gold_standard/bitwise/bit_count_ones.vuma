// bit_count_ones.vuma — Population count (number of set bits) of 15.
// Expected exit code: 4
// 15 = 0b1111 has 4 bits set.
//
// Uses the SWAR popcount algorithm (no loops, straight-line only):
//   v = (v & 0x5555...) + ((v >> 1) & 0x5555...)
//   v = (v & 0x3333...) + ((v >> 2) & 0x3333...)
//   v = (v & 0x0F0F...) + ((v >> 4) & 0x0F0F...)
// For an 8-bit input the result already sits in the low byte.
//
// Workaround note: nested (shift) & mask patterns after a prior shift-and-mask
// are miscompiled, so each shift-then-mask is split into two statements.
fn main() -> i32 {
    x: u64 = 15;
    m1: u64 = 0x5555555555555555;
    m2: u64 = 0x3333333333333333;
    m3: u64 = 0x0F0F0F0F0F0F0F0F;
    one: u64 = 1;
    two: u64 = 2;
    four: u64 = 4;
    x0: u64 = x & m1;
    xs: u64 = x >> one;
    x1: u64 = xs & m1;
    s0: u64 = x0 + x1;
    y0: u64 = s0 & m2;
    ys: u64 = s0 >> two;
    y1: u64 = ys & m2;
    s1: u64 = y0 + y1;
    z0: u64 = s1 & m3;
    zs: u64 = s1 >> four;
    z1: u64 = zs & m3;
    s2: u64 = z0 + z1;
    return s2;
}
