// s70_bit_shl_then_and.vuma — (5 << 5) & 0xFF = 160 & 255 = 160
// Expected exit code: 160
//
// Two-stage bitwise: shift left then AND. (5 << 5) = 160;
// 160 & 255 = 160. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s66_bit_shr_then_or (27), s65_bit_xor_then_and (90) and
// s58_bit_xor_then_and (255).
fn main() -> i32 {
    a: u64 = 5;
    b: u64 = 5;
    c: u64 = 255;          // 0xFF
    x: u64 = a << b;       // 0xA0 = 160
    r: u64 = x & c;        // 0xA0 = 160
    return r;
}
