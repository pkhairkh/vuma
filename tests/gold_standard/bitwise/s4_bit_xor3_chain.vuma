// s4_bit_xor3_chain.vuma — 0xF0 ^ 0x0F ^ 0xAA = 0x55 = 85
// Expected exit code: 85
//
// 0xF0 = 240, 0x0F = 15, 240 ^ 15 = 255 (0xFF).
// 255 ^ 0xAA(170) = 0x55 = 85.
// All operands loaded into variables to dodge the immediate-RHS bug.

fn main() -> i32 {
    a: u64 = 240;   // 0xF0
    b: u64 = 15;    // 0x0F
    c: u64 = 170;   // 0xAA
    t1: u64 = a ^ b;     // 0xFF
    result: u64 = t1 ^ c; // 0x55 = 85
    return result;
}
