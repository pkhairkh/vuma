// s85_bit_or_then_shl.vuma — (5 | 10) << 4 = 0x0F << 4 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: OR then shift left. (5 | 10) = 15 (0x0F);
// 15 << 4 = 240 (0xF0). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s82_bit_or_then_xor, s78_bit_or_then_shl and
// s74_bit_or_then_shl.
fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 10;           // 0x0A
    c: u64 = 4;            // shift amount
    x: u64 = a | b;        // 0x0F = 15
    r: u64 = x << c;       // 0xF0 = 240
    return r;
}
