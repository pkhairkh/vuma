// s73_bit_shr_then_or.vuma — (0xF0 >> 2) | 0x0A = 0x3C | 0x0A = 0x3E = 62
// Expected exit code: 62
//
// Two-stage bitwise: shift right then OR. (240 >> 2) = 60 (0x3C);
// 60 | 10 = 62 (0x3E). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_shl_then_and (160), s69_bit_and_then_shr (126)
// and s66_bit_shr_then_or (27).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 2;
    c: u64 = 10;           // 0x0A
    x: u64 = a >> b;       // 0x3C = 60
    r: u64 = x | c;        // 0x3E = 62
    return r;
}
