// s36_bit_shl_then_xor.vuma — (1 << 4) ^ 0x55 = 0x10 ^ 0x55 = 0x45 = 69
// Expected exit code: 69
//
// Two-stage bitwise: SHL then XOR. (1 << 4) = 16 (0x10);
// 16 ^ 0x55 = 69 (0x45). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s30_bit_shl_then_or (shl-then-or, 0) and s27_bit_shl_then_xor (different values).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 85;           // 0x55
    x: u64 = a << b;       // 0x10 = 16
    r: u64 = x ^ c;        // 0x45 = 69
    return r;
}
