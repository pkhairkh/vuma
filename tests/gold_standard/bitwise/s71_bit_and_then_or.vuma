// s71_bit_and_then_or.vuma — (0x3C & 0x0F) | 0x80 = 0x0C | 0x80 = 0x8C = 140
// Expected exit code: 140
//
// Two-stage bitwise: AND then OR. (60 & 15) = 12 (0x0C); 12 | 128
// = 140 (0x8C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s69_bit_xor_then_or (223), s70_bit_xor_then_shl (96) and s66_bit_
// or_then_shl (112).
fn main() -> i32 {
    a: u64 = 60;           // 0x3C
    b: u64 = 15;           // 0x0F
    c: u64 = 128;          // 0x80
    x: u64 = a & b;        // 0x0C = 12
    r: u64 = x | c;        // 0x8C = 140
    return r;
}
