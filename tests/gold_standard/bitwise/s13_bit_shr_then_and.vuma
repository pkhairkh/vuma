// s13_bit_shr_then_and.vuma — (240 >> 2) & 0x3F = 60 & 63 = 60
// Expected exit code: 60
//
// Shift right then mask. (240 >> 2) = 60; 60 & 63 = 60. All operands
// loaded into u64 variables first. Distinct from s6_bit_shl_then_shr
// (shl-then-shr, no mask) and s10_bit_shl_and_mask (shl-then-mask).

fn main() -> i32 {
    v: u64 = 240;         // 0xF0
    s: u64 = 2;
    m: u64 = 63;          // 0x3F
    a: u64 = v >> s;      // 60
    r: u64 = a & m;       // 60
    return r;
}
