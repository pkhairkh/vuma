// s92_bit_shl_then_and.vuma — (9 << 2) & 0x3F = 36 & 63 = 36
// Expected exit code: 36
//
// Two-stage bitwise: shift-left then AND. 9 << 2 = 36;
// 36 & 63 = 36. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_shl_then_and (20), s86_bit_shl_then_xor (33) and
// s82_bit_or_then_xor (76).
fn main() -> i32 {
    a: u64 = 9;
    b: u64 = 2;
    c: u64 = 63;           // 0x3F
    x: u64 = a << b;       // 36
    r: u64 = x & c;        // 36
    return r;
}
