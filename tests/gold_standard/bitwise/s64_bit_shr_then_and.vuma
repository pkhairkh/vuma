// s64_bit_shr_then_and.vuma — (0xF8 >> 2) & 0x3C = 0x3E & 0x3C = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: shift right then AND. (248 >> 2) = 62 (0x3E);
// 62 & 60 = 60 (0x3C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s62_bit_
// and_then_or (63), s62_bit_shl_then_and (64) and s62_bit_xor_then_shr
// (31).

fn main() -> i32 {
    a: u64 = 248;          // 0xF8
    b: u64 = 2;
    c: u64 = 60;           // 0x3C
    x: u64 = a >> b;       // 0x3E = 62
    r: u64 = x & c;        // 0x3C = 60
    return r;
}
