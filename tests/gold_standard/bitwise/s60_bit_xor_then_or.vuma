// s60_bit_xor_then_or.vuma — (0x6A ^ 0x55) | 0x80 = 0x3F | 0x80 = 0xBF = 191
// Expected exit code: 191
//
// Two-stage bitwise: XOR then OR. (106 ^ 85) = 63 (0x3F);
// 63 | 128 = 191 (0xBF). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_bit_xor_then_and (255) and s57_bit_xor_then_and (64).

fn main() -> i32 {
    a: u64 = 106;          // 0x6A
    b: u64 = 85;           // 0x55
    c: u64 = 128;          // 0x80
    x: u64 = a ^ b;        // 0x3F = 63
    r: u64 = x | c;        // 0xBF = 191
    return r;
}
