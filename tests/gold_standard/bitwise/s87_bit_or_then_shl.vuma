// s87_bit_or_then_shl.vuma — (0x18 | 0x07) << 2 = 0x1F << 2 = 0x7C = 124
// Expected exit code: 124
//
// Two-stage bitwise: OR then shift left. (24 | 7) = 31 (0x1F);
// 31 << 2 = 124 (0x7C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_bit_or_then_shl (92), s82_bit_xor_then_shl (120) and
// s78_bit_or_then_shl (1).
fn main() -> i32 {
    a: u64 = 24;           // 0x18
    b: u64 = 7;            // 0x07
    c: u64 = 2;            // shift amount
    x: u64 = a | b;        // 0x1F = 31
    r: u64 = x << c;       // 0x7C = 124
    return r;
}
