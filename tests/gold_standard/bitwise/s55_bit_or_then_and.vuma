// s55_bit_or_then_and.vuma — (0x33 | 0xCC) & 0xF0 = 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: OR then AND. (51 | 204) = 255 (0xFF);
// 255 & 240 = 240 (0xF0). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_xor_then_or (255) and s53_bit_or_then_xor (207).

fn main() -> i32 {
    a: u64 = 51;            // 0x33
    b: u64 = 204;           // 0xCC
    c: u64 = 240;           // 0xF0
    x: u64 = a | b;         // 0xFF = 255
    r: u64 = x & c;         // 0xF0 = 240
    return r;
}
