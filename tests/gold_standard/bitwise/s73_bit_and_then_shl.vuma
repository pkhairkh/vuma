// s73_bit_and_then_shl.vuma — (0xFF & 0x09) << 3 = 0x09 << 3 = 0x48 = 72
// Expected exit code: 72
//
// Two-stage bitwise: AND then shift left. (255 & 9) = 9 (0x09);
// 9 << 3 = 72 (0x48). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_xor_then_shl (96), s69_bit_xor_then_or (223)
// and s66_bit_or_then_shl (112).
fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 9;            // 0x09
    c: u64 = 3;
    x: u64 = a & b;        // 0x09 = 9
    r: u64 = x << c;       // 0x48 = 72
    return r;
}
