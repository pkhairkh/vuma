// s62_bit_and_then_or.vuma — (0x0F & 0xFF) | 0x30 = 0x0F | 0x30 = 0x3F = 63
// Expected exit code: 63
// 
// Two-stage bitwise: AND then OR. (15 & 255) = 15 (0x0F);
// 15 | 48 = 63 (0x3F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_bit_
// or_then_and (204), s58_bit_xor_then_and (255) and s55_bit_shr_then_
// xor (31).

fn main() -> i32 {
    a: u64 = 15;           // 0x0F
    b: u64 = 255;          // 0xFF
    c: u64 = 48;           // 0x30
    x: u64 = a & b;        // 0x0F = 15
    r: u64 = x | c;        // 0x3F = 63
    return r;
}
