// s9_bit_shl_then_or.vuma — (1 << 3) | 5 = 8 | 5 = 13
// Expected exit code: 13
//
// Shift left 1 by 3 bits -> 8, then OR with 5 -> 13. All operands
// loaded into variables first to dodge the immediate-RHS bitwise
// drop bug. Distinct from s6_bit_shl_then_shr (shift-then-shift).

fn main() -> i32 {
    v: u64 = 1;
    sh: u64 = 3;
    m: u64 = 5;
    shifted: u64 = v << sh;   // 8
    r: u64 = shifted | m;     // 13
    return r;
}
