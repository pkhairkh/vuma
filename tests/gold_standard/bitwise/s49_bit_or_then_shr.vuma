// s49_bit_or_then_shr.vuma — (0x70 | 0x08) >> 1 = 0x78 >> 1 = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: OR then shift right. (112 | 8) = 120 (0x78);
// 120 >> 1 = 60 (0x3C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_bit_shr_then_or (63, shr-then-or) and s42_bit_or_then_xor
// (85, or-then-xor).

fn main() -> i32 {
    a: u64 = 112;          // 0x70
    b: u64 = 8;            // 0x08
    c: u64 = 1;
    m: u64 = a | b;        // 0x78 = 120
    r: u64 = m >> c;       // 0x3C = 60
    return r;
}
