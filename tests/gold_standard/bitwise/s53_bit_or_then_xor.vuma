// s53_bit_or_then_xor.vuma — (0x33 | 0x0C) ^ 0xF0 = 0x3F ^ 0xF0 = 0xCF = 207
// Expected exit code: 207
//
// Two-stage bitwise: OR then XOR. (51 | 12) = 63 (0x3F);
// 63 ^ 240 = 207 (0xCF). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s49_bit_or_then_shr (60) and s50_bit_or_then_shr (60).

fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 12;           // 0x0C
    c: u64 = 240;          // 0xF0
    x: u64 = a | b;        // 0x3F = 63
    r: u64 = x ^ c;        // 0xCF = 207
    return r;
}
