// s82_bit_shr_then_and.vuma — (0xF0 >> 2) & 0x3C = 0x3C & 0x3C = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: shift right then AND. (240 >> 2) = 60
// (0x3C); 60 & 60 = 60 (0x3C). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s78_bit_or_then_shl (1), s74_bit_shr_then_xor
// (55) and s72_bit_and_then_or (140).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 2;            // shift amount
    c: u64 = 60;           // 0x3C
    x: u64 = a >> b;       // 0x3C = 60
    r: u64 = x & c;        // 0x3C = 60
    return r;
}
