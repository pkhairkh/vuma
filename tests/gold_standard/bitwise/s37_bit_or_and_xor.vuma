// s37_bit_or_and_xor.vuma — (0xF0 | 0x0F) & 0xFF ^ 0x55 = 0xFF ^ 0x55 = 0xAA = 170
// Expected exit code: 170
//
// Deterministic test in the bitwise category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_bit_and_or_chain (and-or-chain, 202) and s30_bit_or_then_and (or-then-and).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 255;          // 0xFF
    d: u64 = 85;           // 0x55
    x: u64 = a | b;        // 0xFF = 255
    y: u64 = x & c;        // 0xFF = 255
    r: u64 = y ^ d;        // 0xAA = 170
    return r;
}
