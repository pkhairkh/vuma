// s49_bit_xor_then_shl.vuma — (0x55 ^ 0x0A) << 1 = 0x5F << 1 = 0xBE = 190
// Expected exit code: 190
//
// Two-stage bitwise: XOR then shift left. (85 ^ 10) = 95 (0x5F);
// 95 << 1 = 190 (0xBE). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_bit_and_then_shl (224, and-then-shl) and s42_bit_shl_then_and
// (64, shl-then-and).

fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 10;           // 0x0A
    c: u64 = 1;
    x: u64 = a ^ b;        // 0x5F = 95
    r: u64 = x << c;       // 0xBE = 190
    return r;
}
