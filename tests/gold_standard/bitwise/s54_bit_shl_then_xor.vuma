// s54_bit_shl_then_xor.vuma — (1 << 5) ^ 0x3C = 32 ^ 60 = 28
// Expected exit code: 28
//
// Two-stage bitwise: shift left then XOR. 1 << 5 = 32;
// 32 ^ 60 = 28 (0x1C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s50_bit_or_then_shr (63) and s49_bit_or_then_shr (240).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 60;           // 0x3C
    x: u64 = a << b;       // 32
    r: u64 = x ^ c;        // 0x1C = 28
    return r;
}
