// s74_bit_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0x72 = 0xFF ^ 0x72 = 0x8D = 141
// Expected exit code: 141
//
// Two-stage bitwise: OR then XOR. 240 | 15 = 255 (0xFF);
// 255 ^ 114 = 141 (0x8D). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s70_bit_and_then_xor (36), s66_bit_or_then_shl (180) and
// s62_bit_or_then_xor (48).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 114;          // 0x72
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x ^ c;        // 0x8D = 141
    return r;
}
