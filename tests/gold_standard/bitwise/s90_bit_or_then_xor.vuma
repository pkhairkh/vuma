// s90_bit_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0xEC = 0xFF ^ 0xEC = 0x13 = 19
// Expected exit code: 19
//
// Two-stage bitwise: OR then XOR. (240 | 15) = 255 (0xFF);
// 255 ^ 236 = 19 (0x13). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_bit_xor_then_and (60), s82_bit_or_then_xor (76) and
// s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 236;          // 0xEC
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0x13 = 19
    return r;
}
