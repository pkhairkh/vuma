// s56_bit_and_then_xor.vuma — (0xF0 & 0xCC) ^ 0x0F = 0xC0 ^ 0x0F = 207
// Expected exit code: 207
//
// Two-stage bitwise: AND then XOR. 240 & 204 = 192 (0xC0); 192 ^ 15 =
// 207 (0xCF). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_xor_then_or (255) and s50_bit_xor_then_shr (31).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 204;          // 0xCC
    c: u64 = 15;           // 0x0F
    x: u64 = a & b;        // 0xC0 = 192
    r: u64 = x ^ c;        // 0xCF = 207
    return r;
}
