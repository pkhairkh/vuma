// s28_fn_one_arg_mul.vuma — dbl(40) = 80
// Expected exit code: 80
//
// Helper dbl(x) = x * 2. main calls dbl(40) -> 80. Single literal
// argument, multiplication. Distinct from s26_fn_one_arg_sub
// (sub, 43) and s22_fn_one_arg_add (add).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = dbl(40);
    return v;
}
