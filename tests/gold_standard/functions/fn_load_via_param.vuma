// fn_load_via_param.vuma — main stores 42, function loads and returns
// Expected exit code: 42
//
// Tests that a store performed in main is visible to a callee through
// its Address parameter. main stores 42 at *buf; the function reads *p
// into a local variable and returns it.

fn load_val(p: Address) -> u32 {
    v: u32 = *p;
    return v;
}

fn main() -> i32 {
    buf = allocate(8);
    *buf = 42;
    v: u32 = load_val(buf);
    free(buf);
    return v;
}
