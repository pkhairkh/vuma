// s52_fn_one_arg_add.vuma — add_seven(50) = 57
// Expected exit code: 57
//
// Helper add_seven(x) = x + 7. main calls add_seven(50) -> 57.
// Single-arg function that adds a literal. Distinct from
// s50_fn_one_arg_add (69) and s46_fn_one_arg_sub (73).

fn add_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_seven(50);
    return v;
}
