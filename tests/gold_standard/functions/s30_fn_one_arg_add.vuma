// s30_fn_one_arg_add.vuma — add_five(40) = 45
// Expected exit code: 45
//
// Helper add_five(x) = x + 5. main calls add_five(40) -> 45. Single
// function call, single literal argument, addition. Distinct from
// s26_fn_one_arg_sub (sub_seven(50) = 43) and s22_fn_one_arg_add
// (add_six(36) = 42).

fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_five(40);
    return v;
}
