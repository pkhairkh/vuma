// fn_deep_nesting.vuma — 10 levels of nested function calls
// Expected exit code: 10
//
// Tests ten levels of function-call nesting. Each function is an identity
// function; the value 10 is threaded through all ten. Implemented with
// intermediate variables because VUMA miscompiles nested call expressions
// used directly as arguments.

fn id1(x: u32) -> u32 { return x; }
fn id2(x: u32) -> u32 { return x; }
fn id3(x: u32) -> u32 { return x; }
fn id4(x: u32) -> u32 { return x; }
fn id5(x: u32) -> u32 { return x; }
fn id6(x: u32) -> u32 { return x; }
fn id7(x: u32) -> u32 { return x; }
fn id8(x: u32) -> u32 { return x; }
fn id9(x: u32) -> u32 { return x; }
fn id10(x: u32) -> u32 { return x; }

fn main() -> i32 {
    a: u32 = id1(10);
    b: u32 = id2(a);
    c: u32 = id3(b);
    d: u32 = id4(c);
    e: u32 = id5(d);
    f: u32 = id6(e);
    g: u32 = id7(f);
    h: u32 = id8(g);
    i: u32 = id9(h);
    v: u32 = id10(i);
    return v;
}
