// s53_fn_one_arg_sub.vuma — sub_seven(95) = 88
// Expected exit code: 88
//
// Helper sub_seven(x) = x - 7. main calls sub_seven(95) -> 88.
// Single-arg function that subtracts a literal. Distinct from
// s49_fn_one_arg_add (59) and s50_fn_one_arg_add (69).

fn sub_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_seven(95);
    return v;
}
