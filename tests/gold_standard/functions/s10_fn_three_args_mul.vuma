// s10_fn_three_args_mul.vuma — mul3(3, 4, 5) = 60
// Expected exit code: 60
//
// Helper mul3(a, b, c) = a * b * c. main calls mul3(3, 4, 5) -> 60.
// Distinct from s5_fn_three_args_sum (three args, sum, not mul) and
// s6_fn_two_args_mul (two args, mul).

fn mul3(a: u32, b: u32, c: u32) -> u32 {
    t1: u32 = a * b;
    r: u32 = t1 * c;
    return r;
}

fn main() -> i32 {
    v: u32 = mul3(3, 4, 5);
    return v;
}
