// s97_fn_two_args_mul.vuma — mul(4, 6) = 4 * 6 = 24
// Expected exit code: 24
//
// Helper mul(a, b) = a * b. main calls mul(4, 6) -> 24.
// Two-arg function multiplying its arguments.
// Distinct from s94_fn_one_arg_sub (41), s90_fn_two_args_mul (16), s86_fn_one_arg_add (210).
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(4, 6);      // 24
    return v;
}
