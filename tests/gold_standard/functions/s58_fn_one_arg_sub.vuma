// s58_fn_one_arg_sub.vuma — sub_eight(100) = 92
// Expected exit code: 92
// 
// Helper sub_eight(x) = x - 8. main calls sub_eight(100) -> 92.
// Single-arg function that subtracts a literal. Distinct from
// s51_fn_zero_arg_lit (134), s51_fn_one_arg_add (62) and s51_fn_two_
// args_mul (135).

fn sub_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_eight(100);
    return v;
}
