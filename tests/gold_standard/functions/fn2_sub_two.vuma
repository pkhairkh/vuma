// fn2_sub_two.vuma — sub(10, 4) = 6
// Expected exit code: 6
//
// Tests passing two u32 parameters to a function and returning their
// difference. Verifies that subtraction flows through the call/return
// path.

fn sub(a: u32, b: u32) -> u32 {
    return a - b;
}

fn main() -> i32 {
    v: u32 = sub(10, 4);
    return v;
}
