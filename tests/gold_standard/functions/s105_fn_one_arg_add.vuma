// s105_fn_one_arg_add.vuma — inc(82) = 82 + 1 = 83
// Expected exit code: 83
// 
// Helper inc(x) = x + 1. main calls inc(82) -> 83. Single-arg function adding a constant.
// Distinct from s102_fn_one_arg_add (19), s101_fn_one_arg_mul (55), s100_fn_one_arg_add (37).
fn inc(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = inc(82);      // 83
    return v;
}
