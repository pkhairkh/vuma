// s24_fn_zero_arg_lit.vuma — get_99() returns 99
// Expected exit code: 99
//
// Helper takes no parameters and returns the constant 99. Tests that
// the codegen can compile and call a zero-argument function that returns
// a function-local constant. Distinct from s22_fn_zero_arg_lit (returns
// 88) and s18_fn_zero_arg_lit (returns 77).

fn get_99() -> u32 {
    c: u32 = 99;
    return c;
}

fn main() -> i32 {
    v: u32 = get_99();
    return v;
}
