// s20_fn_two_args_sub.vuma — sub(90, 30) = 60
// Expected exit code: 60
//
// Helper sub(a, b) = a - b. main calls sub(90, 30) -> 60. Two-argument
// function, subtraction. Distinct from s18_fn_two_args_add (two-arg add)
// and s14_fn_two_args_sub (different operands).

fn sub(a: u32, b: u32) -> u32 {
    r: u32 = a - b;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(90, 30);
    return v;
}
