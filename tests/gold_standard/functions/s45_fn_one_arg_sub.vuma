// s45_fn_one_arg_sub.vuma — sub_seven(60) = 53
// Expected exit code: 53
//
// Helper sub_seven(x) = x - 7. main calls sub_seven(60) -> 53.
// Single-arg function that subtracts a literal. Distinct from
// s42_fn_one_arg_add (add_eight(50) = 58) and s34_fn_one_arg_add
// (add_five(60) = 65).

fn sub_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_seven(60);
    return v;
}
