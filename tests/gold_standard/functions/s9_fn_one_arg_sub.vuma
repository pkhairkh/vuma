// s9_fn_one_arg_sub.vuma — sub5(100) = 95
// Expected exit code: 95
//
// Helper sub5(x) = x - 5. main calls sub5(100) -> 95. Single
// function call, single literal argument, subtraction. Distinct
// from s4_fn_pass_literal (tripler, mul) and s4_fn_nested_call
// (two helpers).

fn sub5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub5(100);
    return v;
}
