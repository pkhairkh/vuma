// s92_fn_zero_arg_lit.vuma — get_const() = 50
// Expected exit code: 50
//
// Helper get_const() returns the literal 50. main calls get_const()
// -> 50. Zero-arg function returning a literal. Distinct from
// s90_fn_zero_arg_lit (9), s86_fn_zero_arg_lit (240) and
// s82_fn_zero_arg_lit (195).
fn get_const() -> u32 {
    v: u32 = 50;
    return v;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
