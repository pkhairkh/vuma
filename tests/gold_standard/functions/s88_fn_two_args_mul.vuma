// s88_fn_two_args_mul.vuma — mul(15, 9) = 15 * 9 = 135
// Expected exit code: 135
//
// Helper mul(x, y) = x * y. main calls mul(15, 9) -> 135.
// Two-arg function that multiplies. Distinct from s86_fn_
// two_args_sub (150), s82_fn_two_args_mul (56) and s78_
// fn_two_args_sub (3).
fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(15, 9);
    return v;
}
