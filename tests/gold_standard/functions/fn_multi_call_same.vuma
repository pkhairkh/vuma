// fn_multi_call_same.vuma — call same function 3 times, sum results
// Expected exit code: 126 (40 + 42 + 44)
//
// Tests invoking the same leaf function three times with different
// arguments and summing the results. Each result is captured in its own
// local variable to avoid the nested-call-as-argument miscompilation.

fn id(x: u32) -> u32 {
    return x;
}

fn main() -> i32 {
    a: u32 = id(40);
    b: u32 = id(42);
    c: u32 = id(44);
    v: u32 = a + b + c;
    return v;
}
