// s18_fn_one_arg_mul.vuma — triple(14) = 42
// Expected exit code: 42
//
// Helper triple(x) = x * 3. main calls triple(14) -> 42. Single
// function call, single literal argument, multiplication. Distinct
// from s14_fn_one_arg_add (add_one(41) = 42, addition) and
// s9_fn_one_arg_sub (sub5(100) = 95).

fn triple(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = triple(14);
    return v;
}
