// s88_fn_one_arg_add.vuma — add_forty(150) = 150 + 40 = 190
// Expected exit code: 190
//
// Helper add_forty(x) = x + 40. main calls add_forty(150)
// -> 190. Single-arg function that adds a literal. Distinct
// from s86_fn_one_arg_add (210), s82_fn_one_arg_add (170)
// and s78_fn_one_arg_add (2).
fn add_forty(x: u32) -> u32 {
    n: u32 = 40;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_forty(150);
    return v;
}
