// s106_fn_two_args_add.vuma — add(20, 51) = 20 + 51 = 71
// Expected exit code: 71
//
// Helper add(a, b) = a + b. main calls add(20, 51) -> 71. Two-arg function adding.
// Distinct from s102_fn_two_args_mul (26), s101_fn_two_args_add (75), s100_fn_two_args_mul (40).
fn add(a: u32, b: u32) -> u32 {
    r: u32 = a + b;
    return r;
}

fn main() -> i32 {
    v: u32 = add(20, 51);   // 71
    return v;
}
