// s46_fn_one_arg_sub.vuma — sub_seven(80) = 73
// Expected exit code: 73
//
// Helper sub_seven(x) = x - 7. main calls sub_seven(80) -> 73.
// Single-arg function that subtracts a literal. Distinct from
// s42_fn_one_arg_add (add_eight(50) = 58) and s38_fn_one_arg_sub
// (sub_three(50) = 47).

fn sub_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_seven(80);
    return v;
}
