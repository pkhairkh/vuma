// s96_fn_two_args_mul.vuma — mul(6, 7) = 6 * 7 = 42
// Expected exit code: 42
//
// Two-arg helper mul(x, y) = x * y. main calls mul(6, 7) -> 42.
// Distinct from s94_fn_two_args_add (88), s90_fn_two_args_mul (16)
// and s86_fn_two_args_sub (150).
fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(6, 7);     // 42
    return v;
}
