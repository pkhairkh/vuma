// s15_fn_inc_by_two.vuma — inc2(40) = 42
// Expected exit code: 42
//
// Helper inc2(x) = x + 2. main calls inc2(40) -> 42. Single function call,
// single literal argument, addition. Distinct from s14_fn_one_arg_add
// (add_one(41) = 42, +1) and s13_fn_inc_by (inc_by(x, 5) framing).

fn inc2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = inc2(40);
    return v;
}
