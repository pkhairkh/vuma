// s82_fn_one_arg_add.vuma — add_twenty(150) = 150 + 20 = 170
// Expected exit code: 170
//
// Helper add_twenty(x) = x + 20. main calls add_twenty(150)
// -> 170. Single-arg function that adds a literal. Distinct
// from s78_fn_one_arg_add (2), s74_fn_one_arg_add (95) and
// s72_fn_one_arg_add (77).
fn add_twenty(x: u32) -> u32 {
    n: u32 = 20;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_twenty(150);
    return v;
}
