// s48_fn_two_args_mul.vuma — mul(7, 15) = 105
// Expected exit code: 105
//
// Helper mul(x, y) = x * y. main calls mul(7, 15) -> 105. Two-arg
// function returning the product. Distinct from s46_fn_two_args_mul
// (mul(9, 11) = 99) and s42_fn_two_args_sub.

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(7, 15);
    return v;
}
