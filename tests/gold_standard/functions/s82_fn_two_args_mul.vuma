// s82_fn_two_args_mul.vuma — mul(7, 8) = 7 * 8 = 56
// Expected exit code: 56
//
// Helper mul(x, y) = x * y. main calls mul(7, 8) -> 56.
// Two-arg function that multiplies. Distinct from s78_fn_two_
// args_sub (3), s74_fn_two_args_mul (132) and s72_fn_two_args_
// sub (60).
fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(7, 8);
    return v;
}
