// s42_fn_two_args_sub.vuma — sub(80, 25) = 55
// Expected exit code: 55
//
// Helper sub(x, y) = x - y. main calls sub(80, 25) -> 55. Two-arg
// function returning the difference. Distinct from s38_fn_two_args_
// mul (mul(7, 9) = 63) and s34_fn_two_args_mul (mul_two(8, 9) = 72).

fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(80, 25);
    return v;
}
