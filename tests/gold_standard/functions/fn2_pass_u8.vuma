// fn2_pass_u8.vuma — pass 200 as u8, return it
// Expected exit code: 200
//
// Tests passing an 8-bit unsigned integer parameter (200) and returning
// it unchanged. Verifies u8 parameter passing round-trip with a value
// above 127 (high bit set).

fn echo_u8(x: u8) -> u8 {
    return x;
}

fn main() -> i32 {
    v: u8 = echo_u8(200);
    return v;
}
