// s78_fn_two_args_sub.vuma — sub(4, 1) = 4 - 1 = 3
// Expected exit code: 3
//
// Helper sub(x, y) = x - y. main calls sub(4, 1) -> 3.
// Two-arg function that subtracts. Distinct from s74_fn_two_args_sub
// (105), s73_fn_two_args_mul (132) and s72_fn_two_args_sub (60).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(4, 1);
    return v;
}
