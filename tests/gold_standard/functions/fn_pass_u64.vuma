// fn_pass_u64.vuma — pass u64 to function, return it
// Expected exit code: 250
//
// Tests passing a 64-bit unsigned integer parameter and returning it
// unchanged. Verifies u64 parameter passing round-trip. The value 250
// is chosen so it fits in the 8-bit exit code (originally the spec called
// for 1000, but Linux exit codes are 0..255).

fn echo_u64(x: u64) -> u64 {
    return x;
}

fn main() -> i32 {
    v: u64 = echo_u64(250);
    return v;
}
