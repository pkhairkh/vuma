// s77_fn_two_args_mul.vuma — mul(19, 4) = 76
// Expected exit code: 76
//
// Helper mul(x, y) = x * y. main calls mul(19, 4) -> 76.
// Two-arg function returning the product. Distinct from
// s70_fn_two_args_mul (220), s66_fn_two_args_add (175) and
// s74_fn_two_args_mul (122).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(19, 4);
    return v;
}
