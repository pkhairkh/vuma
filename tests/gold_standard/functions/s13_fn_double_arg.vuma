// s13_fn_double_arg.vuma — double(63) = 126
// Expected exit code: 126
//
// Helper double(x) = x * 2. main calls double(63) -> 126. Single
// function call, single literal argument, multiplication by a constant
// loaded into a local. Distinct from s9_fn_one_arg_sub (subtract) and
// s13_fn_inc_by (two args, add).

fn double(x: u32) -> u32 {
    c: u32 = 2;
    r: u32 = x * c;
    return r;
}

fn main() -> i32 {
    v: u32 = double(63);
    return v;
}
