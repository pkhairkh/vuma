// fn_return_u64.vuma — function returns u64
// Expected exit code: 202
//
// Tests a function that returns a u64 value. Verifies u64 return type
// propagates through the call/return boundary. Spec called for 400, but
// exit codes are 8-bit (400 mod 256 = 144), so 202 is used instead.

fn get_u64() -> u64 {
    return 202;
}

fn main() -> i32 {
    v: u64 = get_u64();
    return v;
}
