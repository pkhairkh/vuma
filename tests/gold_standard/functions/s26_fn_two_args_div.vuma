// s26_fn_two_args_div.vuma — div_pair(60, 4) = 15
// Expected exit code: 15
//
// Helper div_pair(x, y) = x / y. main calls div_pair(60, 4) -> 15. Two
// literal arguments, division. Distinct from s22_fn_two_args_mul
// (mul(7, 6) = 42) and s18_fn_two_args_sub (sub(70, 28) = 42).

fn div_pair(x: u32, y: u32) -> u32 {
    r: u32 = x / y;
    return r;
}

fn main() -> i32 {
    v: u32 = div_pair(60, 4);
    return v;
}
