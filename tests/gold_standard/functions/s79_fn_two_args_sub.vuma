// s79_fn_two_args_sub.vuma — sub(50, 15) = 50 - 15 = 35
// Expected exit code: 35
//
// Helper sub(x, y) = x - y. main calls sub(50, 15) -> 35.
// Two-arg function that subtracts. Distinct from
// s78_fn_two_args_sub (3), s77_fn_two_args_sub (2) and
// s76_fn_two_args_sub (3).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(50, 15);
    return v;
}
