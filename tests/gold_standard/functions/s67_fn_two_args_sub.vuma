// s67_fn_two_args_sub.vuma — sub(220, 75) = 145
// Expected exit code: 145
//
// Helper sub(x, y) = x - y. main calls sub(220, 75) -> 145.
// Two-arg function returning the difference. Distinct from
// s66_fn_two_args_add (175), s62_fn_two_args_mul (180) and
// s58_fn_two_args_add (155).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(220, 75);
    return v;
}
