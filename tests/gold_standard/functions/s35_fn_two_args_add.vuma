// s35_fn_two_args_add.vuma — add_two(70, 80) = 150
// Expected exit code: 150
//
// Helper add_two(x, y) = x + y. main calls add_two(70, 80) -> 150.
// Single function call, two literal arguments, addition. Distinct
// from s34_fn_two_args_mul (mul_two(8, 9) = 72) and s27_fn_two_
// args_mod (mod(50, 7) = 1).

fn add_two(x: u32, y: u32) -> u32 {
    r: u32 = x + y;
    return r;
}

fn main() -> i32 {
    v: u32 = add_two(70, 80);
    return v;
}
