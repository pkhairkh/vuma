// s10_fn_returns_constant.vuma — answer() returns 42
// Expected exit code: 42
//
// Helper answer() takes no arguments and returns the literal 42.
// main calls answer() and returns its result. Distinct from
// s5_fn_return_constant (helper takes an arg, ignores it) and
// s4_fn_pass_literal (main passes a literal).

fn answer() -> u32 {
    v: u32 = 42;
    return v;
}

fn main() -> i32 {
    r: u32 = answer();
    return r;
}
