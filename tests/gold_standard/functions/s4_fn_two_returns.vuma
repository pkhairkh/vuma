// s4_fn_two_returns.vuma — call two different fns, sum
// Expected exit code: 50  (20 + 30)
//
// `f(x) = x + 5`, `g(x) = x + 10`. main calls f(15) → 20 and
// g(20) → 30, sums them. Tests that two distinct callees coexist.

fn f(x: u32) -> u32 {
    five: u32 = 5;
    r: u32 = x + five;
    return r;
}
fn g(x: u32) -> u32 {
    ten: u32 = 10;
    r: u32 = x + ten;
    return r;
}

fn main() -> i32 {
    a: u32 = f(15);
    b: u32 = g(20);
    s: u32 = a + b;
    return s;
}
