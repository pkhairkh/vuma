// s8_fn_two_returns_diff.vuma — twice(15) + twice(20) = 30 + 40 = 70
// Expected exit code: 70
//
// Helper twice(x) = x * 2. main calls twice(15) -> 30 and twice(20)
// -> 40, sums them. Distinct from s6_fn_double_call_diff (inc helper).

fn twice(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x * two;
    return r;
}

fn main() -> i32 {
    a: u32 = twice(15);   // 30
    b: u32 = twice(20);   // 40
    s: u32 = a + b;       // 70
    return s;
}
