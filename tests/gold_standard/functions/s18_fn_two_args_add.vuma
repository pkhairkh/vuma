// s18_fn_two_args_add.vuma — add(37, 48) = 85
// Expected exit code: 85
//
// Helper add(a, b) = a + b. main calls add(37, 48) -> 85. Two-arg
// function with addition. Distinct from s14_fn_two_args_diff
// (diff(80, 35) = 45, subtraction) and s10_fn_three_args_mul
// (three-arg mul).

fn add(a: u32, b: u32) -> u32 {
    r: u32 = a + b;
    return r;
}

fn main() -> i32 {
    v: u32 = add(37, 48);
    return v;
}
