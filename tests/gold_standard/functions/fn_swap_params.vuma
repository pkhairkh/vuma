// fn_swap_params.vuma — function swaps its two params and returns first
// Expected exit code: 7
//
// Tests parameter ordering: a function takes two parameters (a, b) and
// "swaps" them. After swapping, the first element is the original second
// parameter (b). The function returns b, so swap(3, 7) = 7.
//
// Without local mutation (which VUMA drops inside functions), we model
// the swap by simply returning the second parameter — this exercises the
// second-parameter slot in the calling convention.

fn swap(a: u32, b: u32) -> u32 {
    return b;
}

fn main() -> i32 {
    v: u32 = swap(3, 7);
    return v;
}
