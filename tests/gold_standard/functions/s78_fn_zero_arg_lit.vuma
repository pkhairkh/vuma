// s78_fn_zero_arg_lit.vuma — get_const() = 1
// Expected exit code: 1
//
// Helper get_const() returns the literal 1. main calls
// get_const() -> 1. Zero-arg function returning a literal.
// Distinct from s74_fn_zero_arg_lit (86), s73_fn_zero_arg_lit (117)
// and s72_fn_zero_arg_lit (143).
fn get_const() -> u32 {
    v: u32 = 1;
    return v;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
