// s6_fn_double_call_diff.vuma — inc(10) + inc(20) = 11 + 21 = 32
// Expected exit code: 32
//
// Helper inc(x) = x + 1. main calls inc(10) -> 11 and inc(20) -> 21,
// sums them. Distinct from s5_fn_call_chain_diff_funcs (different
// helpers in chain).

fn inc(x: u32) -> u32 {
    one: u32 = 1;
    r: u32 = x + one;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(10);   // 11
    b: u32 = inc(20);   // 21
    s: u32 = a + b;     // 32
    return s;
}
