// fn2_address_return.vuma — function allocates, stores 42, returns Address
// Expected exit code: 42
//
// Tests a function that allocates an 8-byte buffer, stores the literal
// 42 at offset 0 via *buf, and returns the Address. main loads the
// value back. Verifies that Address return values cross the
// call/return boundary intact.

fn make_buf() -> Address {
    buf = allocate(8);
    *buf = 42;
    return buf;
}

fn main() -> i32 {
    p = make_buf();
    v: u32 = *p;
    free(p);
    return v;
}
