// s90_fn_one_arg_add.vuma — inc(7) = 7 + 7 = 14
// Expected exit code: 14
//
// Helper inc(x) = x + 7. main calls inc(7) -> 14. Single-arg
// function adding a constant. Distinct from s86_fn_one_arg_add
// (241), s82_fn_one_arg_add (196) and s78_fn_one_arg_add (3).
fn inc(x: u32) -> u32 {
    k: u32 = 7;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = inc(7);         // 14
    return v;
}
