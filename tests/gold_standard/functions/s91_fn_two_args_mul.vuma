// s91_fn_two_args_mul.vuma — mul(3, 9) = 3 * 9 = 27
// Expected exit code: 27
//
// Helper mul(a, b) = a * b. main calls mul(3, 9) -> 27. Two-arg
// function multiplying its arguments. Distinct from s90_fn_two_
// args_mul (16), s86_fn_two_args_sub (242) and s82_fn_two_args_mul
// (197).
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(3, 9);      // 27
    return v;
}
