// s57_fn_one_arg_add.vuma — add_n(90) = 90 + 18 = 108
// Expected exit code: 108
//
// Helper add_n(x) = x + n where n = 18. main calls add_n(90) -> 108.
// One-arg function returning x plus a literal. Distinct from s54_fn_
// one_arg_sub (88) and s50_fn_one_arg_sub (70).

fn add_n(x: u32) -> u32 {
    n: u32 = 18;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_n(90);
    return v;
}
