// fn2_mul_two.vuma — mul(3, 4) = 12
// Expected exit code: 12
//
// Tests passing two u32 parameters to a function and returning their
// product. Verifies that multiplication flows through the call/return
// path.

fn mul(a: u32, b: u32) -> u32 {
    return a * b;
}

fn main() -> i32 {
    v: u32 = mul(3, 4);
    return v;
}
