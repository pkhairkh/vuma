// s45_fn_two_args_mul.vuma — mul(7, 8) = 56
// Expected exit code: 56
//
// Helper mul(x, y) = x * y. main calls mul(7, 8) -> 56. Two-arg
// function returning the product. Distinct from s42_fn_two_args_sub
// (sub(80, 25) = 55) and s34_fn_two_args_mul (mul_two(8, 9) = 72).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(7, 8);
    return v;
}
