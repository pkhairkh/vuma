// s98_fn_one_arg_sub.vuma — dec(80) = 80 - 31 = 49
// Expected exit code: 49
//
// Helper dec(x) = x - 31. main calls dec(80) -> 49. Single-arg
// function subtracting a constant. Distinct from s94_fn_one_arg_sub
// (41), s90_fn_one_arg_add (14) and s86_fn_one_arg_add (210).
fn dec(x: u32) -> u32 {
    k: u32 = 31;
    r: u32 = x - k;
    return r;
}

fn main() -> i32 {
    v: u32 = dec(80);        // 49
    return v;
}
