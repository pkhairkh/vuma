// s10_fn_square_then_add.vuma — square(7) + 5 = 49 + 5 = 54
// Expected exit code: 54
//
// Helper square(x) = x * x. main calls square(7) -> 49, then adds 5
// (loaded into a variable first) -> 54. Distinct from s6_fn_pass_intermediate
// (chained calls) and s5_fn_call_chain_diff_funcs (different helpers).

fn square(x: u32) -> u32 {
    r: u32 = x * x;
    return r;
}

fn main() -> i32 {
    sq: u32 = square(7);   // 49
    c: u32 = 5;
    r: u32 = sq + c;       // 54
    return r;
}
