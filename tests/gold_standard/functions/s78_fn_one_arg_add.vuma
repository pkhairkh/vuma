// s78_fn_one_arg_add.vuma — add(1) = 1 + 1 = 2
// Expected exit code: 2
//
// Helper add(x) = x + 1. main calls add(1) -> 1 + 1 = 2.
// One-arg function that adds a constant. Distinct from s74_fn_one_
// arg_add (95), s73_fn_one_arg_add (108) and s72_fn_one_arg_add (77).
fn add(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = add(1);
    return v;
}
