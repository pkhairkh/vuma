// s46_fn_two_args_mul.vuma — mul(9, 11) = 99
// Expected exit code: 99
//
// Helper mul(x, y) = x * y. main calls mul(9, 11) -> 99. Two-arg
// function returning the product. Distinct from s42_fn_two_args_sub
// (sub(80, 25) = 55) and s38_fn_two_args_mul (mul(7, 9) = 63).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(9, 11);
    return v;
}
