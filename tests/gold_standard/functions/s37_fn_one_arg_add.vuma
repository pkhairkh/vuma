// s37_fn_one_arg_add.vuma — add_eight(50) = 58
// Expected exit code: 58
//
// Deterministic test in the functions category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_fn_one_arg_mul (mul_six(20)=120) and s30_fn_one_arg_add (add_five(40)=45).
fn add_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_eight(50);
    return v;
}
