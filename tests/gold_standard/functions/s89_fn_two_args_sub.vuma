// s89_fn_two_args_sub.vuma — sub(18, 5) = 13
// Expected exit code: 13
//
// Helper sub(a, b) = a - b. main calls sub(18, 5) -> 13.
// Two-arg function returning a - b. Distinct from
// s86_fn_two_args_sub (225), s82_fn_two_args_sub (210) and
// s78_fn_two_args_sub (3).
fn sub(a: u32, b: u32) -> u32 {
    r: u32 = a - b;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(18, 5);  // 13
    return v;
}
