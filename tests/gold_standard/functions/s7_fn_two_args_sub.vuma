// s7_fn_two_args_sub.vuma — sub(50, 18) = 32
// Expected exit code: 32
//
// Helper sub(a, b) = a - b. main calls sub(50, 18) -> 32. Distinct
// from s6_fn_two_args_mul (mul, not sub) and s5_fn_three_args_sum
// (three args, sum, not sub).

fn sub(a: u32, b: u32) -> u32 {
    r: u32 = a - b;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(50, 18);   // 32
    return v;
}
