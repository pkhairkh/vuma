// fn_nested_calls.vuma — f(g(h(42))) = 42
// Expected exit code: 42
//
// Tests three levels of nested function calls. Each function is an identity
// function, so the original value (42) should pass through unchanged.
// Uses intermediate variables because VUMA miscompiles nested call
// expressions used directly as arguments.

fn h(x: u32) -> u32 {
    return x;
}

fn g(x: u32) -> u32 {
    return x;
}

fn f(x: u32) -> u32 {
    return x;
}

fn main() -> i32 {
    a: u32 = h(42);
    b: u32 = g(a);
    v: u32 = f(b);
    return v;
}
