// s32_fn_one_arg_sub.vuma - sub_one(100) = 99
// Expected exit code: 99
//
// sub_one(100) = 99. All operands loaded into typed variables before any
// bitwise op (immediate-RHS drop workaround where applicable); stores use
// the `*ptr = literal` (or `*ptr = variable + 0`) form with no `*(ptr +
// offset)` indexing. Distinct from s30_fn_one_arg_add (add, value) and
// s26_fn_one_arg_sub (different value).

fn sub_one(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_one(100);
    return v;
}
