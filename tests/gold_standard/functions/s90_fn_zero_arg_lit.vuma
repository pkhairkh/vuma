// Expected exit code: 9
//
// Helper get_const() returns the literal 9. main calls get_const()
// -> 9. Zero-arg function returning a literal. Distinct from
// s86_fn_zero_arg_lit (240), s82_fn_zero_arg_lit (195) and
// s78_fn_zero_arg_lit (1).
fn get_const() -> u32 {
    v: u32 = 9;
    return v;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
