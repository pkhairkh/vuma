// s62_fn_one_arg_add.vuma — add_fifteen(100) = 115
// Expected exit code: 115
// 
// Helper add_fifteen(x) = x + 15. main calls add_fifteen(100) ->
// 115. Single-arg function that adds a literal. Distinct from
// s51_fn_one_arg_add (62), s58_fn_one_arg_sub (92) and s55_fn_one_
// arg_add (62).

fn add_fifteen(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_fifteen(100);
    return v;
}
