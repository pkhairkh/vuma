// fn_chained_calls.vuma — add(add(3,4), 8) = 15
// Expected exit code: 15
//
// Tests chaining function calls: the result of one call is fed as an
// argument to the next. Uses an intermediate variable because VUMA
// miscompiles nested call expressions used directly as arguments.

fn add(a: u32, b: u32) -> u32 {
    return a + b;
}

fn main() -> i32 {
    inner: u32 = add(3, 4);
    v: u32 = add(inner, 8);
    return v;
}
