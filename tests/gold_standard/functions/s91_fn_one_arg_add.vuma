// s91_fn_one_arg_add.vuma — inc(7) = 7 + 9 = 16
// Expected exit code: 16
//
// Helper inc(x) = x + 9. main calls inc(7) -> 16. Single-arg
// function adding a constant. Distinct from s90_fn_one_arg_add
// (14), s86_fn_one_arg_add (241) and s82_fn_one_arg_add (196).
fn inc(x: u32) -> u32 {
    k: u32 = 9;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = inc(7);         // 16
    return v;
}
