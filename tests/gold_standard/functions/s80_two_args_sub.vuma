// s80_fn_two_args_sub.vuma — sub(30, 2) = 30 - 2 = 28
// Expected exit code: 28
//
// Helper sub(x, y) = x - y. main calls sub(30, 2) -> 28.
// Two-arg function that subtracts. Distinct from s78_fn_two_args_sub
// (3), s74_fn_two_args_sub (105) and s73_fn_two_args_mul (132).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(30, 2);
    return v;
}
