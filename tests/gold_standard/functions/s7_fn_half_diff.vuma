// s7_fn_half_diff.vuma — half(40) - half(20) = 20 - 10 = 10
// Expected exit code: 10
//
// Helper half(x) = x / 2. main calls half(40) -> 20 and half(20)
// -> 10, then subtracts. Distinct from s6_fn_double_call_diff
// (inc helper, sum not diff) and s5_fn_call_chain_diff_funcs
// (chain, not two independent calls).

fn half(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x / two;
    return r;
}

fn main() -> i32 {
    a: u32 = half(40);   // 20
    b: u32 = half(20);   // 10
    d: u32 = a - b;      // 10
    return d;
}
