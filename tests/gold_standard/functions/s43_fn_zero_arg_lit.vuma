// s43_fn_zero_arg_lit.vuma — get_const() = 99
// Expected exit code: 99
//
// Helper get_const() returns the literal 99. main calls get_const()
// -> 99. Zero-arg function returning a literal. Distinct from
// s42_fn_zero_arg_lit (95) and s38_fn_zero_arg_lit (88).

fn get_const() -> u32 {
    v: u32 = 99;
    return v;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
