// fn_call_chain_5.vuma — chain of 5 function calls, each adds 1
// Expected exit code: 5
//
// Tests a five-step chain of `inc` calls, each adding 1 to its argument.
// Starting from 0: inc(inc(inc(inc(inc(0))))) = 5. Implemented with
// intermediate variables because VUMA miscompiles nested call expressions
// used directly as arguments.

fn inc(x: u32) -> u32 {
    return x + 1;
}

fn main() -> i32 {
    a: u32 = inc(0);
    b: u32 = inc(a);
    c: u32 = inc(b);
    d: u32 = inc(c);
    v: u32 = inc(d);
    return v;
}
