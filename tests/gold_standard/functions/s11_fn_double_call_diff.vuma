// s11_fn_double_call_diff.vuma — half(60) + half(40) = 30 + 20 = 50
// Expected exit code: 50
//
// Helper half(x) = x / 2. main calls half twice with different args
// (60 and 40) -> 30 and 20, sums -> 50. Distinct from s6_fn_double_call_diff
// (different helper) and s4_fn_double_call (same args twice).

fn half(x: u32) -> u32 {
    c: u32 = 2;
    r: u32 = x / c;
    return r;
}

fn main() -> i32 {
    a: u32 = half(60);    // 30
    b: u32 = half(40);    // 20
    s: u32 = a + b;       // 50
    return s;
}
