// fn_return_param.vuma — identity(99) = 99
// Expected exit code: 99
//
// Tests the identity function: a single parameter passed in is returned
// unmodified. Verifies that parameter values survive the call/return path.

fn identity(x: u32) -> u32 {
    return x;
}

fn main() -> i32 {
    v: u32 = identity(99);
    return v;
}
