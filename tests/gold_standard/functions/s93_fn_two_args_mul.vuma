// s93_fn_two_args_mul.vuma — mul(2, 19) = 2 * 19 = 38
// Expected exit code: 38
//
// Helper mul(a, b) = a * b. main calls mul(2, 19) -> 38. Two-arg
// function multiplying its arguments. Distinct from s90_fn_two_args_mul (16), s82_fn_two_args_mul (56)
// and s78_fn_two_args_sub (3).
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(2, 19);     // 38
    return v;
}
