// s36_cf_for_count_5.vuma — for loop runs 5 iterations, count = 5
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of
// a for loop with range 0..5. Known "for-body assignments
// don't propagate" bug keeps count at 0 -> exit 0. Will
// exit 5 once fixed.
// Distinct from s30_cf_for_count_3 (3 iterations) and s27_cf_for_count_4 (4 iterations).
// Expected exit code: 5

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        count = count + 1;
    }
    return count;
}
