// Binary Search — Search a sorted array for a target value
// Expected exit code: 0
//
// Implements classic binary search on a sorted array of u64 values stored
// in allocated memory. Returns the index of the target if found, or -1
// (wraps to 255 as u8 exit code) if not found.
//
// VUMA Key Concepts:
//   - Sorted array stored in allocated memory (8-byte u64 stride)
//   - Pointer arithmetic for element access (base + index * 8)
//   - While loop with midpoint computation
//   - Three-way comparison (less, equal, greater)
//   - allocate/free with proper cleanup
//   - O(log n) search complexity

// ===========================================================================
// Read a u64 from array at given index (8-byte stride)
// ===========================================================================

fn arr_read(arr: Address, idx: u64) -> u64 {
    return *(arr + idx * 8);
}

// ===========================================================================
// Binary search: returns index of target, or 0xFFFFFFFF if not found
// ===========================================================================
// The array must be sorted in ascending order.

fn binary_search(arr: Address, len: u64, target: u64) -> u64 {
    lo: u64 = 0;
    hi: u64 = len;
    while lo < hi {
        mid: u64 = lo + (hi - lo) / 2;
        val: u64 = arr_read(arr, mid);
        if val == target {
            return mid;
        } else if val < target {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return 4294967295;   // 0xFFFFFFFF = not found sentinel
}

// ===========================================================================
// Main entry point
// ===========================================================================
// Sorted array: [2, 5, 8, 12, 16, 23, 38, 42, 55, 67, 71, 89, 95]
// Search for target 42 → found at index 7
// Search for target 99 → not found
// Exit code: 7 (index of 42 in the array)

fn main() -> i32 {
    // Allocate array of 13 u64 elements (104 bytes)
    arr = allocate(104);

    // Initialize sorted array
    arr_write_val(arr, 0, 2);
    arr_write_val(arr, 1, 5);
    arr_write_val(arr, 2, 8);
    arr_write_val(arr, 3, 12);
    arr_write_val(arr, 4, 16);
    arr_write_val(arr, 5, 23);
    arr_write_val(arr, 6, 38);
    arr_write_val(arr, 7, 42);
    arr_write_val(arr, 8, 55);
    arr_write_val(arr, 9, 67);
    arr_write_val(arr, 10, 71);
    arr_write_val(arr, 11, 89);
    arr_write_val(arr, 12, 95);

    // Search for 42 — should be at index 7
    idx: u64 = binary_search(arr, 13, 42);

    // Also search for a value NOT in the array (sanity check)
    not_found: u64 = binary_search(arr, 13, 99);

    free(arr);

    // If 42 was found at index 7 and 99 was not found, return 7
    if idx == 7 && not_found == 4294967295 {
        return 7;
    }
    // Error case: unexpected search result
    return 255;
}

// ===========================================================================
// Write a u64 to array at given index (8-byte stride)
// ===========================================================================

fn arr_write_val(arr: Address, idx: u64, val: u64) {
    *(arr + idx * 8) = val;
}
