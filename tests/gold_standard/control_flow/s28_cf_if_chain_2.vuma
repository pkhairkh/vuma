// s28_cf_if_chain_2.vuma — chain of two ifs, last sets x=90
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Two sequential if-true blocks. Each overwrites x: 40, then 90. With
// all conditions `true`, x should end at 90. On the current backend the
// if-true body assignments are dropped, so x stays 0. Distinct from
// s26_cf_if_chain_3 (three-if chain, 180) and s22_cf_if_assign_true
// (single if-true).
// Expected exit code: 90

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 40;
    }
    if true {
        x = 90;
    }
    return x;
}
