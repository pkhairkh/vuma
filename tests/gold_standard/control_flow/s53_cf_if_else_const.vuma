// s53_cf_if_else_const.vuma — if true { x = 68 } else { x = 136 }; return x
// Observed on current x86_64 backend: 136 (FAIL — known bug)
//
// If-true branch should set x = 68, else branch sets x = 136. With a
// literal `true` condition the true branch should win -> 68. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (136) survives instead. Will exit 68
// once the if-body drop bug is fixed. Distinct from s49_cf_if_else_
// const (true=72/else=140, observed 140) and s50_cf_if_else_const
// (true=80/else=200, observed 200).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 68;
    } else {
        x = 136;
    }
    return x;
}
