// cf_for_with_if — if-body assignment inside for must persist after loop
// Expected exit code: 42
//
// Exposes: if-body assignments dropped → r stays 0, exit 0 instead of 42.

fn main() -> i32 {
    r: u32 = 0;
    for i in 0..10 {
        if (i == 5) {
            r = 42;
        }
    }
    return r;
}
