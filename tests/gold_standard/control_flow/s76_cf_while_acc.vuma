// s76_cf_while_acc.vuma — while loop accumulates 61*1 = 61
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 61, add 1 each iteration ->
// 61 total. i increments by 1 each iteration. Known "while-body
// assignments don't propagate" bug keeps acc at 0 -> exit 0.
// Will exit 61 once fixed. Distinct from s74_cf_while_acc (73),
// s73_cf_while_acc_7_step_9 (63) and s72_cf_while_acc_5 (65).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 61 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
