// s61_cf_if_else_const.vuma — if true { x = 88 } else { x = 190 }; return x
// Expected exit code (correct): 88
// Observed on current x86_64 backend: 190 (FAIL — known bug)
// 
// If-true branch should set x = 88, else branch sets x = 190. With
// a literal `true` condition the true branch should win -> 88. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (190) survives instead.
// Will exit 88 once the if-body drop bug is fixed. Distinct from
// s58_cf_while_acc_5 (40), s58_cf_for_count_8 (8) and s58_cf_if_
// else_const (64).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 88;
    } else {
        x = 190;
    }
    return x;
}
