// s37_cf_while_acc_4.vuma — while loop accumulates 4*4 = 16
// Expected exit code (correct): 16
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// While loop accumulates 16 over its iterations. Known
// "while-body assignments don't propagate" bug keeps the accumulator at 0.
// Will exit 16 once fixed.
// Distinct from s33_cf_while_acc_3 (3*3=9) and s30_cf_while_acc_5 (5*5=25).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        acc = acc + 4;
        i = i + 1;
    }
    return acc;
}
