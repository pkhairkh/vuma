// s65_cf_while_acc_3.vuma — while loop accumulates 3*19 = 57
// Expected exit code (correct): 57
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 3, add 19 each iteration ->
// 3 * 19 = 57 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 57 once fixed. Distinct from s51_cf_while_acc_4
// (24), s58_cf_while_acc_5 (40) and s62_cf_while_acc_4 (36).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 3 {
        acc = acc + 19;
        i = i + 1;
    }
    return acc;
}
