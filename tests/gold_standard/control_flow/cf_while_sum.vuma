// cf_while_sum — while loop accumulates sum 0..9
// Expected exit code: 45
//
// Exposes: while-body assignments to non-counter variables (sum) don't propagate.

fn main() -> i32 {
    i: u32 = 0;
    sum: u32 = 0;
    while (i < 10) {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}
