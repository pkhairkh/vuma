// s40_cf_if_else_const.vuma — if true { x = 70 } else { x = 130 }; return x
// Observed on current x86_64 backend: 130 (FAIL — known bug)
//
// If-true branch should set x = 70, else branch sets x = 130. With a
// literal `true` condition the true branch should win -> 70. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (130) survives instead. Will exit 70
// once the if-body drop bug is fixed. Distinct from s38_cf_if_else_
// const (true=42/else=99, observed 99) and s34_cf_if_else_const.
// Expected exit code: 70

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 70;
    } else {
        x = 130;
    }
    return x;
}
