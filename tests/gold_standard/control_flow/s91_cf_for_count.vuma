// s91_cf_for_count.vuma — for loop runs 73 iterations, count = 73
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..73. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 73 once
// fixed. Distinct from s90_cf_for_count (69), s86_cf_for_count (9)
// and s82_cf_for_count (6).
// Expected exit code: 73
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..73 {
        count = count + 1;
    }
    return count;
}
