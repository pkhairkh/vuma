// s59_cf_while_acc_3.vuma — while loop accumulates 3*7 = 21
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 3, add 7 each iteration -> 3 * 7
// = 21 total. i increments by 1 each iteration. Known "while-body
// assignments don't propagate" bug keeps acc at 0 -> exit 0. Will
// exit 21 once fixed. Distinct from s58_cf_for_count_8 (8), s58_cf_
// while_acc_5 (40) and s58_cf_if_else_const (64).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 3 {
        acc = acc + 7;
        i = i + 1;
    }
    return acc;
}
