// s33_cf_while_acc_3.vuma — while loop accumulates 3*3 = 9
// Expected exit code (correct): 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// While loop accumulates 9 over its iterations. Known
// "while-body assignments don't propagate" bug keeps the accumulator at 0.
// Will exit 9 once fixed.
// Distinct from s30_cf_while_acc_5 (5*5=25) and s26_cf_while_acc_6 (6*3=18).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 3 {
        acc = acc + 3;
        i = i + 1;
    }
    return acc;
}
