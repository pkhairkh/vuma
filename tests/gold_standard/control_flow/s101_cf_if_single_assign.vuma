// s101_cf_if_single_assign.vuma — x=0; if true { x = 56 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 56. Known "if-body assignments don't
// propagate" bug keeps x at 0 -> exit 0. Will exit 56 once the bug
// is fixed. Distinct from s98_cf_if_single_assign (31),
// s97_cf_if_single_assign (25) and s94_cf_if_single_assign (91).
// Expected exit code: 56
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 56;
    }
    return x;
}
