// s65_cf_if_single_assign.vuma — single if-true sets x = 98
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// One if-true block that overwrites x = 0 to x = 98. With a literal
// `true` condition x should end at 98. On the current backend the
// if-true body's assignment is dropped, so x stays 0 -> exit 0.
// Will exit 98 once the if-body drop bug is fixed. Distinct from
// s51_cf_if_single_assign (58), s58_cf_if_single_assign (99) and s55_
// cf_if_single_assign (92).
// Expected exit code: 98

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 98;
    }
    return x;
}
