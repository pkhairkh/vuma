// s79_cf_if_single_assign.vuma — x=0; if true { x = 49 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug: for/while/if-body assignments don't propagate)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 49. Known "if-body assignments
// don't propagate" bug keeps x at 0 -> exit 0. Will exit 49
// once the bug is fixed. Distinct from s78_cf_if_single_assign
// (22), s77_cf_if_single_assign (2) and s76_cf_if_single_
// assign (3).
// Expected exit code: 49
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 49;
    }
    return x;
}
