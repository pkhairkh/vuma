// cf2_for_sum — for loop accumulates the sum 0+1+2+3+4 = 10.
// Expected exit code: 10
//
// Exposes VUMA bug: for-body assignments to an accumulator do not propagate.
// On buggy codegen, s stays 0 and exit is 0 instead of 10.

fn main() -> i32 {
    s: u32 = 0;
    for i in 0..5 {
        s = s + i;
    }
    return s;
}
