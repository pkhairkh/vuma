// s74_cf_for_count.vuma — for loop runs 93 iterations, count = 93
// Expected exit code (correct): 93
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..93. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 93 once
// fixed. Distinct from s70_cf_for_count_12 (12), s66_cf_for_
// count_9 (9) and s62_cf_for_count_5 (5).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..93 {
        count = count + 1;
    }
    return count;
}
