// s4_cf_if_assign_simple.vuma — if true { x = 10 } else { x = 20 }; return x
// Expected exit code (correct): 10
// Observed on current x86_64 backend: 10 (PASS)
//
// Historically documented as "if-body assignments are silently
// dropped" (exit 0). On the current backend this simple form
// returns the correct value 10, so the bug does not manifest here.
// Kept in the suite as a regression guard: any future change that
// reintroduces the drop will turn this exit into 0.

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 10;
    } else {
        x = 20;
    }
    return x;
}
