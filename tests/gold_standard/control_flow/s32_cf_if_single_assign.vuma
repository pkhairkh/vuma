// s32_cf_if_single_assign.vuma - if true { x = 65 }; return x
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Body assignment(s) should propagate to the return value. On the current
// backend if-true-body and loop-body assignments are dropped, so the result
// stays 0. Will exit 65 once the SCG/bridge bug is fixed. Distinct from
// s30_cf_if_single_assign (value 70) and s26_cf_if_single_assign (different
// value).
// Expected exit code: 65

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 65;
    }
    return x;
}
