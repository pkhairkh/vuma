// s55_cf_if_else_const.vuma — if true { x = 72 } else { x = 190 }; return x
// Observed on current x86_64 backend: 190 (FAIL — known bug)
//
// If-true branch should set x = 72, else branch sets x = 190. With a
// literal `true` condition the true branch should win -> 72. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (190) survives instead. Will exit 72
// once the if-body drop bug is fixed. Distinct from s54_cf_if_else_
// const (true=70/else=180, observed 180) and s53_cf_if_else_const
// (true=68/else=136, observed 136).
// Expected exit code: 72

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 72;
    } else {
        x = 190;
    }
    return x;
}
