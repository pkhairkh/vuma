// s70_cf_if_single_assign.vuma — single if-true sets x = 100
// Expected exit code (correct): 100
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// One if-true block that overwrites x = 0 to x = 100. With a
// literal `true` condition x should end at 100. On the current
// backend the if-true body's assignment is dropped, so x stays 0
// -> exit 0. Will exit 100 once the if-body drop bug is fixed.
// Distinct from s66_cf_if_single_assign (95), s65_cf_if_single_
// assign (98) and s62_cf_if_single_assign (88).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 100;
    }
    return x;
}
