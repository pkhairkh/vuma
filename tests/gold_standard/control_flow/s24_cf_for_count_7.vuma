// s24_cf_for_count_7.vuma — for loop runs 7 iterations, count = 7
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for loop
// with range 0..7. Known "for-body assignments don't propagate" bug
// keeps count at 0 -> exit 0. Will exit 7 once fixed. Distinct from
// s22_cf_for_count_5 (5 iterations) and s18_cf_for_count_6 (6 iterations).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        count = count + 1;
    }
    return count;
}
