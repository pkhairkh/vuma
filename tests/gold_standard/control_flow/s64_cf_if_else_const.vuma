// s64_cf_if_else_const.vuma — if true { x = 64 } else { x = 200 }; return x
// Observed on current x86_64 backend: 200 (FAIL — known bug)
//
// If-true branch should set x = 64, else branch sets x = 200. With a
// literal `true` condition the true branch should win -> 64. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (200) survives instead. Will exit 64
// once the if-body drop bug is fixed. Distinct from s62_cf_for_count_
// 5 (5), s62_cf_if_else_const (56) and s62_cf_while_acc_4 (36).
// Expected exit code: 64

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 64;
    } else {
        x = 200;
    }
    return x;
}
