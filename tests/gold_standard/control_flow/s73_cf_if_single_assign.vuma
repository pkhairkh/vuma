// s73_cf_if_single_assign.vuma — single if-true sets x = 109
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// One if-true block that overwrites x = 0 to x = 109. With a
// literal `true` condition x should end at 109. On the current
// backend the if-true body's assignment is dropped, so x stays 0
// -> exit 0. Will exit 109 once the if-body drop bug is fixed.
// Distinct from s70_cf_if_single_assign (100), s69_cf_if_single_
// assign (102) and s66_cf_if_single_assign (95).
// Expected exit code: 109
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 109;
    }
    return x;
}
