// s93_cf_for_count.vuma — for loop runs 106 iterations, count = 106
// Expected exit code (correct): 106
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..106. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 106 once
// fixed. Distinct from s90_cf_for_count (69), s82_cf_for_count (6) and s78_cf_for_count (1).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..106 {
        count = count + 1;
    }
    return count;
}
