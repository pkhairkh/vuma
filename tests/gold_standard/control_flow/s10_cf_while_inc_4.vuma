// s10_cf_while_inc_4.vuma — while loop runs 4 iterations, count = 4
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0. Loop guard is `i < 4` (literal) where i is
// incremented each iteration. Each iteration also adds 1 to count.
// After 4 iterations i == 4 and the loop exits; count should be 4.
// Known "while-body assignments don't propagate" bug keeps count at 0.
// Distinct from s6_cf_while_dec_count (6 iterations) and s5_cf_while_acc.
// Expected exit code: 4

fn main() -> i32 {
    i: u32 = 0;
    count: u32 = 0;
    while i < 4 {
        count = count + 1;
        i = i + 1;
    }
    return count;
}
