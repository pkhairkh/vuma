// s53_cf_while_acc_6.vuma — while loop accumulates 6*9 = 54
// Expected exit code (correct): 54
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 6, add 9 each iteration ->
// 6 * 9 = 54 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 54 once fixed. Distinct from s49_cf_while_acc_6
// (6*5 = 30) and s50_cf_while_acc_5 (5*7 = 35).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 6 {
        acc = acc + 9;
        i = i + 1;
    }
    return acc;
}
