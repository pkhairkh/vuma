// s69_cf_while_acc_4.vuma -- while loop accumulates 4*13 = 52
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// Accumulator starts at 0. While i < 4, add 13 each iteration -> 4 *
// 13 = 52 total. i increments by 1 each iteration. Known "while-body
// assignments don't propagate" bug keeps acc at 0 -> exit 0. Will
// exit 52 once fixed. Distinct from s66_cf_while_acc_3 (33), s65_cf_
// while_acc_3 (57) and s64_cf_while_acc_5 (40).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        acc = acc + 13;
        i = i + 1;
    }
    return acc;
}
