// s78_cf_if_else_const.vuma — if true { x = 10 } else { x = 1 }; return x
// Observed on current x86_64 backend: 1 (FAIL — known bug)
//
// If-true branch should set x = 10, else branch sets x =
// 1. With a literal `true` condition the true branch should
// win -> 10. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (1)
// survives instead. Will exit 10 once the if-body drop bug is
// fixed. Distinct from s74_cf_if_else_const (19), s73_cf_if_else_
// const (53) and s72_cf_if_else_const (109).
// Expected exit code: 10
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 10;
    } else {
        x = 1;
    }
    return x;
}
