// s89_cf_for_count.vuma — for loop runs 101 iterations, count = 101
// Expected exit code (correct): 101
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..101. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 101 once
// fixed. Distinct from s86_cf_for_count (9), s82_cf_for_count (6)
// and s78_cf_for_count (1).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..101 {
        count = count + 1;
    }
    return count;
}
