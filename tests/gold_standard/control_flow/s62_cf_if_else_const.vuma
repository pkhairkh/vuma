// s62_cf_if_else_const.vuma — if true { x = 56 } else { x = 220 }; return x
// Observed on current x86_64 backend: 220 (FAIL — known bug)
// 
// If-true branch should set x = 56, else branch sets x = 220. With a
// literal `true` condition the true branch should win -> 56. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (220) survives instead. Will exit 56
// once the if-body drop bug is fixed. Distinct from s51_cf_if_else_
// const (70), s58_cf_if_else_const (64) and s55_cf_if_else_const
// (72).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 56;
    } else {
        x = 220;
    }
    return x;
}
