// s67_cf_if_else_const.vuma — if true { x = 72 } else { x = 200 }; return x
// Observed on current x86_64 backend: 200 (FAIL — known bug)
//
// If-true branch should set x = 72, else branch sets x = 200.
// With a literal `true` condition the true branch should win
// -> 72. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (200)
// survives instead. Will exit 72 once the if-body drop bug is
// fixed. Distinct from s66_cf_if_else_const (correct 84 /
// observed 210), s62_cf_if_else_const (56) and s58_cf_if_
// else_const (64).
// Expected exit code: 72
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 72;
    } else {
        x = 200;
    }
    return x;
}
