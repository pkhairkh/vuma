// s70_cf_while_acc_6.vuma — while loop accumulates 6*11 = 66
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 6, add 11 each iteration ->
// 6 * 11 = 66 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 66 once fixed. Distinct from s66_cf_while_
// acc_3 (33), s65_cf_while_acc_3 (57) and s62_cf_while_acc_4 (36).
// Expected exit code: 66
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 6 {
        acc = acc + 11;
        i = i + 1;
    }
    return acc;
}
