// s29_cf_while_acc_7.vuma — while loop accumulates 7*4 = 28
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 7, add 4 each iteration -> 7 * 4 = 28 total. i increments by 1 each iteration. Known "while-body assignments don't propagate" bug keeps acc at 0 -> exit 0. Will exit 28 once fixed. Distinct from s26_cf_while_acc_6 (6*3 = 18) and s22_cf_while_acc_3 (3*5 = 15).
// Expected exit code: 28

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 7 {
        acc = acc + 4;
        i = i + 1;
    }
    return acc;
}
