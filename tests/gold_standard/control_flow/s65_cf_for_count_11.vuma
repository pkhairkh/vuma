// s65_cf_for_count_11.vuma — for loop runs 11 iterations, count = 11
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..11. Known "for-body assignments don't propagate"
// bug keeps count at 0 -> exit 0. Will exit 11 once fixed. Distinct
// from s51_cf_for_count_7 (7), s58_cf_for_count_8 (8) and s62_cf_for_
// count_5 (5).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..11 {
        count = count + 1;
    }
    return count;
}
