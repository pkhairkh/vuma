// s92_cf_while_acc.vuma — while loop accumulates 1 * 73 = 73
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 73, add 1 each iteration
// -> 1 * 73 = 73 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 73 once fixed. Distinct from s90_cf_while_acc
// (71), s86_cf_while_acc (28) and s82_cf_while_acc (9).
// Expected exit code: 73
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 73 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
