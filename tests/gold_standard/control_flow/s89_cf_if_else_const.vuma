// s89_cf_if_else_const.vuma — if true { x = 89 } else { x = 44 }; return x
// Observed on current x86_64 backend: 44 (FAIL — known bug)
//
// If-true branch should set x = 89, else branch sets x = 44.
// With a literal `true` condition the true branch should win
// -> 89. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (44)
// survives instead. Will exit 89 once the if-body drop bug is
// fixed. Distinct from s86_cf_if_else_const (14), s82_cf_if_else_
// const (12) and s78_cf_if_else_const (10).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 89;
    } else {
        x = 44;
    }
    return x;
}
