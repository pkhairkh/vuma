// cf_if_assign — assignment inside if body must propagate
// Expected exit code: 42
//
// Exposes VUMA bug: if-body assignments are silently dropped.
// On buggy codegen, x remains 0 and exit is 0 instead of 42.

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 42;
    }
    return x;
}
