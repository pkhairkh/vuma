// s19_cf_if_chain_2.vuma — if true x=11; if true x=x+22; return 33
// Expected exit code (correct): 33
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Two consecutive if-true blocks. First sets x = 11, second adds 22
// -> 33. With literal `true` conditions both bodies should run. On
// the current backend both if-true body assignments are dropped, so
// x keeps its init value 0. Distinct from s18_cf_if_assign_true
// (single if-true x=64) and s11_cf_if_chain_2 (single if-true x=15).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 11;
    }
    if true {
        x = x + 22;
    }
    return x;
}
