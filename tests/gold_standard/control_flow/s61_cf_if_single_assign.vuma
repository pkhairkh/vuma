// s61_cf_if_single_assign.vuma — single if-true sets x = 110
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// One if-true block that overwrites x = 0 to x = 110. With a
// literal `true` condition x should end at 110. On the current
// backend the if-true body's assignment is dropped, so x stays 0
// -> exit 0. Will exit 110 once the if-body drop bug is fixed.
// Distinct from s58_cf_while_acc_5 (40), s58_cf_for_count_8 (8)
// and s58_cf_if_else_const (64).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 110;
    }
    return x;
}
