// s73_cf_while_acc_7_step_9.vuma — while loop accumulates 7*9 = 63
// Expected exit code (correct): 63
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 7, add 9 each iteration ->
// 7 * 9 = 63 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 63 once fixed. Distinct from s70_cf_while_acc_
// 6 (66), s69_cf_while_acc_4 (52) and s66_cf_while_acc_3 (33).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 7 {
        acc = acc + 9;
        i = i + 1;
    }
    return acc;
}
