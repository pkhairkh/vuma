// s48_cf_if_else_const.vuma — if true { x = 42 } else { x = 99 }; return x
// Observed on current x86_64 backend: 99 (FAIL — known bug)
//
// If-true branch should set x = 42, else branch sets x = 99. With a
// literal `true` condition the true branch should win -> 42. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (99) survives instead. Will exit 42
// once the if-body drop bug is fixed. Distinct from s46_cf_if_else_
// const (true=55/else=120) and s42_cf_if_else_const.
// Expected exit code: 42

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 42;
    } else {
        x = 99;
    }
    return x;
}
