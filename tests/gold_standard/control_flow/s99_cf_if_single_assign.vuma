// s99_cf_if_single_assign.vuma — x=0; if true { x = 36 }; return x
// Expected exit code (correct): 36
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 36. Known "if-body assignments don't
// propagate" bug keeps x at 0 -> exit 0. Will exit 36 once the bug
// is fixed. Distinct from s95_cf_if_single_assign (119),
// s91_cf_if_single_assign (82) and s87_cf_if_single_assign (33).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 36;
    }
    return x;
}
