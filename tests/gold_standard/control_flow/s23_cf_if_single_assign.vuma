// s23_cf_if_single_assign.vuma — standalone if true sets x=85, return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Standalone if-true body sets x = 85. With a literal `true` condition
// x should become 85. On the current backend the if-true body assignment
// is dropped, so x keeps its init value 0. Distinct from
// s22_cf_if_assign_true (if-true x=81) and s20_cf_if_single_assign
// (if-true x=100).
// Expected exit code: 85

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 85;
    }
    return x;
}

