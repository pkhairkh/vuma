// s100_cf_if_single_assign.vuma — x=0; if true { x = 112 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal
// `true` condition x should become 112. Known "if-body
// assignments don't propagate" bug keeps x at 0 -> exit
// 0. Will exit 112 once the bug is fixed.
// Distinct from s97_cf_if_single_assign (115), s94_cf_if_single_assign (91), s90_cf_if_single_assign (78).
// Expected exit code: 112
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 112;
    }
    return x;
}
