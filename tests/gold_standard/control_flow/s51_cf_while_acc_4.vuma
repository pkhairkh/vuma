// s51_cf_while_acc_4.vuma — while loop accumulates 4*6 = 24
// Expected exit code (correct): 24
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 4, add 6 each iteration ->
// 4 * 6 = 24 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 24 once fixed. Distinct from s50_cf_while_acc_5
// (5*7 = 35) and s47_cf_while_acc_3 (3*9 = 27).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        acc = acc + 6;
        i = i + 1;
    }
    return acc;
}
