// s83_cf_while_acc.vuma — while loop accumulates 1*142 = 142
// Expected exit code (correct): 142
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 1, add 142 each iteration
// -> 1 * 142 = 142 total. i increments by 1 each iteration.
// Known "while-body assignments don't propagate" bug keeps acc
// at 0 -> exit 0. Will exit 142 once fixed. Distinct from
// s78_cf_while_acc (2), s74_cf_while_acc (73) and s72_cf_while_
// acc (29).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 1 {
        acc = acc + 142;
        i = i + 1;
    }
    return acc;
}
