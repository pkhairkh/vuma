// s72_cf_for_count_15.vuma — for loop runs 15 iterations, count = 15
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..15. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 15 once
// fixed. Distinct from s70_cf_for_count_12 (12), s69_cf_for_count_
// 13 (13) and s66_cf_for_count_9 (9).
// Expected exit code: 15
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..15 {
        count = count + 1;
    }
    return count;
}
