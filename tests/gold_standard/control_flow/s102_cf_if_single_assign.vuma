// s102_cf_if_single_assign.vuma — x=0; if true { x = 124 }; return x
// Expected exit code (correct): 124
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true` condition x should become 124. Known "if-body assignments don't propagate" bug keeps x at 0 -> exit 0. Will exit 124 once the bug is fixed.
// Distinct from s101_cf_for_count (83), s101_cf_if_else_const (19), s101_cf_if_single_assign (56).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 124;
    }
    return x;
}
