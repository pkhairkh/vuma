// s75_cf_while_acc.vuma — while loop accumulates 62*1 = 62
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 62, add 1 each iteration ->
// 62 total. i increments by 1 each iteration. Known "while-body
// assignments don't propagate" bug keeps acc at 0 -> exit 0.
// Will exit 62 once fixed. Distinct from s74_cf_while_acc (73),
// s70_cf_while_acc_6 (66) and s66_cf_while_acc_3 (33).
// Expected exit code: 62
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 62 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
