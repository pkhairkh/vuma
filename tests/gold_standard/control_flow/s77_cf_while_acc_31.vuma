// s77_cf_while_acc_31.vuma — while loop accumulates 31*1 = 31
// Expected exit code (correct): 31
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 31, add 1 each iteration ->
// 31 total. i increments by 1 each iteration. Known "while-body
// assignments don't propagate" bug keeps acc at 0 -> exit 0.
// Will exit 31 once fixed. Distinct from s70_cf_while_acc_6 (66),
// s66_cf_while_acc_3 (33) and s74_cf_while_acc (73).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 31 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
