// s99_cf_if_else_const.vuma — if true { x = 71 } else { x = 100 }; return x
// Observed on current x86_64 backend: 100 (FAIL — known bug)
//
// If-true branch should set x = 71, else branch sets x = 100. With
// a literal `true` condition the true branch should win -> 71. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (100) survives instead.
// Will exit 71 once the if-body drop bug is fixed. Distinct from
// s95_cf_if_else_const (121), s91_cf_if_else_const (81) and
// s87_cf_if_else_const (22).
// Expected exit code: 71
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 71;
    } else {
        x = 100;
    }
    return x;
}
