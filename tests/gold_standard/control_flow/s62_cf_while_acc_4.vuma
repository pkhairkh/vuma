// s62_cf_while_acc_4.vuma — while loop accumulates 4*9 = 36
// Expected exit code (correct): 36
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Accumulator starts at 0. While i < 4, add 9 each iteration ->
// 4 * 9 = 36 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 36 once fixed. Distinct from s51_cf_while_acc_4
// (24), s58_cf_while_acc_5 (40) and s55_cf_while_acc_5 (50).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        acc = acc + 9;
        i = i + 1;
    }
    return acc;
}
