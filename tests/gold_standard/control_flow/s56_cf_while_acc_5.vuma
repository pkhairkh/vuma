// s56_cf_while_acc_5.vuma — while loop accumulates 5*11 = 55
// Expected exit code (correct): 55
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 5, add 11 each iteration ->
// 5 * 11 = 55 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 55 once fixed. Distinct from s54_cf_while_acc_6
// (54) and s50_cf_while_acc_5 (35).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 5 {
        acc = acc + 11;
        i = i + 1;
    }
    return acc;
}
