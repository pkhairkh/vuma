// s30_cf_if_else_const.vuma — if true { x = 90 } else { x = 180 }; return x
// Expected exit code (correct): 90
// Observed on current x86_64 backend: 180 (FAIL — known bug)
//
// If-true branch should set x = 90, else branch sets x = 180. With a
// literal `true` condition the true branch should win -> 90. On the
// current backend the if-true body's single assignment is dropped, so
// the else body's assignment (180) survives instead. Will exit 90 once
// the if-body drop bug is fixed. Distinct from s26_cf_if_else_const
// (values 200/100, observed 100) and s22_cf_if_else_const
// (values 70/140, observed 140).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 90;
    } else {
        x = 180;
    }
    return x;
}
