// s105_cf_while_acc.vuma — while loop accumulates 3 * 73 = 219
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Accumulator starts at 0. While i < 73, add 3 each iteration and increment i -> 3 * 73 = 219 total. Known "while-body assignments don't propagate" bug keeps acc at 0 -> exit 0. Will exit 219 once fixed.
// Distinct from s102_cf_while_acc (130), s101_cf_while_acc (134), s100_cf_while_acc (125).
// Expected exit code: 219
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 73 {
        acc = acc + 3;
        i = i + 1;
    }
    return acc;
}
