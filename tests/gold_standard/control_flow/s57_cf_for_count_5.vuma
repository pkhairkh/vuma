// s57_cf_for_count_5.vuma — for loop runs 5 iterations, count = 5
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..5. Known "for-body assignments don't propagate"
// bug keeps count at 0 -> exit 0. Will exit 5 once fixed. Distinct
// from s54_cf_for_count_7 (7) and s50_cf_for_count_6 (6).
// Expected exit code: 5

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        count = count + 1;
    }
    return count;
}
