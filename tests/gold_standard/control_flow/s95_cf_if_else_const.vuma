// s95_cf_if_else_const.vuma — if true { x = 121 } else { x = 122 }; return x
// Observed on current x86_64 backend: 122 (FAIL — known bug)
//
// If-true branch should set x = 121, else branch sets x = 122. With
// a literal `true` condition the true branch should win -> 121. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (122) survives instead.
// Will exit 121 once the if-body drop bug is fixed. Distinct from
// s94_cf_if_else_const (64), s90_cf_if_else_const (79) and
// s82_cf_if_else_const (12).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 121;
    } else {
        x = 122;
    }
    return x;
}
