// s63_cf_if_single_assign.vuma — single if-true sets x = 76
// Expected exit code (correct): 76
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// One if-true block that overwrites x = 0 to x = 76. With a
// literal `true` condition x should end at 76. On the current
// backend the if-true body's assignment is dropped, so x stays 0
// -> exit 0. Will exit 76 once the if-body drop bug is fixed.
// Distinct from s51_cf_if_single_assign (58), s58_cf_if_single_
// assign (99) and s55_cf_if_single_assign (92).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 76;
    }
    return x;
}
