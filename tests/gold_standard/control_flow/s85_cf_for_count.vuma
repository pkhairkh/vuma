// s85_cf_for_count.vuma — for loop runs 7 iterations, count = 7
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a
// for loop with range 0..7. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 7 once
// fixed. Distinct from s82_cf_for_count (6), s78_cf_for_count
// (1) and s74_cf_for_count (33).
// Expected exit code: 7
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        count = count + 1;
    }
    return count;
}
