// s50_cf_if_single_assign.vuma — single if-true sets x = 65
// Expected exit code (correct): 65
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// One if-true block that overwrites x = 0 to x = 65. With a literal
// `true` condition x should end at 65. On the current backend the
// if-true body's assignment is dropped, so x stays 0 -> exit 0.
// Will exit 65 once the if-body drop bug is fixed. Distinct from
// s46_cf_if_single_assign (88) and s43_cf_if_single_assign (66).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 65;
    }
    return x;
}
