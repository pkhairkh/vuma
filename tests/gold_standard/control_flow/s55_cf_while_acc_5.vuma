// s55_cf_while_acc_5.vuma — while loop accumulates 5*10 = 50
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 5, add 10 each iteration ->
// 5 * 10 = 50 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 50 once fixed. Distinct from s54_cf_while_acc_6
// (54) and s53_cf_while_acc_6 (54).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 5 {
        acc = acc + 10;
        i = i + 1;
    }
    return acc;
}
