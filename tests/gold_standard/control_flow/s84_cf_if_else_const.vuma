// s84_cf_if_else_const.vuma — if true { x = 59 } else { x = 7 }; return x
// Observed on current x86_64 backend: 7 (FAIL — known bug)
//
// If-true branch should set x = 59, else branch sets x = 7.
// With a literal `true` condition the true branch should win
// -> 59. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (7)
// survives instead. Will exit 59 once the if-body drop bug is
// fixed. Distinct from s82_cf_if_else_const (12), s78_cf_if_
// else_const (10) and s74_cf_if_else_const (19).
// Expected exit code: 59
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 59;
    } else {
        x = 7;
    }
    return x;
}
