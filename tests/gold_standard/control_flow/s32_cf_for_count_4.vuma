// s32_cf_for_count_4.vuma - for loop runs 4 iterations, count = 4
// Expected exit code (correct): 4
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Body assignment(s) should propagate to the return value. On the current
// backend if-true-body and loop-body assignments are dropped, so the result
// stays 0. Will exit 4 once the SCG/bridge bug is fixed. Distinct from
// s30_cf_for_count_3 (3 iterations) and s26_cf_for_count_4 (4 iterations,
// observed 0).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        count = count + 1;
    }
    return count;
}
