// s106_cf_while_acc.vuma — while loop accumulates 1 * 149 = 149
// Expected exit code (correct): 149
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 149, add 1 each iteration -> 1 * 149 = 149 total. i increments by 1 each iteration. Known "while-body assignments don't propagate" bug keeps acc at 0 -> exit 0. Will exit 149 once fixed.
// Distinct from s102_cf_while_acc (130), s101_cf_while_acc (134), s100_cf_while_acc (125).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 149 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
