// s69_cf_if_single_assign.vuma -- single if-true sets x = 102
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// One if-true block that overwrites x = 0 to x = 102. With a literal
// `true` condition x should end at 102. On the current backend the
// if-true body's assignment is dropped, so x stays 0 -> exit 0. Will
// exit 102 once the if-body drop bug is fixed. Distinct from s66_cf_
// if_single_assign (95), s65_cf_if_single_assign (98) and s64_cf_if_
// single_assign (99).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 102;
    }
    return x;
}
