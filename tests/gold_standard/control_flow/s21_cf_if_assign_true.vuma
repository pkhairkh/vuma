// s21_cf_if_assign_true.vuma — if-true sets x=99, return = 99
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Standalone if-true body sets x = 99. With a literal `true` condition
// x should become 99. On the current backend the if-true body assignment
// is dropped, so x keeps its init value 0. Will exit 99 once fixed.
// Distinct from s18_cf_if_assign_true (x=64) and s11_cf_if_chain_2
// (if-true x=15).
// Expected exit code: 99

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 99;
    }
    return x;
}
