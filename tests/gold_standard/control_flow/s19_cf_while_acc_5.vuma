// s19_cf_while_acc_5.vuma — while loop accumulates 5*6 = 30
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 5, add 6 each iteration ->
// 5 * 6 = 30 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 30 once fixed. Distinct from s18_cf_while_acc_4
// (4*5 = 20) and s14_cf_while_acc (5*3 = 15).
// Expected exit code: 30

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 5 {
        acc = acc + 6;
        i = i + 1;
    }
    return acc;
}
