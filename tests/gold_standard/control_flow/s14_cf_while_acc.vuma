// s14_cf_while_acc.vuma — while loop accumulates 5*3 = 15
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 5, add 3 each iteration ->
// 5 * 3 = 15 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 15 once fixed. Distinct from s9_cf_while_mul2
// (adds 2 each iter, total 10) and s5_cf_while_acc (adds 10).
// Expected exit code: 15

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 5 {
        acc = acc + 3;
        i = i + 1;
    }
    return acc;
}
