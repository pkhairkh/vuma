// s97_cf_if_else_const.vuma — if true { x = 122 } else { x = 37 }; return x
// Observed on current x86_64 backend: 37 (FAIL — known bug)
//
// If-true branch should set x = 122, else branch sets x =
// 37. With a literal `true` condition the true branch
// should win -> 122. On the current backend the if-true
// body's single assignment is dropped, so the else body's
// assignment (37) survives instead. Will exit 122 once the
// if-body drop bug is fixed.
// Distinct from s94_cf_if_else_const (64), s90_cf_if_else_const (79), s86_cf_if_else_const (14).
// Expected exit code: 122
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 122;
    } else {
        x = 37;
    }
    return x;
}
