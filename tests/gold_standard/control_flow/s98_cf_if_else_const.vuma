// s98_cf_if_else_const.vuma — if true { x = 38 } else { x = 90 }; return x
// Expected exit code (correct): 38
// Observed on current x86_64 backend: 90 (FAIL — known bug)
//
// If-true branch should set x = 38, else branch sets x = 90. With
// a literal `true` condition the true branch should win -> 38. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (90) survives instead.
// Will exit 38 once the if-body drop bug is fixed. Distinct from
// s94_cf_if_else_const (64), s90_cf_if_else_const (79) and
// s86_cf_if_else_const (14).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 38;
    } else {
        x = 90;
    }
    return x;
}
