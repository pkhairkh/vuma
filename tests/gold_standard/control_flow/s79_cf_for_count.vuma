// s79_cf_for_count.vuma — for loop runs 23 iterations, count = 23
// Observed on current x86_64 backend: 0 (FAIL — known bug: for/while/if-body assignments don't propagate)
//
// Counter starts at 0 and increments by 1 each iteration of a
// for loop with range 0..23. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 23 once
// fixed. Distinct from s78_cf_for_count (1), s77_cf_for_count
// (2) and s76_cf_for_count (1).
// Expected exit code: 23
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..23 {
        count = count + 1;
    }
    return count;
}
