// s102_cf_if_else_const.vuma — if true { x = 126 } else { x = 1 }; return x
// Observed on current x86_64 backend: 1 (FAIL — known bug)
//
// If-true branch should set x = 126, else branch sets x = 1. With a literal `true` condition the true branch should win -> 126. On the current backend the if-true body's single assignment is dropped, so the else body's assignment (1) survives instead. Will exit 126 once the if-body drop bug is fixed.
// Distinct from s101_cf_for_count (83), s101_cf_if_else_const (19), s101_cf_if_single_assign (56).
// Expected exit code: 126
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 126;
    } else {
        x = 1;
    }
    return x;
}
