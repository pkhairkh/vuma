// s93_cf_if_else_const.vuma — if true { x = 105 } else { x = 202 }; return x
// Observed on current x86_64 backend: 202 (FAIL — known bug)
//
// If-true branch should set x = 105, else branch sets x = 202. With
// a literal `true` condition the true branch should win -> 105. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (202) survives instead.
// Will exit 105 once the if-body drop bug is fixed. Distinct from
// s90_cf_if_else_const (79), s82_cf_if_else_const (12) and s78_cf_if_else_const (10).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 105;
    } else {
        x = 202;
    }
    return x;
}
