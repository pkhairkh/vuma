// s101_cf_if_else_const.vuma — if true { x = 19 } else { x = 200 }; return x
// Observed on current x86_64 backend: 200 (FAIL — known bug)
//
// If-true branch should set x = 19, else branch sets x = 200. With
// a literal `true` condition the true branch should win -> 19. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (200) survives instead.
// Will exit 19 once the if-body drop bug is fixed. Distinct from
// s98_cf_if_else_const (38), s97_cf_if_else_const (122) and
// s94_cf_if_else_const (64).
// Expected exit code: 19
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 19;
    } else {
        x = 200;
    }
    return x;
}
