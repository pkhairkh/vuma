// s66_cf_if_else_const.vuma — if true { x = 84 } else { x = 210 }; return x
// Expected exit code (correct): 84
// Observed on current x86_64 backend: 210 (FAIL — known bug)
//
// If-true branch should set x = 84, else branch sets x = 210.
// With a literal `true` condition the true branch should win ->
// 84. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (210)
// survives instead. Will exit 84 once the if-body drop bug is
// fixed. Distinct from s62_cf_if_else_const (56), s58_cf_if_
// else_const (64) and s55_cf_if_else_const (72).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 84;
    } else {
        x = 210;
    }
    return x;
}
