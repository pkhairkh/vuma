// s34_cf_if_chain_2.vuma — chain of two ifs, last sets x = 66
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Two sequential if-true blocks. Each overwrites x: 22, then 66.
// With all conditions `true`, x should end at 66. On the current
// backend the if-true body assignments are dropped, so x stays 0.
// Distinct from s30_cf_if_single_assign (single-if, 70) and
// s27_cf_if_chain_2 (different values, 77).
// Expected exit code: 66

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 22;
    }
    if true {
        x = 66;
    }
    return x;
}
