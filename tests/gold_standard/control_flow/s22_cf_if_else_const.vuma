// s22_cf_if_else_const.vuma — if true { x = 70 } else { x = 140 }; return x
// Observed on current x86_64 backend: 140 (FAIL — known bug)
//
// If-true branch should set x = 70, else branch sets x = 140. With a
// literal `true` condition the true branch should win -> 70. On the
// current backend the if-true body's single assignment is dropped, so
// the else body's assignment (140) survives instead. Will exit 70 once
// the if-body drop bug is fixed. Distinct from s18_cf_if_else_const
// (values 55/110) and s14_cf_if_else_const (values 42/99).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 70;
    } else {
        x = 140;
    }
    return x;
}
