// s70_cf_if_else_const.vuma — if true { x = 76 } else { x = 160 }; return x
// Observed on current x86_64 backend: 160 (FAIL — known bug)
//
// If-true branch should set x = 76, else branch sets x = 160.
// With a literal `true` condition the true branch should win ->
// 76. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (160)
// survives instead. Will exit 76 once the if-body drop bug is
// fixed. Distinct from s66_cf_if_else_const (84), s65_cf_if_
// else_const (44) and s62_cf_if_else_const (56).
// Expected exit code: 76
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 76;
    } else {
        x = 160;
    }
    return x;
}
