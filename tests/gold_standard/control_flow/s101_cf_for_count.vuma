// s101_cf_for_count.vuma — for loop runs 83 iterations, count = 83
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..83. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 83 once
// fixed. Distinct from s98_cf_for_count (24), s97_cf_for_count
// (114) and s94_cf_for_count (37).
// Expected exit code: 83
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..83 {
        count = count + 1;
    }
    return count;
}
