// s70_cf_for_count_12.vuma — for loop runs 12 iterations, count = 12
// Expected exit code (correct): 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..12. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 12 once
// fixed. Distinct from s66_cf_for_count_9 (9), s65_cf_for_count_
// 11 (11) and s58_cf_for_count_8 (8).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..12 {
        count = count + 1;
    }
    return count;
}
