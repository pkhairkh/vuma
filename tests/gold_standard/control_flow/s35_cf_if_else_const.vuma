// s35_cf_if_else_const.vuma — if true { x = 95 } else { x = 38 }; return x
// Observed on current x86_64 backend: 38 (FAIL — known bug)
//
// If-true branch should set x = 95, else branch sets x = 38. With a
// literal `true` condition the true branch should win -> 95. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (38) survives instead. Will exit 95
// once the if-body drop bug is fixed. Distinct from s34_cf_if_else_
// const (true=99/else=33, observed 33) and s30_cf_if_else_const
// (true=90/else=180, observed 180).
// Expected exit code: 95

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 95;
    } else {
        x = 38;
    }
    return x;
}
