// s29_cf_if_else_const.vuma — if true { x = 200 } else { x = 99 }; return x
// Observed on current x86_64 backend: 99 (FAIL — known bug)
//
// If-true branch should set x = 200, else branch sets x = 99. With a literal `true` condition the true branch should win -> 200. On the current backend the if-true body's single assignment is dropped, so the else body's assignment (99) survives instead. Will exit 200 once the if-body drop bug is fixed. Distinct from s26_cf_if_else_const (values 200/100, observed 100) and s22_cf_if_else_const (values 70/140, observed 140).
// Expected exit code: 200

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 200;
    } else {
        x = 99;
    }
    return x;
}
