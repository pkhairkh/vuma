// s84_cf_for_count.vuma — for loop runs 34 iterations, count = 34
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..34. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 34 once
// fixed. Distinct from s82_cf_for_count (6), s78_cf_for_count (1)
// and s74_cf_for_count (93).
// Expected exit code: 34
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..34 {
        count = count + 1;
    }
    return count;
}
