// cf2_loop_return — return from inside an infinite while loop.
// Expected exit code: 7
//
// Exposes VUMA bug: return inside a while body may not actually return, and
// while-body assignments to the loop counter may not propagate. On buggy
// codegen, the loop never terminates or returns 0.

fn main() -> i32 {
    i: u32 = 0;
    while (true) {
        if (i == 7) {
            return i;
        }
        i = i + 1;
    }
    return 0;
}
