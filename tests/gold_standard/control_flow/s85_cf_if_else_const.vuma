// s85_cf_if_else_const.vuma — if true { x = 54 } else { x = 29 }; return x
// Observed on current x86_64 backend: 29 (FAIL — known bug)
//
// If-true branch should set x = 54, else branch sets x = 29.
// With a literal `true` condition the true branch should win
// -> 54. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (29)
// survives instead. Will exit 54 once the if-body drop bug is
// fixed. Distinct from s82_cf_if_else_const (12),
// s78_cf_if_else_const (10) and s74_cf_if_else_const (19).
// Expected exit code: 54
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 54;
    } else {
        x = 29;
    }
    return x;
}
