// s99_cf_while_acc.vuma — while loop accumulates 1 * 18 = 18
// Expected exit code (correct): 18
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 18, add 1 each iteration
// -> 1 * 18 = 18 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 18 once fixed. Distinct from s95_cf_while_acc
// (117), s91_cf_while_acc (68) and s87_cf_while_acc (40).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 18 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
