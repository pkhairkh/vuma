// s22_cf_if_assign_true.vuma — if-true sets x=81, return = 81
// Expected exit code (correct): 81
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Standalone if-true body sets x = 81. With a literal `true` condition
// x should become 81. On the current backend the if-true body assignment
// is dropped, so x keeps its init value 0. Distinct from
// s18_cf_if_assign_true (if-true x=64) and s11_cf_if_chain_2 (if-true
// x=15).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 81;
    }
    return x;
}
