// s16_cf_if_single_assign.vuma — standalone if true sets x=100, return x
// Expected exit code (correct): 100
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Standalone if-true body sets x = 100. With a literal `true` condition
// x should become 100. On the current backend the if-true body
// assignment is dropped, so x keeps its init value 0. Distinct from
// s11_cf_if_chain_2 (if-true x=15, observed 0) and s4_cf_if_assign_simple
// (if-true x=10, else x=20).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 100;
    }
    return x;
}
