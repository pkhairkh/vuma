// s7_cf_for_count_3.vuma — for loop runs 3 iterations
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..3. Known "for-body assignments don't propagate"
// bug keeps count at 0 -> exit 0. Will exit 3 once fixed. Distinct
// from s6_cf_for_count_4 (4 iterations) and s5_cf_for_count_7
// (7 iterations).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        count = count + 1;
    }
    return count;
}
