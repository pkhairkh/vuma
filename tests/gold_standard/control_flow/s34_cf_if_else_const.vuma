// s34_cf_if_else_const.vuma — if true { x = 99 } else { x = 33 }; return x
// Expected exit code (correct): 99
// Observed on current x86_64 backend: 33 (FAIL — known bug)
//
// If-true branch should set x = 99, else branch sets x = 33. With a
// literal `true` condition the true branch should win -> 99. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (33) survives instead. Will exit 99
// once the if-body drop bug is fixed. Distinct from s30_cf_if_else_
// const (true=90/else=180, observed 180) and s27_cf_if_else_const
// (true=88/else=44, observed 44).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 99;
    } else {
        x = 33;
    }
    return x;
}
