// s80_cf_if_single_assign.vuma — x=0; if true { x = 46 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 46. Known "if-body assignments
// don't propagate" bug keeps x at 0 -> exit 0. Will exit 46
// once the bug is fixed. Distinct from s78_cf_if_single_assign (22),
// s74_cf_if_single_assign (47) and s73_cf_if_single_assign (109).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 46;
    }
    return x;
}
