// s87_cf_while_acc.vuma — while loop accumulates 5*8 = 40
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 8, add 5 each iteration
// -> 5 * 8 = 40 total. i increments by 1 each iteration.
// Known "while-body assignments don't propagate" bug keeps acc
// at 0 -> exit 0. Will exit 40 once fixed. Distinct from
// s86_cf_while_acc (28), s82_cf_while_acc (9) and s78_cf_while_
// acc (2).
// Expected exit code: 40
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 8 {
        acc = acc + 5;
        i = i + 1;
    }
    return acc;
}
