// s31_cf_while_acc_3.vuma — while loop accumulates 3*10 = 30
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 3, add 10 each iteration -> 3*10 =
// 30 total. i increments by 1 each iteration. Known "while-body
// assignments don't propagate" bug keeps acc at 0 -> exit 0. Will exit
// 30 once fixed. Distinct from s30_cf_while_acc_5 (5*4 = 20) and
// s28_cf_while_acc_4 (4*6 = 24).
// Expected exit code: 30

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 3 {
        acc = acc + 10;
        i = i + 1;
    }
    return acc;
}
