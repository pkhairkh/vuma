// s69_cf_for_count_13.vuma -- for loop runs 13 iterations, count = 13
// Expected exit code (correct): 13
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..13. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 13 once
// fixed. Distinct from s66_cf_for_count_9 (9), s65_cf_for_count_11
// (11) and s64_cf_for_count_6 (6).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..13 {
        count = count + 1;
    }
    return count;
}
