// s60_cf_if_else_const.vuma — if true { x = 75 } else { x = 175 }; return x
// Expected exit code (correct): 75
// Observed on current x86_64 backend: 175 (FAIL — known bug)
//
// If-true branch should set x = 75, else branch sets x = 175. With
// a literal `true` condition the true branch should win -> 75. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (175) survives instead.
// Will exit 75 once the if-body drop bug is fixed. Distinct from
// s58_cf_if_else_const (true=64/else=200, observed 200) and s57_cf_
// if_else_const (true=85/else=170, observed 170).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 75;
    } else {
        x = 175;
    }
    return x;
}
