// s31_cf_if_else_const.vuma — if true { x = 110 } else { x = 220 }; return x
// Observed on current x86_64 backend: 220 (FAIL — known bug)
//
// If-true branch should set x = 110, else branch sets x = 220. With a
// literal `true` condition the true branch should win -> 110. On the
// current backend the if-true body's single assignment is dropped, so
// the else body's assignment (220) survives instead. Will exit 110 once
// the if-body drop bug is fixed. Distinct from s30_cf_if_else_const
// (values 90/180, observed 180) and s28_cf_if_else_const
// (values 70/140, observed 140).
// Expected exit code: 110

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 110;
    } else {
        x = 220;
    }
    return x;
}
