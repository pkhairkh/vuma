// s15_cf_for_count_6.vuma — for loop runs 6 iterations, count = 6
// Expected exit code (correct): 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for loop with
// range 0..6. Known "for-body assignments don't propagate" bug keeps count
// at 0 -> exit 0. Will exit 6 once fixed. Distinct from s14_cf_for_count_8
// (8 iterations) and s13_cf_for_count_5 (5 iterations).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        count = count + 1;
    }
    return count;
}
