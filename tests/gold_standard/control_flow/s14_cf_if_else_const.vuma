// s14_cf_if_else_const.vuma — if true { x = 42 } else { x = 99 }; return x
// Observed on current x86_64 backend: 99 (FAIL — known bug)
//
// Historically (Task 13-b worklog) the simple if-form returned the
// correct value (the if-true branch's value). On the current
// backend the if-body assignment is silently dropped when the
// condition is the literal `true`, so x takes the else-branch value
// 99 (exit 99). Will exit 42 once the if-body drop bug is fixed.
// Distinct from s9_cf_if_else_one_branch (values 50/200) and
// s10_cf_if_else_compound (values 20/80).
// Expected exit code: 42

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 42;
    } else {
        x = 99;
    }
    return x;
}
