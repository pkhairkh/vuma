// s87_cf_if_single_assign.vuma — x=0; if true { x = 33 }; return x
// Expected exit code (correct): 33
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 33. Known "if-body assignments
// don't propagate" bug keeps x at 0 -> exit 0. Will exit 33
// once the bug is fixed. Distinct from s86_cf_if_single_assign
// (25), s82_cf_if_single_assign (18) and s78_cf_if_single_
// assign (22).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 33;
    }
    return x;
}
