// s93_cf_while_acc.vuma — while loop accumulates 1 * 94 = 94
// Expected exit code (correct): 94
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 94, add 1 each iteration
// -> 1 * 94 = 94 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 94 once fixed. Distinct from s90_cf_while_acc (71), s82_cf_while_acc (9) and
// s78_cf_while_acc (2).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 94 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
