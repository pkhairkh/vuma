// s69_cf_if_else_const.vuma -- if true { x = 80 } else { x = 220 }; return x
// Observed on current x86_64 backend: 220 (FAIL -- known bug)
//
// If-true branch should set x = 80, else branch sets x = 220. With a
// literal `true` condition the true branch should win -> 80. On the
// current backend the if-true body's single assignment is dropped, so
// the else body's assignment (220) survives instead. Will exit 80
// once the if-body drop bug is fixed. Distinct from s66_cf_if_else_
// const (84), s65_cf_if_else_const (44) and s64_cf_if_else_const (64).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 80;
    } else {
        x = 220;
    }
    return x;
}
