// s53_cf_if_single_assign.vuma — single if-true sets x = 84
// Expected exit code (correct): 84
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// One if-true block that overwrites x = 0 to x = 84. With a literal
// `true` condition x should end at 84. On the current backend the
// if-true body's assignment is dropped, so x stays 0 -> exit 0.
// Will exit 84 once the if-body drop bug is fixed. Distinct from
// s49_cf_if_single_assign (92) and s50_cf_if_single_assign (65).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 84;
    }
    return x;
}
