// s44_cf_if_else_const.vuma — if true { x = 88 } else { x = 33 }; return x
// Expected exit code (correct): 88
// Observed on current x86_64 backend: 33 (FAIL — known bug)
//
// If-true branch should set x = 88, else branch sets x = 33. With a
// literal `true` condition the true branch should win -> 88. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (33) survives instead. Will exit 88
// once the if-body drop bug is fixed. Distinct from s42_cf_if_else_
// const (true=42/else=99, observed 99) and s38_cf_if_else_const
// (true=99/else=33, observed 33).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 88;
    } else {
        x = 33;
    }
    return x;
}
