// cf2_while_sum — while loop accumulates the sum 0+1+2+3+4 = 10.
// Expected exit code: 10
//
// Exposes VUMA bug: while-body assignments to the accumulator (and the
// counter) do not propagate. On buggy codegen, s stays 0 and the loop
// either never terminates (i never advances) or returns 0.

fn main() -> i32 {
    i: u32 = 0;
    s: u32 = 0;
    while (i < 5) {
        s = s + i;
        i = i + 1;
    }
    return s;
}
