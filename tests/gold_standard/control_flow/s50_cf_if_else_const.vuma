// s50_cf_if_else_const.vuma — if true { x = 80 } else { x = 200 }; return x
// Observed on current x86_64 backend: 200 (FAIL — known bug)
//
// If-true branch should set x = 80, else branch sets x = 200. With a
// literal `true` condition the true branch should win -> 80. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (200) survives instead. Will exit 80
// once the if-body drop bug is fixed. Distinct from s46_cf_if_else_
// const (true=55/else=120, observed 120) and s43_cf_if_else_const
// (true=55/else=88, observed 88).
// Expected exit code: 80

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 80;
    } else {
        x = 200;
    }
    return x;
}
