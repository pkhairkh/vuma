// s75_cf_if_else_const.vuma — if true { x = 43 } else { x = 210 }; return x
// Observed on current x86_64 backend: 210 (FAIL — known bug)
//
// If-true branch should set x = 43, else branch sets x = 210.
// With a literal `true` condition the true branch should win ->
// 43. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (210)
// survives instead. Will exit 43 once the if-body drop bug is
// fixed. Distinct from s74_cf_if_else_const (19), s70_cf_if_
// else_const (76) and s66_cf_if_else_const (84).
// Expected exit code: 43
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 43;
    } else {
        x = 210;
    }
    return x;
}
