// cf_complex_flow — for loop with conditional break, returns loop-modified var
// Expected exit code: 3
//
// x=0; for i in 0..5 { x=x+1; if x==3 { break; } } return x;
// Iterations: x=1 (i=0), x=2 (i=1), x=3 (i=2) → break. return x=3.
// Exposes: for-body assignment + if-body break + propagation bugs.

fn main() -> i32 {
    x: u32 = 0;
    for i in 0..5 {
        x = x + 1;
        if (x == 3) {
            break;
        }
    }
    return x;
}
