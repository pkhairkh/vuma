// s100_cf_while_acc.vuma — while loop accumulates 1 * 125 = 125
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 125, add 1 each
// iteration -> 1 * 125 = 125 total. i increments by 1
// each iteration. Known "while-body assignments don't
// propagate" bug keeps acc at 0 -> exit 0. Will exit 125
// once fixed.
// Distinct from s97_cf_while_acc (116), s94_cf_while_acc (44), s90_cf_while_acc (71).
// Expected exit code: 125
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 125 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
