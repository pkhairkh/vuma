// s26_cf_if_else_const.vuma — if true { x = 200 } else { x = 100 }; return x
// Expected exit code (correct): 200
// Observed on current x86_64 backend: 100 (FAIL — known bug)
//
// If-true branch should set x = 200, else branch sets x = 100. With a
// literal `true` condition the true branch should win -> 200. On the
// current backend the if-true body's single assignment is dropped, so
// the else body's assignment (100) survives instead. Will exit 200 once
// the if-body drop bug is fixed. Distinct from s22_cf_if_else_const
// (values 70/140, observed 140) and s16_cf_if_else_two_var (two-var).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 200;
    } else {
        x = 100;
    }
    return x;
}
