// s81_cf_if_else_const.vuma — if true { x = 191 } else { x = 4 }; return x
// Expected exit code (correct): 191
// Observed on current x86_64 backend: 4 (FAIL — known bug)
//
// If-true branch should set x = 191, else branch sets x = 4.
// With a literal `true` condition the true branch should win
// -> 191. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (4)
// survives instead. Will exit 191 once the if-body drop bug is
// fixed. Distinct from s78_cf_if_else_const (10),
// s77_cf_if_else_const (37) and s76_cf_if_else_const (80).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 191;
    } else {
        x = 4;
    }
    return x;
}
