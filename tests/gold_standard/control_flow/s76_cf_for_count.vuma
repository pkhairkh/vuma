// s76_cf_for_count.vuma — for loop runs 97 iterations, count = 97
// Expected exit code (correct): 97
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..97. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 97 once
// fixed. Distinct from s74_cf_for_count (93), s73_cf_for_count_17
// (17) and s72_cf_for_count_15 (15).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..97 {
        count = count + 1;
    }
    return count;
}
