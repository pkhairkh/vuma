// s82_cf_for_count.vuma — for loop runs 6 iterations, count = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..6. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 6 once
// fixed. Distinct from s78_cf_for_count (1), s74_cf_for_count
// (33) and s72_cf_for_count_13 (13).
// Expected exit code: 6
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        count = count + 1;
    }
    return count;
}
