// s15_cf_if_chain_3.vuma — if-true sets x = 44, return = 44
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Standalone if-true body sets x = 44. With a literal `true` condition x
// should become 44. On the current backend the if-true body assignment is
// dropped, so x keeps its init value 0. Distinct from s11_cf_if_chain_2
// (if-true x=15) and s4_cf_if_assign_simple (if-true x=10, else x=20).
// Expected exit code: 44

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 44;
    }
    return x;
}
