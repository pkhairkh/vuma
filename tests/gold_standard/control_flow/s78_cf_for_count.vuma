// s78_cf_for_count.vuma — for loop runs 1 iterations, count = 1
// Expected exit code (correct): 1
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..1. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 1 once
// fixed. Distinct from s74_cf_for_count (33), s73_cf_for_count_17
// (17) and s72_cf_for_count_13 (13).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..1 {
        count = count + 1;
    }
    return count;
}
