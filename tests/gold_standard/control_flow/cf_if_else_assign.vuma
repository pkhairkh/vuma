// cf_if_else_assign — assignment inside if/else branches
// Expected exit code: 10
//
// Exposes VUMA bug: if-body assignments are silently dropped.
// On buggy codegen, x remains 0 and exit is 0 instead of 10.

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 10;
    } else {
        x = 20;
    }
    return x;
}
