// cf_return_in_loop — return inside while+if must exit main immediately
// Expected exit code: 7
//
// Exposes: return inside nested if (within a loop) doesn't actually return.

fn main() -> i32 {
    i: u32 = 0;
    while (true) {
        if (i == 7) {
            return i;
        }
        i = i + 1;
    }
    return 0;
}
