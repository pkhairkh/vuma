// s76_cf_if_single_assign.vuma — x=0; if true { x = 41 }; return x
// Expected exit code (correct): 41
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 41. Known "if-body assignments don't
// propagate" bug keeps x at 0 -> exit 0. Will exit 41 once the
// bug is fixed. Distinct from s74_cf_if_single_assign (47),
// s73_cf_if_single_assign (109) and s72_cf_if_single_assign (90).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 41;
    }
    return x;
}
