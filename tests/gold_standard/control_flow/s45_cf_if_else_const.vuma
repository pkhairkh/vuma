// s45_cf_if_else_const.vuma — if true { x = 33 } else { x = 200 }; return x
// Expected exit code (correct): 33
// Observed on current x86_64 backend: 200 (FAIL — known bug)
//
// If-true branch should set x = 33, else branch sets x = 200. With a
// literal `true` condition the true branch should win -> 33. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (200) survives instead. Will exit 33
// once the if-body drop bug is fixed. Distinct from s42_cf_if_else_
// const (true=42/else=99, observed 99) and s34_cf_if_else_const
// (true=99/else=33, observed 33).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 33;
    } else {
        x = 200;
    }
    return x;
}
