// s71_cf_if_else_const.vuma — if true { x = 74 } else { x = 191 }; return x
// Expected exit code (correct): 74
// Observed on current x86_64 backend: 191 (FAIL — known bug)
//
// If-true branch should set x = 74, else branch sets x = 191.
// With a literal `true` condition the true branch should win ->
// 74. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (191)
// survives instead. Will exit 74 once the if-body drop bug is
// fixed. Distinct from s69_cf_if_else_const (80/220), s70_cf_if_
// else_const (76/160) and s66_cf_if_else_const (84/210).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 74;
    } else {
        x = 191;
    }
    return x;
}
