// s4_cf_if_else_two_var.vuma — if-branch sets x=10, else-branch sets y=20
// Expected exit code (correct): 10  (x=10, y=0; sum=10)
// Observed on current x86_64 backend: 10 (PASS)
//
// Two variables x and y initialised to 0. If-branch sets x = 10,
// else-branch sets y = 20. Since the condition is true, after the
// if/else we should have x = 10, y = 0, sum = 10.
// On the current backend the if-branch assignment propagates
// correctly, so exit is 10. Kept as a regression guard for the
// historically-documented if-body drop bug.

fn main() -> i32 {
    x: u32 = 0;
    y: u32 = 0;
    if true {
        x = 10;
    } else {
        y = 20;
    }
    s: u32 = x + y;
    return s;
}
