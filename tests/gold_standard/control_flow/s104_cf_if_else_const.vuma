// s104_cf_if_else_const.vuma — if true { x = 135 } else { x = 1 }; return x
// Expected exit code (correct): 135
// Observed on current x86_64 backend: 1 (FAIL — known bug)
//
// If-true branch should set x = 135, else branch sets x = 1. With a literal `true` condition the true branch should win -> 135. On the current backend the if-true body's single assignment is dropped, so the else body's assignment (1) survives instead. Will exit 135 once the if-body drop bug is fixed.
// Distinct from s102_cf_if_single_assign (124), s102_cf_if_else_const (126), s102_cf_for_count (127), s102_cf_while_acc (130).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 135;
    } else {
        x = 1;
    }
    return x;
}
