// s72_cf_while_acc_5.vuma — while loop accumulates 5*13 = 65
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 5, add 13 each iteration ->
// 5 * 13 = 65 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 65 once fixed. Distinct from s70_cf_while_
// acc_6 (66), s69_cf_while_acc_4 (52) and s66_cf_while_acc_3 (33).
// Expected exit code: 65
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 5 {
        acc = acc + 13;
        i = i + 1;
    }
    return acc;
}
