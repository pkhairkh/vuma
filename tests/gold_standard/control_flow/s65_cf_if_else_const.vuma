// s65_cf_if_else_const.vuma — if true { x = 44 } else { x = 200 }; return x
// Expected exit code (correct): 44
// Observed on current x86_64 backend: 200 (FAIL — known bug)
//
// If-true branch should set x = 44, else branch sets x = 200. With a
// literal `true` condition the true branch should win -> 44. On the
// current backend the if-true body's single assignment is dropped,
// so the else body's assignment (200) survives instead. Will exit 44
// once the if-body drop bug is fixed. Distinct from s51_cf_if_else_
// const (70), s58_cf_if_else_const (64) and s62_cf_if_else_const (56).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 44;
    } else {
        x = 200;
    }
    return x;
}
