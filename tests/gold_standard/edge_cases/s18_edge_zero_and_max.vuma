// s18_edge_zero_and_max.vuma — 0 & 255 = 0
// Expected exit code: 0
//
// Bitwise AND with zero -> zero (annihilator). All operands loaded
// into u32 variables first. Distinct from s10_edge_max_xor_zero
// (255 ^ 0 = 255) and s14_edge_zero_minus_zero (0 - 0 = 0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a & b;       // 0
    return r;
}
