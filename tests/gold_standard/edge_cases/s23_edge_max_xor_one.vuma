// s23_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
//
// XOR with one-bit difference: 0xFF ^ 0x01 = 0xFE (only the lowest bit
// flips). All operands loaded into u32 variables first. Distinct from
// s22_edge_max_or_zero (255 | 0 = 255) and s24_edge_max_xor_max
// (255 ^ 255 = 0).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a ^ b;       // 254
    return r;
}

