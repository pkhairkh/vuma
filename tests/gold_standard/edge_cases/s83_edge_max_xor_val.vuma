// s83_edge_max_xor_val.vuma — 255 ^ 91 = 164
// Expected exit code: 164
//
// XOR the max byte value 255 (0xFF) with 91 (0x5B).
// 255 ^ 91 = 164 (0xA4). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_edge_max_xor (250), s74_edge_zero_xor_max (255) and
// s72_edge_max_xor_high (128).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 91;           // 0x5B
    r: u32 = a ^ b;        // 0xA4 = 164
    return r;
}
