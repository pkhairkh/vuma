// s48_edge_zero_xor.vuma — 0 ^ 255 = 255
// Expected exit code: 255
//
// XOR with zero preserves the operand. 0 ^ 255 = 255. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s46_edge_zero_and_max and s42_edge_
// zero_xor.

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a ^ b;        // 255
    return r;
}
