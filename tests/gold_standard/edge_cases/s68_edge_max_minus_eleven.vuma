// s68_edge_max_minus_eleven.vuma — 255 - 11 = 244
// Expected exit code: 244
//
// Subtract 11 from the max byte 255. 255 - 11 = 244 (0xF4). All
// operands kept as i32 locals. Straight-line arithmetic boundary
// test. Distinct from s66_edge_zero_xor_max (255), s62_edge_zero_
// xor_high_bit (128) and s58_edge_zero_or_zero (0).
fn main() -> i32 {
    a: i32 = 255;
    b: i32 = 11;
    r: i32 = a - b;        // 244
    return r;
}
