// s41_edge_zero_plus_two.vuma - 0 + 2 = 2
// Expected exit code: 2
//
// Add two to zero. 0 + 2 = 2. All operands loaded into u32
// variables first. Distinct from s38_edge_zero_plus_one (1) and
// s34_edge_max_minus_one (254).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 2;
    r: u32 = a + b;        // 2
    return r;
}
