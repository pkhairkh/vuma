// s15_edge_zero_and_full.vuma — 0 & 255 = 0
// Expected exit code: 0
//
// Zero AND-ed with all-ones (0xFF) -> 0 (AND identity with zero). Distinct
// from s12_edge_max_and_zero (255 & 0 = 0, swapped operand order) and
// s11_edge_zero_or_max (0 | 255 = 255, OR framing).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a & b;       // 0
    return r;
}
