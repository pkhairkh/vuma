// s85_edge_store_zero.vuma — store 0, load, return 0
// Expected exit code: 0
//
// Edge case: the minimum u8 value (0x00). Verifies the zero
// value survives the store/load round trip without being
// replaced by a default or garbage. Uses `*ptr = literal`
// form (no offsets). Distinct from s82_edge_store_zero,
// s78_edge_store_zero and s74_edge_store_zero.
fn main() -> i32 {
    buf = allocate(8);
    *buf = 0;
    val: i32 = *buf;
    free(buf);
    return val;
}
