// s22_edge_one_and_max.vuma — 1 & 255 = 1
// Expected exit code: 1
//
// AND identity: 1 & 0xFF = 1 (lowest bit preserved, all higher bits
// masked out except bit 0 which is set in both operands). All operands
// loaded into u32 variables first. Distinct from s18_edge_zero_and_max
// (0 & 255 = 0) and s14_edge_max_and_zero (255 & 0 = 0).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 255;
    r: u32 = a & b;       // 1
    return r;
}
