// s12_edge_one_xor_zero.vuma — 1 ^ 0 = 1
// Expected exit code: 1
//
// XOR with zero is the identity function for nonzero operands. Tests
// the codegen's handling of a zero RHS in XOR (no change to LHS).
// Distinct from s7/s8/s10_edge_zero_xor (0^0=0) and
// s10_edge_max_xor_zero (255^0=255).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 0;
    r: u32 = a ^ b;
    return r;
}
