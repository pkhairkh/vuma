// s102_edge_max_and_val.vuma — 255 & 38 = 38 (AND with all-ones is identity)
// Expected exit code: 38
//
// Edge case: AND with the max byte (0xFF) is the identity. 255 & 38 = 38. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_edge_max_xor_val (155), s101_edge_one_shl_val (16), s101_edge_zero_and_val (0).
fn main() -> i32 {
    a: u32 = 38;
    m: u32 = 255;          // 0xFF
    r: u32 = m & a;        // 38
    return r;
}
