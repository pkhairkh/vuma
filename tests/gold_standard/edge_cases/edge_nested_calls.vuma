// edge_nested_calls — deeply nested function calls (5 levels)
// Expected exit code: 42
//
// Edge case: a 5-level chain of identity functions. Uses intermediate
// variables because VUMA miscompiles nested call expressions used
// directly as arguments. The value 42 must pass through unchanged.

fn l5(x: u32) -> u32 {
    return x;
}

fn l4(x: u32) -> u32 {
    return x;
}

fn l3(x: u32) -> u32 {
    return x;
}

fn l2(x: u32) -> u32 {
    return x;
}

fn l1(x: u32) -> u32 {
    return x;
}

fn main() -> i32 {
    a: u32 = l1(42);
    b: u32 = l2(a);
    c: u32 = l3(b);
    d: u32 = l4(c);
    v: u32 = l5(d);
    return v;
}
