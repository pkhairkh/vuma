// s28_edge_zero_and_max.vuma — 0 & 255 = 0
// Expected exit code: 0
//
// AND identity: 0 & 255 = 0 (AND with zero clears all bits). All
// operands loaded into u32 variables first. Distinct from
// s26_edge_zero_or_one (0 | 1 = 1) and s22_edge_zero_xor_zero
// (0 ^ 0 = 0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a & b;       // 0
    return r;
}
