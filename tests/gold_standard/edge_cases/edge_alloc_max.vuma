// edge_alloc_max — allocate(256), store at offset 0, load, return
// Expected exit code: 42
//
// Edge case: a 256-byte allocation. Stores 42 at offset 0 via *buf and
// loads it back. Verifies that larger buffers do not corrupt offset-0
// stores.

fn main() -> i32 {
    buf = allocate(256);
    *buf = 42;
    val: i32 = *buf;
    free(buf);
    return val;
}
