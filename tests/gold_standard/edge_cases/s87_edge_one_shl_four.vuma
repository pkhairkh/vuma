// s87_edge_one_shl_four.vuma — 1 << 4 = 16
// Expected exit code: 16
//
// Shift the value 1 left by 4. 1 << 4 = 16 (0x10). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s86_edge_one_shl_five (32),
// s82_edge_one_shl_six (64) and s78_edge_max_xor (250).
fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;            // shift amount
    r: u32 = a << b;       // 0x10 = 16
    return r;
}
