// s82_edge_zero_xor_high.vuma — 0 ^ 128 = 128
// Expected exit code: 128
//
// XOR the zero value 0 (0x00) with the high-bit value 128
// (0x80). 0 ^ 128 = 128 (0x80). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s78_edge_high_bit_or (129), s74_edge_zero_xor_
// max (255) and s72_edge_zero_xor_high_bit (128).
fn main() -> i32 {
    a: u32 = 0;            // 0x00
    b: u32 = 128;          // 0x80
    r: u32 = a ^ b;        // 0x80 = 128
    return r;
}
