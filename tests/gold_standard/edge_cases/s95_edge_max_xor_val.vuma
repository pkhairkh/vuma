// s95_edge_max_xor_val.vuma — 255 ^ 219 = 36 (XOR with all-ones inverts bits)
// Expected exit code: 36
//
// Edge case: XOR with all-ones inverts every bit. 255 ^ 219 = 36
// (0xFF ^ 0xDB = 0x24). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_edge_max_and_val (108), s90_edge_max_xor_val (23) and
// s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 219;          // 0xDB
    r: u32 = a ^ b;        // 0x24 = 36
    return r;
}
