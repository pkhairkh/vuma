// s52_edge_max_minus_two.vuma — 255 - 2 = 253
// Expected exit code: 253
//
// Subtract 2 from the max u8 value. 255 - 2 = 253. All operands
// loaded into u32 variables first. Straight-line arithmetic at the
// u8 boundary. Distinct from s50_edge_max_xor_one (254) and
// s46_edge_max_shr_one (127).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a - b;        // 253
    return r;
}
