// s91_edge_zero_xor_val.vuma — 0 ^ 215 = 215 (XOR with zero is identity)
// Expected exit code: 215
//
// Edge case: XOR with zero is the identity. 0 ^ 215 = 215 (0xD7).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s90_edge_zero_or_val
// (22), s86_edge_zero_xor_high (233) and s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 215;          // 0xD7
    r: u32 = a ^ b;        // 0xD7 = 215
    return r;
}
