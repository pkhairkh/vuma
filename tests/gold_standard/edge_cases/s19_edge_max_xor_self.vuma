// s19_edge_max_xor_self.vuma — 255 ^ 255 = 0
// Expected exit code: 0
//
// XOR of a value with itself is the annihilator -> 0. Both operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s18_edge_max_xor_zero (255 ^ 0 = 255)
// and s10_edge_max_xor_zero (255 ^ 0 = 255).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 255;
    r: u32 = a ^ b;       // 0
    return r;
}
