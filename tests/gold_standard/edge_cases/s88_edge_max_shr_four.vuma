// s88_edge_max_shr_four.vuma — 255 >> 4 = 15
// Expected exit code: 15
//
// Shift the max byte value 255 (0xFF) right by 4. 255 >> 4
// = 15 (0x0F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_edge_one_shl_five (32), s82_edge_one_shl_six
// (64) and s78_edge_max_xor (250).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 4;            // shift amount
    r: u32 = a >> b;       // 0x0F = 15
    return r;
}
