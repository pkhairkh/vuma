// s103_edge_zero_xor_val.vuma — 0 ^ 42 = 42 (XOR with zero is identity)
// Expected exit code: 42
//
// Edge case: XOR with zero is the identity. 0 ^ 42 = 42. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s100_edge_zero_xor_val (73), s94_edge_zero_xor_val (75).
fn main() -> i32 {
    a: u32 = 42;
    z: u32 = 0;
    r: u32 = z ^ a;        // 42
    return r;
}
