// s10_edge_zero_xor.vuma — 0 ^ 0 = 0
// Expected exit code: 0
//
// Two zeros XORed -> 0. Tests the codegen's handling of a zero operand
// in XOR (bitwise identity element). Both zeros loaded into u32
// variables first. Distinct from s5_edge_zero_sum (sum of zeros, ADD)
// and s6_edge_zero_mul (zero * constant, MUL).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 0;
    r: u32 = a ^ b;
    return r;
}
