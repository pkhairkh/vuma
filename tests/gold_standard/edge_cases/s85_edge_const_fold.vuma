// s85_edge_const_fold.vuma — constant expression: 90 + 25 = 115
// Expected exit code: 115
//
// Edge case: a literal constant expression that could be
// folded at compile time. Loads both constants into variables
// to avoid any immediate-RHS bitop-drop bug. Straight-line
// arithmetic. Distinct from s82_edge_const_fold,
// s78_edge_const_fold and s74_edge_const_fold.
fn main() -> i32 {
    a: u32 = 90;
    b: u32 = 25;
    r: u32 = a + b;       // 115
    return r;
}
