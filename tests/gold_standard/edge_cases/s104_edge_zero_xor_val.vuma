// s104_edge_zero_xor_val.vuma — 0 ^ 97 = 97 (XOR with zero is identity)
// Expected exit code: 97
//
// Edge case: XOR with zero is the identity. 0 ^ 97 = 97. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_edge_zero_or_val (18), s102_edge_max_and_val (38), s102_edge_one_xor_val (39).
fn main() -> i32 {
    a: u32 = 97;
    z: u32 = 0;
    r: u32 = z ^ a;        // 97
    return r;
}
