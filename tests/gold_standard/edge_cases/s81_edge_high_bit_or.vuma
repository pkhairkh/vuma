// s81_edge_high_bit_or.vuma — 128 | 6 = 134
// Expected exit code: 134
//
// OR the high-bit value 128 (0x80) with 6. 128 | 6 = 134
// (0x86). Sets bit 7 of 6 -> 134. All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_edge_high_bit_or (129),
// s77_edge_max_xor_eighteen (237) and s76_edge_max_and_sixty_four
// (64).
fn main() -> i32 {
    a: u32 = 128;
    b: u32 = 6;
    r: u32 = a | b;        // 134
    return r;
}
