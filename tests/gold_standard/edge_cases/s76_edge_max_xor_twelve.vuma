// s76_edge_max_xor_twelve.vuma — 255 ^ 12 = 243
// Expected exit code: 243
//
// XOR the max u8 value 255 with 12. 255 ^ 12 = 243 (0xF3). All
// operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s74_edge_max_xor_
// eight (247), s73_edge_max_xor_ten (245) and s72_edge_max_xor_
// nine (246).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 12;
    r: u32 = a ^ b;        // 243
    return r;
}
