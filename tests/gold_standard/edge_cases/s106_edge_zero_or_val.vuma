// Distinct from s102_edge_zero_or_val (18), s101_edge_zero_and_val (0), s100_edge_and_self (85).
fn main() -> i32 {
    a: u32 = 53;
    z: u32 = 0;
    r: u32 = z | a;        // 53
    return r;
}
