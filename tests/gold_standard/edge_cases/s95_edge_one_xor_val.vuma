// s95_edge_one_xor_val.vuma — 1 ^ 51 = 50 (XOR with one toggles the low bit)
// Expected exit code: 50
//
// Edge case: XOR with one toggles only the low bit. 1 ^ 51 = 50
// (0x01 ^ 0x33 = 0x32). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_edge_one_or_val (87), s90_edge_one_xor_val (25) and
// s82_edge_one_shl_six (64).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 51;           // 0x33
    r: u32 = a ^ b;        // 0x32 = 50
    return r;
}
