// s61_edge_zero_xor_max.vuma — 0 ^ 255 = 255
// Expected exit code: 255
// 
// XOR identity: 0 ^ 255 = 255. All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s58_edge_zero_or_zero (0), s58_edge_one_shl_seven
// (128) and s58_edge_max_shr_one (127).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a ^ b;        // 255
    return r;
}
