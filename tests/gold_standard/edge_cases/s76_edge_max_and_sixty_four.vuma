// s76_edge_max_and_sixty_four.vuma — 255 & 64 = 64
// Expected exit code: 64
//
// AND the max u8 value 255 (0xFF) with 64 (0x40). 255 & 64 = 64.
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s74_edge_max_and_
// two (2), s73_edge_max_and_eleven (11) and s72_edge_max_and_
// low (5).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 64;
    r: u32 = a & b;        // 64
    return r;
}
