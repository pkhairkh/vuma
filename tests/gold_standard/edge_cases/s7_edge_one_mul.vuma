// s7_edge_one_mul.vuma — 1 * 88 = 88
// Expected exit code: 88
//
// Multiply by one is identity: 1 * 88 = 88. Tests the codegen's
// handling of a unit left operand in multiplication. Distinct from
// s6_edge_zero_mul (0 * anything = 0) and s6_edge_ones_constant
// (literal ones, not multiplication).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 88;
    r: u32 = a * b;   // 88
    return r;
}
