// s4_edge_alloc_one_store.vuma — smallest meaningful buffer, store+load
// Expected exit code: 7
//
// Allocates a single byte (the smallest meaningful allocation), stores
// the literal 7 at offset 0, loads it back, returns 7. Edge case:
// confirms the allocator accepts size 1 and that loads/stores at
// offset 0 of a 1-byte cell work the same as larger cells.

fn main() -> i32 {
    p = allocate(1);
    *(p + 0) = 7;
    v: u64 = *(p + 0);
    free(p);
    return v;
}
