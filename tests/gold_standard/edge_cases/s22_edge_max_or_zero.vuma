// s22_edge_max_or_zero.vuma — 255 | 0 = 255
// Expected exit code: 255
//
// OR identity: 0xFF | 0 = 0xFF (OR with zero preserves all bits).
// All operands loaded into u32 variables first. Distinct from
// s18_edge_max_xor_zero (255 ^ 0 = 255) and s14_edge_max_minus_one
// (255 - 1 = 254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 0;
    r: u32 = a | b;       // 255
    return r;
}
