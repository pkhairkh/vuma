// s91_edge_one_or_val.vuma — 1 | 100 = 101 (OR with one sets bit 0)
// Expected exit code: 101
//
// Edge case: OR with one forces the lowest bit on. 1 | 100 = 101
// (0x65). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_edge_one_xor_val (25), s86_edge_one_shl_five (234) and
// s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 100;          // 0x64
    r: u32 = a | b;        // 0x65 = 101
    return r;
}
