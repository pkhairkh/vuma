// s24_edge_max_xor_max.vuma — 255 ^ 255 = 0
// Expected exit code: 0
//
// XOR identity: a ^ a = 0 (self-xor annihilation). 0xFF ^ 0xFF = 0. All
// operands loaded into u32 variables first. Distinct from
// s22_edge_zero_xor_zero (0 ^ 0 = 0) and s18_edge_max_xor_zero
// (255 ^ 0 = 255).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 255;
    r: u32 = a ^ b;       // 0
    return r;
}
