// s4_edge_max_u8.vuma — store/load the largest 8-bit value (255)
// Expected exit code: 255
//
// Allocate an 8-byte cell, store the literal 255 (the maximum value
// that the known *(buf+offset) U8-truncation bug allows to round-trip
// correctly), load it back, return 255. Confirms 255 is preserved.

fn main() -> i32 {
    p = allocate(8);
    *(p + 0) = 255;
    v: u64 = *(p + 0);
    free(p);
    return v;
}
