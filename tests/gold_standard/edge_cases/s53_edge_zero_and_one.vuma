// s53_edge_zero_and_one.vuma — 0 & 1 = 0
// Expected exit code: 0
//
// AND the min u8 value with 1. 0 & 1 = 0. All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s49_edge_zero_or_one (1) and s50_edge_zero_or_max
// (255).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 1;
    r: u32 = a & b;        // 0
    return r;
}
