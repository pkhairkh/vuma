// s35_edge_one_shl_one.vuma — 1 << 1 = 2
// Expected exit code: 2
//
// Single-bit shift into position 1. 1 << 1 = 2 (0x02). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s34_edge_one_shl_five (1 << 5 = 32)
// and s29_edge_one_shl_six (1 << 6 = 64).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 1;
    r: u32 = a << b;       // 2
    return r;
}
