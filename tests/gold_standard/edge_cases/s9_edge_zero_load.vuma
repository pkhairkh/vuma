// s9_edge_zero_load.vuma — store 0, load, return 0
// Expected exit code: 0
//
// Allocate an 8-byte cell, store literal 0 via `*p = 0`, load it
// back, return 0. Tests the codegen's handling of a zero store
// round-tripping through memory. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s5_edge_zero_sum (sum of zero locals, no memory).

fn main() -> i32 {
    p = allocate(8);
    *p = 0;
    v: u64 = *p;
    free(p);
    return v;
}
