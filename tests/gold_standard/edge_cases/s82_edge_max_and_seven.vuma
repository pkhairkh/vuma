// s82_edge_max_and_seven.vuma — 255 & 7 = 7
// Expected exit code: 7
//
// AND the max byte value 255 (0xFF) with the low-bit mask 7
// (0x07). 255 & 7 = 7. All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_edge_max_and (6), s74_edge_max_and_low (5) and
// s72_edge_max_and_low (5).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 7;            // 0x07
    r: u32 = a & b;        // 0x07 = 7
    return r;
}
