// s99_edge_high_or_low.vuma — 0xC0 | 0x06 = 0xC6 = 198 (OR of high and low nibble)
// Expected exit code: 198
//
// Edge case: OR of two bytes that each occupy a disjoint nibble.
// 192 | 6 = 198 (0xC6). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s95_edge_zero_or_val (37), s91_edge_zero_xor_val (215) and
// s87_edge_zero_xor_high (230).
fn main() -> i32 {
    a: u32 = 192;          // 0xC0
    b: u32 = 6;            // 0x06
    r: u32 = a | b;        // 0xC6 = 198
    return r;
}
