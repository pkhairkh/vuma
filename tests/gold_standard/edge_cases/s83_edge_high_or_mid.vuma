// s83_edge_high_or_mid.vuma — 128 | 51 = 179
// Expected exit code: 179
//
// OR the high-bit value 128 (0x80) with the mid value 51 (0x33).
// 128 | 51 = 179 (0xB3). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_edge_high_bit_or (129), s74_edge_high_or (192) and
// s72_edge_high_bit_or (129).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 51;           // 0x33
    r: u32 = a | b;        // 0xB3 = 179
    return r;
}
