// s10_edge_max_xor_zero.vuma — 255 ^ 0 = 255
// Expected exit code: 255
//
// Max U8 XORed with zero -> unchanged (XOR with zero is identity).
// Distinct from s6_edge_max_byte (returns literal 255 directly) and
// s5_edge_255_minus_1 (255 - 1 = 254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 0;
    r: u32 = a ^ b;
    return r;
}
