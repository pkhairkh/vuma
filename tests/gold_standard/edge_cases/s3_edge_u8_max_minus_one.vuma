// s3_edge_u8_max_minus_one.vuma — arithmetic with 255 minus 1 via vars
// Expected exit code: 254
//
// Edge case: compute 255 - 1 using intermediate variables to avoid
// the immediate-RHS bitwise drop. 255 - 1 = 254.

fn main() -> i32 {
    a: u32 = 255;
    one: u32 = 1;
    r: u32 = a - one;
    return r;
}
