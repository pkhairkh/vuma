// s84_edge_high_xor_low.vuma — 0x80 ^ 0x93 = 0x13 = 19
// Expected exit code: 19
//
// XOR the high-bit value 128 (0x80) with the mixed value 147
// (0x93). 128 ^ 147 = 19 (0x13). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_edge_zero_xor_high (128), s78_edge_high_
// bit_or (129) and s74_edge_max_xor_eight (247).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 147;          // 0x93
    r: u32 = a ^ b;        // 0x13 = 19
    return r;
}
