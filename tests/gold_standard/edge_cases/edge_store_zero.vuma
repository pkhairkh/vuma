// edge_store_zero — store 0, load, return
// Expected exit code: 0
//
// Edge case: storing zero through a pointer. Ensures 0 round-trips
// without being mistaken for an uninitialized slot.

fn main() -> i32 {
    buf = allocate(8);
    *buf = 0;
    val: i32 = *buf;
    free(buf);
    return val;
}
