// s93_edge_max_xor_val.vuma — 255 ^ 226 = 29 (XOR with max flips all bits)
// Expected exit code: 29
//
// Edge case: XOR with the max byte (0xFF) flips every bit
// (one's complement). 255 ^ 226 = 29 (0x1D). All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s90_edge_max_xor_val (23), s82_edge_max_and_seven (7) and s78_edge_max_and (6).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 226;          // 0xE2
    r: u32 = a ^ b;        // 0x1D = 29
    return r;
}
