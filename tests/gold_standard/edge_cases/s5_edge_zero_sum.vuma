// s5_edge_zero_sum.vuma — 0 + 0 + 0 = 0
// Expected exit code: 0
//
// Three zero-valued u32 locals, summed via intermediates. Tests
// the codegen's handling of all-zero operands (no overflow, no
// false non-zero bits).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 0;
    c: u32 = 0;
    t: u32 = a + b;
    total: u32 = t + c;
    return total;
}
