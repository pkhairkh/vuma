// s54_edge_zero_xor_max.vuma — 0 ^ 255 = 255
// Expected exit code: 255
//
// XOR the min and max u8 values. 0 ^ 255 = 255. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s50_edge_zero_or_max (255) and
// s49_edge_zero_or_max (255).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a ^ b;        // 255
    return r;
}
