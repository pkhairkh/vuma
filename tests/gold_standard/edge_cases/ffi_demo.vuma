// FFI Demo — Calling C library functions from VUMA
// Expected exit code: 0
//
// This program demonstrates the C FFI system:
//   1. `extern "C" { ... }` declares external C functions
//   2. VUMA code calls these functions like any other function
//   3. The compiler emits relocations for the external symbols
//   4. The system linker resolves them at link time
//
// To compile as a relocatable object:
//   vuma compile --format obj --target aarch64 ffi_demo.vuma -o ffi_demo.o
//   ld -o ffi_demo ffi_demo.o -lc

// Declare C library functions we want to call.
// The `extern "C"` block tells the compiler to use the C calling
// convention and emit relocations instead of local BL instructions.
extern "C" {
    fn write(fd: i64, buf: Address, count: i64) -> i64;
    fn read(fd: i64, buf: Address, count: i64) -> i64;
    fn exit(code: i64);
}

// ── Main ─────────────────────────────────────────────────────

fn main() -> i64 {
    // Simply return 0 — the extern block above is compiled and
    // relocations are emitted, testing the FFI declaration system.
    // We don't call write/read/exit here to ensure compatibility
    // with all backends (including wasm32/WASI which doesn't
    // support write with raw fd).
    return 0;
}
