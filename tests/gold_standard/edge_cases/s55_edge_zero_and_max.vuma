// s55_edge_zero_and_max.vuma — 0 & 255 = 0
// Expected exit code: 0
//
// AND the min and max u8 values. 0 & 255 = 0. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s54_edge_max_and_zero (0) and
// s53_edge_zero_and_one (0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a & b;        // 0
    return r;
}
