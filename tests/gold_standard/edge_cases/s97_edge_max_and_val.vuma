// s97_edge_max_and_val.vuma — 255 & 90 = 90 (AND with max preserves bits)
// Expected exit code: 90
//
// Edge case: AND with the max byte (0xFF) preserves the
// other operand. 255 & 90 = 90 (0x5A). All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_edge_max_and_val (108), s90_edge_max_xor_val (23), s86_edge_max_and_low (9).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 90;           // 0x5A
    r: u32 = a & b;        // 0x5A = 90
    return r;
}
