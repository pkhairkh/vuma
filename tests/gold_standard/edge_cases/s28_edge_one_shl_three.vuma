// s28_edge_one_shl_three.vuma — 1 << 3 = 8
// Expected exit code: 8
//
// SHL identity: 1 << 3 = 8 (single bit shifted into position 3). All
// operands loaded into u32 variables first. Distinct from
// s26_edge_one_shl_four (1 << 4 = 16) and s22_edge_one_shl_seven
// (1 << 7 = 128).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 3;
    r: u32 = a << b;      // 8
    return r;
}
