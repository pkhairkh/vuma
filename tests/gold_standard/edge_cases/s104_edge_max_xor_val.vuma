// s104_edge_max_xor_val.vuma — 255 ^ 157 = 98 (XOR with all-ones inverts bits)
// Expected exit code: 98
//
// Edge case: XOR with the max byte (0xFF) inverts every bit. 255 ^ 157 = 98. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_edge_zero_or_val (18), s102_edge_max_and_val (38), s102_edge_one_xor_val (39).
fn main() -> i32 {
    a: u32 = 157;
    m: u32 = 255;          // 0xFF
    r: u32 = m ^ a;        // 98
    return r;
}
