// s92_edge_zero_or_val.vuma — 0 | 44 = 44 (OR with zero is identity)
// Expected exit code: 44
//
// Edge case: OR with zero is the identity. 0 | 44 = 44 (0x2C). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s90_edge_zero_or_val (22),
// s86_edge_zero_xor_high (233) and s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 44;           // 0x2C
    r: u32 = a | b;        // 0x2C = 44
    return r;
}
