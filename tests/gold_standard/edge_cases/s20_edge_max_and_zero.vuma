// s20_edge_max_and_zero.vuma — 255 & 0 = 0
// Expected exit code: 0
//
// Bitwise AND with zero is the annihilator: 255 & 0 = 0. All operands
// loaded into u32 variables first. Distinct from s18_edge_zero_and_max
// (0 & 255 = 0, swapped operand order) and s14_edge_zero_minus_zero
// (0 - 0 = 0).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 0;
    r: u32 = a & b;       // 0
    return r;
}
