// s94_edge_max_and_val.vuma — 255 & 108 = 108 (AND with max preserves bits)
// Expected exit code: 108
//
// Edge case: AND with the max byte (0xFF) preserves the other
// operand. 255 & 108 = 108 (0x6C). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s90_edge_max_xor_val (23), s86_edge_max_and_low
// (9) and s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 108;          // 0x6C
    r: u32 = a & b;        // 0x6C = 108
    return r;
}
