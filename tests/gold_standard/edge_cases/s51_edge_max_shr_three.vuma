// s51_edge_max_shr_three.vuma — 255 >> 3 = 31
// Expected exit code: 31
//
// Shift the max u8 value right by 3. 255 >> 3 = 31 (0x1F). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s50_edge_max_xor_one (254) and
// s47_edge_max_xor_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 3;
    r: u32 = a >> b;       // 31
    return r;
}
