// s86_edge_zero_xor_high.vuma — 0 ^ 250 = 250
// Expected exit code: 250
//
// XOR the zero value 0 (0x00) with the high-bit value 250
// (0xFA). 0 ^ 250 = 250 (0xFA). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_edge_zero_xor_high (128), s78_edge_high_bit_
// or (129) and s74_edge_zero_xor_max (255).
fn main() -> i32 {
    a: u32 = 0;            // 0x00
    b: u32 = 250;          // 0xFA
    r: u32 = a ^ b;        // 0xFA = 250
    return r;
}
