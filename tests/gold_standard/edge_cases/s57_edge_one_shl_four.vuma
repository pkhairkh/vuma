// s57_edge_one_shl_four.vuma — 1 << 4 = 16
// Expected exit code: 16
//
// Smallest non-trivial shift: 1 << 4 = 16 (single bit at position
// 4). All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s54_edge_one_shl_seven
// (128) and s50_edge_one_shl_five (32).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    r: u32 = a << b;       // 16
    return r;
}
