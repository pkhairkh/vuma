// s99_edge_max_xor_val.vuma — 255 ^ 200 = 55 (XOR with max flips all bits)
// Expected exit code: 55
//
// Edge case: XOR with the max byte (0xFF) flips all bits of the
// other operand. 255 ^ 200 = 55 (0x37). All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s95_edge_max_xor_val (36), s91_edge_max_and_low (7)
// and s87_edge_max_and_low (9).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 200;          // 0xC8
    r: u32 = a ^ b;        // 0x37 = 55
    return r;
}
