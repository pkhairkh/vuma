// s80_edge_high_bit_or.vuma — 128 | 22 = 150
// Expected exit code: 150
//
// OR the high-bit value 128 (0x80) with 22. 128 | 22 = 150
// (0x96). Sets bit 7 of 22 -> 150. All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s78_edge_high_bit_or (129),
// s74_edge_max_xor_eight (247) and s73_edge_half_max_xor_three (124).
fn main() -> i32 {
    a: u32 = 128;
    b: u32 = 22;
    r: u32 = a | b;        // 150
    return r;
}
