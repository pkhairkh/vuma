// s77_edge_half_max_xor_one.vuma — 127 ^ 1 = 126
// Expected exit code: 126
//
// XOR the half-max u8 value 127 (0x7F) with 1 (0x01).
// 127 ^ 1 = 126 (0x7E). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_edge_half_max_and_low (0), s66_edge_half_max_xor_
// eleven (116) and s74_edge_max_and_two (2).

fn main() -> i32 {
    a: u32 = 127;
    b: u32 = 1;
    r: u32 = a ^ b;        // 126
    return r;
}
