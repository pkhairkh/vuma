// s24_edge_zero_and_max.vuma — 0 & 255 = 0
// Expected exit code: 0
//
// AND with zero annihilates: 0 & 0xFF = 0 (AND with zero clears all
// bits). All operands loaded into u32 variables first. Distinct from
// s22_edge_one_and_max (1 & 255 = 1) and s18_edge_zero_and_max (same
// op, different framing).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a & b;       // 0
    return r;
}
