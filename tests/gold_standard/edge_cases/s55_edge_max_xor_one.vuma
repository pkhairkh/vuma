// s55_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
//
// XOR the max u8 value with one (flip the LSB). 255 ^ 1 = 254.
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s54_edge_zero_xor_max
// (255) and s53_edge_max_xor_eight (247).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a ^ b;        // 254
    return r;
}
