// s27_edge_half_max.vuma — 255 / 2 = 127
// Expected exit code: 127
//
// Integer division of max u8 by two. 255 / 2 = 127 (truncated). All
// operands loaded into u32 variables first. Distinct from
// s26_edge_max_minus_one (sub) and s22_edge_max_or_zero (or).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a / b;       // 127
    return r;
}
