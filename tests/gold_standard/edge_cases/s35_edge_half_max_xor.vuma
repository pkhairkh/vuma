// s35_edge_half_max_xor.vuma — 127 ^ 0 = 127
// Expected exit code: 127
//
// XOR of half-max with zero. 127 ^ 0 = 127. All operands loaded
// into u32 variables first. Distinct from s34_edge_zero_xor_max
// (0 ^ 255 = 255) and s27_edge_half_max (127, no op).

fn main() -> i32 {
    a: u32 = 127;
    b: u32 = 0;
    r: u32 = a ^ b;        // 127
    return r;
}
