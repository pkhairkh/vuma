// s28_edge_max_xor_self.vuma — 255 ^ 255 = 0
// Expected exit code: 0
//
// XOR self: 255 ^ 255 = 0 (any value XORed with itself is zero). All
// operands loaded into u32 variables first. Distinct from
// s26_edge_max_minus_one (255 - 1 = 254) and s22_edge_max_xor_zero
// (255 ^ 0 = 255).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 255;
    r: u32 = a ^ b;       // 0
    return r;
}
