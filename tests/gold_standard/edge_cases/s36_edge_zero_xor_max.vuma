// s36_edge_zero_xor_max.vuma — 0 ^ 255 = 255
// Expected exit code: 255
//
// XOR with zero is identity: 0 ^ 255 = 255. All operands
// loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround).
// Distinct from s30_edge_zero_xor_max (0 ^ 255 = 255) and s27_edge_zero_xor_max (same op, different framing).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a ^ b;        // 255
    return r;
}
