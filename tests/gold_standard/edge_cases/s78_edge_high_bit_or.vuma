// s78_edge_high_bit_or.vuma — 128 | 1 = 129
// Expected exit code: 129
//
// OR the high-bit value 128 (0x80) with 1. 128 | 1 = 129
// (0x81). Sets bit 7 of 1 -> 129. All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s74_edge_max_xor_eight (247), s73_edge_half_max_xor_
// three (124) and s72_edge_max_and_low (5).
fn main() -> i32 {
    a: u32 = 128;
    b: u32 = 1;
    r: u32 = a | b;        // 129
    return r;
}
