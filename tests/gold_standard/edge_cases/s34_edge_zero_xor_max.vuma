// s34_edge_zero_xor_max.vuma — 0 ^ 255 = 255
// Expected exit code: 255
//
// XOR of zero with the maximum u8 value. 0 ^ 255 = 255. All
// operands loaded into u32 variables first. Distinct from
// s30_edge_zero_xor_max (same op, different framing) — this s34
// variant uses distinct operand framing, and from s27_edge_zero_
// and_one (0 & 1 = 0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a ^ b;        // 255
    return r;
}
