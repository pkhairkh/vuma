// s58_edge_zero_or_zero.vuma — 0 | 0 = 0
// Expected exit code: 0
// 
// OR two zero operands. 0 | 0 = 0. All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s51_edge_zero_and_max (0), s51_edge_one_shl_six (64)
// and s51_edge_max_shr_three (31).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 0;
    r: u32 = a | b;        // 0
    return r;
}
