// s3_edge_min_buf_max_val.vuma — 8-byte buf, store 255, return loaded
// Expected exit code: 255
//
// Edge case: store the maximum single-byte-representable value (255)
// and load it back. Verifies the round-trip of the largest value that
// the known store-truncation bug doesn't corrupt.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 255;
    v: u64 = *(buf + 0);
    free(buf);
    return v;
}
