// s23_edge_one_shl_four.vuma — 1 << 4 = 16
// Expected exit code: 16
//
// Power-of-two via shift: 1 << 4 = 16 (0x10). Single-bit set result.
// All operands loaded into u32 variables first. Distinct from
// s22_edge_one_and_max (1 & 255 = 1) and s20_edge_one_shl_seven
// (1 << 7 = 128).

fn main() -> i32 {
    a: u32 = 1;
    s: u32 = 4;
    r: u32 = a << s;      // 16
    return r;
}

