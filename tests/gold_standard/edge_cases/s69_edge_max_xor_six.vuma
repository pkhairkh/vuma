// s69_edge_max_xor_six.vuma -- 255 ^ 6 = 249
// Expected exit code: 249
//
// XOR the boundary value 255 with 6. 255 ^ 6 = 249 (0xF9). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s66_edge_max_xor_three (252),
// s65_edge_max_xor_sixteen (239) and s64_edge_max_xor_one (254).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 6;
    r: u32 = a ^ b;        // 249
    return r;
}
