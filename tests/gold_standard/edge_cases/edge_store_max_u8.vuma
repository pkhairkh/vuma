// edge_store_max_u8 — store 255 as u8, load, return
// Expected exit code: 255
//
// Edge case: the u8 maximum value (255). Verifies the high bit of the
// byte survives the round-trip without spurious sign extension.

fn main() -> i32 {
    buf = allocate(8);
    *buf = 255;
    val: i32 = *buf;
    free(buf);
    return val;
}
