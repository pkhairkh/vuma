// s92_edge_max_xor_val.vuma — 255 ^ 150 = 105 (XOR with max flips all bits)
// Expected exit code: 105
//
// Edge case: XOR with the max byte (0xFF) flips every bit
// (one's complement). 255 ^ 150 = 105 (0x69). All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s90_edge_max_xor_val (23),
// s86_edge_max_and_low (9) and s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 150;          // 0x96
    r: u32 = a ^ b;        // 0x69 = 105
    return r;
}
