// s56_edge_one_shl_three.vuma — 1 << 3 = 8
// Expected exit code: 8
//
// Shift 1 left by 3 -> 8 (0b1000). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s54_edge_one_shl_seven (128) and s50_edge_one_shl_
// five (32).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 3;
    r: u32 = a << b;       // 8
    return r;
}
