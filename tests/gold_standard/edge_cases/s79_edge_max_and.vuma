// s79_edge_max_and.vuma — 255 & 12 = 12
// Expected exit code: 12
//
// AND the max u8 value 255 with 12. 255 & 12 = 12 (0x0C).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s78_edge_max_and
// (6), s77_edge_max_and (11) and s76_edge_max_and (5).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 12;
    r: u32 = a & b;        // 12
    return r;
}
