// s3_edge_return_after_free.vuma — allocate, free, return constant
// Expected exit code: 7
//
// Edge case: allocate a buffer, free it, then return a constant.
// Verifies that calling free doesn't corrupt the function's return
// value path.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 0;
    free(buf);
    return 7;
}
