// s90_edge_one_xor_val.vuma — 1 ^ 24 = 25 (XOR with one flips bit 0)
// Expected exit code: 25
//
// Edge case: XOR with one toggles the lowest bit. 1 ^ 24 = 25
// (0x19). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_edge_one_shl_five (234), s82_edge_max_and_seven (7) and
// s78_edge_max_and (6).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 24;           // 0x18
    r: u32 = a ^ b;        // 0x19 = 25
    return r;
}
