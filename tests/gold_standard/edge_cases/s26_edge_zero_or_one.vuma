// s26_edge_zero_or_one.vuma — 0 | 1 = 1
// Expected exit code: 1
//
// OR identity: 0 | 1 = 1 (OR with zero preserves the other operand).
// All operands loaded into u32 variables first. Distinct from
// s22_edge_zero_xor_zero (0 ^ 0 = 0) and s16_edge_zero_xor_max
// (0 ^ 255 = 255).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 1;
    r: u32 = a | b;       // 1
    return r;
}
