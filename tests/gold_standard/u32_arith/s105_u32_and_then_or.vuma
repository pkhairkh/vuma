// s105_u32_and_then_or.vuma — (0xF0 & 0xA0) | 0x01 = 0xA0 | 0x01 = 0xA1 = 161
// Expected exit code: 161
// 
// Two-stage bitwise: AND then OR. (240 & 160) = 160 (0xA0); 160 | 1 = 161 (0xA1). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Operands nonzero & distinct.
// Distinct from s102_u32_or_then_and (19), s101_u32_xor_then_and (240), s100_u32_and_then_xor (116).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 160;          // 0xA0
    c: u32 = 1;            // 0x01
    x: u32 = a & b;        // 0xA0 = 160
    r: u32 = x | c;        // 0xA1 = 161
    return r;
}
