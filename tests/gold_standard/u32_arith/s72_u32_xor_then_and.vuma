// s72_u32_xor_then_and.vuma — (0x99 ^ 0x33) & 0x0F = 0xAA & 0x0F = 0x0A = 10
// Expected exit code: 10
//
// Two-stage bitwise: XOR then AND. (153 ^ 51) = 170 (0xAA);
// 170 & 15 = 10 (0x0A). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_or_then_and (36), s69_u32_xor_then_or (181) and
// s66_u32_or_then_and (24).
fn main() -> i32 {
    a: u32 = 153;          // 0x99
    b: u32 = 51;           // 0x33
    c: u32 = 15;           // 0x0F
    x: u32 = a ^ b;        // 0xAA = 170
    r: u32 = x & c;        // 0x0A = 10
    return r;
}
