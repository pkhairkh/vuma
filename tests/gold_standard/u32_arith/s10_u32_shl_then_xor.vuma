// s10_u32_shl_then_xor.vuma — (1 << 4) ^ 0x10 = 16 ^ 16 = 0
// Expected exit code: 0
//
// Shift left then XOR with the same value. (1 << 4) = 16; 16 ^ 16 = 0
// (any value XORed with itself cancels). All operands loaded into u32
// variables first. Distinct from s6_u32_shift_left_3 (shift by 3) and
// s5_u32_add_then_shift (add-then-shift).

fn main() -> i32 {
    v: u32 = 1;
    sh: u32 = 4;
    c: u32 = 16;          // 0x10
    shifted: u32 = v << sh;   // 16
    r: u32 = shifted ^ c;     // 0
    return r;
}
