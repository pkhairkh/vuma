// s94_u32_and_then_or.vuma — (0xAA & 0x0F) | 0x60 = 0x0A | 0x60 = 0x6A = 106
// Expected exit code: 106
//
// Two-stage bitwise: AND then OR. (170 & 15) = 10 (0x0A);
// 10 | 96 = 106 (0x6A). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_shl_then_xor (74), s86_u32_and_then_shr (24) and
// s82_u32_shl_then_or (80).
fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 15;           // 0x0F
    c: u32 = 96;           // 0x60
    x: u32 = a & b;        // 0x0A = 10
    r: u32 = x | c;        // 0x6A = 106
    return r;
}
