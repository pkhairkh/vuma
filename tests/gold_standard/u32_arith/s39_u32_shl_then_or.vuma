// s39_u32_shl_then_or.vuma — (1 << 4) | 0x0B = 0x10 | 0x0B = 0x1B = 27
// Expected exit code: 27
//
// Two-stage bitwise: shift left then OR. (1 << 4) = 16 (0x10);
// 16 | 11 = 27 (0x1B). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_shl_then_xor (37) and s34_u32_shl_then_or (69).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 11;           // 0x0B
    s: u32 = a << b;       // 0x10 = 16
    r: u32 = s | c;        // 0x1B = 27
    return r;
}
