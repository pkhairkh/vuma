// s74_u32_shl_then_xor.vuma — (3 << 2) ^ 0x83 = 0x0C ^ 0x83 = 0x8F = 143
// Expected exit code: 143
//
// Two-stage bitwise: shift left then XOR. 3 << 2 = 12 (0x0C);
// 12 ^ 131 = 143 (0x8F). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_shr_then_xor (180), s66_u32_shl_then_and (210)
// and s62_u32_and_then_shl (127).
fn main() -> i32 {
    a: u32 = 3;
    b: u32 = 2;
    c: u32 = 131;          // 0x83
    x: u32 = a << b;       // 0x0C = 12
    r: u32 = x ^ c;        // 0x8F = 143
    return r;
}
