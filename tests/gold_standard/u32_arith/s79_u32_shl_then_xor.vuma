// s79_u32_shl_then_xor.vuma — (0x01 << 5) ^ 0x15 = 0x20 ^ 0x15 = 0x35 = 53
// Expected exit code: 53
//
// Two-stage u32 bitwise: shift left then XOR. (1 << 5) = 32
// (0x20); 32 ^ 21 = 53 (0x35). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s78_u32_shl_then_or (2), s77_u32_shl_then_xor
// (1) and s76_u32_shl_then_xor (2).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 5;
    c: u32 = 21;           // 0x15
    x: u32 = a << b;       // 0x20 = 32
    r: u32 = x ^ c;        // 0x35 = 53
    return r;
}
