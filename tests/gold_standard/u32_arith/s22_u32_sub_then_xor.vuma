// s22_u32_sub_then_xor.vuma — (200 - 50) ^ 0x0F = 150 ^ 0x0F = 0x96 ^ 0x0F = 0x99 = 153
// Expected exit code: 153
//
// Sub then XOR. 200 - 50 = 150 (0x96); 150 ^ 15 = 153 (0x99). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_u32_add_xor_chain (add-then-xor
// chain) and s14_u32_or_then_xor (or-then-xor).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 50;
    c: u32 = 15;          // 0x0F
    d: u32 = a - b;       // 150 = 0x96
    r: u32 = d ^ c;       // 0x99 = 153
    return r;
}
