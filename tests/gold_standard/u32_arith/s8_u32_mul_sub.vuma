// s8_u32_mul_sub.vuma — 7 * 6 - 12 = 42 - 12 = 30
// Expected exit code: 30
//
// Multiplication then subtraction: 7 * 6 = 42, 42 - 12 = 30. Distinct
// from s4_u32_mul_add (mul then add) and s5_u32_sub_chain_3 (sub chain).

fn main() -> i32 {
    a: u32 = 7;
    b: u32 = 6;
    c: u32 = 12;
    p: u32 = a * b;    // 42
    r: u32 = p - c;    // 30
    return r;
}
