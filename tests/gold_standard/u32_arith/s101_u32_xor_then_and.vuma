// s101_u32_xor_then_and.vuma — (0xAA ^ 0x55) & 0xF0 = 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise on u32: XOR then AND. (170 ^ 85) = 255 (0xFF);
// 255 & 240 = 240 (0xF0). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s98_u32_and_then_shr (89), s97_u32_shr_then_and (13) and
// s94_u32_xor_then_shl (32).
fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 85;           // 0x55
    c: u32 = 240;          // 0xF0
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0xF0 = 240
    return r;
}
