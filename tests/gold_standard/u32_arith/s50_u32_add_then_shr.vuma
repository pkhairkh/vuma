// s50_u32_add_then_shr.vuma — (150 + 100) >> 1 = 250 >> 1 = 125
// Expected exit code: 125
//
// Two-stage u32 computation: add then shift right. 150 + 100 = 250;
// 250 >> 1 = 125. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_u32_and_then_or (63) and s43_u32_mul_then_xor (150).

fn main() -> i32 {
    a: u32 = 150;
    b: u32 = 100;
    c: u32 = 1;
    s: u32 = a + b;        // 250
    r: u32 = s >> c;       // 125
    return r;
}
