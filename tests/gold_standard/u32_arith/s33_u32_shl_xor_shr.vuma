// s33_u32_shl_xor_shr.vuma — ((5 << 4) ^ 0x33) >> 1 = (0x50 ^ 0x33) >> 1 = 0x63 >> 1 = 0x31 = 49
// Expected exit code: 49
//
// Deterministic test in the u32_arith category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_u32_shl_then_or (shl-then-or) and s26_u32_xor_then_shl (xor-then-shl, 240).
fn main() -> i32 {
    a: u32 = 5;
    b: u32 = 4;
    c: u32 = 51;           // 0x33
    d: u32 = 1;
    x: u32 = a << b;       // 0x50 = 80
    y: u32 = x ^ c;        // 0x63 = 99
    r: u32 = y >> d;       // 0x31 = 49
    return r;
}
