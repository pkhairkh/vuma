// s83_u32_xor_then_or.vuma — (0x60 ^ 0x0D) | 0x80 = 0x6D | 0x80 = 0xED = 237
// Expected exit code: 237
//
// Two-stage bitwise: XOR then OR. (96 ^ 13) = 109 (0x6D);
// 109 | 128 = 237 (0xED). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_xor_then_and (1), s74_u32_xor_then_or (135)
// and s72_u32_xor_then_and (60).
fn main() -> i32 {
    a: u32 = 96;           // 0x60
    b: u32 = 13;           // 0x0D
    c: u32 = 128;          // 0x80
    x: u32 = a ^ b;        // 0x6D = 109
    r: u32 = x | c;        // 0xED = 237
    return r;
}
