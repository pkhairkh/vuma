// s91_u32_shl_then_and.vuma — (9 << 1) & 0x1E = 0x12 & 0x1E = 0x12 = 18
// Expected exit code: 18
//
// Two-stage bitwise: shift-left then AND. 9 << 1 = 18 (0x12);
// 18 & 30 = 18 (0x12). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_shl_then_xor (74), s86_u32_shl_then_or (52) and
// s82_u32_shl_then_or (50).
fn main() -> i32 {
    a: u32 = 9;
    b: u32 = 1;
    c: u32 = 30;           // 0x1E
    x: u32 = a << b;       // 0x12 = 18
    r: u32 = x & c;        // 0x12 = 18
    return r;
}
