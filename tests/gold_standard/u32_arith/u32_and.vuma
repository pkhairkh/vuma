// u32_and — u32 AND: 0xFF & 0x0F
// Expected exit code: 15
//
// 0xFF & 0x0F = 0x0F = 15. Uses variables for both operands because VUMA
// may drop bitwise ops with immediate RHS.

fn main() -> i32 {
    a: u32 = 255;     // 0xFF
    b: u32 = 15;      // 0x0F
    result: u32 = a & b;
    return result;
}
