// s78_u32_or_then_shr.vuma — (0x00 | 0x04) >> 0 = 0x04 >> 0 = 0x04 = 4
// Expected exit code: 4
//
// Two-stage bitwise: OR then shift right. (0 | 4) = 4
// (0x04); 4 >> 0 = 4 (0x04). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s74_u32_or_then_shl (96),
// s73_u32_xor_then_and (98) and s72_u32_or_then_shr (60).
fn main() -> i32 {
    a: u32 = 0;           // 0x00
    b: u32 = 4;           // 0x04
    c: u32 = 0;
    x: u32 = a | b;        // 0x04 = 4
    r: u32 = x >> c;       // 0x04 = 4
    return r;
}
