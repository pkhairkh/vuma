// s85_u32_shl_then_and.vuma — (3 << 5) & 0xF0 = 0x60 & 0xF0 = 0x60 = 96
// Expected exit code: 96
//
// Two-stage u32 bitwise: shift left then AND. (3 << 5) = 96
// (0x60); 96 & 240 = 96 (0x60). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_u32_shl_then_or, s78_u32_shl_then_and
// and s74_u32_shl_then_and.
fn main() -> i32 {
    a: u32 = 3;
    b: u32 = 5;            // shift amount
    c: u32 = 240;          // 0xF0
    s: u32 = a << b;       // 0x60 = 96
    r: u32 = s & c;        // 0x60 = 96
    return r;
}
