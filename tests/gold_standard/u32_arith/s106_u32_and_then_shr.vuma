// s106_u32_and_then_shr.vuma — (0xFC & 0xBC) >> 1 = 0xBC >> 1 = 0x5E = 94
// Expected exit code: 94
//
// Two-stage bitwise: AND then shift-right. (252 & 188) = 188 (0xBC); 188 >> 1 = 94 (0x5E). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_u32_or_then_and (19), s101_u32_or_then_shr (48), s100_u32_and_then_xor (116).
fn main() -> i32 {
    a: u32 = 252;         // 0xFC
    b: u32 = 188;         // 0xBC
    c: u32 = 1;           // shift amount
    x: u32 = a & b;        // 0xBC = 188
    r: u32 = x >> c;       // 0x5E = 94
    return r;
}
