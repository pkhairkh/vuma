// s66_u32_or_then_and.vuma — (0x10 | 0x08) & 0xFC = 0x18 & 0xFC = 0x18 = 24
// Expected exit code: 24
//
// Two-stage bitwise: OR then AND. (16 | 8) = 24 (0x18); 24 & 252
// = 24 (0x18). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s62_u32_and_then_xor (90), s58_u32_and_then_shr (60) and s55_
// u32_or_then_and (240).
fn main() -> i32 {
    a: u32 = 16;           // 0x10
    b: u32 = 8;            // 0x08
    c: u32 = 252;          // 0xFC
    x: u32 = a | b;        // 0x18 = 24
    r: u32 = x & c;        // 0x18 = 24
    return r;
}
