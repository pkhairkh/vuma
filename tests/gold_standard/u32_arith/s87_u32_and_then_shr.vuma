// s87_u32_and_then_shr.vuma — (0xA0 & 0xF0) >> 3 = 0xA0 >> 3 = 0x14 = 20
// Expected exit code: 20
//
// Two-stage bitwise: AND then shift right. (160 & 240) = 160
// (0xA0); 160 >> 3 = 20 (0x14). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s86_u32_and_then_shr (24), s82_u32_xor_then_shr
// (45) and s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 160;          // 0xA0
    b: u32 = 240;          // 0xF0
    c: u32 = 3;            // shift amount
    x: u32 = a & b;        // 0xA0 = 160
    r: u32 = x >> c;       // 0x14 = 20
    return r;
}
