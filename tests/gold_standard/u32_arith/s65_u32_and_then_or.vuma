// s65_u32_and_then_or.vuma — (0xF0 & 0xCC) | 0x03 = 0xC0 | 0x03 = 0xC3 = 195
// Expected exit code: 195
//
// Two-stage bitwise: AND then OR. (240 & 204) = 192 (0xC0);
// 192 | 3 = 195 (0xC3). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// and_then_or (95), s58_u32_and_then_shr (60) and s62_u32_and_then_
// xor (90).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 204;          // 0xCC
    c: u32 = 3;            // 0x03
    x: u32 = a & b;        // 0xC0 = 192
    r: u32 = x | c;        // 0xC3 = 195
    return r;
}
