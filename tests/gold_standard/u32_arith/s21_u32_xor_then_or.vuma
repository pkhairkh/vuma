// s21_u32_xor_then_or.vuma — (0xA0 ^ 0x0A) | 0x55 = 0xAA | 0x55 = 0xFF = 255
// Expected exit code: 255
//
// XOR-then-OR. (160 ^ 10) = 170 (0xAA); 170 | 85 = 255 (0xFF). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_u32_xor_then_and (xor-then-and, 96)
// and s14_u32_or_then_xor (or-then-xor, opposite order).

fn main() -> i32 {
    a: u32 = 160;         // 0xA0
    b: u32 = 10;          // 0x0A
    c: u32 = 85;          // 0x55
    x: u32 = a ^ b;       // 0xAA = 170
    r: u32 = x | c;       // 0xFF = 255
    return r;
}
