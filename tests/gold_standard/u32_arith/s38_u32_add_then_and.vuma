// s38_u32_add_then_and.vuma — (100 + 50) & 0xF0 = 150 & 240 = 0x90 = 144
// Expected exit code: 144
//
// Two-stage computation: add then AND. (100 + 50) = 150 (0x96);
// 150 & 240 = 144 (0x90). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_u32_add_then_xor (153) and s30_u32_add_then_shr.

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 50;
    c: u32 = 240;          // 0xF0
    s: u32 = a + b;        // 150 = 0x96
    r: u32 = s & c;        // 0x90 = 144
    return r;
}
