// u32_mul_large — u32 overflow on multiply: (65536 * 65536) & 0xFFFFFFFF = 0
// Expected exit code: 0
//
// 0x10000 * 0x10000 = 0x100000000. Masked to u32 = 0.

fn main() -> i32 {
    a: u32 = 65536;          // 0x10000
    b: u32 = 65536;          // 0x10000
    product: u32 = (a * b) & 4294967295;
    return product & 255;
}
