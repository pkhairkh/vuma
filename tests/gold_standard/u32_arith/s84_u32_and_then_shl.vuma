// s84_u32_and_then_shl.vuma — (0xFF & 0x23) << 1 = 0x23 << 1 = 0x46 = 70
// Expected exit code: 70
//
// Two-stage bitwise: AND then shift left. (255 & 35) = 35
// (0x23); 35 << 1 = 70 (0x46). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_u32_shl_then_or (80), s78_u32_shl_then_or
// (2) and s74_u32_shl_then_xor (143).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 35;           // 0x23
    c: u32 = 1;            // shift amount
    x: u32 = a & b;        // 0x23 = 35
    r: u32 = x << c;       // 0x46 = 70
    return r;
}
