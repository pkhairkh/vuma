// s93_u32_xor_then_or.vuma — (0xFF ^ 0xBB) | 0x10 = 0x44 | 0x10 = 0x54 = 84
// Expected exit code: 84
//
// Two-stage bitwise: XOR then OR. (255 ^ 187) = 68 (0x44);
// 68 | 16 = 84 (0x54). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_xor_then_or (58), s82_u32_xor_then_shr (45) and s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 187;          // 0xBB
    c: u32 = 16;           // 0x10
    x: u32 = a ^ b;        // 0x44 = 68
    r: u32 = x | c;        // 0x54 = 84
    return r;
}
