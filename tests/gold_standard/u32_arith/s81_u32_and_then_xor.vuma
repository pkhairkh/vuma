// s81_u32_and_then_xor.vuma — (0xF0 & 0xCC) ^ 0x0F = 0xC0 ^ 0x0F = 0xCF = 207
// Expected exit code: 207
//
// Two-stage bitwise: AND then XOR. 240 & 204 = 192 (0xC0);
// 192 ^ 15 = 207 (0xCF). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_and_then_xor (1), s77_u32_and_then_xor (25) and
// s76_u32_and_then_or (83).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 204;          // 0xCC
    c: u32 = 15;           // 0x0F
    x: u32 = a & b;        // 0xC0 = 192
    r: u32 = x ^ c;        // 0xCF = 207
    return r;
}
