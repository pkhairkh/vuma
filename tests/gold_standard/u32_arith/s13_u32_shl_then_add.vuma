// s13_u32_shl_then_add.vuma — (1 << 5) + 7 = 32 + 7 = 39
// Expected exit code: 39
//
// Shift left then add. 1 << 5 = 32; 32 + 7 = 39. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug workaround
// for the shift). Distinct from s6_u32_shift_left_3 (pure shift) and
// s10_u32_shl_then_xor (shl-then-xor).

fn main() -> i32 {
    v: u32 = 1;
    s: u32 = 5;
    c: u32 = 7;
    a: u32 = v << s;      // 32
    r: u32 = a + c;       // 39
    return r;
}
