// s5_u32_xor_two_stages.vuma — (15 ^ 9) ^ (12 ^ 10) = 6 ^ 6 = 0
// Expected exit code: 0
//
// Two XOR pairs computed in parallel-ish, then XORed together.
// (15 ^ 9) = 6, (12 ^ 10) = 6, 6 ^ 6 = 0. Operands loaded into
// variables first to dodge the immediate-RHS bitwise drop bug.

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 9;
    c: u32 = 12;
    d: u32 = 10;
    p1: u32 = a ^ b;   // 6
    p2: u32 = c ^ d;   // 6
    r: u32 = p1 ^ p2;  // 0
    return r;
}
