// s7_u32_mul_three.vuma — 3 * 4 * 5 = 60
// Expected exit code: 60
//
// Three-way multiplication chain via intermediates. 3 * 4 = 12;
// 12 * 5 = 60. Distinct from s6_u32_add_pair (addition, not mul)
// and s4_u32_mul_add (mul then add, not pure mul chain).

fn main() -> i32 {
    a: u32 = 3;
    b: u32 = 4;
    c: u32 = 5;
    t1: u32 = a * b;   // 12
    r: u32 = t1 * c;   // 60
    return r;
}
