// s38_u32_and_then_or.vuma — (0xCC & 0xF0) | 0x0A = 0xC0 | 0x0A = 0xCA = 202
// Expected exit code: 202
//
// Two-stage bitwise: AND then OR. (204 & 240) = 192 (0xC0); 192 |
// 10 = 202 (0xCA). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_u32_xor_then_and (170) and s30_u32_and_then_xor.

fn main() -> i32 {
    a: u32 = 204;          // 0xCC
    b: u32 = 240;          // 0xF0
    c: u32 = 10;           // 0x0A
    x: u32 = a & b;        // 0xC0 = 192
    r: u32 = x | c;        // 0xCA = 202
    return r;
}
