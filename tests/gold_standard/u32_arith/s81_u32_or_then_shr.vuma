// s81_u32_or_then_shr.vuma — (0x30 | 0x06) >> 1 = 0x36 >> 1 = 0x1B = 27
// Expected exit code: 27
//
// Two-stage bitwise: OR then shift right. 48 | 6 = 54 (0x36);
// 54 >> 1 = 27 (0x1B). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_or_then_shr (4), s77_u32_shl_then_or (88) and
// s76_u32_shr_then_xor (20).
fn main() -> i32 {
    a: u32 = 48;           // 0x30
    b: u32 = 6;            // 0x06
    c: u32 = 1;
    x: u32 = a | b;        // 0x36 = 54
    r: u32 = x >> c;       // 0x1B = 27
    return r;
}
