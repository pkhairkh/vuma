// u32_2_and — u32 AND: 0xFF & 0x0F = 15
// Expected exit code: 15
//
// 255 & 15 = 15. Loads both operands into variables because VUMA may
// drop bitwise ops with immediate RHS.

fn main() -> i32 {
    a: u32 = 255;     // 0xFF
    b: u32 = 15;      // 0x0F
    result: u32 = a & b;
    return result;
}
