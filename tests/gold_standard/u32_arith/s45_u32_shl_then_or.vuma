// s45_u32_shl_then_or.vuma — (1 << 3) | 0x40 = 8 | 64 = 72
// Expected exit code: 72
//
// Two-stage bitwise/arith: shift left then OR. (1 << 3) = 8;
// 8 | 64 = 72 (0x48). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_u32_shl_then_add (shl-then-add, 26) and s34_u32_shl_then_or
// (69).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 3;
    c: u32 = 64;           // 0x40
    s: u32 = a << b;       // 8
    r: u32 = s | c;        // 0x48 = 72
    return r;
}
