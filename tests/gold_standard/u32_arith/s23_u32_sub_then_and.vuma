// s23_u32_sub_then_and.vuma — (200 - 50) & 0xC0 = 150 & 192 = 0x96 & 0xC0 = 0x80 = 128
// Expected exit code: 128
//
// Sub then AND. 200 - 50 = 150 (0x96); 150 & 192 = 128 (0x80, the high
// bit of 0x96). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s22_u32_sub_then_xor (sub-then-xor, value 153) and s22_u32_shl_then_and
// (shl-then-and, value 32).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 50;
    c: u32 = 192;         // 0xC0
    d: u32 = a - b;       // 150 = 0x96
    r: u32 = d & c;       // 0x80 = 128
    return r;
}

