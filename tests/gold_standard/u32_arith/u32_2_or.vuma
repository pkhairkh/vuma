// u32_2_or — u32 OR: 0xF0 | 0x0F = 255
// Expected exit code: 255
//
// 240 | 15 = 255. Loads both operands into variables because VUMA may
// drop bitwise ops with immediate RHS.

fn main() -> i32 {
    a: u32 = 240;     // 0xF0
    b: u32 = 15;      // 0x0F
    result: u32 = a | b;
    return result;
}
