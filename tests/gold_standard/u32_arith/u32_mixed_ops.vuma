// u32_mixed_ops — mixed arithmetic with precedence: ((2 * 3) + 10) - 2 = 14
// Expected exit code: 14
//
// 2 * 3 = 6; 6 + 10 = 16; 16 - 2 = 14. Each step masked to u32.

fn main() -> i32 {
    a: u32 = 2;
    b: u32 = 3;
    c: u32 = 10;
    d: u32 = 2;
    p: u32 = (a * b) & 4294967295;       // 6
    s1: u32 = (p + c) & 4294967295;      // 16
    s2: u32 = (s1 - d) & 4294967295;     // 14
    return s2;
}
