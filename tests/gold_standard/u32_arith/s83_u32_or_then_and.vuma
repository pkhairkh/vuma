// s83_u32_or_then_and.vuma — (0xE0 | 0x0E) & 0xFF = 0xEE & 0xFF = 0xEE = 238
// Expected exit code: 238
//
// Two-stage bitwise: OR then AND. (224 | 14) = 238 (0xEE);
// 238 & 255 = 238 (0xEE). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_and_then_xor (1), s74_u32_or_then_and (135)
// and s72_u32_xor_then_and (60).
fn main() -> i32 {
    a: u32 = 224;          // 0xE0
    b: u32 = 14;           // 0x0E
    c: u32 = 255;          // 0xFF
    x: u32 = a | b;        // 0xEE = 238
    r: u32 = x & c;        // 0xEE = 238
    return r;
}
