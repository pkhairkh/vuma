// s31_u32_add_then_xor.vuma — (100 + 50) ^ 0x33 = 150 ^ 51 = 165
// Expected exit code: 165
//
// Add then XOR. 100 + 50 = 150 (0x96); 150 ^ 51 = 165 (0xA5). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s30_u32_and_then_add (and-then-add)
// and s28_u32_add_xor_chain (add-xor-chain).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 50;
    c: u32 = 51;           // 0x33
    s: u32 = a + b;       // 150 = 0x96
    r: u32 = s ^ c;       // 0xA5 = 165
    return r;
}
