// s90_u32_xor_then_or.vuma — (0xFF ^ 0xC7) | 0x02 = 0x38 | 0x02 = 0x3A = 58
// Expected exit code: 58
//
// Two-stage bitwise: XOR then OR. (255 ^ 199) = 56 (0x38);
// 56 | 2 = 58 (0x3A). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_u32_xor_then_and (51), s82_u32_xor_then_shr (45) and
// s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 199;          // 0xC7
    c: u32 = 2;            // 0x02
    x: u32 = a ^ b;        // 0x38 = 56
    r: u32 = x | c;        // 0x3A = 58
    return r;
}
