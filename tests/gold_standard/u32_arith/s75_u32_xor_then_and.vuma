// s75_u32_xor_then_and.vuma — (0xD7 ^ 0x2A) & 0x7E = 0xFD & 0x7E = 0x7C = 124
// Expected exit code: 124
//
// Two-stage bitwise: XOR then AND. 215 ^ 42 = 253 (0xFD);
// 253 & 126 = 124 (0x7C). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s74_u32_xor_then_or (174), s70_u32_shr_then_xor (180) and
// s66_u32_shl_then_and (210).
fn main() -> i32 {
    a: u32 = 215;          // 0xD7
    b: u32 = 42;           // 0x2A
    c: u32 = 126;          // 0x7E
    x: u32 = a ^ b;        // 0xFD = 253
    r: u32 = x & c;        // 0x7C = 124
    return r;
}
