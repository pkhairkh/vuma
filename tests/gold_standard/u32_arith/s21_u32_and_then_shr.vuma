// s21_u32_and_then_shr.vuma — (0xFF & 0xF0) >> 3 = 0xF0 >> 3 = 0x1E = 30
// Expected exit code: 30
//
// AND-then-SHR. (255 & 240) = 240 (0xF0); 240 >> 3 = 30 (0x1E). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_u32_add_xor_chain (add-xor chain)
// and s14_u32_xor_then_shl (xor-then-shl).

fn main() -> i32 {
    a: u32 = 255;         // 0xFF
    b: u32 = 240;         // 0xF0
    s: u32 = 3;
    x: u32 = a & b;       // 0xF0 = 240
    r: u32 = x >> s;      // 0x1E = 30
    return r;
}
