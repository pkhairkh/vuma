// s53_u32_and_then_shr.vuma — (0xF0 & 0x70) >> 3 = 0x70 >> 3 = 0x0E = 14
// Expected exit code: 14
//
// Two-stage bitwise: AND then shift right. (240 & 112) = 112 (0x70);
// 112 >> 3 = 14 (0x0E). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s49_u32_and_then_shr (15) and s50_u32_add_then_shr (125).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 112;          // 0x70
    c: u32 = 3;
    x: u32 = a & b;        // 0x70 = 112
    r: u32 = x >> c;       // 0x0E = 14
    return r;
}
