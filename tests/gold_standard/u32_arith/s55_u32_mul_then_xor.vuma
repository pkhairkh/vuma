// s55_u32_mul_then_xor.vuma — (10 * 9) ^ 0x3C = 90 ^ 60 = 102
// Expected exit code: 102
//
// Two-stage u32 computation: multiply then XOR. 10 * 9 = 90 (0x5A);
// 90 ^ 60 = 102 (0x66). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_u32_add_then_xor (240) and s53_u32_and_then_shr (14).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 9;
    c: u32 = 60;           // 0x3C
    p: u32 = a * b;        // 0x5A = 90
    r: u32 = p ^ c;        // 0x66 = 102
    return r;
}
