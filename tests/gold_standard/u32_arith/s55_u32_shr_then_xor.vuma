// s55_u32_shr_then_xor.vuma — (0xF0 >> 4) ^ 0xAA = 15 ^ 170 = 165
// Expected exit code: 165
//
// Two-stage bitwise: shift right then XOR. 240 >> 4 = 15 (0x0F);
// 15 ^ 170 = 165 (0xA5). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_u32_shl_then_and (64) and s53_u32_shl_then_and (64).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 4;
    c: u32 = 170;          // 0xAA
    x: u32 = a >> b;       // 0x0F = 15
    r: u32 = x ^ c;        // 0xA5 = 165
    return r;
}
