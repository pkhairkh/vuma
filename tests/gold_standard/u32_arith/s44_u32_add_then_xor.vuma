// s44_u32_add_then_xor.vuma — (10 + 20) ^ 0x10 = 30 ^ 16 = 14
// Expected exit code: 14
//
// Two-stage arith/bitwise: add then XOR. 10 + 20 = 30;
// 30 ^ 16 = 14. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s42_u32_
// mul_then_xor (9) and s38_u32_and_then_or.

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 16;           // 0x10
    s: u32 = a + b;        // 30
    r: u32 = s ^ c;        // 14
    return r;
}
