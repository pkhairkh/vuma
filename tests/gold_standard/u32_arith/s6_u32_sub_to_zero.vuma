// s6_u32_sub_to_zero.vuma — 50 - 50 = 0
// Expected exit code: 0
//
// Subtract a value from itself -> 0. Distinct from s5_u32_sub_chain_3
// (3-way chain ending non-zero) and s5_edge_zero_sum (sum of zeros).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 50;
    r: u32 = a - b;
    return r;
}
