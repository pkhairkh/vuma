// s77_u32_shl_then_or.vuma — (0x03 << 3) | 0x40 = 0x18 | 0x40 = 0x58 = 88
// Expected exit code: 88
//
// Two-stage bitwise: shift left then OR. 3 << 3 = 24 (0x18);
// 24 | 64 = 88 (0x58). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_shr_then_xor (180), s66_u32_shl_then_or (210)
// and s74_u32_shl_then_xor (143).

fn main() -> i32 {
    a: u32 = 3;
    b: u32 = 3;
    c: u32 = 64;           // 0x40
    x: u32 = a << b;       // 0x18 = 24
    r: u32 = x | c;        // 0x58 = 88
    return r;
}
