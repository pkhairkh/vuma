// s29_u32_shr_then_xor.vuma — (0xE0 >> 3) ^ 0x07 = 0x1C ^ 0x07 = 0x1B = 27
// Expected exit code: 27
//
// SHR then XOR. (224 >> 3) = 28 (0x1C); 28 ^ 7 = 27 (0x1B). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Distinct from s26_u32_mul_then_xor (mul-then-xor, 15) and s22_u32_shl_then_and (shl-then-and).

fn main() -> i32 {
    a: u32 = 224;         // 0xE0
    b: u32 = 3;
    c: u32 = 7;           // 0x07
    x: u32 = a >> b;      // 0x1C = 28
    r: u32 = x ^ c;       // 0x1B = 27
    return r;
}
