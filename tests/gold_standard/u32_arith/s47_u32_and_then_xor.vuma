// s47_u32_and_then_xor.vuma — (0xFF & 0x55) ^ 0x0F = 0x55 ^ 0x0F = 0x5A = 90
// Expected exit code: 90
//
// Two-stage bitwise: AND then XOR. (255 & 85) = 85 (0x55); 85 ^ 15 =
// 90 (0x5A). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s46_
// u32_or_then_and (195) and s42_u32_and_then_xor.

fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 85;           // 0x55
    c: u32 = 15;           // 0x0F
    m: u32 = a & b;        // 0x55 = 85
    r: u32 = m ^ c;        // 0x5A = 90
    return r;
}
