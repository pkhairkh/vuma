// s39_u32_add_then_xor.vuma — (120 + 30) ^ 0x07 = 150 ^ 7 = 145
// Expected exit code: 145
//
// Two-stage computation: add then XOR. (120 + 30) = 150 (0x96);
// 150 ^ 7 = 145 (0x91). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_add_then_and (144) and s34_u32_add_then_xor (153).

fn main() -> i32 {
    a: u32 = 120;
    b: u32 = 30;
    c: u32 = 7;            // 0x07
    s: u32 = a + b;        // 150 = 0x96
    r: u32 = s ^ c;        // 0x91 = 145
    return r;
}
