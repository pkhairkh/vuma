// s5_u32_sub_chain_3.vuma — 200 - 50 - 30 - 20 = 100
// Expected exit code: 100
//
// Three-step subtraction chain via intermediates. 200 - 50 = 150,
// 150 - 30 = 120, 120 - 20 = 100. All values within U8 range.
// Distinct from s4_u32_sub_chain (2-step chain).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 50;
    c: u32 = 30;
    d: u32 = 20;
    t1: u32 = a - b;     // 150
    t2: u32 = t1 - c;    // 120
    r: u32 = t2 - d;     // 100
    return r;
}
