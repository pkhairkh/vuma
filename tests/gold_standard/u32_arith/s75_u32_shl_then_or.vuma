// s75_u32_shl_then_or.vuma — (9 << 2) | 0xA0 = 0x24 | 0xA0 = 0xA4 = 164
// Expected exit code: 164
//
// Two-stage bitwise: shift left then OR. 9 << 2 = 36 (0x24);
// 36 | 160 = 164 (0xA4). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s74_u32_shl_then_xor (143), s70_u32_shr_then_xor (180) and
// s66_u32_shl_then_and (210).
fn main() -> i32 {
    a: u32 = 9;
    b: u32 = 2;
    c: u32 = 160;          // 0xA0
    x: u32 = a << b;       // 0x24 = 36
    r: u32 = x | c;        // 0xA4 = 164
    return r;
}
