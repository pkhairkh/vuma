// s17_u32_xor_then_shr.vuma — (0xF0 ^ 0x0F) >> 2 = 0xFF >> 2 = 0x3F = 63
// Expected exit code: 63
//
// XOR-then-shift-right. (240 ^ 15) = 255 (0xFF); 255 >> 2 = 63 (0x3F).
// All operands loaded into u32 variables first. Distinct from
// s14_u32_xor_then_shl (XOR-then-SHL) and s9_u32_shift_right_2 (pure
// shift).

fn main() -> i32 {
    a: u32 = 240;         // 0xF0
    b: u32 = 15;          // 0x0F
    sh: u32 = 2;
    x: u32 = a ^ b;       // 0xFF = 255
    r: u32 = x >> sh;     // 0x3F = 63
    return r;
}
