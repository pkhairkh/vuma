// s96_u32_or_then_shr.vuma — (0xF0 | 0x08) >> 2 = 0xF8 >> 2 = 0x3E = 62
// Expected exit code: 62
//
// Two-stage bitwise: OR then shift-right. (240 | 8) = 248 (0xF8);
// 248 >> 2 = 62 (0x3E). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_or_then_xor (243), s90_u32_and_then_shr (75) and
// s86_u32_and_then_shr (24).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 8;            // 0x08
    s: u32 = 2;
    x: u32 = a | b;        // 0xF8 = 248
    r: u32 = x >> s;       // 0x3E = 62
    return r;
}
