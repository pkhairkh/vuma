// s50_u32_xor_then_and.vuma — (0xCC ^ 0x33) & 0xF0 = 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: XOR then AND. (204 ^ 51) = 255 (0xFF);
// 255 & 240 = 240 (0xF0). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_u32_xor_then_shr (127) and s43_u32_xor_then_and (204).

fn main() -> i32 {
    a: u32 = 204;          // 0xCC
    b: u32 = 51;           // 0x33
    c: u32 = 240;          // 0xF0
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0xF0 = 240
    return r;
}
