// s61_u32_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0xAA = 0xFF ^ 0xAA = 0x55 = 85
// Expected exit code: 85
// 
// Two-stage bitwise: OR then XOR. (240 | 15) = 255 (0xFF); 255 ^
// 170 = 85 (0x55). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s58_
// u32_or_then_xor (207), s58_u32_and_then_shr (60) and s58_u32_xor_
// then_and (255).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 170;          // 0xAA
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x ^ c;        // 0x55 = 85
    return r;
}
