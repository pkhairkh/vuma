// s82_u32_shl_then_or.vuma — (0x02 << 5) | 0x10 = 0x40 | 0x10 = 0x50 = 80
// Expected exit code: 80
//
// Two-stage bitwise: shift left then OR. (2 << 5) = 64 (0x40);
// 64 | 16 = 80 (0x50). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_shl_then_or (2), s74_u32_shl_then_or (40)
// and s72_u32_shl_then_xor (35).
fn main() -> i32 {
    a: u32 = 2;            // 0x02
    b: u32 = 5;            // shift amount
    c: u32 = 16;           // 0x10
    x: u32 = a << b;       // 0x40 = 64
    r: u32 = x | c;        // 0x50 = 80
    return r;
}
