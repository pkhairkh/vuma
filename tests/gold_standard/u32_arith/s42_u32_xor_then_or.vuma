// s42_u32_xor_then_or.vuma — (0xF0 ^ 0x0F) | 0x55 = 0xFF | 0x55 = 0xFF = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then OR. (240 ^ 15) = 255 (0xFF);
// 255 | 85 = 255. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_shl_then_xor (37) and s34_u32_xor_then_and.

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 85;           // 0x55
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x | c;        // 0xFF = 255
    return r;
}
