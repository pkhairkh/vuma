// s62_u32_shl_then_xor.vuma — (1 << 5) ^ 0x03 = 32 ^ 3 = 0x23 = 35
// Expected exit code: 35
// 
// Two-stage bitwise: shift left then XOR. (1 << 5) = 32 (0x20);
// 32 ^ 3 = 35 (0x23). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// or_then_shr (120), s58_u32_or_then_xor (207) and s55_u32_mul_then_
// xor (75).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;
    c: u32 = 3;            // 0x03
    x: u32 = a << b;       // 0x20 = 32
    r: u32 = x ^ c;        // 0x23 = 35
    return r;
}
