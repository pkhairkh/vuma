// Test: read/write u32 big-endian
fn read_u32_be(buf: Address, offset: u64) -> u32 {
    b0: u32 = *(buf + offset);
    b1: u32 = *(buf + offset + 1);
    b2: u32 = *(buf + offset + 2);
    b3: u32 = *(buf + offset + 3);
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
}

fn main() -> i32 {
    buf = allocate(4);
    *(buf + 0) = 0;
    *(buf + 1) = 0;
    *(buf + 2) = 0;
    *(buf + 3) = 1;
    val: u32 = read_u32_be(buf, 0);
    // Should be 1 (big-endian: 0x00000001)
    return 0;
}
