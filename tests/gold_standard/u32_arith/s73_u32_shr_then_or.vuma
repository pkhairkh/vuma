// s73_u32_shr_then_or.vuma — (0xE0 >> 1) | 0x06 = 0x70 | 0x06 = 0x76 = 118
// Expected exit code: 118
//
// Two-stage bitwise: shift right then OR. (224 >> 1) = 112
// (0x70); 112 | 6 = 118 (0x76). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s70_u32_shr_then_xor (180), s69_u32_shl_then_
// xor (83) and s66_u32_shr_then_xor (55).
fn main() -> i32 {
    a: u32 = 224;          // 0xE0
    b: u32 = 1;
    c: u32 = 6;            // 0x06
    x: u32 = a >> b;       // 0x70 = 112
    r: u32 = x | c;        // 0x76 = 118
    return r;
}
