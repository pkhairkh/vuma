// s58_u32_xor_then_and.vuma — (0x0F ^ 0xF0) & 0xFF = 0xFF & 0xFF = 0xFF = 255
// Expected exit code: 255
// 
// Two-stage bitwise: XOR then AND. (15 ^ 240) = 255 (0xFF);
// 255 & 255 = 255 (0xFF). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// or_then_shr (120), s51_u32_and_then_or (95) and s51_u32_xor_then_
// shl (204).

fn main() -> i32 {
    a: u32 = 15;           // 0x0F
    b: u32 = 240;          // 0xF0
    c: u32 = 255;          // 0xFF
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0xFF = 255
    return r;
}
