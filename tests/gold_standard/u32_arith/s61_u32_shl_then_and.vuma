// s61_u32_shl_then_and.vuma — (1 << 4) & 0xFF = 0x10 & 0xFF = 0x10 = 16
// Expected exit code: 16
// 
// Two-stage bitwise: shift left then AND-mask. (1 << 4) = 16 (0x10);
// 16 & 255 = 16 (0x10). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_u32_or_then_xor (207), s58_u32_and_then_shr (60) and s58_u32_
// xor_then_and (255).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 255;          // 0xFF
    x: u32 = a << b;       // 0x10 = 16
    r: u32 = x & c;        // 0x10 = 16
    return r;
}
