// s98_u32_xor_then_shl.vuma — (0x0A ^ 0x01) << 3 = 0x0B << 3 = 0x58 = 88
// Expected exit code: 88
//
// Two-stage bitwise: XOR then shift-left. (10 ^ 1) = 11 (0x0B);
// 11 << 3 = 88 (0x58). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_xor_then_shl (32), s90_u32_shl_then_xor (74) and
// s86_u32_xor_then_and (51).
fn main() -> i32 {
    a: u32 = 10;           // 0x0A
    b: u32 = 1;            // 0x01
    s: u32 = 3;
    x: u32 = a ^ b;        // 0x0B = 11
    r: u32 = x << s;       // 0x58 = 88
    return r;
}
