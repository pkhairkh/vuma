// s92_u32_shl_then_xor.vuma — (10 << 3) ^ 0x0F = 0x50 ^ 0x0F = 0x5F = 95
// Expected exit code: 95
//
// Two-stage bitwise: shift-left then XOR. 10 << 3 = 80 (0x50);
// 80 ^ 15 = 95 (0x5F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_shl_then_xor (74), s86_u32_shl_then_or (52) and
// s82_u32_shl_then_or (50).
fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 3;
    c: u32 = 15;           // 0x0F
    x: u32 = a << b;       // 0x50 = 80
    r: u32 = x ^ c;        // 0x5F = 95
    return r;
}
