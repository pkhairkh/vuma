// s65_u32_shl_then_and.vuma — (0x07 << 3) & 0x3C = 0x38 & 0x3C = 0x38 = 56
// Expected exit code: 56
//
// Two-stage bitwise: shift-left then AND. (7 << 3) = 56 (0x38);
// 56 & 60 = 56 (0x38). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// or_then_shr (120), s58_u32_or_then_xor (207) and s62_u32_shl_then_
// xor (35).

fn main() -> i32 {
    a: u32 = 7;            // 0x07
    b: u32 = 3;            // shift amount
    c: u32 = 60;           // 0x3C
    x: u32 = a << b;       // 0x38 = 56
    r: u32 = x & c;        // 0x38 = 56
    return r;
}
