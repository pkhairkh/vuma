// s68_u32_and_then_shl.vuma — (0x55 & 0x11) << 3 = 0x11 << 3 = 0x88 = 136
// Expected exit code: 136
//
// Two-stage bitwise: AND then shift-left. (85 & 17) = 17 (0x11);
// 17 << 3 = 136 (0x88). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_u32_shr_then_xor (55), s62_u32_and_then_xor (90) and
// s58_u32_and_then_shr (60).
fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 17;           // 0x11
    c: u32 = 3;
    x: u32 = a & b;        // 0x11 = 17
    r: u32 = x << c;       // 0x88 = 136
    return r;
}
