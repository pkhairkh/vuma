// s79_u32_xor_then_and.vuma — (0x2F ^ 0x01) & 0x3F = 0x2E & 0x3F = 0x2E = 46
// Expected exit code: 46
//
// Two-stage u32 bitwise: XOR then AND. (47 ^ 1) = 46 (0x2E);
// 46 & 63 = 46 (0x2E). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_and_then_xor (1), s77_u32_xor_then_and (2) and
// s76_u32_xor_then_and (3).
fn main() -> i32 {
    a: u32 = 47;           // 0x2F
    b: u32 = 1;            // 0x01
    c: u32 = 63;           // 0x3F
    x: u32 = a ^ b;        // 0x2E = 46
    r: u32 = x & c;        // 0x2E = 46
    return r;
}
