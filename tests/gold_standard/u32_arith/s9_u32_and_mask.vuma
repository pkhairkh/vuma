// s9_u32_and_mask.vuma — 0xFF & 0x0F = 15
// Expected exit code: 15
//
// Mask 0xFF (255) with 0x0F (15) -> 15. The mask is loaded into a
// variable first to dodge the immediate-RHS bitwise drop bug.
// Distinct from s5_u32_mask_high_nibble (masks 0xAB with 0x0F -> 11).

fn main() -> i32 {
    v: u32 = 255;     // 0xFF
    m: u32 = 15;      // 0x0F
    r: u32 = v & m;   // 0x0F = 15
    return r;
}
