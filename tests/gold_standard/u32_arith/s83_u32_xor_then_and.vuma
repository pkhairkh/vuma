// s83_u32_xor_then_and.vuma — (0xF0 ^ 0x01) & 0xFF = 0xF1 & 0xFF = 0xF1 = 241
// Expected exit code: 241
//
// Two-stage bitwise: XOR then AND. (240 ^ 1) = 241 (0xF1);
// 241 & 255 = 241 (0xF1). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_and_then_xor (1), s74_u32_xor_then_and (135)
// and s72_u32_xor_then_and (60).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 1;            // 0x01
    c: u32 = 255;          // 0xFF
    x: u32 = a ^ b;        // 0xF1 = 241
    r: u32 = x & c;        // 0xF1 = 241
    return r;
}
