// s69_u32_and_then_shr.vuma -- (0xFF & 0xFC) >> 1 = 0xFC >> 1 = 0x7E = 126
// Expected exit code: 126
//
// Two-stage bitwise: AND then shift right. (255 & 252) = 252 (0xFC);
// 252 >> 1 = 126 (0x7E). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s66_u32_
// or_then_and (24), s65_u32_and_then_or (195) and s64_u32_and_then_
// shr (85).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 252;          // 0xFC
    c: u32 = 1;            // shift amount
    x: u32 = a & b;        // 0xFC = 252
    r: u32 = x >> c;       // 0x7E = 126
    return r;
}
