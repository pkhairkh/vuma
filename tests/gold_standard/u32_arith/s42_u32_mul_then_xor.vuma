// s42_u32_mul_then_xor.vuma — (5 * 5) ^ 0x10 = 25 ^ 16 = 9
// Expected exit code: 9
//
// Two-stage arith/bitwise: multiply then XOR. 5 * 5 = 25;
// 25 ^ 16 = 9. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_and_then_or and s34_u32_add_then_xor.

fn main() -> i32 {
    a: u32 = 5;
    b: u32 = 5;
    c: u32 = 16;           // 0x10
    p: u32 = a * b;        // 25
    r: u32 = p ^ c;        // 9
    return r;
}
