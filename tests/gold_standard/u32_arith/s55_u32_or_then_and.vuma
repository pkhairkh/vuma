// s55_u32_or_then_and.vuma — (0x33 | 0xCC) & 0xF0 = 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: OR then AND. (51 | 204) = 255 (0xFF);
// 255 & 240 = 240 (0xF0). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_u32_xor_then_or (255) and s53_u32_xor_then_or (255).

fn main() -> i32 {
    a: u32 = 51;           // 0x33
    b: u32 = 204;          // 0xCC
    c: u32 = 240;          // 0xF0
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x & c;        // 0xF0 = 240
    return r;
}
