// s82_u32_or_then_and.vuma — (0x33 | 0x0F) & 0x0F = 0x3F & 0x0F = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: OR then AND. (51 | 15) = 63 (0x3F);
// 63 & 15 = 15 (0x0F). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_and_then_xor (1), s74_u32_or_then_and (135)
// and s72_u32_xor_then_and (60).
fn main() -> i32 {
    a: u32 = 51;           // 0x33
    b: u32 = 15;           // 0x0F
    c: u32 = 15;           // 0x0F
    x: u32 = a | b;        // 0x3F = 63
    r: u32 = x & c;        // 0x0F = 15
    return r;
}
