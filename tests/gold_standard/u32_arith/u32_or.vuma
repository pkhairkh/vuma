// u32_or — u32 OR: 0xF0 | 0x0F
// Expected exit code: 255
//
// 0xF0 | 0x0F = 0xFF = 255. Uses variables for both operands because VUMA
// may drop bitwise ops with immediate RHS.

fn main() -> i32 {
    a: u32 = 240;     // 0xF0
    b: u32 = 15;      // 0x0F
    result: u32 = a | b;
    return result;
}
