// s70_u32_or_then_and.vuma — (0xF4 | 0x36) & 0x24 = 0xF6 & 0x24 = 0x24 = 36
// Expected exit code: 36
//
// Two-stage bitwise: OR then AND. (244 | 54) = 246 (0xF6);
// 246 & 36 = 36 (0x24). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_u32_or_then_and (24), s65_u32_and_then_or (195) and
// s62_u32_and_then_xor (90).
fn main() -> i32 {
    a: u32 = 244;          // 0xF4
    b: u32 = 54;           // 0x36
    c: u32 = 36;           // 0x24
    x: u32 = a | b;        // 0xF6 = 246
    r: u32 = x & c;        // 0x24 = 36
    return r;
}
