// s45_u32_xor_then_and.vuma — (0xCC ^ 0x33) & 0x0F = 0xFF & 0x0F = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: XOR then AND. (204 ^ 51) = 255 (0xFF);
// 255 & 15 = 15 (0x0F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_u32_xor_then_or (xor-then-or, 255) and s34_u32_xor_then_and.

fn main() -> i32 {
    a: u32 = 204;          // 0xCC
    b: u32 = 51;           // 0x33
    c: u32 = 15;           // 0x0F
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0x0F = 15
    return r;
}
