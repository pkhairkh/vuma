// s103_u32_shl_then_or.vuma — (0x01 << 3) | 0x10 = 0x08 | 0x10 = 0x18 = 24
// Expected exit code: 24
//
// Two-stage bitwise: shift-left then OR. (1 << 3) = 8 (0x08); 8 | 16 = 24 (0x18). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s100_u32_shl_then_or (29).
fn main() -> i32 {
    a: u32 = 1;           // 0x01
    b: u32 = 3;
    c: u32 = 16;          // 0x10
    x: u32 = a << b;      // 0x08 = 8
    r: u32 = x | c;       // 0x18 = 24
    return r;
}
