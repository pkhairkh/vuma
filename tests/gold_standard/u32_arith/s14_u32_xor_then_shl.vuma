// s14_u32_xor_then_shl.vuma — (0x33 ^ 0x0C) << 2 = 0x3F << 2 = 0xFC = 252
// Expected exit code: 252
//
// XOR-then-shift-left. (51 ^ 12) = 63 (0x3F); 63 << 2 = 252 (0xFC).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s9_u32_and_mask
// (single AND) and s10_u32_shl_then_xor (shift-then-XOR).

fn main() -> i32 {
    a: u32 = 51;          // 0x33
    b: u32 = 12;          // 0x0C
    sh: u32 = 2;
    x: u32 = a ^ b;       // 0x3F = 63
    r: u32 = x << sh;     // 0xFC = 252
    return r;
}
