// s90_u32_shl_then_xor.vuma — (8 << 3) ^ 0x0A = 0x40 ^ 0x0A = 0x4A = 74
// Expected exit code: 74
//
// Two-stage bitwise: shift-left then XOR. 8 << 3 = 64 (0x40);
// 64 ^ 10 = 74 (0x4A). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_u32_shl_then_or (52), s82_u32_shl_then_or (50) and
// s78_u32_shl_then_or (4).
fn main() -> i32 {
    a: u32 = 8;
    b: u32 = 3;
    c: u32 = 10;           // 0x0A
    x: u32 = a << b;       // 0x40 = 64
    r: u32 = x ^ c;        // 0x4A = 74
    return r;
}
