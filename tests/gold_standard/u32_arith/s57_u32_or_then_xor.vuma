// s57_u32_or_then_xor.vuma — (128 | 64) ^ 85 = 192 ^ 85 = 149
// Expected exit code: 149
//
// Two-stage u32 bitwise: OR then XOR. 128 | 64 = 192 (0xC0);
// 192 ^ 85 = 149 (0x95). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_u32_xor_then_or (255) and s50_u32_or_then_xor (200).

fn main() -> i32 {
    a: u32 = 128;
    b: u32 = 64;
    c: u32 = 85;
    x: u32 = a | b;        // 192
    r: u32 = x ^ c;        // 149
    return r;
}
