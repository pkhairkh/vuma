// s15_u32_shl_then_or.vuma — ((0x05 << 4) | 0x0A) = 0x5A = 90
// Expected exit code: 90
//
// Shift-left-then-OR. (5 << 4) = 80 (0x50); 80 | 10 = 90 (0x5A). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s14_u32_or_then_xor (OR-then-XOR) and
// s13_u32_shl_then_add (shift-then-add).

fn main() -> i32 {
    a: u32 = 5;           // 0x05
    sh: u32 = 4;
    b: u32 = 10;          // 0x0A
    x: u32 = a << sh;     // 0x50 = 80
    r: u32 = x | b;       // 0x5A = 90
    return r;
}
