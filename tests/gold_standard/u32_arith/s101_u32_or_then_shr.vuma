// s101_u32_or_then_shr.vuma — (0x80 | 0x40) >> 2 = 0xC0 >> 2 = 0x30 = 48
// Expected exit code: 48
//
// Two-stage bitwise on u32: OR then shift-right. (128 | 64) = 192
// (0xC0); 192 >> 2 = 48 (0x30). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s98_u32_xor_then_shl (88), s97_u32_xor_then_shr
// (17) and s94_u32_or_then_xor (243).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 64;           // 0x40
    s: u32 = 2;
    x: u32 = a | b;        // 0xC0 = 192
    r: u32 = x >> s;       // 0x30 = 48
    return r;
}
