// s46_u32_and_then_or.vuma — (0xF0 & 0x30) | 0x0F = 0x30 | 0x0F = 0x3F = 63
// Expected exit code: 63
//
// Two-stage bitwise: AND then OR. (240 & 48) = 48 (0x30); 48 | 15 =
// 63 (0x3F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s42_
// u32_xor_then_or (255) and s38_u32_and_then_or.

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 48;           // 0x30
    c: u32 = 15;           // 0x0F
    m: u32 = a & b;        // 0x30 = 48
    r: u32 = m | c;        // 0x3F = 63
    return r;
}
