// s29_u32_add_then_or.vuma — (100 + 50) | 0x05 = 150 | 5 = 0x97 = 151
// Expected exit code: 151
//
// Add then OR. 100 + 50 = 150 (0x96); 150 | 5 = 151 (0x97). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Distinct from s26_u32_add_then_and (add-then-and, 44) and s22_u32_add_then_xor (add-then-xor).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 50;
    c: u32 = 5;           // 0x05
    s: u32 = a + b;       // 150 = 0x96
    r: u32 = s | c;       // 0x97 = 151
    return r;
}
