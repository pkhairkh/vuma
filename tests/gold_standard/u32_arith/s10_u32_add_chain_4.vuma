// s10_u32_add_chain_4.vuma — 10 + 20 + 30 + 40 = 100
// Expected exit code: 100
//
// Four-way u32 sum built via chained intermediates. Distinct from
// s4_u32_add_three (three-way sum) and s6_u32_add_pair (two-way sum).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 30;
    d: u32 = 40;
    t1: u32 = a + b;      // 30
    t2: u32 = t1 + c;     // 60
    r: u32 = t2 + d;      // 100
    return r;
}
