// s47_u32_xor_then_or.vuma — (0xC3 ^ 0x3C) | 0x0F = 0xFF | 0x0F = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then OR. (195 ^ 60) = 255 (0xFF);
// 255 | 15 = 255. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s46_
// u32_xor_then_shr (127) and s42_u32_xor_then_or (255, same total
// but different addends).

fn main() -> i32 {
    a: u32 = 195;          // 0xC3
    b: u32 = 60;           // 0x3C
    c: u32 = 15;           // 0x0F
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x | c;        // 0xFF = 255
    return r;
}
