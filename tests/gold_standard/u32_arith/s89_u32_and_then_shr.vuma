// s89_u32_and_then_shr.vuma — (184 & 0xFF) >> 1 = 184 >> 1 = 92
// Expected exit code: 92
//
// Two-stage bitwise: AND then shift right. (184 & 0xFF) = 184;
// 184 >> 1 = 92. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_u32_and_then_shr (180), s82_u32_and_then_shr (76) and
// s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 184;
    m: u32 = 255;          // 0xFF
    s: u32 = 1;
    x: u32 = a & m;        // 184
    r: u32 = x >> s;       // 92
    return r;
}
