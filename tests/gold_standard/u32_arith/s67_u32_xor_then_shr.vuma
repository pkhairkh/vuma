// s67_u32_xor_then_shr.vuma — (0x55 ^ 0xAA) >> 4 = 0xFF >> 4 = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: XOR then shift right. (85 ^ 170) = 255
// (0xFF); 255 >> 4 = 15 (0x0F). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_u32_shr_then_xor (55), s62_u32_xor_then_
// or (252) and s58_u32_xor_then_and (255).
fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 170;          // 0xAA
    c: u32 = 4;
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x >> c;       // 0x0F = 15
    return r;
}
