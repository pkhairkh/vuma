// s84_u32_xor_then_and.vuma — (0x55 ^ 0x12) & 0x47 = 0x47 & 0x47 = 0x47 = 71
// Expected exit code: 71
//
// Two-stage bitwise: XOR then AND. (85 ^ 18) = 71 (0x47);
// 71 & 71 = 71 (0x47). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s82_u32_xor_then_shr (45), s78_u32_and_then_xor (1)
// and s72_u32_xor_then_and (10).
fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 18;           // 0x12
    c: u32 = 71;           // 0x47
    x: u32 = a ^ b;        // 0x47 = 71
    r: u32 = x & c;        // 0x47 = 71
    return r;
}
