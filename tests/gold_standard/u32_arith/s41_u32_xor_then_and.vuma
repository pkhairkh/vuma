// s41_u32_xor_then_and.vuma - (0xAA ^ 0x0F) & 0xF0 = 0xA5 & 0xF0 = 0xA0 = 160
// Expected exit code: 160
//
// Two-stage bitwise: XOR then AND. (170 ^ 15) = 165 (0xA5); 165 &
// 240 = 160 (0xA0). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_and_then_or (202) and s34_u32_xor_then_and (170).

fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 15;           // 0x0F
    c: u32 = 240;          // 0xF0
    x: u32 = a ^ b;        // 0xA5 = 165
    r: u32 = x & c;        // 0xA0 = 160
    return r;
}
