// s92_u32_xor_then_or.vuma — (0xF0 ^ 0x3C) | 0x03 = 0xCC | 0x03 = 0xCF = 207
// Expected exit code: 207
//
// Two-stage bitwise: XOR then OR. (240 ^ 60) = 204 (0xCC);
// 204 | 3 = 207 (0xCF). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_xor_then_or (58), s86_u32_xor_then_and (51) and
// s82_u32_xor_then_shr (45).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 60;           // 0x3C
    c: u32 = 3;            // 0x03
    x: u32 = a ^ b;        // 0xCC = 204
    r: u32 = x | c;        // 0xCF = 207
    return r;
}
