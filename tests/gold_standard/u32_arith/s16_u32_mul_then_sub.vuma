// s16_u32_mul_then_sub.vuma — 12 * 5 - 4 = 56
// Expected exit code: 56
//
// Multiply then subtract. 12 * 5 = 60; 60 - 4 = 56. All operands loaded
// into u32 variables first. Distinct from s13_u32_mul_then_sub (different
// operands) and s8_u32_mul_sub (different operands).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 5;
    c: u32 = 4;
    p: u32 = a * b;       // 60
    r: u32 = p - c;       // 56
    return r;
}
