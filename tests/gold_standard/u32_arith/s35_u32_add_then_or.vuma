// s35_u32_add_then_or.vuma — (60 + 40) | 0x05 = 100 | 5 = 101
// Expected exit code: 101
//
// Two-stage computation: add then OR. (60 + 40) = 100 (0x64);
// 100 | 5 = 101 (0x65). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_u32_add_then_xor (add-then-xor, 153) and s30_u32_add_then_
// shr (add-then-shr).

fn main() -> i32 {
    a: u32 = 60;
    b: u32 = 40;
    c: u32 = 5;            // 0x05
    s: u32 = a + b;        // 100 = 0x64
    r: u32 = s | c;        // 0x65 = 101
    return r;
}
