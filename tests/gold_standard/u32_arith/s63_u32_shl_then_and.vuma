// s63_u32_shl_then_and.vuma — (1 << 4) & 0x1F = 16 & 0x1F = 16
// Expected exit code: 16
//
// Two-stage bitwise: shift left then AND. (1 << 4) = 16 (0x10);
// 16 & 31 = 16 (0x10). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32
// _xor_then_shl (204), s58_u32_xor_then_and (255) and s55_u32_or_
// then_and (204).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 31;           // 0x1F
    x: u32 = a << b;       // 0x10 = 16
    r: u32 = x & c;        // 0x10 = 16
    return r;
}
