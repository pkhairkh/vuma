// s96_u32_xor_then_and.vuma — (0x77 ^ 0x33) & 0x55 = 0x44 & 0x55 = 0x44 = 68
// Expected exit code: 68
//
// Two-stage bitwise: XOR then AND. (119 ^ 51) = 68 (0x44);
// 68 & 85 = 68 (0x44). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_and_then_or (106), s90_u32_xor_then_or (58) and
// s86_u32_xor_then_and (51).
fn main() -> i32 {
    a: u32 = 119;          // 0x77
    b: u32 = 51;           // 0x33
    c: u32 = 85;           // 0x55
    x: u32 = a ^ b;        // 0x44 = 68
    r: u32 = x & c;        // 0x44 = 68
    return r;
}
