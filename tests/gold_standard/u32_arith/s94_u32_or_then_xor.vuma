// s94_u32_or_then_xor.vuma — (0x80 | 0x40) ^ 0x33 = 0xC0 ^ 0x33 = 0xF3 = 243
// Expected exit code: 243
//
// Two-stage bitwise: OR then XOR. (128 | 64) = 192 (0xC0);
// 192 ^ 51 = 243 (0xF3). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_and_then_shr (75), s86_u32_shl_then_or (83) and
// s82_u32_or_then_and (15).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 64;           // 0x40
    c: u32 = 51;           // 0x33
    x: u32 = a | b;        // 0xC0 = 192
    r: u32 = x ^ c;        // 0xF3 = 243
    return r;
}
