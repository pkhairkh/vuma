// s24_u32_add_then_xor.vuma — (50 + 70) ^ 0x0F = 120 ^ 0x0F = 0x78 ^ 0x0F = 0x77 = 119
// Expected exit code: 119
//
// Add then XOR. 50 + 70 = 120 (0x78); 120 ^ 15 = 119 (0x77). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_u32_sub_then_xor (sub-then-xor,
// value 153) and s18_u32_add_xor_chain (add-then-xor chain).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 70;
    c: u32 = 15;          // 0x0F
    s: u32 = a + b;       // 120 = 0x78
    r: u32 = s ^ c;       // 0x77 = 119
    return r;
}
