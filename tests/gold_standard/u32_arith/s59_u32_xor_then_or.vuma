// s59_u32_xor_then_or.vuma — (0xA5 ^ 0x38) | 0x40 = 0x9D | 0x40 = 0xDD = 221
// Expected exit code: 221
//
// Two-stage bitwise: XOR then OR. (165 ^ 56) = 157 (0x9D); 157 | 64 =
// 221 (0xDD). All operands loaded into u32 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s58_u32_xor_then_and
// (255), s58_u32_or_then_xor (207) and s58_u32_and_then_shr (60).

fn main() -> i32 {
    a: u32 = 165;          // 0xA5
    b: u32 = 56;           // 0x38
    c: u32 = 64;           // 0x40
    x: u32 = a ^ b;        // 0x9D = 157
    r: u32 = x | c;        // 0xDD = 221
    return r;
}
