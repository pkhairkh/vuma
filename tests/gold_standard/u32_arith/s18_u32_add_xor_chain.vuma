// s18_u32_add_xor_chain.vuma — (10 + 20) ^ 5 = 30 ^ 5 = 27
// Expected exit code: 27
//
// Add-then-XOR. (10 + 20) = 30; 30 ^ 5 = 27. All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s11_u32_add_sub_chain (add-sub chain) and
// s12_u32_add_then_xor (different operands 20+10 then ^7 = 17).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 5;
    p: u32 = a + b;       // 30
    r: u32 = p ^ c;       // 27
    return r;
}
