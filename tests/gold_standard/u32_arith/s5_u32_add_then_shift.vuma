// s5_u32_add_then_shift.vuma — (50 + 30) << 1 = 80 << 1 = 160
// Expected exit code: 160
//
// Addition first (50 + 30 = 80), then shift left by 1 -> 160. The
// shift amount is loaded into a variable to dodge the immediate-RHS
// bitwise drop bug. Distinct from s4_u32_shift_add (shift first).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 30;
    sh: u32 = 1;
    sum: u32 = a + b;     // 80
    r: u32 = sum << sh;   // 160
    return r;
}
