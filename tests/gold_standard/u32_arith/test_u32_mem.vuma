// Test: u32 store/load through pointers (like SHA256d)
// Expected: exit 79
// Expected exit code: 79

fn write_u32(buf: Address, offset: u64, val: u32) {
    *(buf + offset) = (val >> 24) & 255;
    *(buf + offset + 1) = (val >> 16) & 255;
    *(buf + offset + 2) = (val >> 8) & 255;
    *(buf + offset + 3) = val & 255;
}

fn read_u32(buf: Address, offset: u64) -> u32 {
    b0: u32 = *(buf + offset);
    b1: u32 = *(buf + offset + 1);
    b2: u32 = *(buf + offset + 2);
    b3: u32 = *(buf + offset + 3);
    return ((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) & 4294967295;
}

fn rotr32(x: u32, n: u32) -> u32 {
    return ((x >> n) | (x << (32 - n))) & 4294967295;
}

fn main() -> u64 {
    // Allocate a buffer and store/load u32 values
    buf = allocate(16);

    // Store 0x4F000000 at offset 0
    write_u32(buf, 0, 0x4F000000);
    
    // Read it back
    val: u32 = read_u32(buf, 0);
    
    // Rotate right by 24: rotr(0x4F000000, 24) = 0xF000004F
    rotated: u32 = rotr32(val, 24);
    
    // Return low byte
    result: u32 = rotated & 0xFF;
    return result;
}
