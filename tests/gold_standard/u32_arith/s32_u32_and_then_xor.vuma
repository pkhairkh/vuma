// s32_u32_and_then_xor.vuma - (0xCC & 0xF0) ^ 0x0F = 0xC0 ^ 0x0F = 0xCF = 207
// Expected exit code: 207
//
// (0xCC & 0xF0) ^ 0x0F = 0xC0 ^ 0x0F = 0xCF = 207. All operands loaded into
// typed variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from
// s30_u32_and_then_add (and-then-add) and s26_u32_add_then_and (add-then-
// and).

fn main() -> i32 {
    a: u32 = 204;          // 0xCC
    b: u32 = 240;          // 0xF0
    c: u32 = 15;           // 0x0F
    x: u32 = a & b;        // 0xC0 = 192
    r: u32 = x ^ c;        // 0xCF = 207
    return r;
}
