// s52_u32_shl_then_or.vuma — (1 << 4) | 0x40 = 0x10 | 0x40 = 0x50 = 80
// Expected exit code: 80
//
// Two-stage bitwise: shift left then OR. 1 << 4 = 16 (0x10);
// 16 | 64 = 80 (0x50). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_u32_shl_then_or (31) and s46_u32_shl_then_and (192).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 64;           // 0x40
    x: u32 = a << b;       // 0x10 = 16
    r: u32 = x | c;        // 0x50 = 80
    return r;
}
