// s80_u32_shl_then_or.vuma — (0x00 << 0) | 0x2A = 0x00 | 0x2A = 0x2A = 42
// Expected exit code: 42
//
// Two-stage bitwise: shift left then OR. (0 << 0) = 0
// (0x00); 0 | 42 = 42 (0x2A). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_u32_shl_then_or (2),
// s74_u32_or_then_shl (96) and s73_u32_xor_then_and (98).
fn main() -> i32 {
    a: u32 = 0;           // 0x00
    b: u32 = 0;
    c: u32 = 42;          // 0x2A
    x: u32 = a << b;       // 0x00 = 0
    r: u32 = x | c;        // 0x2A = 42
    return r;
}
