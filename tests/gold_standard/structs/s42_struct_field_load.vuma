// s42_struct_field_load.vuma — store 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as one struct instance. Store
// 175 via `*p = literal`, load and return 175. Uses `*p = literal`
// form. Distinct from s38_struct_field_load (165) and s34_struct_
// field_load (175, same total but different operand 165).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 175;
    a: u64 = *p1;
    free(p1);
    return a;
}
