// struct_partial_init.vuma — only some fields initialized, load uninitialized
// Expected exit code: 0
//
// Allocates a 2-field struct (16 bytes). Stores 42 only in field 0
// (offset 0). Loads field 1 (offset 8), which was never written.
// Returns the loaded value. Fresh mmap'd memory is zero-initialized,
// so the uninitialized field reads as 0.

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 42;
    // Field 1 (offset 8) was never written — should be 0
    val: u64 = *(p + 8);
    free(p);
    return val;
}
