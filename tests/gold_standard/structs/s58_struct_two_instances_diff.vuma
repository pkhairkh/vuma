// s58_struct_two_instances_diff.vuma — two instances, diff = 110 (200 - 90)
// Expected exit code: 110
// 
// Two 8-byte allocations treated as two independent struct
// instances. Store 200/90 via `*p = literal`, load both fields,
// subtract -> 110. Uses `*p = literal` form (no offsets). Distinct
// from s51_struct_two_instances_sum (210), s51_struct_field_load
// (178) and s51_struct_overwrite_field (200).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 90;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 110
    free(p1);
    free(p2);
    return d;
}
