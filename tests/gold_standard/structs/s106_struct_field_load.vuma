// s106_struct_field_load.vuma — store 13, load = 13
// Expected exit code: 13
//
// Single 8-byte struct allocation. Store 13 via `*p = literal`, load and return 13. Uses `*p = literal` form. Straight-line code only.
// Distinct from s102_struct_field_load (5), s101_struct_field_load (71), s100_struct_field_load (8).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 13;
    v: u64 = *p;           // 13
    free(p);
    return v;
}
