// s26_struct_two_instances_xor.vuma — two instances, xor = 102 (0x55 ^ 0x33)
// Expected exit code: 102
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 0x55/0x33 via `*p = literal`, load both, XOR -> 102. Uses `*p =
// literal` form (no offsets). All operands loaded into typed locals
// before the XOR. Distinct from s22_struct_two_instances_sum (44+56=100)
// and s18_struct_two_instances_sum (26+48=74).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 85;            // 0x55
    *p2 = 51;            // 0x33
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 ^ a2;     // 0x66 = 102
    free(p1);
    free(p2);
    return s;
}
