// struct_multiple.vuma — 3 structs with values 1, 2, 3, return sum
// Expected exit code: 6
//
// Allocates three separate single-field structs holding 1, 2, and 3
// respectively. Loads all three and sums them: 1 + 2 + 3 = 6.

fn main() -> i32 {
    s1 = allocate(8);
    s2 = allocate(8);
    s3 = allocate(8);
    *(s1 + 0) = 1;
    *(s2 + 0) = 2;
    *(s3 + 0) = 3;
    v1: u64 = *(s1 + 0);
    v2: u64 = *(s2 + 0);
    v3: u64 = *(s3 + 0);
    sum: u64 = v1 + v2 + v3;
    free(s1);
    free(s2);
    free(s3);
    return sum;
}
