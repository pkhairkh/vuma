// s70_struct_overwrite_field.vuma — overwrite field to 155, load = 155
// Expected exit code: 155
//
// Single 8-byte allocation treated as a one-field struct. Store
// 50 then 155 via `*p = literal` (overwrite), load and return
// 155. Uses `*p = literal` form (no offsets). Distinct from
// s66_struct_overwrite_field (245), s65_struct_overwrite_field
// (218) and s62_struct_overwrite_field (225).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 50;
    *p = 155;
    a: u64 = *p;           // 155
    free(p);
    return a;
}
