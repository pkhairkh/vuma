// s72_struct_field_load.vuma — store 195, load = 195
// Expected exit code: 195
//
// Single 8-byte allocation treated as a one-field struct. Store
// 195 via `*p = literal`, load the field, return 195. Uses `*p
// = literal` form (no offsets). Distinct from s70_struct_field_
// load (95), s69_struct_field_load (190) and s66_struct_field_
// load (205).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 195;
    a: u64 = *p;
    free(p);
    return a;
}
