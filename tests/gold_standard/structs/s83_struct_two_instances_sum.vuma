// s83_struct_two_instances_sum.vuma — two instances, sum = 236 (120 + 116)
// Expected exit code: 236
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 120/116 via `*p = literal`, load both fields,
// sum -> 236. Uses `*p = literal` form (no offsets). Distinct
// from s78_struct_two_instances_sum (3), s74_struct_two_instances_
// sum (137) and s72_struct_two_instances_sum (175).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 120;
    *p2 = 116;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 236
    free(p1);
    free(p2);
    return s;
}
