// s87_struct_overwrite_field.vuma — store 1, overwrite with 205, load = 205
// Expected exit code: 205
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 1 via `*p = literal`, overwrite with 205 via `*p =
// literal`, load the field, return 205. Uses `*p = literal` form
// (no offsets). Distinct from s86_struct_overwrite_field (220),
// s82_struct_overwrite_field (210) and s78_struct_overwrite_field
// (2).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 1;
    *p1 = 205;
    a: u64 = *p1;
    free(p1);
    return a;
}
