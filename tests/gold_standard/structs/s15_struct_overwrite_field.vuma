// s15_struct_overwrite_field.vuma — overwrite single field, final = 144
// Expected exit code: 144
//
// 8-byte allocation treated as a one-field struct. Store 12 via `*p = 12`,
// then overwrite with 144 via `*p = 144` (literal overwrite, last write
// wins). Load and return 144. Uses `*p = literal` form (no offsets).
// Distinct from s14_struct_overwrite_field (9 then 81) and
// s13_struct_overwrite_field (different values).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 12;
    *p = 144;
    a: u64 = *p;
    free(p);
    return a;
}
