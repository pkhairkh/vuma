// struct_swap_fields.vuma — swap two struct fields using a temp variable
// Expected exit code: 1
//
// Allocates a 2-field struct with a=1 (offset 0) and b=2 (offset 8).
// Swaps the two fields using a scalar temp: tmp=a; a=b; b=tmp.
// After the swap, a=2 and b=1. Returns b (the new value at offset 8,
// which is the original a = 1).

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 1;
    *(p + 8) = 2;
    // Swap using temp
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    tmp: u64 = a;
    *(p + 0) = b;
    *(p + 8) = tmp;
    // Return new b (which is original a = 1)
    val: u64 = *(p + 8);
    free(p);
    return val;
}
