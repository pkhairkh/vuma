// s34_struct_field_load.vuma — store 198, load = 198
// Expected exit code: 198
//
// Single 8-byte allocation treated as a one-field struct. Store
// 198 via `*p = literal`, load and return 198. Uses `*p =
// literal` form (no offsets). Distinct from s30_struct_field_load
// (168) and s27_struct_field_load (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 198;
    a: u64 = *p1;
    free(p1);
    return a;
}
