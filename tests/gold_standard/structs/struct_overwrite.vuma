// struct_overwrite.vuma — overwrite a field and load the new value
// Expected exit code: 99
//
// Allocates a single-field struct, stores 42, then overwrites with 99.
// The load returns the latest written value (99), confirming that
// stores to the same offset replace (not accumulate with) prior stores.

fn main() -> i32 {
    p = allocate(8);
    *(p + 0) = 42;
    *(p + 0) = 99;
    val: u64 = *(p + 0);
    free(p);
    return val;
}
