// s97_struct_overwrite_field.vuma — overwrite field to 9, load = 9
// Expected exit code: 9
//
// Single 8-byte struct allocation. Store 5 via `*p =
// literal`, then overwrite to 9, load -> 9 (the overwritten
// value). Uses `*p = literal` form.
// Distinct from s94_struct_overwrite_field (92), s90_struct_overwrite_field (47), s86_struct_overwrite_field (220).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 9;
    v: u64 = *p;           // 9
    free(p);
    return v;
}
