// s48_struct_two_instances_sum.vuma — two instances, sum = 250 (90 + 160)
// Expected exit code: 250
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 90/160 via `*p = literal`, load both fields, sum -> 250.
// Uses `*p = literal` form (no offsets). Distinct from s46_struct_
// two_instances_diff (140) and s42_struct_two_instances_sum (205).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 160;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 250
    free(p1);
    free(p2);
    return s;
}
