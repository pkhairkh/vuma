// s34_struct_two_instances_sum.vuma — two instances, sum = 205 (90 + 115)
// Expected exit code: 205
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 90/115 via `*p = literal`, load both fields,
// sum -> 205. Uses `*p = literal` form (no offsets). Distinct from
// s30_struct_two_instances_sum (180) and s27_struct_two_instances_
// diff (different op).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 115;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
