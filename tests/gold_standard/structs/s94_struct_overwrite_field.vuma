// s94_struct_overwrite_field.vuma — overwrite field to 92, load = 92
// Expected exit code: 92
//
// Single 8-byte struct allocation. Store 5 via `*p = literal`, then
// overwrite to 92, load -> 92 (the overwritten value). Uses
// `*p = literal` form. Distinct from s90_struct_overwrite_field
// (47), s86_struct_overwrite_field (220) and s82_struct_overwrite_
// field (210).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 92;
    v: u64 = *p;           // 92
    free(p);
    return v;
}
