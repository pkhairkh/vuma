// s78_struct_two_instances_sum.vuma — two instances, sum = 3 (1 + 2)
// Expected exit code: 3
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 1/2 via `*p = literal`, load both fields,
// sum -> 3. Uses `*p = literal` form (no offsets). Distinct from
// s74_struct_two_instances_sum (137), s73_struct_two_instances_sum
// (114) and s72_struct_two_instances_sum (175).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 1;
    *p2 = 2;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 3
    free(p1);
    free(p2);
    return s;
}
