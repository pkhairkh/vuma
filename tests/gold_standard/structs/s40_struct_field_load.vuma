// s40_struct_field_load.vuma — store 250, load = 250
// Expected exit code: 250
//
// Single 8-byte allocation treated as a one-field struct. Store
// 250 via `*p = literal`, load and return 250. Uses `*p = literal`
// form (no offsets). Distinct from s38_struct_field_load (215) and
// s34_struct_field_load (198).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 250;
    a: u64 = *p1;
    free(p1);
    return a;
}
