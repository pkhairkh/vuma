// s71_struct_field_load.vuma — store 137, load 137
// Expected exit code: 137
//
// Single 8-byte allocation treated as one struct instance. Store
// 137 via `*p = literal`, load and return 137. Uses `*p = literal`
// form (no offsets). Distinct from s69_struct_field_load (185),
// s70_struct_field_load (230) and s66_struct_field_load (200).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 137;
    v: u64 = *p1;          // 137
    free(p1);
    return v;
}
