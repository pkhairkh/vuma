// s12_struct_field_load.vuma — single-field struct, load field = 95
// Expected exit code: 95
//
// 8-byte allocation treated as a one-field struct. Store 95 via
// `*p = 95`, load it back, return 95. Uses `*p = literal` form
// (no offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s9_struct_field_load (value 33) and s13_struct_field_load (value 64).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 95;
    v: u64 = *p;
    free(p);
    return v;
}
