// s37_struct_field_load.vuma — store 230, load = 230
// Expected exit code: 230
//
// Deterministic test in the structs category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_struct_field_load (value 178) and s30_struct_field_load (value 168).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 230;
    a: u64 = *p1;
    free(p1);
    return a;
}
