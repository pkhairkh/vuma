// struct2_func_store.vuma — function stores 42 in struct via Address param
// Expected exit code: 42
//
// main allocates a 16-byte struct and passes its Address to a helper
// function. The helper stores the literal 42 at offset 0 via *p and
// returns. main then loads the field back. Uses *p (not *(p + 0))
// inside the function because VUMA drops stores through offset
// addressing inside functions.

struct Point {
    x: u64,
    y: u64,
}

fn store_42(p: Address) -> i32 {
    *p = 42;
    return 0;
}

fn main() -> i32 {
    p = allocate(16);
    store_42(p);
    val: u64 = *p;
    free(p);
    return val;
}
