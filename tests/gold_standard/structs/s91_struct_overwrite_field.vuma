// s91_struct_overwrite_field.vuma — overwrite field to 49, load = 49
// Expected exit code: 49
//
// Single 8-byte struct allocation. Store 5 via `*p = literal`, then
// overwrite to 49, load -> 49 (the overwritten value). Uses
// `*p = literal` form. Distinct from s90_struct_overwrite_field
// (47), s86_struct_overwrite_field (245) and s82_struct_overwrite_
// field (242).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 49;
    v: u64 = *p;           // 49
    free(p);
    return v;
}
