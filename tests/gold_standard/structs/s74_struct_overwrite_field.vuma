// s74_struct_overwrite_field.vuma — overwrite field to 69, load = 69
// Expected exit code: 69
//
// Single 8-byte allocation treated as a one-field struct. Store
// 100 then 69 via `*p = literal` (overwrite), load and return
// 69. Uses `*p = literal` form (no offsets). Distinct from
// s70_struct_overwrite_field (155), s66_struct_overwrite_field
// (245) and s62_struct_overwrite_field (225).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 100;
    *p = 69;
    a: u64 = *p;           // 69
    free(p);
    return a;
}
