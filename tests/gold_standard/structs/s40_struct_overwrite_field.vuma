// s40_struct_overwrite_field.vuma — overwrite field, load = 220
// Expected exit code: 220
//
// Single 8-byte allocation treated as a one-field struct. Store 30,
// then overwrite the field with 220 via `*p = literal`. Load and
// return 220. Uses `*p = literal` form (no offsets). Distinct from
// s38_struct_overwrite_field (245) and s34_struct_overwrite_field
// (230).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 30;
    *p1 = 220;
    a: u64 = *p1;
    free(p1);
    return a;
}
