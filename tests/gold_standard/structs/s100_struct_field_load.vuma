// s100_struct_field_load.vuma — store 8, load = 8
// Expected exit code: 8
//
// Single 8-byte struct allocation. Store 8 via `*p =
// literal`, load and return 8. Uses `*p = literal` form.
// Distinct from s97_struct_field_load (4), s94_struct_field_load (63), s90_struct_field_load (52).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: u64 = *p;           // 8
    free(p);
    return v;
}
