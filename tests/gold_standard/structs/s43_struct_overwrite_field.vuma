// s43_struct_overwrite_field.vuma — overwrite 80 -> 170, load 170
// Expected exit code: 170
//
// Single 8-byte struct instance. Store 80 via `*p = literal`, then
// overwrite to 170 via `*p = literal`, load and return 170. Uses
// `*p = literal` form. Distinct from s42_struct_overwrite_field
// (190) and s38_struct_overwrite_field (180).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 80;
    *p1 = 170;
    v: u64 = *p1;          // 170
    free(p1);
    return v;
}
