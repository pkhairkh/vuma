// s69_struct_overwrite_field.vuma -- overwrite field to 145, load = 145
// Expected exit code: 145
//
// Single 8-byte allocation treated as a one-field struct. Store 60
// then 145 via `*p = literal` (overwrite), load and return 145. Uses
// `*p = literal` form (no offsets). Distinct from s66_struct_
// overwrite_field (245), s65_struct_overwrite_field (218) and s64_
// struct_overwrite_field (245).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 60;
    *p = 145;
    a: u64 = *p;           // 145
    free(p);
    return a;
}
