// struct2_point_y.vuma — Point{x=10, y=20}, return y
// Expected exit code: 20
//
// Allocates a Point {x: u64, y: u64} struct (16 bytes), stores x=10 at
// offset 0 and y=20 at offset 8 via *(p + N), then loads y and returns
// it. Verifies struct field access at offset 8 (second u64 field).

struct Point {
    x: u64,
    y: u64,
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 10;
    *(p + 8) = 20;
    y: u64 = *(p + 8);
    free(p);
    return y;
}
