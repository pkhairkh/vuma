// s48_struct_field_load.vuma — store 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as one struct instance. Store 175
// via `*p = literal`, load and return 175. Uses `*ptr = literal`
// form. Distinct from s46_struct_field_load (185) and s42_struct_
// field_load (175, same value, different prefix).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 175;
    a: u64 = *p1;
    free(p1);
    return a;
}
