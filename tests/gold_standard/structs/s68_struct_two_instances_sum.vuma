// s68_struct_two_instances_sum.vuma — two instances, sum = 160 (105 + 55)
// Expected exit code: 160
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 105/55 via `*p = literal`, load both fields,
// sum -> 160. Uses `*p = literal` form (no offsets). Distinct
// from s66_struct_two_instances_diff (130), s62_struct_two_
// instances_sum (230) and s58_struct_two_instances_diff (110).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 105;
    *p2 = 55;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 160
    free(p1);
    free(p2);
    return s;
}
