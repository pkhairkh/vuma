// struct2_func_load.vuma — main stores 42 in struct; function loads and returns
// Expected exit code: 42
//
// main allocates a 16-byte struct, stores the literal 42 at offset 0
// via *p, then passes the Address to a helper that loads the field
// back and returns it. main frees the struct and returns the helper's
// result. Verifies that a caller-side struct store is visible inside a
// callee through a passed-in Address.

struct Point {
    x: u64,
    y: u64,
}

fn load_val(p: Address) -> u64 {
    v: u64 = *p;
    return v;
}

fn main() -> i32 {
    p = allocate(16);
    *p = 42;
    val: u64 = load_val(p);
    free(p);
    return val;
}
