// s4_struct_overwrite_field.vuma — store x=10, overwrite with x=77, return
// Expected exit code: 77
//
// Allocates a 16-byte struct, stores 10 in x (offset 0), then
// overwrites x with 77, reads x back, returns 77. Verifies that
// field overwrites work correctly.

struct Point {
    x: u64,
    y: u64,
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 10;
    *(p + 0) = 77;
    x: u64 = *(p + 0);
    free(p);
    return x;
}
