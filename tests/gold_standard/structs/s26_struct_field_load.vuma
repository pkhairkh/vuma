// s26_struct_field_load.vuma — store 222, load = 222
// Expected exit code: 222
//
// Single 8-byte allocation treated as a one-field struct. Store the
// literal 222 via `*p = literal`, load it back, return. Uses `*p =
// literal` form (no offsets). Distinct from s22_struct_field_load
// (different value) and s18_struct_field_load (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 222;
    a: u64 = *p1;
    free(p1);
    return a;
}
