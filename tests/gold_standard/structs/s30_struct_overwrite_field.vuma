// s30_struct_overwrite_field.vuma — overwrite field, load = 220
// Expected exit code: 220
//
// Single 8-byte allocation treated as a one-field struct. Store 40, then
// overwrite the field with 220 via `*p = literal`. Load and return 220.
// Uses `*p = literal` form (no offsets). Distinct from
// s26_struct_overwrite_field (different value) and
// s22_struct_overwrite_field (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 40;
    *p1 = 220;
    a: u64 = *p1;
    free(p1);
    return a;
}
