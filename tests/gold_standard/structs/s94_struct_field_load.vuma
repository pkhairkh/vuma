// s94_struct_field_load.vuma — store 63, load = 63
// Expected exit code: 63
//
// Single 8-byte struct allocation. Store 63 via `*p = literal`,
// load and return 63. Uses `*p = literal` form. Distinct from
// s90_struct_field_load (52), s86_struct_field_load (145) and
// s82_struct_field_load (25).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 63;
    v: u64 = *p;           // 63
    free(p);
    return v;
}
