// s71_struct_two_instances_sum.vuma — two instances, sum = 195 (125 + 70)
// Expected exit code: 195
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 125/70 via `*p = literal`, load both fields,
// sum -> 195. Uses `*p = literal` form (no offsets). Distinct
// from s69_struct_two_instances_sum (190), s70_struct_two_
// instances_sum (250) and s66_struct_two_instances_diff (130).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 125;
    *p2 = 70;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 195
    free(p1);
    free(p2);
    return s;
}
