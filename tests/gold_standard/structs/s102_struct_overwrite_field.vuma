// s102_struct_overwrite_field.vuma — overwrite to 6, load = 6
// Expected exit code: 6
//
// Single 8-byte struct allocation. Store 10, then overwrite to 6, load and return 6 (the overwritten value). Uses `*p = literal` form. Straight-line code only.
// Distinct from s101_struct_field_load (71), s101_struct_overwrite_field (19), s101_struct_two_instances_sum (205).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    *p = 6;
    v: u64 = *p;           // 6
    free(p);
    return v;
}
