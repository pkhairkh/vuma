// s64_struct_field_load.vuma — store 177, load = 177
// Expected exit code: 177
//
// Single 8-byte allocation treated as a one-field struct. Store 177
// via `*p = literal`, load the field, return 177. Uses `*p =
// literal` form (no offsets). Distinct from s62_struct_field_load
// (182), s62_struct_overwrite_field (225) and s62_struct_two_instances_
// sum (230).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 177;
    a: u64 = *p;
    free(p);
    return a;
}
