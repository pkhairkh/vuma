// s14_struct_overwrite_field.vuma — overwrite single field, final = 81
// Expected exit code: 81
//
// 8-byte allocation treated as a one-field struct. Store 9 via
// `*p = 9`, then overwrite with 81 via `*p = 81` (literal overwrite,
// last write wins). Load and return 81. Uses `*p = literal` form
// (no offsets). Distinct from s9_struct_overwrite_field (5 then 90)
// and s10_struct_overwrite_three_fields (uses broken *(p+N) form).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 9;
    *p = 81;
    a: u64 = *p;
    free(p);
    return a;
}
