// s74_struct_two_instances_sum.vuma — two instances, sum = 137 (100 + 37)
// Expected exit code: 137
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 100/37 via `*p = literal`, load both fields,
// sum -> 137. Uses `*p = literal` form (no offsets). Distinct
// from s70_struct_two_instances_sum (250), s66_struct_two_
// instances_diff (130) and s62_struct_two_instances_sum (230).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 37;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 137
    free(p1);
    free(p2);
    return s;
}
