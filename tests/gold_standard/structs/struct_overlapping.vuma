// struct_overlapping.vuma — store u64, load individual bytes
// Expected exit code: 255
//
// Allocates an 8-byte buffer. Stores 255 in byte 0 (low byte of a
// u64 value), 0 in bytes 1..3 (high bytes), simulating a u64 store
// of 0xFF. Then loads byte 0 individually and returns it (255).
// Demonstrates that struct field offsets can address individual bytes
// within a wider allocation.

fn main() -> i32 {
    p = allocate(8);
    // Store u64 value 0xFF as 8 individual bytes (little-endian)
    *(p + 0) = 255;
    *(p + 1) = 0;
    *(p + 2) = 0;
    *(p + 3) = 0;
    // Load byte 0
    b0: u64 = *(p + 0);
    free(p);
    return b0;
}
