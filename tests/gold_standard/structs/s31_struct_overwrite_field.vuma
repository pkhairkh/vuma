// s31_struct_overwrite_field.vuma — overwrite field, load = 210
// Expected exit code: 210
//
// Single 8-byte allocation treated as a one-field struct. Store 50, then
// overwrite the field with 210 via `*p = literal`. Load and return 210.
// Uses `*p = literal` form (no offsets). Distinct from
// s30_struct_overwrite_field (value 220) and s28_struct_overwrite_field
// (value 140).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 50;
    *p1 = 210;
    a: u64 = *p1;
    free(p1);
    return a;
}
