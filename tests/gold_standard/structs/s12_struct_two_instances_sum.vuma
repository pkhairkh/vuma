// s12_struct_two_instances_sum.vuma — two instances, sum = 120 (38 + 82)
// Expected exit code: 120
//
// Two 8-byte allocations, each treated as a one-field struct
// instance. Store 38/82 via `*p = literal`, load both, sum -> 120.
// Uses `*p = literal` form (no offsets). Distinct from
// s9_struct_two_instances_sum (values 33/77 = 110) and
// s4_struct_two_instances (uses *(p+N) form, 2-field structs).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 38;
    *p2 = 82;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;
    free(p1);
    free(p2);
    return s;
}
