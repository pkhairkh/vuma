// s18_struct_two_instances_sum.vuma — two struct instances, sum = 74 (26 + 48)
// Expected exit code: 74
//
// Two 8-byte allocations, each treated as a one-field struct
// instance. Store 26/48 via `*p = literal`, load both, sum -> 74.
// Uses `*p = literal` form (no offsets). Distinct from
// s14_struct_two_instances_sum (22/55 = 77) and
// s9_struct_two_instances_sum (33/77 = 110).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 26;
    *p2 = 48;
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 + a2;
    free(p1);
    free(p2);
    return s;
}
