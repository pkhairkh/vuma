// s66_struct_field_load.vuma — store 205, load = 205
// Expected exit code: 205
//
// Single 8-byte allocation treated as a one-field struct. Store
// 205 via `*p = literal`, load the field, return 205. Uses `*p
// = literal` form (no offsets). Distinct from s62_struct_field_
// load (182), s58_struct_field_load (165) and s55_struct_field_
// load (175).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 205;
    a: u64 = *p;
    free(p);
    return a;
}
