// s78_struct_overwrite_field.vuma — store 1, overwrite with 2, load = 2
// Expected exit code: 2
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 1 via `*p = literal`, overwrite with 2 via `*p =
// literal`, load the field, return 2. Uses `*p = literal` form
// (no offsets). Distinct from s74_struct_overwrite_field (165),
// s73_struct_overwrite_field (175) and s72_struct_overwrite_field
// (145).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 1;
    *p1 = 2;
    a: u64 = *p1;
    free(p1);
    return a;
}
