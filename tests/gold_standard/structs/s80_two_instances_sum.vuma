// s80_struct_two_instances_sum.vuma — two instances, sum = 55 (27 + 28)
// Expected exit code: 55
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 27/28 via `*p = literal`, load both fields,
// sum -> 55. Uses `*p = literal` form (no offsets). Distinct from
// s78_struct_two_instances_sum (3), s74_struct_two_instances_sum
// (137) and s73_struct_two_instances_sum (114).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 27;
    *p2 = 28;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 55
    free(p1);
    free(p2);
    return s;
}
