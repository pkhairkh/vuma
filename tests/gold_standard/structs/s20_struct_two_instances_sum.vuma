// s20_struct_two_instances_sum.vuma — two struct instances, sum = 100 (48 + 52)
// Expected exit code: 100
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 48/52 via `*p = literal`, load both, sum -> 100. Uses `*p =
// literal` form (no offsets). Distinct from s18_struct_two_instances_sum
// (different values) and s14_struct_two_instances_sum (22+55=77).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 48;
    *p2 = 52;
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 + a2;     // 100
    free(p1);
    free(p2);
    return s;
}
