// s30_struct_two_instances_sum.vuma — two instances, sum = 180 (80 + 100)
// Expected exit code: 180
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 80/100 via `*p = literal`, load both fields, sum -> 180. Uses
// `*p = literal` form (no offsets). Distinct from
// s26_struct_two_instances_xor (xor, 102) and
// s22_struct_two_instances_sum (different values).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 80;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 180
    free(p1);
    free(p2);
    return s;
}
