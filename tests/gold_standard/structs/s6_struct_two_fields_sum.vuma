// s6_struct_two_fields_sum.vuma — 2 fields, sum = 90 (40 + 50)
// Expected exit code: 90
//
// 16-byte struct (two u64 fields). Store 40/50 at offsets 0/8, load
// both, sum, return. Distinct from s5_struct_five_fields (5 fields)
// and s4_struct_field_sum.

struct Pair {
    a: u64,
    b: u64,
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 40;
    *(p + 8) = 50;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    s: u64 = a + b;
    free(p);
    return s;
}
