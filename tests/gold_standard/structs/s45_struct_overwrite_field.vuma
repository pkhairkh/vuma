// s45_struct_overwrite_field.vuma — store 55, overwrite to 185, load = 185
// Expected exit code: 185
//
// Single 8-byte allocation treated as one struct instance. Store 55
// via `*p = literal`, then overwrite with 185. Load and return 185.
// Uses `*p = literal` form (no offsets). Distinct from s42_struct_
// overwrite_field (60 -> 140) and s34_struct_overwrite_field (50 ->
// 140).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 55;
    *p1 = 185;
    a: u64 = *p1;
    free(p1);
    return a;
}
