// s101_struct_field_load.vuma — store 71, load = 71
// Expected exit code: 71
//
// Single 8-byte struct allocation. Store 71 via `*p = literal`,
// load and return 71. Uses `*p = literal` form. Distinct from
// s98_struct_field_load (82), s97_struct_field_load (4) and
// s94_struct_field_load (63).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 71;
    v: u64 = *p;           // 71
    free(p);
    return v;
}
