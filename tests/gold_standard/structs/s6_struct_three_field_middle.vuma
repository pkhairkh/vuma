// s6_struct_three_field_middle.vuma — overwrite middle field, sum = 100
// Expected exit code: 100  (10 + 80 + 10)
//
// 24-byte struct (three u64 fields). Store 10/20/10 at offsets 0/8/16,
// then overwrite the middle field with 80. Load all three, sum -> 100.
// Distinct from s5_struct_overwrite_one_field (different values).

struct Triple {
    a: u64,
    b: u64,
    c: u64,
}

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 10;
    *(p + 8) = 20;
    *(p + 16) = 10;
    *(p + 8) = 80;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    s: u64 = a + b + c;
    free(p);
    return s;
}
