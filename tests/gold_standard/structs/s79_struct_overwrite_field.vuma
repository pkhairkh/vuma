// s79_struct_overwrite_field.vuma — store 1, overwrite with 32, load = 32
// Expected exit code: 32
//
// One 8-byte allocation treated as a single-field struct
// instance. Store 1 via `*p = literal`, overwrite with 32 via
// `*p = literal`, load the field, return 32. Uses `*p =
// literal` form (no offsets). Distinct from
// s78_struct_overwrite_field (2), s77_struct_overwrite_field
// (3) and s76_struct_overwrite_field (2).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 1;
    *p1 = 32;
    a: u64 = *p1;
    free(p1);
    return a;
}
