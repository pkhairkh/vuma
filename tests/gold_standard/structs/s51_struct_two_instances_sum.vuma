// s51_struct_two_instances_sum.vuma — two instances, sum = 210 (100 + 110)
// Expected exit code: 210
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 100/110 via `*p = literal`, load both fields, sum -> 210.
// Uses `*p = literal` form (no offsets). Distinct from s50_struct_
// two_instances_sum (220) and s47_struct_two_instances_sum (215).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 110;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 210
    free(p1);
    free(p2);
    return s;
}
