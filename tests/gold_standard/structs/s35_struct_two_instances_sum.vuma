// s35_struct_two_instances_sum.vuma — two instances, sum = 205 (105 + 100)
// Expected exit code: 205
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 105/100 via `*p = literal`, load both fields,
// sum -> 205. Uses `*p = literal` form (no offsets). Distinct from
// s34_struct_two_instances_sum (205, different operands) and s30_
// struct_two_instances_sum (180).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 105;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
