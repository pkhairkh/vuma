// s46_struct_overwrite_field.vuma — store 50, overwrite to 155, load = 155
// Expected exit code: 155
//
// Single 8-byte allocation treated as one struct instance. Store 50
// via `*p = literal`, then overwrite with 155. Load and return 155.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_struct
// _overwrite_field (140) and s38_struct_overwrite_field (170).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 50;
    *p1 = 155;
    a: u64 = *p1;
    free(p1);
    return a;
}
