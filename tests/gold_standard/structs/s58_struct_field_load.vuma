// s58_struct_field_load.vuma — store 165, load = 165
// Expected exit code: 165
// 
// Single 8-byte allocation treated as a one-field struct. Store 165
// via `*p = literal`, load the field, return 165. Uses `*p =
// literal` form (no offsets). Distinct from s51_struct_two_instances_
// sum (210), s51_struct_field_load (178) and s51_struct_overwrite_
// field (200).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    a: u64 = *p;
    free(p);
    return a;
}
