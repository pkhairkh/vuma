// s43_struct_field_load.vuma — store 110, load 110
// Expected exit code: 110
//
// Single 8-byte struct instance. Store 110 via `*p = literal`, load
// and return 110. Uses `*p = literal` form. Distinct from
// s42_struct_field_load (115) and s38_struct_field_load (105).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 110;
    v: u64 = *p1;          // 110
    free(p1);
    return v;
}
