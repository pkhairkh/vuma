// s60_struct_overwrite_field.vuma — store 60, overwrite to 210, load = 210
// Expected exit code: 210
//
// Single 8-byte allocation treated as a one-field struct. Store 60
// via `*p = literal`, then overwrite the field with 210. Load and
// return 210. Uses `*p = literal` form (no offsets). Distinct from
// s58_struct_overwrite_field (220) and s57_struct_overwrite_field
// (80).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 60;
    *p = 210;
    a: u64 = *p;
    free(p);
    return a;
}
