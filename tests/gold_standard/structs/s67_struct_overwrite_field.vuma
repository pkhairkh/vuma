// s67_struct_overwrite_field.vuma — overwrite field to 225, load = 225
// Expected exit code: 225
//
// Single 8-byte allocation treated as a one-field struct.
// Store 60 then 225 via `*p = literal` (overwrite), load and
// return 225. Uses `*p = literal` form (no offsets). Distinct
// from s66_struct_overwrite_field (245), s62_struct_overwrite_
// field (225) and s58_struct_overwrite_field (220).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 60;
    *p = 225;
    a: u64 = *p;           // 225
    free(p);
    return a;
}
