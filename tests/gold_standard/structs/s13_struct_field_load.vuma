// s13_struct_field_load.vuma — single instance, store 64, load, return 64
// Expected exit code: 64
//
// Single 8-byte allocation treated as a one-field struct. Store 64
// via `*p = literal`, load it back, return 64. Baseline one-field
// struct round-trip. Uses `*p = literal` form (no offsets). Distinct
// from s9_struct_field_load (value 128) and s13_struct_overwrite_field
// (with overwrite).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 64;
    v: u64 = *p;
    free(p);
    return v;
}
