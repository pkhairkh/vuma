// struct2_three_fields.vuma — {a=1, b=2, c=3}, return a+b+c = 6
// Expected exit code: 6
//
// Allocates a 24-byte struct (3 × u64 fields), stores 1, 2, 3 at
// offsets 0, 8, 16 via *(p + N), loads all three, sums them, returns
// 6. All stored values are within the U8 range, so the known
// *(buf + offset) U8-truncation bug does not affect them.

struct Triple {
    a: u64,
    b: u64,
    c: u64,
}

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 1;
    *(p + 8) = 2;
    *(p + 16) = 3;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    sum: u64 = a + b + c;
    free(p);
    return sum;
}
