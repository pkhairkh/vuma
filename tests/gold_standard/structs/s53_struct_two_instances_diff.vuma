// s53_struct_two_instances_diff.vuma — two instances, diff = 135 (200 - 65)
// Expected exit code: 135
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 200/65 via `*p = literal`, load both fields, diff -> 135.
// Uses `*p = literal` form (no offsets). Distinct from s49_struct_
// two_instances_sum (230) and s50_struct_two_instances_sum (220).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 65;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 135
    free(p1);
    free(p2);
    return d;
}
