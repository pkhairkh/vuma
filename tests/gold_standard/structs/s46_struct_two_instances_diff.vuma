// s46_struct_two_instances_diff.vuma — two instances, diff = 140 (200 - 60)
// Expected exit code: 140
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 200/60 via `*p = literal`, load both fields, subtract ->
// 140. Uses `*p = literal` form (no offsets). Distinct from s42_
// struct_two_instances_sum (205) and s38_struct_two_instances_sum
// (225).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 60;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 140
    free(p1);
    free(p2);
    return d;
}
