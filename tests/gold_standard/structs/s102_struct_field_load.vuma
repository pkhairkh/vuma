// s102_struct_field_load.vuma — store 5, load = 5
// Expected exit code: 5
//
// Single 8-byte struct allocation. Store 5 via `*p = literal`, load and return 5. Uses `*p = literal` form. Straight-line code only.
// Distinct from s101_struct_field_load (71), s101_struct_overwrite_field (19), s101_struct_two_instances_sum (205).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: u64 = *p;           // 5
    free(p);
    return v;
}
