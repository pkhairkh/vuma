// s41_struct_field_load.vuma - store 225, load = 225
// Expected exit code: 225
//
// Single 8-byte allocation treated as a one-field struct. Store
// 225 via `*p = literal`, load and return 225. Uses `*p =
// literal` form (no offsets). Distinct from s38_struct_field_load
// (215) and s34_struct_field_load (198).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 225;
    a: u64 = *p1;
    free(p1);
    return a;
}
