// s70_struct_two_instances_sum.vuma — two instances, sum = 250 (120 + 130)
// Expected exit code: 250
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 120/130 via `*p = literal`, load both fields,
// sum -> 250. Uses `*p = literal` form (no offsets). Distinct
// from s66_struct_two_instances_diff (130), s65_struct_two_
// instances_sum (180) and s62_struct_two_instances_sum (230).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 120;
    *p2 = 130;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 250
    free(p1);
    free(p2);
    return s;
}
