// s8_struct_two_instances.vuma — two 8-byte structs, sum = 75 (25 + 50)
// Expected exit code: 75
//
// Two independent 8-byte allocations treated as two struct instances.
// Store 25 in the first, 50 in the second. Load both, sum, return 75.
// Distinct from s4_struct_two_instances (different values).

struct Cell {
    v: u64,
}

fn main() -> i32 {
    p = allocate(8);
    q = allocate(8);
    *(p + 0) = 25;
    *(q + 0) = 50;
    a: u64 = *(p + 0);
    b: u64 = *(q + 0);
    s: u64 = a + b;
    free(p);
    free(q);
    return s;
}
