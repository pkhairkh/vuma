// s27_struct_overwrite_field.vuma — store 50, overwrite 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as a one-field struct. Store the
// literal 50 via `*p = literal`, then overwrite with 175, load it back,
// return. Uses `*p = literal` form (no offsets). Distinct from
// s26_struct_overwrite_field (different values) and
// s22_struct_overwrite_field (different values).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 50;
    *p1 = 175;
    a: u64 = *p1;
    free(p1);
    return a;
}
