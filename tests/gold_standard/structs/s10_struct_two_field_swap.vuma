// s10_struct_two_field_swap.vuma — swap two fields, return offset 0 = 20
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug: `*(p+offset)=literal` writes only the low byte;
//   u64 loads return uninitialized high bytes)
//
// 16-byte struct (two u64 fields). Store 10/20 at offsets 0/8, then
// swap them via the `*ptr = variable + 0` workaround. After swap,
// offset 0 holds 20 (was 10), offset 8 holds 10 (was 20). Load
// offset 0 -> 20. The offset-based stores/loads trigger the U8-
// truncation bug, making the observed exit non-deterministic. Distinct
// from s6_struct_two_fields_sum (no swap) and s4_struct_overwrite_field.
// Expected exit code: 20

struct Pair {
    a: u64,
    b: u64,
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 10;
    *(p + 8) = 20;
    tmp: u64 = *(p + 0);   // 10
    other: u64 = *(p + 8); // 20
    *(p + 0) = other + 0;  // offset 0 now 20 (workaround store)
    *(p + 8) = tmp + 0;    // offset 8 now 10 (workaround store)
    v: u64 = *(p + 0);     // 20
    free(p);
    return v;
}
