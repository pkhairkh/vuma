// s16_struct_two_instances_diff.vuma — two instances, diff = 40 (70 - 30)
// Expected exit code: 40
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 30/70 via `*p = literal`, load both, compute difference (70 - 30)
// -> 40. Uses `*p = literal` form (no offsets). Distinct from
// s14_struct_two_instances_sum (sum, not diff) and s9_struct_two_instances_sum
// (sum, different values).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 30;
    *p2 = 70;
    a1: u64 = *p1;
    a2: u64 = *p2;
    d: u64 = a2 - a1;     // 70 - 30 = 40
    free(p1);
    free(p2);
    return d;
}
