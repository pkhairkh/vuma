// s98_struct_two_instances_diff.vuma — two instances, diff = 84 (200 - 116)
// Expected exit code: 84
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 200/116 via `*p = literal`, load both fields,
// a - b -> 84. Uses `*p = literal` form (no offsets). Distinct
// from s94_struct_two_instances_diff (58),
// s90_struct_two_instances_diff (39) and s86_struct_two_instances_
// sum (210).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 116;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 84
    free(p1);
    free(p2);
    return d;
}
