// s20_struct_field_load.vuma — single-field struct, load field = 96
// Expected exit code: 96
//
// 8-byte allocation treated as a one-field struct. Store 96 via
// `*p = 96`, load it back, return 96. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s18_struct_field_load (value 58) and s14_struct_field_load (value 56).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 96;
    a: u64 = *p;
    free(p);
    return a;
}
