// s105_struct_two_instances_sum.vuma — store 22 in s1, 14 in s2, sum = 36
// Expected exit code: 36
// 
// Two 8-byte struct instances. Store 22 in s1, store 14 in s2, load each, return the sum (36). Uses `*p = literal` form. Straight-line code only.
// Distinct from s102_struct_two_instances_sum (7), s101_struct_two_instances_sum (205), s100_struct_two_instances_diff (22).
struct Single {
    a: u64,
}

fn main() -> i32 {
    s1 = allocate(8);
    s2 = allocate(8);
    *s1 = 22;
    *s2 = 14;
    a: u64 = *s1;          // 22
    b: u64 = *s2;          // 14
    s: u64 = a + b;        // 36
    free(s1);
    free(s2);
    return s;
}
