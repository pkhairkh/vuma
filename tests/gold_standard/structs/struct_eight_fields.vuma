// struct_eight_fields.vuma — eight-field struct, sum all fields
// Expected exit code: 36
//
// Allocates an Eight struct (64 bytes, 8 × u64), stores 1..8 at
// offsets 0, 8, 16, ..., 56, then loads and sums them.
// 1 + 2 + 3 + ... + 8 = 36.

struct Eight {
    f0: u64,
    f1: u64,
    f2: u64,
    f3: u64,
    f4: u64,
    f5: u64,
    f6: u64,
    f7: u64,
}

fn main() -> i32 {
    e = allocate(64);
    *(e + 0) = 1;
    *(e + 8) = 2;
    *(e + 16) = 3;
    *(e + 24) = 4;
    *(e + 32) = 5;
    *(e + 40) = 6;
    *(e + 48) = 7;
    *(e + 56) = 8;
    v0: u64 = *(e + 0);
    v1: u64 = *(e + 8);
    v2: u64 = *(e + 16);
    v3: u64 = *(e + 24);
    v4: u64 = *(e + 32);
    v5: u64 = *(e + 40);
    v6: u64 = *(e + 48);
    v7: u64 = *(e + 56);
    sum: u64 = v0 + v1 + v2 + v3 + v4 + v5 + v6 + v7;
    free(e);
    return sum;
}
