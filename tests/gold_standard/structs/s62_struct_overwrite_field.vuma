// s62_struct_overwrite_field.vuma — store 30, overwrite to 225, load = 225
// Expected exit code: 225
// 
// Single 8-byte allocation treated as a one-field struct. Store 30
// via `*p = literal`, then overwrite the field with 225. Load and
// return 225. Uses `*p = literal` form (no offsets). Distinct from
// s51_struct_overwrite_field (200), s58_struct_overwrite_field (220)
// and s55_struct_overwrite_field (215).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 30;
    *p = 225;
    a: u64 = *p;
    free(p);
    return a;
}
