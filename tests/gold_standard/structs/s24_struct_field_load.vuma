// s24_struct_field_load.vuma — single-field struct, load field = 57
// Expected exit code: 57
//
// 8-byte allocation treated as a one-field struct. Store 57 via
// `*p = 57`, load it back, return 57. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s22_struct_field_load (value 69) and s18_struct_field_load (value 58).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 57;
    a: u64 = *p;
    free(p);
    return a;
}
