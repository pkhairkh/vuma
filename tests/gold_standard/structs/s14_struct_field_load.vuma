// s14_struct_field_load.vuma — single-field struct, load field = 56
// Expected exit code: 56
//
// 8-byte allocation treated as a one-field struct. Store 56 via
// `*p = 56`, load it back, return 56. Uses `*p = literal` form
// (no offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s9_struct_field_load (value 33) and s10_struct_partial_overwrite
// (uses broken *(p+N) form).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 56;
    a: u64 = *p;
    free(p);
    return a;
}
