// s32_struct_two_instances_sum.vuma - two instances, sum = 205 (90 + 115)
// Expected exit code: 205
//
// two instances, sum = 205 (90 + 115). All operands loaded into typed
// variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from
// s30_struct_two_instances_sum (sum, 180) and s26_struct_two_instances_xor
// (xor).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 115;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
