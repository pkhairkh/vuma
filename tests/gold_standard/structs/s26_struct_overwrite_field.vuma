// s26_struct_overwrite_field.vuma — overwrite field, load = 100
// Expected exit code: 100
//
// Single 8-byte allocation treated as a one-field struct. Store 50, then
// overwrite the field with 100 via `*p = literal`. Load and return 100.
// Uses `*p = literal` form (no offsets). Distinct from
// s22_struct_overwrite_field (different value) and
// s18_struct_overwrite_field (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 50;
    *p1 = 100;
    a: u64 = *p1;
    free(p1);
    return a;
}
