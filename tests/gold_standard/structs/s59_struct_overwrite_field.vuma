// s59_struct_overwrite_field.vuma — store 40, overwrite to 240, load = 240
// Expected exit code: 240
//
// Single 8-byte allocation treated as a one-field struct. Store 40
// via `*p = literal`, then overwrite the field with 240. Load and
// return 240. Uses `*p = literal` form (no offsets). Distinct from
// s58_struct_two_instances_diff (110), s58_struct_field_load (165) and
// s58_struct_overwrite_field (220).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 40;
    *p = 240;
    a: u64 = *p;
    free(p);
    return a;
}
