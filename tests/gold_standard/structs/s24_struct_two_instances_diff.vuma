// s24_struct_two_instances_diff.vuma — two struct instances, diff = 44 (88 - 44)
// Expected exit code: 44
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 88/44 via `*p = literal`, load both, subtract -> 44. Uses `*p =
// literal` form (no offsets). Distinct from s22_struct_two_instances_sum
// (44/56 = 100, add) and s14_struct_two_instances_sum (22/55 = 77, add).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 88;
    *p2 = 44;
    a1: u64 = *p1;
    a2: u64 = *p2;
    d: u64 = a1 - a2;
    free(p1);
    free(p2);
    return d;
}
