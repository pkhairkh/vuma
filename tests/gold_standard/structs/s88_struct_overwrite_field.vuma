// s88_struct_overwrite_field.vuma — store 1, overwrite with 225, load = 225
// Expected exit code: 225
//
// One 8-byte allocation treated as a single-field struct
// instance. Store 1 via `*p = literal`, overwrite with 225
// via `*p = literal`, load the field, return 225. Uses `*p
// = literal` form (no offsets). Distinct from s86_struct_
// overwrite_field (220), s82_struct_overwrite_field (210)
// and s78_struct_overwrite_field (2).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 1;
    *p1 = 225;
    a: u64 = *p1;
    free(p1);
    return a;
}
