// s96_struct_overwrite_field.vuma — overwrite field to 191, load = 191
// Expected exit code: 191
//
// Single 8-byte struct allocation. Store 1 via `*p = literal`, then
// overwrite to 191. Load -> 191 (the overwritten value). Uses
// `*p = literal` form. Distinct from s94_struct_overwrite_field (92),
// s90_struct_overwrite_field (47) and s86_struct_overwrite_field
// (220).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    *p = 191;
    v: u64 = *p;           // 191
    free(p);
    return v;
}
