// s95_struct_two_instances_sum.vuma — two instances, sum = 101 (80 + 21)
// Expected exit code: 101
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 80/21 via `*p = literal`, load both fields,
// a + b -> 101. Uses `*p = literal` form (no offsets). Distinct from
// s94_struct_two_instances_diff (58),
// s90_struct_two_instances_diff (39) and
// s82_struct_two_instances_sum (165).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 80;
    *p2 = 21;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 101
    free(p1);
    free(p2);
    return s;
}
