// s27_struct_two_instances_diff.vuma — two instances, diff = 75 (110 - 35)
// Expected exit code: 75
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 110/35 via `*p = literal`, load both, sub -> 75. Uses `*p =
// literal` form (no offsets). All operands loaded into typed locals
// before the sub. Distinct from s26_struct_two_instances_xor (xor,
// 85^51=102) and s22_struct_two_instances_sum (sum).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 110;
    *p2 = 35;
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 - a2;     // 75
    free(p1);
    free(p2);
    return s;
}
