// s51_struct_field_load.vuma — store 178, load = 178
// Expected exit code: 178
//
// Single 8-byte allocation treated as a one-field struct. Store 178
// via `*p = literal`, load the field, return 178. Uses `*p =
// literal` form (no offsets). Distinct from s50_struct_field_load
// (168) and s47_struct_field_load (205).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 178;
    a: u64 = *p;
    free(p);
    return a;
}
