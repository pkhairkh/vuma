// s32_struct_field_load.vuma - store 195, load = 195
// Expected exit code: 195
//
// store 195, load = 195. All operands loaded into typed variables before any
// bitwise op (immediate-RHS drop workaround where applicable); stores use
// the `*ptr = literal` (or `*ptr = variable + 0`) form with no `*(ptr +
// offset)` indexing. Distinct from s30_struct_field_load (value 168) and
// s26_struct_field_load (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 195;
    a: u64 = *p1;
    free(p1);
    return a;
}
