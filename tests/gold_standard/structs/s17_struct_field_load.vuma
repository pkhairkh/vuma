// s17_struct_field_load.vuma — single-field struct, load field = 64
// Expected exit code: 64
//
// 8-byte allocation treated as a one-field struct. Store 64 via
// `*p = 64`, load it back, return 64. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s14_struct_field_load (value 56) and s9_struct_field_load (value 33).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 64;
    a: u64 = *p;
    free(p);
    return a;
}
