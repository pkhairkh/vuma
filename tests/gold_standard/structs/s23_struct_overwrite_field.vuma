// s23_struct_overwrite_field.vuma — overwrite single field, final = 188
// Expected exit code: 188
//
// 8-byte allocation treated as a one-field struct. Store 22 via
// `*p = 22`, then overwrite with 188 via `*p = 188` (literal overwrite,
// last write wins). Load and return 188. Uses `*p = literal` form (no
// offsets). Distinct from s22_struct_overwrite_field (18 then 105) and
// s24_struct_overwrite_field (14 then 95).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 22;
    *p = 188;
    a: u64 = *p;
    free(p);
    return a;
}

