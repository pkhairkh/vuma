// s4_struct_point_x.vuma — {x=42, y=99}; return x = 42
// Expected exit code: 42
//
// A 16-byte struct (two u64 fields). Stores 42 at offset 0 (x) and
// 99 at offset 8 (y), then reads back only x and returns it.

struct Point {
    x: u64,
    y: u64,
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 42;
    *(p + 8) = 99;
    x: u64 = *(p + 0);
    free(p);
    return x;
}
