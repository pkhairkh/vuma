// s23_struct_field_load.vuma — single-field struct, load field = 117
// Expected exit code: 117
//
// 8-byte allocation treated as a one-field struct. Store 117 via
// `*p = 117`, load it back, return 117. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s22_struct_field_load (value 69) and s24_struct_field_load (value 57).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 117;
    a: u64 = *p;
    free(p);
    return a;
}

