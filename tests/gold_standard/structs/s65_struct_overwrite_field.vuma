// s65_struct_overwrite_field.vuma — store 50, overwrite to 218, load = 218
// Expected exit code: 218
//
// Single 8-byte allocation treated as a one-field struct. Store 50,
// then overwrite the field with 218 via `*p = literal`, load the
// field, return 218. Uses `*p = literal` form (no offsets). Distinct
// from s51_struct_overwrite_field (200), s58_struct_overwrite_field
// (220) and s62_struct_overwrite_field (225).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 50;
    *p = 218;
    a: u64 = *p;
    free(p);
    return a;
}
