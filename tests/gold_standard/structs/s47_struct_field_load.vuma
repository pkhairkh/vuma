// s47_struct_field_load.vuma — store 205, load = 205
// Expected exit code: 205
//
// Single 8-byte allocation treated as one struct instance. Store 205
// via `*p = literal`, load and return 205. Uses `*ptr = literal`
// form. Distinct from s46_struct_field_load (185) and s42_struct_
// field_load (175).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 205;
    a: u64 = *p1;
    free(p1);
    return a;
}
