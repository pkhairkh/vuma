// struct_copy.vuma — copy fields from one struct to another
// Expected exit code: 42
//
// Allocates src and dst Point structs. Stores x=42, y=99 in src.
// main loads src's fields into scalar intermediates and stores them
// into dst. Loading dst.x returns 42, verifying field-by-field copy
// through scalar temporaries.

struct Point {
    x: u64,
    y: u64,
}

fn main() -> i32 {
    src = allocate(16);
    dst = allocate(16);
    *(src + 0) = 42;
    *(src + 8) = 99;
    sx: u64 = *(src + 0);
    sy: u64 = *(src + 8);
    *(dst + 0) = sx;
    *(dst + 8) = sy;
    val: u64 = *(dst + 0);
    free(src);
    free(dst);
    return val;
}
