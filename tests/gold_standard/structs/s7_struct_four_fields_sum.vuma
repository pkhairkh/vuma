// s7_struct_four_fields_sum.vuma — 4 fields, sum = 10+20+30+40 = 100
// Expected exit code: 100
//
// 32-byte struct (four u64 fields). Stores 10/20/30/40 at offsets
// 0/8/16/24, loads all four, sums, returns 100. Uses
// pointer-arithmetic aliases (f0..f3) so all stores/loads go through
// `*fN`. Distinct from s5_struct_five_fields (5 fields) and
// s6_struct_two_fields_sum (2 fields).

struct Quad {
    a: u64,
    b: u64,
    c: u64,
    d: u64,
}

fn main() -> i32 {
    p = allocate(32);
    f0 = p;
    f1 = p + 8;
    f2 = p + 16;
    f3 = p + 24;
    *f0 = 10;
    *f1 = 20;
    *f2 = 30;
    *f3 = 40;
    a: u64 = *f0;
    b: u64 = *f1;
    c: u64 = *f2;
    d: u64 = *f3;
    t1: u64 = a + b;
    t2: u64 = c + d;
    s: u64 = t1 + t2;
    free(p);
    return s;
}
