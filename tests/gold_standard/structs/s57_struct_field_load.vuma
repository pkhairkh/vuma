// s57_struct_field_load.vuma — store/load single field = 155
// Expected exit code: 155
//
// Single 8-byte allocation treated as one struct instance. Store
// 155 via `*p = literal`, load field -> 155. Uses `*p = literal`
// form (no offsets). Distinct from s54_struct_field_load (165) and
// s50_struct_field_load (135).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 155;
    a: u64 = *p1;          // 155
    free(p1);
    return a;
}
