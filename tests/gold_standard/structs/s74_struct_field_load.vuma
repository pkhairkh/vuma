// s74_struct_field_load.vuma — store 193, load = 193
// Expected exit code: 193
//
// Single 8-byte allocation treated as a one-field struct. Store
// 193 via `*p = literal`, load the field, return 193. Uses `*p
// = literal` form (no offsets). Distinct from s70_struct_field_
// load (95), s66_struct_field_load (205) and s62_struct_field_
// load (182).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 193;
    a: u64 = *p;
    free(p);
    return a;
}
