// s92_struct_overwrite_field.vuma — overwrite field to 91, load = 91
// Expected exit code: 91
//
// Single 8-byte struct allocation. Store 5 via `*p = literal`, then
// overwrite to 91, load -> 91 (the overwritten value). Uses
// `*p = literal` form. Distinct from s90_struct_overwrite_field
// (47), s86_struct_overwrite_field (245) and s82_struct_overwrite_
// field (242).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 91;
    v: u64 = *p;           // 91
    free(p);
    return v;
}
