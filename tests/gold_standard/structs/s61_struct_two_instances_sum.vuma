// s61_struct_two_instances_sum.vuma — two instances, sum = 205 (130 + 75)
// Expected exit code: 205
// 
// Two 8-byte allocations treated as two independent struct instances.
// Store 130/75 via `*p = literal`, load both fields, sum -> 205.
// Uses `*p = literal` form (no offsets). Distinct from s58_struct_
// two_instances_diff (110), s58_struct_field_load (165) and s58_
// struct_overwrite_field (220).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 130;
    *p2 = 75;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
