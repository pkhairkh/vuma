// struct_offset_compute.vuma — compute field offset dynamically
// Expected exit code: 42
//
// Allocates a struct and computes the field offset in a variable
// (off = 0). Stores 42 at *(p + off) and loads it back. Verifies
// that field access can use a variable offset expression (p + var)
// rather than only a constant literal offset.
//
// NOTE: VUMA has a known U8 type-truncation bug on computed-offset
// stores/loads when the stored value exceeds 255. This test uses
// value 42 which fits in U8, so it is unaffected by that bug. The
// test will start to fail if extended to values > 255 until the
// parallel U8 fix lands.

fn main() -> i32 {
    p = allocate(16);
    off: u64 = 0;
    *(p + off) = 42;
    val: u64 = *(p + off);
    free(p);
    return val;
}
