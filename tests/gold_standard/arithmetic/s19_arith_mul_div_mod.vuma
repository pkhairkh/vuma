// s19_arith_mul_div_mod.vuma — ((15 * 5) / 3) % 7 = 75 / 3 = 25; 25 % 7 = 4
// Expected exit code: 4
//
// Three-stage u32 computation: mul then div then mod. 15 * 5 = 75;
// 75 / 3 = 25; 25 % 7 = 4. All operands loaded into u32 variables
// first. Distinct from s18_arith_div_mod_sum (div-mod-sum) and
// s11_arith_add_mul_div (add-mul-div).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 5;
    c: u32 = 3;
    m: u32 = 7;
    p: u32 = a * b;       // 75
    q: u32 = p / c;       // 25
    r: u32 = q % m;       // 4
    return r;
}
