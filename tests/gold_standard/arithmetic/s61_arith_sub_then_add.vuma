// s61_arith_sub_then_add.vuma — (250 - 100) + 70 = 150 + 70 = 220
// Expected exit code: 220
// 
// Two-stage u32 computation: subtract then add. 250 - 100 = 150;
// 150 + 70 = 220. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_add_then_sub
// (150), s58_arith_mul_then_div (35) and s58_arith_div_then_mul
// (120).

fn main() -> i32 {
    a: u32 = 250;
    b: u32 = 100;
    c: u32 = 70;
    s: u32 = a - b;        // 150
    r: u32 = s + c;        // 220
    return r;
}
