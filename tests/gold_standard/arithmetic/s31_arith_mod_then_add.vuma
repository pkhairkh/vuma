// s31_arith_mod_then_add.vuma — (200 % 7) + 100 = 4 + 100 = 104
// Expected exit code: 104
//
// Two-stage u32 computation: modulo then add. 200 % 7 = 4; 4 + 100 =
// 104. All operands loaded into u32 variables first. Distinct from
// s30_arith_sub_then_mod (sub-then-mod, 45) and s26_arith_div_mod_chain
// (div-mod chain, 32).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 7;
    c: u32 = 100;
    m: u32 = a % b;       // 4
    r: u32 = m + c;       // 104
    return r;
}
