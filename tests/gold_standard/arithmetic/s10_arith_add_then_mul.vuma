// s10_arith_add_then_mul.vuma — (15 + 25) * 3 = 40 * 3 = 120
// Expected exit code: 120
//
// Two-stage computation: sum then multiply. (15 + 25) = 40; 40 * 3 = 120.
// All operands loaded into u32 variables first. Distinct from
// s5_arith_mul_then_add3 (mul-then-add) and s6_arith_sub_then_add.

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 25;
    c: u32 = 3;
    s: u32 = a + b;       // 40
    r: u32 = s * c;       // 120
    return r;
}
