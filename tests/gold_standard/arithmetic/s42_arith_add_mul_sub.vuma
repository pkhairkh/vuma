// s42_arith_add_mul_sub.vuma — ((40 + 5) * 4) - 30 = 180 - 30 = 150
// Expected exit code: 150
//
// Three-stage u32 computation: add, then multiply, then subtract.
// (40 + 5) = 45; 45 * 4 = 180; 180 - 30 = 150. All operands loaded
// into u32 variables first. Straight-line arithmetic. Distinct from
// s38_arith_add_sub_mul (add-sub-mul, 180) and s34_arith_add_mul_sub
// (75).

fn main() -> i32 {
    a: u32 = 40;
    b: u32 = 5;
    c: u32 = 4;
    d: u32 = 30;
    s: u32 = a + b;       // 45
    t: u32 = s * c;       // 180
    r: u32 = t - d;       // 150
    return r;
}
