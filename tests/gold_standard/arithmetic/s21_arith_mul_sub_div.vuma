// s21_arith_mul_sub_div.vuma — (12 * 15 - 30) / 5 = 150 / 5 = 30
// Expected exit code: 30
//
// Three-stage mul-sub-div. 12 * 15 = 180; 180 - 30 = 150; 150 / 5 = 30.
// All operands loaded into u32 variables first. Distinct from
// s16_arith_sub_div_chain (sub-div, no mul) and s13_arith_sub_div_mul
// (sub-div-mul, different order).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 15;
    s: u32 = 30;
    d: u32 = 5;
    p: u32 = a * b;       // 180
    m: u32 = p - s;       // 150
    r: u32 = m / d;       // 30
    return r;
}
