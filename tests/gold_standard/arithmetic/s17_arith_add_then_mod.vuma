// s17_arith_add_then_mod.vuma — (50 + 30) % 7 = 80 % 7 = 3
// Expected exit code: 3
//
// Two-stage computation: add then modulo. (50 + 30) = 80; 80 % 7 = 3.
// All operands loaded into u32 variables first. Distinct from
// s14_arith_mod_then_add (mod-then-add) and s10_arith_add_then_mul
// (add-then-mul).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 30;
    d: u32 = 7;
    s: u32 = a + b;       // 80
    r: u32 = s % d;       // 3
    return r;
}
