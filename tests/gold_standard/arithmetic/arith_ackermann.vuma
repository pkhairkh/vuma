// arith_ackermann — Ackermann function (small values: A(2,3) = 9)
// Expected exit code: 9
//
// A(0, n)   = n + 1
// A(m, 0)   = A(m-1, 1)              for m > 0
// A(m, n)   = A(m-1, A(m, n-1))      for m, n > 0
// A(2, 3)   = 9.

fn ackermann(m: u32, n: u32) -> u32 {
    zero: u32 = 0;
    one: u32 = 1;
    if m == zero {
        return n + one;
    }
    if n == zero {
        return ackermann(m - one, one);
    }
    inner: u32 = ackermann(m, n - one);
    return ackermann(m - one, inner);
}

fn main() -> i32 {
    result: u32 = ackermann(2, 3);
    return result;
}
