// arith_tribonacci — Tribonacci sequence: T(0)=0, T(1)=0, T(2)=1,
// T(n) = T(n-1) + T(n-2) + T(n-3).
// Expected exit code: 81
//
// T(8) = 0, 0, 1, 1, 2, 4, 7, 13, 24, 44, 81 (with T(0)=0).
// Standard: T(0)=0, T(1)=0, T(2)=1, T(3)=1, T(4)=2, T(5)=4, T(6)=7,
//           T(7)=13, T(8)=24, T(9)=44, T(10)=81.
// We compute T(10) = 81.

fn main() -> i32 {
    n: u32 = 10;
    zero: u32 = 0;
    one: u32 = 1;
    a: u32 = 0;
    b: u32 = 0;
    c: u32 = 1;
    i: u32 = 3;
    while i <= n {
        next: u32 = a + b + c;
        a = b;
        b = c;
        c = next;
        i = i + 1;
    }
    return c;
}
