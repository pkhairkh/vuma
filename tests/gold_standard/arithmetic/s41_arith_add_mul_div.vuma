// s41_arith_add_mul_div.vuma - ((30 + 18) * 2) / 3 = 96 / 3 = 32
// Expected exit code: 32
//
// Three-stage u32 computation: add, then multiply, then divide.
// (30 + 18) = 48; 48 * 2 = 96; 96 / 3 = 32. All operands loaded
// into u32 variables first. Straight-line arithmetic. Distinct
// from s38_arith_add_sub_mul (add-sub-mul, 180) and s34_arith_
// add_mul_sub (add-mul-sub, 75).

fn main() -> i32 {
    a: u32 = 30;
    b: u32 = 18;
    c: u32 = 2;
    d: u32 = 3;
    s: u32 = a + b;       // 48
    t: u32 = s * c;       // 96
    r: u32 = t / d;       // 32
    return r;
}
