// s103_arith_sub_then_add.vuma — (200 - 50) + 7 = 150 + 7 = 157
// Expected exit code: 157
//
// Two-stage arithmetic: subtract then add. 200 - 50 = 150; 150 + 7 = 157. All operands kept as i32 locals. Straight-line arithmetic.
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 50;
    c: i32 = 7;
    d: i32 = a - b;        // 150
    r: i32 = d + c;        // 157
    return r;
}
