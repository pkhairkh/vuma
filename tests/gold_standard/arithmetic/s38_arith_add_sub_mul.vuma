// s38_arith_add_sub_mul.vuma — ((60 + 70) - 40) * 2 = 90 * 2 = 180
// Expected exit code: 180
//
// Three-stage u32 computation: add, then subtract, then multiply.
// (60 + 70) = 130; 130 - 40 = 90; 90 * 2 = 180. All operands
// loaded into u32 variables first. Straight-line arithmetic. Distinct
// from s34_arith_add_mul_sub (add-mul-sub, 75) and s30_arith_mul_
// then_add (mul-then-add, 95).

fn main() -> i32 {
    a: u32 = 60;
    b: u32 = 70;
    c: u32 = 40;
    d: u32 = 2;
    s: u32 = a + b;       // 130
    t: u32 = s - c;       // 90
    r: u32 = t * d;       // 180
    return r;
}
