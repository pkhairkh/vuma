// s26_arith_sub_then_div.vuma — (255 - 15) / 8 = 240 / 8 = 30
// Expected exit code: 30
//
// Two-stage u32 computation: sub then div. 255 - 15 = 240; 240 / 8 = 30.
// All operands loaded into u32 variables first. Distinct from
// s22_arith_sub_then_div (same shape, different values 100/4) and
// s18_arith_mul_add_sub (mul-add-sub, 82).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 15;
    c: u32 = 8;
    d: u32 = a - b;       // 240
    r: u32 = d / c;       // 30
    return r;
}
