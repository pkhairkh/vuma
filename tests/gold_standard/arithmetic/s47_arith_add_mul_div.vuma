// s47_arith_add_mul_div.vuma — (45 + 35) * 3 / 5 = 240 / 5 = 48
// Expected exit code: 48
//
// Three-stage u32 computation: add, multiply, then divide. 45 + 35 =
// 80; 80 * 3 = 240; 240 / 5 = 48. All operands loaded into u32
// variables first. Straight-line arithmetic. Distinct from s46_
// arith_sub_then_div (30) and s42_arith_add_mul_sub (200).

fn main() -> i32 {
    a: u32 = 45;
    b: u32 = 35;
    c: u32 = 3;
    d: u32 = 5;
    s: u32 = a + b;        // 80
    p: u32 = s * c;        // 240
    r: u32 = p / d;        // 48
    return r;
}
