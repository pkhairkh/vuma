// s98_arith_mul_then_sub.vuma — (10 * 2) - 3 = 20 - 3 = 17
// Expected exit code: 17
//
// Two-stage arithmetic: multiply then subtract. 10 * 2 = 20;
// 20 - 3 = 17. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s94_arith_mul_then_mod (43),
// s90_arith_mul_then_sub (54) and s86_arith_mul_then_sub (126).
fn main() -> i32 {
    a: i32 = 10;
    b: i32 = 2;
    c: i32 = 3;
    x: i32 = a * b;        // 20
    r: i32 = x - c;        // 17
    return r;
}
