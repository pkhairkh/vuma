// s31_arith_add_then_mul.vuma — (10 + 20) * 5 = 30 * 5 = 150
// Expected exit code: 150
//
// Two-stage u32 computation: add then multiply. 10 + 20 = 30; 30 * 5 =
// 150. All operands loaded into u32 variables first. Distinct from
// s30_arith_mul_then_add (mul-then-add, 95) and s26_arith_add_mul_sub
// (add-mul-sub, 85).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 5;
    s: u32 = a + b;       // 30
    r: u32 = s * c;       // 150
    return r;
}
