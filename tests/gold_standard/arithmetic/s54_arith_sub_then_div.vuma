// s54_arith_sub_then_div.vuma — (200 - 35) / 5 = 165 / 5 = 33
// Expected exit code: 33
//
// Two-stage u32 computation: subtract then divide. 200 - 35 = 165;
// 165 / 5 = 33. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s50_arith_div_then_add
// (42) and s49_arith_div_then_add (210).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 35;
    c: u32 = 5;
    d: u32 = a - b;        // 165
    r: u32 = d / c;        // 33
    return r;
}
