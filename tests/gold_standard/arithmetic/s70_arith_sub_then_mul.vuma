// s70_arith_sub_then_mul.vuma — (200 - 180) * 11 = 20 * 11 = 220
// Expected exit code: 220
//
// Two-stage arithmetic: subtract then multiply. 200 - 180 = 20;
// 20 * 11 = 220. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s66_arith_mul_then_sub (168),
// s65_arith_mul_then_sub (80) and s62_arith_mul_then_add (135).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 180;
    c: i32 = 11;
    d: i32 = a - b;        // 20
    r: i32 = d * c;        // 220
    return r;
}
