// s8_arith_div_mod_sum.vuma — (100 / 7) + (100 % 7) = 14 + 2 = 16
// Expected exit code: 16
//
// Same dividend (100). Divide by 7 -> 14, modulo 7 -> 2 (since
// 7 * 14 = 98, 100 - 98 = 2). Sum = 16. Distinct from
// s6_arith_div_mod_combined (different dividend/divisors).

fn main() -> i32 {
    n: u32 = 100;
    d: u32 = 7;
    q: u32 = n / d;     // 14
    r: u32 = n % d;     // 2
    s: u32 = q + r;     // 16
    return s;
}
