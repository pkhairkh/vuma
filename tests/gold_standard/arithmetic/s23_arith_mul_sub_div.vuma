// s23_arith_mul_sub_div.vuma — (16 * 13 - 80) / 8 = (208 - 80) / 8 = 16
// Expected exit code: 16
//
// Three-stage u32 computation: mul then sub then div. 16 * 13 = 208;
// 208 - 80 = 128; 128 / 8 = 16. All operands loaded into u32 variables
// first. Distinct from s22_arith_sub_then_div (sub-then-div, value 30)
// and s21_arith_mul_sub_div (mul-then-sub-then-div, value 41).

fn main() -> i32 {
    a: u32 = 16;
    b: u32 = 13;
    c: u32 = 80;
    d: u32 = 8;
    p: u32 = a * b;       // 208
    s: u32 = p - c;       // 128
    q: u32 = s / d;       // 16
    return q;
}

