// s62_arith_mul_then_add.vuma — 12 * 10 + 15 = 120 + 15 = 135
// Expected exit code: 135
// 
// Two-stage u32 computation: multiply then add. 12 * 10 = 120;
// 120 + 15 = 135. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_mul_add_div
// (30), s58_arith_mul_then_div (35) and s55_arith_add_then_sub
// (140).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 10;
    c: u32 = 15;
    p: u32 = a * b;        // 120
    r: u32 = p + c;        // 135
    return r;
}
