// s20_arith_add_div_chain.vuma — (60 + 40) / 5 = 100 / 5 = 20
// Expected exit code: 20
//
// Two-stage computation: add then divide. (60 + 40) = 100; 100 / 5 = 20.
// All operands loaded into u32 variables first. Distinct from
// s17_arith_div_then_mul (div-then-mul) and s14_arith_mul_then_div
// (mul-then-div).

fn main() -> i32 {
    a: u32 = 60;
    b: u32 = 40;
    d: u32 = 5;
    s: u32 = a + b;       // 100
    r: u32 = s / d;       // 20
    return r;
}
