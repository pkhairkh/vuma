// s17_arith_mul_then_sub.vuma — 12 * 6 - 20 = 72 - 20 = 52
// Expected exit code: 52
//
// Two-stage computation: multiply then subtract. (12 * 6) = 72;
// 72 - 20 = 52. Distinct from s14_arith_sub_then_mul (sub-then-mul)
// and s10_arith_mul_then_div (mul-then-div).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 6;
    c: u32 = 20;
    p: u32 = a * b;       // 72
    r: u32 = p - c;       // 52
    return r;
}
