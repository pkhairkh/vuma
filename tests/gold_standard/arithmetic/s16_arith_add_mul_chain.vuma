// s16_arith_add_mul_chain.vuma — (10 + 20) * 5 = 150
// Expected exit code: 150
//
// Two-stage add-then-multiply. (10 + 20) = 30; 30 * 5 = 150. All
// operands loaded into u32 variables first. Distinct from
// s14_arith_quad_ascending (sum-quad chain) and s10_arith_add_then_mul
// (different operands 7+8 then *3).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    m: u32 = 5;
    s: u32 = a + b;       // 30
    r: u32 = s * m;       // 150
    return r;
}
