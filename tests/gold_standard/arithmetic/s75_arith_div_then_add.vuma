// s75_arith_div_then_add.vuma — (200 / 5) + 31 = 40 + 31 = 71
// Expected exit code: 71
//
// Two-stage arithmetic: divide then add. 200 / 5 = 40; 40 + 31 = 71.
// All operands kept as i32 locals. Straight-line arithmetic. Distinct
// from s74_arith_add_then_div (17), s70_arith_div_then_add (55) and
// s62_arith_add_then_div (50).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 5;
    c: i32 = 31;
    d: i32 = a / b;        // 40
    r: i32 = d + c;        // 71
    return r;
}
