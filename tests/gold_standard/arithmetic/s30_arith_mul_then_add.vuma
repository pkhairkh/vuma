// s30_arith_mul_then_add.vuma — (14 * 6) + 11 = 84 + 11 = 95
// Expected exit code: 95
//
// Two-stage u32 computation: multiply then add. 14 * 6 = 84; 84 + 11 =
// 95. All operands loaded into u32 variables first. Distinct from
// s26_arith_add_mul_sub (add-mul-sub, 85) and s22_arith_add_then_mul
// (add-then-mul).

fn main() -> i32 {
    a: u32 = 14;
    b: u32 = 6;
    c: u32 = 11;
    m: u32 = a * b;       // 84
    r: u32 = m + c;       // 95
    return r;
}
