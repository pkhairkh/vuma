// s23_arith_sub_add_mod.vuma — (240 - 60 + 30) % 50 = 210 % 50 = 10
// Expected exit code: 10
//
// Three-stage u32 computation: sub then add then mod. 240 - 60 = 180;
// 180 + 30 = 210; 210 % 50 = 10. All operands loaded into u32 variables
// first. Distinct from s20_arith_sub_then_mod (sub-then-mod, value 50)
// and s14_arith_mod_then_add (mod-then-add, value 13).

fn main() -> i32 {
    a: u32 = 240;
    b: u32 = 60;
    c: u32 = 30;
    m: u32 = 50;
    s: u32 = a - b;       // 180
    t: u32 = s + c;       // 210
    r: u32 = t % m;       // 10
    return r;
}

