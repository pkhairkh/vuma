// s60_arith_mul_then_div.vuma — (15 * 9) / 5 = 135 / 5 = 27
// Expected exit code: 27
//
// Two-stage u32 computation: multiply then divide. 15 * 9 = 135;
// 135 / 5 = 27. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_mul_then_div
// (35) and s57_arith_mul_then_add (125).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 9;
    c: u32 = 5;
    p: u32 = a * b;        // 135
    r: u32 = p / c;        // 27
    return r;
}
