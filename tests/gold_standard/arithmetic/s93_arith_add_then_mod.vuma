// s93_arith_add_then_mod.vuma — (80 + 79) % 100 = 159 % 100 = 59
// Expected exit code: 59
//
// Two-stage arithmetic: add then modulo. 80 + 79 = 159; 159 % 100
// = 59. All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s90_arith_add_then_mod (53), s82_arith_add_then_mul (200) and s78_arith_add_then_div (11).
fn main() -> i32 {
    a: i32 = 80;
    b: i32 = 79;
    c: i32 = 100;
    s: i32 = a + b;        // 159
    r: i32 = s % c;        // 59
    return r;
}
