// arith2_stern_brocot — Stern-Brocot tree: parent of 3/5
// Expected exit code: 2
//
// In the Stern-Brocot tree, 3/5 is the mediant of 1/2 (left ancestor)
// and 2/3 (right ancestor).  The right ancestor 2/3 is the parent of
// 3/5.  This test computes the mediant to verify (1+2)/(2+3) = 3/5,
// then returns the numerator of the parent (2).
// Straight-line code only.

fn main() -> i32 {
    // Left neighbor of 3/5 in the tree
    la: u32 = 1;  lb: u32 = 2;
    // Right neighbor of 3/5 (this is the parent)
    ra: u32 = 2;  rb: u32 = 3;
    // Mediant = (la+ra)/(lb+rb) = 3/5 (the child)
    child_num: u32 = la + ra;   // 3
    child_den: u32 = lb + rb;   // 5
    // Parent of 3/5 is the right neighbor (2/3)
    parent_num: u32 = ra;       // 2
    return parent_num;
}
