// s31_arith_mul_then_sub.vuma — (12 * 15) - 50 = 180 - 50 = 130
// Expected exit code: 130
//
// Two-stage u32 computation: multiply then subtract. 12 * 15 = 180;
// 180 - 50 = 130. All operands loaded into u32 variables first.
// Distinct from s30_arith_div_then_mul (div-then-mul, 64) and
// s26_arith_sub_then_div (sub-then-div, 30).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 15;
    c: u32 = 50;
    m: u32 = a * b;       // 180
    r: u32 = m - c;       // 130
    return r;
}
