// s80_arith_add_then_div.vuma — (24 + 18) / 2 = 42 / 2 = 21
// Expected exit code: 21
//
// Two-stage arithmetic: add then divide (exact). 24 + 18 = 42;
// 42 / 2 = 21. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_add_then_div (11),
// s74_arith_add_then_div (170) and s73_arith_add_then_mod (23).
fn main() -> i32 {
    a: i32 = 24;
    b: i32 = 18;
    c: i32 = 2;
    s: i32 = a + b;        // 42
    r: i32 = s / c;        // 21
    return r;
}
