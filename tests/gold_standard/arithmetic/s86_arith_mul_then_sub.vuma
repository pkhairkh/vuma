// s86_arith_mul_then_sub.vuma — 13 * 12 - 30 = 156 - 30 = 126
// Expected exit code: 126
//
// Two-stage arithmetic: multiply then subtract. 13 * 12 = 156;
// 156 - 30 = 126. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s82_arith_mul_then_add (115),
// s78_arith_sub_then_mul (78) and s74_arith_mul_then_sub (90).
fn main() -> i32 {
    a: i32 = 13;
    b: i32 = 12;
    c: i32 = 30;
    p: i32 = a * b;        // 156
    r: i32 = p - c;        // 126
    return r;
}
