// s27_arith_mul_then_mod.vuma — (12 * 13) % 17 = 156 % 17 = 3
// Expected exit code: 3
//
// MUL then MOD. 12 * 13 = 156; 156 % 17 = 3 (17*9=153, remainder 3). All
// operands loaded into u32 variables first. Distinct from
// s26_arith_div_mod_chain (div-then-mod) and s22_arith_mul_mod_add
// (mul-mod-add).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 13;
    c: u32 = 17;
    p: u32 = a * b;       // 156
    r: u32 = p % c;       // 3
    return r;
}
