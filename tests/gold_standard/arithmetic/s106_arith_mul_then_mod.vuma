// s106_arith_mul_then_mod.vuma — (3 * 71) % 110 = 213 % 110 = 103
// Expected exit code: 103
//
// Two-stage arithmetic: multiply then modulo. 3 * 71 = 213; 213 % 110 = 103 (213 = 1*110 + 103). All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s102_arith_mod_then_mul (88), s101_arith_mul_then_add (131), s100_arith_mul_then_add (77).
fn main() -> i32 {
    a: i32 = 3;
    b: i32 = 71;
    c: i32 = 110;
    p: i32 = a * b;        // 213
    r: i32 = p % c;        // 103
    return r;
}
