// s40_arith_mul_mod_chain.vuma — (15 * 9) % 17 = 135 % 17 = 16
// Expected exit code: 16
//
// Two-stage u32 computation: multiply then modulo. (15 * 9) = 135;
// 135 % 17 = 16. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s38_arith_sub_then_mod
// (50) and s34_arith_mul_then_mod (7).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 9;
    c: u32 = 17;
    m: u32 = a * b;       // 135
    r: u32 = m % c;       // 16
    return r;
}
