// arith_next_power_of_two — smallest power of 2 >= n
// Expected exit code: 64
//
// next_pow2(50) = 64. Algorithm: decrement, set all lower bits, then add 1.

fn main() -> i32 {
    n: u32 = 50;
    one: u32 = 1;
    two: u32 = 2;
    zero: u32 = 0;
    if n == zero {
        return one;
    }
    x: u32 = n - one;
    shift: u32 = 1;
    while shift < 32 {
        x = x | (x >> shift);
        shift = shift + 1;
    }
    result: u32 = x + one;
    return result;
}
