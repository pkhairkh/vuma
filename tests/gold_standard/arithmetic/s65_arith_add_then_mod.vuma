// s65_arith_add_then_mod.vuma — (140 + 80) % 150 = 220 % 150 = 70
// Expected exit code: 70
//
// Two-stage u32 computation: add then modulo. 140 + 80 = 220;
// 220 % 150 = 70. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_add_mod_then_add
// (140), s59_arith_add_then_div (51) and s62_arith_add_then_div (50).

fn main() -> i32 {
    a: u32 = 140;
    b: u32 = 80;
    c: u32 = 150;
    s: u32 = a + b;        // 220
    r: u32 = s % c;        // 70
    return r;
}
