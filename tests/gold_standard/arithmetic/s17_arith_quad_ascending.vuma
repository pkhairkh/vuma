// s17_arith_quad_ascending.vuma — 10 + 20 + 30 + 40 = 100
// Expected exit code: 100
//
// Four ascending values summed in a chain. 10 + 20 = 30; 30 + 30 = 60;
// 60 + 40 = 100. Distinct from s14_arith_quad_ascending (same shape,
// different values 5/15/25/35 = 80) and s10_arith_quad_then_sub
// (quad-sum then subtract).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 30;
    d: u32 = 40;
    s1: u32 = a + b;      // 30
    s2: u32 = s1 + c;     // 60
    r: u32 = s2 + d;      // 100
    return r;
}
