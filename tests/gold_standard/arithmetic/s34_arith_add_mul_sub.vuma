// s34_arith_add_mul_sub.vuma — (10 + 20) * 3 - 15 = 30 * 3 - 15 = 90 - 15 = 75
// Expected exit code: 75
//
// Three-stage u32 computation: add, then multiply, then subtract.
// (10 + 20) = 30; 30 * 3 = 90; 90 - 15 = 75. All operands loaded into
// u32 variables first. Distinct from s30_arith_mul_then_add (mul-then-
// add, 95) and s27_arith_add_mul_sub (different values, 70).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 3;
    d: u32 = 15;
    s: u32 = a + b;       // 30
    m: u32 = s * c;       // 90
    r: u32 = m - d;       // 75
    return r;
}
