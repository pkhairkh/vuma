// s88_arith_mul_then_add.vuma — 7 * 15 + 20 = 105 + 20 = 125
// Expected exit code: 125
//
// Two-stage arithmetic: multiply then add. 7 * 15 = 105;
// 105 + 20 = 125. All operands kept as i32 locals. Straight-
// line arithmetic. Distinct from s86_arith_mul_then_sub
// (126), s82_arith_mul_then_add (115) and s78_arith_sub_
// then_mul (78).
fn main() -> i32 {
    a: i32 = 7;
    b: i32 = 15;
    c: i32 = 20;
    p: i32 = a * b;        // 105
    r: i32 = p + c;        // 125
    return r;
}
