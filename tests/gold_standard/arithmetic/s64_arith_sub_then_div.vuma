// s64_arith_sub_then_div.vuma — (250 - 10) / 4 = 240 / 4 = 60
// Expected exit code: 60
//
// Two-stage u32 computation: subtract then divide. 250 - 10 = 240;
// 240 / 4 = 60. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s62_arith_add_then_div (50),
// s62_arith_mul_then_add (135) and s62_arith_sub_then_add (180).

fn main() -> i32 {
    a: u32 = 250;
    b: u32 = 10;
    c: u32 = 4;
    s: u32 = a - b;        // 240
    r: u32 = s / c;        // 60
    return r;
}
