// s104_arith_mul_then_div.vuma — (4 * 61) / 2 = 244 / 2 = 122
// Expected exit code: 122
//
// Two-stage arithmetic: multiply then integer-divide. 4 * 61 = 244; 244 / 2 = 122. All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s102_arith_add_then_div (74), s102_arith_mod_then_mul (88), s102_arith_mul_then_sub (79).
fn main() -> i32 {
    a: i32 = 4;
    b: i32 = 61;
    c: i32 = 2;
    p: i32 = a * b;        // 244
    r: i32 = p / c;        // 122
    return r;
}
