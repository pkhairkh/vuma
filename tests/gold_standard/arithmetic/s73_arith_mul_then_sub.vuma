// s73_arith_mul_then_sub.vuma — 13 * 9 - 5 = 117 - 5 = 112
// Expected exit code: 112
//
// Two-stage arithmetic: multiply then subtract. 13 * 9 = 117;
// 117 - 5 = 112. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s70_arith_sub_then_mul (220),
// s69_arith_mul_then_add (145) and s66_arith_mul_then_sub (168).
fn main() -> i32 {
    a: i32 = 13;
    b: i32 = 9;
    c: i32 = 5;
    p: i32 = a * b;        // 117
    r: i32 = p - c;        // 112
    return r;
}
