// arith_palindrome — check if a number is a palindrome
// Expected exit code: 1
//
// 12321 reversed = 12321, so it is a palindrome. Returns 1 for true.

fn main() -> i32 {
    n: u32 = 12321;
    ten: u32 = 10;
    zero: u32 = 0;
    one: u32 = 1;
    original: u32 = n;
    reversed: u32 = 0;
    while n > zero {
        digit: u32 = n % ten;
        reversed = reversed * ten + digit;
        n = n / ten;
    }
    if original == reversed {
        return one;
    }
    return zero;
}
