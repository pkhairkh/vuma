// s42_arith_mul_add_div.vuma — ((15 * 5) + 25) / 4 = 100 / 4 = 25
// Expected exit code: 25
//
// Three-stage u32 computation: multiply, then add, then divide.
// 15 * 5 = 75; 75 + 25 = 100; 100 / 4 = 25. All operands loaded
// into u32 variables first. Straight-line arithmetic. Distinct from
// s38_arith_add_sub_mul (add-sub-mul, 180) and s34_arith_mul_then_mod
// (mul-then-mod, 4).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 5;
    c: u32 = 25;
    d: u32 = 4;
    p: u32 = a * b;       // 75
    s: u32 = p + c;       // 100
    r: u32 = s / d;       // 25
    return r;
}
