// s36_arith_add_mod_chain.vuma — 40 + 80 = 120; 120 % 50 = 20
// Expected exit code: 20
//
// Two-stage u32 computation: add then modulo.
// 40 + 80 = 120; 120 % 50 = 20. All operands loaded into
// u32 variables first.
// Distinct from s30_arith_mod_then_add (mod-then-add, 35) and s27_arith_add_mod_chain (different values).

fn main() -> i32 {
    a: u32 = 40;
    b: u32 = 80;
    c: u32 = 50;
    s: u32 = a + b;       // 120
    r: u32 = s % c;       // 20
    return r;
}
