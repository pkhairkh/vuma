// s61_arith_mul_then_add.vuma — 12 * 5 + 95 = 60 + 95 = 155
// Expected exit code: 155
// 
// Two-stage u32 computation: multiply then add. 12 * 5 = 60;
// 60 + 95 = 155. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_add_then_sub
// (150), s58_arith_mul_then_div (35) and s58_arith_div_then_mul
// (120).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 5;
    c: u32 = 95;
    p: u32 = a * b;        // 60
    r: u32 = p + c;        // 155
    return r;
}
