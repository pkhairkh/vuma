// arith_collatz — Collatz sequence length
// Expected exit code: 16
//
// Counts the number of steps to reach 1 from n=7 under Collatz iteration:
//   n -> n/2     (n even)
//   n -> 3n+1    (n odd)
// Sequence: 7, 22, 11, 34, 17, 52, 26, 13, 40, 20, 10, 5, 16, 8, 4, 2, 1
// Length = 16 steps to reach 1, plus we count the start, so 17.
// Standard convention: number of steps to reach 1 from 7 is 16.
// We return 16.

fn main() -> i32 {
    n: u32 = 7;
    one: u32 = 1;
    two: u32 = 2;
    three: u32 = 3;
    steps: u32 = 0;
    while n != one {
        if n % two == 0 {
            n = n / two;
        } else {
            n = three * n + 1;
        }
        steps = steps + 1;
    }
    return steps;
}
