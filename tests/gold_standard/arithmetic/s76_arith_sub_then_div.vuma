// s76_arith_sub_then_div.vuma — (200 - 75) / 5 = 125 / 5 = 25
// Expected exit code: 25
//
// Two-stage arithmetic: subtract then divide. 200 - 75 = 125;
// 125 / 5 = 25. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s74_arith_mod_then_add (211),
// s73_arith_div_then_sub (39) and s72_arith_sub_then_div (24).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 75;
    c: i32 = 5;
    s: i32 = a - b;        // 125
    r: i32 = s / c;        // 25
    return r;
}
