// arith_digit_sum — sum of decimal digits of a number
// Expected exit code: 6
//
// digit_sum(123) = 1 + 2 + 3 = 6.

fn main() -> i32 {
    n: u32 = 123;
    ten: u32 = 10;
    zero: u32 = 0;
    sum: u32 = 0;
    while n > zero {
        sum = sum + (n % ten);
        n = n / ten;
    }
    return sum;
}
