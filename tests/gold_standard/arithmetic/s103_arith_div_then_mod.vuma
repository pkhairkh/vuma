// s103_arith_div_then_mod.vuma — (180 / 6) % 13 = 30 % 13 = 4
// Expected exit code: 4
//
// Two-stage arithmetic: integer-divide then mod. 180 / 6 = 30; 30 % 13 = 4 (30 = 13*2 + 4). All operands kept as i32 locals. Straight-line arithmetic.
fn main() -> i32 {
    a: i32 = 180;
    b: i32 = 6;
    c: i32 = 13;
    q: i32 = a / b;        // 30
    r: i32 = q % c;        // 4
    return r;
}
