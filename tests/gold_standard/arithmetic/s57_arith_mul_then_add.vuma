// s57_arith_mul_then_add.vuma — 7 * 15 + 20 = 105 + 20 = 125
// Expected exit code: 125
//
// Two-stage u32 computation: multiply then add. 7 * 15 = 105;
// 105 + 20 = 125. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s54_arith_mul_then_add
// (125) and s50_arith_mul_then_mod (180).

fn main() -> i32 {
    a: u32 = 7;
    b: u32 = 15;
    c: u32 = 20;
    s: u32 = a * b;        // 105
    r: u32 = s + c;        // 125
    return r;
}
