// s45_arith_sub_mul_div.vuma — ((100 - 30) * 2) / 7 = 140 / 7 = 20
// Expected exit code: 20
//
// Three-stage u32 computation: subtract, then multiply, then divide.
// 100 - 30 = 70; 70 * 2 = 140; 140 / 7 = 20. All operands loaded
// into u32 variables first. Straight-line arithmetic. Distinct from
// s42_arith_add_mul_sub (add-mul-sub, 80) and s38_arith_sub_mul_add
// (sub-mul-add, 90).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 30;
    c: u32 = 2;
    d: u32 = 7;
    s: u32 = a - b;       // 70
    p: u32 = s * c;       // 140
    r: u32 = p / d;       // 20
    return r;
}
