// s100_arith_add_then_mul.vuma — (9 + 4) * 9 = 13 * 9 = 117
// Expected exit code: 117
//
// Two-stage arithmetic: add then multiply. 9 + 4 = 13;
// 13 * 9 = 117. All operands kept as i32 locals. Straight-
// line arithmetic.
// Distinct from s97_arith_add_then_div (72), s94_arith_div_then_add (80), s90_arith_add_then_mod (53).
fn main() -> i32 {
    a: i32 = 9;
    b: i32 = 4;
    c: i32 = 9;
    s: i32 = a + b;        // 13
    m: i32 = s * c;        // 117
    return m;
}
