// s51_arith_mul_add_div.vuma — (12 * 6 + 18) / 3 = 90 / 3 = 30
// Expected exit code: 30
//
// Three-stage u32 computation: multiply, add, divide. 12 * 6 = 72;
// 72 + 18 = 90; 90 / 3 = 30. All operands loaded into u32 variables
// first. Straight-line arithmetic. Distinct from s50_arith_add_then_
// div (50) and s47_arith_add_mul_div (48).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 6;
    c: u32 = 18;
    d: u32 = 3;
    p: u32 = a * b;        // 72
    s: u32 = p + c;        // 90
    r: u32 = s / d;        // 30
    return r;
}
