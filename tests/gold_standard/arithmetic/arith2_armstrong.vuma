// arith2_armstrong — Armstrong (narcissistic) number check
// Expected exit code: 1
//
// A 3-digit Armstrong number equals the sum of cubes of its digits.
// 153 = 1^3 + 5^3 + 3^3 = 1 + 125 + 27 = 153 ✓
// We compute sum - n = 0 and return 1 - 0 = 1 to encode "is Armstrong"
// in straight-line code (no if).

fn main() -> i32 {
    d1: u32 = 1;
    d2: u32 = 5;
    d3: u32 = 3;
    c1: u32 = d1 * d1 * d1;   // 1
    c2: u32 = d2 * d2 * d2;   // 125
    c3: u32 = d3 * d3 * d3;   // 27
    sum: u32 = c1 + c2 + c3;  // 153
    n: u32 = 153;
    diff: u32 = sum - n;       // 0 (equal)
    one: u32 = 1;
    is_armstrong: u32 = one - diff;   // 1 - 0 = 1
    return is_armstrong;
}
