// s26_arith_add_mul_sub.vuma — (10 + 20) * 3 - 5 = 30 * 3 - 5 = 85
// Expected exit code: 85
//
// Three-stage u32 computation: add then mul then sub. 10 + 20 = 30;
// 30 * 3 = 90; 90 - 5 = 85. All operands loaded into u32 variables
// first. Distinct from s22_arith_add_then_mul (add-then-mul, 160) and
// s18_arith_mul_add_sub (mul-then-add-then-sub, 82).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 3;
    d: u32 = 5;
    s: u32 = a + b;       // 30
    m: u32 = s * c;       // 90
    r: u32 = m - d;       // 85
    return r;
}
