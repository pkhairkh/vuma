// s58_arith_add_then_sub.vuma — (100 + 80) - 30 = 180 - 30 = 150
// Expected exit code: 150
// 
// Two-stage u32 computation: add then subtract. 100 + 80 = 180;
// 180 - 30 = 150. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_sub_then_mul
// (240), s51_arith_add_mod_then_add (140) and s51_arith_mul_add_div
// (30).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 80;
    c: u32 = 30;
    s: u32 = a + b;        // 180
    r: u32 = s - c;        // 150
    return r;
}
