// s74_arith_mul_then_sub.vuma — (15 * 8) - 11 = 120 - 11 = 109
// Expected exit code: 109
//
// Two-stage arithmetic: multiply then subtract. 15 * 8 = 120;
// 120 - 11 = 109. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s70_arith_sub_then_mul (220),
// s66_arith_mul_then_sub (168) and s62_arith_mul_then_add (135).
fn main() -> i32 {
    a: i32 = 15;
    b: i32 = 8;
    c: i32 = 11;
    m: i32 = a * b;        // 120
    r: i32 = m - c;        // 109
    return r;
}
