// s32_arith_mul_sub_chain.vuma - 15 * 5 - 25 = 75 - 25 = 50
// Expected exit code: 50
//
// 15 * 5 - 25 = 75 - 25 = 50. All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_arith_mul_then_add (mul-
// then-add, 110) and s26_arith_mul_sub_chain (different operands).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 5;
    c: u32 = 25;
    p: u32 = a * b;        // 75
    r: u32 = p - c;        // 50
    return r;
}
