// s65_arith_div_then_sub.vuma — 240 / 4 - 20 = 60 - 20 = 40
// Expected exit code: 40
//
// Two-stage u32 computation: divide then subtract. 240 / 4 = 60;
// 60 - 20 = 40. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_sub_then_mul
// (240), s58_arith_div_then_mul (120) and s62_arith_sub_then_add
// (180).

fn main() -> i32 {
    a: u32 = 240;
    b: u32 = 4;
    c: u32 = 20;
    q: u32 = a / b;        // 60
    r: u32 = q - c;        // 40
    return r;
}
