// s18_arith_mul_add_sub.vuma — (12 * 5) + 30 - 8 = 60 + 30 - 8 = 82
// Expected exit code: 82
//
// Three-stage u32 computation: mul then add then sub. 12 * 5 = 60;
// 60 + 30 = 90; 90 - 8 = 82. All operands loaded into u32 variables
// first. Distinct from s10_arith_add_then_mul (add-then-mul) and
// s14_arith_sub_then_mul (sub-then-mul).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 5;
    c: u32 = 30;
    d: u32 = 8;
    p: u32 = a * b;       // 60
    q: u32 = p + c;       // 90
    r: u32 = q - d;       // 82
    return r;
}
