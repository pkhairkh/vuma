// s53_arith_sub_then_div.vuma — (240 - 30) / 7 = 210 / 7 = 30
// Expected exit code: 30
//
// Two-stage u32 computation: subtract then divide. 240 - 30 = 210;
// 210 / 7 = 30. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s49_arith_div_then_add
// (52) and s50_arith_div_then_add (130).

fn main() -> i32 {
    a: u32 = 240;
    b: u32 = 30;
    c: u32 = 7;
    d: u32 = a - b;        // 210
    r: u32 = d / c;        // 30
    return r;
}
