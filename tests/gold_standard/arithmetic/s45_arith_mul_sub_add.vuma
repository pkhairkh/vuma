// s45_arith_mul_sub_add.vuma — ((12 * 7) - 20) + 30 = 84 - 20 + 30 = 94
// Expected exit code: 94
//
// Three-stage u32 computation: multiply, then subtract, then add.
// 12 * 7 = 84; 84 - 20 = 64; 64 + 30 = 94. All operands loaded into
// u32 variables first. Straight-line arithmetic. Distinct from
// s42_arith_mul_add_div (mul-add-div, 25) and s38_arith_add_sub_mul
// (add-sub-mul, 180).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 7;
    c: u32 = 20;
    d: u32 = 30;
    p: u32 = a * b;       // 84
    s: u32 = p - c;       // 64
    r: u32 = s + d;       // 94
    return r;
}
