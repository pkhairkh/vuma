// s77_arith_add_then_mod.vuma — (240 + 13) % 90 = 253 % 90 = 73
// Expected exit code: 73
//
// Two-stage arithmetic: add then modulus. 240 + 13 = 253;
// 253 % 90 = 73 (253 = 2*90 + 73). All operands kept as i32
// locals. Straight-line arithmetic. Distinct from s70_arith_
// add_then_div (22), s66_arith_add_then_mod (10) and s74_arith_
// mod_then_add (211).

fn main() -> i32 {
    a: i32 = 240;
    b: i32 = 13;
    c: i32 = 90;
    s: i32 = a + b;        // 253
    r: i32 = s % c;        // 73
    return r;
}
