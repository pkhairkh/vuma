// s57_arith_add_then_sub.vuma — (90 + 70) - 40 = 160 - 40 = 120
// Expected exit code: 120
//
// Two-stage u32 computation: add then subtract. 90 + 70 = 160;
// 160 - 40 = 120. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s54_arith_add_then_mul
// (110) and s50_arith_mul_then_sub (76).

fn main() -> i32 {
    a: u32 = 90;
    b: u32 = 70;
    c: u32 = 40;
    s: u32 = a + b;        // 160
    r: u32 = s - c;        // 120
    return r;
}
