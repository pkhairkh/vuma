// s32_arith_mod_then_add.vuma - 250 % 7 + 100 = 5 + 100 = 105
// Expected exit code: 105
//
// 250 % 7 + 100 = 5 + 100 = 105. All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_arith_sub_then_mod (sub-
// then-mod, 3) and s26_arith_mod_then_add (different operands).

fn main() -> i32 {
    a: u32 = 250;
    b: u32 = 7;
    c: u32 = 100;
    m: u32 = a % b;        // 5
    r: u32 = m + c;        // 105
    return r;
}
