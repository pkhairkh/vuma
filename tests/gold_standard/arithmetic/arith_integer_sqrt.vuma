// arith_integer_sqrt — integer square root via Newton's method
// Expected exit code: 12
//
// isqrt(144) = 12. Newton iteration: x_{k+1} = (x_k + n / x_k) / 2.

fn main() -> i32 {
    n: u32 = 144;
    zero: u32 = 0;
    one: u32 = 1;
    two: u32 = 2;
    if n < two {
        return n;
    }
    x: u32 = n;
    y: u32 = (x + one) / two;
    while y < x {
        x = y;
        y = (x + n / x) / two;
    }
    return x;
}
