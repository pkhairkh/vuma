// s81_arith_sub_then_mul.vuma — (120 - 30) * 2 = 90 * 2 = 180
// Expected exit code: 180
//
// Two-stage arithmetic: subtract then multiply. 120 - 30 = 90;
// 90 * 2 = 180. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_sub_then_mul (78),
// s77_arith_sub_then_mod (69) and s76_arith_sub_then_div (25).
fn main() -> i32 {
    a: i32 = 120;
    b: i32 = 30;
    c: i32 = 2;
    d: i32 = a - b;        // 90
    r: i32 = d * c;        // 180
    return r;
}
