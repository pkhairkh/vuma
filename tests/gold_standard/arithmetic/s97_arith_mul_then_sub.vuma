// s97_arith_mul_then_sub.vuma — (13 * 9) - 31 = 117 - 31 = 86
// Expected exit code: 86
//
// Two-stage arithmetic: multiply then subtract. 13 * 9 =
// 117; 117 - 31 = 86. All operands kept as i32 locals.
// Straight-line arithmetic.
// Distinct from s94_arith_div_then_add (80), s90_arith_mul_then_sub (54), s86_arith_mul_then_sub (126).
fn main() -> i32 {
    a: i32 = 13;
    b: i32 = 9;
    c: i32 = 31;
    m: i32 = a * b;        // 117
    r: i32 = m - c;        // 86
    return r;
}
