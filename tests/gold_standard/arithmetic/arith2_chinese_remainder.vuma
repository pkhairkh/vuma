// arith2_chinese_remainder — Chinese Remainder Theorem (small case)
// Expected exit code: 7
//
// Solve x ≡ 1 (mod 3), x ≡ 2 (mod 5).  CRT formula:
//   M = 15, M1 = 5, M2 = 3, y1 = inv(5,3) = 2 (5*2=10≡1), y2 = inv(3,5) = 2 (3*2=6≡1)
//   x = (a1*M1*y1 + a2*M2*y2) mod M = (1*5*2 + 2*3*2) mod 15 = (10 + 12) mod 15 = 22 mod 15 = 7
// Straight-line code only.

fn main() -> i32 {
    a1: u32 = 1;  r1: u32 = 3;   // x ≡ 1 (mod 3)
    a2: u32 = 2;  r2: u32 = 5;   // x ≡ 2 (mod 5)
    M: u32 = 15;
    M1: u32 = 5;
    M2: u32 = 3;
    y1: u32 = 2;   // inv(5, 3)
    y2: u32 = 2;   // inv(3, 5)
    x: u32 = (a1 * M1 * y1 + a2 * M2 * y2) % M;   // (10 + 12) % 15 = 7
    // Verify (computations are dead but exercise the mod path)
    c1: u32 = x % r1;   // 7 % 3 = 1
    c2: u32 = x % r2;   // 7 % 5 = 2
    return x;
}
