// s76_arith_mul_then_add.vuma — (12 * 10) + 1 = 120 + 1 = 121
// Expected exit code: 121
//
// Two-stage arithmetic: multiply then add. 12 * 10 = 120;
// 120 + 1 = 121. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s74_arith_mul_then_sub (109),
// s73_arith_mul_then_sub (112) and s72_arith_mul_then_add (163).
fn main() -> i32 {
    a: i32 = 12;
    b: i32 = 10;
    c: i32 = 1;
    m: i32 = a * b;        // 120
    r: i32 = m + c;        // 121
    return r;
}
