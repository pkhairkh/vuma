// s105_arith_mul_then_add.vuma — 7 * 11 + 6 = 77 + 6 = 83
// Expected exit code: 83
// 
// Two-stage arithmetic: multiply then add. 7 * 11 = 77; 77 + 6 = 83. All operands kept as i32 locals. Straight-line arithmetic; intermediate 77 stays within 0-255.
// Distinct from s102_arith_mul_then_sub (79), s101_arith_mul_then_add (131), s100_arith_mul_then_add (77).
fn main() -> i32 {
    a: i32 = 7;
    b: i32 = 11;
    c: i32 = 6;
    p: i32 = a * b;        // 77
    r: i32 = p + c;        // 83
    return r;
}
