// s103_arith_mul_then_mod.vuma — (15 * 11) % 8 = 165 % 8 = 5
// Expected exit code: 5
//
// Two-stage arithmetic: multiply then integer-modulo. 15 * 11 = 165; 165 % 8 = 5 (165 = 8*20 + 5). All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s99_arith_mul_then_mod (6), s94_arith_mul_then_mod (43).
fn main() -> i32 {
    a: i32 = 15;
    b: i32 = 11;
    c: i32 = 8;
    p: i32 = a * b;        // 165
    r: i32 = p % c;        // 5
    return r;
}
