// s61_arith_div_then_add.vuma — 240 / 8 + 100 = 30 + 100 = 130
// Expected exit code: 130
// 
// Two-stage u32 computation: divide then add. 240 / 8 = 30;
// 30 + 100 = 130. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_add_then_sub
// (150), s58_arith_mul_then_div (35) and s58_arith_div_then_mul
// (120).

fn main() -> i32 {
    a: u32 = 240;
    b: u32 = 8;
    c: u32 = 100;
    q: u32 = a / b;        // 30
    r: u32 = q + c;        // 130
    return r;
}
