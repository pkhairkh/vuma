// s41_arith_sub_mul_add.vuma - ((100 - 30) * 2) + 15 = 140 + 15 = 155
// Expected exit code: 155
//
// Three-stage u32 computation: subtract, then multiply, then add.
// (100 - 30) = 70; 70 * 2 = 140; 140 + 15 = 155. All operands
// loaded into u32 variables first. Straight-line arithmetic.
// Distinct from s38_arith_sub_then_mod (sub-then-mod, 50) and
// s34_arith_div_then_add (div-then-add).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 30;
    c: u32 = 2;
    d: u32 = 15;
    s: u32 = a - b;       // 70
    t: u32 = s * c;       // 140
    r: u32 = t + d;       // 155
    return r;
}
