// arith2_continued_fraction — continued fraction of 22/7
// Expected exit code: 3
//
// The continued fraction expansion of 22/7 is [3; 7] because
//   22 = 3*7 + 1, then 7 = 7*1 + 0
// The first partial quotient (and floor(22/7)) is 3.  This test returns 3.
// Straight-line code only.

fn main() -> i32 {
    num: u32 = 22;
    den: u32 = 7;
    a0: u32 = num / den;   // 3 (first partial quotient)
    return a0;
}
