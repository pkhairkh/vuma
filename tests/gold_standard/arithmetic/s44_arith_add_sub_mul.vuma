// s44_arith_add_sub_mul.vuma — ((30 + 15) - 5) * 3 = 40 * 3 = 120
// Expected exit code: 120
//
// Three-stage u32 computation: add, then subtract, then multiply.
// (30 + 15) = 45; 45 - 5 = 40; 40 * 3 = 120. All operands loaded into
// u32 variables first. Straight-line arithmetic. Distinct from
// s42_arith_add_mul_sub (add-mul-sub, 150) and s38_arith_add_sub_mul
// (add-sub-mul, 180).

fn main() -> i32 {
    a: u32 = 30;
    b: u32 = 15;
    c: u32 = 5;
    d: u32 = 3;
    s: u32 = a + b;       // 45
    t: u32 = s - c;       // 40
    r: u32 = t * d;       // 120
    return r;
}
