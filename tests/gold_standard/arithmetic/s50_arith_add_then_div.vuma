// s50_arith_add_then_div.vuma — (140 + 60) / 4 = 200 / 4 = 50
// Expected exit code: 50
//
// Two-stage u32 computation: add then divide. 140 + 60 = 200;
// 200 / 4 = 50. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s46_arith_sub_then_div
// (30) and s43_arith_mul_add_div (17).

fn main() -> i32 {
    a: u32 = 140;
    b: u32 = 60;
    c: u32 = 4;
    s: u32 = a + b;        // 200
    r: u32 = s / c;        // 50
    return r;
}
