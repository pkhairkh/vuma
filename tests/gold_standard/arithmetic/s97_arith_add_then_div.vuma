// s97_arith_add_then_div.vuma — (200 + 16) / 3 = 216 / 3 = 72
// Expected exit code: 72
//
// Two-stage arithmetic: add then divide. 200 + 16 = 216;
// 216 / 3 = 72. All operands kept as i32 locals. Straight-
// line arithmetic.
// Distinct from s94_arith_div_then_add (80), s90_arith_add_then_mod (53), s86_arith_add_then_div (10).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 16;
    c: i32 = 3;
    s: i32 = a + b;        // 216
    q: i32 = s / c;        // 72
    return q;
}
