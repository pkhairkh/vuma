// s13_arith_div_rem_sum.vuma — (200 / 6) + (200 % 6) = 33 + 2 = 35
// Expected exit code: 35
//
// Integer division and modulo of the same dividend, then summed.
// 200 / 6 = 33; 200 % 6 = 2; 33 + 2 = 35. All operands loaded into
// u32 variables first. Distinct from s6_arith_div_mod_combined
// (div-then-mod chain, no final sum) and s9_arith_mod_then_add
// (mod-then-add with a separate addend).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 6;
    q: u32 = a / b;       // 33
    r: u32 = a % b;       // 2
    s: u32 = q + r;       // 35
    return s;
}
