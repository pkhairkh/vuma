// s63_arith_div_then_add.vuma — 240 / 6 + 20 = 40 + 20 = 60
// Expected exit code: 60
//
// Two-stage u32 computation: divide then add. 240 / 6 = 40;
// 40 + 20 = 60. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_sub_then_mul
// (240), s58_arith_add_then_sub (150) and s55_arith_mul_then_sub
// (155).

fn main() -> i32 {
    a: u32 = 240;
    b: u32 = 6;
    c: u32 = 20;
    q: u32 = a / b;        // 40
    r: u32 = q + c;        // 60
    return r;
}
