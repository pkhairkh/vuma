// s87_arith_mul_then_sub.vuma — 14 * 11 - 50 = 154 - 50 = 104
// Expected exit code: 104
//
// Two-stage arithmetic: multiply then subtract. 14 * 11 = 154;
// 154 - 50 = 104. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s86_arith_mul_then_sub (126),
// s82_arith_mul_then_add (115) and s78_arith_sub_then_mul (78).
fn main() -> i32 {
    a: i32 = 14;
    b: i32 = 11;
    c: i32 = 50;
    p: i32 = a * b;        // 154
    r: i32 = p - c;        // 104
    return r;
}
