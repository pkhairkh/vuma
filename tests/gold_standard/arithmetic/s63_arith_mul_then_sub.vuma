// s63_arith_mul_then_sub.vuma — 14 * 11 - 20 = 154 - 20 = 134
// Expected exit code: 134
//
// Two-stage u32 computation: multiply then subtract. 14 * 11 = 154;
// 154 - 20 = 134. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_add_mod_then_
// add (140), s58_arith_div_then_mul (120) and s55_arith_div_then_
// mul (90).

fn main() -> i32 {
    a: u32 = 14;
    b: u32 = 11;
    c: u32 = 20;
    p: u32 = a * b;        // 154
    r: u32 = p - c;        // 134
    return r;
}
