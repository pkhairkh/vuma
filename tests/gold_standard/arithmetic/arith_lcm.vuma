// arith_lcm — least common multiple: lcm(4, 6) = 12
// Expected exit code: 12
//
// lcm(a, b) = a / gcd(a, b) * b. lcm(4, 6) = 4 / 2 * 6 = 12.

fn gcd(a: u32, b: u32) -> u32 {
    x: u32 = a;
    y: u32 = b;
    zero: u32 = 0;
    while y > zero {
        t: u32 = x % y;
        x = y;
        y = t;
    }
    return x;
}

fn main() -> i32 {
    a: u32 = 4;
    b: u32 = 6;
    g: u32 = gcd(a, b);
    result: u32 = (a / g) * b;
    return result;
}
