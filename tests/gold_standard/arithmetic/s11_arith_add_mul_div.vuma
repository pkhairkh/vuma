// s11_arith_add_mul_div.vuma — (10 + 20) * 3 / 5 = 90 / 5 = 18
// Expected exit code: 18
//
// Three-stage computation: add then multiply then divide. (10 + 20) = 30;
// 30 * 3 = 90; 90 / 5 = 18. All operands loaded into u32 variables first.
// Distinct from s10_arith_add_then_mul (add-then-mul, no divide) and
// s9_arith_div_then_mul (div-then-mul).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 3;
    d: u32 = 5;
    s: u32 = a + b;       // 30
    p: u32 = s * c;       // 90
    r: u32 = p / d;       // 18
    return r;
}
