// s8_arith_mul_div_chain.vuma — (12 * 5) / 3 = 20
// Expected exit code: 20
//
// Multiplication then division: 12 * 5 = 60, 60 / 3 = 20. All operands
// within U8 range. Distinct from s6_arith_mul_chain_3 (3-way mul) and
// s4_arith_div_chain (chain of divisions).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 5;
    c: u32 = 3;
    p: u32 = a * b;     // 60
    q: u32 = p / c;     // 20
    return q;
}
