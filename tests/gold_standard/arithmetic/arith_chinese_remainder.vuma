// arith_chinese_remainder — Chinese Remainder Theorem (simple case)
// Expected exit code: 23
//
// Solve x ≡ 2 (mod 3), x ≡ 3 (mod 5), x ≡ 2 (mod 7).
// CRT gives x = 23 (mod 105). Brute-force search returns 23.

fn main() -> i32 {
    three: u32 = 3;
    five: u32 = 5;
    seven: u32 = 7;
    zero: u32 = 0;
    one: u32 = 1;
    n: u32 = 105;     // 3 * 5 * 7
    x: u32 = 0;
    while x < n {
        if x % three == 2 {
            if x % five == 3 {
                if x % seven == 2 {
                    return x;
                }
            }
        }
        x = x + one;
    }
    return zero;
}
