// s94_arith_div_then_add.vuma — (200 / 5) + 40 = 40 + 40 = 80
// Expected exit code: 80
//
// Two-stage arithmetic: divide then add. 200 / 5 = 40; 40 + 40 = 80.
// All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s90_arith_add_then_mod (53), s86_arith_add_then_div
// (10) and s82_arith_add_then_mul (200).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 5;
    c: i32 = 40;
    q: i32 = a / b;        // 40
    r: i32 = q + c;        // 80
    return r;
}
