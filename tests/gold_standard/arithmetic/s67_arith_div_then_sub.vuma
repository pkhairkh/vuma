// s67_arith_div_then_sub.vuma — (240 / 8) - 12 = 30 - 12 = 18
// Expected exit code: 18
//
// Two-stage arithmetic: divide then subtract. 240 / 8 = 30;
// 30 - 12 = 18. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s66_arith_sub_then_div (28),
// s62_arith_add_then_div (50) and s58_arith_div_then_mul (120).
fn main() -> i32 {
    a: i32 = 240;
    b: i32 = 8;
    c: i32 = 12;
    q: i32 = a / b;        // 30
    r: i32 = q - c;        // 18
    return r;
}
