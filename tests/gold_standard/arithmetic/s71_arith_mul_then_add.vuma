// s71_arith_mul_then_add.vuma — 13 * 7 + 50 = 91 + 50 = 141
// Expected exit code: 141
//
// Two-stage arithmetic: multiply then add. 13 * 7 = 91; 91 + 50
// = 141. All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s69_arith_mul_then_add (145), s70_arith_sub_then_
// mul (189) and s66_arith_add_then_mul (180).
fn main() -> i32 {
    a: i32 = 13;
    b: i32 = 7;
    c: i32 = 50;
    p: i32 = a * b;        // 91
    r: i32 = p + c;        // 91 + 50 = 141
    return r;
}
