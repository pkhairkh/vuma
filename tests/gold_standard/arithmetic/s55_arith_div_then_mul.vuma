// s55_arith_div_then_mul.vuma — (220 / 4) * 3 = 55 * 3 = 165
// Expected exit code: 165
//
// Two-stage u32 computation: divide then multiply. 220 / 4 = 55;
// 55 * 3 = 165. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s54_arith_sub_then_div
// (33) and s53_arith_sub_then_div (30).

fn main() -> i32 {
    a: u32 = 220;
    b: u32 = 4;
    c: u32 = 3;
    d: u32 = a / b;        // 55
    r: u32 = d * c;        // 165
    return r;
}
