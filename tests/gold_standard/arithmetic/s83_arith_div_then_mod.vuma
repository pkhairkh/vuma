// s83_arith_div_then_mod.vuma — (216 / 2) % 200 = 108 % 200 = 108
// Expected exit code: 108
//
// Two-stage arithmetic: divide then modulo. 216 / 2 = 108 (integer
// division); 108 % 200 = 108. All operands kept as i32 locals.
// Straight-line arithmetic. Distinct from s78_arith_div_then_mod
// (3), s74_arith_div_then_mod (2) and s72_arith_div_then_mod (1).
fn main() -> i32 {
    a: i32 = 216;
    b: i32 = 2;
    c: i32 = 200;
    d: i32 = a / b;        // 108
    r: i32 = d % c;        // 108
    return r;
}
