// s20_arith_mul_then_mod.vuma — (17 * 9) % 20 = 153 % 20 = 13
// Expected exit code: 13
//
// Two-stage computation: multiply then modulo. (17 * 9) = 153;
// 153 % 20 = 13. All operands loaded into u32 variables first.
// Distinct from s17_arith_mul_then_sub (mul-then-sub) and
// s14_arith_sub_then_mul (sub-then-mul).

fn main() -> i32 {
    a: u32 = 17;
    b: u32 = 9;
    d: u32 = 20;
    p: u32 = a * b;       // 153
    r: u32 = p % d;       // 13
    return r;
}
