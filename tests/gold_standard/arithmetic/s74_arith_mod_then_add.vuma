// s74_arith_mod_then_add.vuma — (255 % 50) + 206 = 5 + 206 = 211
// Expected exit code: 211
//
// Two-stage arithmetic: modulus then add. 255 % 50 = 5 (255 = 5*50
// + 5); 5 + 206 = 211. All operands kept as i32 locals. Straight-
// line arithmetic. Distinct from s70_arith_mul_then_mod (100),
// s66_arith_add_then_mod (10) and s62_arith_add_then_div (50).
fn main() -> i32 {
    a: i32 = 255;
    b: i32 = 50;
    c: i32 = 206;
    m: i32 = a % b;        // 5
    r: i32 = m + c;        // 211
    return r;
}
