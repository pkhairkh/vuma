// s81_arith_add_then_mod.vuma — (210 + 50) % 220 = 260 % 220 = 40
// Expected exit code: 40
//
// Two-stage arithmetic: add then modulo. 210 + 50 = 260;
// 260 % 220 = 40. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_add_then_div (11),
// s77_arith_add_then_mod (73) and s76_arith_add_then_mod (28).
fn main() -> i32 {
    a: i32 = 210;
    b: i32 = 50;
    c: i32 = 220;
    s: i32 = a + b;        // 260
    r: i32 = s % c;        // 40
    return r;
}
