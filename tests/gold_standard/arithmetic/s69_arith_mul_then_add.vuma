// s69_arith_mul_then_add.vuma -- 12 * 10 + 25 = 120 + 25 = 145
// Expected exit code: 145
//
// Two-stage arithmetic: multiply then add. 12 * 10 = 120; 120 + 25 =
// 145. All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s66_arith_add_then_mod (10), s65_arith_div_then_sub
// (40) and s63_arith_add_then_mul (170).
fn main() -> i32 {
    a: i32 = 12;
    b: i32 = 10;
    c: i32 = 25;
    p: i32 = a * b;        // 120
    r: i32 = p + c;        // 145
    return r;
}
