// s51_arith_add_mod_then_add.vuma — (120 + 70) % 100 + 50 = 90 + 50 = 140
// Expected exit code: 140
//
// Three-stage u32 computation: add, modulo, add. 120 + 70 = 190;
// 190 % 100 = 90; 90 + 50 = 140. All operands loaded into u32
// variables first. Straight-line arithmetic. Distinct from
// s50_arith_div_then_add (130) and s47_arith_div_mod_add (51).

fn main() -> i32 {
    a: u32 = 120;
    b: u32 = 70;
    c: u32 = 100;
    d: u32 = 50;
    s: u32 = a + b;        // 190
    m: u32 = s % c;        // 90
    r: u32 = m + d;        // 140
    return r;
}
