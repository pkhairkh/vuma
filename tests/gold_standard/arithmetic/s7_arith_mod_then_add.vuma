// s7_arith_mod_then_add.vuma — (17 % 5) + 100 = 2 + 100 = 102
// Expected exit code: 102
//
// Modulo then addition. 17 % 5 = 2; 2 + 100 = 102. All values
// inside U8 range. Distinct from s5_arith_div_then_mod (div + mod
// pair, no add) and s4_arith_mod_then_mul (mod then mul, no add).

fn main() -> i32 {
    n: u32 = 17;
    d: u32 = 5;
    base: u32 = 100;
    m: u32 = n % d;        // 2
    total: u32 = m + base; // 102
    return total;
}
