// s49_nl_6x3_count.vuma — 6x3 nested loop, count = 18
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 6 iterations, inner loop 3 iterations each -> 6*3 = 18
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s46_nl_4x3_count (12) and s43_nl_3x6_count (18,
// same total but different dims).
// Expected exit code: 18

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
