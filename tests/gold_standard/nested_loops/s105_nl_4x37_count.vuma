// s105_nl_4x37_count.vuma — 4x37 nested loop, count = 4*37 = 148
// Expected exit code (correct): 148
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Outer loop runs 4 iterations, inner loop runs 37 iterations each -> 4*37 = 148 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 148 once fixed.
// Distinct from s102_nl_5x25_count (125), s101_nl_4x15_count (60), s100_nl_2x59_count (118).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..37 {
            count = count + 1;
        }
    }
    return count;
}
