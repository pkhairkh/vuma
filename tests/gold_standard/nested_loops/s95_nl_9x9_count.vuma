// s95_nl_9x9_count.vuma — 9x9 nested loop, count = 81
// Expected exit code (correct): 81
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 9 iterations, inner loop 9 iterations each ->
// 9*9 = 81 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_4x13_count (52),
// s90_nl_4x21_count (84) and s82_nl_2x21_count (42).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..9 {
        for j in 0..9 {
            count = count + 1;
        }
    }
    return count;
}
