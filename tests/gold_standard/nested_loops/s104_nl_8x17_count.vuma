// s104_nl_8x17_count.vuma — 8x17 nested loop, count = 8*17 = 136
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Expected exit code: 136
// Outer loop runs 8 iterations, inner loop runs 17 iterations each -> 8*17 = 136 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 136 once fixed.
// Distinct from s102_nl_2x53_count (106), s102_nl_2x61_count (122), s102_nl_2x62_count (124), s102_nl_5x25_count (125).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..8 {
        for j in 0..17 {
            count = count + 1;
        }
    }
    return count;
}
