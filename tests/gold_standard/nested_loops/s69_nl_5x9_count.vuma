// s69_nl_5x9_count.vuma -- 5x9 nested loop, count = 45
// Expected exit code (correct): 45
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// Outer loop 5 iterations, inner loop 9 iterations each -> 5*9 = 45
// total. Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s66_nl_5x6_count (30), s65_nl_5x7_count (35) and s64_nl_5x3_count
// (15).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..9 {
            count = count + 1;
        }
    }
    return count;
}
