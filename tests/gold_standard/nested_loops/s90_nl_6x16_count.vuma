// s90_nl_6x16_count.vuma — 6x16 nested loop, count = 96
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 6 iterations, inner loop 16 iterations each ->
// 6*16 = 96 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s86_nl_3x11_count (33), s82_nl_3x16_count (48)
// and s78_nl_3x19_count (57).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..16 {
            count = count + 1;
        }
    }
    return count;
}
