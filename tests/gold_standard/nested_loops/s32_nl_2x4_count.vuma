// s32_nl_2x4_count.vuma - 2x4 nested loop, count = 8
// Expected exit code (correct): 8
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Outer * inner iterations give a total count of 8. On the current backend
// for-body assignments don't propagate, so count stays 0. Will exit 8 once
// the loop-body drop bug is fixed. Distinct from s30_nl_2x4_count (2x4 = 8)
// and s26_nl_2x4_count (different set).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
