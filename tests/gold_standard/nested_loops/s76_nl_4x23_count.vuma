// s76_nl_4x23_count.vuma — 4x23 nested loop, count = 92
// Expected exit code (correct): 92
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 23 iterations each ->
// 4*23 = 92 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s74_nl_4x13_count (52), s73_nl_5x13_count
// (65) and s72_nl_6x8_count (48).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..23 {
            count = count + 1;
        }
    }
    return count;
}
