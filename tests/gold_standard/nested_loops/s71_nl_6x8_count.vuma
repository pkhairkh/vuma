// s71_nl_6x8_count.vuma — 6x8 nested loop, count = 48
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 6 iterations, inner loop 8 iterations each ->
// 6*8 = 48 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s69_nl_6x7_count (42), s70_nl_2x11_count
// (22) and s66_nl_4x5_count (20).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..8 {
            count = count + 1;
        }
    }
    return count;
}
