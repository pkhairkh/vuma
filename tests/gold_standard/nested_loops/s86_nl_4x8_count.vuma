// s86_nl_4x8_count.vuma — 4x8 nested loop, count = 32
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 8 iterations each ->
// 4*8 = 32 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s82_nl_6x9_count (54), s78_nl_5x17_count
// (85) and s74_nl_5x11_count (55).
// Expected exit code: 32
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..8 {
            count = count + 1;
        }
    }
    return count;
}
