// s95_nl_2x43_count.vuma — 2x43 nested loop, count = 86
// Expected exit code (correct): 86
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 43 iterations each ->
// 2*43 = 86 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_5x7_count (35),
// s90_nl_5x22_count (110) and s82_nl_6x9_count (54).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..43 {
            count = count + 1;
        }
    }
    return count;
}
