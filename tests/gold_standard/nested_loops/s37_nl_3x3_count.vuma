// s37_nl_3x3_count.vuma — 3x3 nested loop, count = 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Nested for-loop produces 9 iterations total. Known
// "for-body assignments don't propagate" bug keeps the result at 0. Will exit
// 9 once fixed.
// Distinct from s33_nl_3x4_count (3x4=12) and s30_nl_3x3_count (3x3=9).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
