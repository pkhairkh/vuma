// s43_nl_3x6_count.vuma — 3x6 nested loop, count = 18
// Expected exit code (correct): 18
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 6 iterations each -> 3*6 = 18
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s42_nl_2x6_count (12) and s38_nl_3x4_count (12,
// same total but different dims).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..6 {
            count = count + 1;
        }
    }
    return count;
}
