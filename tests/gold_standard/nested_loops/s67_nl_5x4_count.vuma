// s67_nl_5x4_count.vuma — 5x4 nested loop, count = 20
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 4 iterations each ->
// 5*4 = 20 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s66_nl_5x6_count (30),
// s62_nl_4x5_count (20) and s58_nl_5x5_count (25).
// Expected exit code: 20
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
