// s74_nl_4x13_count.vuma — 4x13 nested loop, count = 52
// Expected exit code (correct): 52
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 13 iterations each ->
// 4*13 = 52 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_4x9_count (36), s66_nl_4x7_count
// (28) and s62_nl_4x5_count (20).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
