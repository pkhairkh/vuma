// s70_nl_4x9_count.vuma — 4x9 nested loop, count = 36
// Expected exit code (correct): 36
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 9 iterations each ->
// 4*9 = 36 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s66_nl_4x7_count (28), s65_nl_4x8_count
// (32) and s62_nl_4x5_count (20).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..9 {
            count = count + 1;
        }
    }
    return count;
}
