// s102_nl_5x25_count.vuma — 5x25 nested loop, count = 5*25 = 125
// Expected exit code (correct): 125
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop runs 5 iterations, inner loop runs 25 iterations each -> 5*25 = 125 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 125 once fixed.
// Distinct from s101_nl_2x31_count (62), s101_nl_3x17_count (51), s101_nl_4x15_count (60).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..25 {
            count = count + 1;
        }
    }
    return count;
}
