// s7_nl_2x3_count.vuma — 2x3 nested loop, count = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer 2 iterations, inner 3 each -> 6 total. Counter increments
// by 1 each inner iteration. Known "for-body assignments don't
// propagate" bug keeps count at 0. Distinct from s5_nl_2x3_acc
// (2x3, acc accumulates 5s) and s4_nl_2x3_count (already exists
// with same shape; this one is the s7 regression-guard variant
// documented to track the bug).
// Expected exit code: 6

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
