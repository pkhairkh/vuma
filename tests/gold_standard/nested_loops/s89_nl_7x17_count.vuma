// s89_nl_7x17_count.vuma — 7x17 nested loop, count = 119
// Expected exit code (correct): 119
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 17 iterations each ->
// 7*17 = 119 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s86_nl_2x15_count (30),
// s82_nl_2x21_count (42) and s78_nl_3x19_count (57).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..17 {
            count = count + 1;
        }
    }
    return count;
}
