// s10_nl_5x1_count.vuma — 5x1 nested loop, count = 5
// Expected exit code (correct): 5
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 1 iteration each -> 5 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s6_nl_4x1_count (4x1) and s5_nl_3x2_count (3x2).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..1 {
            count = count + 1;
        }
    }
    return count;
}
