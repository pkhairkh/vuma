// s81_nl_5x13_count.vuma — 5x13 nested loop, count = 65
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 13 iterations each ->
// 5*13 = 65 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_5x17_count (85),
// s77_nl_5x16_count (80) and s76_nl_2x63_count (126).
// Expected exit code: 65
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
