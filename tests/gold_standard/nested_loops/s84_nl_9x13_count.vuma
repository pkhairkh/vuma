// s84_nl_9x13_count.vuma — 9x13 nested loop, count = 117
// Expected exit code (correct): 117
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 9 iterations, inner loop 13 iterations each ->
// 9*13 = 117 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s82_nl_9x3_count (27), s78_nl_5x19_count
// (95) and s74_nl_2x19_count (38).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..9 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
