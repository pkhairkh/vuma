// s90_nl_4x21_count.vuma — 4x21 nested loop, count = 84
// Expected exit code (correct): 84
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 21 iterations each ->
// 4*21 = 84 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s86_nl_2x15_count (30), s82_nl_2x21_count (42)
// and s78_nl_3x19_count (57).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..21 {
            count = count + 1;
        }
    }
    return count;
}
