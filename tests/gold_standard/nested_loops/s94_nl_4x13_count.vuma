// s94_nl_4x13_count.vuma — 4x13 nested loop, count = 52
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 13 iterations each ->
// 4*13 = 52 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_4x21_count (84), s86_nl_4x8_count (32)
// and s82_nl_3x16_count (48).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
