// s83_nl_3x72_count.vuma — 3x72 nested loop, count = 216
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 72 iterations each ->
// 3*72 = 216 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_3x19_count (57), s74_nl_4x13_count
// (52) and s72_nl_3x9_count (27).
// Expected exit code: 216
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..72 {
            count = count + 1;
        }
    }
    return count;
}
