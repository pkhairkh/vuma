// s70_nl_3x7_count.vuma — 3x7 nested loop, count = 21
// Expected exit code (correct): 21
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 7 iterations each ->
// 3*7 = 21 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s66_nl_3x6_count (18), s65_nl_3x11_count
// (33) and s62_nl_3x3_count (9).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..7 {
            count = count + 1;
        }
    }
    return count;
}
