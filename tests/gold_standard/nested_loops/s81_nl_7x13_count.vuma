// s81_nl_7x13_count.vuma — 7x13 nested loop, count = 91
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 13 iterations each ->
// 7*13 = 91 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_5x19_count (95),
// s77_nl_6x11_count (66) and s76_nl_7x11_count (77).
// Expected exit code: 91
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
