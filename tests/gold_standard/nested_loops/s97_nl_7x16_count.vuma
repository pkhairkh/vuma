// s97_nl_7x16_count.vuma — 7x16 nested loop, count = 112
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 16 iterations each
// -> 7*16 = 112 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate"
// bug keeps count at 0.
// Distinct from s94_nl_2x10_count (20), s90_nl_3x44_count (132), s86_nl_2x15_count (30).
// Expected exit code: 112
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..16 {
            count = count + 1;
        }
    }
    return count;
}
