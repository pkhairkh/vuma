// s52_nl_5x6_count.vuma — 5x6 nested loop, count = 30
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 6 iterations each -> 5*6 = 30
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s50_nl_3x7_count (21) and s47_nl_5x3_count (15).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..6 {
            count = count + 1;
        }
    }
    return count;
}
