// s15_nl_2x6_count.vuma — 2x6 nested loop, count = 12
// Expected exit code (correct): 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 6 iterations each -> 2*6 = 12 total
// iterations. Counter is a scalar accumulator updated inside the inner loop
// body. Known "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s14_nl_2x5_sum (2x5 = 10) and s12_nl_2x5_count (2x5 = 10).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..6 {
            count = count + 1;
        }
    }
    return count;
}
