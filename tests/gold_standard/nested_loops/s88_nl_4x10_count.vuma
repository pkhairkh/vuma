// s88_nl_4x10_count.vuma — 4x10 nested loop, count = 40
// Expected exit code (correct): 40
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 10 iterations each ->
// 4*10 = 40 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate"
// bug keeps count at 0. Distinct from s86_nl_4x8_count
// (32), s82_nl_6x9_count (54) and s78_nl_5x17_count (85).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..10 {
            count = count + 1;
        }
    }
    return count;
}
