// s61_nl_5x5_count.vuma — 5x5 nested loop, count = 25
// Expected exit code (correct): 25
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Outer loop 5 iterations, inner loop 5 iterations each -> 5*5 = 25
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s58_nl_2x3_count (6), s58_nl_3x4_count (12) and
// s58_nl_4x4_count (16).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..5 {
            count = count + 1;
        }
    }
    return count;
}
