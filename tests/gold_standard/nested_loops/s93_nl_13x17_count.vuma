// s93_nl_13x17_count.vuma — 13x17 nested loop, count = 221
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 13 iterations, inner loop 17 iterations each ->
// 13*17 = 221 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_4x21_count (84), s82_nl_6x9_count (54) and s78_nl_5x19_count (95).
// Expected exit code: 221
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..13 {
        for j in 0..17 {
            count = count + 1;
        }
    }
    return count;
}
