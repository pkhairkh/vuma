// s35_nl_4x5_count.vuma — 4x5 nested loop, count = 20
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 5 iterations each -> 4*5 = 20
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s34_nl_2x4_count (2x4 = 8) and s30_nl_3x3_count
// (3x3 = 9).
// Expected exit code: 20

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..5 {
            count = count + 1;
        }
    }
    return count;
}
