// s7_nl_3x3_count.vuma — 3x3 nested loop, count = 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer 3 iterations, inner 3 each -> 9 total. Counter increments
// by 1 each inner iteration. Known "for-body assignments don't
// propagate" bug keeps count at 0. Distinct from s5_nl_3x2_count
// (3x2 = 6) and s6_nl_3x3_with_j (sums j*j, not counts).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
