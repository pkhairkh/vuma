// nl_sum_2d.vuma — sum of 2x5 grid of 1s
// Expected exit code (correct): 10
// Expected exit code (current buggy backend): 0
//
// Iterates a 2x5 grid (10 cells), each cell contributing value 1 to the
// running sum.
// EXPECTED TO FAIL until the for-body assignment propagation bug is fixed.

fn main() -> i32 {
    sum: u32 = 0;
    for i in 0..2 {
        for j in 0..5 {
            sum = sum + 1;
        }
    }
    return sum;
}
