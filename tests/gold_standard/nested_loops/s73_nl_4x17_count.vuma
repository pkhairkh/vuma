// s73_nl_4x17_count.vuma — 4x17 nested loop, count = 68
// Expected exit code (correct): 68
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 17 iterations each ->
// 4*17 = 68 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_4x9_count (36), s69_nl_4x11_count
// (44) and s74_nl_4x13_count (52).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..17 {
            count = count + 1;
        }
    }
    return count;
}
