// s6_nl_2x2_count_diff.vuma — 2x2 nested loop, count = 4
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 2 iterations -> 4 total. Counter
// increments by 1 each inner iteration. Known "for-body assignments
// don't propagate" bug keeps counter at 0. Distinct from
// s5_nl_2x2_product (sums j, not count) and s5_nl_3x2_count.

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
