// s97_nl_3x35_count.vuma — 3x35 nested loop, count = 105
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 35 iterations each
// -> 3*35 = 105 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate"
// bug keeps count at 0.
// Distinct from s94_nl_2x10_count (20), s90_nl_3x44_count (132), s86_nl_2x15_count (30).
// Expected exit code: 105
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..35 {
            count = count + 1;
        }
    }
    return count;
}
