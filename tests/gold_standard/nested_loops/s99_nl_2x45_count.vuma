// s99_nl_2x45_count.vuma — 2x45 nested loop, count = 90
// Expected exit code (correct): 90
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 45 iterations each ->
// 2*45 = 90 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s95_nl_2x43_count (86), s91_nl_3x31_count (93)
// and s87_nl_2x13_count (26).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..45 {
            count = count + 1;
        }
    }
    return count;
}
