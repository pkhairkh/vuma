// s6_nl_4x1_count.vuma — 4x1 nested loop, count = 4
// Expected exit code (correct): 4
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 1 iteration -> 4 total. Counter
// increments by 1 each inner iteration. Even with a single-iteration
// inner loop, the body-assignment bug keeps count at 0. Distinct from
// s5_nl_3x2_count (3x2).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..1 {
            count = count + 1;
        }
    }
    return count;
}
