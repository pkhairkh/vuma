// nl_2x2.vuma — 2x2 nested loop, count iterations
// Expected exit code (correct): 4
// Expected exit code (current buggy backend): 0
//
// Outer loop runs 2 iterations, inner loop runs 2 iterations each →
// 2*2 = 4 total iterations. The counter is a scalar accumulator updated
// inside the inner loop body.
//
// This test is EXPECTED TO FAIL on the current x86_64 backend: the known
// "for-body assignments don't propagate" bug means the `count = count + 1`
// inside the inner loop never updates `count` outside the loop, so the
// program returns 0 instead of 4. It will pass once that bug is fixed.

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
