// s24_nl_2x3_count.vuma — 2x3 nested loop, count = 6
// Expected exit code (correct): 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 3 iterations each -> 2*3 = 6
// total iterations. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s22_nl_2x2_count (2x2 = 4) and s18_nl_2x3_count
// (same dims, different operand framing).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
