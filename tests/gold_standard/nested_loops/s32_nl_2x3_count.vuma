// s32_nl_2x3_count.vuma - 2x3 nested loop, count = 6
// Expected exit code (correct): 6
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Outer * inner iterations give a total count of 6. On the current backend
// for-body assignments don't propagate, so count stays 0. Will exit 6 once
// the loop-body drop bug is fixed. Distinct from s30_nl_2x3_count (2x3 = 6)
// and s26_nl_2x3_count (different set).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
