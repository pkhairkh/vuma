// s26_nl_3x3_acc.vuma — 3x3 nested loop, count = 9
// Expected exit code (correct): 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 3 iterations each -> 3*3 = 9 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s22_nl_3x3_count (3x3 = 9, same dims, different name) and
// s16_nl_3x4_sum (3x4 = 12).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
