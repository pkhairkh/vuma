// s77_nl_6x11_count.vuma — 6x11 nested loop, count = 66
// Expected exit code (correct): 66
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 6 iterations, inner loop 11 iterations each ->
// 6*11 = 66 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_4x9_count (36), s66_nl_4x7_count
// (28) and s74_nl_4x13_count (52).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
