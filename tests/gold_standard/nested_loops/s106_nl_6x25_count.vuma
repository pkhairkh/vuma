// s106_nl_6x25_count.vuma — 6x25 nested loop, count = 6*25 = 150
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop runs 6 iterations, inner loop runs 25 iterations each -> 6*25 = 150 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 150 once fixed.
// Distinct from s102_nl_5x25_count (125), s101_nl_6x6_count (36), s100_nl_11x11_count (121).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..25 {
            count = count + 1;
        }
    }
    return count;
}
