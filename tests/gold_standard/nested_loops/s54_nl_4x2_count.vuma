// s54_nl_4x2_count.vuma — 4x2 nested loop, count = 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 2 iterations each -> 4*2 = 8
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s50_nl_4x4_count (16) and s49_nl_4x7_count (28).
// Expected exit code: 8

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
