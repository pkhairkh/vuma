// s105_nl_6x23_count.vuma — 6x23 nested loop, count = 6*23 = 138
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Outer loop runs 6 iterations, inner loop runs 23 iterations each -> 6*23 = 138 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 138 once fixed.
// Distinct from s102_nl_2x62_count (124), s101_nl_3x17_count (51), s100_nl_3x36_count (108).
// Expected exit code: 138
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..23 {
            count = count + 1;
        }
    }
    return count;
}
