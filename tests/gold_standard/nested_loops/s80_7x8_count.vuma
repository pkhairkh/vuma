// s80_nl_7x8_count.vuma — 7x8 nested loop, count = 56
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 8 iterations each ->
// 7*8 = 56 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug keeps
// count at 0. Distinct from s78_nl_3x19_count (57),
// s74_nl_4x13_count (52) and s73_nl_3x17_count (51).
// Expected exit code: 56
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..8 {
            count = count + 1;
        }
    }
    return count;
}
