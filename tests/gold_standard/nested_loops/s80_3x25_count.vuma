// s80_nl_3x25_count.vuma — 3x25 nested loop, count = 75
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 25 iterations each ->
// 3*25 = 75 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug keeps
// count at 0. Distinct from s78_nl_5x19_count (95),
// s74_nl_4x13_count (52) and s73_nl_3x17_count (51).
// Expected exit code: 75
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..25 {
            count = count + 1;
        }
    }
    return count;
}
