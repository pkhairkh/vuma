// s100_nl_2x59_count.vuma — 2x59 nested loop, count = 118
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 59 iterations each
// -> 2*59 = 118 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate"
// bug keeps count at 0.
// Distinct from s97_nl_2x51_count (102), s94_nl_2x10_count (20), s90_nl_3x44_count (132).
// Expected exit code: 118
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..59 {
            count = count + 1;
        }
    }
    return count;
}
