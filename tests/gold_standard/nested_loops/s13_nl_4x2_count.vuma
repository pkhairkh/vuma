// s13_nl_4x2_count.vuma — 4x2 nested loop, count iterations = 8
// Expected exit code (correct): 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 2 iterations each -> 4*2 = 8
// total iterations. Counter is a scalar accumulator updated inside
// the inner loop body. Known "for-body assignments don't propagate"
// bug keeps count at 0. Distinct from s9_nl_2x4_count (2x4 = 8,
// swapped dimensions) and s6_nl_4x1_count (4x1 = 4).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
