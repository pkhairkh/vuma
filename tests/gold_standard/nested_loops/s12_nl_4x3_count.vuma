// s12_nl_4x3_count.vuma — 4x3 nested loop, count = 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 3 iterations each -> 12 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s9_nl_4x2_acc_outer (4x2) and s13_nl_4x2_count (4x2).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
