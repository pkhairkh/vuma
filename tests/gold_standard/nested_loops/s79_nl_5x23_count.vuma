// s79_nl_5x23_count.vuma — 5x23 nested loop, count = 115
// Observed on current x86_64 backend: 0 (FAIL — known bug: for-body assignments don't propagate)
//
// Outer loop 5 iterations, inner loop 23 iterations each ->
// 5*23 = 115 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s78_nl_3x19_count (57),
// s77_nl_3x19_count (4) and s76_nl_3x19_count (3).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..23 {
            count = count + 1;
        }
    }
    return count;
}
