// s69_nl_4x11_count.vuma -- 4x11 nested loop, count = 44
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// Outer loop 4 iterations, inner loop 11 iterations each -> 4*11 = 44
// total. Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s66_nl_4x7_count (28), s65_nl_4x8_count (32) and s64_nl_4x4_count
// (16).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
