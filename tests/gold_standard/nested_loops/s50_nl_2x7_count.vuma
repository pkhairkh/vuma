// s50_nl_2x7_count.vuma — 2x7 nested loop, count = 14
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 7 iterations each -> 2*7 = 14
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s46_nl_2x4_count (8) and s43_nl_5x4_count (20).
// Expected exit code: 14

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..7 {
            count = count + 1;
        }
    }
    return count;
}
