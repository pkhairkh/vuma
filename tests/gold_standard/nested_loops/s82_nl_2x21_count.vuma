// s82_nl_2x21_count.vuma — 2x21 nested loop, count = 42
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 21 iterations each ->
// 2*21 = 42 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_3x19_count (57), s74_nl_4x13_count
// (52) and s72_nl_3x9_count (27).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..21 {
            count = count + 1;
        }
    }
    return count;
}
