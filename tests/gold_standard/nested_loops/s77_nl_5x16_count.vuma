// s77_nl_5x16_count.vuma — 5x16 nested loop, count = 80
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 16 iterations each ->
// 5*16 = 80 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_3x7_count (21), s66_nl_3x5_count
// (15) and s74_nl_2x23_count (46).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..16 {
            count = count + 1;
        }
    }
    return count;
}
