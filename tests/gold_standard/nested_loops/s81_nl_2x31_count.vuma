// s81_nl_2x31_count.vuma — 2x31 nested loop, count = 62
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 31 iterations each ->
// 2*31 = 62 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_3x19_count (57),
// s77_nl_4x18_count (72) and s76_nl_2x29_count (58).
// Expected exit code: 62
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..31 {
            count = count + 1;
        }
    }
    return count;
}
