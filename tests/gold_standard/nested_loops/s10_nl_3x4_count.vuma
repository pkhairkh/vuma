// s10_nl_3x4_count.vuma — 3x4 nested loop, count = 12
// Expected exit code (correct): 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 4 iterations each -> 12 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s4_nl_3x3_sum (3x3, sums j) and s5_nl_2x3_acc (2x3, sums i+j).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
