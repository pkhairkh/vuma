// s73_nl_5x13_count.vuma — 5x13 nested loop, count = 65
// Expected exit code (correct): 65
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 13 iterations each ->
// 5*13 = 65 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_5x8_count (40), s69_nl_5x9_count
// (45) and s72_nl_5x11_count (55).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
