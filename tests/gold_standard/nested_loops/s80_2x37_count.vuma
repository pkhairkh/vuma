// s80_nl_2x37_count.vuma — 2x37 nested loop, count = 74
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 37 iterations each ->
// 2*37 = 74 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug keeps
// count at 0. Distinct from s78_nl_5x17_count (85),
// s74_nl_4x13_count (52) and s73_nl_3x17_count (51).
// Expected exit code: 74
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..37 {
            count = count + 1;
        }
    }
    return count;
}
