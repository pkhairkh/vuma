// s19_nl_3x3_sum.vuma — 3x3 nested loop, acc += 5 each, sum = 45
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 3 iterations each -> 9 total
// iterations. Accumulator adds 5 each inner iteration -> 9 * 5 = 45.
// Known "for-body assignments don't propagate" bug keeps acc at 0.
// Distinct from s18_nl_3x3_count (3x3 = 9, count) and
// s14_nl_3x3_count (3x3 = 9, count).

fn main() -> i32 {
    acc: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            acc = acc + 5;
        }
    }
    return acc;
}
