// s62_nl_2x4_count.vuma — 2x4 nested loop, count = 8
// Expected exit code (correct): 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Outer loop 2 iterations, inner loop 4 iterations each -> 2*4 = 8
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s51_nl_2x5_count (10), s58_nl_2x3_count (6) and s55_
// nl_2x3_count (6).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
