// nl_grid_sum.vuma — 3x2 grid, all cells = 1, return sum
// Expected exit code: 6
//
// Iterates a 3x2 grid (6 cells), each contributing 1 to the running sum.
// NOW PASSING until the for-body assignment propagation bug is fixed.

fn main() -> i32 {
    sum: u32 = 0;
    for i in 0..3 {
        for j in 0..2 {
            sum = sum + 1;
        }
    }
    return sum;
}
