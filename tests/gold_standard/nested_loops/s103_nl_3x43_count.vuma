// s103_nl_3x43_count.vuma — 3x43 nested loop, count = 3*43 = 129
// Expected exit code (correct): 129
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop runs 3 iterations, inner loop runs 43 iterations each -> 3*43 = 129 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 129 once fixed.
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..43 {
            count = count + 1;
        }
    }
    return count;
}
