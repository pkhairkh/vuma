// s96_nl_2x18_count.vuma — 2x18 nested loop, count = 36
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 18 iterations each ->
// 2*18 = 36 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_2x10_count (20), s90_nl_3x44_count (132)
// and s86_nl_2x15_count (30).
// Expected exit code: 36
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..18 {
            count = count + 1;
        }
    }
    return count;
}
