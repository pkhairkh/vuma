// s12_nl_3x5_count.vuma — 3x5 nested loop, count = 15
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 5 iterations each -> 15 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s10_nl_3x4_count (3x4 = 12) and s13_nl_3x3_count (3x3 = 9).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..5 {
            count = count + 1;
        }
    }
    return count;
}
