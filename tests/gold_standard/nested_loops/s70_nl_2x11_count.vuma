// s70_nl_2x11_count.vuma — 2x11 nested loop, count = 22
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 11 iterations each ->
// 2*11 = 22 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s66_nl_2x7_count (14), s65_nl_2x13_count
// (26) and s62_nl_2x4_count (8).
// Expected exit code: 22
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
