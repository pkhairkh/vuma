// s34_nl_2x3_count.vuma — 2x3 nested loop, count = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 3 iterations each -> 2*3 = 6
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s30_nl_3x2_count (3x2 = 6, transposed dims) and
// s27_nl_2x3_count (2x3 = 6, same dims, different op).
// Expected exit code: 6

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
