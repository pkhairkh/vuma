// s49_nl_4x7_count.vuma — 4x7 nested loop, count = 28
// Expected exit code (correct): 28
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 7 iterations each -> 4*7 = 28
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s46_nl_3x5_count (15) and s43_nl_4x6_count (24).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..7 {
            count = count + 1;
        }
    }
    return count;
}
