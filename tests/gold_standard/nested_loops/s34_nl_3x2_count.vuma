// s34_nl_3x2_count.vuma — 3x2 nested loop, count = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 2 iterations each -> 3*2 = 6
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s30_nl_2x2_count (2x2 = 4) and s27_nl_3x2_sum
// (3x2, sum-variant).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
