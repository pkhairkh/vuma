// s86_nl_3x11_count.vuma — 3x11 nested loop, count = 33
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 11 iterations each ->
// 3*11 = 33 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s82_nl_3x16_count (48), s78_nl_3x23_count
// (69) and s74_nl_3x17_count (51).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
