// s55_nl_5x4_count.vuma — 5x4 nested loop, count = 20
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 4 iterations each -> 5*4 = 20
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s54_nl_3x4_count (12) and s53_nl_5x3_count (15).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
