// s87_nl_2x13_count.vuma — 2x13 nested loop, count = 26
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 13 iterations each ->
// 2*13 = 26 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s86_nl_2x15_count (30), s82_nl_2x21_count
// (42) and s78_nl_3x19_count (57).
// Expected exit code: 26
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
