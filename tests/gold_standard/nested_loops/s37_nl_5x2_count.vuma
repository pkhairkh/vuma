// s37_nl_5x2_count.vuma — 5x2 nested loop, count = 10
// Expected exit code (correct): 10
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Nested for-loop produces 10 iterations total. Known
// "for-body assignments don't propagate" bug keeps the result at 0. Will exit
// 10 once fixed.
// Distinct from s33_nl_2x5_count (2x5=10) and s30_nl_2x4_count (2x4=8).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
