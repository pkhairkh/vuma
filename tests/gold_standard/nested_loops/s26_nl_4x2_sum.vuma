// s26_nl_4x2_sum.vuma — 4x2 nested loop, count = 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 2 iterations each -> 4*2 = 8 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s22_nl_2x4_count (2x4 = 8, transposed dims) and s16_nl_4x3_acc (4x3 = 12).
// Expected exit code: 8

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
