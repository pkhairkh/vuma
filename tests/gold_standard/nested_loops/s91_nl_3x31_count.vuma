// s91_nl_3x31_count.vuma — 3x31 nested loop, count = 93
// Expected exit code (correct): 93
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 31 iterations each ->
// 3*31 = 93 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_3x44_count (132), s86_nl_5x5_count (25)
// and s82_nl_9x3_count (27).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..31 {
            count = count + 1;
        }
    }
    return count;
}
