// s75_nl_3x19_count.vuma — 3x19 nested loop, count = 57
// Expected exit code (correct): 57
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 19 iterations each ->
// 3*19 = 57 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s74_nl_2x23_count (46), s70_nl_4x9_count
// (36) and s66_nl_4x7_count (28).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..19 {
            count = count + 1;
        }
    }
    return count;
}
