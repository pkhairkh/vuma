// nl_4x4.vuma — 4x4 nested loop, count iterations
// Expected exit code: 16
//
// 4*4 = 16 total iterations of an inner-loop counter.
// NOW PASSING until the for-body assignment propagation bug is fixed.

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
