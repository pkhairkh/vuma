// s4_nl_3x3_sum.vuma — 3x3 nested loop, sum inner index = (0+1+2)*3 = 9
// Expected exit code (correct): 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 3 iterations each. Each inner
// iteration adds the inner index j to the accumulator. j takes
// values 0,1,2 in each outer iteration, so the sum is
// (0+1+2) * 3 = 9. Known "for-body assignments don't propagate" bug
// means acc stays 0 → exit 0.

fn main() -> i32 {
    acc: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            acc = acc + j;
        }
    }
    return acc;
}
