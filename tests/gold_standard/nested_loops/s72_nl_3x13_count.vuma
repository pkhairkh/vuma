// s72_nl_3x13_count.vuma — 3x13 nested loop, count = 39
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 13 iterations each ->
// 3*13 = 39 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_3x7_count (21), s69_nl_4x11_count
// (44) and s66_nl_3x6_count (18).
// Expected exit code: 39
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
