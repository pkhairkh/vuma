// s83_nl_4x55_count.vuma — 4x55 nested loop, count = 220
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 55 iterations each ->
// 4*55 = 220 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_5x17_count (85), s74_nl_3x17_count
// (51) and s72_nl_3x9_count (27).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..55 {
            count = count + 1;
        }
    }
    return count;
}
