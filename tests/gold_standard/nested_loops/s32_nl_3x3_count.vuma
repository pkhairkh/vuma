// s32_nl_3x3_count.vuma - 3x3 nested loop, count = 9
// Expected exit code (correct): 9
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Outer * inner iterations give a total count of 9. On the current backend
// for-body assignments don't propagate, so count stays 0. Will exit 9 once
// the loop-body drop bug is fixed. Distinct from s30_nl_3x3_count (3x3 = 9)
// and s26_nl_3x3_count (3x3 = 9).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
