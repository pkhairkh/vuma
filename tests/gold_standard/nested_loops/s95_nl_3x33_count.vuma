// s95_nl_3x33_count.vuma — 3x33 nested loop, count = 99
// Expected exit code (correct): 99
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 33 iterations each ->
// 3*33 = 99 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_2x10_count (20), s90_nl_3x44_count (132)
// and s82_nl_3x16_count (48).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..33 {
            count = count + 1;
        }
    }
    return count;
}
