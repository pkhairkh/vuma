// s32_nl_2x2_count.vuma - 2x2 nested loop, count = 4
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Outer * inner iterations give a total count of 4. On the current backend
// for-body assignments don't propagate, so count stays 0. Will exit 4 once
// the loop-body drop bug is fixed. Distinct from s30_nl_2x2_count (2x2 = 4)
// and s26_nl_2x2_count (2x2 = 4).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
