// s69_nl_3x9_count.vuma -- 3x9 nested loop, count = 27
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// Outer loop 3 iterations, inner loop 9 iterations each -> 3*9 = 27
// total. Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s66_nl_3x6_count (18), s65_nl_3x11_count (33) and s64_nl_3x4_count
// (12).
// Expected exit code: 27
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..9 {
            count = count + 1;
        }
    }
    return count;
}
