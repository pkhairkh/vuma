// s23_nl_3x4_count.vuma — 3x4 nested loop, count = 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 4 iterations each -> 3*4 = 12
// total iterations. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s24_nl_3x4_count (same dims, s24 framing) and
// s10_nl_3x4_count (same dims, s10 framing).
// Expected exit code: 12

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}

