// s99_nl_4x19_count.vuma — 4x19 nested loop, count = 76
// Expected exit code (correct): 76
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 19 iterations each ->
// 4*19 = 76 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s95_nl_4x15_count (60), s91_nl_5x19_count (95)
// and s87_nl_4x7_count (28).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..19 {
            count = count + 1;
        }
    }
    return count;
}
