// s85_nl_2x3_count.vuma — 2x3 nested loop, count = 6
// Expected exit code (correct): 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 3 iterations each ->
// 2*3 = 6 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s82_nl_2x21_count (42), s78_nl_3x19_count
// (57) and s74_nl_4x13_count (52).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
