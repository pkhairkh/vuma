// s74_nl_2x23_count.vuma — 2x23 nested loop, count = 46
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 23 iterations each ->
// 2*23 = 46 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_3x7_count (21), s66_nl_3x6_count
// (18) and s62_nl_3x3_count (9).
// Expected exit code: 46
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..23 {
            count = count + 1;
        }
    }
    return count;
}
