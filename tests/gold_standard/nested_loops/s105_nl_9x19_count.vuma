// s105_nl_9x19_count.vuma — 9x19 nested loop, count = 9*19 = 171
// Expected exit code (correct): 171
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Outer loop runs 9 iterations, inner loop runs 19 iterations each -> 9*19 = 171 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 171 once fixed.
// Distinct from s102_nl_2x61_count (122), s101_nl_2x31_count (62), s100_nl_2x57_count (114).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..9 {
        for j in 0..19 {
            count = count + 1;
        }
    }
    return count;
}
