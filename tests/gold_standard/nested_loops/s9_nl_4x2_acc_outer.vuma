// s9_nl_4x2_acc_outer.vuma — 4x2 nested loop, sum of i = (0+1+2+3)*2 = 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 2 iterations each. Each
// inner iteration adds the outer index i to acc. i takes values
// 0, 1, 2, 3 — each repeated twice — so the sum is
// (0+1+2+3) * 2 = 12. Known bug keeps acc at 0. Distinct from
// s6_nl_4x1_count (counts iterations, doesn't sum i).
// Expected exit code: 12

fn main() -> i32 {
    acc: u32 = 0;
    for i in 0..4 {
        for j in 0..2 {
            acc = acc + i;
        }
    }
    return acc;
}
