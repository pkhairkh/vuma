// s93_nl_7x23_count.vuma — 7x23 nested loop, count = 161
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 23 iterations each ->
// 7*23 = 161 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_6x16_count (96), s82_nl_3x16_count (48) and s78_nl_3x19_count (57).
// Expected exit code: 161
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..23 {
            count = count + 1;
        }
    }
    return count;
}
