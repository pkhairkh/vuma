// nl_countdown.vuma — nested countdown
// Expected exit code: 0
// Expected exit code (current buggy backend): nonzero (initial sum value)
//
// Outer loop runs i from 4 down to 1; inner loop runs j from i down to 1.
// The total iteration count is 4+3+2+1 = 10. The program computes
// (n - 10) where n is the accumulated count — correct result is 0.
// NOW PASSING until the while-body assignment propagation bug is fixed.

fn main() -> i32 {
    n: u32 = 0;
    i: u32 = 4;
    while i > 0 {
        j: u32 = i;
        while j > 0 {
            n = n + 1;
            j = j - 1;
        }
        i = i - 1;
    }
    ten: u32 = 10;
    return n - ten;
}
