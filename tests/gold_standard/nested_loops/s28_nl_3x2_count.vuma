// s28_nl_3x2_count.vuma — 3x2 nested loop, count = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 2 iterations each -> 3*2 = 6 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s26_nl_4x2_sum (4x2 = 8) and s22_nl_3x2_count (3x2 = 6, same dims).
// Expected exit code: 6

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
