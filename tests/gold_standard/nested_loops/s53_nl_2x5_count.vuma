// s53_nl_2x5_count.vuma — 2x5 nested loop, count = 10
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 5 iterations each -> 2*5 = 10
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s49_nl_6x3_count (18) and s50_nl_2x7_count (14).
// Expected exit code: 10

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..5 {
            count = count + 1;
        }
    }
    return count;
}
