// s30_nl_3x2_count.vuma — 3x2 nested loop, count = 6
// Expected exit code (correct): 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 2 iterations each -> 3*2 = 6 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s26_nl_3x3_acc (3x3 = 9) and s22_nl_3x2_count (3x2 = 6, same dims).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
