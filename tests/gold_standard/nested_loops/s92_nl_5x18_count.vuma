// s92_nl_5x18_count.vuma — 5x18 nested loop, count = 90
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 18 iterations each ->
// 5*18 = 90 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_5x22_count (110), s86_nl_4x8_count (32)
// and s82_nl_6x9_count (54).
// Expected exit code: 90
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..18 {
            count = count + 1;
        }
    }
    return count;
}
