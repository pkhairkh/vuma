// s82_nl_6x9_count.vuma — 6x9 nested loop, count = 54
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 6 iterations, inner loop 9 iterations each ->
// 6*9 = 54 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_5x17_count (85), s74_nl_5x11_count
// (55) and s72_nl_4x6_count (24).
// Expected exit code: 54
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..9 {
            count = count + 1;
        }
    }
    return count;
}
