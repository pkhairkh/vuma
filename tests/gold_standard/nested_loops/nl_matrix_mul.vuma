// nl_matrix_mul.vuma — 2x2 matrix multiply, return XOR checksum
// Expected exit code: 0
// Expected exit code (current buggy backend): 0 (degenerate)
//
// Computes C = A * B for 2x2 matrices where A = B = [[1,1],[1,1]].
// Resulting C = [[2,2],[2,2]], and XOR of the 4 cells is 2^2^2^2 = 0.
//
// NOTE: This test is degenerate on the current backend — both the correct
// behaviour (XOR of 2,2,2,2 = 0) and the buggy behaviour (matrix cells
// never updated, all stay 0, XOR of 0,0,0,0 = 0) yield exit code 0. It is
// included to exercise the triple-nested matrix-multiply code path
// (function calls, pointer arithmetic, inner-loop accumulators) so that
// once the loop-body assignment propagation bug is fixed, this test
// continues to pass and serves as a regression test for matrix-multiply
// codegen.

fn mat_read(mat: Address, row: u64, col: u64) -> u32 {
    offset: u64 = (row * 2 + col) * 4;
    val: u32 = *(mat + offset);
    return val;
}

fn mat_write(mat: Address, row: u64, col: u64, val: u32) {
    offset: u64 = (row * 2 + col) * 4;
    *(mat + offset) = val;
}

fn main() -> i32 {
    a = allocate(16);
    b = allocate(16);
    c = allocate(16);

    // A = [[1,1],[1,1]]
    mat_write(a, 0, 0, 1); mat_write(a, 0, 1, 1);
    mat_write(a, 1, 0, 1); mat_write(a, 1, 1, 1);

    // B = [[1,1],[1,1]]
    mat_write(b, 0, 0, 1); mat_write(b, 0, 1, 1);
    mat_write(b, 1, 0, 1); mat_write(b, 1, 1, 1);

    // Triple-nested matrix multiply: C[i][j] = sum_k A[i][k] * B[k][j]
    for i in 0..2 {
        for j in 0..2 {
            sum: u32 = 0;
            for k in 0..2 {
                prod: u32 = mat_read(a, i, k) * mat_read(b, k, j);
                sum = sum + prod;
            }
            mat_write(c, i, j, sum);
        }
    }

    // XOR checksum of all 4 cells of C
    check: u32 = 0;
    for i in 0..2 {
        for j in 0..2 {
            v: u32 = mat_read(c, i, j);
            check = check ^ v;
        }
    }

    free(a);
    free(b);
    free(c);
    return check;
}
