// s80_nl_8x8_count.vuma — 8x8 nested loop, count = 64
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 8 iterations, inner loop 8 iterations each ->
// 8*8 = 64 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug keeps
// count at 0. Distinct from s78_nl_3x23_count (69),
// s74_nl_4x13_count (52) and s73_nl_3x17_count (51).
// Expected exit code: 64
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..8 {
        for j in 0..8 {
            count = count + 1;
        }
    }
    return count;
}
