// s84_nl_10x10_count.vuma — 10x10 nested loop, count = 100
// Expected exit code (correct): 100
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 10 iterations, inner loop 10 iterations each ->
// 10*10 = 100 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s82_nl_2x21_count (42),
// s78_nl_5x17_count (85) and s74_nl_6x9_count (54).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..10 {
        for j in 0..10 {
            count = count + 1;
        }
    }
    return count;
}
