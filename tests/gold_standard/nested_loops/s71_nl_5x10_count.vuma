// s71_nl_5x10_count.vuma — 5x10 nested loop, count = 50
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 10 iterations each ->
// 5*10 = 50 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s69_nl_4x11_count (44), s70_nl_4x9_count
// (36) and s66_nl_3x6_count (18).
// Expected exit code: 50
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..10 {
            count = count + 1;
        }
    }
    return count;
}
