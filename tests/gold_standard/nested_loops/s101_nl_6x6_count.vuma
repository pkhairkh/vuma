// s101_nl_6x6_count.vuma — 6x6 nested loop, count = 36
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 6 iterations, inner loop 6 iterations each ->
// 6*6 = 36 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s98_nl_7x11_count (77), s97_nl_3x35_count (105)
// and s94_nl_4x13_count (52).
// Expected exit code: 36
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..6 {
            count = count + 1;
        }
    }
    return count;
}
