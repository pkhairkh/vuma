// s75_nl_4x19_count.vuma — 4x19 nested loop, count = 76
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 19 iterations each ->
// 4*19 = 76 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s74_nl_4x13_count (52), s70_nl_3x7_count
// (21) and s66_nl_3x6_count (18).
// Expected exit code: 76
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..19 {
            count = count + 1;
        }
    }
    return count;
}
