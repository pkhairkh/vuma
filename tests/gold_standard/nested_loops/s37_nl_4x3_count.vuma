// s37_nl_4x3_count.vuma — 4x3 nested loop, count = 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Nested for-loop produces 12 iterations total. Known
// "for-body assignments don't propagate" bug keeps the result at 0. Will exit
// 12 once fixed.
// Distinct from s33_nl_4x2_count (4x2=8) and s30_nl_2x4_count (2x4=8).
// Expected exit code: 12
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
