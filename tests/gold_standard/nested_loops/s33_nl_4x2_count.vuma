// s33_nl_4x2_count.vuma — 4x2 nested loop, count = 8
// Expected exit code (correct): 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Nested for-loop produces 8 iterations total. Known
// "for-body assignments don't propagate" bug keeps the result at 0. Will exit
// 8 once fixed.
// Distinct from s30_nl_2x4_count (2x4=8) and s26_nl_4x2_count (4x2=8, same dims, observed 0).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
