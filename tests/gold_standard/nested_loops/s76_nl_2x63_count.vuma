// s76_nl_2x63_count.vuma — 2x63 nested loop, count = 126
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 63 iterations each ->
// 2*63 = 126 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s74_nl_2x23_count (46), s73_nl_4x17_count
// (68) and s72_nl_5x11_count (55).
// Expected exit code: 126
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..63 {
            count = count + 1;
        }
    }
    return count;
}
