// s94_nl_2x10_count.vuma — 2x10 nested loop, count = 20
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 10 iterations each ->
// 2*10 = 20 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_3x44_count (132), s86_nl_2x15_count (30)
// and s82_nl_2x21_count (42).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..10 {
            count = count + 1;
        }
    }
    return count;
}
