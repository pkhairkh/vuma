// s100_nl_11x11_count.vuma — 11x11 nested loop, count = 121
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 11 iterations, inner loop 11 iterations each
// -> 11*11 = 121 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate"
// bug keeps count at 0.
// Distinct from s97_nl_2x51_count (102), s94_nl_2x10_count (20), s90_nl_3x44_count (132).
// Expected exit code: 121
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..11 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
