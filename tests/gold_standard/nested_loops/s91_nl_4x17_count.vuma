// s91_nl_4x17_count.vuma — 4x17 nested loop, count = 68
// Expected exit code (correct): 68
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 17 iterations each ->
// 4*17 = 68 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_4x21_count (84), s86_nl_2x15_count (30)
// and s82_nl_2x21_count (42).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..17 {
            count = count + 1;
        }
    }
    return count;
}
