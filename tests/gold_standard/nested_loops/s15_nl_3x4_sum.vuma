// s15_nl_3x4_sum.vuma — 3x4 nested loop, count = 12
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 4 iterations each -> 3*4 = 12 total
// iterations. Counter is a scalar accumulator updated inside the inner loop
// body. Known "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s10_nl_3x4_count (3x4 = 12, same dims, _count suffix) and
// s14_nl_4x2_count (4x2 = 8).
// Expected exit code: 12

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
