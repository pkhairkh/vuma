// s84_nl_8x11_count.vuma — 8x11 nested loop, count = 88
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 8 iterations, inner loop 11 iterations each ->
// 8*11 = 88 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s82_nl_6x9_count (54), s78_nl_3x23_count
// (69) and s74_nl_2x23_count (46).
// Expected exit code: 88
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..8 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
