// s67_nl_2x8_count.vuma — 2x8 nested loop, count = 16
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 8 iterations each ->
// 2*8 = 16 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s66_nl_2x7_count (14),
// s62_nl_4x5_count (20) and s58_nl_2x3_count (6).
// Expected exit code: 16
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..8 {
            count = count + 1;
        }
    }
    return count;
}
