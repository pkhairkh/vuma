// s94_nl_7x8_count.vuma — 7x8 nested loop, count = 56
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 8 iterations each ->
// 7*8 = 56 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s90_nl_6x16_count (96), s86_nl_3x11_count (33)
// and s82_nl_9x3_count (27).
// Expected exit code: 56
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..8 {
            count = count + 1;
        }
    }
    return count;
}
