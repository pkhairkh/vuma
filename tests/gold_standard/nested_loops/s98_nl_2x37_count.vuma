// s98_nl_2x37_count.vuma — 2x37 nested loop, count = 74
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 37 iterations each ->
// 2*37 = 74 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_7x8_count (56), s90_nl_5x22_count (110)
// and s86_nl_4x8_count (32).
// Expected exit code: 74
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..37 {
            count = count + 1;
        }
    }
    return count;
}
