// s69_nl_6x7_count.vuma -- 6x7 nested loop, count = 42
// Observed on current x86_64 backend: 0 (FAIL -- known bug)
//
// Outer loop 6 iterations, inner loop 7 iterations each -> 6*7 = 42
// total. Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s66_nl_2x7_count (14), s65_nl_2x13_count (26) and s64_nl_2x6_count
// (12).
// Expected exit code: 42
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..6 {
        for j in 0..7 {
            count = count + 1;
        }
    }
    return count;
}
