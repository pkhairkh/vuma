// s87_nl_3x9_count.vuma — 3x9 nested loop, count = 27
// Expected exit code (correct): 27
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 9 iterations each ->
// 3*9 = 27 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s86_nl_3x11_count (33), s82_nl_3x16_count
// (48) and s78_nl_3x23_count (69).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..9 {
            count = count + 1;
        }
    }
    return count;
}
