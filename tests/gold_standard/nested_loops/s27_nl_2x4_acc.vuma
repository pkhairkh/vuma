// s27_nl_2x4_acc.vuma — 2x4 nested loop, acc = 120 (8 * 15)
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 4 iterations each -> 8 total. acc
// increments by 15 each inner iteration -> 120. Known "for-body
// assignments don't propagate" bug keeps acc at 0. Distinct from
// s26_nl_2x5_count (2x5=10) and s22_nl_2x4_count (2x4=8).

fn main() -> i32 {
    acc: u32 = 0;
    for i in 0..2 {
        for j in 0..4 {
            acc = acc + 15;
        }
    }
    return acc;
}
