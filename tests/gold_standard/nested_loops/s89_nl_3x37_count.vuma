// s89_nl_3x37_count.vuma — 3x37 nested loop, count = 111
// Expected exit code (correct): 111
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 37 iterations each ->
// 3*37 = 111 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s86_nl_2x15_count (30),
// s82_nl_2x21_count (42) and s78_nl_3x19_count (57).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..37 {
            count = count + 1;
        }
    }
    return count;
}
