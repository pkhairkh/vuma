// s105_nl_7x19_count.vuma — 7x19 nested loop, count = 7*19 = 133
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Expected exit code: 133
// Outer loop runs 7 iterations, inner loop runs 19 iterations each -> 7*19 = 133 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 133 once fixed.
// Distinct from s102_nl_2x53_count (106), s101_nl_6x6_count (36), s100_nl_11x11_count (121).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..19 {
            count = count + 1;
        }
    }
    return count;
}
