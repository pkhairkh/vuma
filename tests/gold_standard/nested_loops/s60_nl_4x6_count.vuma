// s60_nl_4x6_count.vuma — 4x6 nested loop, count = 24
// Expected exit code (correct): 24
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 6 iterations each -> 4*6 = 24
// total. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s58_nl_4x4_count (16) and s57_nl_4x4_count (16).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..6 {
            count = count + 1;
        }
    }
    return count;
}
