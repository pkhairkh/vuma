// s40_atom_two_cell_diff.vuma — two cells, atomic diff = 125 (220 - 95)
// Expected exit code: 125
//
// Two 8-byte cells. atomic_store 220/95, atomic_load each, diff -> 125.
// On the current backend the loads return 0 -> exit 0. Will exit 125
// once atomics are wired through. Distinct from s38_atom_two_cell_sum
// (170) and s34_atom_two_cell_sum (165).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 220);
    atomic_store(c2, 95);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                  // 125
    free(c1);
    free(c2);
    return d;
}
