// s10_atom_three_cells.vuma — three atomic stores + loads, sum = 60
// Expected exit code: 60
// Expected exit code (correct, post-bridge-fix): 60  (10 + 20 + 30)
//
// Three 8-byte cells. atomic_store 10/20/30 into each, then atomic_load
// all three and sum. On the current backend all loads return 0 -> exit 0.
// Will exit 60 once atomic ops are wired through. Distinct from
// s6_atom_two_cells_sum (2 cells) and s5_atom_three_cells_sum (different
// values 10/20/30 are new for s10).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 10);
    atomic_store(c2, 20);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
