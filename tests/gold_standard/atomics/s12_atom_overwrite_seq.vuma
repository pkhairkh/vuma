// s12_atom_overwrite_seq.vuma — atomic store 15/95/220, load sees 220
// Expected exit code: 220
//
// Single 8-byte cell. atomic_store 15, then 95, then 220 (three
// sequential writes). atomic_load should yield 220 (last write wins).
// Current backend returns 0. Distinct from s13_atom_overwrite_load
// (two writes 30/150) and s9_atom_overwrite_load (two writes 20/200).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 15);
    atomic_store(c, 95);
    atomic_store(c, 220);
    v = atomic_load(c);
    free(c);
    return v;
}
