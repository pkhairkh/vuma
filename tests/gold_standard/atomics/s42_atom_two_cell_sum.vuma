// s42_atom_two_cell_sum.vuma — two cells, atomic sum = 175 (110 + 65)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 175
//
// Two 8-byte cells. atomic_store 110/65, atomic_load each, sum -> 175.
// On the current backend the loads return 0 -> exit 0. Will exit 175
// once atomics are wired through. Distinct from s38_atom_two_cell_sum
// (170) and s34_atom_two_cell_sum (165).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 110);
    atomic_store(c2, 65);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 175
    free(c1);
    free(c2);
    return s;
}
