// s102_atom_three_cell_diff.vuma — atomic_store 3 cells (200, 1, 2), 200-1-2 = 197
// Expected exit code: 197
//
// Three 8-byte cells. atomic_store 200, 1, 2; atomic_load each, return 200 - 1 - 2 = 197. On the current backend atomic_load returns 0 -> exit 0. Will exit 197 once atomics are wired through.
// Distinct from s101_atom_overwrite_value (56), s101_atom_three_cell_diff (110), s101_atom_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 1);
    atomic_store(c3, 2);
    a = atomic_load(c1);          // 200
    b = atomic_load(c2);          // 1
    c = atomic_load(c3);          // 2
    d = a - b - c;                // 197
    free(c1);
    free(c2);
    free(c3);
    return d;
}
