// s79_atom_two_cell_sum.vuma — two cells, atomic sum = 4 (1 + 3)
// Observed on current x86_64 backend: 0 (FAIL — known bug: atomic_load returns 0)
//
// Two 8-byte cells. atomic_store 1/3, atomic_load each, sum
// -> 4. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 4 once atomics are wired through.
// Distinct from s78_atom_two_cell_sum (2), s77_atom_two_cell_sum
// (3) and s76_atom_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c2, 3);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 4
    free(c1);
    free(c2);
    return s;
}
