// s22_atom_two_cell_xor.vuma — atomic_store 41/98, xor = 75 (41 ^ 98)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 75  (41 ^ 98)
//
// Two 8-byte cells. atomic_store 41/98 into each, then atomic_load both
// and XOR. On the current backend all loads return 0 (atomic_store/load
// not bridged through to x86_64) -> exit 0. Will exit 75 once atomic ops
// are wired through. Distinct from s18_atom_two_cell_sum (sum, 23+67=90)
// and s14_atom_two_cell_sum (33+44=77).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 41);
    atomic_store(c2, 98);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a ^ b;
    free(c1);
    free(c2);
    return s;
}
