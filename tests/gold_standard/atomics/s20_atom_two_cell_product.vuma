// s20_atom_two_cell_product.vuma — two cells, atomic_store 13/7, product = 91
// Expected exit code: 91
// Expected exit code (correct, post-bridge-fix): 91  (13 * 7)
//
// Two 8-byte cells. atomic_store 13 in c1, 7 in c2, then atomic_load
// both and multiply. On the current backend both loads return 0
// (atomic_store/load not bridged through to x86_64) -> exit 0. Will
// exit 91 once atomics are wired through. Distinct from
// s18_atom_two_cell_sum (sum, 23+67=90) and s14_atom_two_cell_sum
// (33+44=77).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 13);
    atomic_store(c2, 7);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a * b;
    free(c1);
    free(c2);
    return s;
}
