// s75_atom_three_cell_sum.vuma — three cells, atomic sum = 161 (50 + 80 + 31)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 161
//
// Three 8-byte cells. atomic_store 50/80/31, atomic_load each,
// sum -> 161. On the current backend the loads return 0 -> 0 + 0
// + 0 = 0 -> exit 0. Will exit 161 once atomics are wired through.
// Distinct from s74_atom_three_cell_diff (88), s70_atom_three_cell_
// diff (110) and s66_atom_three_cell_diff (90).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c2, 80);
    atomic_store(c3, 31);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b;                   // 130
    r: i32 = s + c;                   // 161
    free(c1);
    free(c2);
    free(c3);
    return r;
}
