// s9_atom_single_load.vuma — atomic_store 99, atomic_load -> 99
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 99
//
// Single 8-byte cell. atomic_store 99 then atomic_load. Per the
// documented KNOWN CODEGEN GAP, atomic_store/load aren't lowered
// through the bridge yet, so the load returns 0. Will return 99
// once atomics are bridged. Distinct from s4_atom_basic_store_load
// (value 42).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 99);
    v = atomic_load(c);
    free(c);
    return v;
}
