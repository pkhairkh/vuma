// s101_atom_two_cell_sum.vuma — two cells, atomic sum = 230 (100 + 130)
// Expected exit code: 230
//
// Two 8-byte cells. atomic_store 100/130, atomic_load each, a + b
// -> 230. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 230 once atomics are wired through.
// Distinct from s98_atom_two_cell_diff (0; correct 117),
// s97_atom_two_cell_sum (0; correct 29) and s94_atom_two_cell_diff
// (0; correct 5).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 130);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 230
    free(c1);
    free(c2);
    return s;
}
