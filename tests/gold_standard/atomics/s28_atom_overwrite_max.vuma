// s28_atom_overwrite_max.vuma — overwrite first store with 230, load = 230
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 230
//
// Single 8-byte cell. atomic_store 20, then atomic_store 230 (overwrite).
// atomic_load should return 230. On the current backend the load returns
// 0 -> exit 0. Will exit 230 once atomics are wired through. Distinct
// from s26_atom_overwrite_max (value 250) and s22_atom_overwrite_load
// (0xFF).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 20);
    atomic_store(c1, 230);
    a = atomic_load(c1);
    free(c1);
    return a;
}
