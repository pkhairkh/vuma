// s28_atom_two_cell_and.vuma — atomic_store 0xF0/0x3C, and = 48
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 48  (240 & 60)
//
// Two 8-byte cells. atomic_store 240/60 into each, then atomic_load both
// and AND. On the current backend all loads return 0 (atomic_store/load
// not bridged through to x86_64) -> exit 0. Will exit 48 once atomic
// ops are wired through. Distinct from s26_atom_two_cell_or (or,
// 240|15=255) and s22_atom_two_cell_xor (xor, 75).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 240);
    atomic_store(c2, 60);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a & b;
    free(c1);
    free(c2);
    return s;
}
