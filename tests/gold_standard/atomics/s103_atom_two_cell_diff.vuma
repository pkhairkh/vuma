// s103_atom_two_cell_diff.vuma — atomic_store 2 cells (200, 50), load and diff = 200-50 = 150
// Expected exit code (correct): 150
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Two 8-byte cells. atomic_store 200 to c1, atomic_store 50 to c2, atomic_load each and return the difference (200 - 50 = 150). On the current backend atomic_load returns 0 -> 0 - 0 = 0 -> exit 0. Will exit 150 once atomics are wired through.
// Distinct from s94_atom_two_cell_diff (33).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 50);
    a = atomic_load(c1);          // 200
    b = atomic_load(c2);          // 50
    d = a - b;                    // 150
    free(c1);
    free(c2);
    return d;
}
