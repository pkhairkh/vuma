// s96_atom_two_cell_sum.vuma — two cells, atomic sum = 255 (140 + 115)
// Expected exit code: 255
//
// Two 8-byte cells. atomic_store 140/115, atomic_load each, a + b
// -> 255. On the current backend the loads return 0 -> 0 + 0 = 0 ->
// exit 0. Will exit 255 once atomics are wired through. Distinct from
// s94_atom_two_cell_diff (33), s90_atom_two_cell_diff (1) and
// s86_atom_two_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 140);
    atomic_store(c2, 115);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 255
    free(c1);
    free(c2);
    return s;
}
