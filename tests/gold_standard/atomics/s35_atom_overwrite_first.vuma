// s35_atom_overwrite_first.vuma — overwrite first store with 220, load = 220
// Expected exit code: 220
//
// Single 8-byte cell. atomic_store 40, then atomic_store 220
// (overwrite first). atomic_load should return 220. On the current
// backend the load returns 0 -> exit 0. Will exit 220 once atomics
// are wired through. Distinct from s34_atom_overwrite_max (250) and
// s30_atom_overwrite_first (100).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c1, 220);
    a = atomic_load(c1);
    free(c1);
    return a;
}
