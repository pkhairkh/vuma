// s87_atom_two_cell_sum.vuma — two cells, atomic sum = 195 (110 + 85)
// Expected exit code: 195
//
// Two 8-byte cells. atomic_store 110/85, atomic_load each, sum
// -> 195. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 195 once atomics are wired through.
// Distinct from s86_atom_two_cell_sum (200), s82_atom_two_cell_
// sum (24) and s78_atom_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 110);
    atomic_store(c2, 85);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 195
    free(c1);
    free(c2);
    return s;
}
