// s91_atom_three_cell_sum.vuma — three cells, atomic sum = 21 (6 + 7 + 8)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 21
//
// Three 8-byte cells. atomic_store 6/7/8, atomic_load each, sum
// -> 21. On the current backend the loads return 0 -> 0 + 0 + 0 = 0
// -> exit 0. Will exit 21 once atomics are wired through. Distinct
// from s90_atom_three_cell_sum (12), s86_atom_three_cell_diff (60)
// and s82_atom_three_cell_diff (110).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 6);
    atomic_store(c2, 7);
    atomic_store(c3, 8);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b + c;               // 21
    free(c1);
    free(c2);
    free(c3);
    return s;
}
