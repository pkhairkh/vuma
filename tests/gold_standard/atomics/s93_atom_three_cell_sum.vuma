// s93_atom_three_cell_sum.vuma — three cells, atomic sum = 22 (6 + 7 + 9)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 22
//
// Three 8-byte cells. atomic_store 6/7/9, atomic_load each, sum
// -> 22. On the current backend the loads return 0 -> 0 + 0 + 0 = 0
// -> exit 0. Will exit 22 once atomics are wired through. Distinct
// from s90_atom_three_cell_sum (12), s82_atom_three_cell_diff (26) and s78_atom_three_cell_diff (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 6);
    atomic_store(c2, 7);
    atomic_store(c3, 9);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b + c;               // 22
    free(c1);
    free(c2);
    free(c3);
    return s;
}
