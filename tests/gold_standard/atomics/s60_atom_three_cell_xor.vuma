// s60_atom_three_cell_xor.vuma — three cells, atomic XOR = 119 (0x11^0x22^0x44)
// Expected exit code: 119
//
// Three 8-byte cells. atomic_store 17/34/68 (0x11/0x22/0x44),
// atomic_load each, XOR -> 119 (0x77). On the current backend the
// loads return 0 -> exit 0. Will exit 119 once atomics are wired
// through. Distinct from s57_atom_three_cell_xor (30) and
// s56_atom_three_cell_xor (15).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 17);             // 0x11
    atomic_store(c2, 34);             // 0x22
    atomic_store(c3, 68);             // 0x44
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;                   // 0x33 = 51
    r: i32 = t ^ c;                   // 0x77 = 119
    free(c1);
    free(c2);
    free(c3);
    return r;
}
