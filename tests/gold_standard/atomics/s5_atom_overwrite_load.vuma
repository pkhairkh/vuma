// s5_atom_overwrite_load.vuma — atomic_store twice, load final = 55
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 55
//
// Single 8-byte cell. atomic_store 11, then atomic_store 55
// (overwrite). atomic_load should yield 55. Current backend
// returns 0. Will exit 55 once atomic ops are wired through.

fn main() -> i32 {
    cell = allocate(8);
    atomic_store(cell, 11);
    atomic_store(cell, 55);
    v = atomic_load(cell);
    free(cell);
    return v;
}
