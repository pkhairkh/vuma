// s61_atom_two_cell_sum.vuma — two cells, atomic sum = 205 (110 + 95)
// Expected exit code: 205
// 
// Two 8-byte cells. atomic_store 110/95, atomic_load each, sum
// -> 205. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 205 once atomics are wired through. Distinct
// from s58_atom_two_cell_sum (165), s58_atom_three_cell_diff (120)
// and s58_atom_overwrite_high (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 110);
    atomic_store(c2, 95);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 205
    free(c1);
    free(c2);
    return s;
}
