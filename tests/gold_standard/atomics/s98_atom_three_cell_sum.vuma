// s98_atom_three_cell_sum.vuma — three cells, atomic sum = 34 (20 + 8 + 6)
// Expected exit code: 34
//
// Three 8-byte cells. atomic_store 20/8/6, atomic_load each, sum
// -> 34. On the current backend the loads return 0 -> 0 + 0 + 0 = 0
// -> exit 0. Will exit 34 once atomics are wired through. Distinct
// from s94_atom_three_cell_sum (98), s90_atom_three_cell_sum (12)
// and s86_atom_three_cell_diff (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 20);
    atomic_store(c2, 8);
    atomic_store(c3, 6);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b + c;               // 34
    free(c1);
    free(c2);
    free(c3);
    return s;
}
