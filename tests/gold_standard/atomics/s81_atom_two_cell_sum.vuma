// s81_atom_two_cell_sum.vuma — two cells, atomic sum = 145 (90 + 55)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 145
//
// Two 8-byte cells. atomic_store 90/55, atomic_load each, sum
// -> 145. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 145 once atomics are wired through.
// Distinct from s78_atom_two_cell_sum (2),
// s77_atom_two_cell_sum (154) and s76_atom_two_cell_sum (57).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 90);
    atomic_store(c2, 55);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 145
    free(c1);
    free(c2);
    return s;
}
