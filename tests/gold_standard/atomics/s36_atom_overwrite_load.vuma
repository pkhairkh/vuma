// s36_atom_overwrite_load.vuma — atomic_store 50, overwrite to 200, load = 200
// Expected exit code (correct): 200
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single 8-byte cell. atomic_store 50, then atomic_store
// 200 (overwrite). atomic_load should return 200. On the
// current backend the load returns 0 -> exit 0. Will exit
// 200 once atomics are wired through.
// Distinct from s30_atom_overwrite_first (overwrite, 100) and s27_atom_overwrite_load (different values).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 200);
    a = atomic_load(c1);
    free(c1);
    return a;
}
