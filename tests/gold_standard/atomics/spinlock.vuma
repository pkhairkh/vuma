// Spinlock — demonstrates VUMA atomic operations
//
// This example shows how to implement a simple spinlock using
// VUMA's atomic operations:
//   - atomic_load(addr)    — load with acquire semantics
//   - atomic_store(addr, val) — store with release semantics
//   - atomic_cas(addr, expected, desired) — compare-and-swap
//
// The spinlock is the most basic synchronization primitive.
// VUMA's IVE verifies:
//   - No data races on the lock state
//   - Atomic operations target correct addresses
//   - Values come from valid writes (Origin invariant)
// Expected exit code: 3

// Spinlock struct — uses a single u64 as the lock state
// 0 = unlocked, 1 = locked
struct SpinLock {
    state: u64,
}

// Initialize a new spinlock in the unlocked state
fn spinlock_init(lock: Address) {
    *lock = SpinLock { state: 0 };
}

// Acquire the spinlock — spins until the lock is available
//
// Uses atomic_cas in a loop:
// 1. Try to swap state from 0 (unlocked) to 1 (locked)
// 2. If CAS returns 0 (the old value was unlocked), we got the lock
// 3. If CAS returns non-zero, someone else holds it — retry
fn spinlock_lock(lock: Address) {
    loop {
        // Try to atomically change state from 0 to 1
        old = atomic_cas(lock, 0, 1);
        if old == 0 {
            // Successfully acquired the lock
            return;
        }
        // Lock is held by another thread — spin (retry)
        // In a real system, we'd add a pause/yield hint here
    }
}

// Release the spinlock — sets state back to 0
//
// Uses atomic_store to ensure the release is visible
// to other threads before they can observe the unlock
fn spinlock_unlock(lock: Address) {
    // Release the lock with atomic store
    // This ensures all our previous writes are visible
    // before the lock state change becomes visible
    atomic_store(lock, 0);
}

// Try to acquire the lock without spinning
// Returns true if the lock was acquired, false otherwise
fn spinlock_trylock(lock: Address) -> bool {
    old = atomic_cas(lock, 0, 1);
    return old == 0;
}

// Example: using a spinlock to protect a shared counter
fn increment_with_lock(lock: Address, counter: Address) {
    spinlock_lock(lock);
    // Critical section — only one thread at a time
    val = *counter;
    *counter = val + 1;
    spinlock_unlock(lock);
}

fn main() {
    // Allocate a spinlock and a shared counter
    lock = allocate(8);     // SpinLock state
    counter = allocate(8);  // Shared counter

    // Initialize
    spinlock_init(lock);
    *counter = 0;

    // Increment the counter under the lock
    increment_with_lock(lock, counter);
    increment_with_lock(lock, counter);
    increment_with_lock(lock, counter);

    // Read the result (should be 3)
    result = *counter;
}
