// s31_atom_overwrite_middle.vuma — overwrite middle cell, sum = 130 (10+90+30)
// Expected exit code: 130
//
// Three 8-byte cells. atomic_store 10/20/30, then overwrite the middle
// cell with 90. atomic_load each, sum -> 130. On the current backend
// the load returns 0 -> exit 0. Will exit 130 once atomics are wired
// through. Distinct from s30_atom_overwrite_first (overwrite first, 230)
// and s28_atom_overwrite_max (overwrite max, 230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 10);
    atomic_store(c2, 20);
    atomic_store(c3, 30);
    atomic_store(c2, 90);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;
    r: i32 = t + c;                 // 130
    free(c1);
    free(c2);
    free(c3);
    return r;
}
