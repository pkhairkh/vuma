// s63_atom_three_cell_diff.vuma — three cells, atomic diff = 120 (200 - 50 - 30)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 120
//
// Three 8-byte cells. atomic_store 200/50/30, atomic_load each,
// 200 - 50 - 30 = 120. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 120 once atomics are wired
// through. Distinct from s51_atom_overwrite_value (245), s58_atom_
// overwrite_high (210) and s55_atom_overwrite_value (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 50);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 150
    d: i32 = t - c;                   // 120
    free(c1);
    free(c2);
    free(c3);
    return d;
}
