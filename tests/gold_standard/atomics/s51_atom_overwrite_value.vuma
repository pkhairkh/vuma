// s51_atom_overwrite_value.vuma — overwrite to 245, atomic_load = 245
// Expected exit code: 245
//
// Single 8-byte cell. atomic_store 60, then atomic_store 245.
// atomic_load should return 245. On the current backend the load
// returns 0 -> exit 0. Will exit 245 once atomics are wired
// through. Distinct from s50_atom_overwrite_value (220) and
// s47_atom_overwrite_high (235).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c1, 245);
    v = atomic_load(c1);
    free(c1);
    return v;
}
