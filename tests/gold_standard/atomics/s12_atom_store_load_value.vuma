// s12_atom_store_load_value.vuma — atomic_store 88, atomic_load -> 88
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 88
//
// Single 8-byte cell. atomic_store 88 then atomic_load. Per the
// documented KNOWN CODEGEN GAP, atomic_store/load aren't lowered
// through the bridge yet, so the load returns 0. Will return 88
// once atomics are bridged. Distinct from s9_atom_single_load
// (value 99) and s13_atom_single_load (value 77).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 88);
    v = atomic_load(c);
    free(c);
    return v;
}
