// s32_atom_overwrite_first.vuma - overwrite atomic cell, load = 200
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Uses atomic_store/atomic_load on the cell(s). On the current backend
// atomic_load returns 0, so the computed result is 0 rather than 200. Will
// exit 200 once the atomics bridge is wired through. Distinct from
// s30_atom_overwrite_first (different value) and s26_atom_overwrite_load
// (different value).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 200);
    a = atomic_load(c1);
    free(c1);
    return a;
}
