// s42_atom_three_cell_xor.vuma — three cells, atomic xor = 195 (0xA5 ^ 0x3C ^ 0x5A)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 195
//
// Three 8-byte cells. atomic_store 165/60/90, atomic_load each,
// xor -> 195 (0xC3). On the current backend the loads return 0 ->
// exit 0. Will exit 195 once atomics are wired through. Distinct from
// s38_atom_three_cell_sum (sum, 150) and s34_atom_three_cell_xor
// (xor).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 165);   // 0xA5
    atomic_store(c2, 60);    // 0x3C
    atomic_store(c3, 90);    // 0x5A
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;
    s: i32 = t ^ c;          // 0xC3 = 195
    free(c1);
    free(c2);
    free(c3);
    return s;
}
