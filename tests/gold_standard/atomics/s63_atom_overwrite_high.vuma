// s63_atom_overwrite_high.vuma — overwrite to 235, atomic_load = 235
// Expected exit code: 235
//
// Single 8-byte cell. atomic_store 60, then atomic_store 235.
// atomic_load should return 235. On the current backend the load
// returns 0 -> exit 0. Will exit 235 once atomics are wired
// through. Distinct from s51_atom_two_cell_diff (60), s58_atom_
// two_cell_sum (165) and s55_atom_two_cell_sum (250).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c1, 235);
    v = atomic_load(c1);
    free(c1);
    return v;
}
