// s105_atom_two_cell_sum.vuma — atomic_store 2 cells (17, 28), load and sum = 17+28 = 45
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 45
// 
// Two 8-byte cells. atomic_store 17 to c1, atomic_store 28 to c2, atomic_load each and return the sum (45). On the current backend atomic_load returns 0 -> sum 0 -> exit 0. Will exit 45 once atomics are wired through.
// Distinct from s102_atom_two_cell_sum (37), s101_atom_two_cell_sum (230), s100_atom_two_cell_sum (0).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 17);
    atomic_store(c2, 28);
    a = atomic_load(c1);          // 17
    b = atomic_load(c2);          // 28
    s = a + b;                    // 45
    free(c1);
    free(c2);
    return s;
}
