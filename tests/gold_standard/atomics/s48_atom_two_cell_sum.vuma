// s48_atom_two_cell_sum.vuma — two cells, atomic sum = 198 (88 + 110)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 198
//
// Two 8-byte cells. atomic_store 88/110, atomic_load each, sum ->
// 198. On the current backend the loads return 0 -> exit 0. Will
// exit 198 once atomics are wired through. Distinct from s46_atom_
// three_cell_sum (210) and s42_atom_two_cell_sum.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 88);
    atomic_store(c2, 110);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 198
    free(c1);
    free(c2);
    return s;
}
