// s106_atom_overwrite_value.vuma — atomic_store 5 then overwrite 39, atomic_load = 39
// Expected exit code: 39
//
// Single 8-byte cell. atomic_store 5, then atomic_store 39 (overwrite), then atomic_load -> 39. On the current backend the load returns 0 -> exit 0. Will exit 39 once atomics are wired through.
// Distinct from s102_atom_overwrite_value (38), s101_atom_overwrite_value (56), s100_atom_overwrite_value (53).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 39);
    v = atomic_load(c1);              // 39
    free(c1);
    return v;
}
