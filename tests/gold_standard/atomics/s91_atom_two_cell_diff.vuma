// s91_atom_two_cell_diff.vuma — two cells, atomic diff = 5 (200 - 195)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 5
//
// Two 8-byte cells. atomic_store 200/195, atomic_load each, a - b
// -> 5. On the current backend the loads return 0 -> 0 - 0 = 0 ->
// exit 0. Will exit 5 once atomics are wired through. Distinct from
// s90_atom_two_cell_diff (1), s86_atom_two_cell_sum (200) and
// s82_atom_two_cell_sum (24).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 195);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 5
    free(c1);
    free(c2);
    return d;
}
