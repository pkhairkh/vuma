// s26_atom_overwrite_max.vuma — overwrite first store with 250, load = 250
// Expected exit code: 250
//
// Single 8-byte cell. atomic_store 10, then atomic_store 250 (overwrite).
// atomic_load should return 250. On the current backend the load returns
// 0 -> exit 0. Will exit 250 once atomics are wired through. Distinct
// from s22_atom_overwrite_load (overwrite pattern, 0xFF) and
// s16_atom_overwrite_then_load (different values).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 10);
    atomic_store(c1, 250);
    a = atomic_load(c1);
    free(c1);
    return a;
}
