// s67_atom_two_cell_xor.vuma — two cells, atomic xor = 255 (170 ^ 85)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 255
//
// Two 8-byte cells. atomic_store 170/85, atomic_load each, xor
// -> 170 ^ 85 = 255 (0xFF). On the current backend the loads
// return 0 -> 0 ^ 0 = 0 -> exit 0. Will exit 255 once atomics
// are wired through. Distinct from s66_atom_two_cell_sum
// (correct 200), s62_atom_two_cell_diff (170) and s58_atom_
// two_cell_sum (165).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 170);
    atomic_store(c2, 85);
    a = atomic_load(c1);
    b = atomic_load(c2);
    r: i32 = a ^ b;                   // 255
    free(c1);
    free(c2);
    return r;
}
