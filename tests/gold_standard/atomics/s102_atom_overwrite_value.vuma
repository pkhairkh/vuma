// s102_atom_overwrite_value.vuma — atomic_store 1 then overwrite 38, atomic_load = 38
// Expected exit code: 38
//
// Single 8-byte cell. atomic_store 1, then atomic_store 38 (overwrite), then atomic_load -> 38. On the current backend the load returns 0 -> exit 0. Will exit 38 once atomics are wired through.
// Distinct from s101_atom_overwrite_value (56), s101_atom_three_cell_diff (110), s101_atom_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c1, 38);
    v = atomic_load(c1);              // 38
    free(c1);
    return v;
}
