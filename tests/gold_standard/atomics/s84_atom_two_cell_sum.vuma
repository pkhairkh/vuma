// s84_atom_two_cell_sum.vuma — two cells, atomic sum = 8 (3 + 5)
// Expected exit code: 8
//
// Two 8-byte cells. atomic_store 3/5, atomic_load each, sum
// -> 8. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 8 once atomics are wired through.
// Distinct from s82_atom_two_cell_sum (24), s78_atom_two_cell_sum
// (2) and s74_atom_two_cell_sum (179).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 3);
    atomic_store(c2, 5);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 8
    free(c1);
    free(c2);
    return s;
}
