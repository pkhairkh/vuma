// s71_atom_overwrite_high.vuma — overwrite to 199, atomic_load = 199
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 199
//
// Single 8-byte cell. atomic_store 50, then atomic_store 199.
// atomic_load should return 199. On the current backend the load
// returns 0 -> exit 0. Will exit 199 once atomics are wired
// through. Distinct from s69_atom_overwrite_value (225), s70_atom_
// overwrite_value (185) and s66_atom_overwrite_high (230).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 199);
    v = atomic_load(c1);
    free(c1);
    return v;
}
