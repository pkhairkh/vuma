// s39_atom_three_cell_sum.vuma — three cells, atomic sum = 180 (45 + 60 + 75)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 180
//
// Three 8-byte cells. atomic_store 45/60/75, atomic_load each,
// sum -> 180. On the current backend the loads return 0 -> exit 0.
// Will exit 180 once atomics are wired through. Distinct from
// s38_atom_three_cell_sum (150) and s34_atom_three_cell_xor.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 45);
    atomic_store(c2, 60);
    atomic_store(c3, 75);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;
    s: i32 = t + c;                  // 180
    free(c1);
    free(c2);
    free(c3);
    return s;
}
