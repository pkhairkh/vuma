// s102_atom_two_cell_sum.vuma — atomic_store 2 cells (1, 36), load and sum = 1+36 = 37
// Expected exit code: 37
//
// Two 8-byte cells. atomic_store 1 to c1, atomic_store 36 to c2, atomic_load each and return the sum (37). On the current backend atomic_load returns 0 -> sum 0 -> exit 0. Will exit 37 once atomics are wired through.
// Distinct from s101_atom_overwrite_value (56), s101_atom_three_cell_diff (110), s101_atom_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c2, 36);
    a = atomic_load(c1);          // 1
    b = atomic_load(c2);          // 36
    s = a + b;                    // 37
    free(c1);
    free(c2);
    return s;
}
