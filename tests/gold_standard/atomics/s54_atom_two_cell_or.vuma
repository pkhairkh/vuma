// s54_atom_two_cell_or.vuma — two cells, atomic OR = 127 (110 | 95)
// Expected exit code: 127
//
// Two 8-byte cells. atomic_store 110/95, atomic_load each, OR
// -> 127. On the current backend the loads return 0 -> exit 0.
// Will exit 127 once atomics are wired through. Distinct from
// s50_atom_two_cell_sum (175) and s49_atom_two_cell_sum (170).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 110);
    atomic_store(c2, 95);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a | b;                  // 127
    free(c1);
    free(c2);
    return s;
}
