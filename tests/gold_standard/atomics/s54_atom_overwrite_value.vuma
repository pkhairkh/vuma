// s54_atom_overwrite_value.vuma — store 50, overwrite to 200, load = 200
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 200
//
// Single 8-byte cell. atomic_store 50, then overwrite with 200,
// atomic_load -> 200. On the current backend the load returns 0
// -> exit 0. Will exit 200 once atomics are wired through.
// Distinct from s50_atom_overwrite_value (190) and s49_atom_
// overwrite_max (250).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 50);
    atomic_store(c, 200);
    v = atomic_load(c);
    free(c);
    return v;
}
