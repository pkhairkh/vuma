// s65_atom_three_cell_sum.vuma — three cells, atomic sum = 95 (25 + 30 + 40)
// Expected exit code: 95
//
// Three 8-byte cells. atomic_store 25/30/40, atomic_load each,
// 25 + 30 + 40 = 95. On the current backend the loads return 0
// -> 0 + 0 + 0 = 0 -> exit 0. Will exit 95 once atomics are wired
// through. Distinct from s51_atom_three_cell_sum (250), s58_atom_
// three_cell_diff (120) and s62_atom_three_cell_sum (205).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 25);
    atomic_store(c2, 30);
    atomic_store(c3, 40);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;                   // 55
    s: i32 = t + c;                   // 95
    free(c1);
    free(c2);
    free(c3);
    return s;
}
