// s97_atom_three_cell_diff.vuma — three cells, atomic diff = 46 (80 - 20 - 14)
// Expected exit code: 46
//
// Three 8-byte cells. atomic_store 80/20/14,
// atomic_load each, a - b - c -> 46. On the current
// backend the loads return 0 -> 0 - 0 - 0 = 0 -> exit 0.
// Will exit 46 once atomics are wired through.
// Distinct from s94_atom_overwrite_value (201), s90_atom_overwrite_value (13), s86_atom_three_cell_diff (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c2, 20);
    atomic_store(c3, 14);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    d: i32 = a - b - c;               // 46
    free(c1);
    free(c2);
    free(c3);
    return d;
}
