// s69_atom_three_cell_diff.vuma -- three cells, atomic diff = 105 (220 - 70 - 45)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 105
//
// Three 8-byte cells. atomic_store 220/70/45, atomic_load each, diff
// -> 220 - 70 - 45 = 105. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 105 once atomics are wired
// through. Distinct from s66_atom_three_cell_diff (90), s65_atom_
// three_cell_sum (95) and s64_atom_three_cell_diff (125).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 220);
    atomic_store(c2, 70);
    atomic_store(c3, 45);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 150
    r: i32 = t - c;                   // 105
    free(c1);
    free(c2);
    free(c3);
    return r;
}
