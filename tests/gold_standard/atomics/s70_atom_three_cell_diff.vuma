// s70_atom_three_cell_diff.vuma — three cells, atomic diff = 110 (200 - 60 - 30)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 110
//
// Three 8-byte cells. atomic_store 200/60/30, atomic_load each,
// diff -> 200 - 60 - 30 = 110. On the current backend the loads
// return 0 -> 0 - 0 - 0 = 0 -> exit 0. Will exit 110 once atomics
// are wired through. Distinct from s66_atom_three_cell_diff (90),
// s65_atom_three_cell_sum (95) and s62_atom_three_cell_sum (205).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 60);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 140
    r: i32 = t - c;                   // 110
    free(c1);
    free(c2);
    free(c3);
    return r;
}
