// s87_atom_three_cell_diff.vuma — three cells, atomic diff = 150 (225 - 60 - 15)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 150
//
// Three 8-byte cells. atomic_store 225/60/15, atomic_load each,
// a - b - c -> 150. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 150 once atomics are
// wired through. Distinct from s86_atom_three_cell_diff (170),
// s82_atom_three_cell_diff (26) and s78_atom_three_cell_diff
// (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 225);
    atomic_store(c2, 60);
    atomic_store(c3, 15);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    r: i32 = a - b - c;               // 150
    free(c1);
    free(c2);
    free(c3);
    return r;
}
