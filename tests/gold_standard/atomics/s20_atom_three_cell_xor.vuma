// s20_atom_three_cell_xor.vuma — three cells, atomic_store 170/85/15, xor = 240
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 240  (170 ^ 85 ^ 15)
//
// Three 8-byte cells. atomic_store 170/85/15 into each, then atomic_load
// all three and XOR. (170 ^ 85) = 255; 255 ^ 15 = 240. On the current
// backend all loads return 0 -> exit 0. Will exit 240 once atomics are
// wired. Distinct from s18_atom_three_cells_odd (40/60/80 sum) and
// s14_atom_three_cell_dec (three-cell sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 170);
    atomic_store(c2, 85);
    atomic_store(c3, 15);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a ^ b ^ c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
