// s96_atom_overwrite_value.vuma — overwrite c1 to 205, atomic load = 205
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 205
//
// Single 8-byte cell. atomic_store 1, then atomic_store 205
// (overwrite). atomic_load -> 205. On the current backend the load
// returns 0 -> exit 0. Will exit 205 once atomics are wired through.
// Distinct from s94_atom_overwrite_value (201),
// s90_atom_overwrite_value (13) and s86_atom_overwrite_value (240).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c1, 205);
    v = atomic_load(c1);              // 205
    free(c1);
    return v;
}
