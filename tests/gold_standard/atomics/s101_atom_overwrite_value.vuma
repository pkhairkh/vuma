// s101_atom_overwrite_value.vuma — overwrite atomic to 56, load = 56
// Expected exit code: 56
//
// Single 8-byte cell. atomic_store 5, then atomic_store 56,
// atomic_load -> 56 (the overwritten value). On the current
// backend the load returns 0 -> exit 0. Will exit 56 once atomics
// are wired through. Distinct from s98_atom_overwrite_value (0;
// correct 118), s97_atom_overwrite_value (0; correct 52) and
// s94_atom_overwrite_value (0; correct 6).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 56);
    v = atomic_load(c1);              // 56
    free(c1);
    return v;
}
