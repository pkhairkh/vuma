// s97_atom_overwrite_value.vuma — overwrite c1 to 52, atomic load = 52
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 52
//
// Single 8-byte cell. atomic_store 4, then atomic_store
// 52 (overwrite), then atomic_load -> 52. On the current
// backend the load returns 0 -> exit 0. Will exit 52
// once atomics are wired through.
// Distinct from s94_atom_overwrite_value (201), s90_atom_overwrite_value (13), s86_atom_overwrite_value (240).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 4);
    atomic_store(c1, 52);
    v = atomic_load(c1);              // 52
    free(c1);
    return v;
}
