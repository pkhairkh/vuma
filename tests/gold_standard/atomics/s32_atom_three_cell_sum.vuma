// s32_atom_three_cell_sum.vuma - three cells, atomic sum = 210 (60 + 70 + 80)
// Expected exit code (correct): 210
// Observed on current x86_64 backend: 0 (FAIL - known bug)
//
// Uses atomic_store/atomic_load on the cell(s). On the current backend
// atomic_load returns 0, so the computed result is 0 rather than 210. Will
// exit 210 once the atomics bridge is wired through. Distinct from
// s30_atom_three_cell_sum (different values) and s26_atom_three_cell_sum
// (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c2, 70);
    atomic_store(c3, 80);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d = atomic_load(c3);
    t: i32 = a + b;
    r: i32 = t + d;                 // 210
    free(c1);
    free(c2);
    free(c3);
    return r;
}
