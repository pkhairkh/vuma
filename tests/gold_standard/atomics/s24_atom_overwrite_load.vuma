// s24_atom_overwrite_load.vuma — atomic_store 19 then 84, load = 84
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 84
//
// Single 8-byte cell. atomic_store 19, then overwrite with 84.
// atomic_load should observe 84 (last write wins). On the current
// backend the load returns 0 (atomic_store/load not bridged) -> exit 0.
// Will exit 84 once atomics are wired. Distinct from
// s22_atom_overwrite_load (17 then 88) and s18_atom_overwrite_then_load
// (7 then 71).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 19);
    atomic_store(c, 84);
    v = atomic_load(c);
    free(c);
    return v;
}
