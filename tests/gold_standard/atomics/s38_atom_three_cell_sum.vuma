// s38_atom_three_cell_sum.vuma — three cells, atomic sum = 150 (40 + 50 + 60)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 150
//
// Three 8-byte cells. atomic_store 40/50/60, atomic_load each, sum -> 150.
// On the current backend the loads return 0 -> exit 0. Will exit 150
// once atomics are wired through. Distinct from s34_atom_three_cell_xor
// (xor) and s30_atom_two_cell_xor (different shape).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c2, 50);
    atomic_store(c3, 60);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;
    s: i32 = t + c;                  // 150
    free(c1);
    free(c2);
    free(c3);
    return s;
}
