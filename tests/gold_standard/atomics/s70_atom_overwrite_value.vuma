// s70_atom_overwrite_value.vuma — overwrite to 185, atomic_load = 185
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 185
//
// Single 8-byte cell. atomic_store 50, then atomic_store 185.
// atomic_load should return 185. On the current backend the load
// returns 0 -> exit 0. Will exit 185 once atomics are wired
// through. Distinct from s66_atom_overwrite_high (230),
// s65_atom_overwrite_high (195) and s62_atom_overwrite_low (240).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 185);
    v = atomic_load(c1);
    free(c1);
    return v;
}
