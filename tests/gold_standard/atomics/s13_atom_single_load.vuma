// s13_atom_single_load.vuma — atomic_store 77, atomic_load -> 77
// Expected exit code: 77
//
// Single 8-byte cell. atomic_store 77 then atomic_load. Per the
// documented KNOWN CODEGEN GAP, atomic_store/load aren't lowered
// through the bridge yet, so the load returns 0. Will return 77 once
// atomics are bridged. Distinct from s9_atom_single_load (value 99)
// and s4_atom_basic_store_load (value 42).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 77);
    v = atomic_load(c);
    free(c);
    return v;
}
