// s38_atom_two_cell_sum.vuma — two cells, atomic sum = 170 (100 + 70)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 170
//
// Two 8-byte cells. atomic_store 100/70, atomic_load each, sum -> 170.
// On the current backend the loads return 0 -> exit 0. Will exit 170
// once atomics are wired through. Distinct from s34_atom_two_cell_sum
// (165) and s30_atom_two_cell_xor (xor, 255).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 70);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 170
    free(c1);
    free(c2);
    return s;
}
