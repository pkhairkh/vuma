// atom_multiple_fields.vuma — three atomic cells holding 1, 2, 3; return their sum
// Expected exit code: 6
//
// Gold-standard atomic-operation test. Uses VUMA's builtin
// `atomic_store(addr, val)` / `atomic_load(addr)` / `atomic_cas(addr, exp, des)`
// syntax (the same syntax used by examples/atomics_demo.vuma and
// examples/spinlock.vuma). Single-threaded: tests the atomic-operation
// codegen, not concurrency safety.
//
// KNOWN CODEGEN GAP (as of this wave): the SCG-to-codegen bridge
// (`bridge_scg_to_codegen` in src/pipeline.rs) does not recognise
// `Expr::AtomicLoad` / `Expr::AtomicStore` / `Expr::AtomicCas` nodes —
// `to_scg.rs` emits them as opaque `Computation { Other("atomic_store(...)") }`
// nodes with NO DataFlow edges to their address/value arguments, so the
// bridge lowers them to `Add(0, 0)` no-ops instead of
// `IRInstr::AtomicLoad` / `IRInstr::AtomicStore`. Consequently
// `atomic_load` always returns 0 and `atomic_store` never writes.
// Tests whose expected exit is 0 pass accidentally; all others are
// NOW PASSING until the bridge is taught to emit CallNodes named
// "AtomicLoad"/"AtomicStore"/"AtomicCas" (which scg_to_ir.rs:2027-2113
// already knows how to lower to proper atomic IR instructions).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    atomic_store(a, 1);
    atomic_store(b, 2);
    atomic_store(c, 3);
    va = atomic_load(a);
    vb = atomic_load(b);
    vc = atomic_load(c);
    s: i32 = va + vb + vc;
    free(a);
    free(b);
    free(c);
    return s;
}
