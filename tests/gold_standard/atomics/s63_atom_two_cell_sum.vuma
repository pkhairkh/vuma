// s63_atom_two_cell_sum.vuma — two cells, atomic sum = 215 (120 + 95)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 215
//
// Two 8-byte cells. atomic_store 120/95, atomic_load each,
// 120 + 95 = 215. On the current backend the loads return 0
// -> 0 + 0 = 0 -> exit 0. Will exit 215 once atomics are wired
// through. Distinct from s51_atom_three_cell_sum (250), s58_atom_
// three_cell_diff (120) and s55_atom_two_cell_sum (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 120);
    atomic_store(c2, 95);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 215
    free(c1);
    free(c2);
    return s;
}
