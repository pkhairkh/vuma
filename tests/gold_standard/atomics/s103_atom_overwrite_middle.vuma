// s103_atom_overwrite_middle.vuma — atomic_store 1,200,50 then overwrite c2 to 41, atomic_load = 41
// Expected exit code (correct): 41
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Three 8-byte cells. atomic_store 1 to c1, 200 to c2, 50 to c3, then atomic_store 41 to c2 (overwrite). atomic_load c2 -> 41. On the current backend atomic_load returns 0 -> exit 0. Will exit 41 once atomics are wired through.
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c2, 200);
    atomic_store(c3, 50);
    atomic_store(c2, 41);
    v = atomic_load(c2);          // 41
    free(c1);
    free(c2);
    free(c3);
    return v;
}
