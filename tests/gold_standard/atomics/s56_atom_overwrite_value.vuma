// s56_atom_overwrite_value.vuma — store 80, overwrite to 175, load = 175
// Expected exit code: 175
//
// Single 8-byte cell. atomic_store 80, then atomic_store 175 (over-
// write), atomic_load -> 175. On the current backend the load returns
// 0 -> exit 0. Will exit 175 once atomics are wired through. Distinct
// from s54_atom_overwrite_value (140) and s50_atom_overwrite_value
// (160).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c1, 175);
    a = atomic_load(c1);
    free(c1);
    return a;
}
