// s56_atom_three_cell_xor.vuma — three cells, atomic XOR = 15 (0xAA^0x55^0xF0)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 15
//
// Three 8-byte cells. atomic_store 170/85/240, atomic_load each, XOR
// sequentially -> 15 (0x0F). On the current backend the loads return
// 0 -> exit 0. Will exit 15 once atomics are wired through. Distinct
// from s54_atom_three_cell_sum (190) and s50_atom_three_cell_xor (60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 170);            // 0xAA
    atomic_store(c2, 85);             // 0x55
    atomic_store(c3, 240);            // 0xF0
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;                   // 0xFF
    s: i32 = t ^ c;                   // 0x0F = 15
    free(c1);
    free(c2);
    free(c3);
    return s;
}
