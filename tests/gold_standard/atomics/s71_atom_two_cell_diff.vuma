// s71_atom_two_cell_diff.vuma — two cells, atomic diff = 130 (200 - 70)
// Expected exit code: 130
//
// Two 8-byte cells. atomic_store 200/70, atomic_load each, diff
// -> 130. On the current backend the loads return 0 -> 0 - 0 = 0
// -> exit 0. Will exit 130 once atomics are wired through.
// Distinct from s69_atom_two_cell_sum (155), s70_atom_two_cell_sum
// (75) and s66_atom_two_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 70);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 130
    free(c1);
    free(c2);
    return d;
}
