// s46_atom_three_cell_sum.vuma — three cells, atomic sum = 210 (60 + 70 + 80)
// Expected exit code: 210
//
// Three 8-byte cells. atomic_store 60/70/80, atomic_load each, sum ->
// 210. On the current backend the loads return 0 -> exit 0. Will
// exit 210 once atomics are wired through. Distinct from s42_atom_
// three_cell_xor (195) and s38_atom_three_cell_sum (150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c2, 70);
    atomic_store(c3, 80);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;
    s: i32 = t + c;                  // 210
    free(c1);
    free(c2);
    free(c3);
    return s;
}
