// s76_atom_overwrite_value.vuma — overwrite to 72, atomic_load = 72
// Expected exit code: 72
//
// Single 8-byte cell. atomic_store 100, then atomic_store 72.
// atomic_load should return 72. On the current backend the load
// returns 0 -> exit 0. Will exit 72 once atomics are wired
// through. Distinct from s74_atom_overwrite_value (23),
// s73_atom_overwrite_value (137) and s72_atom_overwrite_value (170).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 72);
    v = atomic_load(c1);
    free(c1);
    return v;
}
