// s79_atom_overwrite_value.vuma — overwrite to 17, atomic_load = 17
// Expected exit code (correct): 17
// Observed on current x86_64 backend: 0 (FAIL — known bug: atomic_load returns 0)
//
// Single 8-byte cell. atomic_store 1, then atomic_store 17.
// atomic_load should return 17. On the current backend the load
// returns 0 -> exit 0. Will exit 17 once atomics are wired
// through. Distinct from s78_atom_overwrite_value (3),
// s77_atom_overwrite_value (2) and s76_atom_overwrite_value (3).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c1, 17);
    r = atomic_load(c1);
    free(c1);
    return r;
}
