// s33_atom_overwrite_first.vuma — overwrite first cell, atomic load = 100
// Expected exit code (correct): 100
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Atomics test. On the current x86_64 backend atomic_load returns 0, so the
// documented correct value (100) is not observed. Will exit
// 100 once the atomics bridge is wired through.
// Distinct from s30_atom_overwrite_first (different values) and s26_atom_overwrite_load (overwrite-then-load).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c1, 100);
    a = atomic_load(c1);
    r: i32 = a;                     // 100
    free(c1);
    return r;
}
