// s86_atom_three_cell_diff.vuma — three cells, atomic diff = 170 (240 - 50 - 20)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 170
//
// Three 8-byte cells. atomic_store 240/50/20, atomic_load each,
// a - b - c -> 170. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 170 once atomics are
// wired through. Distinct from s82_atom_three_cell_diff (26),
// s78_atom_three_cell_diff (148) and s74_atom_three_cell_diff (40).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 240);
    atomic_store(c2, 50);
    atomic_store(c3, 20);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    r: i32 = a - b - c;               // 170
    free(c1);
    free(c2);
    free(c3);
    return r;
}
