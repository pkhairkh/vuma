// s86_atom_overwrite_value.vuma — overwrite to 240, atomic_load = 240
// Expected exit code: 240
//
// Single 8-byte cell. atomic_store 7, then atomic_store 240.
// atomic_load should return 240. On the current backend the load
// returns 0 -> exit 0. Will exit 240 once atomics are wired
// through. Distinct from s82_atom_overwrite_value (30),
// s78_atom_overwrite_value (3) and s74_atom_overwrite_value (23).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 7);
    atomic_store(c1, 240);
    r = atomic_load(c1);
    free(c1);
    return r;
}
