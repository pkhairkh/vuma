// s105_atom_overwrite_value.vuma — atomic_store 50, overwrite to 206, load = 206
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 206
// 
// Single 8-byte cell. atomic_store 50, then atomic_store 206 (overwrite), atomic_load -> 206 (the overwritten value). On the current backend atomic_load returns 0 -> exit 0. Will exit 206 once atomics are wired through.
// Distinct from s102_atom_overwrite_value (38), s101_atom_overwrite_value (56), s100_atom_overwrite_value (0).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 206);
    v = atomic_load(c1);          // 206
    free(c1);
    return v;
}
