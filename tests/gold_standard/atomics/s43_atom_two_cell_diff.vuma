// s43_atom_two_cell_diff.vuma — two cells, atomic diff = 70 (140 - 70)
// Expected exit code: 70
//
// Two 8-byte cells. atomic_store 140/70, atomic_load each, diff -> 70.
// On the current backend the loads return 0 -> exit 0. Will exit 70
// once atomics are wired through. Distinct from s42_atom_two_cell_sum
// (175) and s38_atom_two_cell_sum (170).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 140);
    atomic_store(c2, 70);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                  // 70
    free(c1);
    free(c2);
    return d;
}
