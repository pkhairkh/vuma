// s101_atom_three_cell_diff.vuma — three cells, atomic diff = 110 (220 - 80 - 30)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 110
//
// Three 8-byte cells. atomic_store 220/80/30, atomic_load each,
// a - b - c -> 110. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 110 once atomics are wired
// through. Distinct from s98_atom_three_cell_sum (0; correct 119),
// s97_atom_three_cell_diff (0; correct 46) and
// s94_atom_three_cell_sum (0; correct 77).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 220);
    atomic_store(c2, 80);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    d: i32 = a - b - c;               // 110
    free(c1);
    free(c2);
    free(c3);
    return d;
}
