// s73_atom_overwrite_value.vuma — store 30 then overwrite to 144
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 144
//
// One 8-byte cell. atomic_store 30, then atomic_store 144 to the
// same cell, atomic_load -> 144. On the current backend the load
// returns 0 -> exit 0. Will exit 144 once atomics are wired through.
// Distinct from s70_atom_overwrite_value (185), s69_atom_overwrite_
// value (225) and s66_atom_overwrite_high (230).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 30);
    atomic_store(c1, 144);
    v = atomic_load(c1);              // 144
    free(c1);
    return v;
}
