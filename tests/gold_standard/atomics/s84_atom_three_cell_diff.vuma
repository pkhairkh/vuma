// s84_atom_three_cell_diff.vuma — three cells, atomic diff = 9 (20 - 8 - 3)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 9
//
// Three 8-byte cells. atomic_store 20/8/3, atomic_load each,
// a - b - c -> 9. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 9 once atomics are
// wired through. Distinct from s82_atom_three_cell_diff (26),
// s74_atom_three_cell_diff (88) and s72_atom_three_cell_diff (180).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 20);
    atomic_store(c2, 8);
    atomic_store(c3, 3);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    r: i32 = a - b - c;               // 9
    free(c1);
    free(c2);
    free(c3);
    return r;
}
