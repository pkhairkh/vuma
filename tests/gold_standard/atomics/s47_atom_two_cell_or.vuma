// s47_atom_two_cell_or.vuma — two cells, atomic or = 204 (0x88 | 0x44)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 204
//
// Two 8-byte cells. atomic_store 136/68 (0x88/0x44), atomic_load each,
// or -> 204 (0xCC). On the current backend the loads return 0 ->
// exit 0. Will exit 204 once atomics are wired through. Distinct
// from s46_atom_two_cell_xor (0xA5 ^ 0x5A = 255) and s42_atom_two_
// cell_sum (175).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 136);
    atomic_store(c2, 68);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a | b;                  // 204
    free(c1);
    free(c2);
    return s;
}
