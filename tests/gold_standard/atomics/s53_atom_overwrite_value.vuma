// s53_atom_overwrite_value.vuma — overwrite to 235, atomic_load = 235
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 235
//
// Single 8-byte cell. atomic_store 50, then atomic_store 235.
// atomic_load should return 235. On the current backend the load
// returns 0 -> exit 0. Will exit 235 once atomics are wired
// through. Distinct from s49_atom_overwrite_max (255) and
// s50_atom_overwrite_value (220).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 235);
    v = atomic_load(c1);
    free(c1);
    return v;
}
