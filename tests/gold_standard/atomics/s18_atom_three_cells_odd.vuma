// s18_atom_three_cells_odd.vuma — atomic_store 11/33/55, sum = 99
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 99  (11 + 33 + 55)
//
// Three 8-byte cells. atomic_store 11/33/55 (ascending odd multiples
// of 11) into each, then atomic_load all three and sum. On the current
// backend all loads return 0 (atomic_store/load not bridged) -> exit 0.
// Will exit 99 once atomic ops are wired. Distinct from
// s14_atom_store_three_load (values 33/44/55 = 132) and
// s10_atom_three_cells (10/20/30 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 11);
    atomic_store(c2, 33);
    atomic_store(c3, 55);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
