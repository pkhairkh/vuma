// s41_atom_two_cell_sum.vuma - two cells, atomic sum = 215 (140 + 75)
// Expected exit code: 215
//
// Two 8-byte cells. atomic_store 140/75, atomic_load each, sum -> 215.
// On the current backend the loads return 0 -> exit 0. Will exit 215
// once atomics are wired through. Distinct from s38_atom_two_cell_sum
// (170) and s34_atom_two_cell_sum (165).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 140);
    atomic_store(c2, 75);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 215
    free(c1);
    free(c2);
    return s;
}
