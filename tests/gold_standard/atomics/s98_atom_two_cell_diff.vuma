// s98_atom_two_cell_diff.vuma — two cells, atomic diff = 19 (100 - 81)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 19
//
// Two 8-byte cells. atomic_store 100/81, atomic_load each, a - b
// -> 19. On the current backend the loads return 0 -> 0 - 0 = 0 ->
// exit 0. Will exit 19 once atomics are wired through. Distinct from
// s94_atom_two_cell_diff (33), s90_atom_two_cell_diff (1) and
// s86_atom_two_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 81);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 19
    free(c1);
    free(c2);
    return d;
}
