// s28_atom_three_cell_sum.vuma — three cells, atomic_store 40/50/60, sum = 150
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 150  (40 + 50 + 60)
//
// Three 8-byte cells. atomic_store 40/50/60 into each, then atomic_load
// all three and sum. On the current backend all loads return 0 -> exit 0.
// Will exit 150 once atomics are wired through. Distinct from
// s26_atom_three_cell_sum (50/60/70 = 180) and s22_atom_three_cell_inc
// (inc-pattern).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c2, 50);
    atomic_store(c3, 60);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
