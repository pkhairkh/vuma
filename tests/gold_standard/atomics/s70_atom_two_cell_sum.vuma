// s70_atom_two_cell_sum.vuma — two cells, atomic sum = 75 (55 + 20)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 75
//
// Two 8-byte cells. atomic_store 55/20, atomic_load each, sum
// -> 75. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 75 once atomics are wired through.
// Distinct from s66_atom_two_cell_sum (200), s65_atom_two_cell_
// diff (135) and s62_atom_two_cell_diff (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 55);
    atomic_store(c2, 20);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 75
    free(c1);
    free(c2);
    return s;
}
