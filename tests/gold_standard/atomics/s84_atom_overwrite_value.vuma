// s84_atom_overwrite_value.vuma — overwrite to 10, atomic_load = 10
// Expected exit code: 10
//
// Single 8-byte cell. atomic_store 2, then atomic_store 10.
// atomic_load should return 10. On the current backend the load
// returns 0 -> exit 0. Will exit 10 once atomics are wired
// through. Distinct from s82_atom_overwrite_value (30),
// s78_atom_overwrite_value (3) and s74_atom_overwrite_value (23).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 2);
    atomic_store(c1, 10);
    r = atomic_load(c1);
    free(c1);
    return r;
}
