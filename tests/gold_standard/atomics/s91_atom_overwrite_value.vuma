// s91_atom_overwrite_value.vuma — overwrite c1 to 14, atomic load = 14
// Expected exit code: 14
//
// Single 8-byte cell. atomic_store 5, then atomic_store 14
// (overwrite), then atomic_load -> 14. On the current backend the
// load returns 0 -> exit 0. Will exit 14 once atomics are wired
// through. Distinct from s90_atom_overwrite_value (13),
// s86_atom_overwrite_value (245) and s82_atom_overwrite_value (242).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 14);
    v = atomic_load(c1);              // 14
    free(c1);
    return v;
}
