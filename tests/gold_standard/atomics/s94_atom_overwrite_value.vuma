// s94_atom_overwrite_value.vuma — overwrite c1 to 201, atomic load = 201
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 201
//
// Single 8-byte cell. atomic_store 5, then atomic_store 201
// (overwrite), then atomic_load -> 201. On the current backend the
// load returns 0 -> exit 0. Will exit 201 once atomics are wired
// through. Distinct from s90_atom_overwrite_value (13),
// s86_atom_overwrite_value (240) and s82_atom_overwrite_value (30).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 201);
    v = atomic_load(c1);              // 201
    free(c1);
    return v;
}
