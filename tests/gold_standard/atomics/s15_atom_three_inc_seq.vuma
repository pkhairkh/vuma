// s15_atom_three_inc_seq.vuma — three cells, atomic_store 10/20/30, sum = 60
// Expected exit code: 60
// Expected exit code (correct, post-bridge-fix): 60  (10 + 20 + 30)
//
// Three 8-byte cells. atomic_store 10/20/30 in ascending order, then
// atomic_load all three and sum. On the current backend all loads return 0
// -> exit 0. Will exit 60 once atomics are wired through. Distinct from
// s14_atom_store_three_load (values 33/44/55 = 132) and
// s8_atom_three_diff_values (three distinct values framing).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 10);
    atomic_store(c2, 20);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
