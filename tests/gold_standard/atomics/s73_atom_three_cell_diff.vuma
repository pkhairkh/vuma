// s73_atom_three_cell_diff.vuma — three cells, diff = 131 (200 - 50 - 19)
// Expected exit code: 131
//
// Three 8-byte cells. atomic_store 200/50/19, atomic_load each,
// diff -> 200 - 50 - 19 = 131. On the current backend the loads
// return 0 -> exit 0. Will exit 131 once atomics are wired through.
// Distinct from s70_atom_three_cell_diff (110), s69_atom_three_cell_
// diff (105) and s66_atom_three_cell_diff (90).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 50);
    atomic_store(c3, 19);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 150
    d: i32 = t - c;                   // 131
    free(c1);
    free(c2);
    free(c3);
    return d;
}
