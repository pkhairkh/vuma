// s60_atom_overwrite_value.vuma — store 50, overwrite to 215, atomic_load = 215
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 215
//
// Single 8-byte cell. atomic_store 50, then atomic_store 215.
// atomic_load should return 215. On the current backend the load
// returns 0 -> exit 0. Will exit 215 once atomics are wired
// through. Distinct from s58_atom_overwrite_high (210) and
// s57_atom_overwrite_first (50).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 215);
    v = atomic_load(c1);
    free(c1);
    return v;
}
