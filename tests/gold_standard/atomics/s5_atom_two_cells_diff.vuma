// s5_atom_two_cells_diff.vuma — two atomic cells, distinct values, sum
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 150  (100 + 50)
//
// Two 8-byte cells. atomic_store 100 in cell1, 50 in cell2. Load
// both, sum, should be 150. Current backend returns 0+0=0.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 50);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a + b;
    free(c1);
    free(c2);
    return s;
}
