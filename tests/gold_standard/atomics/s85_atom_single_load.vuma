// s85_atom_single_load.vuma — atomic_store 130, atomic_load = 130
// Expected exit code: 130
//
// Single 8-byte cell. atomic_store 130, atomic_load should
// return 130. On the current backend the load returns 0 ->
// exit 0. Will exit 130 once atomics are wired through.
// Distinct from s82_atom_single_load, s78_atom_single_load
// and s74_atom_single_load.
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 130);
    r = atomic_load(c1);
    free(c1);
    return r;
}
