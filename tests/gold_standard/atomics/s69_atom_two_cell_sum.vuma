// s69_atom_two_cell_sum.vuma -- two cells, atomic sum = 155 (70 + 85)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 155
//
// Two 8-byte cells. atomic_store 70/85, atomic_load each, sum -> 155.
// On the current backend the loads return 0 -> 0 + 0 = 0 -> exit 0.
// Will exit 155 once atomics are wired through. Distinct from s66_atom_
// two_cell_sum (200), s65_atom_two_cell_diff (135) and s64_atom_two_
// cell_sum (175).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 70);
    atomic_store(c2, 85);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 155
    free(c1);
    free(c2);
    return s;
}
