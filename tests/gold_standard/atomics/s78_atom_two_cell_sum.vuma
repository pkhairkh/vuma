// s78_atom_two_cell_sum.vuma — two cells, atomic sum = 2 (1 + 1)
// Expected exit code: 2
//
// Two 8-byte cells. atomic_store 1/1, atomic_load each, sum
// -> 2. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 2 once atomics are wired through.
// Distinct from s74_atom_two_cell_sum (90), s73_atom_two_cell_sum
// (108) and s72_atom_two_cell_sum (120).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c2, 1);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 2
    free(c1);
    free(c2);
    return s;
}
