// s83_atom_overwrite_value.vuma — overwrite to 19, atomic_load = 19
// Expected exit code: 19
//
// Single 8-byte cell. atomic_store 6, then atomic_store 19.
// atomic_load should return 19. On the current backend the load
// returns 0 -> exit 0. Will exit 19 once atomics are wired
// through. Distinct from s78_atom_overwrite_value (3),
// s74_atom_overwrite_value (23) and s72_atom_overwrite_value (144).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 6);
    atomic_store(c1, 19);
    r = atomic_load(c1);
    free(c1);
    return r;
}
