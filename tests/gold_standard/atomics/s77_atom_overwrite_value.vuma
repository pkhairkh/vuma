// s77_atom_overwrite_value.vuma — overwrite to 47, atomic_load = 47
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 47
//
// Single 8-byte cell. atomic_store 100, then atomic_store 47.
// atomic_load should return 47. On the current backend the load
// returns 0 -> exit 0. Will exit 47 once atomics are wired
// through. Distinct from s70_atom_overwrite_value (185),
// s66_atom_overwrite_high (230) and s74_atom_overwrite_value (23).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 47);
    v = atomic_load(c1);
    free(c1);
    return v;
}
