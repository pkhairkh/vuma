// s106_atom_three_cell_diff.vuma — atomic_store 3 cells (200, 63, 63), 200-63-63 = 74
// Expected exit code: 74
//
// Three 8-byte cells. atomic_store 200, 63, 63; atomic_load each, return 200 - 63 - 63 = 74. On the current backend atomic_load returns 0 -> exit 0. Will exit 74 once atomics are wired through.
// Distinct from s102_atom_three_cell_diff (197), s101_atom_three_cell_diff (110), s100_atom_three_cell_diff (43).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 63);
    atomic_store(c3, 63);
    a = atomic_load(c1);          // 200
    b = atomic_load(c2);          // 63
    c = atomic_load(c3);          // 63
    d = a - b - c;                // 74
    free(c1);
    free(c2);
    free(c3);
    return d;
}
