// s65_atom_overwrite_high.vuma — overwrite to 195, atomic_load = 195
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 195
//
// Single 8-byte cell. atomic_store 70, then atomic_store 195.
// atomic_load should return 195. On the current backend the load
// returns 0 -> exit 0. Will exit 195 once atomics are wired
// through. Distinct from s51_atom_overwrite_value (245), s58_atom_
// overwrite_high (210) and s62_atom_overwrite_low (240).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 70);
    atomic_store(c1, 195);
    v = atomic_load(c1);
    free(c1);
    return v;
}
