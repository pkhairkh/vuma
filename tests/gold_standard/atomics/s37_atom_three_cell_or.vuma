// s37_atom_three_cell_or.vuma — three cells, atomic or = 0x10 | 0x20 | 0x40 = 0x70 = 112
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Atomics test. On the current x86_64 backend atomic_load returns 0, so the
// documented correct value (112) is not observed. Will exit
// 112 once the atomics bridge is wired through.
// Distinct from s33_atom_three_cell_xor (xor, 15) and s30_atom_three_cell_sum (sum, 0).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 16);           // 0x10
    atomic_store(c2, 32);           // 0x20
    atomic_store(c3, 64);           // 0x40
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    r: i32 = a | b | c;            // 0x70 = 112
    free(c1);
    free(c2);
    free(c3);
    return r;
}
