// s74_atom_two_cell_sum.vuma — two cells, atomic sum = 179 (122 + 57)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 179
//
// Two 8-byte cells. atomic_store 122/57, atomic_load each, sum
// -> 179. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 179 once atomics are wired through.
// Distinct from s70_atom_two_cell_sum (75), s66_atom_two_cell_sum
// (200) and s62_atom_two_cell_diff (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 122);
    atomic_store(c2, 57);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 179
    free(c1);
    free(c2);
    return s;
}
