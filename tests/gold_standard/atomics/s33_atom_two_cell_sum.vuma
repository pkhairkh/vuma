// s33_atom_two_cell_sum.vuma — two cells, atomic sum = 100 + 155 = 255
// Expected exit code (correct): 255
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Atomics test. On the current x86_64 backend atomic_load returns 0, so the
// documented correct value (255) is not observed. Will exit
// 255 once the atomics bridge is wired through.
// Distinct from s30_atom_two_cell_xor (xor, 255) and s26_atom_two_cell_or (or, 255).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 155);
    a = atomic_load(c1);
    b = atomic_load(c2);
    r: i32 = a + b;          // 255
    free(c1);
    free(c2);
    return r;
}
