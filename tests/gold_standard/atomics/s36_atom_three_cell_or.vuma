// s36_atom_three_cell_or.vuma — cells 100/020/010, OR = 110
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Three 8-byte cells store 100/20/10. OR of the three
// loaded values should be 110 (0x6E). On the current
// backend all atomic_loads return 0 -> exit 0. Will exit
// 110 once atomics are wired through.
// Distinct from s30_atom_three_cell_xor (xor, 0) and s27_atom_three_cell_or (different values).
// Expected exit code: 126

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 20);
    atomic_store(c3, 10);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d = atomic_load(c3);
    r = a | b;
    r = r | d;
    free(c1);
    free(c2);
    free(c3);
    return r;
}
