// s7_atom_three_cells_prod.vuma — three atomic cells, product = 4*5*6 = 120
// Expected exit code: 120
// Expected exit code (correct, post-bridge-fix): 120  (4 * 5 * 6)
//
// Three 8-byte cells. atomic_store 4/5/6 into each, then atomic_load
// all three and multiply. On the current backend all loads return 0
// -> exit 0. Will exit 120 once atomic ops are wired through.
// Distinct from s5_atom_three_cells_sum (sum, not product) and
// s4_atom_chain (sum of 11/22/33).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 4);
    atomic_store(c2, 5);
    atomic_store(c3, 6);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t = a * b;
    s = t * c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
