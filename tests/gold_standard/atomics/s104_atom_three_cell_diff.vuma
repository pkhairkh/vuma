// s104_atom_three_cell_diff.vuma — atomic_store 3 cells (210, 5, 3), 210-5-3 = 202
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 202
//
// Three 8-byte cells. atomic_store 210, 5, 3; atomic_load each, return 210 - 5 - 3 = 202. On the current backend atomic_load returns 0 -> exit 0. Will exit 202 once atomics are wired through.
// Distinct from s102_atom_overwrite_value (38), s102_atom_three_cell_diff (197), s102_atom_two_cell_sum (37).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 210);
    atomic_store(c2, 5);
    atomic_store(c3, 3);
    a = atomic_load(c1);          // 210
    b = atomic_load(c2);          // 5
    c = atomic_load(c3);          // 3
    d = a - b - c;                // 202
    free(c1);
    free(c2);
    free(c3);
    return d;
}
