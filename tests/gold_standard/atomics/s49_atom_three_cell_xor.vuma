// s49_atom_three_cell_xor.vuma — three cells, atomic xor = 216 (40 ^ 80 ^ 160)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 216
//
// Three 8-byte cells. atomic_store 40/80/160, atomic_load each, xor ->
// 216. 40 ^ 80 = 120; 120 ^ 160 = 216. On the current backend the
// loads return 0 -> exit 0. Will exit 216 once atomics are wired
// through. Distinct from s46_atom_three_cell_sum (210, sum) and s42_
// atom_three_cell_xor (195, xor).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c2, 80);
    atomic_store(c3, 160);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;
    s: i32 = t ^ c;                   // 216
    free(c1);
    free(c2);
    free(c3);
    return s;
}
