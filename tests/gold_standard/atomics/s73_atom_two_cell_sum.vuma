// s73_atom_two_cell_sum.vuma — two cells, atomic sum = 108 (47 + 61)
// Expected exit code: 108
//
// Two 8-byte cells. atomic_store 47/61, atomic_load each, sum
// -> 108. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 108 once atomics are wired through.
// Distinct from s70_atom_two_cell_sum (75), s69_atom_two_cell_sum
// (155) and s66_atom_two_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 47);
    atomic_store(c2, 61);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 108
    free(c1);
    free(c2);
    return s;
}
