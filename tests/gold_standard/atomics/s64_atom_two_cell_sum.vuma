// s64_atom_two_cell_sum.vuma — two cells, atomic sum = 175 (130 + 45)
// Expected exit code: 175
//
// Two 8-byte cells. atomic_store 130/45, atomic_load each, sum
// -> 175. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 175 once atomics are wired through. Distinct
// from s62_atom_overwrite_low (240), s62_atom_three_cell_sum (205)
// and s62_atom_two_cell_diff (170).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 130);
    atomic_store(c2, 45);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 175
    free(c1);
    free(c2);
    return s;
}
