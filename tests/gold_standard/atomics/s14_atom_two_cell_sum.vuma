// s14_atom_two_cell_sum.vuma — two cells, atomic_store 18/81, sum = 99
// Expected exit code: 99
// Expected exit code (correct, post-bridge-fix): 99  (18 + 81)
//
// Two 8-byte cells. atomic_store 18 in c1, 81 in c2, then
// atomic_load both and sum. On the current backend both loads
// return 0 -> exit 0. Will exit 99 once atomics are bridged.
// Distinct from s9_atom_two_cells_xor (XOR framing, two cells) and
// s10_atom_three_cells (three cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 18);
    atomic_store(c2, 81);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a + b;
    free(c1);
    free(c2);
    return s;
}
