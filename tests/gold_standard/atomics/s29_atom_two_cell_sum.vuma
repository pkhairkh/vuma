// s29_atom_two_cell_sum.vuma — atomic_store 70/65, sum = 135
// Expected exit code: 135
// Expected exit code (correct, post-bridge-fix): 135  (70 + 65)
//
// Two 8-byte cells. atomic_store 70/65 into each, then atomic_load both and sum. On the current backend all loads return 0 (atomic_store/load not bridged through to x86_64) -> exit 0. Will exit 135 once atomic ops are wired through. Distinct from s26_atom_two_cell_or (or, 240|15=255) and s22_atom_two_cell_xor (xor, 41^98=75).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 70);
    atomic_store(c2, 65);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a + b;
    free(c1);
    free(c2);
    return s;
}
