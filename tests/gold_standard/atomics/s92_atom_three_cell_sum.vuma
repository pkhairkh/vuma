// s92_atom_three_cell_sum.vuma — three cells, atomic sum = 35 (8 + 9 + 18)
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Three 8-byte cells. atomic_store 8/9/18, atomic_load each, sum
// -> 35. On the current backend the loads return 0 -> 0 + 0 + 0 = 0
// -> exit 0. Will exit 35 once atomics are wired through. Distinct
// from s90_atom_three_cell_sum (12), s86_atom_three_cell_diff (60)
// and s82_atom_three_cell_diff (110).
// Expected exit code: 35
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 8);
    atomic_store(c2, 9);
    atomic_store(c3, 18);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b + c;               // 35
    free(c1);
    free(c2);
    free(c3);
    return s;
}
