// s8_atom_three_diff_values.vuma — three atomic stores + loads, sum = 30 (5 + 10 + 15)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 30  (5 + 10 + 15)
//
// Three 8-byte cells. atomic_store 5/10/15 into each, then atomic_load
// all three and sum. On the current backend all loads return 0 -> exit 0.
// Will exit 30 once atomic ops are wired through. Distinct from
// s6_atom_two_cells_sum (two cells, different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c2, 10);
    atomic_store(c3, 15);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
