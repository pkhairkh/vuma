// s95_mf_two_helpers_mul.vuma — f1(2) * f2(3) = 4 * 4 = 16
// Expected exit code: 16
//
// Two single-arg helpers. f1(x) = x + 2; f2(y) = y + 1. main calls
// both and multiplies: f1(2) * f2(3) = 4 * 4 = 16. Distinct from
// s94_mf_two_helpers_mul (96), s90_mf_two_helpers_sub (2) and
// s82_mf_two_helpers_add (105).
fn f1(x: u32) -> u32 {
    k: u32 = 2;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 1;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(2);          // 4
    b: u32 = f2(3);          // 4
    p: u32 = a * b;          // 16
    return p;
}
