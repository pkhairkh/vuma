// s92_mf_two_helpers_sub.vuma — f1(100) - f2(28) = 101 - 29 = 72
// Expected exit code: 72
//
// Two single-arg helpers. f1(x) = x + 1; f2(y) = y + 1. main calls
// both and subtracts: f1(100) - f2(28) = 101 - 29 = 72. Distinct
// from s90_mf_two_helpers_sub (2), s86_mf_two_helpers_add (150) and
// s82_mf_two_helpers_add (105).
fn f1(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 1;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(100);        // 101
    b: u32 = f2(28);         // 29
    d: u32 = a - b;          // 72
    return d;
}
