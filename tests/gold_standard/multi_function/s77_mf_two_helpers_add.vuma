// s77_mf_two_helpers_add.vuma — add_eighteen(60)=78, add_forty_four(30)=74; 78+74=152
// Expected exit code: 152
//
// Two single-arg helpers called on different literals then summed.
// add_eighteen(x) = x + 18; add_forty_four(x) = x + 44. main
// calls add_eighteen(60) -> 78 and add_forty_four(30) -> 74;
// sum = 152. Distinct from s70_mf_two_helpers_add (210), s66_mf_
// two_helpers_sub (185) and s74_mf_two_helpers_add (184).

fn add_eighteen(x: u32) -> u32 {
    n: u32 = 18;
    r: u32 = x + n;
    return r;
}
fn add_forty_four(x: u32) -> u32 {
    n: u32 = 44;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_eighteen(60);       // 78
    b: u32 = add_forty_four(30);     // 74
    r: u32 = a + b;                  // 152
    return r;
}
