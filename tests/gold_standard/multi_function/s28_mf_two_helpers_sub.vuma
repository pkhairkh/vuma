// s28_mf_two_helpers_sub.vuma — sub5(80) - add10(20) = 75 - 30 = 45
// Expected exit code: 45
//
// Two single-arg helpers, each called once from main, results subtracted.
// sub5(x) = x - 5; add10(x) = x + 10. main calls sub5(80) -> 75 and
// add10(20) -> 30; diff = 75 - 30 = 45. Distinct from
// s26_mf_two_helpers_sum (add3+mul2 = 53) and s22_mf_two_helpers_diff
// (dbl-half = 10).

fn sub5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}
fn add10(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = sub5(80);    // 75
    b: u32 = add10(20);   // 30
    r: u32 = a - b;       // 45
    return r;
}
