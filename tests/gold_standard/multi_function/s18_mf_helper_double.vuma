// s18_mf_helper_double.vuma — double(15) = 30, return
// Expected exit code: 30
//
// Helper double(x) = x * 2. main calls double(15) -> 30 and returns
// it. Single helper, single call. Distinct from s14_mf_helper_double
// (double(20) = 40) and s10_mf_helper_returns_arg (identity helper).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = double(15);
    return v;
}
