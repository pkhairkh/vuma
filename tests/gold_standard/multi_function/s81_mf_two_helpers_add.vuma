// s81_mf_two_helpers_add.vuma — f1(40) + f2(40) = 70 + 85 = 155
// Expected exit code: 155
//
// Two single-arg helpers. f1(x) = x + 30; f2(y) = y + 45. main
// calls both and adds: f1(40) + f2(40) = 70 + 85 = 155.
// Distinct from s78_mf_two_helpers_add (4),
// s77_mf_two_helpers_add (152) and s76_mf_two_helpers_add (102).
fn f1(x: u32) -> u32 {
    k: u32 = 30;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 45;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(40);          // 70
    b: u32 = f2(40);          // 85
    s: u32 = a + b;            // 155
    return s;
}
