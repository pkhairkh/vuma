// s17_mf_two_helpers_sum.vuma — add3(10) + add3(20) = 13 + 23 = 36
// Expected exit code: 36
//
// add3(x) = x + 3. main calls add3(10) -> 13 and add3(20) -> 23, sums
// -> 36. Same helper called twice with different args, results summed.
// Distinct from s14_mf_three_helpers_sum (three helpers) and
// s9_mf_one_helper_called_thrice (same helper, no sum).

fn add3(x: u32) -> u32 {
    three: u32 = 3;
    r: u32 = x + three;
    return r;
}

fn main() -> i32 {
    a: u32 = add3(10);    // 13
    b: u32 = add3(20);    // 23
    s: u32 = a + b;       // 36
    return s;
}
