// s105_mf_double_then_add.vuma — 2*f(50) + g(10) = 2*51 + 11 = 113
// Expected exit code: 113
// 
// Two helpers f(x)=x+1, g(x)=x+1. main calls a = f(50) = 51; b = g(10) = 11; r = a + a + b = 51 + 51 + 11 = 113 (doubling a via self-addition, then adding b). Flat sequential form, no nested calls.
// Distinct from s102_mf_two_helpers_sub (1), s101_mf_double_then_sub (39), s100_mf_two_helpers_mul (144).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn g(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn main() -> i32 {
    a: u32 = f(50);         // 51
    b: u32 = g(10);         // 11
    r: u32 = a + a + b;     // 113
    return r;
}
