// s36_mf_three_chain.vuma — f(10)=25, g(25)=75, h(75)=73
// Expected exit code: 73
//
// Three single-arg helpers chained: f(x)=x+15, g(x)=x*3,
// h(x)=x-2. main calls them in sequence via intermediate
// variables: f(10)=25, g(25)=75, h(75)=73. Uses
// intermediates to avoid the nested-call miscompilation.
// Distinct from s30_mf_three_chain (different ops) and s27_mf_three_chain (different values).

fn f(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x + n;
    return r;
}
fn g(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn h(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f(10);        // 25
    b: u32 = g(a);         // 75
    c: u32 = h(b);         // 73
    return c;
}
