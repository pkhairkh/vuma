// s83_mf_two_helpers_add.vuma — f1(100) + f2(7) = 108 + 101 = 209
// Expected exit code: 209
//
// Two single-arg helpers. f1(x) = x + 8; f2(y) = y + 94. main
// calls both and adds: f1(100) + f2(7) = 108 + 101 = 209.
// Distinct from s78_mf_two_helpers_add (4), s74_mf_two_helpers_
// add (130) and s72_mf_two_helpers_add (155).
fn f1(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 94;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(100);         // 108
    b: u32 = f2(7);           // 101
    s: u32 = a + b;           // 209
    return s;
}
