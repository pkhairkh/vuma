// s10_mf_helper_returns_arg.vuma — identity(77) = 77
// Expected exit code: 77
//
// Helper identity(x) returns its argument unchanged. main calls
// identity(77) -> 77. Distinct from s5_mf_param_passthrough (chains
// two helpers passing the arg through) and s3_mf_param_passthrough.

fn identity(x: u32) -> u32 {
    r: u32 = x;
    return r;
}

fn main() -> i32 {
    v: u32 = identity(77);
    return v;
}
