// s36_mf_two_helpers_sum.vuma — add_one(40) + dbl(50) = 41 + 100 = 141
// Expected exit code: 141
//
// Two single-arg helpers: add_one(x) = x + 1, dbl(x) =
// x * 2. main calls add_one(40) -> 41 and dbl(50) ->
// 100; sum = 141. Uses intermediate variables for each
// call result to avoid the nested-call-expression
// miscompilation.
// Distinct from s30_mf_two_helpers_sum (add4+mul3 = 79) and s27_mf_two_helpers_sum (different ops).

fn add_one(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_one(40);  // 41
    b: u32 = dbl(50);      // 100
    r: u32 = a + b;        // 141
    return r;
}
