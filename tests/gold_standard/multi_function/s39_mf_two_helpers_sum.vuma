// s39_mf_two_helpers_sum.vuma — add_five(45) + mul_three(20) = 50 + 60 = 110
// Expected exit code: 110
//
// Two single-arg helpers, each called once from main, results
// added. add_five(x) = x + 5; mul_three(x) = x * 3. main calls
// add_five(45) -> 50 and mul_three(20) -> 60; sum = 110. Distinct
// from s38_mf_two_helpers_sum (116) and s34_mf_two_helpers_sum
// (105).

fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn mul_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_five(45);    // 50
    b: u32 = mul_three(20);   // 60
    r: u32 = a + b;           // 110
    return r;
}
