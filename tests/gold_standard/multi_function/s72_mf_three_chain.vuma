// s72_mf_three_chain.vuma — f3(f2(f1(95))) = f3(f2(101)) = f3(111) = 141
// Expected exit code: 141
//
// Three single-arg helpers chained. f1(x) = x + 6; f2(x) = x + 10;
// f3(x) = x + 30. main calls f3(f2(f1(95))) -> 95 + 6 + 10 + 30
// = 141. Distinct from s70_mf_three_chain (165), s69_mf_three_
// chain (83) and s66_mf_three_chain (85).
fn f1(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 30;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(95);             // 101
    b: u32 = f2(a);              // 111
    c: u32 = f3(b);              // 141
    return c;
}
