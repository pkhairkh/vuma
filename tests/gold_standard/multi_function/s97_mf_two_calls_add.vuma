// s97_mf_two_calls_add.vuma — f(20) + f(28) = 35 + 43 = 78
// Expected exit code: 78
//
// Single helper f(x) = x + 15. main calls it twice and
// adds: f(20) + f(28) = 35 + 43 = 78.
// Distinct from s94_mf_three_chain (70), s90_mf_two_calls_add (59), s86_mf_double_then_add (65).
fn f(x: u32) -> u32 {
    k: u32 = 15;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(20);          // 35
    b: u32 = f(28);          // 43
    s: u32 = a + b;          // 78
    return s;
}
