// s55_mf_three_chain.vuma — h(8)=18, g(18)=36, f(36)=41
// Expected exit code: 41
//
// Three single-arg helpers chained sequentially. h(x) = x + 10;
// g(x) = x * 2; f(x) = x + 5. main calls h(8) -> 18, g(18) -> 36,
// f(36) -> 41. Distinct from s54_mf_three_chain (35) and
// s53_mf_three_chain (30).

fn h(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn g(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn f(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = h(8);             // 18
    b: u32 = g(a);             // 36
    r: u32 = f(b);             // 41
    return r;
}
