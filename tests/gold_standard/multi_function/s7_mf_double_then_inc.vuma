// s7_mf_double_then_inc.vuma — double(5)=10, inc(10)=11, sum = 21
// Expected exit code: 21
//
// double(x) = x * 2; inc(x) = x + 1. main calls double(5) -> 10 and
// inc(10) -> 11, sums -> 21. Distinct from s5_mf_three_chain (three
// add-helpers chained) and s6_mf_call_two_then_sum (half + third).

fn double(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x * two;
    return r;
}

fn inc(x: u32) -> u32 {
    one: u32 = 1;
    r: u32 = x + one;
    return r;
}

fn main() -> i32 {
    a: u32 = double(5);   // 10
    b: u32 = inc(a);      // 11
    s: u32 = a + b;       // 21
    return s;
}
