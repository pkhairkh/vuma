// s70_mf_three_chain.vuma — f3(f2(f1(100))) = f3(f2(105)) = f3(115) = 165
// Expected exit code: 165
//
// Three single-arg helpers chained. f1(x) = x + 5; f2(x) = x + 10;
// f3(x) = x + 50. main calls f3(f2(f1(100))) -> 100 + 5 + 10 + 50
// = 165. Distinct from s66_mf_three_chain (85), s65_mf_three_chain
// (127) and s62_mf_three_chain (80).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 50;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(100);           // 105
    b: u32 = f2(a);             // 115
    c: u32 = f3(b);             // 165
    return c;
}
