// s68_mf_two_helpers_mul.vuma — mul2(50)=100, mul3(30)=90; 100+90=190
// Expected exit code: 190
//
// Two single-arg helpers called on different literals then summed.
// mul2(x) = x * 2; mul3(x) = x * 3. main calls mul2(50) -> 100
// and mul3(30) -> 90; sum = 190. Distinct from s66_mf_two_helpers_
// sub (185), s62_mf_two_helpers_add (150) and s58_mf_two_helpers_
// sub (112).
fn mul2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn mul3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = mul2(50);          // 100
    b: u32 = mul3(30);          // 90
    r: u32 = a + b;             // 190
    return r;
}
