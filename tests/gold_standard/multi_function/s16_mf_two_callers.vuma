// s16_mf_two_callers.vuma — add100(5) + add100(50) = 105 + 150 = 255
// Expected exit code: 255
//
// Single helper add100(x) = x + 100, called twice from main with
// different arguments. Sums both results -> 105 + 150 = 255. Distinct
// from s5_mf_two_callers (two helpers, two callers) and s9_mf_pass_two_then_mul
// (pass-two-then-mul).

fn add100(x: u32) -> u32 {
    c: u32 = 100;
    r: u32 = x + c;
    return r;
}

fn main() -> i32 {
    a: u32 = add100(5);    // 105
    b: u32 = add100(50);   // 150
    s: u32 = a + b;        // 255
    return s;
}
