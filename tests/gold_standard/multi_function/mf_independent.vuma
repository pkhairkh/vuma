// mf_independent.vuma — two independent functions, sum results (4+5=9)
// Expected exit code: 9
//
// Tests two leaf functions that have no caller/callee relationship
// with each other. main sums their results: 4 + 5 = 9.

fn make4() -> u32 {
    return 4;
}

fn make5() -> u32 {
    return 5;
}

fn main() -> i32 {
    a: u32 = make4();
    b: u32 = make5();
    v: u32 = a + b;
    return v;
}
