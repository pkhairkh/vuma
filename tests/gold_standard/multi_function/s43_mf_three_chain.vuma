// s43_mf_three_chain.vuma — f1(20)=25, f2(25)=75, f3(75)=67
// Expected exit code: 67
//
// Three single-arg helpers chained: f1(x)=x+5, f2(x)=x*3,
// f3(x)=x-8. main calls f3(f2(f1(20))) -> f1(20)=25, f2(25)=75,
// f3(75)=67. Distinct from s42_mf_three_chain (55) and s38_mf_
// three_chain (65).

fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(20);    // 25
    b: u32 = f2(a);     // 75
    c: u32 = f3(b);     // 67
    return c;
}
