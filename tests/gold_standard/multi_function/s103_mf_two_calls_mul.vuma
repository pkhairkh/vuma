// s103_mf_two_calls_mul.vuma — f(2) * f(3) = 3 * 4 = 12
// Expected exit code: 12
//
// Single helper f(x) = x + 1. main calls it twice and multiplies: f(2) * f(3) = 3 * 4 = 12.
// Distinct from s99_mf_two_calls_mul (120).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(2);          // 3
    b: u32 = f(3);          // 4
    p: u32 = a * b;         // 12
    return p;
}
