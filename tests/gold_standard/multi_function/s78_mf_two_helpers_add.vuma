// s78_mf_two_helpers_add.vuma — f1(1) + f2(1) = 2 + 2 = 4
// Expected exit code: 4
//
// Two single-arg helpers. f1(x) = x + 1; f2(y) = y + 1. main
// calls both and adds: f1(1) + f2(1) = 2 + 2 = 4.
// Distinct from s74_mf_two_helpers_add (130), s73_mf_two_helpers_add
// (148) and s72_mf_two_helpers_add (155).
fn f1(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 1;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(1);          // 2
    b: u32 = f2(1);          // 2
    s: u32 = a + b;            // 4
    return s;
}
