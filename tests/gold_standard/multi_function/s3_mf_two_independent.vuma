// s3_mf_two_independent.vuma — two independent helpers, sum results
// Expected exit code: 90  (40 + 50)
//
// Helper A returns 40, helper B returns 50. Neither depends on the
// other. main calls both and returns their sum.

fn ha() -> u32 {
    return 40;
}
fn hb() -> u32 {
    return 50;
}

fn main() -> i32 {
    a: u32 = ha();
    b: u32 = hb();
    s: u32 = a + b;
    return s;
}
