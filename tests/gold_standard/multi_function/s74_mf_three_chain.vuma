// s74_mf_three_chain.vuma — f3(f2(f1(50))) = f3(f2(55)) = f3(65) = 111
// Expected exit code: 111
//
// Three single-arg helpers chained. f1(x) = x + 5; f2(x) = x + 10;
// f3(x) = x + 46. main calls f3(f2(f1(50))) -> 50 + 5 + 10 + 46
// = 111. Distinct from s70_mf_three_chain (165), s66_mf_three_
// chain (85) and s62_mf_three_chain (80).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 46;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(50);           // 55
    b: u32 = f2(a);            // 65
    c: u32 = f3(b);            // 111
    return c;
}
