// s31_mf_two_helpers_sum.vuma — add5(35) + mul4(20) = 40 + 80 = 120
// Expected exit code: 120
//
// Two single-arg helpers, each called once from main, results added.
// add5(x) = x + 5; mul4(x) = x * 4. main calls add5(35) -> 40 and
// mul4(20) -> 80; sum = 120. Distinct from s30_mf_two_helpers_sum
// (add4+mul3 = 79) and s28_mf_two_helpers_sub (sub-helper, 45).

fn add5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn mul4(x: u32) -> u32 {
    n: u32 = 4;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add5(35);    // 40
    b: u32 = mul4(20);    // 80
    r: u32 = a + b;       // 120
    return r;
}
