// s80_mf_two_helpers_add.vuma — f1(18) + f2(19) = 19 + 20 = 39
// Expected exit code: 39
//
// Two single-arg helpers. f1(x) = x + 1; f2(y) = y + 1. main
// calls both and adds: f1(18) + f2(19) = 19 + 20 = 39.
// Distinct from s78_mf_two_helpers_add (4),
// s74_mf_two_helpers_add (130) and s73_mf_two_helpers_add (148).
fn f1(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 1;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(18);          // 19
    b: u32 = f2(19);          // 20
    s: u32 = a + b;            // 39
    return s;
}
