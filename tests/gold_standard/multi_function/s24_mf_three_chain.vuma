// s24_mf_three_chain.vuma — sub2(inc(dbl(9))) = sub2(inc(18)) = sub2(19) = 17
// Expected exit code: 17
//
// Three single-arg helpers chained: dbl(x) = x * 2; inc(x) = x + 1;
// sub2(x) = x - 2. main calls dbl(9) -> 18, then inc(18) -> 19, then
// sub2(19) -> 17. Distinct from s22_mf_three_chain (dbl/inc/sub2 on 8,
// value 15) and s18_mf_three_helpers_sum (three helpers summed, not
// chained).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn sub2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(9);      // 18
    b: u32 = inc(a);      // 19
    c: u32 = sub2(b);     // 17
    return c;
}
