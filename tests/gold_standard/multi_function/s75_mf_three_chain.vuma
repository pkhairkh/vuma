// s75_mf_three_chain.vuma — f3(f2(f1(87))) = f3(f2(96)) = f3(111) = 134
// Expected exit code: 134
//
// Three single-arg helpers chained. f1(x) = x + 9; f2(x) = x + 15;
// f3(x) = x + 23. main calls f3(f2(f1(87))) -> 87 + 9 + 15 + 23
// = 134. Distinct from s74_mf_three_chain (111), s70_mf_three_
// chain (165) and s66_mf_three_chain (85).
fn f1(x: u32) -> u32 {
    n: u32 = 9;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 23;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(87);           // 96
    b: u32 = f2(a);            // 111
    c: u32 = f3(b);            // 134
    return c;
}
