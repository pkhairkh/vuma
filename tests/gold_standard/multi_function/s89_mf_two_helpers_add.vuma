// s89_mf_two_helpers_add.vuma — inc(5) + 58 = 6 + 58 = 64
// Expected exit code: 64
//
// Helper inc(x) = x + 1. main calls inc(5) -> 6, then
// adds literal 58 -> 64. Distinct from s86_mf_two_helpers_add
// (215), s82_mf_two_helpers_add (200) and s78_mf_two_helpers_add (3).
fn inc(x: u32) -> u32 {
    r: u32 = x + 1;
    return r;
}

fn main() -> i32 {
    v: u32 = inc(5);       // 6
    k: u32 = 58;
    s: u32 = v + k;         // 64
    return s;
}
