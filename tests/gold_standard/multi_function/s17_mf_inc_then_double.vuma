// s17_mf_inc_then_double.vuma — double(inc(15)) = double(16) = 32
// Expected exit code: 32
//
// inc(x) = x + 1; double(x) = x * 2. main calls inc(15) -> 16, passes
// that to double -> 32. Two helpers in a call chain. Distinct from
// s14_mf_helper_double (single helper) and s7_mf_double_then_inc
// (reverse order).

fn inc(x: u32) -> u32 {
    one: u32 = 1;
    r: u32 = x + one;
    return r;
}

fn double(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x * two;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(15);     // 16
    b: u32 = double(a);   // 32
    return b;
}
