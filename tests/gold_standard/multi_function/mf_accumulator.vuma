// mf_accumulator.vuma — helper(1) + helper(2) + helper(3) = 6
// Expected exit code: 6
//
// Tests calling the same helper three times with different arguments
// and summing the results: 1 + 2 + 3 = 6. Uses intermediate variables
// because VUMA miscompiles nested call expressions used directly
// inside arithmetic.

fn ident(x: u32) -> u32 {
    return x;
}

fn main() -> i32 {
    a: u32 = ident(1);
    b: u32 = ident(2);
    c: u32 = ident(3);
    v: u32 = a + b + c;
    return v;
}
