// s22_mf_two_helpers_diff.vuma — dbl(15) - half(40) = 30 - 20 = 10
// Expected exit code: 10
//
// Two single-arg helpers, each called once from main, results
// subtracted. dbl(x) = x * 2; half(x) = x / 2. main calls dbl(15) -> 30
// and half(40) -> 20; diff = 10. Distinct from s18_mf_helper_double
// (single helper, single call, value 30) and s14_mf_two_helpers_sub
// (two-helper sub, different values).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn half(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x / n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(15);     // 30
    b: u32 = half(40);    // 20
    r: u32 = a - b;       // 10
    return r;
}
