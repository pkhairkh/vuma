// s21_mf_three_chain.vuma — h(g(f(5))) = h(g(17)) = h(51) = 41
// Expected exit code: 41
//
// Three single-arg helpers chained. f(x) = x + 12; g(x) = x * 3;
// h(x) = x - 10. main calls f(5) -> 17, g(17) -> 51, h(51) -> 41.
// Distinct from s18_mf_three_helpers_sum (summed, not chained, 37) and
// s14_mf_three_helpers_sum (summed, 43).

fn f(x: u32) -> u32 {
    n: u32 = 12;
    r: u32 = x + n;
    return r;
}
fn g(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn h(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f(5);        // 17
    b: u32 = g(a);        // 51
    c: u32 = h(b);        // 41
    return c;
}
