// mf_four_funcs.vuma — main → add → mul → sub, return result
// Expected exit code: 10
//
// Tests a four-function linear call chain where each function performs
// its named operation with a constant and then calls the next function
// in the chain. main calls add(5); add computes 5+1=6 and calls mul(6);
// mul computes 6*2=12 and calls sub(12); sub computes 12-2=10 and
// returns 10. The value 10 propagates back through mul → add → main.
//
// Uses intermediate variables for the nested calls because VUMA
// miscompiles nested call expressions used directly as arguments.

fn sub(x: u32) -> u32 {
    return x - 2;
}

fn mul(x: u32) -> u32 {
    r: u32 = x * 2;
    s: u32 = sub(r);
    return s;
}

fn add(x: u32) -> u32 {
    r: u32 = x + 1;
    s: u32 = mul(r);
    return s;
}

fn main() -> i32 {
    v: u32 = add(5);
    return v;
}
