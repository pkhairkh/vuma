// s102_mf_two_helpers_sub.vuma — f(2) - g(1) = 3 - 2 = 1
// Expected exit code: 1
//
// Two helpers f(x)=x+1, g(x)=x+1. main calls f(2) - g(1) = 3 - 2 = 1. Two-helper subtraction.
// Distinct from s101_mf_double_then_sub (39), s101_mf_three_chain (20), s101_mf_two_helpers_sum (80).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn g(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn main() -> i32 {
    a: u32 = f(2);          // 3
    b: u32 = g(1);          // 2
    r: u32 = a - b;          // 1
    return r;
}
