// s58_mf_three_chain.vuma — add_eight(20)=28, double(28)=56, sub_six(56)=50
// Expected exit code: 50
// 
// Three single-arg helpers chained: add_eight(x)=x+8, double(x)=x*2,
// sub_six(x)=x-6. main calls add_eight(20) -> 28, double(28) -> 56,
// sub_six(56) -> 50. Distinct from s51_mf_two_helpers_add (80), s51_
// mf_three_chain (53) and s51_mf_double_then_add (120).

fn add_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_eight(20);     // 28
    b: u32 = double(a);         // 56
    r: u32 = sub_six(b);        // 50
    return r;
}
