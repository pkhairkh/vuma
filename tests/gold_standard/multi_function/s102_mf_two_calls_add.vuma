// s102_mf_two_calls_add.vuma — f(1) + f(3) = 2 + 4 = 6
// Expected exit code: 6
//
// Single helper f(x) = x + 1. main calls it twice and adds: f(1) + f(3) = 2 + 4 = 6.
// Distinct from s101_mf_double_then_sub (39), s101_mf_three_chain (20), s101_mf_two_helpers_sum (80).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(1);          // 2
    b: u32 = f(3);          // 4
    s: u32 = a + b;          // 6
    return s;
}
