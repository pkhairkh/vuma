// s99_mf_three_chain.vuma — f3(f2(f1(50))) = 50 + 8 + 8 + 8 = 74
// Expected exit code: 74
//
// Three single-arg helpers, each adds 8. main calls them in
// sequence, threading the result: a = f1(50) = 58; b = f2(a) = 66;
// c = f3(b) = 74. Distinct from s95_mf_three_chain (91),
// s91_mf_three_chain (35) and s87_mf_three_chain (105).
fn f1(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(50);         // 58
    b: u32 = f2(a);          // 66
    c: u32 = f3(b);          // 74
    return c;
}
