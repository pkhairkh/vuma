// s51_mf_three_chain.vuma — add_six(15)=21, triple(21)=63, sub_ten(63)=53
// Expected exit code: 53
//
// Three single-arg helpers chained: add_six(x)=x+6, triple(x)=x*3,
// sub_ten(x)=x-10. main calls add_six(15) -> 21, triple(21) -> 63,
// sub_ten(63) -> 53. Distinct from s50_mf_three_chain (50) and
// s47_mf_three_chain (68).

fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}
fn triple(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn sub_ten(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_six(15);      // 21
    b: u32 = triple(a);        // 63
    r: u32 = sub_ten(b);       // 53
    return r;
}
