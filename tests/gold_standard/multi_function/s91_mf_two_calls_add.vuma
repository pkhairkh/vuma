// s91_mf_two_calls_add.vuma — f(22) + f(23) = 32 + 33 = 65
// Expected exit code: 65
//
// Single helper f(x) = x + 10. main calls it twice and adds:
// f(22) + f(23) = 32 + 33 = 65. Distinct from s90_mf_two_calls_add
// (59), s86_mf_double_then_add (60) and s82_mf_two_helpers_add (105).
fn f(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(22);          // 32
    b: u32 = f(23);          // 33
    s: u32 = a + b;          // 65
    return s;
}
