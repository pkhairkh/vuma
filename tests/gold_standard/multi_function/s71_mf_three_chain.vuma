// s71_mf_three_chain.vuma — f3(f2(f1(70))) = f3(f2(77)) = f3(90) = 117
// Expected exit code: 117
//
// Three single-arg helpers chained. f1(x) = x + 7; f2(x) = x + 13;
// f3(x) = x + 27. main calls f3(f2(f1(70))) -> 70 + 7 + 13 + 27
// = 117. Distinct from s69_mf_three_chain (83), s70_mf_three_chain
// (165) and s66_mf_three_chain (85).
fn f1(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 13;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 27;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(70);            // 77
    b: u32 = f2(a);             // 90
    c: u32 = f3(b);             // 117
    return c;
}
