// s41_mf_three_chain.vuma - f1(30)=34, f2(34)=68, f3(68)=60
// Expected exit code: 60
//
// Three single-arg helpers chained: f1(x)=x+4, f2(x)=x*2,
// f3(x)=x-8. main calls f3(f2(f1(30))) -> f1(30)=34, f2(34)=68,
// f3(68)=60. Distinct from s38_mf_three_chain (65) and s34_mf_
// three_chain (80).

fn f1(x: u32) -> u32 {
    n: u32 = 4;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(30);    // 34
    b: u32 = f2(a);     // 68
    c: u32 = f3(b);     // 60
    return c;
}
