// s61_mf_two_helpers_add.vuma — add5(40)=45, add10(45)=55
// Expected exit code: 55
// 
// Two single-arg helpers chained: add5(x)=x+5, add10(x)=x+10. main
// calls add5(40) -> 45, add10(45) -> 55. Distinct from s58_mf_two_
// helpers_sub (112), s58_mf_three_chain (50) and s58_mf_triple_
// then_add (120).

fn add5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn add10(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add5(40);         // 45
    r: u32 = add10(a);         // 55
    return r;
}
