// s37_mf_two_callers.vuma — h(15) + h(35) = 25 + 45 = 70
// Expected exit code: 70
//
// Deterministic test in the multi_function category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_mf_two_callers (h(20)+h(50)=90) and s30_mf_two_callers (different helper).
fn h(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = h(15);       // 25
    b: u32 = h(35);       // 45
    r: u32 = a + b;       // 70
    return r;
}
