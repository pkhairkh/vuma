// s67_mf_three_chain.vuma — f3(f2(f1(40))) = f3(f2(45)) = f3(55) = 70
// Expected exit code: 70
//
// Three single-arg helpers chained. f1(x) = x + 5; f2(x) =
// x + 10; f3(x) = x + 15. main calls f3(f2(f1(40))) -> 40 +
// 5 + 10 + 15 = 70. Distinct from s66_mf_three_chain (85),
// s62_mf_three_chain (80) and s58_mf_three_chain (50).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(40);              // 45
    b: u32 = f2(a);               // 55
    c: u32 = f3(b);               // 70
    return c;
}
