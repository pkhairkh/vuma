// s101_mf_three_chain.vuma — f3(f2(f1(5))) = 5 + 5 + 5 + 5 = 20
// Expected exit code: 20
//
// Three single-arg helpers, each adds 5. main calls them in
// sequence, threading the result: a = f1(5) = 10; b = f2(a) = 15;
// c = f3(b) = 20. Distinct from s98_mf_three_chain (66),
// s97_mf_three_chain (94) and s94_mf_three_chain (70).
fn f1(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(5);          // 10
    b: u32 = f2(a);          // 15
    c: u32 = f3(b);          // 20
    return c;
}
