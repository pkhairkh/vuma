// mf_address_pass.vuma — main allocates, passes address to helper, helper
// stores 42, main loads
// Expected exit code: 42
//
// Tests passing an Address (allocated buffer) as a function parameter:
// main allocates a buffer, passes it to a helper that stores 42 at the
// start of the buffer, then main loads that value back and returns it.
//
// Uses `*p` (no offset) inside the function and `*buf` (no offset) in
// main because VUMA miscompiles `*(p + 0)` stores inside function
// bodies (the store is silently dropped, see Task 5-b workaround (c))
// and `*(buf + 0)` loads do not reliably observe `*p` stores.

fn store_val(p: Address) -> i32 {
    *p = 42;
    return 0;
}

fn main() -> i32 {
    buf = allocate(8);
    store_val(buf);
    v: u32 = *buf;
    free(buf);
    return v;
}
