// s76_mf_two_helpers_add.vuma — add_twenty(50)=70, add_two(30)=32; 70+32=102
// Expected exit code: 102
//
// Two single-arg helpers called on different literals then summed.
// add_twenty(x) = x + 20; add_two(x) = x + 2. main calls
// add_twenty(50) -> 70 and add_two(30) -> 32; sum = 102.
// Distinct from s74_mf_two_helpers_add (184), s73_mf_two_helpers_
// add (146) and s72_mf_two_helpers_add (224).
fn add_twenty(x: u32) -> u32 {
    n: u32 = 20;
    r: u32 = x + n;
    return r;
}
fn add_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_twenty(50);       // 70
    b: u32 = add_two(30);          // 32
    r: u32 = a + b;                // 102
    return r;
}
