// s22_mf_three_chain.vuma — sub2(inc(dbl(8))) = sub2(inc(16)) = sub2(17) = 15
// Expected exit code: 15
//
// Three single-arg helpers chained: dbl(x) = x * 2; inc(x) = x + 1;
// sub2(x) = x - 2. main calls dbl(8) -> 16, then inc(16) -> 17, then
// sub2(17) -> 15. Distinct from s18_mf_three_helpers_sum (three helpers
// summed, not chained) and s14_mf_three_chain (three chained, different
// ops).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn sub2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(8);      // 16
    b: u32 = inc(a);      // 17
    c: u32 = sub2(b);     // 15
    return c;
}
