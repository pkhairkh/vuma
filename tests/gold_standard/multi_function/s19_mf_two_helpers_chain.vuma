// s19_mf_two_helpers_chain.vuma — outer(inner(20)) = (20+8)*2 = 28*2 = 56
// Expected exit code: 56
//
// Two single-arg helpers chained: inner(x) = x + 8, outer(x) = x * 2.
// main calls inner(20) -> 28, then outer(28) -> 56. Each call uses an
// intermediate local. Distinct from s18_mf_two_helpers_chain
// (inner+12, outer*3 -> 51) and s14_mf_two_helpers_chain
// (inner+10, outer*2 -> 30).

fn inner(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}
fn outer(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inner(20);   // 28
    b: u32 = outer(a);    // 56
    return b;
}
