// s27_mf_inc_then_double.vuma — dbl(inc(50)) = dbl(51) = 102
// Expected exit code: 102
//
// Two single-arg helpers composed. inc(x) = x + 1; dbl(x) = x * 2.
// main calls dbl(inc(50)) -> dbl(51) -> 102. Distinct from
// s26_mf_inc_then_double (different operands) and s22_mf_double_then_inc
// (reversed order).

fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(50);     // 51
    r: u32 = dbl(a);      // 102
    return r;
}
