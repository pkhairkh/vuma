// s45_mf_double_then_add.vuma — dbl(45) + add_six(45) = 90 + 51 = 141
// Expected exit code: 141
//
// Two single-arg helpers called on the same literal then summed.
// dbl(x) = x * 2; add_six(x) = x + 6. main calls dbl(45) -> 90
// and add_six(45) -> 51; sum = 141. Distinct from s42_mf_double_
// then_sub (112) and s34_mf_double_then_add (80).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(45);          // 90
    b: u32 = add_six(45);      // 51
    r: u32 = a + b;            // 141
    return r;
}
