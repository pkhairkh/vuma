// s44_mf_double_then_add.vuma — dbl(35) + add_five(35) = 70 + 40 = 110
// Expected exit code: 110
//
// Two single-arg helpers called on the same literal then summed.
// dbl(x) = x * 2; add_five(x) = x + 5. main calls dbl(35) -> 70 and
// add_five(35) -> 40; sum = 110. Distinct from s42_mf_double_then_sub
// (112) and s38_mf_double_then_add (97).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(35);          // 70
    b: u32 = add_five(35);     // 40
    r: u32 = a + b;            // 110
    return r;
}
