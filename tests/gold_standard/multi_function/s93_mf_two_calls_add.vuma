// s93_mf_two_calls_add.vuma — f(33) + f(44) = 38 + 49 = 87
// Expected exit code: 87
//
// Single helper f(x) = x + 5. main calls it twice and adds:
// f(33) + f(44) = 38 + 49 = 87. Distinct from s90_mf_two_calls_add (59), s82_mf_two_helpers_add (105) and
// s78_mf_two_helpers_add (4).
fn f(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(33);          // 38
    b: u32 = f(44);          // 49
    s: u32 = a + b;          // 87
    return s;
}
