// s56_mf_two_helpers_add.vuma — add5(50) + add10(60) = 55 + 70 = 125
// Expected exit code: 125
//
// Two single-arg helpers summed. add5(x) = x + 5; add10(x) = x + 10.
// main calls add5(50) -> 55 and add10(60) -> 70, sum -> 125. Distinct
// from s54_mf_two_helpers_add (175) and s50_mf_two_helpers_mul (144).

fn add5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn add10(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add5(50);          // 55
    b: u32 = add10(60);         // 70
    r: u32 = a + b;             // 125
    return r;
}
