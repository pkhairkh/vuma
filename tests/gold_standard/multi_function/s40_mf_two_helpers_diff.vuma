// s40_mf_two_helpers_diff.vuma — dbl(35) - sub_five(35) = 70 - 30 = 40
// Expected exit code: 40
//
// Two single-arg helpers called on the same literal then differenced.
// dbl(x) = x * 2; sub_five(x) = x - 5. main calls dbl(35) -> 70 and
// sub_five(35) -> 30; diff = 40. Distinct from s38_mf_double_then_add
// (97) and s34_mf_double_then_add (80).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(35);        // 70
    b: u32 = sub_five(35);   // 30
    r: u32 = a - b;          // 40
    return r;
}
