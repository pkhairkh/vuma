// s106_mf_two_helpers_mul.vuma — f(1) * g(52) = 2 * 53 = 106
// Expected exit code: 106
//
// Two helpers f(x)=x+1, g(x)=x+1. main calls f(1) * g(52) = 2 * 53 = 106. Two-helper multiplication.
// Distinct from s102_mf_two_helpers_sub (1), s101_mf_two_helpers_sum (80), s100_mf_two_helpers_mul (144).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn g(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn main() -> i32 {
    a: u32 = f(1);          // 2
    b: u32 = g(52);          // 53
    r: u32 = a * b;          // 106
    return r;
}
