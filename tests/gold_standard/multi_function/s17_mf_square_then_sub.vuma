// s17_mf_square_then_sub.vuma — sq(9) - 5 = 81 - 5 = 76
// Expected exit code: 76
//
// sq(x) = x * x. main calls sq(9) -> 81, subtracts literal 5 -> 76.
// Single helper plus inline subtraction. Distinct from
// s14_mf_helper_double (double, not square) and s13_mf_shared_squarer
// (square called twice).

fn sq(x: u32) -> u32 {
    r: u32 = x * x;
    return r;
}

fn main() -> i32 {
    a: u32 = sq(9);       // 81
    five: u32 = 5;
    r: u32 = a - five;    // 76
    return r;
}
