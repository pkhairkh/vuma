// s34_mf_three_chain.vuma — f1(10)=20, f2(20)=40, f3(40)=80
// Expected exit code: 80
//
// Three single-arg helpers chained: f1(x)=x+10, f2(x)=x*2,
// f3(x)=x+40. main calls f3(f2(f1(10))) -> f1(10)=20, f2(20)=40,
// f3(40)=80. Distinct from s30_mf_three_chain (different ops)
// and s27_mf_three_chain (different values).

fn f1(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 40;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(10);    // 20
    b: u32 = f2(a);     // 40
    c: u32 = f3(b);     // 80
    return c;
}
