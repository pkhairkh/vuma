// s77_mf_three_chain.vuma — f3(f2(f1(40))) = f3(f2(63)) = f3(80) = 119
// Expected exit code: 119
//
// Three single-arg helpers chained. f1(x) = x + 23; f2(x) =
// x + 17; f3(x) = x + 39. main calls f3(f2(f1(40))) -> 40 + 23
// + 17 + 39 = 119. Distinct from s70_mf_three_chain (165),
// s66_mf_three_chain (85) and s74_mf_three_chain (111).

fn f1(x: u32) -> u32 {
    n: u32 = 23;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 17;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 39;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(40);           // 63
    b: u32 = f2(a);            // 80
    c: u32 = f3(b);            // 119
    return c;
}
