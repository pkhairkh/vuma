// s70_mf_two_helpers_add.vuma — add_five(100)=105, add_ten(95)=105; 105+105=210
// Expected exit code: 210
//
// Two single-arg helpers called on different literals then summed.
// add_five(x) = x + 5; add_ten(x) = x + 10. main calls
// add_five(100) -> 105 and add_ten(95) -> 105; sum = 210. Distinct
// from s66_mf_two_helpers_sub (185), s65_mf_two_helpers_add (85)
// and s62_mf_two_helpers_add (150).
fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn add_ten(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_five(100);     // 105
    b: u32 = add_ten(95);       // 105
    r: u32 = a + b;             // 210
    return r;
}
