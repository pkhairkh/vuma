// s60_mf_three_chain.vuma — add_seven(30)=37, double(37)=74, sub_four(74)=70
// Expected exit code: 70
//
// Three single-arg helpers chained: add_seven(x)=x+7, double(x)=x*2,
// sub_four(x)=x-4. main calls add_seven(30) -> 37, double(37) -> 74,
// sub_four(74) -> 70. Distinct from s58_mf_three_chain (50) and
// s57_mf_three_chain (45).

fn add_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_four(x: u32) -> u32 {
    n: u32 = 4;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_seven(30);     // 37
    b: u32 = double(a);         // 74
    r: u32 = sub_four(b);       // 70
    return r;
}
