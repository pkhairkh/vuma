// s27_mf_three_chain.vuma — f3(f2(f1(10))) = f3(f2(12)) = f3(36) = 31
// Expected exit code: 31
//
// Three single-arg helpers composed in a chain. f1(x) = x + 2;
// f2(x) = x * 3; f3(x) = x - 5. main calls f3(f2(f1(10))) -> 31.
// Distinct from s26_mf_three_chain (different chain) and
// s22_mf_three_chain (different chain).

fn f1(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(10);      // 12
    b: u32 = f2(a);       // 36
    r: u32 = f3(b);       // 31
    return r;
}
