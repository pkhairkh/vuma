// s103_mf_two_helpers_sum.vuma — f(5) + g(7) = 6 + 8 = 14
// Expected exit code: 14
//
// Two helpers f(x)=x+1, g(x)=x+1. main calls f(5) + g(7) = 6 + 8 = 14. Two-helper sum.
// Distinct from s101_mf_two_helpers_sum (80).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn g(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn main() -> i32 {
    a: u32 = f(5);          // 6
    b: u32 = g(7);          // 8
    s: u32 = a + b;         // 14
    return s;
}
