// s32_mf_two_helpers_sum.vuma - add5(100) + add10(100) = 105 + 110 = 215
// Expected exit code: 215
//
// add5(100) + add10(100) = 105 + 110 = 215. All operands loaded into typed
// variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from
// s30_mf_two_helpers_sum (add4+mul3 = 79) and s26_mf_two_helpers_sum
// (different operands).

fn add5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn add10(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add5(100);    // 105
    b: u32 = add10(100);   // 110
    r: u32 = a + b;        // 215
    return r;
}
