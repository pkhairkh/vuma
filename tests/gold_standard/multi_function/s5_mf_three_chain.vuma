// s5_mf_three_chain.vuma — add1(add2(add3(5))) = 5 + 3 + 2 + 1 = 11
// Expected exit code: 11
//
// Three single-arg helpers chained: add3(x) = x + 3, add2(x) = x + 2,
// add1(x) = x + 1. main calls add3(5) -> 8, add2(8) -> 10, add1(10)
// -> 11. Each call uses an intermediate local. Distinct from
// s4_mf_chain_3 (different addends).

fn add3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x + n;
    return r;
}
fn add2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x + n;
    return r;
}
fn add1(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add3(5);   // 8
    b: u32 = add2(a);   // 10
    c: u32 = add1(b);   // 11
    return c;
}
