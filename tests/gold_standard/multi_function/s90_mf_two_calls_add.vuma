// s90_mf_two_calls_add.vuma — f(20) + f(19) = 30 + 29 = 59
// Expected exit code: 59
//
// Single helper f(x) = x + 10. main calls it twice and adds:
// f(20) + f(19) = 30 + 29 = 59. Distinct from s86_mf_double_then_
// add (60), s82_mf_two_helpers_add (105) and s78_mf_two_helpers_
// add (4).
fn f(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(20);          // 30
    b: u32 = f(19);          // 29
    s: u32 = a + b;          // 59
    return s;
}
