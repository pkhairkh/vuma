// s65_mf_double_then_sub.vuma — double(75)=150, sub_ten(150)=140
// Expected exit code: 140
//
// Two single-arg helpers chained: double(x)=x*2, sub_ten(x)=x-10.
// main calls double(75) -> 150, sub_ten(150) -> 140. Distinct from
// s51_mf_double_then_add (120), s58_mf_triple_then_add (120) and s62_
// mf_double_then_add (115).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_ten(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(75);       // 150
    r: u32 = sub_ten(a);       // 140
    return r;
}
