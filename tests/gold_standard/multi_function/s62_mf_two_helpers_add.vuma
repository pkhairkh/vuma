// s62_mf_two_helpers_add.vuma — add_three(60)=63, add_seven(80)=87; 63+87=150
// Expected exit code: 150
// 
// Two single-arg helpers called on different literals then summed.
// add_three(x) = x + 3; add_seven(x) = x + 7. main calls add_three(60)
// -> 63 and add_seven(80) -> 87; sum = 150. Distinct from s51_mf_two_
// helpers_add (80), s58_mf_two_helpers_sub (112) and s55_mf_two_
// helpers_add (80).

fn add_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x + n;
    return r;
}
fn add_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_three(60);     // 63
    b: u32 = add_seven(80);     // 87
    r: u32 = a + b;             // 150
    return r;
}
