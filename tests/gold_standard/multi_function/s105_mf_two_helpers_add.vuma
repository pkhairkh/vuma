// s105_mf_two_helpers_add.vuma — f(100) + g(47) = 101 + 48 = 149
// Expected exit code: 149
// 
// Two helpers f(x)=x+1, g(x)=x+1. main calls f(100) + g(47) = 101 + 48 = 149. Two-helper addition.
// Distinct from s102_mf_two_calls_add (6), s101_mf_two_helpers_sum (80), s100_mf_two_calls_add (118).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn g(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn main() -> i32 {
    a: u32 = f(100);        // 101
    b: u32 = g(47);         // 48
    r: u32 = a + b;         // 149
    return r;
}
