// s94_mf_two_calls_sub.vuma — f(40) - f(17) = 50 - 27 = 23
// Expected exit code: 23
//
// Single helper f(x) = x + 10. main calls it twice and subtracts:
// f(40) - f(17) = 50 - 27 = 23. Distinct from s90_mf_two_calls_add
// (59), s86_mf_double_then_add (65) and s82_mf_double_then_add (50).
fn f(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(40);          // 50
    b: u32 = f(17);          // 27
    d: u32 = a - b;          // 23
    return d;
}
