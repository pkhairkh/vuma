// s66_mf_three_chain.vuma — f3(f2(f1(50))) = f3(f2(55)) = f3(65) = 85
// Expected exit code: 85
//
// Three single-arg helpers chained. f1(x) = x + 5; f2(x) = x + 10;
// f3(x) = x + 20. main calls f3(f2(f1(50))) -> 50 + 5 + 10 + 20
// = 85. Distinct from s62_mf_three_chain (80), s58_mf_three_
// chain (50) and s55_mf_three_chain (41).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 20;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(50);            // 55
    b: u32 = f2(a);             // 65
    c: u32 = f3(b);             // 85
    return c;
}
