// s95_mf_two_calls_add.vuma — f(40) + f(30) = 51 + 41 = 92
// Expected exit code: 92
//
// Single helper f(x) = x + 11. main calls it twice and adds:
// f(40) + f(30) = 51 + 41 = 92. Distinct from s94_mf_two_calls_sub
// (23), s90_mf_two_calls_add (59) and s82_mf_double_then_add (50).
fn f(x: u32) -> u32 {
    k: u32 = 11;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(40);          // 51
    b: u32 = f(30);          // 41
    s: u32 = a + b;          // 92
    return s;
}
