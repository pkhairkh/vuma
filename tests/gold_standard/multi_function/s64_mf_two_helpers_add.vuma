// s64_mf_two_helpers_add.vuma — add_eleven(55)=66, add_fourteen(55)=69; 66+69=135
// Expected exit code: 135
//
// Two single-arg helpers called on the same literal then summed.
// add_eleven(x) = x + 11; add_fourteen(x) = x + 14. main calls
// add_eleven(55) -> 66 and add_fourteen(55) -> 69; sum = 135. Distinct
// from s62_mf_double_then_add (115), s62_mf_three_chain (80) and s62_mf_
// two_helpers_add (150).

fn add_eleven(x: u32) -> u32 {
    n: u32 = 11;
    r: u32 = x + n;
    return r;
}
fn add_fourteen(x: u32) -> u32 {
    n: u32 = 14;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_eleven(55);    // 66
    b: u32 = add_fourteen(55);  // 69
    r: u32 = a + b;             // 135
    return r;
}
