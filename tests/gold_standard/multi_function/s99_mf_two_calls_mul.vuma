// s99_mf_two_calls_mul.vuma — f(7) * f(5) = 12 * 10 = 120
// Expected exit code: 120
//
// Single helper f(x) = x + 5. main calls it twice and multiplies:
// f(7) * f(5) = 12 * 10 = 120. Distinct from s95_mf_two_calls_add
// (92), s91_mf_two_calls_add (65) and s87_mf_double_then_add (85).
fn f(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(7);           // 12
    b: u32 = f(5);           // 10
    p: u32 = a * b;          // 120
    return p;
}
