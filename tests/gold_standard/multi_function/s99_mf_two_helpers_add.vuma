// s99_mf_two_helpers_add.vuma — f1(30) + f2(40) = 34 + 45 = 79
// Expected exit code: 79
//
// Two single-arg helpers. f1(x) = x + 4; f2(y) = y + 5. main calls
// both and adds: f1(30) + f2(40) = 34 + 45 = 79. Distinct from
// s95_mf_two_helpers_mul (16), s91_mf_two_helpers_sub (5) and
// s87_mf_two_helpers_add (140).
fn f1(x: u32) -> u32 {
    k: u32 = 4;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 5;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(30);         // 34
    b: u32 = f2(40);         // 45
    s: u32 = a + b;          // 79
    return s;
}
