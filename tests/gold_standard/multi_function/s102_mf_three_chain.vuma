// s102_mf_three_chain.vuma — f3(f2(f1(10))) = 10 + 1 + 1 + 1 = 13
// Expected exit code: 13
//
// Three single-arg helpers f1(x)=x+1, f2(x)=x+1, f3(x)=x+1. main calls them in sequence, threading the result: a = f1(10) = 11; b = f2(a) = 12; c = f3(b) = 13.
// Distinct from s101_mf_double_then_sub (39), s101_mf_three_chain (20), s101_mf_two_helpers_sum (80).
fn f1(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(10);         // 11
    b: u32 = f2(a);          // 12
    c: u32 = f3(b);          // 13
    return c;
}
