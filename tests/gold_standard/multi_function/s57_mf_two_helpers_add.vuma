// s57_mf_two_helpers_add.vuma — add25(40) = 65; add35(65) = 100
// Expected exit code: 100
//
// Two single-arg helpers called sequentially with intermediate
// variable. add25(x) = x + 25; add35(x) = x + 35. main calls
// add25(40) -> 65, then add35(65) -> 100. Distinct from s54_mf_two_
// helpers_add (125) and s50_mf_two_helpers_mul (110).

fn add25(x: u32) -> u32 {
    n: u32 = 25;
    r: u32 = x + n;
    return r;
}
fn add35(x: u32) -> u32 {
    n: u32 = 35;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add25(40);         // 65
    r: u32 = add35(a);          // 100
    return r;
}
