// s51_mf_double_then_add.vuma — dbl(35)=70, add_fifteen(35)=50; 70+50=120
// Expected exit code: 120
//
// Two single-arg helpers called on the same literal then summed:
// dbl(x) = x * 2; add_fifteen(x) = x + 15. main calls dbl(35) -> 70
// and add_fifteen(35) -> 50; sum = 120. Distinct from s50_mf_double_
// then_sub (100) and s47_mf_double_then_sub (55).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_fifteen(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(35);          // 70
    b: u32 = add_fifteen(35);  // 50
    r: u32 = a + b;            // 120
    return r;
}
