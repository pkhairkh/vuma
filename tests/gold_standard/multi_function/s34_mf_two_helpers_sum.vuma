// s34_mf_two_helpers_sum.vuma — add_five(40) + mul_three(20) = 45 + 60 = 105
// Expected exit code: 105
//
// Two single-arg helpers, each called once from main, results
// added. add_five(x) = x + 5; mul_three(x) = x * 3. main calls
// add_five(40) -> 45 and mul_three(20) -> 60; sum = 105. Distinct
// from s30_mf_two_helpers_sum (add4+mul3 = 79) and s27_mf_two_
// helpers_sum (different values).

fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn mul_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_five(40);   // 45
    b: u32 = mul_three(20);  // 60
    r: u32 = a + b;          // 105
    return r;
}
