// s46_mf_three_chain.vuma — f1(12)=19, f2(19)=57, f3(57)=51
// Expected exit code: 51
//
// Three single-arg helpers chained: f1(x)=x+7, f2(x)=x*3,
// f3(x)=x-6. main calls f3(f2(f1(12))) -> f1(12)=19, f2(19)=57,
// f3(57)=51. Distinct from s42_mf_three_chain (55) and s38_mf_
// three_chain (65).

fn f1(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(12);    // 19
    b: u32 = f2(a);     // 57
    c: u32 = f3(b);     // 51
    return c;
}
