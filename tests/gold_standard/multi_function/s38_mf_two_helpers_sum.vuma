// s38_mf_two_helpers_sum.vuma — add_six(40) + mul_two(35) = 46 + 70 = 116
// Expected exit code: 116
//
// Two single-arg helpers, each called once from main, results
// added. add_six(x) = x + 6; mul_two(x) = x * 2. main calls
// add_six(40) -> 46 and mul_two(35) -> 70; sum = 116. Distinct
// from s34_mf_two_helpers_sum (105) and s30_mf_two_helpers_sum.

fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}
fn mul_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_six(40);   // 46
    b: u32 = mul_two(35);   // 70
    r: u32 = a + b;         // 116
    return r;
}
