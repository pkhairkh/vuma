// s11_mf_pass_arg_through.vuma — id(10) + add3(20) = 10 + 23 = 33
// Expected exit code: 33
//
// Two helpers: id(x) = x (pass-through); add3(x) = x + 3. main calls
// id(10) -> 10 and add3(20) -> 23, sums -> 33. Distinct from
// s10_mf_helper_returns_arg (single helper) and s8_mf_pass_through
// (single pass-through helper).

fn id(x: u32) -> u32 {
    r: u32 = x;
    return r;
}

fn add3(x: u32) -> u32 {
    c: u32 = 3;
    r: u32 = x + c;
    return r;
}

fn main() -> i32 {
    a: u32 = id(10);     // 10
    b: u32 = add3(20);   // 23
    s: u32 = a + b;      // 33
    return s;
}
