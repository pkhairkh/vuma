// s20_mf_two_helpers_chain.vuma — outer(inner(5)) = (5+9)*2 = 14*2 = 28
// Expected exit code: 28
//
// Two single-arg helpers chained: inner(x) = x + 9, outer(x) = x * 2.
// main calls inner(5) -> 14, then outer(14) -> 28. Each call uses an
// intermediate local. Distinct from s18_mf_two_helpers_chain
// (inner+12, outer*3 -> 51) and s14_mf_two_helpers_chain (inner+10,
// outer*2 -> 30).

fn inner(x: u32) -> u32 {
    n: u32 = 9;
    r: u32 = x + n;
    return r;
}
fn outer(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inner(5);    // 14
    b: u32 = outer(a);    // 28
    return b;
}
