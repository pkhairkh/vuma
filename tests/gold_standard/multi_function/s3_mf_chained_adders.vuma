// s3_mf_chained_adders.vuma — 4 adders in a chain, each adds 1
// Expected exit code: 14  (10 + 1 + 1 + 1 + 1)
//
// f4(x) = x + 1; f3(x) = f4(x+1); f2(x) = f3(x+1); f1(x) = f2(x+1).
// main calls f1(10), walks the chain, result is 10 + 4 = 14.

fn f4(x: u32) -> u32 {
    one: u32 = 1;
    r: u32 = x + one;
    return r;
}
fn f3(x: u32) -> u32 {
    one: u32 = 1;
    s: u32 = x + one;
    r: u32 = f4(s);
    return r;
}
fn f2(x: u32) -> u32 {
    one: u32 = 1;
    s: u32 = x + one;
    r: u32 = f3(s);
    return r;
}
fn f1(x: u32) -> u32 {
    one: u32 = 1;
    s: u32 = x + one;
    r: u32 = f2(s);
    return r;
}

fn main() -> i32 {
    v: u32 = f1(10);
    return v;
}
