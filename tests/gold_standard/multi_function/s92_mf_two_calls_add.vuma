// s92_mf_two_calls_add.vuma — f(30) + f(35) = 40 + 45 = 85
// Expected exit code: 85
//
// Single helper f(x) = x + 10. main calls it twice and adds:
// f(30) + f(35) = 40 + 45 = 85. Distinct from s90_mf_two_calls_add
// (59), s86_mf_double_then_add (60) and s82_mf_two_helpers_add (105).
fn f(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(30);          // 40
    b: u32 = f(35);          // 45
    s: u32 = a + b;          // 85
    return s;
}
