// s69_mf_three_chain.vuma -- add_five(40)=45 -> mul_two(45)=90 -> sub_seven(90)=83
// Expected exit code: 83
//
// Three-function call chain. add_five(40) = 45; mul_two(45) = 90;
// sub_seven(90) = 83. main threads the result through three
// single-arg helpers. Distinct from s66_mf_three_chain (85), s65_mf_
// three_chain (127) and s64_mf_three_chain (121).
fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn mul_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_seven(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_five(40);      // 45
    b: u32 = mul_two(a);        // 90
    r: u32 = sub_seven(b);      // 83
    return r;
}
