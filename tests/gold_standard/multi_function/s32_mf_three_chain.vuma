// s32_mf_three_chain.vuma - inc(halve(double(100))) = inc(100) = 101
// Expected exit code: 101
//
// inc(halve(double(100))) = inc(100) = 101. All operands loaded into typed
// variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from s30_mf_three_chain
// (inc(double(5)) = 11) and s26_mf_three_chain (different chain).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn halve(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x / n;
    return r;
}
fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(100);  // 200
    b: u32 = halve(a);     // 100
    r: u32 = inc(b);       // 101
    return r;
}
