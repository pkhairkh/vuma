// s106_mf_two_calls_add.vuma — f(7) + f(9) = 8 + 10 = 18
// Expected exit code: 18
//
// Single helper f(x) = x + 1. main calls it twice and adds: f(7) + f(9) = 8 + 10 = 18.
// Distinct from s102_mf_two_calls_add (6), s101_mf_double_then_sub (39), s100_mf_two_calls_add (118).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f(7);          // 8
    b: u32 = f(9);          // 10
    s: u32 = a + b;          // 18
    return s;
}
