// s83_cs_two_cell_sum.vuma — two cells, sum = 169 (94 + 75)
// Expected exit code: 169
//
// Two 8-byte cells. Store 94/75 via `*ptr = literal`, load
// both, sum -> 169. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_cs_two_cell_sum (2), s74_cs_two_cell_sum
// (110) and s72_cs_two_cell_sum (240).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 94;
    *c2 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 169
    free(c1);
    free(c2);
    return s;
}
