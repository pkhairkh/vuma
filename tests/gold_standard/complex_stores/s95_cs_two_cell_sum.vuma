// s95_cs_two_cell_sum.vuma — two cells, sum = 59 (24 + 35)
// Expected exit code: 59
//
// Two 8-byte cells. Store 24/35 via `*ptr = literal`, load both,
// a + b -> 59. Uses `*ptr = literal` form (no offsets). Distinct
// from s94_cs_two_cell_sum (110), s90_cs_two_cell_diff (4) and
// s82_cs_two_cell_sum (160).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 24;
    *c2 = 35;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 59
    free(c1);
    free(c2);
    return s;
}
