// s103_cs_two_cell_diff.vuma — store 200, 1 in 2 cells, load and diff = 200-1 = 199
// Expected exit code: 199
//
// Two 8-byte cells. Store 200 at c1, store 1 at c2, load each and return the difference (199). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s100_cs_two_cell_diff (19).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 1;
    a: u64 = *c1;          // 200
    b: u64 = *c2;          // 1
    d: u64 = a - b;        // 199
    free(c1);
    free(c2);
    return d;
}
