// s4_cs_three_offsets.vuma — store at offsets 0/8/16, sum loads = 90
// Expected exit code: 90  (15 + 25 + 50)
//
// 24-byte buffer, three stores at offsets 0, 8, 16. Loads them back
// in the same order, sums, returns 90.

fn main() -> i32 {
    buf = allocate(24);
    *(buf + 0) = 15;
    *(buf + 8) = 25;
    *(buf + 16) = 50;
    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    s: u64 = a + b + c;
    free(buf);
    return s;
}
