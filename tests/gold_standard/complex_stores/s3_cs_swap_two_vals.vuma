// s3_cs_swap_two_vals.vuma — store A,B, load swapped, return sum
// Expected exit code: 100  (40 + 60)
//
// Stores 40 at offset 0 and 60 at offset 8 in a 16-byte buffer. Loads
// them in swapped order into local variables (a gets 60, b gets 40),
// sums them, returns 100. Tests offset-to-variable mapping.

fn main() -> i32 {
    buf = allocate(16);
    *(buf + 0) = 40;
    *(buf + 8) = 60;

    // Read in swapped order to local variables
    a: u64 = *(buf + 8);
    b: u64 = *(buf + 0);
    s: u64 = a + b;

    free(buf);
    return s;
}
