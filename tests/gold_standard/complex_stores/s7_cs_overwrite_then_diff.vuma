// s7_cs_overwrite_then_diff.vuma — overwrite cell 2 then sum = 100 + 20 = 120
// Expected exit code: 120
//
// 16-byte buffer treated as two 8-byte slots. Store 100/50 in slots
// 0/8, then overwrite slot 8 with 20. Load both, sum -> 100 + 20 = 120.
// Uses pointer-arithmetic aliases for each slot so stores/loads go
// through `*pN`. Distinct from s5_cs_overwrite_then_sum (overwrites
// and sums across offsets) and s6_cs_overwrite_then_load (single
// offset overwrite + load).

fn main() -> i32 {
    buf = allocate(16);
    p0 = buf;
    p8 = buf + 8;
    *p0 = 100;
    *p8 = 50;
    *p8 = 20;
    a: u64 = *p0;
    b: u64 = *p8;
    s: u64 = a + b;
    free(buf);
    return s;
}
