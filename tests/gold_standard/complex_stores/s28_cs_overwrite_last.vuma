// s28_cs_overwrite_last.vuma — overwrite last cell, load = 115
// Expected exit code: 115
//
// Single 8-byte cell. Store 15 via `*ptr = literal`, then overwrite
// with 115 via `*ptr = literal`. Load and return 115. Uses `*ptr =
// literal` form (no offsets). Distinct from s26_cs_overwrite_middle
// (overwrite middle of three, 160) and s22_cs_overwrite_first
// (overwrite first).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 15;
    *c1 = 115;
    a: u64 = *c1;
    free(c1);
    return a;
}
