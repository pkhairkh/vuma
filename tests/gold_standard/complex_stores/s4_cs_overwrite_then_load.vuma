// s4_cs_overwrite_then_load.vuma — store 50 then 99 at same offset, load
// Expected exit code: 99
//
// 8-byte buffer. Store the literal 50 at offset 0, then overwrite
// the same cell with 99, load it back. Verifies that the second
// store wins.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 50;
    *(buf + 0) = 99;
    v: u64 = *(buf + 0);
    free(buf);
    return v;
}
