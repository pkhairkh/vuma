// s32_cs_two_cell_diff.vuma - two cells, diff = 120 (200 - 80)
// Expected exit code: 120
//
// two cells, diff = 120 (200 - 80). All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_cs_two_cell_sum (sum, 130)
// and s26_cs_three_cells_dec (three-cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    r: u64 = a - b;        // 120
    free(c1);
    free(c2);
    return r;
}
