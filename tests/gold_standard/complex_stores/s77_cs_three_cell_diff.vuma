// s77_cs_three_cell_diff.vuma — three cells, diff = 127 (235 - 75 - 33)
// Expected exit code: 127
//
// Three 8-byte cells. Store 235/75/33 via `*ptr = literal`,
// load all three, diff -> 127. Uses `*ptr = literal` form (no
// offsets). Distinct from s70_cs_three_cell_sum (150), s66_cs_
// three_cell_diff (90) and s74_cs_three_cell_diff (67).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 235;
    *c2 = 75;
    *c3 = 33;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 160
    r: u64 = t - c;        // 127
    free(c1);
    free(c2);
    free(c3);
    return r;
}
