// s45_cs_overwrite_middle.vuma — overwrite middle to 120, sum = 240 (40 + 120 + 80)
// Expected exit code: 240
//
// Three 8-byte cells. Store 40/60/80 via `*ptr = literal`, then
// overwrite the middle cell with 120. Load all three, sum -> 240.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s42_cs_overwrite_last (210) and s38_cs_overwrite_middle (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 60;
    *c3 = 80;
    *c2 = 120;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
