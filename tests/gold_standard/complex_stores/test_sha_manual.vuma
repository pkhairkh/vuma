// Test: SHA-256 compression with loops and memory
// Expected: exit 79
// Expected exit code: 24

fn rotr32(x: u32, n: u32) -> u32 {
    return ((x >> n) | (x << (32 - n))) & 4294967295;
}

fn ch(x: u32, y: u32, z: u32) -> u32 {
    return (x & y) ^ ((x ^ 4294967295) & z);
}

fn maj(a: u32, b: u32, c: u32) -> u32 {
    return (a & b) ^ (a & c) ^ (b & c);
}

fn big_sigma0(x: u32) -> u32 {
    return rotr32(x, 2) ^ rotr32(x, 13) ^ rotr32(x, 22);
}

fn big_sigma1(x: u32) -> u32 {
    return rotr32(x, 6) ^ rotr32(x, 11) ^ rotr32(x, 25);
}

fn small_sigma0(x: u32) -> u32 {
    return (rotr32(x, 7) ^ rotr32(x, 18) ^ (x >> 3)) & 4294967295;
}

fn small_sigma1(x: u32) -> u32 {
    return (rotr32(x, 17) ^ rotr32(x, 19) ^ (x >> 10)) & 4294967295;
}

fn write_u32(buf: Address, offset: u64, val: u32) {
    *(buf + offset) = (val >> 24) & 255;
    *(buf + offset + 1) = (val >> 16) & 255;
    *(buf + offset + 2) = (val >> 8) & 255;
    *(buf + offset + 3) = val & 255;
}

fn read_u32(buf: Address, offset: u64) -> u32 {
    b0: u32 = *(buf + offset);
    b1: u32 = *(buf + offset + 1);
    b2: u32 = *(buf + offset + 2);
    b3: u32 = *(buf + offset + 3);
    return ((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) & 4294967295;
}

fn main() -> u64 {
    // Allocate state and a single block for "abc"
    state = allocate(32);
    w = allocate(256);
    block = allocate(64);

    // Initialize state (SHA-256 initial hash values)
    write_u32(state, 0,  1779033703);
    write_u32(state, 4,  3144134277);
    write_u32(state, 8,  1013904242);
    write_u32(state, 12, 2773480762);
    write_u32(state, 16, 1359893119);
    write_u32(state, 20, 2600822924);
    write_u32(state, 24, 528734635);
    write_u32(state, 28, 1541459225);

    // Pad "abc" into block (simplified: just store first 4 bytes = 0x61626380)
    write_u32(block, 0,  1668247168);  // 0x61626380
    write_u32(block, 4,  0);           // padding zeros
    write_u32(block, 8,  0);
    write_u32(block, 12, 0);
    write_u32(block, 16, 0);
    write_u32(block, 20, 0);
    write_u32(block, 24, 0);
    write_u32(block, 28, 0);
    write_u32(block, 32, 0);
    write_u32(block, 36, 0);
    write_u32(block, 40, 0);
    write_u32(block, 44, 0);
    write_u32(block, 48, 0);
    write_u32(block, 52, 0);
    write_u32(block, 56, 0);        // length high bits
    write_u32(block, 60, 24);       // length = 24 bits

    // Just do first round manually
    // K[0] = 0x428a2f98 = 1116352408
    // W[0] = 0x61626380 = 1668247168
    
    a: u32 = read_u32(state, 0);
    b: u32 = read_u32(state, 4);
    c: u32 = read_u32(state, 8);
    d: u32 = read_u32(state, 12);
    e: u32 = read_u32(state, 16);
    f: u32 = read_u32(state, 20);
    g: u32 = read_u32(state, 24);
    h: u32 = read_u32(state, 28);

    // Round 0
    ki: u32 = 1116352408;
    wi: u32 = 1668247168;
    t1: u32 = (h + big_sigma1(e) + ch(e, f, g) + ki + wi) & 4294967295;
    t2: u32 = (big_sigma0(a) + maj(a, b, c)) & 4294967295;
    new_h: u32 = g;
    new_g: u32 = f;
    new_f: u32 = e;
    new_e: u32 = (d + t1) & 4294967295;
    new_d: u32 = c;
    new_c: u32 = b;
    new_b: u32 = a;
    new_a: u32 = (t1 + t2) & 4294967295;

    // Return low byte of new_a
    result: u32 = new_a & 0xFF;
    return result;
}
