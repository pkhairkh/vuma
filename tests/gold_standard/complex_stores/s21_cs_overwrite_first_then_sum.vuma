// s21_cs_overwrite_first_then_sum.vuma — overwrite first of three, sum = 210
// Expected exit code: 210  (90 + 45 + 75)
//
// Three 8-byte cells. Store 15/45/75 in c1/c2/c3, then overwrite c1 with
// 90. Load all three, sum -> 210. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_cs_overwrite_last (overwrites LAST cell) and
// s14_cs_overwrite_first (15/25 -> 100/25 = 125, two cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 15;
    *c2 = 45;
    *c3 = 75;
    *c1 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
