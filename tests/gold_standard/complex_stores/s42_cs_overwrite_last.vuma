// s42_cs_overwrite_last.vuma — overwrite last to 120, sum = 210 (30 + 60 + 120)
// Expected exit code: 210
//
// Three 8-byte cells. Store 30/60/90 via `*ptr = literal`, then
// overwrite the last cell with 120. Load all three, sum -> 210.
// Uses `*ptr = literal` form (no offsets). Distinct from s38_cs_
// overwrite_middle (210) and s34_cs_overwrite_first (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c3 = 90;
    *c3 = 120;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 210
    free(c1);
    free(c2);
    free(c3);
    return s;
}
