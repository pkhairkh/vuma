// s73_cs_three_cell_diff.vuma — three cells, diff = 134 (200 - 47 - 19)
// Expected exit code: 134
//
// Three 8-byte cells. Store 200/47/19 via `*ptr = literal`, load
// all three, diff -> 200 - 47 - 19 = 134. Uses `*ptr = literal`
// form. Distinct from s70_cs_three_cell_sum (150), s69_cs_three_
// cell_diff (225) and s66_cs_three_cell_diff (115).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 47;
    *c3 = 19;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 153
    d: u64 = t - c;        // 134
    free(c1);
    free(c2);
    free(c3);
    return d;
}
