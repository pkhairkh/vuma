// s50_cs_three_cell_diff.vuma — three cells, diff = 130 (200 - 40 - 30)
// Expected exit code: 130
//
// Three 8-byte cells. Store 200/40/30 via `*ptr = literal`, load all
// three, subtract the second and third from the first -> 130. Uses
// `*ptr = literal` form (no offsets). Distinct from s46_cs_three_
// cell_sum (195) and s43_cs_three_cell_sum (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 40;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    d: u64 = t - c;        // 130
    free(c1);
    free(c2);
    free(c3);
    return d;
}
