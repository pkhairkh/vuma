// s3_cs_struct_like.vuma — 3-field struct in one allocation, sum
// Expected exit code: 100  (10 + 30 + 60)
//
// 24-byte allocation treated as a struct with three 8-byte fields:
// field_a = 10, field_b = 30, field_c = 60. main loads all three and
// sums them.

fn main() -> i32 {
    s = allocate(24);
    *(s + 0) = 10;
    *(s + 8) = 30;
    *(s + 16) = 60;

    a: u64 = *(s + 0);
    b: u64 = *(s + 8);
    c: u64 = *(s + 16);
    s1: u64 = a + b;
    s2: u64 = s1 + c;

    free(s);
    return s2;
}
