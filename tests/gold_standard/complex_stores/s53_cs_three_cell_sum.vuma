// s53_cs_three_cell_sum.vuma — three cells, sum = 220 (60 + 90 + 70)
// Expected exit code: 220
//
// Three 8-byte cells. Store 60/90/70 via `*ptr = literal`, load all
// three, sum -> 220. Uses `*ptr = literal` form (no offsets).
// Distinct from s49_cs_three_cell_xor (31) and s50_cs_three_cell_
// diff (130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 90;
    *c3 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 220
    free(c1);
    free(c2);
    free(c3);
    return s;
}
