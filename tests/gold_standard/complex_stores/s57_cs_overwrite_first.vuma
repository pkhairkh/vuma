// s57_cs_overwrite_first.vuma — overwrite first cell, load = 60
// Expected exit code: 60
//
// Single 8-byte cell. Store 180 via `*ptr = literal`, overwrite
// with 60 via `*ptr = literal`, load -> 60. Uses `*ptr = literal`
// form (no offsets). Distinct from s54_cs_overwrite_last (250) and
// s50_cs_overwrite_last (210).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 180;
    *c1 = 60;
    a: u64 = *c1;          // 60
    free(c1);
    return a;
}
