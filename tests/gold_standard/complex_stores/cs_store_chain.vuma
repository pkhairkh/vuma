// cs_store_chain.vuma — store in buf1, copy to buf2, copy to buf3, load buf3
// Expected exit code: 55
//
// Three-buffer copy chain: 55 stored in buf1, copied to buf2, copied to
// buf3, then loaded from buf3. Verifies transitive copy correctness.
//
// Implementation note: storing a bare scalar variable through a pointer
// (`*(p) = v;`) is miscompiled on the current x86_64 backend (the store
// is silently dropped). The `| 0` is an identity-expression workaround
// that forces the codegen down the "store expression" path, which works.

fn main() -> i32 {
    b1 = allocate(8);
    b2 = allocate(8);
    b3 = allocate(8);
    *(b1 + 0) = 55;
    t1: u32 = *(b1 + 0);
    *(b2 + 0) = t1 | 0;
    t2: u32 = *(b2 + 0);
    *(b3 + 0) = t2 | 0;
    out: u32 = *(b3 + 0);
    free(b1);
    free(b2);
    free(b3);
    return out;
}
