// s69_cs_overwrite_first.vuma -- overwrite c1 to 25, sum = 105 (25 + 80)
// Expected exit code: 105
//
// Two 8-byte cells. Store 50/80 via `*ptr = literal`, overwrite c1
// to 25 via `*ptr = literal`, load both, sum -> 25 + 80 = 105. Uses
// `*ptr = literal` form. Distinct from s66_cs_overwrite_first (175),
// s65_cs_overwrite_first (115) and s64_cs_overwrite_first (160).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 50;
    *c2 = 80;
    *c1 = 25;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 105
    free(c1);
    free(c2);
    return s;
}
