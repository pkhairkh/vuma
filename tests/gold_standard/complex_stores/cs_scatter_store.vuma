// cs_scatter_store.vuma — store at offsets 0, 4, 8, load all, return sum
// Expected exit code: 6  (1 + 2 + 3)
//
// Scatters three values across a larger buffer at strided offsets, then
// loads each back and sums them.

fn main() -> i32 {
    buf = allocate(16);
    *(buf + 0) = 1;
    *(buf + 4) = 2;
    *(buf + 8) = 3;
    a: u32 = *(buf + 0);
    b: u32 = *(buf + 4);
    c: u32 = *(buf + 8);
    free(buf);
    return a + b + c;
}
