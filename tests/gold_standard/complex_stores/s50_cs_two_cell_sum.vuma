// s50_cs_two_cell_sum.vuma — two cells, sum = 235 (105 + 130)
// Expected exit code: 235
//
// Two 8-byte cells. Store 105/130 via `*ptr = literal`, load both,
// sum -> 235. Uses `*ptr = literal` form (no offsets). Distinct from
// s46_cs_two_cell_diff (150) and s43_cs_two_cell_diff (120).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 105;
    *c2 = 130;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 235
    free(c1);
    free(c2);
    return s;
}
