// cs2_chain.vuma — store 55 in buf1, copy to buf2, copy to buf3, load buf3
// Expected exit code: 55
//
// Three-buffer transitive copy chain: 55 -> buf1 -> buf2 -> buf3 -> load.
// Each copy step uses the `| 0` identity-expression workaround so the
// store of a loaded variable is not silently dropped by the backend.

fn main() -> i32 {
    b1 = allocate(8);
    b2 = allocate(8);
    b3 = allocate(8);
    *(b1 + 0) = 55;
    t1: u32 = *(b1 + 0);
    *(b2 + 0) = t1 | 0;       // copy b1 -> b2 (workaround for *ptr = variable)
    t2: u32 = *(b2 + 0);
    *(b3 + 0) = t2 | 0;       // copy b2 -> b3 (workaround for *ptr = variable)
    out: u32 = *(b3 + 0);
    free(b1);
    free(b2);
    free(b3);
    return out;
}
