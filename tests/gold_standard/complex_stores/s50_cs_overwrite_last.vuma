// s50_cs_overwrite_last.vuma — overwrite last to 110, sum = 240 (60 + 70 + 110)
// Expected exit code: 240
//
// Three 8-byte cells. Store 60/70/80 via `*ptr = literal`, then
// overwrite the last cell with 110. Load all three, sum -> 240.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_cs_
// overwrite_first (250) and s43_cs_overwrite_first (180).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 70;
    *c3 = 80;
    *c3 = 110;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
