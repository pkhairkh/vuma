// s38_cs_three_cell_sum.vuma — three cells, sum = 220 (55 + 75 + 90)
// Expected exit code: 220
//
// Three 8-byte cells. Store 55/75/90 via `*ptr = literal`, load all,
// sum -> 220. Uses `*ptr = literal` form (no offsets). Distinct from
// s34_cs_three_cell_sum (180) and s30_cs_two_cell_diff.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 55;
    *c2 = 75;
    *c3 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 220
    free(c1);
    free(c2);
    free(c3);
    return s;
}
