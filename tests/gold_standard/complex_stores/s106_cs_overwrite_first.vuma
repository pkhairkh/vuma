// s106_cs_overwrite_first.vuma — overwrite c1 to 69, load = 69
// Expected exit code: 69
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c1 to 69. Load c1 -> 69 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_overwrite_last (1), s101_cs_overwrite_first (28), s100_cs_overwrite_middle (47).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 69;
    v: u64 = *c1;          // 69
    free(c1);
    free(c2);
    free(c3);
    return v;
}
