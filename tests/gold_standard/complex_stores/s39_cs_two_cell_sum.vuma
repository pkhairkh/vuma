// s39_cs_two_cell_sum.vuma — two cells, sum = 230 (140 + 90)
// Expected exit code: 230
//
// Two 8-byte cells. Store 140/90 via `*ptr = literal`, load both,
// sum -> 230. Uses `*ptr = literal` form (no offsets). Distinct from
// s38_cs_two_cell_diff (140) and s34_cs_two_cell_sum (195).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 140;
    *c2 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 230
    free(c1);
    free(c2);
    return s;
}
