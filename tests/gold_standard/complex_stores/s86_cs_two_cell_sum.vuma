// s86_cs_two_cell_sum.vuma — two cells, sum = 170 (110 + 60)
// Expected exit code: 170
//
// Two 8-byte cells. Store 110/60 via `*ptr = literal`, load
// both, sum -> 170. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_cs_two_cell_sum (160), s78_cs_two_cell_sum
// (2) and s74_cs_two_cell_sum (110).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 110;
    *c2 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 170
    free(c1);
    free(c2);
    return s;
}
