// s30_cs_overwrite_middle.vuma — overwrite middle cell, sum = 120 (10+80+30)
// Expected exit code: 120
//
// Three 8-byte cells. Store 10/20/30 in c1/c2/c3, then overwrite c2 (the
// middle cell) with 80. Load all three, sum -> 120. Uses `*ptr = literal`
// form (no offsets). Distinct from s26_cs_three_cells_dec (different
// values) and s22_cs_overwrite_first (overwrites the first cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
