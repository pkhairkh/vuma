// s81_cs_two_cell_sum.vuma — two cells, sum = 165 (95 + 70)
// Expected exit code: 165
//
// Two 8-byte cells. Store 95/70 via `*ptr = literal`, load both,
// sum -> 165. Uses `*ptr = literal` form (no offsets). Distinct
// from s78_cs_two_cell_sum (2), s77_cs_two_cell_sum (122) and
// s76_cs_two_cell_sum (128).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 165
    free(c1);
    free(c2);
    return s;
}
