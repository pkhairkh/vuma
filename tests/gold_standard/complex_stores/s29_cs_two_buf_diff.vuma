// s29_cs_two_buf_diff.vuma — two cells, diff = 70 (100 - 30)
// Expected exit code: 70
//
// Two 8-byte cells. Store 100/30 via `*ptr = literal`, load both, subtract -> 70. Uses `*ptr = literal` form (no offsets). All operands loaded into typed locals before the SUB. Distinct from s26_cs_two_buf_xor (xor, 102) and s22_cs_two_buf_sum (two-cell add).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a - b;       // 70
    free(c1);
    free(c2);
    return s;
}
