// s8_cs_overwrite_first_last.vuma — overwrite offsets 0 and 24, sum = 160
// Expected exit code: 160  (50 + 20 + 30 + 60)
//
// 32-byte buffer. Store 10/20/30/40 at offsets 0/8/16/24, then overwrite
// offset 0 with 50 and offset 24 with 60. Load all four, sum, return 160.
// Distinct from s6_cs_overwrite_then_load (single-cell overwrite).

fn main() -> i32 {
    buf = allocate(32);
    *(buf + 0) = 10;
    *(buf + 8) = 20;
    *(buf + 16) = 30;
    *(buf + 24) = 40;
    *(buf + 0) = 50;
    *(buf + 24) = 60;
    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    d: u64 = *(buf + 24);
    t1: u64 = a + b;
    t2: u64 = c + d;
    s: u64 = t1 + t2;
    free(buf);
    return s;
}
