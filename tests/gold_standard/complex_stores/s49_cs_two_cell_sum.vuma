// s49_cs_two_cell_sum.vuma — two cells, sum = 235 (120 + 115)
// Expected exit code: 235
//
// Two 8-byte cells. Store 120/115 via `*ptr = literal`, load both,
// sum -> 235. Uses `*ptr = literal` form (no offsets). Distinct from
// s48_cs_two_cell_sum (240, 115+125) and s46_cs_two_cell_diff (150,
// diff).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 120;
    *c2 = 115;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 235
    free(c1);
    free(c2);
    return s;
}
