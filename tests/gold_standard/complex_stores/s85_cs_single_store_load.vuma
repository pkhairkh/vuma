// s85_cs_single_store_load.vuma — store 73, load, return 73
// Expected exit code: 73
//
// Single 8-byte cell. Store 73 via `*ptr = literal`, load it
// back, return 73. Uses `*ptr = literal` form (no offsets) to
// avoid the *(ptr+N) store-drop bug. Distinct from
// s82_cs_single_store_load, s78_cs_single_store_load and
// s74_cs_single_store_load.
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 73;
    r: u64 = *c1;
    free(c1);
    return r;
}
