// s104_cs_overwrite_first.vuma — overwrite c1 to 94, load = 94
// Expected exit code: 94
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c1 to 94. Load c1 -> 94 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_overwrite_last (1), s102_cs_three_cell_sum (26), s102_cs_two_cell_sum (23).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 94;
    v: u64 = *c1;          // 94
    free(c1);
    free(c2);
    free(c3);
    return v;
}
