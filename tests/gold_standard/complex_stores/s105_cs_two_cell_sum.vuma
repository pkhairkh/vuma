// s105_cs_two_cell_sum.vuma — store 38 + 41 in 2 cells, load and sum = 79
// Expected exit code: 79
// 
// Two 8-byte cells. Store 38 at c1, store 41 at c2, load each and return the sum (79). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_two_cell_sum (23), s101_cs_two_cell_xor (192), s100_cs_two_cell_diff (19).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 38;
    *c2 = 41;
    a: u64 = *c1;          // 38
    b: u64 = *c2;          // 41
    s: u64 = a + b;        // 79
    free(c1);
    free(c2);
    return s;
}
