// s84_cs_three_cell_diff.vuma — three cells, diff = 11 (20 - 5 - 4)
// Expected exit code: 11
//
// Three 8-byte cells. Store 20/5/4 via `*ptr = literal`,
// load all three, a - b - c -> 11. Uses `*ptr = literal` form
// (no offsets). Distinct from s82_cs_three_cell_diff (125),
// s78_cs_three_cell_diff (148) and s74_cs_three_cell_diff (67).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 5;
    *c3 = 4;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 11
    free(c1);
    free(c2);
    free(c3);
    return r;
}
