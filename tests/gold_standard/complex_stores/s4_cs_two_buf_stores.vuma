// s4_cs_two_buf_stores.vuma — two buffers, cross-sum of loads = 130
// Expected exit code: 130  (40 + 50 + 10 + 30)
//
// Two 8-byte buffers. Store 40 in buf1[0], 10 in buf1[8], 50 in
// buf2[0], 30 in buf2[8]. Load all four, sum. Tests multi-buffer,
// multi-offset store/load correctness.

fn main() -> i32 {
    buf1 = allocate(16);
    buf2 = allocate(16);
    *(buf1 + 0) = 40;
    *(buf1 + 8) = 10;
    *(buf2 + 0) = 50;
    *(buf2 + 8) = 30;
    a: u64 = *(buf1 + 0);
    b: u64 = *(buf1 + 8);
    c: u64 = *(buf2 + 0);
    d: u64 = *(buf2 + 8);
    s: u64 = a + b + c + d;
    free(buf1);
    free(buf2);
    return s;
}
