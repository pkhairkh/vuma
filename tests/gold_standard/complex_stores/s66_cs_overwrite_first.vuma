// s66_cs_overwrite_first.vuma — overwrite c1 to 175, load = 175
// Expected exit code: 175
//
// Two 8-byte cells. Store 80 then 175 at c1 (overwrite), store 40
// at c2. Load c1 -> 175 (the overwritten value). Uses `*ptr =
// literal` form (no offsets). Distinct from s62_cs_overwrite_
// last (130), s58_cs_overwrite_first (200) and s55_cs_overwrite_
// first (180).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c1 = 175;
    *c2 = 40;
    a: u64 = *c1;          // 175
    free(c1);
    free(c2);
    return a;
}
