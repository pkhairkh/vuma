// s57_cs_three_cell_diff.vuma — three cells, diff = 120 (220 - 70 - 30)
// Expected exit code: 120
//
// Three 8-byte cells. Store 220/70/30 via `*ptr = literal`, load
// each, subtract sequentially -> 120. Uses `*ptr = literal` form
// (no offsets). Distinct from s54_cs_three_cell_diff (80) and s50_cs_
// three_cell_diff (60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 70;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a - b;        // 150
    r: u64 = s - c;        // 120
    free(c1);
    free(c2);
    free(c3);
    return r;
}
