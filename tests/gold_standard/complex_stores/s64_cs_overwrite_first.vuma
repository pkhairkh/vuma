// s64_cs_overwrite_first.vuma — overwrite first to 108, sum = 168 (108 + 24 + 36)
// Expected exit code: 168
//
// Three 8-byte cells. Store 12/24/36 via `*ptr = literal`, then
// overwrite the first cell with 108. Load all three, sum -> 168.
// Uses `*ptr = literal` form (no offsets). Distinct from s62_cs_
// overwrite_last (130), s62_cs_three_cell_sum (195) and s62_cs_two_
// cell_diff (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 12;
    *c2 = 24;
    *c3 = 36;
    *c1 = 108;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 168
    free(c1);
    free(c2);
    free(c3);
    return s;
}
