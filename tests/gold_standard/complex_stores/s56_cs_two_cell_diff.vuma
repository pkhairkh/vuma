// s56_cs_two_cell_diff.vuma — two cells, diff = 120 (200 - 80)
// Expected exit code: 120
//
// Two 8-byte cells. Store 200/80 via `*ptr = literal`, load both,
// diff -> 120. Uses `*ptr = literal` form (no offsets). Distinct from
// s54_cs_two_cell_sum (245) and s50_cs_two_cell_sum (235).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 120
    free(c1);
    free(c2);
    return d;
}
