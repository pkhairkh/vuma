// s84_cs_two_cell_sum.vuma — two cells, sum = 5 (2 + 3)
// Expected exit code: 5
//
// Two 8-byte cells. Store 2/3 via `*ptr = literal`, load
// both, sum -> 5. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_cs_two_cell_sum (160), s78_cs_two_cell_sum
// (2) and s74_cs_two_cell_sum (187).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 2;
    *c2 = 3;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 5
    free(c1);
    free(c2);
    return s;
}
