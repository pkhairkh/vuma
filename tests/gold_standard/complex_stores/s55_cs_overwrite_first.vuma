// s55_cs_overwrite_first.vuma — overwrite first to 25, sum = 180 (25+65+90)
// Expected exit code: 180
//
// Three 8-byte cells. Store 40/65/90 via `*ptr = literal`, then
// overwrite the first cell with 25. Load all three, sum -> 180.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s54_cs_overwrite_last (250) and s53_cs_overwrite_middle (215).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 65;
    *c3 = 90;
    *c1 = 25;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 180
    free(c1);
    free(c2);
    free(c3);
    return s;
}
