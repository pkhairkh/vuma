// s76_cs_overwrite_last.vuma — overwrite c3 to 138, load = 138
// Expected exit code: 138
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c3 to 138. Load c3 -> 138 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s74_cs_overwrite_last (191),
// s73_cs_overwrite_middle (144) and s72_cs_overwrite_middle (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c3 = 138;
    v: i32 = *c3;          // 138
    free(c1);
    free(c2);
    free(c3);
    return v;
}
