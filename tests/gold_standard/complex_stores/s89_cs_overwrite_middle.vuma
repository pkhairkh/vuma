// s89_cs_overwrite_middle.vuma — overwrite c2 to 25, load = 25
// Expected exit code: 25
//
// Three 8-byte cells. Store 40 at c1, store 70 at c2, then
// overwrite c2 to 25, store 90 at c3. Load c2 -> 25 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s86_cs_overwrite_first (230), s82_cs_overwrite_middle
// (220) and s78_cs_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 70;
    *c2 = 25;
    *c3 = 90;
    v: u64 = *c2;          // 25
    free(c1);
    free(c2);
    free(c3);
    return v;
}
