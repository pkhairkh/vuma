// s44_cs_two_cell_diff.vuma — two cells, diff = 140 (180 - 40)
// Expected exit code: 140
//
// Two 8-byte cells. Store 180/40 via `*ptr = literal`, load both,
// subtract -> 140. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_cs_two_cell_sum (250) and s38_cs_two_cell_diff (140, same
// total but different operands 200/60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 180;
    *c2 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 140
    free(c1);
    free(c2);
    return d;
}
