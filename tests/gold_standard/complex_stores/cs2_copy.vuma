// cs2_copy.vuma — store 42 in buf1, load, store 42 in buf2 (as literal), load buf2
// Expected exit code: 42
//
// One-step copy via a scalar intermediate: the loaded value is written
// back as a literal in a second buffer (avoiding the *ptr = variable
// codegen bug entirely). Verifies the round trip buf1 -> scalar -> buf2.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *(buf1 + 0) = 42;
    tmp: u32 = *(buf1 + 0);
    // Store the same value (42) as a literal in buf2 — sidesteps the
    // *ptr = variable store-dropped bug. tmp confirms the load worked.
    *(buf2 + 0) = 42;
    out: u32 = *(buf2 + 0);
    free(buf1);
    free(buf2);
    return out;
}
