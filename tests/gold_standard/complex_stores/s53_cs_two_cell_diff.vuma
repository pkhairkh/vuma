// s53_cs_two_cell_diff.vuma — two cells, diff = 170 (220 - 50)
// Expected exit code: 170
//
// Two 8-byte cells. Store 220/50 via `*ptr = literal`, load both,
// diff -> 170. Uses `*ptr = literal` form (no offsets). Distinct
// from s49_cs_two_cell_sum (235) and s50_cs_two_cell_sum (235).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 170
    free(c1);
    free(c2);
    return d;
}
