// s23_cs_overwrite_last_then_sum.vuma — overwrite last cell, sum = 120 (25 + 35 + 60)
// Expected exit code: 120
//
// Three 8-byte cells. Store 25/35/45, then overwrite the last cell (c3)
// with 60. Load all three, sum -> 120. Uses `*ptr = literal` form (no
// offsets). Distinct from s22_cs_overwrite_first (overwrites first cell)
// and s20_cs_overwrite_middle (overwrites middle cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 25;
    *c2 = 35;
    *c3 = 45;
    *c3 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;   // 120
    free(c1);
    free(c2);
    free(c3);
    return s;
}

