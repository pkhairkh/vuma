// s20_cs_three_cells_xor.vuma — three cells, xor = 200 ^ 100 ^ 50 = 158
// Expected exit code: 158
//
// Three 8-byte cells. Store 200/100/50 via `*ptr = literal`, load all
// three, XOR -> 158. (200 ^ 100) = 172; 172 ^ 50 = 158. Uses `*ptr =
// literal` form (no offsets). Distinct from s18_cs_two_buf_overwrite_one
// (two cells, overwrite) and s14_cs_three_cells_asc (three cells, sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 100;
    *c3 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a ^ b ^ c;   // 158
    free(c1);
    free(c2);
    free(c3);
    return r;
}
