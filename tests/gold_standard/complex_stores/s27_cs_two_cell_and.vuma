// s27_cs_two_cell_and.vuma — two cells, and = 15 (0xFF & 0x0F)
// Expected exit code: 15
//
// Two 8-byte cells. Store 255/15 via `*ptr = literal`, load both, AND
// -> 15. Uses `*ptr = literal` form (no offsets). All operands loaded
// into typed locals before the AND. Distinct from s26_cs_two_buf_xor
// (xor, 85^51=102) and s22_cs_two_buf_sum (sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 255;            // 0xFF
    *c2 = 15;             // 0x0F
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a & b;       // 0x0F = 15
    free(c1);
    free(c2);
    return s;
}
