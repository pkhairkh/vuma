// cs_pattern_fill.vuma — fill 4 bytes with value 7, load first byte
// Expected exit code: 7
//
// Stores the same byte value 7 at offsets 0,1,2,3 (a memset-like pattern),
// then loads offset 0 and returns it.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 7;
    *(buf + 1) = 7;
    *(buf + 2) = 7;
    *(buf + 3) = 7;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
