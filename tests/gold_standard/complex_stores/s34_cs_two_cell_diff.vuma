// s34_cs_two_cell_diff.vuma — two cells, diff = 65 (100 - 35)
// Expected exit code: 65
//
// Two 8-byte cells. Store 100/35 via `*ptr = literal`, load both,
// subtract -> 65. Uses `*ptr = literal` form (no offsets). Distinct
// from s30_cs_two_cell_sum (sum, 130) and s27_cs_two_cell_and (and).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 35;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 65
    free(c1);
    free(c2);
    return d;
}
