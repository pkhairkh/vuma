// s43_cs_three_cell_sum.vuma — three cells, sum = 200 (40 + 70 + 90)
// Expected exit code: 200
//
// Three 8-byte cells. Store 40/70/90 via `*ptr = literal`, load all,
// sum -> 200. Uses `*ptr = literal` form (no offsets). Distinct from
// s42_cs_three_cell_xor (195) and s38_cs_three_cell_sum (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 70;
    *c3 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 200
    free(c1);
    free(c2);
    free(c3);
    return s;
}
