// s80_cs_three_cell_diff.vuma — three cells, diff = 13 (15 - 1 - 1)
// Expected exit code: 13
//
// Three 8-byte cells. Store 15/1/1 via `*ptr = literal`, load
// all three, a - b - c -> 13. Uses `*ptr = literal` form (no
// offsets). Distinct from s78_cs_three_cell_diff (148),
// s74_cs_three_cell_diff (50) and s73_cs_three_cell_diff (70).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 15;
    *c2 = 1;
    *c3 = 1;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 13
    free(c1);
    free(c2);
    free(c3);
    return r;
}
