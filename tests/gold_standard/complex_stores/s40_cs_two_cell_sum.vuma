// s40_cs_two_cell_sum.vuma — two cells, sum = 240 (175 + 65)
// Expected exit code: 240
//
// Two 8-byte cells. Store 175/65 via `*ptr = literal`, load both,
// sum -> 240. Uses `*ptr = literal` form (no offsets). Distinct from
// s38_cs_two_cell_diff (140) and s34_cs_two_cell_diff (65).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 175;
    *c2 = 65;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 240
    free(c1);
    free(c2);
    return s;
}
