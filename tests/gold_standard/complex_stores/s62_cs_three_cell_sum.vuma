// s62_cs_three_cell_sum.vuma — three cells, sum = 195 (70 + 85 + 40)
// Expected exit code: 195
// 
// Three 8-byte cells. Store 70/85/40 via `*ptr = literal`, load all
// three, sum -> 195. Uses `*ptr = literal` form (no offsets). Distinct
// from s51_cs_three_cell_sum (215), s58_cs_three_cell_diff (120) and
// s55_cs_overwrite_first (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 70;
    *c2 = 85;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 195
    free(c1);
    free(c2);
    free(c3);
    return s;
}
