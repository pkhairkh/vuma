// s96_cs_three_cell_diff.vuma — three cells, diff = 120 (250 - 100 - 30)
// Expected exit code: 120
//
// Three 8-byte cells. Store 250/100/30 via `*ptr = literal`, load
// all three, 250 - 100 - 30 -> 120. Uses `*ptr = literal` form.
// Distinct from s94_cs_three_cell_sum (90),
// s90_cs_three_cell_diff (6) and s86_cs_three_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 100;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    d: u64 = a - b - c;    // 120
    free(c1);
    free(c2);
    free(c3);
    return d;
}
