// s59_cs_two_cell_diff.vuma — two cells, diff = 180 (230 - 50)
// Expected exit code: 180
//
// Two 8-byte cells. Store 230/50 via `*ptr = literal`, load both,
// subtract -> 180. Uses `*ptr = literal` form (no offsets). Distinct
// from s58_cs_two_cell_sum (200), s58_cs_three_cell_diff (120) and
// s58_cs_overwrite_first (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 230;
    *c2 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 180
    free(c1);
    free(c2);
    return d;
}
