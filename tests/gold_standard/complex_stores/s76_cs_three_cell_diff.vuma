// s76_cs_three_cell_diff.vuma — three cells, diff = 33 (240 - 130 - 77)
// Expected exit code: 33
//
// Three 8-byte cells. Store 240/130/77 via `*ptr = literal`, load
// all three, diff -> 33. Uses `*ptr = literal` form (no offsets).
// Distinct from s74_cs_three_cell_diff (67), s73_cs_three_cell_diff
// (134) and s72_cs_three_cell_sum (190).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 240;
    *c2 = 130;
    *c3 = 77;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 110
    r: u64 = t - c;        // 33
    free(c1);
    free(c2);
    free(c3);
    return r;
}
