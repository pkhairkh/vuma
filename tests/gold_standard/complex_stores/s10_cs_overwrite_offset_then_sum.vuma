// s10_cs_overwrite_offset_then_sum.vuma — overwrite offset 8, sum = 139
// Expected exit code (correct): 139  (10 + 99 + 30)
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// 24-byte buffer. Store 10/20/30 at offsets 0/8/16, then overwrite
// offset 8 with 99. Load all three, sum -> 10 + 99 + 30 = 139.
// Distinct from s5_cs_overwrite_then_sum (overwrites offset 0) and
// s6_cs_overwrite_then_load (single offset, no sum).

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 10;
    *(p + 8) = 20;
    *(p + 16) = 30;
    *(p + 8) = 99;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    s: u64 = a + b + c;
    free(p);
    return s;
}
