// s21_cs_two_buf_overwrite_last.vuma — overwrite last of two cells, sum = 121
// Expected exit code: 121  (33 + 88)
//
// Two 8-byte cells. Store 33/55 in c1/c2, then overwrite c2 with 88.
// Load both, sum -> 121. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_cs_two_buf_overwrite_one (overwrites FIRST cell,
// 50+82 = 132) and s14_cs_two_buf_overwrite_one (15/25 -> 100/25 = 125).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 33;
    *c2 = 55;
    *c2 = 88;
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
