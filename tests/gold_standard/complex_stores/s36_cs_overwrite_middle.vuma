// s36_cs_overwrite_middle.vuma — 3 cells 50/60/70, overwrite middle to 120, sum = 240
// Expected exit code: 240
//
// Three 8-byte cells. Store 50/60/70, then overwrite the
// middle cell to 120; load all three, sum -> 240. Uses
// `*ptr = literal` form (no offsets).
// Distinct from s30_cs_overwrite_middle (overwrite, 210) and s27_cs_overwrite_middle (different cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 60;
    *c2 = 120;
    *c3 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = *c3;
    s: u64 = a + b + d;    // 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
