// s61_cs_three_cell_diff.vuma — three cells, diff = 140 (240 - 60 - 40)
// Expected exit code: 140
// 
// Three 8-byte cells. Store 240/60/40 via `*ptr = literal`, load
// all three, 240 - 60 - 40 = 140. Uses `*ptr = literal` form (no
// offsets). Distinct from s58_cs_two_cell_sum (200), s58_cs_three_
// cell_diff (120) and s58_cs_overwrite_first (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 240;
    *c2 = 60;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    r: u64 = t - c;        // 140
    free(c1);
    free(c2);
    free(c3);
    return r;
}
