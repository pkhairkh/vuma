// Base64 Encode — Encode binary data into Base64 ASCII representation
//
// Implements RFC 4648 Base64 encoding. Every 3 input bytes produce 4 output
// characters from the Base64 alphabet (A-Z, a-z, 0-9, +, /). Input data
// that is not a multiple of 3 bytes is padded with '=' characters.
//
// VUMA Key Concepts:
//   - Bit manipulation: extracting 6-bit groups from 8-bit bytes
//   - Lookup table pattern for alphabet mapping
//   - Variable-length processing with padding logic
//   - Pointer arithmetic for both input and output buffers
//   - allocate/free with proper cleanup
//   - Pure computation returning meaningful checksum

// ===========================================================================
// Base64 alphabet lookup (6-bit index → ASCII character)
// ===========================================================================
// 0-25: A-Z (65-90), 26-51: a-z (97-122), 52-61: 0-9 (48-57),
// 62: + (43), 63: / (47)

fn b64_char(index: u64) -> u64 {
    if index < 26 {
        return index + 65;     // A-Z
    }
    if index < 52 {
        return index + 71;     // a-z (index 26→97, so 26+71=97)
    }
    if index < 62 {
        return index - 4;      // 0-9 (index 52→48, so 52-4=48)
    }
    if index == 62 {
        return 43;             // +
    }
    return 47;                 // /
}

// ===========================================================================
// Encode 3 bytes into 4 Base64 characters
// ===========================================================================
// Extracts four 6-bit groups from three 8-bit bytes:
//   [bbbbbbbb][bbbbbbbb][bbbbbbbb]
//   → [bbbbbb][bbbbbb][bbbbbb][bbbbbb]

fn encode_triple(dst: Address, b0: u64, b1: u64, b2: u64) {
    // Extract 6-bit groups
    g0: u64 = (b0 >> 2) & 63;
    g1: u64 = ((b0 & 3) << 4) | ((b1 >> 4) & 15);
    g2: u64 = ((b1 & 15) << 2) | ((b2 >> 6) & 3);
    g3: u64 = b2 & 63;

    // Map to Base64 alphabet
    *(dst + 0) = b64_char(g0);
    *(dst + 1) = b64_char(g1);
    *(dst + 2) = b64_char(g2);
    *(dst + 3) = b64_char(g3);
}

// ===========================================================================
// Encode the final 1 or 2 bytes with padding
// ===========================================================================

fn encode_final(dst: Address, b0: u64, b1: u64, remaining: u64) {
    g0: u64 = (b0 >> 2) & 63;
    g1: u64 = (b0 & 3) << 4;

    if remaining == 1 {
        // 1 remaining byte: 2 Base64 chars + 2 padding
        *(dst + 0) = b64_char(g0);
        *(dst + 1) = b64_char(g1);
        *(dst + 2) = 61;   // '='
        *(dst + 3) = 61;   // '='
    } else {
        // 2 remaining bytes: 3 Base64 chars + 1 padding
        g2: u64 = ((b1 & 15) << 2);
        g1 = g1 | ((b1 >> 4) & 15);
        *(dst + 0) = b64_char(g0);
        *(dst + 1) = b64_char(g1);
        *(dst + 2) = b64_char(g2);
        *(dst + 3) = 61;   // '='
    }
}

// ===========================================================================
// Encode a full buffer into Base64
// ===========================================================================
// Returns the length of the output (always a multiple of 4).
// Also computes an XOR checksum of all output characters.

fn base64_encode(input: Address, in_len: u64, output: Address) -> u64 {
    i: u64 = 0;
    out_idx: u64 = 0;
    checksum: u64 = 0;

    // Process complete triples
    full_triples: u64 = in_len / 3;
    triple: u64 = 0;
    while triple < full_triples {
        b0: u64 = *(input + i);
        b1: u64 = *(input + i + 1);
        b2: u64 = *(input + i + 2);
        encode_triple(output + out_idx, b0, b1, b2);
        // Accumulate checksum
        checksum = checksum ^ *(output + out_idx);
        checksum = checksum ^ *(output + out_idx + 1);
        checksum = checksum ^ *(output + out_idx + 2);
        checksum = checksum ^ *(output + out_idx + 3);
        i = i + 3;
        out_idx = out_idx + 4;
        triple = triple + 1;
    }

    // Process remaining bytes (1 or 2) with padding
    remaining: u64 = in_len % 3;
    if remaining > 0 {
        b0: u64 = *(input + i);
        b1: u64 = 0;
        if remaining == 2 {
            b1 = *(input + i + 1);
        }
        encode_final(output + out_idx, b0, b1, remaining);
        checksum = checksum ^ *(output + out_idx);
        checksum = checksum ^ *(output + out_idx + 1);
        checksum = checksum ^ *(output + out_idx + 2);
        checksum = checksum ^ *(output + out_idx + 3);
        out_idx = out_idx + 4;
    }

    // Store checksum at a global-ish location via return
    // Return (out_idx << 32) | (checksum & 4294967295)
    return (out_idx << 32) | (checksum & 4294967295);
}

// ===========================================================================
// Main entry point
// ===========================================================================
// Encodes "Hello, World!" (13 bytes) in Base64.
// Expected: "SGVsbG8sIFdvcmxkIQ=="
// Output length: 20 bytes (ceil(13/3)*4 = 20)
// Returns: output length (20) as exit code
//
// Base64("Hello, World!") = SGVsbG8sIFdvcmxkIQ==
// That's 5 groups of 4: SGVs, bG8s, IFdv, cmxk, IQ==

fn main() -> i32 {
    // Allocate input: "Hello, World!" (13 bytes)
    input = allocate(13);
    *(input + 0) = 72;    // 'H'
    *(input + 1) = 101;   // 'e'
    *(input + 2) = 108;   // 'l'
    *(input + 3) = 108;   // 'l'
    *(input + 4) = 111;   // 'o'
    *(input + 5) = 44;    // ','
    *(input + 6) = 32;    // ' '
    *(input + 7) = 87;    // 'W'
    *(input + 8) = 111;   // 'o'
    *(input + 9) = 114;   // 'r'
    *(input + 10) = 108;  // 'l'
    *(input + 11) = 100;  // 'd'
    *(input + 12) = 33;   // '!'

    // Allocate output buffer (ceil(13/3)*4 = 20 bytes)
    output = allocate(20);

    // Encode
    result: u64 = base64_encode(input, 13, output);

    // Extract output length (upper 32 bits) and checksum (lower 32 bits)
    out_len: u64 = result >> 32;
    checksum: u64 = result & 4294967295;

    free(input);
    free(output);

    // Return output length as exit code
    // Expected: 20
    return out_len;
}
