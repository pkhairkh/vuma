// s100_cs_three_cell_sum.vuma — three cells, sum = 54 (14 + 22 + 18)
// Expected exit code: 54
//
// Three 8-byte cells. Store 14/22/18 via `*ptr = literal`,
// load all, a + b + c -> 54. Uses `*ptr = literal` form
// (no offsets).
// Distinct from s97_cs_three_cell_sum (40), s94_cs_three_cell_sum (90), s90_cs_overwrite_last (8).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 14;
    *c2 = 22;
    *c3 = 18;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 54
    free(c1);
    free(c2);
    free(c3);
    return s;
}
