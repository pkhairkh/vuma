// cs2_independent.vuma — two bufs, store 42 in buf1 / 99 in buf2, load buf1
// Expected exit code: 42
//
// Confirms two simultaneously-live allocations don't alias: a store into
// buf2 must not corrupt buf1. Returns the value loaded from buf1.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *(buf1 + 0) = 42;
    *(buf2 + 0) = 99;
    val: u32 = *(buf1 + 0);
    free(buf1);
    free(buf2);
    return val;
}
