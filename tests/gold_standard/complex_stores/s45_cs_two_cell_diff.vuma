// s45_cs_two_cell_diff.vuma — two cells, diff = 180 (210 - 30)
// Expected exit code: 180
//
// Two 8-byte cells. Store 210/30 via `*ptr = literal`, load both,
// subtract -> 180. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_cs_two_cell_sum (sum, 250) and s38_cs_two_cell_diff (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 210;
    *c2 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 180
    free(c1);
    free(c2);
    return d;
}
