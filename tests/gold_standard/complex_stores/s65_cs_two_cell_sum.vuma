// s65_cs_two_cell_sum.vuma — two cells, sum = 175 (95 + 80)
// Expected exit code: 175
//
// Two 8-byte cells. Store 95/80 via `*ptr = literal`, load both,
// sum -> 175. Uses `*ptr = literal` form (no offsets). Distinct from
// s51_cs_two_cell_diff (100), s58_cs_two_cell_sum (200) and s62_cs_
// two_cell_diff (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 175
    free(c1);
    free(c2);
    return s;
}
