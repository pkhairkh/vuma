// s6_cs_four_offsets.vuma — scatter 4 values across 32 bytes, sum = 100
// Expected exit code: 100  (10 + 20 + 30 + 40)
//
// 32-byte buffer. Store 10/20/30/40 at offsets 0/8/16/24. Load all
// four, sum, return 100. Distinct from s5_cs_long_scatter (different
// values 10/20/40/60).

fn main() -> i32 {
    buf = allocate(32);
    *(buf + 0) = 10;
    *(buf + 8) = 20;
    *(buf + 16) = 30;
    *(buf + 24) = 40;
    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    d: u64 = *(buf + 24);
    t1: u64 = a + b;
    t2: u64 = c + d;
    s: u64 = t1 + t2;
    free(buf);
    return s;
}
