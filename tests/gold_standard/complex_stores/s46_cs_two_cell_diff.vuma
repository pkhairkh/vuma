// s46_cs_two_cell_diff.vuma — two cells, diff = 150 (220 - 70)
// Expected exit code: 150
//
// Two 8-byte cells. Store 220/70 via `*ptr = literal`, load both,
// subtract -> 150. Uses `*ptr = literal` form (no offsets).
// Distinct from s42_cs_two_cell_sum (250) and s38_cs_two_cell_diff
// (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 150
    free(c1);
    free(c2);
    return d;
}
