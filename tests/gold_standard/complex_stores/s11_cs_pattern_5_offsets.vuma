// s11_cs_pattern_5_offsets.vuma — 5 offsets, sum = 150
// Expected exit code (correct): 150  (10 + 20 + 30 + 40 + 50)
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// 40-byte buffer. Store 10/20/30/40/50 at offsets 0/8/16/24/32. Load
// all five, sum -> 150. Distinct from s10_cs_pattern_4_offsets (4
// offsets, 4 values) and s7_cs_six_offsets_sum (6 offsets).

fn main() -> i32 {
    p = allocate(40);
    *(p + 0) = 10;
    *(p + 8) = 20;
    *(p + 16) = 30;
    *(p + 24) = 40;
    *(p + 32) = 50;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    d: u64 = *(p + 24);
    e: u64 = *(p + 32);
    t1: u64 = a + b;
    t2: u64 = t1 + c;
    t3: u64 = t2 + d;
    s: u64 = t3 + e;
    free(p);
    return s;
}
