// s65_cs_three_cell_diff.vuma — three cells, diff = 165 (230 - 40 - 25)
// Expected exit code: 165
//
// Three 8-byte cells. Store 230/40/25 via `*ptr = literal`, load all
// three, diff -> 165. Uses `*ptr = literal` form (no offsets). Distinct
// from s51_cs_three_cell_sum (215), s58_cs_three_cell_diff (120) and
// s62_cs_three_cell_sum (195).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 230;
    *c2 = 40;
    *c3 = 25;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    s: u64 = t - c;        // 165
    free(c1);
    free(c2);
    free(c3);
    return s;
}
