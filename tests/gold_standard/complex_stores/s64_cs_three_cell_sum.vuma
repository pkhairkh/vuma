// s64_cs_three_cell_sum.vuma — three cells, sum = 185 (65 + 78 + 42)
// Expected exit code: 185
//
// Three 8-byte cells. Store 65/78/42 via `*ptr = literal`, load all
// three, sum -> 185. Uses `*ptr = literal` form (no offsets). Distinct
// from s62_cs_overwrite_last (130), s62_cs_three_cell_sum (195) and
// s62_cs_two_cell_diff (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 65;
    *c2 = 78;
    *c3 = 42;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 185
    free(c1);
    free(c2);
    free(c3);
    return s;
}
