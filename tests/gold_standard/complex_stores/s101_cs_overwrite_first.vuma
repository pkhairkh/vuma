// s101_cs_overwrite_first.vuma — overwrite c1 to 28, load = 28
// Expected exit code: 28
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50
// at c3, then overwrite c1 to 28. Load c1 -> 28 (the overwritten
// value). Uses `*ptr = literal` form. Distinct from
// s98_cs_overwrite_middle (116), s97_cs_overwrite_last (24) and
// s94_cs_overwrite_middle (42).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 28;
    v: u64 = *c1;          // 28
    free(c1);
    free(c2);
    free(c3);
    return v;
}
