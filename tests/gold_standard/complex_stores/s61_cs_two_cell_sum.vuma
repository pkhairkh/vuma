// s61_cs_two_cell_sum.vuma — two cells, sum = 225 (95 + 130)
// Expected exit code: 225
// 
// Two 8-byte cells. Store 95/130 via `*ptr = literal`, load both,
// sum -> 225. Uses `*ptr = literal` form (no offsets). Distinct
// from s58_cs_two_cell_sum (200), s58_cs_three_cell_diff (120)
// and s58_cs_overwrite_first (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 130;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 225
    free(c1);
    free(c2);
    return s;
}
