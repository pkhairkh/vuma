// s77_cs_two_cell_sum.vuma — two cells, sum = 122 (110 + 12)
// Expected exit code: 122
//
// Two 8-byte cells. Store 110/12 via `*ptr = literal`, load
// both, sum -> 122. Uses `*ptr = literal` form (no offsets).
// Distinct from s70_cs_two_cell_diff (90), s66_cs_two_cell_sum
// (250) and s74_cs_two_cell_sum (187).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 110;
    *c2 = 12;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 122
    free(c1);
    free(c2);
    return s;
}
