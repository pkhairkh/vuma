// s37_cs_three_cell_sum.vuma — three cells, sum = 50 + 100 + 105 = 255
// Expected exit code: 255
//
// Deterministic test in the complex_stores category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_cs_three_cell_xor (xor, 15) and s30_cs_three_cell_xor (different values).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 105;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;     // 255
    free(c1);
    free(c2);
    free(c3);
    return s;
}
