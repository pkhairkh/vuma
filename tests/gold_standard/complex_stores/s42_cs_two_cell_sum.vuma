// s42_cs_two_cell_sum.vuma — two cells, sum = 250 (100 + 150)
// Expected exit code: 250
//
// Two 8-byte cells. Store 100/150 via `*ptr = literal`, load both,
// sum -> 250. Uses `*ptr = literal` form (no offsets). Distinct from
// s38_cs_two_cell_diff (140) and s34_cs_two_cell_diff (65).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 150;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 250
    free(c1);
    free(c2);
    return s;
}
