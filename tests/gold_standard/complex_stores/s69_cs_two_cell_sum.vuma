// s69_cs_two_cell_sum.vuma -- two cells, sum = 145 (65 + 80)
// Expected exit code: 145
//
// Two 8-byte cells. Store 65/80 via `*ptr = literal`, load both,
// sum -> 145. Uses `*ptr = literal` form (no offsets). Distinct from
// s66_cs_two_cell_sum (250), s65_cs_two_cell_sum (175) and s64_cs_
// two_cell_diff (168).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 65;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 145
    free(c1);
    free(c2);
    return s;
}
