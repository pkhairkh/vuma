// cs2_before_free.vuma — store 42, load, free, return loaded value
// Expected exit code: 42
//
// Mirror of cs2_after_alloc: the load happens before free, and the
// loaded value is returned after the free. Verifies that free does
// not corrupt the scalar register holding the loaded value.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
