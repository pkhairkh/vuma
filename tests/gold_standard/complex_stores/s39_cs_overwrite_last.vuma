// s39_cs_overwrite_last.vuma — overwrite last to 100, sum = 170 (30 + 40 + 100)
// Expected exit code: 170
//
// Three 8-byte cells. Store 30/40/50 via `*ptr = literal`, then
// overwrite the last cell with 100. Load all three, sum -> 170.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s38_cs_overwrite_middle (210) and s34_cs_overwrite_first (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c3 = 50;
    *c3 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 170
    free(c1);
    free(c2);
    free(c3);
    return s;
}
