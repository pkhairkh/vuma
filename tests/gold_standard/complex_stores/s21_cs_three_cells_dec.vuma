// s21_cs_three_cells_dec.vuma — three cells, descending values, sum = 240
// Expected exit code: 240
//
// Three 8-byte cells. Store 120/80/40 (descending by 40) in c1/c2/c3.
// Load all three, sum -> 240. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_cs_three_cells_inc (ascending 11/22/33 = 66) and
// s14_cs_three_cells_desc (30/20/10 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 120;
    *c2 = 80;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
