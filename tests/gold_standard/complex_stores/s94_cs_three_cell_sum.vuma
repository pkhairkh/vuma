// s94_cs_three_cell_sum.vuma — three cells, sum = 90 (30 + 40 + 20)
// Expected exit code: 90
//
// Three 8-byte cells. Store 30/40/20 via `*ptr = literal`, load all
// three, a + b + c -> 90. Uses `*ptr = literal` form (no offsets).
// Distinct from s90_cs_three_cell_diff (6), s86_cs_three_cell_diff
// (140) and s82_cs_three_cell_diff (125).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c3 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a + b + c;    // 90
    free(c1);
    free(c2);
    free(c3);
    return r;
}
