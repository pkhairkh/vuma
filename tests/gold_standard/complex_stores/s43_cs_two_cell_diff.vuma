// s43_cs_two_cell_diff.vuma — two cells, diff = 120 (180 - 60)
// Expected exit code: 120
//
// Two 8-byte cells. Store 180/60 via `*ptr = literal`, load both,
// subtract -> 120. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_cs_two_cell_sum (250) and s38_cs_two_cell_diff (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 180;
    *c2 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 120
    free(c1);
    free(c2);
    return d;
}
