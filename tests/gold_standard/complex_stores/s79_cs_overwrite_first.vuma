// s79_cs_overwrite_first.vuma — store 1, overwrite with 36, load = 36
// Expected exit code: 36
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite
// with 36 via `*ptr = literal`, load and return 36. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s78_cs_overwrite_first (3), s77_cs_overwrite_first (2) and
// s76_cs_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 36;
    r: u64 = *c1;          // 36
    free(c1);
    return r;
}
