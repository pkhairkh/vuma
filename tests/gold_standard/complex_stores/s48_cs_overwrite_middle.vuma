// s48_cs_overwrite_middle.vuma — overwrite middle to 100, sum = 220 (50 + 100 + 70)
// Expected exit code: 220
//
// Three 8-byte cells. Store 50/60/70 via `*ptr = literal`, then
// overwrite the middle cell with 100. Load all three, sum -> 220.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_cs_
// overwrite_first (250) and s42_cs_overwrite_last (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 60;
    *c3 = 70;
    *c2 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 220
    free(c1);
    free(c2);
    free(c3);
    return s;
}
