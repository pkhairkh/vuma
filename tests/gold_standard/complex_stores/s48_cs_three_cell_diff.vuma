// s48_cs_three_cell_diff.vuma — three cells, diff = 180 (250 - 40 - 30)
// Expected exit code: 180
//
// Three 8-byte cells. Store 250/40/30 via `*ptr = literal`, load all,
// subtract twice -> 180. Uses `*ptr = literal` form (no offsets).
// Distinct from s46_cs_three_cell_sum (195) and s42_cs_three_cell_xor.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 40;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    s: u64 = t - c;        // 180
    free(c1);
    free(c2);
    free(c3);
    return s;
}
