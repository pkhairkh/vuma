// cs_overwrite_store.vuma — store 42, overwrite with 99, load
// Expected exit code: 99
//
// Verifies that a second store to the same offset overwrites the first.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    *(buf + 0) = 99;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
