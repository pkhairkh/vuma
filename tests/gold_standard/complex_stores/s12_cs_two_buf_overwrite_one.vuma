// s12_cs_two_buf_overwrite_one.vuma — two cells, overwrite first, sum = 139
// Expected exit code: 139  (99 + 40)
//
// Two independent 8-byte cells. Store 20/40, then overwrite the first
// cell with 99 (last write wins). Load both, sum -> 99 + 40 = 139.
// Uses `*ptr = literal` form (no offsets) to avoid the offset-store
// drop bug. Distinct from s9_cs_two_buf_overwrite_both (overwrites
// both) and s9_cs_overwrite_middle (three cells, middle overwrite).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 20;
    *b = 40;
    *a = 99;
    va: u64 = *a;
    vb: u64 = *b;
    s: u64 = va + vb;
    free(a);
    free(b);
    return s;
}
