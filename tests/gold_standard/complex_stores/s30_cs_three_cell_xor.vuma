// s30_cs_three_cell_xor.vuma — three cells, xor = 119 (0x11 ^ 0x22 ^ 0x44)
// Expected exit code: 119
//
// Three 8-byte cells. Store 0x11/0x22/0x44 via `*ptr = literal`, load
// all three, XOR -> 0x77 = 119. Uses `*ptr = literal` form (no offsets).
// All operands loaded into typed locals before the XOR. Distinct from
// s26_cs_overwrite_middle (overwrite, 160) and s22_cs_overwrite_first
// (overwrite, 110).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 17;             // 0x11
    *c2 = 34;             // 0x22
    *c3 = 68;             // 0x44
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a ^ b;
    r: u64 = t ^ c;        // 0x77 = 119
    free(c1);
    free(c2);
    free(c3);
    return r;
}
