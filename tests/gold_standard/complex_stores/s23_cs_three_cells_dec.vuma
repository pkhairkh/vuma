// s23_cs_three_cells_dec.vuma — three cells descending, sum = 165 (80 + 55 + 30)
// Expected exit code: 165
//
// Three 8-byte cells. Store 80/55/30 (descending) in c1/c2/c3. Load all
// three, sum -> 165. Uses `*ptr = literal` form (no offsets). Distinct
// from s22_cs_three_cells_asc (12/34/56 = 102) and s21_cs_three_cells_dec
// (60/40/20 = 120).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 80;
    *c2 = 55;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;   // 165
    free(c1);
    free(c2);
    free(c3);
    return s;
}

