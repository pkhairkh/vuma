// s43_cs_overwrite_first.vuma — overwrite first cell 50 -> 150, sum with 30 = 180
// Expected exit code: 180
//
// Two 8-byte cells. Store 50 in c1 via `*ptr = literal`, then
// overwrite c1 to 150 via `*ptr = literal`. Store 30 in c2. Load
// both, sum -> 180. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_cs_overwrite_last (225) and s38_cs_overwrite_middle (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 50;
    *c1 = 150;
    *c2 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 180
    free(c1);
    free(c2);
    return s;
}
