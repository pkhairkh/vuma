// s9_cs_overwrite_middle.vuma — overwrite middle cell, sum = 140
// Expected exit code: 140  (10 + 100 + 30)
//
// Three 8-byte cells. Store 10/20/30 in c1/c2/c3, then overwrite
// c2 (the middle cell) with 100. Load all three, sum -> 140. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s5_cs_overwrite_then_sum (uses *(buf+N) form, overwrites offset 0)
// and s5_ls_overwrite_middle (linked-structure framing).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c2 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
