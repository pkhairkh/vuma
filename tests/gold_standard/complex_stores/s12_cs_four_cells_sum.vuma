// s12_cs_four_cells_sum.vuma — four cells, sum loads = 100 (10+20+30+40)
// Expected exit code: 100
//
// Four independent 8-byte cells. Store 10/20/30/40 via `*ptr =
// literal` form (deterministic on the current backend). All four
// loaded back and summed. Distinct from s9_cs_three_cells_asc
// (3 cells, 5/15/25 = 45) and s10_cs_pattern_4_offsets (uses
// *(p+N) form, non-deterministic).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    c4 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c4 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    d: u64 = *c4;
    t1: u64 = a + b;
    t2: u64 = t1 + c;
    s: u64 = t2 + d;
    free(c1);
    free(c2);
    free(c3);
    free(c4);
    return s;
}
