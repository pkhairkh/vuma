// s55_cs_two_cell_diff.vuma — two cells, diff = 125 (220 - 95)
// Expected exit code: 125
//
// Two 8-byte cells. Store 220/95 via `*ptr = literal`, load both,
// subtract -> 125. Uses `*ptr = literal` form (no offsets). Distinct
// from s54_cs_two_cell_sum (245) and s53_cs_two_cell_diff (170).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 95;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a - b;        // 125
    free(c1);
    free(c2);
    return s;
}
