// cs_store_after_alloc.vuma — allocate, immediately store, load
// Expected exit code: 42
//
// Smallest meaningful pattern: allocation followed immediately by a store
// and load. Verifies the alloc→store→load sequence without intervening
// operations.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
