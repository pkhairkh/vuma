// s11_cs_overwrite_two_offsets.vuma — overwrite offsets 0 and 16, sum = 110
// Expected exit code: 110
// Expected exit code (correct): 110  (40 + 20 + 50)
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// 24-byte buffer. Store 10/20/30 at offsets 0/8/16, then overwrite
// offsets 0 and 16 with 40 and 50 respectively. Load all three, sum
// -> 40 + 20 + 50 = 110. Distinct from s10_cs_overwrite_offset_then_sum
// (overwrites only offset 8) and s8_cs_overwrite_first_last (overwrites
// first and last with same value).

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 10;
    *(p + 8) = 20;
    *(p + 16) = 30;
    *(p + 0) = 40;
    *(p + 16) = 50;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    s: u64 = a + b + c;
    free(p);
    return s;
}
