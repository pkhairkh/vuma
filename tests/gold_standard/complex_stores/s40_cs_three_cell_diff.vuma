// s40_cs_three_cell_diff.vuma — three cells, diff = 100 (230 - 95 - 35)
// Expected exit code: 100
//
// Three 8-byte cells. Store 230/95/35 via `*ptr = literal`, load
// all, subtract -> 100. Uses `*ptr = literal` form (no offsets).
// Distinct from s38_cs_three_cell_sum (220) and s34_cs_three_cell_
// sum (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 230;
    *c2 = 95;
    *c3 = 35;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    d: u64 = t - c;        // 100
    free(c1);
    free(c2);
    free(c3);
    return d;
}
