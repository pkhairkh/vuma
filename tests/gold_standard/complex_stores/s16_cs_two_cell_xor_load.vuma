// s16_cs_two_cell_xor_load.vuma — two cells 0x55/0x33, XOR = 102
// Expected exit code: 102
//
// Two 8-byte cells. Store 0x55 (85) / 0x33 (51) via `*ptr = literal`.
// Load both, XOR -> 0x66 (102). Uses `*ptr = literal` form (no offsets).
// Distinct from s11_cs_two_buf_offset_diff (uses broken *(p+N) form) and
// s9_cs_two_buf_overwrite_both (sum, not XOR).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 85;            // 0x55
    *c2 = 51;            // 0x33
    a: u64 = *c1;
    b: u64 = *c2;
    r: u64 = a ^ b;      // 0x66 = 102
    free(c1);
    free(c2);
    return r;
}
