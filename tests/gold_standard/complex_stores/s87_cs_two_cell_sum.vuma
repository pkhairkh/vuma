// s87_cs_two_cell_sum.vuma — two cells, sum = 180 (95 + 85)
// Expected exit code: 180
//
// Two 8-byte cells. Store 95/85 via `*ptr = literal`, load
// both, sum -> 180. Uses `*ptr = literal` form (no offsets).
// Distinct from s86_cs_two_cell_sum (170), s82_cs_two_cell_sum
// (160) and s78_cs_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 85;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 180
    free(c1);
    free(c2);
    return s;
}
