// s54_cs_three_cell_diff.vuma — three cells, diff = 80 (200-80-40)
// Expected exit code: 80
//
// Three 8-byte cells. Store 200/80/40 via `*ptr = literal`, load
// all three, subtract sequentially -> 80. Uses `*ptr = literal`
// form (no offsets). Distinct from s50_cs_three_cell_diff (195)
// and s49_cs_overwrite_last (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 80;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    s: u64 = t - c;        // 80
    free(c1);
    free(c2);
    free(c3);
    return s;
}
