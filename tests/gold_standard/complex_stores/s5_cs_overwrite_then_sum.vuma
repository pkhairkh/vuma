// s5_cs_overwrite_then_sum.vuma — overwrite first offset, sum = 130
// Expected exit code: 130  (88 + 20 + 22)
//
// 24-byte buffer. Store 1/20/22 at offsets 0/8/16, then overwrite
// offset 0 with 88. Load all three, sum = 88 + 20 + 22 = 130.
// Distinct from s4_cs_overwrite_then_load (single value return).

fn main() -> i32 {
    buf = allocate(24);
    *(buf + 0) = 1;
    *(buf + 8) = 20;
    *(buf + 16) = 22;
    *(buf + 0) = 88;
    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    s: u64 = a + b + c;
    free(buf);
    return s;
}
