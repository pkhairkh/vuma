// s49_cs_overwrite_middle.vuma — overwrite middle to 90, sum = 190 (40 + 90 + 60)
// Expected exit code: 190
//
// Three 8-byte cells. Store 40/50/60 via `*ptr = literal`, then
// overwrite the middle cell with 90. Load all three, sum -> 190.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_cs_
// overwrite_first (250, first overwrite) and s42_cs_overwrite_last
// (210, last overwrite).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 50;
    *c3 = 60;
    *c2 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
