// s41_cs_three_cell_sum.vuma - three cells, sum = 230 (45 + 85 + 100)
// Expected exit code: 230
//
// Three 8-byte cells. Store 45/85/100 via `*ptr = literal`, load all,
// sum -> 230. Uses `*ptr = literal` form (no offsets). Distinct from
// s38_cs_three_cell_sum (220) and s34_cs_three_cell_sum (180).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 45;
    *c2 = 85;
    *c3 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 230
    free(c1);
    free(c2);
    free(c3);
    return s;
}
