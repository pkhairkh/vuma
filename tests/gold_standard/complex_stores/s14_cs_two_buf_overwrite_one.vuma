// s14_cs_two_buf_overwrite_one.vuma — overwrite first of two cells, sum = 125
// Expected exit code: 125  (100 + 25)
//
// Two 8-byte cells. Store 15/25 in c1/c2, then overwrite c1 with
// 100. Load both, sum -> 125. Uses `*ptr = literal` form (no
// offsets). Distinct from s9_cs_two_buf_overwrite_both (overwrites
// BOTH cells, values 70/80 = 150) and s10_cs_two_buf_offset_sum
// (uses broken *(buf+N) form).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 15;
    *c2 = 25;
    *c1 = 100;
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
