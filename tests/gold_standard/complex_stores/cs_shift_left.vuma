// cs_shift_left.vuma — store 1 at offset 0, store 0 at offset 0 (overwrite), load
// Expected exit code: 0
//
// Trivial overwrite sequence: store non-zero, then zero, then load. Verifies
// that the second store replaces the first.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 1;
    *(buf + 0) = 0;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
