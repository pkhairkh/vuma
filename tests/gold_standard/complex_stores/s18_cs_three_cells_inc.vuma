// s18_cs_three_cells_inc.vuma — three cells, ascending values, sum = 66 (11 + 22 + 33)
// Expected exit code: 66
//
// Three 8-byte cells. Store 11/22/33 (ascending by 11) in c1/c2/c3.
// Load all three, sum -> 66. Uses `*ptr = literal` form (no offsets).
// Distinct from s14_cs_three_cells_desc (descending values 30/20/10)
// and s10_cs_two_buf_offset_sum (uses broken *(buf+N) form).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 11;
    *c2 = 22;
    *c3 = 33;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
