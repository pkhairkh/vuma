// cs2_byte_store.vuma — store literal 42 at offset 0, load
// Expected exit code: 42
//
// Canonical single-byte store/load roundtrip on a fresh allocation.
// This is the bridge test between the cs_* family (offset-0 stores via
// *(buf + 0)) and the cs2_* family — same shape, new prefix, to widen
// the regression net for the offset-store codegen path.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
