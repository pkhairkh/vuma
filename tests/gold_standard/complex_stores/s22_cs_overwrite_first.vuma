// s22_cs_overwrite_first.vuma — overwrite first of three cells, sum = 110 (70 + 15 + 25)
// Expected exit code: 110
//
// Three 8-byte cells. Store 5/15/25 in c1/c2/c3, then overwrite c1 (the
// first cell) with 70. Load all three, sum -> 110. Uses `*ptr = literal`
// form (no offsets). Distinct from s18_cs_overwrite_last (overwrites the
// last cell, 10/20/30 -> 99 = 129) and s14_cs_overwrite_first (different
// values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 5;
    *c2 = 15;
    *c3 = 25;
    *c1 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
