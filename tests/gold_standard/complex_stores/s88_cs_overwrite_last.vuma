// s88_cs_overwrite_last.vuma — overwrite c3 to 215, load = 215
// Expected exit code: 215
//
// Three 8-byte cells. Store 40 at c1, store 70 at c2, store
// 90 at c3, then overwrite c3 to 215. Load c3 -> 215 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s86_cs_overwrite_first (230), s82_cs_overwrite_
// middle (220) and s78_cs_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 70;
    *c3 = 90;
    *c3 = 215;
    v: u64 = *c3;          // 215
    free(c1);
    free(c2);
    free(c3);
    return v;
}
