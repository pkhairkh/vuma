// s82_cs_three_cell_diff.vuma — three cells, diff = 125 (220 - 80 - 15)
// Expected exit code: 125
//
// Three 8-byte cells. Store 220/80/15 via `*ptr = literal`,
// load all three, a - b - c -> 125. Uses `*ptr = literal` form
// (no offsets). Distinct from s78_cs_three_cell_diff (148),
// s74_cs_three_cell_diff (50) and s72_cs_three_cell_diff (30).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 80;
    *c3 = 15;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 125
    free(c1);
    free(c2);
    free(c3);
    return r;
}
