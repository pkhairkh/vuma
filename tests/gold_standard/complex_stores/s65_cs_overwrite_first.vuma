// s65_cs_overwrite_first.vuma — overwrite first to 80, sum = 115 (80 + 25 + 10)
// Expected exit code: 115
//
// Three 8-byte cells. Store 50/25/10 via `*ptr = literal`, then
// overwrite the first cell with 80. Load all three, sum -> 115.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_cs_
// overwrite_middle (220), s58_cs_overwrite_first (200), s62_cs_
// overwrite_last (130) and s64_cs_two_cell_diff (135).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 25;
    *c3 = 10;
    *c1 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 115
    free(c1);
    free(c2);
    free(c3);
    return s;
}
