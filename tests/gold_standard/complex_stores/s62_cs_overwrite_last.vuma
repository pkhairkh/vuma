// s62_cs_overwrite_last.vuma — overwrite last to 100, sum = 130 (10 + 20 + 100)
// Expected exit code: 130
// 
// Three 8-byte cells. Store 10/20/30 via `*ptr = literal`, then
// overwrite the last cell with 100. Load all three, sum -> 130.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_cs_
// overwrite_middle (220), s58_cs_overwrite_first (200) and s55_cs_
// two_cell_diff (100).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c3 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 130
    free(c1);
    free(c2);
    free(c3);
    return s;
}
