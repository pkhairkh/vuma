// s95_cs_three_cell_diff.vuma — three cells, diff = 43 (100 - 30 - 27)
// Expected exit code: 43
//
// Three 8-byte cells. Store 100/30/27 via `*ptr = literal`, load all
// three, a - b - c -> 43. Uses `*ptr = literal` form. Distinct from
// s94_cs_three_cell_sum (90), s90_cs_three_cell_diff (6) and
// s82_cs_three_cell_diff (125).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 30;
    *c3 = 27;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    d: u64 = a - b - c;    // 43
    free(c1);
    free(c2);
    free(c3);
    return d;
}
