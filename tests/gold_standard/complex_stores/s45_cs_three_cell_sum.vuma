// s45_cs_three_cell_sum.vuma — three cells, sum = 195 (55 + 65 + 75)
// Expected exit code: 195
//
// Three 8-byte cells. Store 55/65/75 via `*ptr = literal`, load all,
// sum -> 195. Uses `*ptr = literal` form (no offsets). Distinct from
// s42_cs_three_cell_xor (xor, 195, same total but xor vs sum) and
// s38_cs_three_cell_sum (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 55;
    *c2 = 65;
    *c3 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 195
    free(c1);
    free(c2);
    free(c3);
    return s;
}
