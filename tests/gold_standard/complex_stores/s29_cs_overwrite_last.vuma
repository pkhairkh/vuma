// s29_cs_overwrite_last.vuma — overwrite last of three, sum = 160 (30 + 40 + 90)
// Expected exit code: 160
//
// Three 8-byte cells. Store 30/40/50 in c1/c2/c3, then overwrite c3 (the last cell) with 90. Load all three, sum -> 160. Uses `*ptr = literal` form (no offsets). Distinct from s26_cs_overwrite_middle (overwrites the middle cell, 160) and s22_cs_overwrite_first (overwrites the first cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c3 = 50;
    *c3 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
