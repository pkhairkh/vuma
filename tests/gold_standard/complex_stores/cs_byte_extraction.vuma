// cs_byte_extraction.vuma — store u64, extract byte 0
// Expected exit code: 66  (0x42)
//
// Stores the bytes of a 64-bit value (0x...0042) one byte at a time in
// little-endian order, then loads byte 0 (the low byte = 0x42 = 66) to
// verify byte-level extraction via stores.
// Shifts are loaded into variables to avoid the "bitwise op with immediate
// RHS dropped" bug.

fn main() -> i32 {
    buf = allocate(8);
    val: u32 = 0x42;
    mask: u32 = 255;
    shift8: u32 = 8;
    shift16: u32 = 16;
    shift24: u32 = 24;
    // Store the low 4 bytes of "u64" (we model it as u32 for byte extraction)
    *(buf + 0) = val & mask;
    *(buf + 1) = (val >> shift8) & mask;
    *(buf + 2) = (val >> shift16) & mask;
    *(buf + 3) = (val >> shift24) & mask;
    byte0: u32 = *(buf + 0);
    free(buf);
    return byte0;
}
