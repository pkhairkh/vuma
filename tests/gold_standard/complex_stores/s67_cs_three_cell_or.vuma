// s67_cs_three_cell_or.vuma — three cells, or = 119 (17 | 34 | 68)
// Expected exit code: 119
//
// Three 8-byte cells. Store 17/34/68 via `*ptr = literal`,
// load all three, or -> 17 | 34 = 51; 51 | 68 = 119 (0x77).
// Uses `*ptr = literal` form (no offsets). Distinct from s66_
// cs_three_cell_diff (115), s62_cs_three_cell_sum (195) and
// s58_cs_three_cell_diff (120).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 17;              // 0x11
    *c2 = 34;              // 0x22
    *c3 = 68;              // 0x44
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a | b;        // 0x33 = 51
    r: u64 = t | c;        // 0x77 = 119
    free(c1);
    free(c2);
    free(c3);
    return r;
}
