// s70_cs_three_cell_sum.vuma — three cells, sum = 150 (50 + 40 + 60)
// Expected exit code: 150
//
// Three 8-byte cells. Store 50/40/60 via `*ptr = literal`, load
// all three, sum -> 150. Uses `*ptr = literal` form (no offsets).
// Distinct from s66_cs_three_cell_diff (115), s65_cs_three_cell_
// diff (165) and s62_cs_three_cell_sum (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 40;
    *c3 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 90
    s: u64 = t + c;        // 150
    free(c1);
    free(c2);
    free(c3);
    return s;
}
