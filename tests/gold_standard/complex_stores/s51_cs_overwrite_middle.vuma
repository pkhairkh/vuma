// s51_cs_overwrite_middle.vuma — overwrite middle to 80, sum = 220 (50 + 80 + 90)
// Expected exit code: 220
//
// Three 8-byte cells. Store 50/70/90 via `*ptr = literal`, then
// overwrite the middle cell with 80. Load all three, sum -> 220.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_cs_
// overwrite_last (240) and s47_cs_overwrite_middle (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 70;
    *c3 = 90;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 220
    free(c1);
    free(c2);
    free(c3);
    return s;
}
