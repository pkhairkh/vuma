// s101_cs_two_cell_xor.vuma — two cells, xor = 192 (0x80 ^ 0x40)
// Expected exit code: 192
//
// Two 8-byte cells. Store 128/64 via `*ptr = literal`, load both,
// a ^ b -> 192. Uses `*ptr = literal` form (no offsets). Distinct
// from s98_cs_two_cell_sum (113), s97_cs_two_cell_sum (53) and
// s94_cs_two_cell_sum (110).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 128;             // 0x80
    *c2 = 64;              // 0x40
    a: u64 = *c1;
    b: u64 = *c2;
    r: u64 = a ^ b;        // 0xC0 = 192
    free(c1);
    free(c2);
    return r;
}
