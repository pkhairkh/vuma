// s106_cs_three_cell_diff.vuma — store 200,74,69 in 3 cells, 200-74-69 = 57
// Expected exit code: 57
//
// Three 8-byte cells. Store 200, 74, 69; load each, return 200 - 74 - 69 = 57. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_three_cell_sum (26), s101_cs_three_cell_sum (150), s100_cs_three_cell_sum (54).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 74;
    *c3 = 69;
    a: u64 = *c1;          // 200
    b: u64 = *c2;          // 74
    c: u64 = *c3;          // 69
    d: u64 = a - b - c;    // 57
    free(c1);
    free(c2);
    free(c3);
    return d;
}
