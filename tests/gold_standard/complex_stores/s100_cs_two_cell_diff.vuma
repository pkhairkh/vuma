// s100_cs_two_cell_diff.vuma — two cells, diff = 19 (35 - 16)
// Expected exit code: 19
//
// Two 8-byte cells. Store 35/16 via `*ptr = literal`, load
// both, a - b -> 19. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s97_cs_overwrite_last (53), s94_cs_overwrite_middle (42), s90_cs_two_cell_diff (4).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 35;
    *c2 = 16;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 19
    free(c1);
    free(c2);
    return d;
}
