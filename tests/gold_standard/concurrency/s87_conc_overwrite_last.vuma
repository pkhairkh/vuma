// s87_conc_overwrite_last.vuma — overwrite c2 to 215, load = 215
// Expected exit code: 215
//
// Two 8-byte cells. Store 50 at c1, store 80 at c2, then
// overwrite c2 to 215. Load c2 -> 215 (the overwritten value).
// Uses `*ptr = literal` form. Distinct from s86_conc_overwrite_
// last (195), s82_conc_overwrite_first (175) and s78_conc_
// overwrite_last (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 50;
    *c2 = 80;
    *c2 = 215;
    r: i32 = *c2;          // 215
    free(c1);
    free(c2);
    return r;
}
