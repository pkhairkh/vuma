// s41_conc_three_cell_sum.vuma - three cells, sum = 190 (35 + 65 + 90)
// Expected exit code: 190
//
// Three independent 8-byte cells. Store 35/65/90 via `*ptr =
// literal`, load all, sum -> 190. Uses `*ptr = literal` form.
// Distinct from s38_conc_three_cell_sum (170) and s34_conc_three_
// cell_sum (180).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 35;
    *c2 = 65;
    *c3 = 90;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
