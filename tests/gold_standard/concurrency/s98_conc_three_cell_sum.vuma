// s98_conc_three_cell_sum.vuma — three cells, sum = 119 (50 + 33 + 36)
// Expected exit code: 119
//
// Three independent 8-byte cells. Store 50/33/36 via `*ptr =
// literal`, load all three, a + b + c -> 119. Uses `*ptr = literal`
// form. Distinct from s94_conc_three_cell_sum (77),
// s90_conc_three_cell_diff (10) and s86_conc_three_cell_diff (150).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 33;
    *c3 = 36;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 + v2 + v3; // 119
    free(c1);
    free(c2);
    free(c3);
    return r;
}
