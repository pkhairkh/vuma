// s88_conc_overwrite_first.vuma — overwrite c1 to 205, load = 205
// Expected exit code: 205
//
// Two 8-byte cells. Store 40 at c1, store 70 at c2, then
// overwrite c1 to 205. Load c1 -> 205 (the overwritten
// value). Uses `*ptr = literal` form. Distinct from s86_
// conc_overwrite_last (195), s82_conc_overwrite_first
// (175) and s78_conc_overwrite_last (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 40;
    *c2 = 70;
    *c1 = 205;
    r: i32 = *c1;          // 205
    free(c1);
    free(c2);
    return r;
}
