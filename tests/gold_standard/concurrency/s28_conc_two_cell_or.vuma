// s28_conc_two_cell_or.vuma — two cells, or = 51 (0x11 | 0x22 = 0x33)
// Expected exit code: 51
//
// Two independent 8-byte cells. Each gets a distinct literal at offset 0
// (17/34). Both loaded back and ORed. All operands loaded into typed
// locals before the OR (immediate-RHS bitwise drop bug workaround).
// Distinct from s26_conc_two_cell_and (and, 15) and s22_conc_two_cell_xor
// (xor, 75).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 17;            // 0x11
    *c2 = 34;            // 0x22
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 | v2;     // 0x33 = 51
    free(c1);
    free(c2);
    return s;
}
