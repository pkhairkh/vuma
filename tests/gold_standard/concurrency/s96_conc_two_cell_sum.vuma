// s96_conc_two_cell_sum.vuma — two cells, sum = 145 (75 + 70)
// Expected exit code: 145
//
// Two independent 8-byte cells. Store 75/70 via `*ptr = literal`,
// load both, a + b -> 145. Uses `*ptr = literal` form. Distinct from
// s94_conc_two_cell_sum (120), s90_conc_two_cell_diff (5) and
// s86_conc_two_cell_sum (210).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 75;
    *c2 = 70;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 145
    free(c1);
    free(c2);
    return s;
}
