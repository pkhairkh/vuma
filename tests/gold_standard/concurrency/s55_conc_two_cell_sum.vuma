// s55_conc_two_cell_sum.vuma — two cells, sum = 245 (115 + 130)
// Expected exit code: 245
//
// Two independent 8-byte cells. Store 115/130 via `*ptr = literal`,
// load both, sum -> 245. Uses `*ptr = literal` form. Distinct from
// s54_conc_two_cell_sum (230) and s53_conc_two_cell_diff (140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 115;
    *c2 = 130;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 245
    free(c1);
    free(c2);
    return s;
}
