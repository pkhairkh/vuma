// s52_conc_overwrite_first.vuma — store 50, overwrite to 220, load = 220
// Expected exit code: 220
//
// Single 8-byte cell. Store 50 via `*p = literal`, then overwrite
// the cell with 220. Load and return 220. Uses `*p = literal` form.
// Distinct from s50_conc_overwrite_first (230) and s46_conc_two_
// cell_sum (200).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 50;
    *c1 = 220;
    v: i32 = *c1;          // 220
    free(c1);
    return v;
}
