// s33_conc_three_cell_or.vuma — three cells, or = 0x10 | 0x20 | 0x40 = 0x70 = 112
// Expected exit code: 112
//
// Deterministic test in the concurrency category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_conc_three_cell_sum (sum) and s26_conc_three_cell_xor (xor, 105).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 16;               // 0x10
    *c2 = 32;               // 0x20
    *c3 = 64;               // 0x40
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 | v2 | v3;  // 0x70 = 112
    free(c1);
    free(c2);
    free(c3);
    return r;
}
