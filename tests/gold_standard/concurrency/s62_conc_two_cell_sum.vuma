// s62_conc_two_cell_sum.vuma — two cells, sum = 230 (145 + 85)
// Expected exit code: 230
// 
// Two independent 8-byte cells. Store 145/85 via `*ptr = literal`,
// load both, sum -> 230. Uses `*ptr = literal` form. Distinct from
// s51_conc_two_cell_sum (225), s58_conc_two_cell_diff (140) and s55_
// conc_two_cell_sum (245).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 145;
    *c2 = 85;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 230
    free(c1);
    free(c2);
    return s;
}
