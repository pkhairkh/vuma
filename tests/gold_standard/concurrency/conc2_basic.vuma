// conc2_basic.vuma — store 42, load, return
// Expected exit code: 42
//
// The smallest "atomic-like" roundtrip: store 42 into a freshly
// allocated cell, load it back, return. Single-threaded, but the
// pattern (publish-then-observe through shared memory) is the
// foundation of every higher-level concurrency primitive.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell = allocate(8);
    *cell = 42;
    val: i32 = *cell;
    free(cell);
    return val;
}
