// s90_conc_overwrite_last.vuma — overwrite c3 to 11, load = 11
// Expected exit code: 11
//
// Three independent 8-byte cells. Store 100 at c1, store 200 at c2,
// store 50 at c3, then overwrite c3 to 11. Load c3 -> 11 (the
// overwritten value). Uses `*ptr = literal` form. Distinct from
// s86_conc_overwrite_last (245), s82_conc_overwrite_last (242) and
// s78_conc_overwrite_last (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c3 = 11;
    v: i32 = *c3;          // 11
    free(c1);
    free(c2);
    free(c3);
    return v;
}
