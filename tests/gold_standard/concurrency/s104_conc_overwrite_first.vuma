// s104_conc_overwrite_first.vuma — overwrite c1 to 34, load = 34
// Expected exit code: 34
//
// Three independent 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c1 to 34. Load c1 -> 34 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_conc_overwrite_middle (1), s102_conc_three_cell_diff (198), s102_conc_two_cell_sum (22).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 34;
    v: i32 = *c1;          // 34
    free(c1);
    free(c2);
    free(c3);
    return v;
}
