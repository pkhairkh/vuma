// s42_conc_overwrite_middle.vuma — overwrite middle to 100, sum = 220 (40 + 100 + 80)
// Expected exit code: 220
//
// Three independent 8-byte cells. Store 40/60/80 via `*ptr = literal`,
// then overwrite the middle cell with 100. Load all three, sum -> 220.
// Uses `*ptr = literal` form. Distinct from s38_conc_overwrite_first
// (185) and s34_conc_overwrite_last (130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 60;
    *c3 = 80;
    *c2 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 220
    free(c1);
    free(c2);
    free(c3);
    return s;
}
