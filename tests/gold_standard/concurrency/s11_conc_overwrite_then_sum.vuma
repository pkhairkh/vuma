// s11_conc_overwrite_then_sum.vuma — c1 overwrite 50->80, c2=30, sum = 110
// Expected exit code: 110
//
// Two independent 8-byte cells. c1 gets 50 then overwritten with 80
// (last write wins). c2 gets 30. Both loaded and summed -> 80 + 30 = 110.
// Distinct from s10_conc_overwrite_one (single cell overwrite) and
// s7_conc_overwrite_first (overwrite first of three).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 50;
    *c1 = 80;
    *c2 = 30;
    v1: i32 = *c1;      // 80
    v2: i32 = *c2;      // 30
    s: i32 = v1 + v2;   // 110
    free(c1);
    free(c2);
    return s;
}
