// s49_conc_overwrite_first.vuma — overwrite first to 100, sum = 190 (100 + 40 + 50)
// Expected exit code: 190
//
// Three independent 8-byte cells. Store 30/40/50 via `*ptr =
// literal`, then overwrite the first cell with 100. Load all three,
// sum -> 190. Uses `*ptr = literal` form. Distinct from s46_conc_
// overwrite_last (180, last overwrite) and s42_conc_overwrite_middle
// (220, middle overwrite).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c3 = 50;
    *c1 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
