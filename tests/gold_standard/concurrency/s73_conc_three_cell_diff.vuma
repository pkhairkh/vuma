// s73_conc_three_cell_diff.vuma — three cells, diff = 131 (200 - 47 - 22)
// Expected exit code: 131
//
// Three independent 8-byte cells. Store 200/47/22 via `*ptr =
// literal`, load all three, diff -> 200 - 47 - 22 = 131. Uses
// `*ptr = literal` form. Distinct from s70_conc_three_cell_diff
// (160), s69_conc_three_cell_xor (95) and s66_conc_three_cell_
// sum (240).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 47;
    *c3 = 22;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 153
    d: i32 = t - v3;       // 131
    free(c1);
    free(c2);
    free(c3);
    return d;
}
