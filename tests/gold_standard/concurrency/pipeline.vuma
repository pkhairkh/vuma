// Pipeline — Pipe-Fork-Exec Pipeline with Signal Handling
//
// This program creates a mini-shell pipeline:
//
//   stdin ──▶ [SHA256d filter] ──pipe1──▶ [hex encoder] ──pipe2──▶ stdout
//
// The parent creates two pipes, forks two children, and reads the final
// hex-encoded SHA256d digest from pipe2.
//
//   Child 1 (SHA256d filter): reads stdin, computes SHA256d, writes 32-byte digest to pipe1
//   Child 2 (hex encoder): reads 32 bytes from pipe1, converts to 64 hex chars + newline, writes to pipe2
//   Parent: reads hex output from pipe2, writes to stdout, waits for children,
//           checks atomic SIGCHLD flag, exits with first hex byte as exit code
//
// VUMA Key Concepts:
//   - Full SHA256d (rotr32, ch, maj, sigma, schedule, compression, padding, double-hash)
//   - Atomic flag for SIGCHLD handler (AtomicStore / AtomicLoad)
//   - Unix syscall FFI: pipe, fork, dup2, close, read, write, waitpid, sigaction
//   - Byte-to-hex conversion with lookup table
//   - Error checking on all syscalls; every allocate paired with free
//   - u32 arithmetic masked with & 4294967295; no bitwise NOT (use XOR)

// ===========================================================================
// External C function declarations (Linux syscalls)
// ===========================================================================

extern "C" {
    fn pipe(pipefd: Address) -> i64;           // create pipe; pipefd = int[2]
    fn fork() -> i64;                          // create child process
    fn dup2(oldfd: i64, newfd: i64) -> i64;   // duplicate file descriptor
    fn close(fd: i64) -> i64;                  // close file descriptor
    fn read(fd: i64, buf: Address, count: i64) -> i64;
    fn write(fd: i64, buf: Address, count: i64) -> i64;
    fn waitpid(pid: i64, status: Address, options: i64) -> i64;
    fn exit(code: i64);
    fn sigaction(signum: i64, act: Address, oldact: Address) -> i64;
    fn getpid() -> i64;
}

// ===========================================================================
// Atomic flag for SIGCHLD handler
// ===========================================================================
// Handler sets this to 1 via AtomicStore when a child exits.
// Parent checks via AtomicLoad after waitpid.

child_exited: Address = allocate(8);

fn sigchld_handler(signum: i64) {
    AtomicStore(1, child_exited);
}

// ===========================================================================
// Helper: little-endian i32 read/write (for pipefd arrays)
// ===========================================================================

fn write_i32_le(buf: Address, offset: u64, val: i32) {
    *(buf + offset)     = (val as u64) & 255;
    *(buf + offset + 1) = ((val as u64) >> 8) & 255;
    *(buf + offset + 2) = ((val as u64) >> 16) & 255;
    *(buf + offset + 3) = ((val as u64) >> 24) & 255;
}

fn read_i32_le(buf: Address, offset: u64) -> i32 {
    b0: u64 = *(buf + offset);
    b1: u64 = *(buf + offset + 1);
    b2: u64 = *(buf + offset + 2);
    b3: u64 = *(buf + offset + 3);
    return ((b3 << 24) | (b2 << 16) | (b1 << 8) | b0) as i32;
}

// ===========================================================================
// SHA-256 Implementation (from sha256d.vuma)
// ===========================================================================
// Full FIPS 180-4 implementation. All u32 adds masked with & 4294967295.

// ── u32 right-rotate (no built-in rotate; compose from shifts) ────────

fn rotr32(x: u32, n: u32) -> u32 {
    return ((x >> n) | (x << (32 - n))) & 4294967295;
}

// ── SHA-256 logical functions (FIPS 180-4 §4.1.2) ─────────────────────

fn ch(x: u32, y: u32, z: u32) -> u32 {
    // Constant-time: (x & y) ^ ((x ^ 0xFFFFFFFF) & z); no bitwise NOT
    return (x & y) ^ ((x ^ 4294967295) & z);
}

fn maj(a: u32, b: u32, c: u32) -> u32 {
    return (a & b) ^ (a & c) ^ (b & c);
}

fn big_sigma0(x: u32) -> u32 {
    return rotr32(x, 2) ^ rotr32(x, 13) ^ rotr32(x, 22);
}

fn big_sigma1(x: u32) -> u32 {
    return rotr32(x, 6) ^ rotr32(x, 11) ^ rotr32(x, 25);
}

fn small_sigma0(x: u32) -> u32 {
    return (rotr32(x, 7) ^ rotr32(x, 18) ^ (x >> 3)) & 4294967295;
}

fn small_sigma1(x: u32) -> u32 {
    return (rotr32(x, 17) ^ rotr32(x, 19) ^ (x >> 10)) & 4294967295;
}

// ── Read/write u32 big-endian (FIPS 180-4 byte order) ─────────────────

fn read_u32_be(buf: Address, offset: u64) -> u32 {
    b0: u32 = *(buf + offset);
    b1: u32 = *(buf + offset + 1);
    b2: u32 = *(buf + offset + 2);
    b3: u32 = *(buf + offset + 3);
    return ((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) & 4294967295;
}

fn write_u32_be(buf: Address, offset: u64, val: u32) {
    *(buf + offset)     = (val >> 24) & 255;
    *(buf + offset + 1) = (val >> 16) & 255;
    *(buf + offset + 2) = (val >> 8) & 255;
    *(buf + offset + 3) = val & 255;
}

// ── W schedule array helpers (stride = 4 bytes) ───────────────────────

fn w_store(w_base: Address, idx: u64, val: u32) {
    write_u32_be(w_base, idx * 4, val);
}

fn w_load(w_base: Address, idx: u64) -> u32 {
    return read_u32_be(w_base, idx * 4);
}

// ── Initialize H[0..7] (FIPS 180-4 §5.3.3) ───────────────────────────

fn sha256_init_state(state: Address) {
    write_u32_be(state, 0,  1779033703);   // 0x6a09e667
    write_u32_be(state, 4,  3144134277);   // 0xbb67ae85
    write_u32_be(state, 8,  1013904242);   // 0x3c6ef372
    write_u32_be(state, 12, 2773480762);   // 0xa54ff53a
    write_u32_be(state, 16, 1359893119);   // 0x510e527f
    write_u32_be(state, 20, 2600822924);   // 0x9b05688c
    write_u32_be(state, 24, 528734635);    // 0x1f83d9ab
    write_u32_be(state, 28, 1541459225);   // 0x5be0cd19
}

// ── Initialize K[0..63] (FIPS 180-4 §4.2.2) ──────────────────────────

fn sha256_init_k(k: Address) {
    write_u32_be(k, 0,   1116352408);  write_u32_be(k, 4,   1899447441);
    write_u32_be(k, 8,   3049323471);  write_u32_be(k, 12,  3921009573);
    write_u32_be(k, 16,  961987163);   write_u32_be(k, 20,  1508970993);
    write_u32_be(k, 24,  2453635748);  write_u32_be(k, 28,  2870763221);
    write_u32_be(k, 32,  3624381080);  write_u32_be(k, 36,  310598401);
    write_u32_be(k, 40,  607225278);   write_u32_be(k, 44,  1426881987);
    write_u32_be(k, 48,  1925078388);  write_u32_be(k, 52,  2162078206);
    write_u32_be(k, 56,  2614888103);  write_u32_be(k, 60,  3248222580);
    write_u32_be(k, 64,  3835390401);  write_u32_be(k, 68,  4022224774);
    write_u32_be(k, 72,  264347078);   write_u32_be(k, 76,  604807628);
    write_u32_be(k, 80,  770255983);   write_u32_be(k, 84,  1249150122);
    write_u32_be(k, 88,  1555081692);  write_u32_be(k, 92,  1996064986);
    write_u32_be(k, 96,  2554220882);  write_u32_be(k, 100, 2821834349);
    write_u32_be(k, 104, 2952996808);  write_u32_be(k, 108, 3210313671);
    write_u32_be(k, 112, 3336571891);  write_u32_be(k, 116, 3584528711);
    write_u32_be(k, 120, 113926993);   write_u32_be(k, 124, 338241895);
    write_u32_be(k, 128, 666307205);   write_u32_be(k, 132, 773529912);
    write_u32_be(k, 136, 1294757372);  write_u32_be(k, 140, 1396182291);
    write_u32_be(k, 144, 1695183700);  write_u32_be(k, 148, 1986661051);
    write_u32_be(k, 152, 2177026350);  write_u32_be(k, 156, 2456956037);
    write_u32_be(k, 160, 2730485921);  write_u32_be(k, 164, 2820302411);
    write_u32_be(k, 168, 3259730800);  write_u32_be(k, 172, 3345764771);
    write_u32_be(k, 176, 3516065817);  write_u32_be(k, 180, 3600352804);
    write_u32_be(k, 184, 4094571909);  write_u32_be(k, 188, 275423344);
    write_u32_be(k, 192, 430227734);   write_u32_be(k, 196, 506948616);
    write_u32_be(k, 200, 659060556);   write_u32_be(k, 204, 883997877);
    write_u32_be(k, 208, 958139571);   write_u32_be(k, 212, 1322822218);
    write_u32_be(k, 216, 1537002063);  write_u32_be(k, 220, 1747873779);
    write_u32_be(k, 224, 1955562222);  write_u32_be(k, 228, 2024104815);
    write_u32_be(k, 232, 2227730452);  write_u32_be(k, 236, 2361852424);
    write_u32_be(k, 240, 2428436474);  write_u32_be(k, 244, 2756734187);
    write_u32_be(k, 248, 3204031479);  write_u32_be(k, 252, 3329325298);
}

// ── SHA-256 compression: process one 512-bit block (FIPS 180-4 §6.2.2) ─

fn sha256_transform(state: Address, k: Address, w: Address, block: Address) {
    // Build message schedule W[0..63]
    i: u64 = 0;
    for i in 0..16 {
        val: u32 = read_u32_be(block, i * 4);
        w_store(w, i, val);
    }
    for i in 16..64 {
        w15: u32 = w_load(w, i - 15);
        w2: u32  = w_load(w, i - 2);
        w7: u32  = w_load(w, i - 7);
        w16: u32 = w_load(w, i - 16);
        val: u32 = (small_sigma1(w2) + w7 + small_sigma0(w15) + w16) & 4294967295;
        w_store(w, i, val);
    }

    // Initialize working variables from current state
    a: u32 = read_u32_be(state, 0);
    b: u32 = read_u32_be(state, 4);
    c: u32 = read_u32_be(state, 8);
    d: u32 = read_u32_be(state, 12);
    e: u32 = read_u32_be(state, 16);
    f: u32 = read_u32_be(state, 20);
    g: u32 = read_u32_be(state, 24);
    h: u32 = read_u32_be(state, 28);

    // 64-round compression — all u32 adds masked
    for i in 0..64 {
        ki: u32 = read_u32_be(k, i * 4);
        wi: u32 = w_load(w, i);
        t1: u32 = (h + big_sigma1(e) + ch(e, f, g) + ki + wi) & 4294967295;
        t2: u32 = (big_sigma0(a) + maj(a, b, c)) & 4294967295;
        h = g;
        g = f;
        f = e;
        e = (d + t1) & 4294967295;
        d = c;
        c = b;
        b = a;
        a = (t1 + t2) & 4294967295;
    }

    // Add compressed chunk to hash state
    write_u32_be(state, 0,  (read_u32_be(state, 0)  + a) & 4294967295);
    write_u32_be(state, 4,  (read_u32_be(state, 4)  + b) & 4294967295);
    write_u32_be(state, 8,  (read_u32_be(state, 8)  + c) & 4294967295);
    write_u32_be(state, 12, (read_u32_be(state, 12) + d) & 4294967295);
    write_u32_be(state, 16, (read_u32_be(state, 16) + e) & 4294967295);
    write_u32_be(state, 20, (read_u32_be(state, 20) + f) & 4294967295);
    write_u32_be(state, 24, (read_u32_be(state, 24) + g) & 4294967295);
    write_u32_be(state, 28, (read_u32_be(state, 28) + h) & 4294967295);
}

// ── Pad message into 64-byte block (up to 55-byte messages) ───────────

fn sha256_pad_block(block: Address, msg: Address, msg_len: u64) {
    i: u64 = 0;
    for i in 0..msg_len {
        *(block + i) = *(msg + i);
    }
    *(block + msg_len) = 128;  // append '1' bit (0x80)
    for i in msg_len + 1..56 {
        *(block + i) = 0;
    }
    // Append 64-bit big-endian message length in bits
    bit_len: u64 = msg_len * 8;
    *(block + 56) = (bit_len >> 56) & 255;
    *(block + 57) = (bit_len >> 48) & 255;
    *(block + 58) = (bit_len >> 40) & 255;
    *(block + 59) = (bit_len >> 32) & 255;
    *(block + 60) = (bit_len >> 24) & 255;
    *(block + 61) = (bit_len >> 16) & 255;
    *(block + 62) = (bit_len >> 8) & 255;
    *(block + 63) = bit_len & 255;
}

// ── Copy 32 bytes ─────────────────────────────────────────────────────

fn copy32(dst: Address, src: Address) {
    i: u64 = 0;
    for i in 0..32 {
        *(dst + i) = *(src + i);
    }
}

// ── SHA256d: SHA-256(SHA-256(message)) ────────────────────────────────

fn sha256d(msg: Address, msg_len: u64, out: Address) {
    state = allocate(32);
    k = allocate(256);
    w = allocate(256);
    block = allocate(64);
    inner = allocate(32);

    sha256_init_k(k);

    // Inner hash: SHA-256(message)
    sha256_init_state(state);
    sha256_pad_block(block, msg, msg_len);
    sha256_transform(state, k, w, block);
    copy32(inner, state);

    // Outer hash: SHA-256(inner_hash)
    sha256_init_state(state);
    sha256_pad_block(block, inner, 32);
    sha256_transform(state, k, w, block);
    copy32(out, state);

    free(state);
    free(k);
    free(w);
    free(block);
    free(inner);
}

// ===========================================================================
// Hex Encoding — byte-to-hex using a 16-byte lookup table
// ===========================================================================

fn init_hex_table(table: Address) {
    *(table + 0)  = 48;  // '0'    *(table + 1)  = 49;  // '1'
    *(table + 2)  = 50;  // '2'    *(table + 3)  = 51;  // '3'
    *(table + 4)  = 52;  // '4'    *(table + 5)  = 53;  // '5'
    *(table + 6)  = 54;  // '6'    *(table + 7)  = 55;  // '7'
    *(table + 8)  = 56;  // '8'    *(table + 9)  = 57;  // '9'
    *(table + 10) = 97;  // 'a'    *(table + 11) = 98;  // 'b'
    *(table + 12) = 99;  // 'c'    *(table + 13) = 100; // 'd'
    *(table + 14) = 101; // 'e'    *(table + 15) = 102; // 'f'
}

// Convert 32 bytes → 64 hex characters (high nibble first per byte)

fn hex_encode(input: Address, output: Address) {
    hex_table = allocate(16);
    init_hex_table(hex_table);

    i: u64 = 0;
    for i in 0..32 {
        byte: u64 = *(input + i);
        hi: u64 = byte >> 4;
        lo: u64 = byte & 15;
        *(output + i * 2)     = *(hex_table + hi);
        *(output + i * 2 + 1) = *(hex_table + lo);
    }

    free(hex_table);
}

// ===========================================================================
// SIGCHLD handler installation via sigaction
// ===========================================================================
// Linux struct sigaction (64-bit):
//   Offset 0:   8 bytes — sa_handler (function pointer)
//   Offset 8:   8 bytes — sa_flags
//   Offset 16: 128 bytes — sa_mask (1024-bit signal set)
//
// We set sa_flags = SA_NOCLDSTOP (1) to only be notified on child exit,
// not stop/continue. sa_mask = all zeros (don't block signals in handler).

fn install_sigchld_handler() -> i64 {
    act = allocate(144);
    oldact = allocate(144);

    // Zero-initialize both structs
    i: u64 = 0;
    for i in 0..144 {
        *(act + i) = 0;
        *(oldact + i) = 0;
    }

    // Store sa_handler as 8-byte address at offset 0 (little-endian)
    handler_addr: u64 = @sigchld_handler;
    *(act + 0) = handler_addr & 255;
    *(act + 1) = (handler_addr >> 8) & 255;
    *(act + 2) = (handler_addr >> 16) & 255;
    *(act + 3) = (handler_addr >> 24) & 255;
    *(act + 4) = (handler_addr >> 32) & 255;
    *(act + 5) = (handler_addr >> 40) & 255;
    *(act + 6) = (handler_addr >> 48) & 255;
    *(act + 7) = (handler_addr >> 56) & 255;

    // sa_flags = SA_NOCLDSTOP = 1 at offset 8
    write_i32_le(act, 8, 1);

    // SIGCHLD = 17 on Linux x86-64
    ret: i64 = sigaction(17, act, oldact);

    free(act);
    free(oldact);
    return ret;
}

// ===========================================================================
// Child 1: SHA256d Filter
// ===========================================================================
// Reads up to 4096 bytes from stdin, computes SHA256d, writes 32-byte
// digest to the pipe1 write end.

fn child_sha256d_filter(pipe1_write: i64) {
    inbuf = allocate(4096);
    n: i64 = read(0, inbuf, 4096);
    if n < 0 {
        close(pipe1_write);
        free(inbuf);
        exit(2);
    }

    digest = allocate(32);
    sha256d(inbuf, n as u64, digest);

    written: i64 = write(pipe1_write, digest, 32);
    if written < 0 {
        close(pipe1_write);
        free(inbuf);
        free(digest);
        exit(3);
    }

    close(pipe1_write);
    free(inbuf);
    free(digest);
    exit(0);
}

// ===========================================================================
// Child 2: Hex Encoder
// ===========================================================================
// Reads 32 bytes from pipe1, converts to 64 hex chars + newline,
// writes 65 bytes to pipe2.

fn child_hex_encoder(pipe1_read: i64, pipe2_write: i64) {
    digest = allocate(32);
    n: i64 = read(pipe1_read, digest, 32);
    if n < 0 {
        close(pipe1_read);
        close(pipe2_write);
        free(digest);
        exit(4);
    }

    // Handle partial reads: zero-fill the remainder
    if n < 32 {
        i: i64 = n;
        while i < 32 {
            *(digest + i as u64) = 0;
            i += 1;
        }
    }

    // Convert 32 bytes → 64 hex chars
    hex_out = allocate(65);   // 64 hex + '\n'
    hex_encode(digest, hex_out);
    *(hex_out + 64) = 10;    // newline

    written: i64 = write(pipe2_write, hex_out, 65);
    if written < 0 {
        close(pipe1_read);
        close(pipe2_write);
        free(digest);
        free(hex_out);
        exit(5);
    }

    close(pipe1_read);
    close(pipe2_write);
    free(digest);
    free(hex_out);
    exit(0);
}

// ===========================================================================
// Main entry point
// ===========================================================================
// Pipeline: stdin → child1(SHA256d) → pipe1 → child2(hex) → pipe2 → parent → stdout

fn main() -> i32 {
    // ── Create pipe1 (child1 → child2) ────────────────────────────────
    pipefd1 = allocate(8);   // int[2]
    ret1: i64 = pipe(pipefd1);
    if ret1 < 0 {
        free(pipefd1);
        free(child_exited);
        return 1;
    }
    pipe1_read: i64  = read_i32_le(pipefd1, 0) as i64;
    pipe1_write: i64 = read_i32_le(pipefd1, 4) as i64;

    // ── Create pipe2 (child2 → parent) ────────────────────────────────
    pipefd2 = allocate(8);
    ret2: i64 = pipe(pipefd2);
    if ret2 < 0 {
        close(pipe1_read);
        close(pipe1_write);
        free(pipefd1);
        free(pipefd2);
        free(child_exited);
        return 1;
    }
    pipe2_read: i64  = read_i32_le(pipefd2, 0) as i64;
    pipe2_write: i64 = read_i32_le(pipefd2, 4) as i64;

    // ── Install SIGCHLD handler ───────────────────────────────────────
    AtomicStore(0, child_exited);
    sa_ret: i64 = install_sigchld_handler();
    if sa_ret < 0 {
        close(pipe1_read);
        close(pipe1_write);
        close(pipe2_read);
        close(pipe2_write);
        free(pipefd1);
        free(pipefd2);
        free(child_exited);
        return 1;
    }

    // ── Fork child 1 (SHA256d filter) ────────────────────────────────
    pid1: i64 = fork();
    if pid1 < 0 {
        close(pipe1_read);
        close(pipe1_write);
        close(pipe2_read);
        close(pipe2_write);
        free(pipefd1);
        free(pipefd2);
        free(child_exited);
        return 1;
    }
    if pid1 == 0 {
        // Child 1: close unused pipe ends, free parent copies
        close(pipe1_read);
        close(pipe2_read);
        close(pipe2_write);
        free(pipefd1);
        free(pipefd2);
        free(child_exited);
        // Reads from stdin (fd 0), writes SHA256d digest to pipe1
        child_sha256d_filter(pipe1_write);
        return 0;  // unreachable — child_sha256d_filter calls exit()
    }

    // ── Fork child 2 (hex encoder) ───────────────────────────────────
    pid2: i64 = fork();
    if pid2 < 0 {
        close(pipe1_read);
        close(pipe1_write);
        close(pipe2_read);
        close(pipe2_write);
        free(pipefd1);
        free(pipefd2);
        free(child_exited);
        return 1;
    }
    if pid2 == 0 {
        // Child 2: close unused pipe ends, free parent copies
        close(pipe1_write);
        close(pipe2_read);
        free(pipefd1);
        free(pipefd2);
        free(child_exited);
        // Read from pipe1, write hex to pipe2
        child_hex_encoder(pipe1_read, pipe2_write);
        return 0;  // unreachable — child_hex_encoder calls exit()
    }

    // ── Parent: read hex output from pipe2 ────────────────────────────
    // Close ends the parent doesn't use. Closing pipe1 write is critical
    // so child2 sees EOF after child1 finishes writing.
    close(pipe1_write);
    close(pipe1_read);
    close(pipe2_write);

    outbuf = allocate(128);
    n: i64 = read(pipe2_read, outbuf, 128);
    if n < 0 {
        n = 0;
    }

    // Write hex output to stdout
    if n > 0 {
        write(1, outbuf, n);
    }

    close(pipe2_read);

    // ── Wait for both children ────────────────────────────────────────
    status_buf = allocate(4);
    waitpid(pid1, status_buf, 0);
    waitpid(pid2, status_buf, 0);

    // ── Check atomic SIGCHLD flag ─────────────────────────────────────
    // Handler should have set this ≥ 1. Validates atomic signal mechanism.
    exited_flag: u64 = AtomicLoad(child_exited);

    // ── Compute exit code from first hex byte ─────────────────────────
    exit_code: i32 = 0;
    if n > 0 {
        exit_code = *(outbuf + 0) as i32;
    }

    // ── Clean up all memory ───────────────────────────────────────────
    free(outbuf);
    free(status_buf);
    free(pipefd1);
    free(pipefd2);
    free(child_exited);

    return exit_code;
}
