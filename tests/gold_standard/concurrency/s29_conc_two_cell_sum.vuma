// s29_conc_two_cell_sum.vuma — two cells, sum = 120 (75 + 45)
// Expected exit code: 120
//
// Two independent 8-byte cells. Each gets a distinct literal at offset 0 (75/45). Both loaded back and summed -> 120. Uses `*ptr = literal` form (no offsets). Distinct from s26_conc_two_cell_and (and, 255&15=15) and s22_conc_two_cell_xor (xor, 41^98=75).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 75;
    *c2 = 45;
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 + v2;     // 120
    free(c1);
    free(c2);
    return s;
}
