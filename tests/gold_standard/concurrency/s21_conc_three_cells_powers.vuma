// s21_conc_three_cells_powers.vuma — three cells, powers of 2, sum = 21 (1 + 4 + 16)
// Expected exit code: 21
//
// Three independent 8-byte cells. Each gets a distinct power-of-2 literal
// (1/4/16). All three loaded back and summed. Uses `*ptr = literal` form
// (no offsets). Distinct from s18_conc_three_cells_prime (13/17/19 = 49)
// and s14_conc_three_cells_even (20/40/60 = 120).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 1;
    *c2 = 4;
    *c3 = 16;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
