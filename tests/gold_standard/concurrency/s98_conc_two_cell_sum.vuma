// s98_conc_two_cell_sum.vuma — two cells, sum = 117 (80 + 37)
// Expected exit code: 117
//
// Two independent 8-byte cells. Store 80/37 via `*ptr = literal`,
// load both, a + b -> 117. Uses `*ptr = literal` form. Distinct
// from s94_conc_two_cell_sum (120), s90_conc_two_cell_diff (5) and
// s86_conc_two_cell_sum (210).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 37;
    v1: i32 = *c1;
    v2: i32 = *c2;
    r: i32 = v1 + v2;      // 117
    free(c1);
    free(c2);
    return r;
}
