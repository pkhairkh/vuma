// s103_conc_overwrite_first.vuma — overwrite c1 to 2, load = 2
// Expected exit code: 2
//
// Three independent 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c1 to 2. Load c1 -> 2 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_conc_overwrite_first (27), s100_conc_overwrite_first (47), s94_conc_overwrite_first (49).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 2;
    v: i32 = *c1;          // 2
    free(c1);
    free(c2);
    free(c3);
    return v;
}
