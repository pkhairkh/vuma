// s63_conc_overwrite_last.vuma — overwrite last to 110, sum = 140 (10 + 20 + 110)
// Expected exit code: 140
//
// Three independent 8-byte cells. Store 10/20/30 via `*ptr =
// literal`, then overwrite the last cell with 110. Load all three,
// sum -> 140. Uses `*ptr = literal` form. Distinct from s51_conc_
// overwrite_last (200), s58_conc_overwrite_middle (200) and s55_
// conc_two_cell_sum (225).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c3 = 110;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 140
    free(c1);
    free(c2);
    free(c3);
    return s;
}
