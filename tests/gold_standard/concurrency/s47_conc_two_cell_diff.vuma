// s47_conc_two_cell_diff.vuma — two cells, diff = 90 (175 - 85)
// Expected exit code: 90
//
// Two independent 8-byte cells. Store 175/85 via `*ptr = literal`,
// load both, subtract -> 90. Uses `*ptr = literal` form. Distinct
// from s46_conc_two_cell_sum (200) and s42_conc_two_cell_diff (150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 175;
    *c2 = 85;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 90
    free(c1);
    free(c2);
    return d;
}
