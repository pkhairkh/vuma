// s54_conc_overwrite_middle.vuma — overwrite mid to 120, sum = 220 (30+120+70)
// Expected exit code: 220
//
// Three independent 8-byte cells. Store 30/50/70 via `*ptr =
// literal`, then overwrite the middle cell with 120. Load all
// three, sum -> 220. Uses `*ptr = literal` form. Distinct from
// s50_conc_overwrite_first (230) and s49_conc_overwrite_first (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 50;
    *c3 = 70;
    *c2 = 120;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 220
    free(c1);
    free(c2);
    free(c3);
    return s;
}
