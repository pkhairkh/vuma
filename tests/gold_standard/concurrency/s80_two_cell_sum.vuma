// s80_conc_two_cell_sum.vuma — two cells, sum = 16 (8 + 8)
// Expected exit code: 16
//
// Two independent 8-byte cells. Store 8/8 via `*ptr = literal`,
// load both, sum -> 16. Uses `*ptr = literal` form. Distinct from
// s78_conc_two_cell_sum (2), s74_conc_two_cell_sum (105) and
// s73_conc_two_cell_sum (111).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 8;
    *c2 = 8;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 16
    free(c1);
    free(c2);
    return s;
}
