// s97_conc_three_cell_diff.vuma — three cells, diff = 35 (70 - 20 - 15)
// Expected exit code: 35
//
// Three independent 8-byte cells. Store 70/20/15 via `*ptr
// = literal`, load all, a - b - c -> 35. Uses `*ptr =
// literal` form.
// Distinct from s94_conc_overwrite_first (49), s90_conc_three_cell_diff (10), s86_conc_three_cell_diff (150).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 70;
    *c2 = 20;
    *c3 = 15;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 35
    free(c1);
    free(c2);
    free(c3);
    return r;
}
