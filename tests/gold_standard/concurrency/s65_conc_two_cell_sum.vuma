// s65_conc_two_cell_sum.vuma — two cells, sum = 240 (140 + 100)
// Expected exit code: 240
//
// Two independent 8-byte cells. Store 140/100 via `*ptr = literal`,
// load both, sum -> 240. Uses `*ptr = literal` form. Distinct from
// s51_conc_two_cell_sum (225), s58_conc_two_cell_diff (140) and s62_
// conc_two_cell_sum (230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 140;
    *c2 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 240
    free(c1);
    free(c2);
    return s;
}
