// s51_conc_three_cell_sum.vuma — three cells, sum = 205 (60 + 70 + 75)
// Expected exit code: 205
//
// Three independent 8-byte cells. Store 60/70/75 via `*ptr =
// literal`, load all three, sum -> 205. Uses `*ptr = literal` form.
// Distinct from s50_conc_three_cell_diff (120) and s47_conc_three_
// cell_or (224).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 70;
    *c3 = 75;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 205
    free(c1);
    free(c2);
    free(c3);
    return s;
}
