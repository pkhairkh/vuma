// Channel Demo - MPSC channel for multi-producer single-consumer messaging
// Demonstrates: channel creation, sender cloning, message passing, select
//
// Channels are the preferred communication primitive in safe concurrent
// programming. VUMA's MPSC (Multi-Producer Single-Consumer) channel
// provides verified message passing with these guarantees:
//
//   1. No data race: multiple senders write to different slots
//   2. No message loss: every sent message is received exactly once
//   3. No use-after-free: channel owns message memory until received
//   4. Backpressure: sender blocks when channel is full (bounded)
//   5. Cleanup: all channel memory freed when sender and receiver drop
//
// VUMA Key Concepts:
//   - Channel<T> with bounded capacity
//   - Sender<T> can be cloned for multiple producers
//   - Receiver<T> is single-owner (move semantics)
//   - IVE proves no data races between concurrent senders
//   - IVE proves no message corruption or loss
//   - select() for multiplexing across multiple channels

struct Message {
    sender_id: u64,   // 8 bytes - which producer sent this
    payload: u64,     // 8 bytes - message data
    timestamp: u64,   // 8 bytes - send time
}

struct Channel<T> {
    buffer: Address,       // Ring buffer for messages
    capacity: u64,        // Maximum pending messages
    head: AtomicU64,      // Producer write position
    tail: AtomicU64,      // Consumer read position
    sender_count: AtomicU64, // Active sender count
    closed: AtomicU64,    // 1 = all senders dropped
}

struct Sender<T> {
    channel: Address,     // Shared channel reference
    id: u64,              // Unique sender identifier
}

struct Receiver<T> {
    channel: Address,     // Shared channel reference
}

fn channel_new(capacity: u64) -> (Address, Address) {
    // Create a bounded MPSC channel, returning (sender, receiver)
    //
    // IVE verifies:
    //   - Buffer allocation matches capacity * sizeof(Message)
    //   - Atomic counters are initialized correctly
    //   - Sender and receiver point to the same channel allocation
    msg_size = 24;  // sizeof(Message)
    buf = allocate(capacity * msg_size);
    chan = allocate(48);  // sizeof(Channel)

    *chan = Channel {
        buffer: buf,
        capacity,
        head: AtomicU64::new(0),
        tail: AtomicU64::new(0),
        sender_count: AtomicU64::new(1),  // One sender initially
        closed: AtomicU64::new(0),
    };

    sender = allocate(16);  // sizeof(Sender)
    *sender = Sender { channel: chan, id: 0 };

    receiver = allocate(8);  // sizeof(Receiver)
    *receiver = Receiver { channel: chan };

    return (sender, receiver);
}

fn sender_clone(sender: Address) -> Address {
    // Clone a sender for use in another producer thread
    //
    // IVE verifies: sender_count increment is atomic (no data race)
    // IVE verifies: new sender points to same live channel
    new_sender = allocate(16);
    chan = (*sender).channel;
    *new_sender = Sender {
        channel: chan,
        id: (*chan).sender_count.fetch_add(1, Acquire),
    };
    return new_sender;
}

fn sender_send(sender: Address, payload: u64, timestamp: u64) -> bool {
    // Send a message through the channel (blocking if full)
    //
    // IVE verifies concurrent safety:
    //   - head.load(Acquire) sees values from other senders
    //   - Slot computation stays within buffer bounds
    //   - Message write completes before head.store(Release)
    //   - Multiple senders write to different slots (no overlap)
    chan = (*sender).channel;

    // Loop until we find a free slot (bounded backpressure)
    loop {
        head = (*chan).head.load(Acquire);
        tail = (*chan).tail.load(Acquire);

        // Check if channel is full
        if (head - tail) >= (*chan).capacity {
            // Channel full — would block in real runtime
            // For demo, spin-wait (IVE verifies: no deadlock)
            continue;
        }

        // Try to claim this slot with CAS
        // IVE verifies: CAS ensures only one sender claims each slot
        if (*chan).head.compare_exchange(head, head + 1, Acquire, Relaxed) {
            break;  // We claimed slot at `head`
        }
        // Another sender claimed it — retry
    }

    // Write message to the claimed slot
    // IVE verifies: slot is within buffer allocation
    slot = (*chan).buffer + (head % (*chan).capacity) * 24;
    *slot = Message {
        sender_id: (*sender).id,
        payload,
        timestamp,
    };

    // Publish with Release ordering
    // IVE verifies: write is visible before index advance
    (*chan).head.store(head + 1, Release);
    return true;
}

fn receiver_recv(receiver: Address) -> Option<Address> {
    // Receive a message from the channel
    //
    // IVE verifies:
    //   - tail.load(Acquire) sees producer's Release store
    //   - Slot read is within buffer bounds
    //   - Returned message pointer is a live allocation
    //   - No data race: only one consumer reads each slot
    chan = (*receiver).channel;

    head = (*chan).head.load(Acquire);
    tail = (*chan).tail.load(Acquire);

    // Check if channel is empty
    if tail == head {
        // Check if all senders have dropped
        if (*chan).closed.load(Acquire) == 1 {
            return None;  // Channel closed, no more messages
        }
        return None;  // Empty but still open
    }

    // Read the message from the slot
    // IVE verifies: slot is within buffer, message is valid
    slot = (*chan).buffer + (tail % (*chan).capacity) * 24;
    msg = allocate(24);  // Copy message out of ring buffer
    *msg = *slot;        // IVE verifies: read from live allocation

    // Advance tail with Release ordering
    (*chan).tail.store(tail + 1, Release);
    return Some(msg);
}

fn sender_drop(sender: Address) {
    // Drop a sender — decrement sender count
    // IVE verifies: atomic decrement prevents data race
    chan = (*sender).channel;
    count = (*chan).sender_count.fetch_sub(1, Release);
    if count == 1 {
        // Last sender dropped — close channel
        // IVE verifies: closed.store is after sender_count store
        (*chan).closed.store(1, Release);
    }
    free(sender);
}

fn channel_destroy(receiver: Address) {
    // Destroy the channel after all messages are consumed
    // IVE verifies: all allocations freed (Cleanup invariant)
    // IVE verifies: no senders remain (closed == 1)
    chan = (*receiver).channel;
    free((*chan).buffer);   // Free ring buffer
    free(chan);             // Free channel struct
    free(receiver);         // Free receiver struct
}

fn producer_task(sender: Address, start: u64, count: u64) {
    // Producer thread: send `count` messages starting from `start`
    // IVE verifies: concurrent sender_clone'd senders don't race
    i: u64 = 0;
    while i < count {
        value = start + i;
        sender_send(sender, value, i);
        delay_ms(10);  // Simulate work
        i = i + 1;
    }
    sender_drop(sender);
}

fn main() -> i32 {
    // Create a bounded channel with capacity 8
    (tx, rx) = channel_new(8);

    // Clone sender for two producers
    tx2 = sender_clone(tx);

    // Spawn producer threads
    // IVE verifies: each thread gets its own Sender (no aliasing)
    t1 = spawn(producer_task, tx, 0, 5);   // Sends 0..4
    t2 = spawn(producer_task, tx2, 100, 5); // Sends 100..104

    // Consumer: receive all messages
    received: u64 = 0;
    while received < 10 {
        result = receiver_recv(rx);
        if result != 0 {
            msg = result;
            print((*msg).sender_id);
            print((*msg).payload);
            free(msg);
            received = received + 1;
        }
    }

    // Wait for producers to finish
    join(t1);
    join(t2);

    // Clean up channel
    channel_destroy(rx);
    return 0;
}
// IVE verification: no data races between producers, no message loss,
// no use-after-free, all allocations cleaned up
