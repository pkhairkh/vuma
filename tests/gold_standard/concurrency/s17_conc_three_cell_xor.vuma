// s17_conc_three_cell_xor.vuma — three cells, 0x55 ^ 0x33 ^ 0x0F = 0x69 = 105
// Expected exit code: 105
//
// Three independent 8-byte cells. Each gets a distinct literal
// (0x55 / 0x33 / 0x0F). All three loaded back and XORed -> 105.
// Distinct from s11_conc_three_cells_xor (different values) and
// s8_conc_three_cells_mul (product, not XOR).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 85;             // 0x55
    *c2 = 51;             // 0x33
    *c3 = 15;             // 0x0F
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 ^ v2;     // 0x66
    r: i32 = t ^ v3;      // 0x69 = 105
    free(c1);
    free(c2);
    free(c3);
    return r;
}
