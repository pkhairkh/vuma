// s26_conc_overwrite_first.vuma — overwrite first cell, sum = 110 (70 + 15 + 25)
// Expected exit code: 110
//
// Three independent 8-byte cells. Store 5/15/25, then overwrite the first
// cell with 70. Load all three, sum -> 110. Uses `*ptr = literal` form.
// Distinct from s22_conc_overwrite_last (overwrites the last cell, 80)
// and s18_conc_overwrite_first (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 5;
    *c2 = 15;
    *c3 = 25;
    *c1 = 70;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
