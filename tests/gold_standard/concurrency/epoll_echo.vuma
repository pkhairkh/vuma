// Epoll Basic Test — epoll_create1 + close
// Expected exit code: 0
//
// This test verifies that epoll_create1 and close syscalls work correctly.
// It creates an epoll instance, closes it, and verifies the return values.
//
// VUMA Key Concepts:
//   - Extern FFI: epoll_create1, close, exit
//   - Syscall error checking (negative return = error)
//   - File descriptor management

extern "C" {
    fn epoll_create1(flags: i64) -> i64;
    fn close(fd: i64) -> i64;
    fn exit(code: i64);
}

fn main() -> i32 {
    // Create an epoll instance
    // epoll_create1(0) = create epoll fd with no flags
    // Returns non-negative fd on success, -1 on error
    epfd: i64 = epoll_create1(0);
    if epfd < 0 {
        return 1;
    }

    // Close the epoll fd
    rc: i64 = close(epfd);
    if rc != 0 {
        return 2;
    }

    // Success — epoll create and close worked
    return 0;
}
