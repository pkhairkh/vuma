// s103_conc_two_cell_diff.vuma — store 200, 22 in 2 cells, load and diff = 200-22 = 178
// Expected exit code: 178
//
// Two independent 8-byte cells. Store 200 at c1, store 22 at c2, load each and return the difference (178). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s100_conc_two_cell_diff (36).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 22;
    a: i32 = *c1;          // 200
    b: i32 = *c2;          // 22
    d: i32 = a - b;        // 178
    free(c1);
    free(c2);
    return d;
}
