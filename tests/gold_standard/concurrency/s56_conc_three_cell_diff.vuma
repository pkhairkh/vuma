// s56_conc_three_cell_diff.vuma — three cells, diff = 120 (200-50-30)
// Expected exit code: 120
//
// Three independent 8-byte cells. Store 200/50/30 via `*ptr = literal`,
// load all three, diff -> 120. Uses `*ptr = literal` form. Distinct
// from s54_conc_three_cell_diff (140) and s50_conc_three_cell_diff
// (130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 50;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    d: i32 = t - v3;       // 120
    free(c1);
    free(c2);
    free(c3);
    return d;
}
