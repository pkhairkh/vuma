// s71_conc_two_cell_sum.vuma — two cells, sum = 130 (75 + 55)
// Expected exit code: 130
//
// Two independent 8-byte cells. Store 75/55 via `*ptr = literal`,
// load both, sum -> 130. Uses `*ptr = literal` form. Distinct
// from s69_conc_two_cell_sum (170), s70_conc_two_cell_sum (105)
// and s66_conc_two_cell_diff (125).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 75;
    *c2 = 55;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 130
    free(c1);
    free(c2);
    return s;
}
