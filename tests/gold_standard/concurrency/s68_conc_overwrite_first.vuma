// s68_conc_overwrite_first.vuma — overwrite c1 to 178, load = 178
// Expected exit code: 178
//
// Three independent 8-byte cells. Store 100/50/80 then overwrite
// c1 to 178. Load c1 -> 178 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s66_conc_overwrite_middle (190),
// s62_conc_overwrite_first (150) and s58_conc_overwrite_middle
// (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c3 = 80;
    *c1 = 178;
    v: i32 = *c1;          // 178
    free(c1);
    free(c2);
    free(c3);
    return v;
}
