// s71_conc_three_cell_diff.vuma — three cells, diff = 155 (220-50-15)
// Expected exit code: 155
//
// Three independent 8-byte cells. Store 220/50/15 via `*ptr =
// literal`, load all three, diff -> 220 - 50 - 15 = 155. Uses
// `*ptr = literal` form. Distinct from s69_conc_three_cell_xor
// (95), s70_conc_three_cell_diff (160) and s66_conc_three_cell_
// sum (240).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 50;
    *c3 = 15;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 170
    d: i32 = t - v3;       // 155
    free(c1);
    free(c2);
    free(c3);
    return d;
}
