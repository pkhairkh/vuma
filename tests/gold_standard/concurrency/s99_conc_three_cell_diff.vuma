// s99_conc_three_cell_diff.vuma — three cells, diff = 21 (90 - 40 - 29)
// Expected exit code: 21
//
// Three independent 8-byte cells. Store 90/40/29 via `*ptr =
// literal`, load all three, a - b - c -> 21. Uses `*ptr = literal`
// form. Distinct from s95_conc_three_cell_sum (31),
// s91_conc_three_cell_diff (12) and s87_conc_three_cell_diff (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 90;
    *c2 = 40;
    *c3 = 29;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 21
    free(c1);
    free(c2);
    free(c3);
    return r;
}
