// s96_conc_three_cell_diff.vuma — three cells, diff = 128 (248 - 90 - 30)
// Expected exit code: 128
//
// Three independent 8-byte cells. Store 248/90/30 via `*ptr =
// literal`, load all three, 248 - 90 - 30 -> 128. Uses `*ptr =
// literal` form. Distinct from s94_conc_three_cell_sum (77),
// s90_conc_three_cell_diff (10) and s86_conc_three_cell_diff (150).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 248;
    *c2 = 90;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    d: i32 = v1 - v2 - v3; // 128
    free(c1);
    free(c2);
    free(c3);
    return d;
}
