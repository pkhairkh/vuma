// s34_conc_overwrite_last.vuma — overwrite last cell to 100, sum with 30 = 130
// Expected exit code: 130
//
// Two 8-byte cells. Store 30 in c1; store 20 then overwrite to 100
// in c2; load both, sum -> 130. Uses `*ptr = literal` form. Distinct
// from s30_conc_overwrite_last (different values) and s27_conc_
// overwrite_middle (different cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 30;
    *c2 = 20;
    *c2 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 130
    free(c1);
    free(c2);
    return s;
}
