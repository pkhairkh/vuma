// s50_conc_overwrite_first.vuma — overwrite first to 90, sum = 230 (90 + 60 + 80)
// Expected exit code: 230
//
// Three independent 8-byte cells. Store 40/60/80 via `*ptr =
// literal`, then overwrite the first cell with 90. Load all three,
// sum -> 230. Uses `*ptr = literal` form. Distinct from s46_conc_
// overwrite_last (180) and s43_conc_overwrite_max (255).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 60;
    *c3 = 80;
    *c1 = 90;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 230
    free(c1);
    free(c2);
    free(c3);
    return s;
}
