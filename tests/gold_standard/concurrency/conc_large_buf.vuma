// conc_large_buf.vuma — allocate 256 bytes, use first 8 as the "atomic"
// Expected exit code: 42
//
// In real lock-free code the atomic counter is often embedded at a
// known offset in a larger shared struct (e.g. the head/tail fields of
// a ring buffer). This test allocates a 256-byte block, treats the
// first 8 bytes as the "atomic cell", stores 42 there via `*buf`, and
// loads it back. The larger allocation exercises the heap allocator's
// sizing path while keeping the actual atomic access at offset 0.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    buf = allocate(256);
    *buf = 42;
    val: i32 = *buf;
    free(buf);
    return val;
}
