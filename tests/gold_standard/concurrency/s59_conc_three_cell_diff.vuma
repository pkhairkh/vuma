// s59_conc_three_cell_diff.vuma — three cells, diff = 160 (250 - 60 - 30)
// Expected exit code: 160
//
// Three independent 8-byte cells. Store 250/60/30 via `*ptr =
// literal`, load all three, 250 - 60 - 30 = 160. Uses `*ptr =
// literal` form. Distinct from s58_conc_two_cell_diff (140), s58_conc_
// three_cell_sum (230) and s58_conc_overwrite_middle (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 60;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    d: i32 = t - v3;       // 160
    free(c1);
    free(c2);
    free(c3);
    return d;
}
