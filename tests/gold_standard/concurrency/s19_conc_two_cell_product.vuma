// s19_conc_two_cell_product.vuma — two cells, product = 96 (8 * 12)
// Expected exit code: 96
//
// Two 8-byte cells. Store 8/12 via `*ptr = literal`, load both,
// multiply -> 96. Uses `*ptr = literal` form (no offsets). Distinct
// from s18_conc_two_cell_sum (23/67 = 90, sum) and
// s14_conc_two_cell_diff (subtraction).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 8;
    *p2 = 12;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a * b;
    free(p1);
    free(p2);
    return s;
}
