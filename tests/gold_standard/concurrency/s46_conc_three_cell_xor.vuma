// s46_conc_three_cell_xor.vuma — three cells, xor = 240 (0xAA ^ 0x55 ^ 0x0F)
// Expected exit code: 240
//
// Three independent 8-byte cells. Store 170/85/15 via `*ptr = literal`,
// load all, xor -> 240 (0xF0). Uses `*ptr = literal` form. Distinct
// from s42_conc_three_cell_sum (225) and s38_conc_three_cell_sum.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 170;             // 0xAA
    *c2 = 85;              // 0x55
    *c3 = 15;              // 0x0F
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 ^ v2;
    s: i32 = t ^ v3;       // 0xF0 = 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
