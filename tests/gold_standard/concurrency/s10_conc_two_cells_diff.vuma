// s10_conc_two_cells_diff.vuma — two cells, sum loads = 80 (35 + 45)
// Expected exit code: 80
//
// Two independent 8-byte cells. Each gets a different literal at
// offset 0 (35/45). Both loaded back and summed. Distinct from
// s6_conc_two_cell (values 30/40) and s5_conc_three_cells (3 cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 35;
    *c2 = 45;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
