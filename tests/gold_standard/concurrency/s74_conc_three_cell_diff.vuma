// s74_conc_three_cell_diff.vuma — three cells, diff = 29 (100 - 50 - 21)
// Expected exit code: 29
//
// Three independent 8-byte cells. Store 100/50/21 via `*ptr =
// literal`, load all three, diff -> 29. Uses `*ptr = literal`
// form. Distinct from s70_conc_three_cell_diff (160),
// s66_conc_three_cell_diff (190) and s62_conc_three_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c3 = 21;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 50
    r: i32 = t - v3;       // 29
    free(c1);
    free(c2);
    free(c3);
    return r;
}
