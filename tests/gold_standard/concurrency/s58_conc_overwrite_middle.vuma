// s58_conc_overwrite_middle.vuma — overwrite middle to 100, sum = 200 (40 + 100 + 60)
// Expected exit code: 200
// 
// Three independent 8-byte cells. Store 40/50/60 via `*ptr =
// literal`, then overwrite the middle cell with 100. Load all three,
// sum -> 200. Uses `*ptr = literal` form. Distinct from s51_conc_two_
// cell_sum (225), s51_conc_three_cell_sum (205) and s51_conc_overwrite_
// last (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 50;
    *c3 = 60;
    *c2 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 200
    free(c1);
    free(c2);
    free(c3);
    return s;
}
