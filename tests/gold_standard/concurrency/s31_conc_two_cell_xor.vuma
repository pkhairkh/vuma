// s31_conc_two_cell_xor.vuma — two cells, xor = 255 (0xCC ^ 0x33)
// Expected exit code: 255
//
// Two independent 8-byte cells. Store 0xCC/0x33 via `*ptr = literal`,
// load both, XOR -> 255. Uses `*ptr = literal` form. Distinct from
// s30_conc_two_cell_product (product, 156) and s28_conc_two_cell_or
// (or, 51).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 204;            // 0xCC
    *c2 = 51;             // 0x33
    v1: i32 = *c1;
    v2: i32 = *c2;
    p: i32 = v1 ^ v2;       // 0xFF = 255
    free(c1);
    free(c2);
    return p;
}
