// conc2_chain.vuma — chain of 3 stores across 3 cells, return the tail
// Expected exit code: 3
//
// A "chain copy" pipeline: store 3 into cell1, copy cell1 -> cell2 ->
// cell3, return cell3. Each copy is a load-then-store; this exercises
// the store-loaded-variable codegen path three times in sequence.
//
// KNOWN WORKAROUND: storing a loaded variable via `*ptr = loaded_var`
// is silently dropped by the current x86_64 codegen (the Store IR
// accepts a Register value, but the actual instruction emission fails
// to write the register's value to memory). Storing an inline binary
// expression like `*ptr = loaded_var + 0` triggers a different codegen
// path that DOES emit the store correctly. This test uses the inline
// `+ 0` form; once the Store of a Register value is fixed in the
// backend, the `+ 0` becomes a no-op and the test still passes.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *a = 3;
    v1: i32 = *a;
    *b = v1 + 0;          // copy a -> b (inline +0 workaround)
    v2: i32 = *b;
    *c = v2 + 0;          // copy b -> c (inline +0 workaround)
    v3: i32 = *c;
    free(a);
    free(b);
    free(c);
    return v3;
}
