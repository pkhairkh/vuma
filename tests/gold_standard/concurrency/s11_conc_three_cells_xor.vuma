// s11_conc_three_cells_xor.vuma — three cells, xor = 240
// Expected exit code: 240
//
// Three independent 8-byte cells. Each gets a distinct literal at
// offset 0 (0xAA / 0x55 / 0x0F). All three loaded back and XORed
// -> 0xAA ^ 0x55 = 0xFF; 0xFF ^ 0x0F = 0xF0 = 240. Distinct from
// s10_conc_two_cells_diff (two cells, sum) and s8_conc_three_cells_mul
// (three cells, product).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 170;          // 0xAA
    *c2 = 85;           // 0x55
    *c3 = 15;           // 0x0F
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 ^ v2;   // 0xFF
    r: i32 = t ^ v3;    // 0xF0 = 240
    free(c1);
    free(c2);
    free(c3);
    return r;
}
