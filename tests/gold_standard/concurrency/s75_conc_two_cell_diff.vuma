// s75_conc_two_cell_diff.vuma — two cells, diff = 127 (200 - 73)
// Expected exit code: 127
//
// Two independent 8-byte cells. Store 200/73 via `*ptr = literal`,
// load both, diff -> 127. Uses `*ptr = literal` form. Distinct from
// s74_conc_two_cell_sum (132), s70_conc_two_cell_sum (105) and
// s66_conc_two_cell_diff (125).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 73;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 - v2;      // 127
    free(c1);
    free(c2);
    return s;
}
