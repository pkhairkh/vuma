// s65_conc_three_cell_diff.vuma — three cells, diff = 135 (200 - 40 - 25)
// Expected exit code: 135
//
// Three independent 8-byte cells. Store 200/40/25 via `*ptr =
// literal`, load all three, diff -> 135. Uses `*ptr = literal`
// form. Distinct from s51_conc_three_cell_sum (205), s58_conc_three_
// cell_sum (230) and s62_conc_three_cell_diff (110).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 40;
    *c3 = 25;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    s: i32 = t - v3;       // 135
    free(c1);
    free(c2);
    free(c3);
    return s;
}
