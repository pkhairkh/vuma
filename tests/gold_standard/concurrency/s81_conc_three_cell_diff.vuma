// s81_conc_three_cell_diff.vuma — three cells, diff = 120 (250 - 90 - 40)
// Expected exit code: 120
//
// Three independent 8-byte cells. Store 250/90/40 via `*ptr =
// literal`, load all three, a - b - c -> 120. Uses `*ptr =
// literal` form. Distinct from s78_conc_three_cell_diff (148),
// s77_conc_three_cell_diff (122) and s76_conc_three_cell_diff (37).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 90;
    *c3 = 40;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 120
    free(c1);
    free(c2);
    free(c3);
    return r;
}
