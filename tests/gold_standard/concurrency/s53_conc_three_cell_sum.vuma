// s53_conc_three_cell_sum.vuma — three cells, sum = 170 (55 + 85 + 30)
// Expected exit code: 170
//
// Three independent 8-byte cells. Store 55/85/30 via `*ptr =
// literal`, load all three, sum -> 170. Uses `*ptr = literal` form.
// Distinct from s49_conc_three_cell_sum (165) and s50_conc_three_
// cell_diff (120).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 55;
    *c2 = 85;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 170
    free(c1);
    free(c2);
    free(c3);
    return s;
}
