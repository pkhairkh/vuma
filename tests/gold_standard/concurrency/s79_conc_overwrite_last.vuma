// s79_conc_overwrite_last.vuma — store 1, overwrite with 19, load = 19
// Expected exit code: 19
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite
// with 19 via `*ptr = literal`, load and return 19. Uses `*ptr
// = literal` form. Distinct from s78_conc_overwrite_last (3),
// s77_conc_overwrite_last (2) and s76_conc_overwrite_last (3).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 19;
    r: i32 = *c1;          // 19
    free(c1);
    return r;
}
