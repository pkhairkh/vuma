// s95_conc_two_cell_diff.vuma — two cells, diff = 45 (80 - 35)
// Expected exit code: 45
//
// Two independent 8-byte cells. Store 80/35 via `*ptr = literal`,
// load both, a - b -> 45. Uses `*ptr = literal` form. Distinct from
// s94_conc_two_cell_sum (120), s90_conc_two_cell_diff (5) and
// s82_conc_two_cell_sum (190).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 35;
    v1: i32 = *c1;
    v2: i32 = *c2;
    r: i32 = v1 - v2;      // 45
    free(c1);
    free(c2);
    return r;
}
