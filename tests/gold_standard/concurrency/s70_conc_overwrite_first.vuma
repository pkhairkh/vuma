// s70_conc_overwrite_first.vuma — overwrite c1 to 215, load = 215
// Expected exit code: 215
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c1 to 215. Load c1 -> 215 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s66_conc_overwrite_middle (190),
// s65_conc_overwrite_last (145) and s62_conc_overwrite_first (150).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c1 = 215;
    v: i32 = *c1;          // 215
    free(c1);
    free(c2);
    free(c3);
    return v;
}
