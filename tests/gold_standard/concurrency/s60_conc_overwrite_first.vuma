// s60_conc_overwrite_first.vuma — overwrite first to 105, sum = 245 (105 + 55 + 85)
// Expected exit code: 245
//
// Three independent 8-byte cells. Store 25/55/85 via `*ptr =
// literal`, then overwrite the first cell with 105. Load all three,
// sum -> 245. Uses `*ptr = literal` form. Distinct from s58_conc_
// overwrite_middle (200) and s57_conc_overwrite_middle (175).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 25;
    *c2 = 55;
    *c3 = 85;
    *c1 = 105;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 245
    free(c1);
    free(c2);
    free(c3);
    return s;
}
