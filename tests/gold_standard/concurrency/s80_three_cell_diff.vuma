// s80_conc_three_cell_diff.vuma — three cells, diff = 17 (19 - 1 - 1)
// Expected exit code: 17
//
// Three independent 8-byte cells. Store 19/1/1 via `*ptr =
// literal`, load all three, a - b - c -> 17. Uses `*ptr = literal`
// form. Distinct from s78_conc_three_cell_diff (148),
// s74_conc_three_cell_diff (55) and s73_conc_three_cell_diff (75).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 19;
    *c2 = 1;
    *c3 = 1;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 17
    free(c1);
    free(c2);
    free(c3);
    return r;
}
