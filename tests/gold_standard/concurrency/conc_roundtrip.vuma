// conc_roundtrip.vuma — double round-trip through two cells, return tail
// Expected exit code: 123
//
// Store 123 in cell1, copy to cell2, load cell2 and return. Identical
// pattern to conc_copy but with a 3-digit value to make it easy to
// distinguish from accidental zeros. Single-threaded; the multi-hop
// pattern mirrors what a forwarding ring does across multiple threads.
//
// KNOWN WORKAROUND: storing a loaded variable via `*ptr = loaded_var`
// is silently dropped by the current x86_64 codegen. The inline form
// `*ptr = loaded_var + 0` triggers a different codegen path that emits
// the store correctly. This test uses the inline `+ 0` form.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell1 = allocate(8);
    cell2 = allocate(8);
    *cell1 = 123;
    v1: i32 = *cell1;
    *cell2 = v1 + 0;        // copy cell1 -> cell2 (inline +0 workaround)
    v2: i32 = *cell2;
    free(cell1);
    free(cell2);
    return v2;
}
