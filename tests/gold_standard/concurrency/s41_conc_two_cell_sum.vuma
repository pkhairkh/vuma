// s41_conc_two_cell_sum.vuma - two cells, sum = 195 (110 + 85)
// Expected exit code: 195
//
// Two independent 8-byte cells. Store 110/85 via `*ptr = literal`,
// load both, sum -> 195. Uses `*ptr = literal` form. Distinct from
// s38_conc_two_cell_sum (205) and s34_conc_two_cell_diff (65).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 110;
    *c2 = 85;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 195
    free(c1);
    free(c2);
    return s;
}
