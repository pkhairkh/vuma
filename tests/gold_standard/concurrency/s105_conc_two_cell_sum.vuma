// s105_conc_two_cell_sum.vuma — store 41 + 13 in 2 cells, load and sum = 54
// Expected exit code: 54
// 
// Two independent 8-byte cells. Store 41 at c1, store 13 at c2, load each and return the sum (54). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_conc_two_cell_sum (22), s101_conc_two_cell_sum (230), s100_conc_two_cell_diff (36).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 41;
    *c2 = 13;
    a: i32 = *c1;          // 41
    b: i32 = *c2;          // 13
    s: i32 = a + b;        // 54
    free(c1);
    free(c2);
    return s;
}
