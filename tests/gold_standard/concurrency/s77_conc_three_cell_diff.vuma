// s77_conc_three_cell_diff.vuma — three cells, diff = 122 (225 - 65 - 38)
// Expected exit code: 122
//
// Three independent 8-byte cells. Store 225/65/38 via `*ptr =
// literal`, load all three, diff -> 122. Uses `*ptr = literal`
// form. Distinct from s70_conc_three_cell_diff (160), s66_conc_
// three_cell_xor (90) and s74_conc_three_cell_diff (29).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 225;
    *c2 = 65;
    *c3 = 38;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 160
    r: i32 = t - v3;       // 122
    free(c1);
    free(c2);
    free(c3);
    return r;
}
