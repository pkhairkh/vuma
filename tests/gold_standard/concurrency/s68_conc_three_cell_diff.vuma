// s68_conc_three_cell_diff.vuma — three cells, diff = 85 (150 - 30 - 35)
// Expected exit code: 85
//
// Three independent 8-byte cells. Store 150/30/35 via `*ptr =
// literal`, load all three, diff -> 150 - 30 - 35 = 85. Uses
// `*ptr = literal` form. Distinct from s66_conc_three_cell_sum
// (240), s62_conc_three_cell_diff (110) and s58_conc_overwrite_
// middle (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 150;
    *c2 = 30;
    *c3 = 35;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 120
    r: i32 = t - v3;       // 85
    free(c1);
    free(c2);
    free(c3);
    return r;
}
