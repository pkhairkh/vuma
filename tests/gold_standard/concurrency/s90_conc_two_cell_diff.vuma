// s90_conc_two_cell_diff.vuma — two cells, diff = 5 (250 - 245)
// Expected exit code: 5
//
// Two independent 8-byte cells. Store 250/245 via `*ptr = literal`,
// load both, a - b -> 5. Uses `*ptr = literal` form. Distinct from
// s86_conc_two_cell_sum (210), s82_conc_two_cell_sum (190) and
// s78_conc_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 250;
    *c2 = 245;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 5
    free(c1);
    free(c2);
    return d;
}
