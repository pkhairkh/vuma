// s82_conc_two_cell_sum.vuma — two cells, sum = 190 (105 + 85)
// Expected exit code: 190
//
// Two independent 8-byte cells. Store 105/85 via `*ptr =
// literal`, load both, sum -> 190. Uses `*ptr = literal` form.
// Distinct from s78_conc_two_cell_sum (2), s74_conc_two_cell_
// sum (105) and s72_conc_two_cell_sum (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 105;
    *c2 = 85;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 190
    free(c1);
    free(c2);
    return s;
}
