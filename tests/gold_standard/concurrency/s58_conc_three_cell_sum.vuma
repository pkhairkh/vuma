// s58_conc_three_cell_sum.vuma — three cells, sum = 230 (50 + 100 + 80)
// Expected exit code: 230
// 
// Three independent 8-byte cells. Store 50/100/80 via `*ptr =
// literal`, load all three, sum -> 230. Uses `*ptr = literal` form.
// Distinct from s51_conc_two_cell_sum (225), s51_conc_three_cell_sum
// (205) and s51_conc_overwrite_last (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 230
    free(c1);
    free(c2);
    free(c3);
    return s;
}
