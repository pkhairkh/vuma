// s21_conc_overwrite_middle.vuma — overwrite middle cell, sum = 155 (35 + 25 + 95)
// Expected exit code: 155
//
// Three 8-byte cells. Store 35/5/95 in c1/c2/c3, then overwrite c2 with
// 25. Load all three, sum -> 155. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_conc_overwrite_first (overwrites FIRST cell,
// 80+20+30 = 130) and s14_conc_overwrite_middle (10/70/30 = 110).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 35;
    *c2 = 5;
    *c3 = 95;
    *c2 = 25;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
