// s68_conc_two_cell_sum.vuma — two cells, sum = 223 (144 + 79)
// Expected exit code: 223
//
// Two independent 8-byte cells. Store 144/79 via `*ptr =
// literal`, load both, sum -> 223. Uses `*ptr = literal` form.
// Distinct from s66_conc_two_cell_diff (125), s62_conc_two_cell_
// sum (230) and s58_conc_two_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 144;
    *c2 = 79;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 223
    free(c1);
    free(c2);
    return s;
}
