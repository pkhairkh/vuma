// s23_conc_overwrite_middle.vuma — overwrite middle cell, sum = 143 (11 + 99 + 33)
// Expected exit code: 143
//
// Three independent 8-byte cells. Store 11/22/33, then overwrite the
// middle cell (c2) with 99. Load all three, sum -> 143. Uses `*ptr =
// literal` form (no offsets). Distinct from s22_conc_overwrite_last
// (overwrites last cell) and s20_conc_overwrite_first (overwrites first).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 11;
    *c2 = 22;
    *c3 = 33;
    *c2 = 99;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;     // 143
    free(c1);
    free(c2);
    free(c3);
    return s;
}

