// s78_conc_two_cell_sum.vuma — two cells, sum = 2 (1 + 1)
// Expected exit code: 2
//
// Two independent 8-byte cells. Store 1/1 via `*ptr = literal`,
// load both, sum -> 2. Uses `*ptr = literal` form. Distinct from
// s74_conc_two_cell_sum (105), s73_conc_two_cell_sum (111) and
// s72_conc_two_cell_sum (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 1;
    *c2 = 1;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 2
    free(c1);
    free(c2);
    return s;
}
