// s57_conc_overwrite_middle.vuma — overwrite middle cell, load = 175
// Expected exit code: 175
//
// Three independent 8-byte cells. Store 100/130/90 via `*ptr =
// literal`, overwrite the middle cell with 175 via `*ptr = literal`,
// load middle -> 175. Uses `*ptr = literal` form. Distinct from
// s54_conc_overwrite_middle (220) and s50_conc_overwrite_first (230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 130;
    *c3 = 90;
    *c2 = 175;             // overwrite middle
    v: i32 = *c2;          // 175
    free(c1);
    free(c2);
    free(c3);
    return v;
}
