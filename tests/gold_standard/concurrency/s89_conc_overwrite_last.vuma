// s89_conc_overwrite_last.vuma — overwrite c3 to 8, load = 8
// Expected exit code: 8
//
// Three independent 8-byte cells. Store 45 at c1, store 75 at
// c2, store 95 at c3, then overwrite c3 to 8. Load c3 -> 8
// (the overwritten value). Uses `*ptr = literal` form. Distinct
// from s86_conc_overwrite_last (200), s82_conc_overwrite_last
// (230) and s78_conc_overwrite_last (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 45;
    *c2 = 75;
    *c3 = 95;
    *c3 = 8;
    v: i32 = *c3;          // 8
    free(c1);
    free(c2);
    free(c3);
    return v;
}
