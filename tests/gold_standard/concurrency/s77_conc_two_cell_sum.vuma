// s77_conc_two_cell_sum.vuma — two cells, sum = 158 (130 + 28)
// Expected exit code: 158
//
// Two independent 8-byte cells. Store 130/28 via `*ptr =
// literal`, load both, sum -> 158. Uses `*ptr = literal` form.
// Distinct from s70_conc_two_cell_sum (105), s66_conc_two_cell_
// diff (125) and s74_conc_two_cell_sum (132).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 130;
    *c2 = 28;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 158
    free(c1);
    free(c2);
    return s;
}
