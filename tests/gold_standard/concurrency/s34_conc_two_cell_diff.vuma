// s34_conc_two_cell_diff.vuma — two cells, diff = 65 (100 - 35)
// Expected exit code: 65
//
// Two independent 8-byte cells. Store 100/35 via `*ptr = literal`,
// load both, subtract -> 65. Uses `*ptr = literal` form. Distinct
// from s30_conc_two_cell_product (product, 156) and s27_conc_two_
// cell_or (or).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 35;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 65
    free(c1);
    free(c2);
    return d;
}
