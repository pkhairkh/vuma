// s35_conc_overwrite_middle.vuma — overwrite middle cell, sum = 125 (15+75+35)
// Expected exit code: 125
//
// Three independent 8-byte cells. Store 15/25/35 in c1/c2/c3, then
// overwrite c2 with 75. Load all three, sum -> 125. Uses `*ptr =
// literal` form. Distinct from s34_conc_overwrite_last (130) and
// s30_conc_overwrite_last (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 15;
    *c2 = 25;
    *c3 = 35;
    *c2 = 75;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 125
    free(c1);
    free(c2);
    free(c3);
    return s;
}
