// s37_conc_three_cell_sum.vuma — three cells, sum = 60 + 90 + 100 = 250
// Expected exit code: 250
//
// Deterministic test in the concurrency category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_conc_three_cell_or (or, 112) and s30_conc_three_cell_sum (sum).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 90;
    *c3 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    s: i32 = v1 + v2 + v3;  // 250
    free(c1);
    free(c2);
    free(c3);
    return s;
}
