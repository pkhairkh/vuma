// s44_conc_three_cell_diff.vuma — three cells, diff = 115 (200 - 55 - 30)
// Expected exit code: 115
//
// Three independent 8-byte cells. Store 200/55/30 via `*ptr = literal`,
// load all, subtract -> 115. Uses `*ptr = literal` form. Distinct from
// s42_conc_three_cell_sum (225) and s38_conc_three_cell_xor (xor).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 55;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    d: i32 = t - v3;       // 115
    free(c1);
    free(c2);
    free(c3);
    return d;
}
