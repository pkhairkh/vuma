// s69_conc_overwrite_last.vuma -- overwrite c2 to 85, load = 85
// Expected exit code: 85
//
// Two independent 8-byte cells. Store 100/60 via `*ptr = literal`,
// overwrite c2 to 85 via `*ptr = literal`, load c2 -> 85. Uses
// `*ptr = literal` form. Distinct from s66_conc_overwrite_middle
// (190), s65_conc_overwrite_last (145) and s64_conc_overwrite_last
// (210).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 60;
    *c2 = 85;
    v: i32 = *c2;          // 85
    free(c1);
    free(c2);
    return v;
}
