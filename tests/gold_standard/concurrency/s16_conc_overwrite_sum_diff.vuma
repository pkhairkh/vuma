// s16_conc_overwrite_sum_diff.vuma — overwrite c1, sum = 120 (100 + 20)
// Expected exit code: 120
//
// Two independent 8-byte cells. Store 10/20, then overwrite c1 with 100.
// Load both, sum -> 120. Distinct from s11_conc_overwrite_then_sum
// (values 5/15 -> 50/15 = 65) and s6_conc_overwrite_then_sum (other values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c1 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
