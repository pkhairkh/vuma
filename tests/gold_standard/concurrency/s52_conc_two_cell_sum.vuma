// s52_conc_two_cell_sum.vuma — two cells, sum = 230 (100 + 130)
// Expected exit code: 230
//
// Two independent 8-byte cells. Store 100/130 via `*ptr = literal`,
// load both, sum -> 230. Uses `*ptr = literal` form. Distinct from
// s50_conc_two_cell_sum (215) and s46_conc_two_cell_sum (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 130;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 230
    free(c1);
    free(c2);
    return s;
}
