// s28_conc_three_cell_sum.vuma — three cells, sum = 120 (30 + 40 + 50)
// Expected exit code: 120
//
// Three independent 8-byte cells. Each gets a distinct literal (30/40/50).
// All three loaded back and summed. Uses `*ptr = literal` form. Distinct
// from s26_conc_three_cell_or (or, 7) and s22_conc_three_cell_dec
// (descending sum, 150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c3 = 50;
    v1: u64 = *c1;
    v2: u64 = *c2;
    v3: u64 = *c3;
    t: u64 = v1 + v2;     // 70
    s: u64 = t + v3;      // 120
    free(c1);
    free(c2);
    free(c3);
    return s;
}
