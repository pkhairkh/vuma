// s58_conc_two_cell_diff.vuma — two cells, diff = 140 (200 - 60)
// Expected exit code: 140
// 
// Two independent 8-byte cells. Store 200/60 via `*ptr = literal`,
// load both, subtract -> 140. Uses `*ptr = literal` form. Distinct
// from s51_conc_two_cell_sum (225), s51_conc_three_cell_sum (205)
// and s51_conc_overwrite_last (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 60;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 140
    free(c1);
    free(c2);
    return d;
}
