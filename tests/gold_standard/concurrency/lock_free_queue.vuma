// Lock-Free SPSC Queue - demonstrates VUMA concurrency verification
// Expected exit code: 0
// Single-producer single-consumer ring buffer
//
// Lock-free data structures are among the hardest code to get right.
// The combination of concurrent access and subtle memory ordering
// requirements makes bugs difficult to reproduce and diagnose.
//
// VUMA's IVE extends its 5 invariants to concurrent code:
//   - Liveness: verifies no use-after-free across threads
//   - Exclusivity: verifies no data races (two threads writing same bytes)
//   - Interpretation: verifies atomic operations target correct addresses
//   - Origin: verifies values come from valid writes (no torn reads)
//   - Cleanup: verifies all shared resources are eventually freed
//
// VUMA Key Concepts:
//   - AtomicU64 with Acquire/Release memory ordering
//   - Concurrent access verification by IVE
//   - Ring buffer index arithmetic
//   - IVE proves absence of data races without locks
//   - Generic struct parameter <T> for type-safe queues

struct Queue<T> {
    buffer: Address,      // Ring buffer storage
    capacity: u64,        // Maximum number of elements
    head: AtomicU64,      // Producer write index
    tail: AtomicU64,      // Consumer read index
}

fn queue_new(capacity: u64) -> Address {
    // Create a new SPSC queue
    // IVE verifies: buffer allocation matches capacity * element_size
    q = allocate(32);  // Queue struct
    buf = allocate(capacity * 8);  // Buffer for u64 values
    *q = Queue {
        buffer: buf,
        capacity,
        head: AtomicU64::new(0),
        tail: AtomicU64::new(0),
    };
    return q;
}

fn queue_push(q: Address, value: u64) -> bool {
    // Push a value onto the queue (producer side)
    //
    // IVE verifies:
    //   - slot is within buffer region (bounds check)
    //   - Release ordering ensures the value write is visible
    //     before the head index update
    //   - No data race: producer only writes slots between old
    //     head and new head, consumer only reads slots between
    //     old tail and new tail

    head = (*q).head.load(Acquire);
    tail = (*q).tail.load(Acquire);
    next_head = head + 1;

    if next_head % (*q).capacity == tail % (*q).capacity {
        return false;  // Queue is full
    }

    // Compute the slot address within the ring buffer
    // IVE verifies: slot is within buffer region
    slot = (*q).buffer + (head % (*q).capacity) * 8;
    *slot = value;

    // Publish the new head with Release ordering
    // IVE verifies: Release ordering ensures write visible before head update
    (*q).head.store(next_head, Release);
    return true;
}

fn queue_pop(q: Address) -> Option<u64> {
    // Pop a value from the queue (consumer side)
    //
    // IVE verifies:
    //   - No data race between push and pop on different slots
    //   - Acquire ordering ensures the consumer sees the value
    //     written by the producer before reading the slot
    //   - The value read originated from a valid write (Origin)

    tail = (*q).tail.load(Acquire);
    head = (*q).head.load(Acquire);

    if tail % (*q).capacity == head % (*q).capacity {
        return None;  // Queue is empty
    }

    // Compute the slot address within the ring buffer
    // IVE verifies: slot is within buffer region
    slot = (*q).buffer + (tail % (*q).capacity) * 8;
    value = *slot;

    // Advance the tail with Release ordering
    // IVE verifies: no data race between push and pop on different slots
    (*q).tail.store(tail + 1, Release);

    return Some(value);
}

fn main() -> i32 {
    q = queue_new(4);
    queue_push(q, 42);
    queue_push(q, 99);
    result = queue_pop(q);
    free(q);
    return 0;
}
