// Lock-Free SPSC Queue — simplified for cross-backend compatibility
// Expected exit code: 0
//
// Tests ring buffer index arithmetic with 32-bit values.
// Uses 32-bit elements to avoid 64-bit arithmetic issues on 32-bit backends.

// ===========================================================================
// Queue using separate allocations for each component.
// Uses 32-bit values to avoid 64-bit shift issues on riscv32/x86_32.
// ===========================================================================

fn queue_push(buf: Address, head_flag: Address, tail_flag: Address, capacity: u32, value: u32) -> i32 {
    head: u32 = AtomicLoad(head_flag);
    tail: u32 = AtomicLoad(tail_flag);
    next_head: u32 = head + 1;

    if next_head % capacity == tail % capacity {
        return 0;  // Queue is full
    }

    // Write 32-bit value at slot = buf + (head % capacity) * 4
    slot: u32 = buf + (head % capacity) * 4;
    // Write little-endian u32
    *(slot + 0) = value & 255;
    *(slot + 1) = (value >> 8) & 255;
    *(slot + 2) = (value >> 16) & 255;
    *(slot + 3) = (value >> 24) & 255;

    AtomicStore(next_head, head_flag);
    return 1;
}

fn queue_pop(buf: Address, head_flag: Address, tail_flag: Address, capacity: u32) -> u32 {
    tail: u32 = AtomicLoad(tail_flag);
    head: u32 = AtomicLoad(head_flag);

    if tail % capacity == head % capacity {
        return 4294967295;  // Queue is empty — return sentinel
    }

    // Read 32-bit value from slot = buf + (tail % capacity) * 4
    slot: u32 = buf + (tail % capacity) * 4;
    b0: u32 = *(slot + 0);
    b1: u32 = *(slot + 1);
    b2: u32 = *(slot + 2);
    b3: u32 = *(slot + 3);
    value: u32 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);

    AtomicStore(tail + 1, tail_flag);
    return value;
}

// ===========================================================================
// Main Entry Point
// ===========================================================================

fn main() -> i32 {
    // Allocate queue components separately
    capacity: u32 = 4;
    buf = allocate(capacity * 4);  // 4 elements × 4 bytes = 16 bytes
    head_flag = allocate(8);
    tail_flag = allocate(8);

    // Initialize head and tail to 0
    AtomicStore(0, head_flag);
    AtomicStore(0, tail_flag);

    // Push two values
    queue_push(buf, head_flag, tail_flag, capacity, 42);
    queue_push(buf, head_flag, tail_flag, capacity, 99);

    // Pop two values
    val1: u32 = queue_pop(buf, head_flag, tail_flag, capacity);
    val2: u32 = queue_pop(buf, head_flag, tail_flag, capacity);

    // Clean up
    free(buf);
    free(head_flag);
    free(tail_flag);

    // Verify results
    if val1 != 42 {
        return 1;
    }
    if val2 != 99 {
        return 2;
    }
    return 0;
}
