// Lock-Free SPSC Queue — simplified to use manual memory layout
// Expected exit code: 0
//
// Single-producer single-consumer ring buffer using AtomicLoad/AtomicStore
// for inter-thread communication. This version uses manual byte-level
// memory access instead of struct assignment to test the compiler's
// atomic operation support.
//
// VUMA Key Concepts:
//   - AtomicLoad / AtomicStore for inter-thread communication
//   - Ring buffer index arithmetic
//   - Manual struct layout (byte-level write_u64_le / read_u64_le)
//   - allocate / free with proper cleanup

// ===========================================================================
// Write/read u64 little-endian (for struct field access)
// ===========================================================================

fn write_u64_le(buf: Address, offset: u64, val: u64) {
    *(buf + offset) = val & 255;
    *(buf + offset + 1) = (val >> 8) & 255;
    *(buf + offset + 2) = (val >> 16) & 255;
    *(buf + offset + 3) = (val >> 24) & 255;
    *(buf + offset + 4) = (val >> 32) & 255;
    *(buf + offset + 5) = (val >> 40) & 255;
    *(buf + offset + 6) = (val >> 48) & 255;
    *(buf + offset + 7) = (val >> 56) & 255;
}

fn read_u64_le(buf: Address, offset: u64) -> u64 {
    b0: u64 = *(buf + offset);
    b1: u64 = *(buf + offset + 1);
    b2: u64 = *(buf + offset + 2);
    b3: u64 = *(buf + offset + 3);
    b4: u64 = *(buf + offset + 4);
    b5: u64 = *(buf + offset + 5);
    b6: u64 = *(buf + offset + 6);
    b7: u64 = *(buf + offset + 7);
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56);
}

// ===========================================================================
// Queue layout (32 bytes):
//   offset  0: buffer   (8 bytes, Address)
//   offset  8: capacity (8 bytes, u64)
//   offset 16: head     (8 bytes, AtomicU64 — producer index)
//   offset 24: tail     (8 bytes, AtomicU64 — consumer index)
// ===========================================================================

fn queue_new(capacity: u64) -> Address {
    q = allocate(32);
    buf = allocate(capacity * 8);
    write_u64_le(q, 0, buf);
    write_u64_le(q, 8, capacity);
    // head = 0, tail = 0 (already zeroed by allocate, but set explicitly)
    AtomicStore(0, q + 16);
    AtomicStore(0, q + 24);
    return q;
}

fn queue_push(q: Address, value: u64) -> i32 {
    head: u64 = AtomicLoad(q + 16);
    tail: u64 = AtomicLoad(q + 24);
    capacity: u64 = read_u64_le(q, 8);
    next_head: u64 = head + 1;

    if next_head % capacity == tail % capacity {
        return 0;  // Queue is full
    }

    buf: u64 = read_u64_le(q, 0);
    slot: u64 = buf + (head % capacity) * 8;
    write_u64_le(slot, 0, value);

    AtomicStore(next_head, q + 16);
    return 1;
}

fn queue_pop(q: Address) -> u64 {
    tail: u64 = AtomicLoad(q + 24);
    head: u64 = AtomicLoad(q + 16);
    capacity: u64 = read_u64_le(q, 8);

    if tail % capacity == head % capacity {
        return 4294967295;  // Queue is empty — return sentinel
    }

    buf: u64 = read_u64_le(q, 0);
    slot: u64 = buf + (tail % capacity) * 8;
    value: u64 = read_u64_le(slot, 0);

    AtomicStore(tail + 1, q + 24);
    return value;
}

// ===========================================================================
// Main Entry Point
// ===========================================================================

fn main() -> i32 {
    q = queue_new(4);
    queue_push(q, 42);
    queue_push(q, 99);
    val1: u64 = queue_pop(q);
    val2: u64 = queue_pop(q);

    // Clean up
    buf: u64 = read_u64_le(q, 0);
    free(buf);
    free(q);

    // Verify results
    if val1 != 42 {
        return 1;
    }
    if val2 != 99 {
        return 2;
    }
    return 0;
}
