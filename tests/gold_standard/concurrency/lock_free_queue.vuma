// Lock-Free SPSC Queue — simplified for cross-backend compatibility
// Expected exit code: 0
//
// Tests AtomicLoad/AtomicStore and ring buffer index arithmetic.
// Uses separate allocations for each field to avoid pointer arithmetic
// issues on 32-bit backends.

// ===========================================================================
// Write/read u64 little-endian
// ===========================================================================

fn write_u64_le(buf: Address, offset: u64, val: u64) {
    *(buf + offset) = val & 255;
    *(buf + offset + 1) = (val >> 8) & 255;
    *(buf + offset + 2) = (val >> 16) & 255;
    *(buf + offset + 3) = (val >> 24) & 255;
    *(buf + offset + 4) = (val >> 32) & 255;
    *(buf + offset + 5) = (val >> 40) & 255;
    *(buf + offset + 6) = (val >> 48) & 255;
    *(buf + offset + 7) = (val >> 56) & 255;
}

fn read_u64_le(buf: Address, offset: u64) -> u64 {
    b0: u64 = *(buf + offset);
    b1: u64 = *(buf + offset + 1);
    b2: u64 = *(buf + offset + 2);
    b3: u64 = *(buf + offset + 3);
    b4: u64 = *(buf + offset + 4);
    b5: u64 = *(buf + offset + 5);
    b6: u64 = *(buf + offset + 6);
    b7: u64 = *(buf + offset + 7);
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56);
}

// ===========================================================================
// Queue using separate allocations for each component.
// This avoids pointer arithmetic on struct fields which can cause issues
// on 32-bit backends.
// ===========================================================================

fn queue_push(buf: Address, head_flag: Address, tail_flag: Address, capacity: u64, value: u64) -> i32 {
    head: u64 = AtomicLoad(head_flag);
    tail: u64 = AtomicLoad(tail_flag);
    next_head: u64 = head + 1;

    if next_head % capacity == tail % capacity {
        return 0;  // Queue is full
    }

    slot: u64 = buf + (head % capacity) * 8;
    write_u64_le(slot, 0, value);

    AtomicStore(next_head, head_flag);
    return 1;
}

fn queue_pop(buf: Address, head_flag: Address, tail_flag: Address, capacity: u64) -> u64 {
    tail: u64 = AtomicLoad(tail_flag);
    head: u64 = AtomicLoad(head_flag);

    if tail % capacity == head % capacity {
        return 4294967295;  // Queue is empty — return sentinel
    }

    slot: u64 = buf + (tail % capacity) * 8;
    value: u64 = read_u64_le(slot, 0);

    AtomicStore(tail + 1, tail_flag);
    return value;
}

// ===========================================================================
// Main Entry Point
// ===========================================================================

fn main() -> i32 {
    // Allocate queue components separately
    capacity: u64 = 4;
    buf = allocate(capacity * 8);
    head_flag = allocate(8);
    tail_flag = allocate(8);

    // Initialize head and tail to 0
    AtomicStore(0, head_flag);
    AtomicStore(0, tail_flag);

    // Push two values
    queue_push(buf, head_flag, tail_flag, capacity, 42);
    queue_push(buf, head_flag, tail_flag, capacity, 99);

    // Pop two values
    val1: u64 = queue_pop(buf, head_flag, tail_flag, capacity);
    val2: u64 = queue_pop(buf, head_flag, tail_flag, capacity);

    // Clean up
    free(buf);
    free(head_flag);
    free(tail_flag);

    // Verify results
    if val1 != 42 {
        return 1;
    }
    if val2 != 99 {
        return 2;
    }
    return 0;
}
