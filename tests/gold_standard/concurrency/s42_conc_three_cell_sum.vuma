// s42_conc_three_cell_sum.vuma — three cells, sum = 225 (50 + 75 + 100)
// Expected exit code: 225
//
// Three independent 8-byte cells. Store 50/75/100 via `*ptr = literal`,
// load all, sum -> 225. Uses `*ptr = literal` form. Distinct from
// s38_conc_three_cell_sum and s34_conc_three_cell_sum.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 75;
    *c3 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 225
    free(c1);
    free(c2);
    free(c3);
    return s;
}
