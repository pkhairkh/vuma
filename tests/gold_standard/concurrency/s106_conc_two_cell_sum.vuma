// s106_conc_two_cell_sum.vuma — store 14 + 18 in 2 cells, load and sum = 32
// Expected exit code: 32
//
// Two independent 8-byte cells. Store 14 at c1, store 18 at c2, load each and return the sum (32). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_conc_two_cell_sum (22), s101_conc_two_cell_sum (230), s100_conc_two_cell_diff (36).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 14;
    *c2 = 18;
    a: i32 = *c1;          // 14
    b: i32 = *c2;          // 18
    s: i32 = a + b;        // 32
    free(c1);
    free(c2);
    return s;
}
