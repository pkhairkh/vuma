// s43_conc_overwrite_max.vuma — overwrite 100 -> 255, load 255
// Expected exit code: 255
//
// Single 8-byte cell. Store 100 via `*ptr = literal`, then overwrite
// to 255 (max u8 value), load and return 255. Uses `*ptr = literal`
// form. Distinct from s42_conc_overwrite_middle (170) and
// s38_conc_overwrite_first (130).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 100;
    *c1 = 255;
    v: i32 = *c1;          // 255
    free(c1);
    return v;
}
