// s62_mem_overwrite_middle.vuma — overwrite middle to 90, sum = 170 (20 + 90 + 60)
// Expected exit code: 170
// 
// Three 8-byte cells. Store 20/40/60 via `*ptr = literal`, then
// overwrite the middle cell with 90. Load all three, sum -> 170.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_mem_
// overwrite_first (220), s58_mem_overwrite_last (180) and s55_mem_
// overwrite_last (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 20;
    *p2 = 40;
    *p3 = 60;
    *p2 = 90;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 170
    free(p1);
    free(p2);
    free(p3);
    return s;
}
