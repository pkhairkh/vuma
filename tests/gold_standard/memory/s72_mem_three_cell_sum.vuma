// s72_mem_three_cell_sum.vuma — three cells, sum = 175 (75 + 60 + 40)
// Expected exit code: 175
//
// Three 8-byte cells. Store 75/60/40 via `*ptr = literal`,
// load all three, sum -> 175. Uses `*ptr = literal` form.
// Distinct from s70_mem_three_cell_diff (150), s69_mem_three_
// cell_xor (165) and s66_mem_three_cell_xor (204).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 75;
    *c2 = 60;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 135
    s: u64 = t + c;        // 175
    free(c1);
    free(c2);
    free(c3);
    return s;
}
