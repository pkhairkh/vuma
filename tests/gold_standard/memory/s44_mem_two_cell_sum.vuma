// s44_mem_two_cell_sum.vuma — two cells, sum = 205 (140 + 65)
// Expected exit code: 205
//
// Two 8-byte cells. Store 140/65 via `*ptr = literal`, load both,
// sum -> 205. Uses `*ptr = literal` form (no offsets). Distinct from
// s42_mem_two_cell_sum (200) and s38_mem_two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 140;
    *p2 = 65;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
