// s48_mem_two_cell_sum.vuma — two cells, sum = 220 (100 + 120)
// Expected exit code: 220
//
// Two 8-byte cells. Store 100/120 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form (no offsets). Distinct
// from s46_mem_three_cell_sum (255) and s42_mem_two_cell_sum.

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 120;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
