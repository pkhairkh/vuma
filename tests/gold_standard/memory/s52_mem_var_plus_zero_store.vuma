// s52_mem_var_plus_zero_store.vuma — store via *p = v + 0 = 215
// Expected exit code: 215
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 215 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 215 (the overwritten value).
// Distinct from s50_mem_overwrite_middle (250) and s46_ptr_var_plus_
// zero_store (175).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: u64 = 215;
    *p = v + 0;
    r: u64 = *p;
    free(p);
    return r;
}
