// mem_gather.vuma — gather values from non-contiguous locations
// Expected exit code: 100
//
// Gathers 4 values from non-contiguous offsets (0, 4, 8, 12) in a source
// buffer into a contiguous destination buffer. Then sums them and returns
// the low byte. Values: [10, 20, 30, 40] → sum = 100.

fn main() -> i32 {
    src = allocate(16);
    dst = allocate(4);
    // Source has values at offsets 0, 4, 8, 12
    *(src + 0) = 10;
    *(src + 4) = 20;
    *(src + 8) = 30;
    *(src + 12) = 40;
    // Gather into dst at offsets 0, 1, 2, 3
    v0: u32 = *(src + 0); *(dst + 0) = v0;
    v1: u32 = *(src + 4); *(dst + 1) = v1;
    v2: u32 = *(src + 8); *(dst + 2) = v2;
    v3: u32 = *(src + 12); *(dst + 3) = v3;
    // Sum the gathered values
    d0: u32 = *(dst + 0);
    d1: u32 = *(dst + 1);
    d2: u32 = *(dst + 2);
    d3: u32 = *(dst + 3);
    sum: u32 = d0 + d1 + d2 + d3;
    free(src);
    free(dst);
    return sum;
}
