// s29_mem_two_cell_sum.vuma — two cells, sum = 135 (80 + 55)
// Expected exit code: 135
//
// Two 8-byte cells. Store 80/55 via `*ptr = literal`, load both, sum -> 135. Uses `*ptr = literal` form (no offsets). Distinct from s26_mem_two_cell_xor (xor, 102) and s22_mem_two_cell_diff (sub, 35).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 80;
    *p2 = 55;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;       // 135
    free(p1);
    free(p2);
    return s;
}
