// s74_mem_three_cell_diff.vuma — three cells, diff = 78 (200 - 50 - 72)
// Expected exit code: 78
//
// Three 8-byte cells. Store 200/50/72 via `*ptr = literal`, load
// all three, diff -> 78. Uses `*ptr = literal` form. Distinct
// from s70_mem_three_cell_diff (150), s66_mem_three_cell_xor (90)
// and s62_mem_three_cell_sum (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 50;
    *c3 = 72;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 150
    r: u64 = t - c;        // 78
    free(c1);
    free(c2);
    free(c3);
    return r;
}
