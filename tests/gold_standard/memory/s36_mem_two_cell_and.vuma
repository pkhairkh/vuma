// s36_mem_two_cell_and.vuma — cells 0xF0 and 0x3C, AND = 0x30 = 48
// Expected exit code: 48
//
// Two 8-byte cells. Store 240/60 (0xF0/0x3C) via `*ptr =
// literal`, load both, AND -> 0x30 = 48. All bitwise
// operands loaded into u64 variables first. Uses `*ptr =
// literal` form (no offsets).
// Distinct from s30_mem_two_cell_and (and, 15) and s27_mem_two_cell_and (different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 240;             // 0xF0
    *p2 = 60;              // 0x3C
    a: u64 = *p1;
    b: u64 = *p2;
    r: u64 = a & b;        // 0x30 = 48
    free(p1);
    free(p2);
    return r;
}
