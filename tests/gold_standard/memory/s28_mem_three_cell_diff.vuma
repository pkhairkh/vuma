// s28_mem_three_cell_diff.vuma — three cells, diff = 120 (200 - 50 - 30)
// Expected exit code: 120
//
// Three 8-byte cells. Store 200/50/30 via `*ptr = literal`, load all
// three, subtract the last two from the first -> 120. Uses `*ptr =
// literal` form (no offsets). Distinct from s26_mem_overwrite_middle
// (overwrite pattern, 90) and s22_mem_store_load_lit (single cell).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 200;
    *p2 = 50;
    *p3 = 30;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a - b;       // 150
    s: u64 = t - c;       // 120
    free(p1);
    free(p2);
    free(p3);
    return s;
}
