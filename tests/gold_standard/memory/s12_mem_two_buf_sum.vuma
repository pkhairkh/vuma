// s12_mem_two_buf_sum.vuma — two buffers, sum loads = 80 (35 + 45)
// Expected exit code: 80
//
// Two independent 8-byte buffers. Store 35/45 via `*ptr = literal`
// form (deterministic on the current backend). Both loaded back and
// summed -> 80. Distinct from s9_mem_two_buf_sum (values 11/22 = 33)
// and s4_mem_two_buf_sum (uses *(buf+N) form, values 30/70 = 100).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 35;
    *b = 45;
    va: u64 = *a;
    vb: u64 = *b;
    s: u64 = va + vb;
    free(a);
    free(b);
    return s;
}
