// s26_mem_two_cell_xor.vuma — two cells, xor = 102 (0x33 ^ 0x55 = 0x66)
// Expected exit code: 102
//
// Two 8-byte cells. Store 0x33/0x55 via `*ptr = literal`, load both, XOR
// -> 102. Uses `*ptr = literal` form (no offsets). All operands loaded
// into typed locals before the XOR. Distinct from s22_mem_two_cell_diff
// (sub, 35) and s18_mem_two_cell_sum (sum, 80).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 51;            // 0x33
    *p2 = 85;            // 0x55
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a ^ b;       // 0x66 = 102
    free(p1);
    free(p2);
    return s;
}
