// s88_mem_two_cell_sum.vuma — two cells, sum = 215 (130 + 85)
// Expected exit code: 215
//
// Two 8-byte cells. Store 130/85 via `*ptr = literal`, load
// both, sum -> 215. Uses `*ptr = literal` form (no offsets).
// Distinct from s86_mem_two_cell_sum (205), s82_mem_two_
// cell_sum (145) and s78_mem_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 130;
    *c2 = 85;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 215
    free(c1);
    free(c2);
    return s;
}
