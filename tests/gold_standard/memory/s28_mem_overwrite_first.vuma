// s28_mem_overwrite_first.vuma — overwrite first cell, load = 90
// Expected exit code: 90
//
// Single 8-byte cell. Store 10 via `*ptr = literal`, then overwrite
// with 90 via `*ptr = literal`. Load and return 90. Uses `*ptr =
// literal` form (no offsets). Distinct from s26_mem_store_load_lit
// (single store, 200) and s22_mem_overwrite_load (overwrite pattern).

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 10;
    *p1 = 90;
    a: u64 = *p1;
    free(p1);
    return a;
}
