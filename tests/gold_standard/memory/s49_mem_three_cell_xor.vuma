// s49_mem_three_cell_xor.vuma — three cells, xor = 160 (70 ^ 100 ^ 130)
// Expected exit code: 160
//
// Three 8-byte cells. Store 70/100/130 via `*ptr = literal`, load
// all, xor -> 160. 70 ^ 100 = 34; 34 ^ 130 = 160. Uses `*ptr =
// literal` form (no offsets). Distinct from s46_mem_three_cell_sum
// (255, sum) and s42_mem_three_cell_xor (195, xor).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 70;
    *p2 = 100;
    *p3 = 130;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;
    r: u64 = t ^ c;        // 160
    free(p1);
    free(p2);
    free(p3);
    return r;
}
