// s67_mem_three_cell_sum.vuma — three cells, sum = 180 (60 + 80 + 40)
// Expected exit code: 180
//
// Three 8-byte cells. Store 60/80/40 via `*ptr = literal`,
// load all three, sum -> 60 + 80 + 40 = 180. Uses `*ptr =
// literal` form. Distinct from s66_mem_three_cell_xor (204),
// s62_mem_three_cell_xor (72) and s58_mem_three_cell_or (112).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 80;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 140
    s: u64 = t + c;        // 180
    free(c1);
    free(c2);
    free(c3);
    return s;
}
