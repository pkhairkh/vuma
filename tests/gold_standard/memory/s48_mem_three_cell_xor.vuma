// s48_mem_three_cell_xor.vuma — three cells, xor = 255 (0xC0 ^ 0x30 ^ 0x0F)
// Expected exit code: 255
//
// Three 8-byte cells. Store 192/48/15 (0xC0/0x30/0x0F) via `*ptr =
// literal`, load all, xor -> 0xFF = 255. Uses `*ptr = literal`
// form (no offsets). Distinct from s46_mem_three_cell_sum (255,
// sum vs xor) and s42_mem_three_cell_xor.

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 192;             // 0xC0
    *p2 = 48;              // 0x30
    *p3 = 15;              // 0x0F
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;
    s: u64 = t ^ c;        // 0xFF = 255
    free(p1);
    free(p2);
    free(p3);
    return s;
}
