// mem_ring_buffer_write.vuma — write to ring buffer
// Expected exit code: 0
//
// Simulates a ring buffer with capacity 4. Writes 6 values (with wraparound),
// verifying that the write head advances correctly. The buffer ends up
// holding the last 4 values written: [4, 5, 6, ?]. Actually since we wrap
// at capacity 4, writing 6 values overwrites positions 0 and 1, so the
// final state is [4, 5, 2, 3] (positions 2 and 3 keep the older values).
// We verify position 0 == 4.

fn main() -> i32 {
    buf = allocate(4);
    head: u32 = 0;
    capacity: u32 = 4;
    // Write 6 values: 1, 2, 3, 4, 5, 6
    *(buf + 0) = 1;
    head = (head + 1) & 3;
    *(buf + 1) = 2;
    head = (head + 1) & 3;
    *(buf + 2) = 3;
    head = (head + 1) & 3;
    *(buf + 3) = 4;
    head = (head + 1) & 3;
    *(buf + 0) = 5;  // overwrites position 0
    head = (head + 1) & 3;
    *(buf + 1) = 6;  // overwrites position 1
    head = (head + 1) & 3;
    // Verify position 0 has the latest write (6 if i were 1-based, here it's 5)
    // Wait — we wrote 5 at position 0, then 6 at position 1. Position 0 should be 5.
    v0: u32 = *(buf + 0);
    v1: u32 = *(buf + 1);
    free(buf);
    if v0 == 5 {
        if v1 == 6 { return 0; }
    }
    return 1;
}
