// s4_mem_scatter_three.vuma — store 10, 20, 30 at offsets 0/8/16, sum = 60
// Expected exit code: 60
//
// Allocates a 24-byte buffer, scatters three byte-sized values at
// offsets 0, 8, 16, then loads them all back and sums. Tests offset
// arithmetic and multi-load correctness.

fn main() -> i32 {
    buf = allocate(24);
    *(buf + 0) = 10;
    *(buf + 8) = 20;
    *(buf + 16) = 30;
    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    s: u64 = a + b + c;
    free(buf);
    return s;
}
