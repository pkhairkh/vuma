// mem_multi_alloc.vuma — multiple allocations
// Expected exit code: 60
//
// Allocates 3 buffers, stores distinct values, loads them back, sums.
// Sum = 10 + 20 + 30 = 60.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *a = 10;
    *b = 20;
    *c = 30;
    va: i32 = *a;
    vb: i32 = *b;
    vc: i32 = *c;
    sum: i32 = va + vb + vc;
    free(a);
    free(b);
    free(c);
    return sum;
}
