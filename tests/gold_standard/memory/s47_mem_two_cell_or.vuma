// s47_mem_two_cell_or.vuma — two cells, or = 240 (0xC0 | 0x30)
// Expected exit code: 240
//
// Two 8-byte cells. Store 192/48 (0xC0/0x30) via `*ptr = literal`,
// load both, or -> 240 (0xF0). Uses `*ptr = literal` form (no
// offsets). Distinct from s46_mem_two_cell_xor (255) and s42_mem_
// two_cell_sum (200).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 192;             // 0xC0
    *p2 = 48;              // 0x30
    a: u64 = *p1;
    b: u64 = *p2;
    r: u64 = a | b;        // 0xF0 = 240
    free(p1);
    free(p2);
    return r;
}
