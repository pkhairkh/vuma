// s56_mem_overwrite_first.vuma — overwrite first to 25, sum = 205 (25+100+80)
// Expected exit code: 205
//
// Three 8-byte cells. Store 50/100/80 via `*ptr = literal`, then
// overwrite the first cell with 25. Load all three, sum -> 205. Uses
// `*ptr = literal` form (no offsets). Distinct from s54_mem_overwrite_
// middle (230) and s50_mem_overwrite_middle (250).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 50;
    *p2 = 100;
    *p3 = 80;
    *p1 = 25;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 205
    free(p1);
    free(p2);
    free(p3);
    return s;
}
