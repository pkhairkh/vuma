// s43_mem_three_cell_xor.vuma — three cells, xor = 90 (0xA5 ^ 0x3C ^ 0xC3)
// Expected exit code: 90
//
// Three 8-byte cells. Store 165/60/195 via `*ptr = literal`, load all,
// xor -> 90 (0x5A). Uses `*ptr = literal` form (no offsets). Distinct
// from s42_mem_three_cell_xor (195) and s38_mem_three_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 165;             // 0xA5
    *p2 = 60;              // 0x3C
    *p3 = 195;             // 0xC3
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;        // 0x99 = 153
    r: u64 = t ^ c;        // 0x5A = 90
    free(p1);
    free(p2);
    free(p3);
    return r;
}
