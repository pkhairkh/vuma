// s24_mem_overwrite_last.vuma — overwrite last of two cells, sum = 110 (22 + 88)
// Expected exit code: 110
//
// Two 8-byte cells. Store 22/44, then overwrite the second cell with 88.
// Load both, sum -> 110. Uses `*ptr = literal` form (no offsets).
// Distinct from s22_mem_overwrite_first (overwrites the first cell,
// 25/50 -> 60/50 = 110) and s18_mem_overwrite_load (single-cell
// overwrite, different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 22;
    *p2 = 44;
    *p2 = 88;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;
    free(p1);
    free(p2);
    return s;
}
