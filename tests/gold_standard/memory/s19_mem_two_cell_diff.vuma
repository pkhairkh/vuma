// s19_mem_two_cell_diff.vuma — two cells, diff = 55 (95 - 40)
// Expected exit code: 55
//
// Two 8-byte cells. Store 95/40 via `*ptr = literal`, load both,
// subtract (a - b) -> 55. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_mem_two_cell_sum (31/49 = 80, sum) and
// s14_mem_two_cell_sum (35/55 = 90, sum).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 40;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a - b;
    free(p1);
    free(p2);
    return s;
}
