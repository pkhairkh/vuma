// s20_mem_store_load_lit.vuma — store 91, load 91
// Expected exit code: 91
//
// Single 8-byte cell. Store literal 91 via `*p = 91`, load it back,
// return 91. Most basic store-load round trip via pointer. Distinct from
// s18_mem_store_load_lit (value 73) and s14_mem_store_load_lit (value
// 64).

fn main() -> i32 {
    p = allocate(8);
    *p = 91;
    v: u64 = *p;
    free(p);
    return v;
}
