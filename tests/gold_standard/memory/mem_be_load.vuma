// mem_be_load.vuma — big-endian load
// Expected exit code: 18
//
// Stores the 4 bytes of 0x12345678 in big-endian order, then reassembles
// them into a u32 using big-endian byte order and returns the high byte
// (0x12 = 18).

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 0x12;
    *(buf + 1) = 0x34;
    *(buf + 2) = 0x56;
    *(buf + 3) = 0x78;
    b0: u32 = *(buf + 0);
    b1: u32 = *(buf + 1);
    b2: u32 = *(buf + 2);
    b3: u32 = *(buf + 3);
    result: u32 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
    free(buf);
    return result >> 24;
}
