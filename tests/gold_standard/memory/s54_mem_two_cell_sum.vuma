// s54_mem_two_cell_sum.vuma — two cells, sum = 250 (100 + 150)
// Expected exit code: 250
//
// Two 8-byte cells. Store 100/150 via `*ptr = literal`, load both,
// sum -> 250. Uses `*ptr = literal` form (no offsets). Distinct from
// s50_mem_two_cell_sum (245) and s49_mem_two_cell_sum (230).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 150;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 250
    free(p1);
    free(p2);
    return s;
}
