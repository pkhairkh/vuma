// s45_mem_overwrite_last.vuma — overwrite last to 100, sum = 160 (20 + 40 + 100)
// Expected exit code: 160
//
// Three 8-byte cells. Store 20/40/60 via `*ptr = literal`, then
// overwrite the last cell with 100. Load all three, sum -> 160.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_mem_
// overwrite_middle (210) and s38_mem_overwrite_last (190).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 20;
    *p2 = 40;
    *p3 = 60;
    *p3 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 160
    free(p1);
    free(p2);
    free(p3);
    return s;
}
