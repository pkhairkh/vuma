// s6_mem_load_store_diff.vuma — copy src into dst via var, sum = 20
// Expected exit code: 20  (10 + 10)
//
// Two 8-byte cells. src gets 10. dst gets 70. We load src into a
// variable, then store that variable into dst using the documented
// `*ptr = variable + 0` workaround (plain `*ptr = variable` is
// silently dropped). dst now holds 10 (overwriting 70). Reload both
// and sum -> 10 + 10 = 20. Tests the workaround form across cells.

fn main() -> i32 {
    src = allocate(8);
    dst = allocate(8);
    *(src + 0) = 10;
    *(dst + 0) = 70;
    tmp: u64 = *(src + 0);
    *(dst + 0) = tmp + 0;   // overwrite dst with 10 via workaround
    vsrc: u64 = *(src + 0);
    vdst: u64 = *(dst + 0);
    s: u64 = vsrc + vdst;
    free(src);
    free(dst);
    return s;
}
