// s8_mem_two_buf_add.vuma — two buffers, sum loads = 70 (30 + 40)
// Expected exit code: 70
//
// Two independent 8-byte buffers. Each gets a different literal at
// offset 0. Both loaded back and summed. Distinct from
// s6_mem_two_buf_diff (different values) and s4_mem_two_buf_sum.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 30;
    *b = 40;
    va: i32 = *a;
    vb: i32 = *b;
    s: i32 = va + vb;
    free(a);
    free(b);
    return s;
}
