// s39_mem_store_load_lit.vuma — store 185, load = 185
// Expected exit code: 185
//
// Single 8-byte cell. Store 185 via `*ptr = literal`, load and
// return 185. Uses `*ptr = literal` form (no offsets). Distinct
// from s38_mem_store_load_lit (175) and s34_mem_store_load_lit
// (187).

fn main() -> i32 {
    p = allocate(8);
    *p = 185;
    v: u64 = *p;
    free(p);
    return v;
}
