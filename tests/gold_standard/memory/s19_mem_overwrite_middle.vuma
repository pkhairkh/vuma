// s19_mem_overwrite_middle.vuma — overwrite middle cell, sum = 125 (30 + 5 + 90)
// Expected exit code: 125
//
// Three 8-byte cells. Store 30/60/90 in c1/c2/c3, then overwrite c2
// (the middle cell) with 5. Load all three, sum -> 125. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s18_mem_overwrite_load (single cell overwrite) and
// s14_mem_overwrite_middle (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c3 = 90;
    *c2 = 5;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
