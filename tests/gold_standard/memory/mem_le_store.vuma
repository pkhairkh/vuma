// mem_le_store.vuma — little-endian store (manual byte decomposition)
// Expected exit code: 120
//
// Manually decomposes a u32 (0x12345678) into little-endian bytes and
// stores them, then returns the lowest byte (0x78 = 120).

fn main() -> i32 {
    buf = allocate(8);
    val: u32 = 0x12345678;
    // Little-endian: low byte first
    *(buf + 0) = (val & 255);
    *(buf + 1) = ((val >> 8) & 255);
    *(buf + 2) = ((val >> 16) & 255);
    *(buf + 3) = ((val >> 24) & 255);
    b0: u32 = *(buf + 0);
    free(buf);
    return b0;
}
