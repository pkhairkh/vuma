// s62_mem_two_cell_diff.vuma — two cells, diff = 130 (200 - 70)
// Expected exit code: 130
// 
// Two 8-byte cells. Store 200/70 via `*ptr = literal`, load both,
// subtract -> 130. Uses `*ptr = literal` form (no offsets). Distinct
// from s51_mem_two_cell_diff (90), s58_mem_two_cell_sum (230) and
// s55_mem_two_cell_sum (240).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 70;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 130
    free(p1);
    free(p2);
    return d;
}
