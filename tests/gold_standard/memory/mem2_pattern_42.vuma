// mem2_pattern_42 — fill 4 consecutive bytes with 42, load first
// Expected exit code: 42
//
// Pattern-fill test: writes the same byte value (42) to four consecutive
// offsets, then loads offset 0.  Confirms that bulk pattern writes don't
// corrupt the first byte.  Straight-line code only.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    *(buf + 1) = 42;
    *(buf + 2) = 42;
    *(buf + 3) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
