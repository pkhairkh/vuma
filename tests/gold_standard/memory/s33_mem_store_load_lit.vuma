// s33_mem_store_load_lit.vuma — store 195, load = 195
// Expected exit code: 195
//
// Deterministic test in the memory category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_mem_store_load_lit (value 175) and s26_mem_store_load_lit (different value).
fn main() -> i32 {
    p = allocate(8);
    *p = 195;
    r: i32 = *p;
    free(p);
    return r;
}
