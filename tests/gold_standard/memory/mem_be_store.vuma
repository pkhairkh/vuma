// mem_be_store.vuma — big-endian store
// Expected exit code: 18
//
// Manually decomposes a u32 (0x12345678) into big-endian bytes and stores
// them. Returns the first byte (0x12 = 18).

fn main() -> i32 {
    buf = allocate(8);
    val: u32 = 0x12345678;
    // Big-endian: high byte first
    *(buf + 0) = ((val >> 24) & 255);
    *(buf + 1) = ((val >> 16) & 255);
    *(buf + 2) = ((val >> 8) & 255);
    *(buf + 3) = (val & 255);
    b0: u32 = *(buf + 0);
    free(buf);
    return b0;
}
