// s53_mem_overwrite_first.vuma — overwrite first to 85, sum = 235 (85 + 70 + 80)
// Expected exit code: 235
//
// Three 8-byte cells. Store 30/70/80 via `*ptr = literal`, then
// overwrite the first cell with 85. Load all three, sum -> 235.
// Uses `*ptr = literal` form (no offsets). Distinct from s49_mem_
// overwrite_first (175) and s50_mem_overwrite_middle (250).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 30;
    *p2 = 70;
    *p3 = 80;
    *p1 = 85;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 235
    free(p1);
    free(p2);
    free(p3);
    return s;
}
