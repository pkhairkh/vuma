// s93_mem_three_cell_diff.vuma — three cells, diff = 26 (250 - 200 - 24)
// Expected exit code: 26
//
// Three 8-byte cells. Store 250/200/24 via `*ptr = literal`, load
// all three, a - b - c -> 26. Uses `*ptr = literal` form (no
// offsets). Distinct from s90_mem_three_cell_diff (29), s82_mem_three_cell_diff (230) and s78_mem_three_cell_diff (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 200;
    *c3 = 24;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 26
    free(c1);
    free(c2);
    free(c3);
    return r;
}
