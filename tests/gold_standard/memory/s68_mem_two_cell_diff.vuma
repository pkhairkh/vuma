// s68_mem_two_cell_diff.vuma — two cells, diff = 155 (230 - 75)
// Expected exit code: 155
//
// Two 8-byte cells. Store 230/75 via `*ptr = literal`, load both,
// diff -> 155. Uses `*ptr = literal` form. Distinct from s66_mem_
// two_cell_sum (225), s62_mem_two_cell_diff (130) and s58_mem_two_
// cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 230;
    *c2 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 155
    free(c1);
    free(c2);
    return d;
}
