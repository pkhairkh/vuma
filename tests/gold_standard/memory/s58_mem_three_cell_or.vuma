// s58_mem_three_cell_or.vuma — three cells, or = 112 (0x10 | 0x20 | 0x40)
// Expected exit code: 112
// 
// Three 8-byte cells. Store 16/32/64 via `*ptr = literal`, load all,
// or -> 112 (0x70). 16 | 32 = 48 (0x30); 48 | 64 = 112 (0x70). Uses
// `*ptr = literal` form (no offsets). Distinct from s51_mem_two_cell_
// diff (90), s51_mem_three_cell_xor (192) and s51_mem_overwrite_first
// (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 16;
    *p2 = 32;
    *p3 = 64;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a | b;        // 0x30 = 48
    s: u64 = t | c;        // 0x70 = 112
    free(p1);
    free(p2);
    free(p3);
    return s;
}
