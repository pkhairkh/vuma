// s85_mem_overwrite_last.vuma — store 33 then 178, load = 178
// Expected exit code: 178
//
// Single 8-byte cell. Store 33 via `*ptr = literal`, overwrite
// with 178 via `*ptr = literal` (last write wins). Load and
// return 178. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_mem_overwrite_last (215), s78_mem_overwrite_
// last (3) and s74_mem_overwrite_last (85).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 33;
    *c1 = 178;
    r: u64 = *c1;
    free(c1);
    return r;
}
