// s34_mem_two_cell_sum.vuma — two cells, sum = 195 (95 + 100)
// Expected exit code: 195
//
// Two 8-byte cells. Store 95/100 via `*ptr = literal`, load both,
// sum -> 195. Uses `*ptr = literal` form (no offsets). Distinct
// from s30_mem_two_cell_and (and, 15) and s27_mem_two_cell_sum
// (different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 195
    free(p1);
    free(p2);
    return s;
}
