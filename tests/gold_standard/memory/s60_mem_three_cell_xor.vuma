// s60_mem_three_cell_xor.vuma — three cells, XOR = 119 (0x11 ^ 0x22 ^ 0x44)
// Expected exit code: 119
//
// Three 8-byte cells. Store 17/34/68 (0x11/0x22/0x44) via `*ptr =
// literal`, load all three, XOR -> 119 (0x77). 17 ^ 34 = 51 (0x33);
// 51 ^ 68 = 119 (0x77). Uses `*ptr = literal` form (no offsets).
// Distinct from s58_mem_three_cell_or (112) and s57_mem_three_cell_
// xor (120).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 17;              // 0x11
    *p2 = 34;              // 0x22
    *p3 = 68;              // 0x44
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;        // 0x33 = 51
    s: u64 = t ^ c;        // 0x77 = 119
    free(p1);
    free(p2);
    free(p3);
    return s;
}
