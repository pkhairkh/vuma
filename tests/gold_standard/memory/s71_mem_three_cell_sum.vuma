// s71_mem_three_cell_sum.vuma — three cells, sum = 155 (30 + 50 + 75)
// Expected exit code: 155
//
// Three 8-byte cells. Store 30/50/75 via `*ptr = literal`, load
// all three, sum -> 155. Uses `*ptr = literal` form. Distinct
// from s69_mem_three_cell_xor (165), s70_mem_three_cell_diff (130)
// and s66_mem_three_cell_sum (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 50;
    *c3 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 80
    s: u64 = t + c;        // 155
    free(c1);
    free(c2);
    free(c3);
    return s;
}
