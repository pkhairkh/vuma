// s15_mem_store_load_val.vuma — store 99, load 99
// Expected exit code: 99
//
// Single 8-byte cell. Store literal 99, load back, return. Most basic
// store-load round trip. Uses `*p = literal` form. Distinct from
// s14_mem_store_load_lit (value 88) and s9_mem_load_then_double (load then
// arithmetic).

fn main() -> i32 {
    p = allocate(8);
    *p = 99;
    v: u64 = *p;
    free(p);
    return v;
}
