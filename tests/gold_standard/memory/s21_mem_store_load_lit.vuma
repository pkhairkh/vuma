// s21_mem_store_load_lit.vuma — store 61, load 61
// Expected exit code: 61
//
// Single 8-byte cell. Store literal 61 via `*p = 61`, load it back,
// return 61. Most basic store-load round trip via pointer. Distinct from
// s18_mem_store_load_lit (value 73) and s14_mem_store_load_lit (value 64).

fn main() -> i32 {
    p = allocate(8);
    *p = 61;
    v: u64 = *p;
    free(p);
    return v;
}
