// s95_mem_two_cell_diff.vuma — two cells, diff = 40 (90 - 50)
// Expected exit code: 40
//
// Two 8-byte cells. Store 90/50 via `*ptr = literal`, load both,
// a - b -> 40. Uses `*ptr = literal` form (no offsets). Distinct from
// s94_mem_two_cell_sum (160), s90_mem_two_cell_diff (7) and
// s82_mem_two_cell_sum (145).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 90;
    *c2 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 40
    free(c1);
    free(c2);
    return d;
}
