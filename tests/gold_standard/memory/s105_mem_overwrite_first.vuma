// s105_mem_overwrite_first.vuma — overwrite c1 to 75, load = 75
// Expected exit code: 75
// 
// Three 8-byte cells. Store 100 at c1, store 50 at c2, store 30 at c3, then overwrite c1 to 75. Load c1 -> 75 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_mem_overwrite_last (1), s101_mem_overwrite_middle (33), s100_mem_overwrite_first (71).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c3 = 30;
    *c1 = 75;
    v: u64 = *c1;          // 75
    free(c1);
    free(c2);
    free(c3);
    return v;
}
