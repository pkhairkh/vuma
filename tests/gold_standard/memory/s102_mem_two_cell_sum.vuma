// s102_mem_two_cell_sum.vuma — store 1 + 3 in 2 cells, load and sum = 4
// Expected exit code: 4
//
// Two 8-byte cells. Store 1 at c1, store 3 at c2, load each and return the sum (4). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_mem_overwrite_middle (33), s101_mem_three_cell_diff (100), s101_mem_two_cell_sum (155).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 1;
    *c2 = 3;
    a: u64 = *c1;          // 1
    b: u64 = *c2;          // 3
    s: u64 = a + b;        // 4
    free(c1);
    free(c2);
    return s;
}
