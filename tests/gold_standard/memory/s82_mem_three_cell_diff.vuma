// s82_mem_three_cell_diff.vuma — three cells, diff = 230 (250 - 15 - 5)
// Expected exit code: 230
//
// Three 8-byte cells. Store 250/15/5 via `*ptr = literal`,
// load all three, a - b - c -> 230. Uses `*ptr = literal` form
// (no offsets). Distinct from s78_mem_three_cell_diff (148),
// s74_mem_three_cell_diff (40) and s72_mem_three_cell_diff (30).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 15;
    *c3 = 5;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 230
    free(c1);
    free(c2);
    free(c3);
    return r;
}
