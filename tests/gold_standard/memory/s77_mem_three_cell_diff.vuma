// s77_mem_three_cell_diff.vuma — three cells, diff = 132 (240 - 80 - 28)
// Expected exit code: 132
//
// Three 8-byte cells. Store 240/80/28 via `*ptr = literal`, load
// all three, diff -> 132. Uses `*ptr = literal` form. Distinct
// from s70_mem_three_cell_diff (150), s66_mem_three_cell_xor (90)
// and s74_mem_three_cell_diff (78).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 240;
    *c2 = 80;
    *c3 = 28;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 160
    r: u64 = t - c;        // 132
    free(c1);
    free(c2);
    free(c3);
    return r;
}
