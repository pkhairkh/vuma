// s79_mem_overwrite_first.vuma — store 1, overwrite with 38, load = 38
// Expected exit code: 38
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite
// with 38 via `*ptr = literal`, load and return 38. Uses `*ptr
// = literal` form. Distinct from s78_mem_overwrite_first (3),
// s77_mem_overwrite_first (2) and s76_mem_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 38;
    r: u64 = *c1;          // 38
    free(c1);
    return r;
}
