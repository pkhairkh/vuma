// s47_mem_three_cell_sum.vuma — three cells, sum = 255 (65 + 80 + 110)
// Expected exit code: 255
//
// Three 8-byte cells. Store 65/80/110 via `*ptr = literal`, load all,
// sum -> 255. Uses `*ptr = literal` form (no offsets). Distinct
// from s46_mem_three_cell_sum (40+85+130=255, same total but
// different addends) and s42_mem_three_cell_xor (195).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 65;
    *p2 = 80;
    *p3 = 110;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 255
    free(p1);
    free(p2);
    free(p3);
    return s;
}
