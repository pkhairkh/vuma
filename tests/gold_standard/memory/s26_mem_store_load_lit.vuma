// s26_mem_store_load_lit.vuma — store 200, load = 200
// Expected exit code: 200
//
// Single 8-byte cell. Store the literal 200 via `*ptr = literal`, load
// it back, return. Uses `*ptr = literal` form (no offsets). Distinct
// from s22_mem_store_load_lit (different value) and s18_mem_store_load_lit
// (different value).

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 200;
    a: u64 = *p1;
    free(p1);
    return a;
}
