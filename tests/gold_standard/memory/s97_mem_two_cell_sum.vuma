// s97_mem_two_cell_sum.vuma — two cells, sum = 13 (8 + 5)
// Expected exit code: 13
//
// Two 8-byte cells. Store 8/5 via `*ptr = literal`, load
// both, a + b -> 13. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s94_mem_two_cell_sum (160), s90_mem_overwrite_middle (31), s86_mem_two_cell_sum (205).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 8;
    *c2 = 5;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 13
    free(c1);
    free(c2);
    return s;
}
