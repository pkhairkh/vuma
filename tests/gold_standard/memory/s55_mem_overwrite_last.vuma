// s55_mem_overwrite_last.vuma — overwrite last to 140, sum = 220 (25+55+140)
// Expected exit code: 220
//
// Three 8-byte cells. Store 25/55/75 via `*ptr = literal`, then
// overwrite the last cell with 140. Load all three, sum -> 220.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s54_mem_overwrite_middle (230) and s53_mem_overwrite_first (235).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 25;
    *p2 = 55;
    *p3 = 75;
    *p3 = 140;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 220
    free(p1);
    free(p2);
    free(p3);
    return s;
}
