// s93_mem_two_cell_diff.vuma — two cells, diff = 5 (200 - 195)
// Expected exit code: 5
//
// Two 8-byte cells. Store 200/195 via `*ptr = literal`, load both,
// a - b -> 5. Uses `*ptr = literal` form (no offsets). Distinct from
// s90_mem_two_cell_diff (7), s82_mem_two_cell_sum (145) and s78_mem_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 195;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 5
    free(c1);
    free(c2);
    return d;
}
