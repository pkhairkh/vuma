// mem_reverse_buffer.vuma — reverse buffer contents in place
// Expected exit code: 0
//
// Fills a buffer with values 1..8, reverses in place, verifies the
// reversal: position i should now hold value (8 - i).

fn main() -> i32 {
    buf = allocate(8);
    // Fill with 1..8
    *(buf + 0) = 1;
    *(buf + 1) = 2;
    *(buf + 2) = 3;
    *(buf + 3) = 4;
    *(buf + 4) = 5;
    *(buf + 5) = 6;
    *(buf + 6) = 7;
    *(buf + 7) = 8;
    // Reverse in place
    i: u32 = 0;
    while i < 4 {
        j: u32 = 8 - 1 - i;
        vi: u32 = *(buf + i);
        vj: u32 = *(buf + j);
        *(buf + i) = vj;
        *(buf + j) = vi;
        i = i + 1;
    }
    // Verify: position 0 should be 8, position 7 should be 1
    v0: u32 = *(buf + 0);
    v7: u32 = *(buf + 7);
    free(buf);
    if v0 == 8 {
        if v7 == 1 { return 0; }
    }
    return 1;
}
