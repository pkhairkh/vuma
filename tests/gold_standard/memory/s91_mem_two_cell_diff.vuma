// s91_mem_two_cell_diff.vuma — two cells, diff = 17 (200 - 183)
// Expected exit code: 17
//
// Two 8-byte cells. Store 200/183 via `*ptr = literal`, load both,
// a - b -> 17. Uses `*ptr = literal` form (no offsets). Distinct
// from s90_mem_two_cell_diff (54), s86_mem_two_cell_sum (140) and
// s82_mem_two_cell_sum (160).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 183;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 17
    free(c1);
    free(c2);
    return d;
}
