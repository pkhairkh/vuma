// s23_mem_two_cell_xor.vuma — two cells, xor = 91 (110 ^ 53 = 0x6E ^ 0x35 = 0x5B)
// Expected exit code: 91
//
// Two 8-byte cells. Store 110/53 via `*ptr = literal`, load both, XOR
// -> 91. Uses `*ptr = literal` form (no offsets). All operands loaded
// into typed locals before the XOR (immediate-RHS bitwise drop bug
// workaround). Distinct from s22_mem_two_cell_diff (sub, 90 - 55 = 35)
// and s24_mem_two_cell_sum (40 + 59 = 99).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 110;            // 0x6E
    *p2 = 53;             // 0x35
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a ^ b;       // 0x5B = 91
    free(p1);
    free(p2);
    return s;
}

