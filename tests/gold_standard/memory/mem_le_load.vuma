// mem_le_load.vuma — little-endian load (manual byte assembly)
// Expected exit code: 120
//
// Stores the 4 bytes of 0x12345678 in little-endian order, then reassembles
// them into a u32 and returns the low byte (0x78 = 120).

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 0x78;
    *(buf + 1) = 0x56;
    *(buf + 2) = 0x34;
    *(buf + 3) = 0x12;
    b0: u32 = *(buf + 0);
    b1: u32 = *(buf + 1);
    b2: u32 = *(buf + 2);
    b3: u32 = *(buf + 3);
    result: u32 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    free(buf);
    return result;
}
