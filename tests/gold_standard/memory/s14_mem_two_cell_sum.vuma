// s14_mem_two_cell_sum.vuma — two cells, sum = 90 (35 + 55)
// Expected exit code: 90
//
// Two 8-byte cells. Store 35/55 via `*ptr = literal`, load both,
// sum -> 90. Uses `*ptr = literal` form (no offsets). Distinct from
// s9_mem_two_buf_sum (uses broken *(buf+N) form) and
// s10_mem_quad_buf_sum (four cells via offsets).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 35;
    *p2 = 55;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;
    free(p1);
    free(p2);
    return s;
}
