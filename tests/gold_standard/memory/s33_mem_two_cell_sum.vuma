// s33_mem_two_cell_sum.vuma — two cells, sum = 95 + 110 = 205
// Expected exit code: 205
//
// Deterministic test in the memory category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_mem_two_cell_and (and, 0) and s26_mem_two_cell_sum (different values).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 110;
    a: i32 = *c1;
    b: i32 = *c2;
    s: i32 = a + b;         // 205
    free(c1);
    free(c2);
    return s;
}
