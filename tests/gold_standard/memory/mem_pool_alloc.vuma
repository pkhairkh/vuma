// mem_pool_alloc.vuma — simple pool allocator
// Expected exit code: 0
//
// Implements a simple pool allocator: one large backing buffer divided into
// fixed-size slots (4 bytes each, 4 slots total). Tracks allocation with a
// bitmap-like free list. Allocates 2 slots, writes to them, frees them,
// re-allocates one, verifies.

fn main() -> i32 {
    pool = allocate(16);   // 4 slots × 4 bytes
    free_list = allocate(4);  // 4 bytes, 1 per slot (1 = free, 0 = used)
    // Initialize all slots as free
    *(free_list + 0) = 1;
    *(free_list + 1) = 1;
    *(free_list + 2) = 1;
    *(free_list + 3) = 1;
    // Allocate slot 0 (mark as used)
    *(free_list + 0) = 0;
    *(pool + 0) = 100;
    // Allocate slot 1
    *(free_list + 1) = 0;
    *(pool + 4) = 200;
    // Verify values
    v0: u32 = *(pool + 0);
    v1: u32 = *(pool + 4);
    // Free slot 0
    *(free_list + 0) = 1;
    // Re-allocate slot 0
    *(free_list + 0) = 0;
    *(pool + 0) = 150;
    v0_new: u32 = *(pool + 0);
    free(pool);
    free(free_list);
    if v0 == 100 {
        if v1 == 200 {
            if v0_new == 150 { return 0; }
        }
    }
    return 1;
}
