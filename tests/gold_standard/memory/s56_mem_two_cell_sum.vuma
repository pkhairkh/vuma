// s56_mem_two_cell_sum.vuma — two cells, sum = 250 (110 + 140)
// Expected exit code: 250
//
// Two 8-byte cells. Store 110/140 via `*ptr = literal`, load both,
// sum -> 250. Uses `*ptr = literal` form (no offsets). Distinct from
// s54_mem_two_cell_sum (250) and s50_mem_two_cell_sum (235).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 110;
    *p2 = 140;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 250
    free(p1);
    free(p2);
    return s;
}
