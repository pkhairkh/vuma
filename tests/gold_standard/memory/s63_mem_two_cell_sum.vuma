// s63_mem_two_cell_sum.vuma — two cells, sum = 245 (180 + 65)
// Expected exit code: 245
//
// Two 8-byte cells. Store 180/65 via `*ptr = literal`, load both,
// sum -> 245. Uses `*ptr = literal` form (no offsets). Distinct
// from s51_mem_two_cell_diff (90), s58_mem_two_cell_sum (230) and
// s55_mem_two_cell_sum (240).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 180;
    *p2 = 65;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 245
    free(p1);
    free(p2);
    return s;
}
