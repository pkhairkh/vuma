// s50_mem_three_cell_sum.vuma — three cells, sum = 195 (65 + 90 + 40)
// Expected exit code: 195
//
// Three 8-byte cells. Store 65/90/40 via `*ptr = literal`, load all,
// sum -> 195. Uses `*ptr = literal` form (no offsets). Distinct from
// s46_mem_three_cell_sum (255) and s43_mem_three_cell_xor (90).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 65;
    *p2 = 90;
    *p3 = 40;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 195
    free(p1);
    free(p2);
    free(p3);
    return s;
}
