// s31_mem_store_load_lit.vuma — store 220, load = 220
// Expected exit code: 220
//
// Single 8-byte cell. Store the literal 220 via `*ptr = literal`, load
// it back, return. Uses `*ptr = literal` form (no offsets). Distinct
// from s30_mem_store_load_lit (value 175) and s26_mem_store_load_lit
// (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 220;
    r: i32 = *p;
    free(p);
    return r;
}
