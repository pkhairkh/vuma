// s21_mem_overwrite_load.vuma — store 7 then 79, load = 79
// Expected exit code: 79
//
// Single 8-byte cell. Store literal 7, then overwrite with literal 79
// (last write wins). Load and return 79. Uses `*p = literal` form.
// Distinct from s18_mem_overwrite_load (8 then 92) and
// s14_mem_overwrite_load (5 then 95).

fn main() -> i32 {
    p = allocate(8);
    *p = 7;
    *p = 79;
    v: u64 = *p;
    free(p);
    return v;
}
