// s104_mem_two_cell_sum.vuma — store 14 + 20 in 2 cells, load and sum = 34
// Expected exit code: 34
//
// Two 8-byte cells. Store 14 at c1, store 20 at c2, load each and return the sum (34). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_mem_overwrite_last (1), s102_mem_three_cell_diff (197), s102_mem_two_cell_sum (4).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 14;
    *c2 = 20;
    a: u64 = *c1;          // 14
    b: u64 = *c2;          // 20
    s: u64 = a + b;        // 34
    free(c1);
    free(c2);
    return s;
}
