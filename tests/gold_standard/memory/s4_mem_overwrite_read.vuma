// s4_mem_overwrite_read.vuma — store 50, overwrite with 80, read = 80
// Expected exit code: 80
//
// Writes the literal 50 at offset 0 of an 8-byte buffer, then
// overwrites the same cell with 80, loads it back, returns 80.
// Verifies that subsequent stores to the same cell clobber earlier
// ones.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 50;
    *(buf + 0) = 80;
    v: u64 = *(buf + 0);
    free(buf);
    return v;
}
