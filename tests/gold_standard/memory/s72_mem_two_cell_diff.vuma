// s72_mem_two_cell_diff.vuma — two cells, diff = 135 (230 - 95)
// Expected exit code: 135
//
// Two 8-byte cells. Store 230/95 via `*ptr = literal`, load
// both, diff -> 135. Uses `*ptr = literal` form. Distinct from
// s70_mem_two_cell_sum (105), s69_mem_two_cell_sum (215) and
// s66_mem_two_cell_sum (225).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 230;
    *c2 = 95;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 135
    free(c1);
    free(c2);
    return d;
}
