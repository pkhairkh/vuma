// s8_mem_overwrite_load.vuma — same cell overwritten 3x, last wins = 33
// Expected exit code: 33
//
// One 8-byte cell. Store 11, then 22, then 33. Final load should
// observe 33 (last write wins). Distinct from s6_mem_overwrite_3x
// (different values 10/20/25) — this variant uses *p (no offset).

fn main() -> i32 {
    p = allocate(8);
    *p = 11;
    *p = 22;
    *p = 33;
    v: i32 = *p;
    free(p);
    return v;
}
