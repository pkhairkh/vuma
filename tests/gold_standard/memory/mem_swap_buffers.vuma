// mem_swap_buffers.vuma — swap contents of two buffers
// Expected exit code: 0
//
// Fills buf_a with 1..4 and buf_b with 5..8, swaps them via a temp buffer,
// verifies that buf_a now contains 5..8 and buf_b contains 1..4.

fn main() -> i32 {
    a = allocate(4);
    b = allocate(4);
    tmp = allocate(4);
    *(a + 0) = 1; *(a + 1) = 2; *(a + 2) = 3; *(a + 3) = 4;
    *(b + 0) = 5; *(b + 1) = 6; *(b + 2) = 7; *(b + 3) = 8;
    // Swap: tmp = a; a = b; b = tmp
    i: u32 = 0;
    while i < 4 {
        va: u32 = *(a + i);
        *(tmp + i) = va;
        vb: u32 = *(b + i);
        *(a + i) = vb;
        vt: u32 = *(tmp + i);
        *(b + i) = vt;
        i = i + 1;
    }
    // Verify
    ok: u32 = 1;
    a0: u32 = *(a + 0);
    if a0 != 5 { ok = 0; }
    b0: u32 = *(b + 0);
    if b0 != 1 { ok = 0; }
    free(a);
    free(b);
    free(tmp);
    if ok == 1 { return 0; }
    return 1;
}
