// s49_mem_overwrite_first.vuma — overwrite first to 75, sum = 175 (75 + 45 + 55)
// Expected exit code: 175
//
// Three 8-byte cells. Store 35/45/55 via `*ptr = literal`, then
// overwrite the first cell with 75. Load all three, sum -> 175.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_mem_
// overwrite_last (210, last overwrite) and s42_mem_overwrite_middle
// (210, middle overwrite).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 35;
    *p2 = 45;
    *p3 = 55;
    *p1 = 75;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 175
    free(p1);
    free(p2);
    free(p3);
    return s;
}
