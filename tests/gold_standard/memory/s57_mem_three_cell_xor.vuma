// s57_mem_three_cell_xor.vuma — three cells, XOR = 120 (30 ^ 60 ^ 90)
// Expected exit code: 120
//
// Three 8-byte cells. Store 30/60/90 via `*ptr = literal`, load each,
// XOR -> 120 (30 ^ 60 = 34; 34 ^ 90 = 120). Uses `*ptr = literal`
// form (no offsets). Distinct from s54_mem_three_cell_xor (15) and
// s50_mem_three_cell_xor (60).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 30;
    *p2 = 60;
    *p3 = 90;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    s: u64 = a ^ b;        // 34
    r: u64 = s ^ c;        // 120
    free(p1);
    free(p2);
    free(p3);
    return r;
}
