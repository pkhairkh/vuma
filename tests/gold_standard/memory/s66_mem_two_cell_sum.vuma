// s66_mem_two_cell_sum.vuma — two cells, sum = 225 (120 + 105)
// Expected exit code: 225
//
// Two 8-byte cells. Store 120/105 via `*ptr = literal`, load
// both, sum -> 225. Uses `*ptr = literal` form. Distinct from
// s62_mem_two_cell_diff (130), s58_mem_two_cell_sum (230) and
// s55_mem_two_cell_sum (245).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 120;
    *c2 = 105;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 225
    free(c1);
    free(c2);
    return s;
}
