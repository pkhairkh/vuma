// s32_mem_two_cell_sum.vuma - two cells, sum = 245 (115 + 130)
// Expected exit code: 245
//
// two cells, sum = 245 (115 + 130). All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_mem_two_cell_and (and) and
// s26_mem_two_cell_sum (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 115;
    *c2 = 130;
    a: i32 = *c1;
    b: i32 = *c2;
    s: i32 = a + b;        // 245
    free(c1);
    free(c2);
    return s;
}
