// s22_mem_two_cell_diff.vuma — two cells, diff = 35 (90 - 55)
// Expected exit code: 35
//
// Two 8-byte cells. Store 90/55 via `*ptr = literal`, load both,
// subtract -> 35. Uses `*ptr = literal` form (no offsets). Distinct
// from s18_mem_two_cell_sum (31/49 = 80, add) and s14_mem_two_cell_sum
// (35/55 = 90, add).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 55;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a - b;       // 35
    free(p1);
    free(p2);
    return s;
}
