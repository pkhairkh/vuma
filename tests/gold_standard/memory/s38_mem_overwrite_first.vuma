// s38_mem_overwrite_first.vuma ‚Äî overwrite cell to 195, load = 195
// Expected exit code: 195
//
// Single 8-byte cell. Store 60 via `*ptr = literal`, then overwrite
// to 195 via `*ptr = literal`. Load and return 195. Uses `*ptr =
// literal` form (no offsets). Distinct from s34_mem_overwrite_first
// (210) and s30_mem_two_cell_and.

fn main() -> i32 {
    p = allocate(8);
    *p = 60;
    *p = 195;
    v: u64 = *p;
    free(p);
    return v;
}
