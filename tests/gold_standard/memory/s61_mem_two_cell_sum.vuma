// s61_mem_two_cell_sum.vuma — two cells, sum = 220 (145 + 75)
// Expected exit code: 220
// 
// Two 8-byte cells. Store 145/75 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form (no offsets). Distinct
// from s58_mem_two_cell_sum (230), s58_mem_three_cell_or (112)
// and s58_mem_overwrite_last (180).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 145;
    *p2 = 75;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
