// s10_mem_overwrite_middle.vuma — overwrite middle buffer, sum = 139
// Expected exit code: 139  (10 + 99 + 30)
//
// Three independent 8-byte buffers. Store 10/20/30 via `*ptr` form,
// then overwrite the middle buffer (b) with 99. Load all three, sum
// -> 10 + 99 + 30 = 139. Deterministic on the current backend.
// Distinct from s5_mem_overwrite_at_diff_offsets (overwrites 3 offsets
// in one buf via `*(p+N)`, non-deterministic) and s6_mem_overwrite_3x.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *a = 10;
    *b = 20;
    *c = 30;
    *b = 99;
    va: u64 = *a;
    vb: u64 = *b;
    vc: u64 = *c;
    s: u64 = va + vb + vc;
    free(a);
    free(b);
    free(c);
    return s;
}
