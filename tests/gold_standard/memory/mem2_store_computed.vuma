// mem2_store_computed — store a literal 10, load, return
// Expected exit code: 10
//
// A second basic store/load round-trip with a different value (10) to
// confirm that arbitrary decimal literals survive the store→load path
// and the value isn't truncated or replaced.  Straight-line code only.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 10;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
