// mem_string_copy.vuma — copy string
// Expected exit code: 0
//
// Copies a null-terminated string from src to dst, then verifies the
// copy matches the original.

fn main() -> i32 {
    src = allocate(8);
    dst = allocate(8);
    *(src + 0) = 88; *(src + 1) = 89; *(src + 2) = 90; *(src + 3) = 0;
    // Copy until null terminator (max 8 bytes)
    i: u32 = 0;
    while i < 8 {
        v: u32 = *(src + i);
        *(dst + i) = v;
        if v == 0 { i = 8; } else { i = i + 1; }
    }
    // Verify
    ok: u32 = 1;
    j: u32 = 0;
    while j < 4 {
        vs: u32 = *(src + j);
        vd: u32 = *(dst + j);
        if vs != vd { ok = 0; }
        j = j + 1;
    }
    free(src);
    free(dst);
    if ok == 1 { return 0; }
    return 1;
}
