// s76_mem_three_cell_diff.vuma — three cells, diff = 45 (230 - 90 - 95)
// Expected exit code: 45
//
// Three 8-byte cells. Store 230/90/95 via `*ptr = literal`, load
// all three, diff -> 45. Uses `*ptr = literal` form. Distinct
// from s74_mem_three_cell_diff (78), s73_mem_three_cell_diff
// (131) and s72_mem_three_cell_sum (175).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 230;
    *c2 = 90;
    *c3 = 95;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 140
    r: u64 = t - c;        // 45
    free(c1);
    free(c2);
    free(c3);
    return r;
}
