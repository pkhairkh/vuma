// s73_mem_three_cell_diff.vuma — three cells, diff = 131 (200 - 47 - 22)
// Expected exit code: 131
//
// Three 8-byte cells. Store 200/47/22 via `*ptr = literal`,
// load all three, diff -> 200 - 47 - 22 = 131. Uses `*ptr =
// literal` form. Distinct from s70_mem_three_cell_diff (150),
// s69_mem_three_cell_xor (165) and s66_mem_three_cell_xor (204).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 47;
    *c3 = 22;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 153
    d: u64 = t - c;        // 131
    free(c1);
    free(c2);
    free(c3);
    return d;
}
