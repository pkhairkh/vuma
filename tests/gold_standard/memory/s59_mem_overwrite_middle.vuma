// s59_mem_overwrite_middle.vuma — overwrite middle to 100, sum = 140 (10 + 100 + 30)
// Expected exit code: 140
//
// Three 8-byte cells. Store 10/20/30 via `*ptr = literal`, then
// overwrite the middle cell with 100. Load all three, sum -> 140.
// Uses `*ptr = literal` form (no offsets). Distinct from s58_mem_two_
// cell_sum (230), s58_mem_three_cell_or (112) and s58_mem_overwrite_
// last (180).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 10;
    *p2 = 20;
    *p3 = 30;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 140
    free(p1);
    free(p2);
    free(p3);
    return s;
}
