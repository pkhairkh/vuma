// s68_mem_overwrite_first.vuma — overwrite c1 to 182, load = 182
// Expected exit code: 182
//
// Three 8-byte cells. Store 90/40/70 then overwrite c1 to 182.
// Load c1 -> 182 (the overwritten value). Uses `*ptr = literal`
// form. Distinct from s66_mem_overwrite_last (200), s62_mem_
// overwrite_middle (170) and s58_mem_overwrite_last (180).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 90;
    *c2 = 40;
    *c3 = 70;
    *c1 = 182;
    v: u64 = *c1;          // 182
    free(c1);
    free(c2);
    free(c3);
    return v;
}
