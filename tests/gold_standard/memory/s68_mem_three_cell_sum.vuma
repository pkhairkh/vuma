// s68_mem_three_cell_sum.vuma — three cells, sum = 168 (48 + 52 + 68)
// Expected exit code: 168
//
// Three 8-byte cells. Store 48/52/68 via `*ptr = literal`, load
// all three, sum -> 168. Uses `*ptr = literal` form. Distinct
// from s66_mem_three_cell_xor (204), s62_mem_three_cell_xor (72)
// and s58_mem_three_cell_xor (85).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 48;
    *c2 = 52;
    *c3 = 68;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 168
    free(c1);
    free(c2);
    free(c3);
    return s;
}
