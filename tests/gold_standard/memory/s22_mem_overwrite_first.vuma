// s22_mem_overwrite_first.vuma — overwrite first of two cells, sum = 110 (60 + 50)
// Expected exit code: 110
//
// Two 8-byte cells. Store 25/50, then overwrite the first cell with 60.
// Load both, sum -> 110. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_mem_overwrite_load (single-cell overwrite) and
// s14_mem_overwrite_load (single-cell overwrite, different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 25;
    *p2 = 50;
    *p1 = 60;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;
    free(p1);
    free(p2);
    return s;
}
