// s53_mem_two_cell_diff.vuma — two cells, diff = 150 (230 - 80)
// Expected exit code: 150
//
// Two 8-byte cells. Store 230/80 via `*ptr = literal`, load both,
// diff -> 150. Uses `*ptr = literal` form (no offsets). Distinct
// from s49_mem_two_cell_sum (250) and s50_mem_two_cell_sum (245).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 230;
    *p2 = 80;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 150
    free(p1);
    free(p2);
    return d;
}
