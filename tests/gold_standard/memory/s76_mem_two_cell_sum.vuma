// s76_mem_two_cell_sum.vuma — two cells, sum = 151 (100 + 51)
// Expected exit code: 151
//
// Two 8-byte cells. Store 100/51 via `*ptr = literal`, load
// both, sum -> 151. Uses `*ptr = literal` form. Distinct from
// s74_mem_two_cell_sum (199), s73_mem_two_cell_sum (116) and
// s72_mem_two_cell_diff (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 51;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 151
    free(c1);
    free(c2);
    return s;
}
