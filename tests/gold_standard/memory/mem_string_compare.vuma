// mem_string_compare.vuma — compare two strings
// Expected exit code: 0
//
// Compares two null-terminated strings stored in buffers. Returns 0 if
// equal, 1 if not.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *(a + 0) = 65; *(a + 1) = 66; *(a + 2) = 67; *(a + 3) = 0;
    *(b + 0) = 65; *(b + 1) = 66; *(b + 2) = 67; *(b + 3) = 0;
    equal: u32 = 1;
    i: u32 = 0;
    while i < 4 {
        va: u32 = *(a + i);
        vb: u32 = *(b + i);
        if va != vb { equal = 0; }
        i = i + 1;
    }
    free(a);
    free(b);
    if equal == 1 { return 0; }
    return 1;
}
