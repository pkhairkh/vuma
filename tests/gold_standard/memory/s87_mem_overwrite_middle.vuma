// s87_mem_overwrite_middle.vuma — overwrite c2 to 215, load = 215
// Expected exit code: 215
//
// Three 8-byte cells. Store 60 at c1, store 90 at c2 then
// overwrite c2 to 215, store 180 at c3. Load c2 -> 215 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s86_mem_overwrite_middle (235), s82_mem_overwrite_last
// (245) and s78_mem_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 90;
    *c2 = 215;
    *c3 = 180;
    v: u64 = *c2;          // 215
    free(c1);
    free(c2);
    free(c3);
    return v;
}
