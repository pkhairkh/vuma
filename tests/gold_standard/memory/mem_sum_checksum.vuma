// mem_sum_checksum.vuma — additive checksum
// Expected exit code: 100
//
// Computes an additive byte checksum with a final modulo 256.
// Buffer = [10, 20, 30, 40]. Sum = 100.

fn main() -> i32 {
    buf = allocate(4);
    *(buf + 0) = 10;
    *(buf + 1) = 20;
    *(buf + 2) = 30;
    *(buf + 3) = 40;
    sum: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        v: u32 = *(buf + i);
        sum = sum + v;
        i = i + 1;
    }
    checksum: u32 = sum & 255;
    free(buf);
    return checksum;
}
