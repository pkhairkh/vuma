// s51_mem_three_cell_xor.vuma — three cells, xor = 192 (50 ^ 100 ^ 150)
// Expected exit code: 192
//
// Three 8-byte cells. Store 50/100/150 via `*ptr = literal`, load all,
// xor -> 192 (0xC0). 50 ^ 100 = 86 (0x56); 86 ^ 150 = 192 (0xC0).
// Uses `*ptr = literal` form (no offsets). Distinct from s50_mem_three_
// cell_sum (195) and s47_mem_three_cell_sum (255).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 50;
    *p2 = 100;
    *p3 = 150;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;        // 0x56 = 86
    s: u64 = t ^ c;        // 0xC0 = 192
    free(p1);
    free(p2);
    free(p3);
    return s;
}
