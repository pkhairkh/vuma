// s85_mem_single_store_load.vuma — store 67, load, return 67
// Expected exit code: 67
//
// Single 8-byte cell. Store 67 via `*ptr = literal`, load it
// back, return 67. Uses `*ptr = literal` form (no offsets) to
// avoid the *(ptr+N) store-drop bug. Distinct from
// s82_mem_single_store_load, s78_mem_single_store_load and
// s74_mem_single_store_load.
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 67;
    r: u64 = *c1;
    free(c1);
    return r;
}
