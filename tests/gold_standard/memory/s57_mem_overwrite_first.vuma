// s57_mem_overwrite_first.vuma — overwrite first cell, load = 65
// Expected exit code: 65
//
// Single 8-byte cell. Store 175 via `*ptr = literal`, overwrite with
// 65 via `*ptr = literal`, load -> 65. Uses `*ptr = literal` form
// (no offsets). Distinct from s54_mem_overwrite_middle (230) and
// s50_mem_overwrite_middle (250).

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 175;
    *p1 = 65;
    a: u64 = *p1;          // 65
    free(p1);
    return a;
}
