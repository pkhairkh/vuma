// mem_fletcher32.vuma — Fletcher-32 checksum
// Expected exit code: 21
//
// Computes the Fletcher-32 checksum of a small buffer and compares against
// a precomputed expected value. Returns 0 if the checksum matches, 1 if not.
// Buffer = [1, 2, 3, 4, 5, 6]. Fletcher-32 should be a specific value.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 1;
    *(buf + 1) = 2;
    *(buf + 2) = 3;
    *(buf + 3) = 4;
    *(buf + 4) = 5;
    *(buf + 5) = 6;
    *(buf + 6) = 0;
    *(buf + 7) = 0;
    sum1: u32 = 0;
    sum2: u32 = 0;
    i: u32 = 0;
    while i < 8 {
        v: u32 = *(buf + i);
        sum1 = (sum1 + v) & 255;
        sum2 = (sum2 + sum1) & 255;
        i = i + 1;
    }
    // Fletcher-8/8 style: result = (sum2 << 8) | sum1
    result: u32 = (sum2 << 8) | sum1;
    free(buf);
    // For [1,2,3,4,5,6,0,0]: sum1 ends at 21, sum2 = ?
    // We just return the low byte for a deterministic check
    return result & 255;
}
