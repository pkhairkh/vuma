// s97_mem_three_cell_diff.vuma — three cells, diff = 24 (70 - 30 - 16)
// Expected exit code: 24
//
// Three 8-byte cells. Store 70/30/16 via `*ptr = literal`,
// load all, a - b - c -> 24. Uses `*ptr = literal` form.
// Distinct from s94_mem_overwrite_first (67), s90_mem_three_cell_diff (29), s86_mem_three_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 70;
    *c2 = 30;
    *c3 = 16;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    d: u64 = a - b - c;    // 24
    free(c1);
    free(c2);
    free(c3);
    return d;
}
