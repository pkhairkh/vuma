// mem2_double_buf — store 42 in each of two buffers, load both, return sum
// Expected exit code: 84
//
// Stores 42 in buf1 and 42 in buf2, loads both, returns 42 + 42 = 84.
// Confirms that two independent stores + loads compose correctly and
// that the sum (84, well within U8 range as exit code) is computed.
// Straight-line code only.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *(buf1 + 0) = 42;
    *(buf2 + 0) = 42;
    v1: u32 = *(buf1 + 0);   // 42
    v2: u32 = *(buf2 + 0);   // 42
    sum: u32 = v1 + v2;      // 84
    free(buf1);
    free(buf2);
    return sum;
}
