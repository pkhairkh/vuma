// s84_mem_two_cell_sum.vuma — two cells, sum = 27 (13 + 14)
// Expected exit code: 27
//
// Two 8-byte cells. Store 13/14 via `*ptr = literal`, load
// both, sum -> 27. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_mem_two_cell_sum (145), s78_mem_two_cell_
// sum (2) and s74_mem_two_cell_sum (199).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 13;
    *c2 = 14;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 27
    free(c1);
    free(c2);
    return s;
}
