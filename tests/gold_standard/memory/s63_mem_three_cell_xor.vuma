// s63_mem_three_cell_xor.vuma — three cells, xor = 77 (100 ^ 55 ^ 30)
// Expected exit code: 77
//
// Three 8-byte cells. Store 100/55/30 via `*ptr = literal`, load
// all three, xor -> 77. 100 ^ 55 = 83 (0x53); 83 ^ 30 = 77 (0x4D).
// Uses `*ptr = literal` form (no offsets). Distinct from s51_mem_
// three_cell_xor (192), s58_mem_three_cell_or (112) and s55_mem_
// three_cell_xor (192).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 100;
    *p2 = 55;
    *p3 = 30;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;        // 0x53 = 83
    s: u64 = t ^ c;        // 0x4D = 77
    free(p1);
    free(p2);
    free(p3);
    return s;
}
