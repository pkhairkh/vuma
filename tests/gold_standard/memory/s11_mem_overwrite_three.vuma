// s11_mem_overwrite_three.vuma — store 10/20/30, load = 30
// Expected exit code: 30
//
// Single 8-byte cell. Store 10, then overwrite with 20, then overwrite
// with 30 via `*ptr` form (deterministic). Load returns 30 (last write
// wins, three writes total). Distinct from s10_mem_overwrite_middle
// (overwrites a middle-offset cell) and s6_mem_overwrite_3x (offset-based
// overwrite, non-det).

fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    *p = 20;
    *p = 30;
    v: u64 = *p;
    free(p);
    return v;
}
