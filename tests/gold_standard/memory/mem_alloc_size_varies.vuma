// mem_alloc_size_varies.vuma — various allocation sizes (8, 16, 32, 64, 128, 256)
// Expected exit code: 0
//
// Allocates buffers of various sizes, writes a byte to the last position
// of each, reads it back, verifies, and frees them.

fn main() -> i32 {
    b8 = allocate(8);
    b16 = allocate(16);
    b32 = allocate(32);
    b64 = allocate(64);
    b128 = allocate(128);
    b256 = allocate(256);
    *(b8 + 7) = 1;
    *(b16 + 15) = 2;
    *(b32 + 31) = 3;
    *(b64 + 63) = 4;
    *(b128 + 127) = 5;
    *(b256 + 255) = 6;
    v1: u32 = *(b8 + 7);
    v2: u32 = *(b16 + 15);
    v3: u32 = *(b32 + 31);
    v4: u32 = *(b64 + 63);
    v5: u32 = *(b128 + 127);
    v6: u32 = *(b256 + 255);
    free(b8);
    free(b16);
    free(b32);
    free(b64);
    free(b128);
    free(b256);
    if v1 == 1 {
        if v2 == 2 {
            if v3 == 3 {
                if v4 == 4 {
                    if v5 == 5 {
                        if v6 == 6 { return 0; }
                    }
                }
            }
        }
    }
    return 1;
}
