// s86_mem_three_cell_diff.vuma — three cells, diff = 140 (230 - 60 - 30)
// Expected exit code: 140
//
// Three 8-byte cells. Store 230/60/30 via `*ptr = literal`,
// load all three, a - b - c -> 140. Uses `*ptr = literal` form
// (no offsets). Distinct from s82_mem_three_cell_diff (230),
// s78_mem_three_cell_diff (148) and s74_mem_three_cell_diff (40).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 230;
    *c2 = 60;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 140
    free(c1);
    free(c2);
    free(c3);
    return r;
}
