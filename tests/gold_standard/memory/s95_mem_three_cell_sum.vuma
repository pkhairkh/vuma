// s95_mem_three_cell_sum.vuma — three cells, sum = 52 (13 + 17 + 22)
// Expected exit code: 52
//
// Three 8-byte cells. Store 13/17/22 via `*ptr = literal`, load all
// three, a + b + c -> 52. Uses `*ptr = literal` form. Distinct from
// s94_mem_three_cell_sum (109), s90_mem_three_cell_diff (29) and
// s82_mem_three_cell_diff (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 13;
    *c2 = 17;
    *c3 = 22;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 52
    free(c1);
    free(c2);
    free(c3);
    return s;
}
