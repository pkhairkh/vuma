// s69_mem_three_cell_xor.vuma -- three cells, xor = 165 (0xC3 ^ 0x3C ^ 0x5A)
// Expected exit code: 165
//
// Three 8-byte cells. Store 195/60/90 via `*ptr = literal`, load all,
// xor -> 0xC3 ^ 0x3C ^ 0x5A = 0xFF ^ 0x5A = 0xA5 = 165. Uses `*ptr =
// literal` form. Distinct from s66_mem_three_cell_xor (204), s65_mem_
// three_cell_xor (102) and s64_mem_three_cell_sum (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 195;             // 0xC3
    *c2 = 60;              // 0x3C
    *c3 = 90;              // 0x5A
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a ^ b;        // 0xFF = 255
    r: u64 = t ^ c;        // 0xA5 = 165
    free(c1);
    free(c2);
    free(c3);
    return r;
}
