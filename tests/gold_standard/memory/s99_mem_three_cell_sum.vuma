// s99_mem_three_cell_sum.vuma — three cells, sum = 130 (60 + 50 + 20)
// Expected exit code: 130
//
// Three 8-byte cells. Store 60/50/20 via `*ptr = literal`, load all
// three, a + b + c -> 130. Uses `*ptr = literal` form (no offsets).
// Distinct from s95_mem_three_cell_sum (52),
// s91_mem_three_cell_diff (47) and s87_mem_three_cell_diff (160).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 50;
    *c3 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 130
    free(c1);
    free(c2);
    free(c3);
    return s;
}
