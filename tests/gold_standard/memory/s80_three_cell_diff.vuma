// s80_mem_three_cell_diff.vuma — three cells, diff = 36 (38 - 1 - 1)
// Expected exit code: 36
//
// Three 8-byte cells. Store 38/1/1 via `*ptr = literal`, load
// all three, a - b - c -> 36. Uses `*ptr = literal` form (no
// offsets). Distinct from s78_mem_three_cell_diff (148),
// s74_mem_three_cell_diff (40) and s73_mem_three_cell_diff (60).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 38;
    *c2 = 1;
    *c3 = 1;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 36
    free(c1);
    free(c2);
    free(c3);
    return r;
}
