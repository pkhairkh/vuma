// s98_mem_three_cell_sum.vuma — three cells, sum = 58 (20 + 18 + 20)
// Expected exit code: 58
//
// Three 8-byte cells. Store 20/18/20 via `*ptr = literal`, load all
// three, a + b + c -> 58. Uses `*ptr = literal` form (no offsets).
// Distinct from s94_mem_three_cell_sum (109), s90_mem_three_cell_diff
// (29) and s86_mem_three_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 18;
    *c3 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 58
    free(c1);
    free(c2);
    free(c3);
    return s;
}
