// mem2_store_before_free — store, load, then free; return loaded value
// Expected exit code: 42
//
// Validates that a value loaded BEFORE free is still returned correctly
// after the free() call (i.e., free() doesn't retroactively clobber
// already-loaded values held in registers).  Straight-line code only.

fn main() -> i32 {
    buf = allocate(16);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);   // load before free
    free(buf);
    return val;              // return the pre-free loaded value
}
