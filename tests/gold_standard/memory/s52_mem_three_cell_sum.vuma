// s52_mem_three_cell_sum.vuma — three cells, sum = 180 (50 + 60 + 70)
// Expected exit code: 180
//
// Three 8-byte cells. Store 50/60/70 via `*ptr = literal`, load all
// three, sum -> 180. Uses `*ptr = literal` form (no offsets). Distinct
// from s50_mem_three_cell_sum (195) and s46_mem_two_cell_xor (255).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 50;
    *p2 = 60;
    *p3 = 70;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    s: u64 = a + b + c;    // 180
    free(p1);
    free(p2);
    free(p3);
    return s;
}
