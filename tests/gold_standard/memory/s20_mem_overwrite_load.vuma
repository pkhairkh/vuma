// s20_mem_overwrite_load.vuma — store 11 then overwrite 111, load = 111
// Expected exit code: 111
//
// Single 8-byte cell. Store literal 11, then overwrite with literal 111
// (last write wins). Load and return 111. Uses `*p = literal` form.
// Distinct from s18_mem_overwrite_load (different values) and
// s14_mem_overwrite_load (single-cell overwrite).

fn main() -> i32 {
    p = allocate(8);
    *p = 11;
    *p = 111;
    v: u64 = *p;
    free(p);
    return v;
}
