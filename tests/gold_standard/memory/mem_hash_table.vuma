// mem_hash_table.vuma — simple hash table (open addressing)
// Expected exit code: 0
//
// Implements a tiny hash table with open addressing in a 4-slot buffer.
// Each slot stores a key (we use slot index = key mod 4). Insert 3 keys,
// then look them up.

fn main() -> i32 {
    table = allocate(4);
    // Initialize all slots to "empty" (0xFF)
    *(table + 0) = 255;
    *(table + 1) = 255;
    *(table + 2) = 255;
    *(table + 3) = 255;
    // Insert keys 5, 9, 2 (using key mod 4 as slot)
    // 5 mod 4 = 1, 9 mod 4 = 1 (collision!), 2 mod 4 = 2
    // For 9: probe next slot (2). But 2 is taken by key 2, so probe 3.
    // Wait, key 2 is inserted last. Let me re-order: insert 5, 2, 9.
    // 5 mod 4 = 1 → slot 1
    // 2 mod 4 = 2 → slot 2
    // 9 mod 4 = 1 → collision → slot 2 (taken) → slot 3
    *(table + 1) = 5;
    *(table + 2) = 2;
    *(table + 3) = 9;
    // Lookup 9: probe from slot 1, then 2, then 3 (found).
    key: u32 = 9;
    slot: u32 = key & 3;  // = 1
    found: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        s: u32 = (slot + i) & 3;
        v: u32 = *(table + s);
        if v == key {
            found = 1;
        }
        i = i + 1;
    }
    free(table);
    if found == 1 { return 0; }
    return 1;
}
