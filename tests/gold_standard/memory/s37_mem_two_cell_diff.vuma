// s37_mem_two_cell_diff.vuma — two cells, diff = 220 - 100 = 120
// Expected exit code: 120
//
// Deterministic test in the memory category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_mem_two_cell_sum (sum, 205) and s30_mem_two_cell_and (and, 0).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 100;
    a: i32 = *c1;
    b: i32 = *c2;
    d: i32 = a - b;         // 120
    free(c1);
    free(c2);
    return d;
}
