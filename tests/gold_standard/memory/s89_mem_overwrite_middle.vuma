// s89_mem_overwrite_middle.vuma — overwrite c2 to 23, load = 23
// Expected exit code: 23
//
// Three 8-byte cells. Store 35 at c1, store 65 at c2, then
// overwrite c2 to 23, store 85 at c3. Load c2 -> 23 (the
// overwritten value). Uses `*ptr = literal` form. Distinct from
// s86_mem_overwrite_middle (220), s82_mem_overwrite_middle (215)
// and s78_mem_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 35;
    *c2 = 65;
    *c2 = 23;
    *c3 = 85;
    v: u64 = *c2;          // 23
    free(c1);
    free(c2);
    free(c3);
    return v;
}
