// s54_mem_overwrite_middle.vuma — overwrite middle to 130, sum = 230 (30+130+70)
// Expected exit code: 230
//
// Three 8-byte cells. Store 30/50/70 via `*ptr = literal`, then
// overwrite the middle cell with 130. Load all three, sum -> 230.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_mem_
// overwrite_middle (250) and s49_mem_overwrite_first (230).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 30;
    *p2 = 50;
    *p3 = 70;
    *p2 = 130;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 230
    free(p1);
    free(p2);
    free(p3);
    return s;
}
