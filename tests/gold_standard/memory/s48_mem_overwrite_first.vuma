// s48_mem_overwrite_first.vuma — overwrite first to 80, sum = 240 (80 + 70 + 90)
// Expected exit code: 240
//
// Three 8-byte cells. Store 40/70/90 via `*ptr = literal`, then
// overwrite the first cell with 80. Load all three, sum -> 240.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_mem_
// overwrite_last (210) and s42_mem_overwrite_first.

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 40;
    *p2 = 70;
    *p3 = 90;
    *p1 = 80;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 240
    free(p1);
    free(p2);
    free(p3);
    return s;
}
