// s24_mem_store_load_lit.vuma — store 81, load 81
// Expected exit code: 81
//
// Single 8-byte cell. Store literal 81 via `*p = 81`, load it back,
// return 81. Most basic store-load round trip via pointer. Distinct
// from s22_mem_store_load_lit (value 95) and s18_mem_store_load_lit
// (value 73).

fn main() -> i32 {
    p = allocate(8);
    *p = 81;
    v: u64 = *p;
    free(p);
    return v;
}
