// s40_mem_two_cell_diff.vuma — two cells, diff = 140 (230 - 90)
// Expected exit code: 140
//
// Two 8-byte cells. Store 230/90 via `*ptr = literal`, load both,
// subtract -> 140. Uses `*ptr = literal` form (no offsets). Distinct
// from s38_mem_two_cell_sum (220) and s34_mem_two_cell_sum (195).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 230;
    *p2 = 90;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 140
    free(p1);
    free(p2);
    return d;
}
