// s45_mem_two_cell_diff.vuma — two cells, diff = 150 (190 - 40)
// Expected exit code: 150
//
// Two 8-byte cells. Store 190/40 via `*ptr = literal`, load both,
// subtract -> 150. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_mem_two_cell_sum (sum, 200) and s38_mem_two_cell_diff
// (diff, 130).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 190;
    *p2 = 40;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 150
    free(p1);
    free(p2);
    return d;
}
