// s51_mem_overwrite_first.vuma — overwrite first to 60, sum = 220 (60 + 70 + 90)
// Expected exit code: 220
//
// Three 8-byte cells. Store 30/70/90 via `*ptr = literal`, then
// overwrite the first cell with 60. Load all three, sum -> 220.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_mem_
// overwrite_middle (250) and s47_mem_overwrite_middle (190).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 30;
    *p2 = 70;
    *p3 = 90;
    *p1 = 60;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 220
    free(p1);
    free(p2);
    free(p3);
    return s;
}
