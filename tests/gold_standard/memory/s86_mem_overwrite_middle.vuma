// s86_mem_overwrite_middle.vuma — overwrite c2 to 235, load = 235
// Expected exit code: 235
//
// Three 8-byte cells. Store 50 at c1, store 100 at c2 then
// overwrite c2 to 235, store 200 at c3. Load c2 -> 235 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s82_mem_overwrite_last (245), s78_mem_overwrite_first
// (3) and s74_mem_overwrite_first (155).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c2 = 235;
    *c3 = 200;
    v: u64 = *c2;          // 235
    free(c1);
    free(c2);
    free(c3);
    return v;
}
