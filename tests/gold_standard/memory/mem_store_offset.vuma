// mem_store_offset.vuma — store at computed offset
// Expected exit code: 42
//
// Stores a value at a computed offset (base + 2 * 3 = 6) and loads it back.

fn main() -> i32 {
    buf = allocate(16);
    off: u64 = 2 * 3;  // = 6
    *(buf + off) = 42;
    val: u32 = *(buf + off);
    free(buf);
    return val;
}
