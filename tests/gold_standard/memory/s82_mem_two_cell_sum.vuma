// s82_mem_two_cell_sum.vuma — two cells, sum = 145 (100 + 45)
// Expected exit code: 145
//
// Two 8-byte cells. Store 100/45 via `*ptr = literal`, load
// both, sum -> 145. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_mem_two_cell_sum (2), s74_mem_two_cell_sum
// (110) and s72_mem_two_cell_sum (240).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 45;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 145
    free(c1);
    free(c2);
    return s;
}
