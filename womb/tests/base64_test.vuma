// womb/tests/base64_test.vuma — Test driver for Base64 library
// Expected exit code: 0 (round-trip "Hello" → "SGVsbG8=" → "Hello")

import "../lib/base64.vuma"::{base64_encode, base64_decode};

fn main() -> i32 {
    input = allocate(5);
    *(input + 0) = 72;   // 'H'
    *(input + 1) = 101;  // 'e'
    *(input + 2) = 108;  // 'l'
    *(input + 3) = 108;  // 'l'
    *(input + 4) = 111;  // 'o'

    encoded = allocate(8);
    enclen: u32 = base64_encode(input, 5, encoded);
    if enclen != 8 { free(input); free(encoded); return 1; }

    // Check "SGVsbG8="
    if *(encoded + 0) != 83 { free(input); free(encoded); return 2; }
    if *(encoded + 7) != 61 { free(input); free(encoded); return 3; }

    decoded = allocate(5);
    declen: u32 = base64_decode(encoded, 8, decoded);
    if declen != 5 { free(input); free(encoded); free(decoded); return 4; }

    i: u32 = 0;
    while i < 5 {
        if *(decoded + i) != *(input + i) { free(input); free(encoded); free(decoded); return 5; }
        i = i + 1;
    }

    free(input); free(encoded); free(decoded);
    return 0;
}
