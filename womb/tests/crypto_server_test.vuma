// womb/tests/crypto_server_test.vuma — Real program using womb libraries
// Expected exit code: 0
//
// This program demonstrates a real use case: it imports both the SHA-256
// and Base64 libraries from the womb, hashes a message, and encodes the
// digest as Base64. This is the pattern used by HTTP Basic Auth, JWT,
// and many crypto protocols.

import "../lib/sha256.vuma"::{sha256_oneshot, load_u32_be};
import "../lib/base64.vuma"::{base64_encode};

fn main() -> i32 {
    // Message: "Hello, World!"
    msg = allocate(13);
    *(msg + 0) = 72;   // H
    *(msg + 1) = 101;  // e
    *(msg + 2) = 108;  // l
    *(msg + 3) = 108;  // l
    *(msg + 4) = 111;  // o
    *(msg + 5) = 44;   // ,
    *(msg + 6) = 32;   // (space)
    *(msg + 7) = 87;   // W
    *(msg + 8) = 111;  // o
    *(msg + 9) = 114;  // r
    *(msg + 10) = 108; // l
    *(msg + 11) = 100; // d
    *(msg + 12) = 33;  // !

    // Hash the message
    digest = allocate(32);
    sha256_oneshot(msg, 13, digest);

    // Base64-encode the digest (32 bytes → 44 chars with padding)
    encoded = allocate(48);
    enclen: u32 = base64_encode(digest, 32, encoded);

    // Verify we got 44 bytes of output (32 bytes → ceil(32/3)*4 = 44)
    free(msg);
    free(digest);
    free(encoded);

    if enclen == 44 {
        return 0;
    }
    return 1;
}
