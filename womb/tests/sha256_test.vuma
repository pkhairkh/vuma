// womb/tests/sha256_test.vuma — Test driver for SHA-256 library
// Expected exit code: 0 (SHA-256("abc") matches NIST test vector)
//
// This file imports the SHA-256 library and runs the NIST FIPS 180-4
// test vector: SHA-256("abc") = ba7816bf...

import "../lib/sha256.vuma"::{sha256_oneshot, load_u32_be};

fn main() -> i32 {
    // Test vector: "abc"
    msg = allocate(3);
    *(msg + 0) = 97;  // 'a'
    *(msg + 1) = 98;  // 'b'
    *(msg + 2) = 99;  // 'c'

    out = allocate(32);
    sha256_oneshot(msg, 3, out);

    // Verify first 4 bytes = 0xBA7816BF
    h0: u32 = load_u32_be(out, 0);
    expected: u32 = 3132259095;  // 0xBA7816BF

    free(msg);
    free(out);

    if h0 == expected {
        return 0;
    }
    return 1;
}
