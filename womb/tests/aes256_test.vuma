// womb/tests/aes256_test.vuma — Test driver for AES-256 library
// Expected exit code: 0 (FIPS 197 C.3 test vector passes)

import "../lib/aes256.vuma"::{aes256_encrypt_block};

fn main() -> i32 {
    // Key (32 bytes): 000102...1f
    key = allocate(32);
    i: u32 = 0;
    while i < 32 {
        *(key + i) = i;
        i = i + 1;
    }

    // Plaintext (16 bytes): 00112233445566778899aabbccddeeff
    pt = allocate(16);
    *(pt + 0) = 0x00; *(pt + 1) = 0x11; *(pt + 2) = 0x22; *(pt + 3) = 0x33;
    *(pt + 4) = 0x44; *(pt + 5) = 0x55; *(pt + 6) = 0x66; *(pt + 7) = 0x77;
    *(pt + 8) = 0x88; *(pt + 9) = 0x99; *(pt + 10) = 0xaa; *(pt + 11) = 0xbb;
    *(pt + 12) = 0xcc; *(pt + 13) = 0xdd; *(pt + 14) = 0xee; *(pt + 15) = 0xff;

    ct = allocate(16);
    aes256_encrypt_block(pt, key, ct);

    // Check first 4 bytes = 0x8EA2B7CA
    b0: u32 = *(ct + 0);
    b1: u32 = *(ct + 1);
    b2: u32 = *(ct + 2);
    b3: u32 = *(ct + 3);
    h0: u32 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
    expected: u32 = 2393327434;  // 0x8EA2B7CA

    free(key); free(pt); free(ct);
    if h0 == expected { return 0; }
    return 1;
}
