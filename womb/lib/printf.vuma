                    *(buf + out_pos) = 37;
                    out_pos = out_pos + 1;
                } else if st == SPEC_STR || st == SPEC_CHAR || st == SPEC_PTR {
                    let arg: Address = empty;
                    if str_used == 0 { arg = s1; str_used = 1; }
                    out_pos = emit_str(buf, out_pos, spec_buf, arg);
                } else if st == SPEC_FLOAT || st == SPEC_EXP_LO || st == SPEC_EXP_UP ||
                          st == SPEC_GEXP_LO || st == SPEC_GEXP_UP {
                    let iv: i64 = 0;
                    if int_used == 0 { iv = v1; int_used = 1; }
                    let arg: f64 = iv;  // i64 -> f64 via declaration
                    let pr: u32 = load_u32(spec_buf, 8);
                    let w: u32 = load_u32(spec_buf, 4);
                    let fl: u32 = load_u32(spec_buf, 12);
                    let left: u32 = 0;
                    if (fl & FLAG_LEFT_ALIGN) != 0 { left = 1; }
                    let use_pr: u32 = pr;
                    if pr == PREC_UNSPEC { use_pr = 6; }
                    let mode: u32 = mode_from_spec(st);
                    out_pos = fmt_float_full(buf, out_pos, arg, use_pr, w, mode, left);
                } else {
                    let arg: i64 = 0;
                    if int_used == 0 { arg = v1; int_used = 1; }
                    out_pos = emit_int(buf, out_pos, spec_buf, arg);
                }
            }
        } else {
            *(buf + out_pos) = c;
            out_pos = out_pos + 1;
            p = p + 1;
        }
    }

    *(buf + out_pos) = 0;
    free(spec_buf);
    free(empty);
    return out_pos;
}

fn sprintf_str_int_str(buf: Address, fmt: Address, s1: Address, v1: i64, s2: Address) -> u32 {
    let spec_buf: Address = allocate(20);
    let empty: Address = allocate(1);
    *(empty + 0) = 0;

    let p: u32 = 0;
    let out_pos: u32 = 0;
    let str_used: u32 = 0;
    let int_used: u32 = 0;

    while *(fmt + p) != 0 {
        let c: u32 = *(fmt + p);
        if c == 37 {
            let saved_p: u32 = p;
            let p2: u32 = p + 1;
            let new_p: u32 = parse_spec(fmt, p2, spec_buf);
            let st: u32 = load_u32(spec_buf, 0);
            if st == SPEC_INVALID {
                *(buf + out_pos) = 37;
                out_pos = out_pos + 1;
                p = saved_p + 1;
            } else {
                p = new_p;
                if st == SPEC_PERCENT {
                    *(buf + out_pos) = 37;
                    out_pos = out_pos + 1;
                } else if st == SPEC_STR || st == SPEC_CHAR || st == SPEC_PTR {
                    let arg: Address = empty;
                    if str_used == 0 { arg = s1; str_used = 1; }
                    else if str_used == 1 { arg = s2; str_used = 2; }
                    out_pos = emit_str(buf, out_pos, spec_buf, arg);
                } else if st == SPEC_FLOAT || st == SPEC_EXP_LO || st == SPEC_EXP_UP ||
                          st == SPEC_GEXP_LO || st == SPEC_GEXP_UP {
                    let iv: i64 = 0;
                    if int_used == 0 { iv = v1; int_used = 1; }
                    let arg: f64 = iv;  // i64 -> f64 via declaration
                    let pr: u32 = load_u32(spec_buf, 8);
                    let w: u32 = load_u32(spec_buf, 4);
                    let fl: u32 = load_u32(spec_buf, 12);
                    let left: u32 = 0;
                    if (fl & FLAG_LEFT_ALIGN) != 0 { left = 1; }
                    let use_pr: u32 = pr;
                    if pr == PREC_UNSPEC { use_pr = 6; }
                    let mode: u32 = mode_from_spec(st);
                    out_pos = fmt_float_full(buf, out_pos, arg, use_pr, w, mode, left);
                } else {
                    let arg: i64 = 0;
                    if int_used == 0 { arg = v1; int_used = 1; }
                    out_pos = emit_int(buf, out_pos, spec_buf, arg);
                }
            }
        } else {
            *(buf + out_pos) = c;
            out_pos = out_pos + 1;
            p = p + 1;
        }
    }

    *(buf + out_pos) = 0;
    free(spec_buf);
    free(empty);
    return out_pos;
}

// ===========================================================================
// snprintf_* — bounded sprintf
// ===========================================================================
//
// snprintf returns the number of characters that *would* have been
// written (excluding the null terminator) — matching C99 semantics.
// At most max_len-1 chars are written, plus a null terminator.
// If max_len is 0, nothing is written and the would-be length is returned.

fn snprintf_str(buf: Address, max_len: u32, fmt: Address, s1: Address) -> u32 {
    // Format into a temporary buffer, then copy with the size limit.
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_str(temp, fmt, s1);

    if max_len > 0 {
        let to_copy: u32 = n;
        if to_copy >= max_len { to_copy = max_len - 1; }
        let i: u32 = 0;
        while i < to_copy {
            *(buf + i) = *(temp + i);
            i = i + 1;
        }
        *(buf + to_copy) = 0;
    }

    free(temp);
    return n;
}

// ===========================================================================
// printf_* — format to stdout via write(2)
// ===========================================================================
//
// Each printf_* variant formats into a temporary buffer and then issues
// a single write() syscall on fd=1. The return value is the result of
// write() (bytes written, or -1 on error).

fn printf_str(fmt: Address, s1: Address) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_str(temp, fmt, s1);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}

fn printf_int(fmt: Address, v1: i64) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_int(temp, fmt, v1);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}

fn printf_uint(fmt: Address, v1: u64) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_uint(temp, fmt, v1);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}

fn printf_hex(fmt: Address, v1: u64) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_hex(temp, fmt, v1);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}

fn printf_float(fmt: Address, v1: f64) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_float(temp, fmt, v1);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}

fn printf_str_int(fmt: Address, s1: Address, v1: i64) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_str_int(temp, fmt, s1, v1);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}

fn printf_str_str(fmt: Address, s1: Address, s2: Address) -> i64 {
    let temp: Address = allocate(65536);
    let n: u32 = sprintf_str_str(temp, fmt, s1, s2);
    let wr: i64 = write(STDOUT_FD, temp, n);
    free(temp);
    return wr;
}
