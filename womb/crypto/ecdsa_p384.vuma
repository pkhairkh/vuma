    buf = allocate(48);
    *(buf +  0) = 179; *(buf +  1) =  49; *(buf +  2) =  47; *(buf +  3) = 167;
    *(buf +  4) = 226; *(buf +  5) =  62; *(buf +  6) = 231; *(buf +  7) = 228;
    *(buf +  8) = 152; *(buf +  9) = 142; *(buf + 10) =   5; *(buf + 11) = 107;
