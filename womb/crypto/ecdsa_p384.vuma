// womb/crypto/ecdsa_p384.vuma — ECDSA over NIST P-384 (FIPS 186-4)
// No main() — importable library module.
// Requires: sha384.vuma (sha384_oneshot), hmac.vuma (hmac_sha512).
//
// P-384 parameters (FIPS 186-4 Section D.1.2.4):
//   p = 2^384 - 2^128 - 2^96 + 2^32 - 1
//   a = -3 mod p
//   b = 0xB3312FA7E23EE7E4988E056BE3F82D19181D9C6EFE8141120314088F5013875A
//       C656398D8A2ED19D2A85C8EDD3EC2AEF
//   Gx = 0xAA87CA22BE8B05378EB1C71EF320AD746E1D3B628BA79B9859F741E082542A38
//        5502F25DBF55296C3A545E3872760AB8
//   Gy = 0x3617DE4A96262C6F5D9E98BF9292DC29F8F41DBD289A147CE9DA3113B5F0B8C0
//        0A60B1CE1D7E819D7A431D7C90EA0E5F
//   n  = 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFC7634D81F4372DDF
//        581A0DB248B0A77AECEC196ACCC52973
//
// All scalars and point coordinates are 48-byte (384-bit) big-endian on the
// wire. Internally we operate on 48-byte little-endian limb buffers (6 × u64).
//
// Signing uses RFC 6979 deterministic nonce derivation via HMAC-SHA-512
// (matching the curve strength), with the 384-bit digest truncated to 48 bytes
// for the nonce block.

const MASK64: u64 = ((1 << 63) | ((1 << 63) - 1));

// ===========================================================================
// 384-bit bignum primitives (6 × u64 limbs, little-endian)
// ===========================================================================

fn bn384_load_u64(ptr: Address, off: u32) -> u64 {
    b0: u64 = *(ptr + off);     b1: u64 = *(ptr + off + 1);
    b2: u64 = *(ptr + off + 2); b3: u64 = *(ptr + off + 3);
    b4: u64 = *(ptr + off + 4); b5: u64 = *(ptr + off + 5);
    b6: u64 = *(ptr + off + 6); b7: u64 = *(ptr + off + 7);
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56);
}

fn bn384_store_u64(ptr: Address, off: u32, val: u64) {
    *(ptr + off)     = val & 255;
    *(ptr + off + 1) = (val >> 8) & 255;
    *(ptr + off + 2) = (val >> 16) & 255;
    *(ptr + off + 3) = (val >> 24) & 255;
    *(ptr + off + 4) = (val >> 32) & 255;
    *(ptr + off + 5) = (val >> 40) & 255;
    *(ptr + off + 6) = (val >> 48) & 255;
    *(ptr + off + 7) = (val >> 56) & 255;
}

fn bn384_zero(a: Address) {
    i: u32 = 0;
    while i < 48 { *(a + i) = 0; i = i + 1; }
}

fn bn384_copy(r: Address, a: Address) {
    i: u32 = 0;
    while i < 48 { *(r + i) = *(a + i); i = i + 1; }
}

fn bn384_is_zero(a: Address) -> u32 {
    i: u32 = 0;
    while i < 6 {
        if bn384_load_u64(a, i * 8) != 0 { return 0; }
        i = i + 1;
    }
    return 1;
}

fn bn384_set_u32(r: Address, val: u32) {
    bn384_zero(r);
    *(r + 0) = val & 255;
    *(r + 1) = (val >> 8) & 255;
    *(r + 2) = (val >> 16) & 255;
    *(r + 3) = (val >> 24) & 255;
}

fn bn384_cmp(a: Address, b: Address) -> i32 {
    i: u32 = 5;
    while 1 == 1 {
        av: u64 = bn384_load_u64(a, i * 8);
        bv: u64 = bn384_load_u64(b, i * 8);
        if av > bv { return 1; }
        if av < bv { return -1; }
        if i == 0 { break; }
        i = i - 1;
    }
    return 0;
}

fn bn384_add(r: Address, a: Address, b: Address) -> u32 {
    carry: u64 = 0;
    i: u32 = 0;
    while i < 6 {
        av: u64 = bn384_load_u64(a, i * 8);
        bv: u64 = bn384_load_u64(b, i * 8);
        sum: u64 = av + bv + carry;
        bn384_store_u64(r, i * 8, sum);
        if sum < av { carry = 1; }
        else { carry = 0; }
        i = i + 1;
    }
    return carry;
}

fn bn384_sub(r: Address, a: Address, b: Address) -> u32 {
    borrow: u64 = 0;
    i: u32 = 0;
    while i < 6 {
        av: u64 = bn384_load_u64(a, i * 8);
        bv: u64 = bn384_load_u64(b, i * 8);
        diff: u64 = av - bv - borrow;
        bn384_store_u64(r, i * 8, diff);
        if av < bv { borrow = 1; }
        else { borrow = 0; }
        i = i + 1;
    }
    return borrow;
}

fn bn384_lshift1(r: Address, a: Address) {
    carry: u64 = 0;
    i: u32 = 0;
    while i < 6 {
        v: u64 = bn384_load_u64(a, i * 8);
        bn384_store_u64(r, i * 8, (v << 1) | carry);
        carry = v >> 63;
        i = i + 1;
    }
}

fn bn384_rshift1(r: Address, a: Address) {
    i: u32 = 5;
    while i > 0 {
        hi: u64 = bn384_load_u64(a, i * 8);
        lo: u64 = bn384_load_u64(a, (i - 1) * 8);
        bn384_store_u64(r, i * 8, (hi >> 1) | (lo << 63));
        i = i - 1;
    }
    v0: u64 = bn384_load_u64(a, 0);
    bn384_store_u64(r, 0, v0 >> 1);
}

fn bn384_get_bit(a: Address, bit: u32) -> u32 {
    limb: u32 = bit / 64;
    pos: u32 = bit % 64;
    if limb >= 6 { return 0; }
    v: u64 = bn384_load_u64(a, limb * 8);
    return (v >> pos) & 1;
}

fn bn384_bitlen(a: Address) -> u32 {
    i: u32 = 5;
    while 1 == 1 {
        v: u64 = bn384_load_u64(a, i * 8);
        if v != 0 {
            bits: u32 = 64;
            while bits > 0 {
                if ((v >> (bits - 1)) & 1) == 1 { return i * 64 + bits; }
                bits = bits - 1;
            }
            return i * 64 + 1;
        }
        if i == 0 { break; }
        i = i - 1;
    }
    return 0;
}

fn bn384_mod_add(r: Address, a: Address, b: Address, m: Address) {
    carry: u32 = bn384_add(r, a, b);
    if carry == 1 { bn384_sub(r, r, m); }
    else {
        if bn384_cmp(r, m) >= 0 { bn384_sub(r, r, m); }
    }
}

fn bn384_mod_sub(r: Address, a: Address, b: Address, m: Address) {
    borrow: u32 = bn384_sub(r, a, b);
    if borrow == 1 { bn384_add(r, r, m); }
}

fn bn384_mod_mul(r: Address, a: Address, b: Address, m: Address) {
    bn384_zero(r);
    temp = allocate(48);
    bn384_copy(temp, a);
    bits: u32 = bn384_bitlen(b);
    i: u32 = 0;
    while i < bits {
        if bn384_get_bit(b, i) == 1 {
            bn384_mod_add(r, r, temp, m);
        }
        // temp = 2 * temp mod m
        bn384_mod_add(temp, temp, temp, m);
        i = i + 1;
    }
    free(temp);
}

fn bn384_mod_exp(r: Address, a: Address, exp: Address, m: Address) {
    bn384_zero(r);
    *(r + 0) = 1;
    base = allocate(48);
    bn384_copy(base, a);
    bits: u32 = bn384_bitlen(exp);
    i: u32 = 0;
    while i < bits {
        if bn384_get_bit(exp, i) == 1 {
            tmp = allocate(48);
            bn384_mod_mul(tmp, r, base, m);
            bn384_copy(r, tmp);
            free(tmp);
        }
        tmp2 = allocate(48);
        bn384_mod_mul(tmp2, base, base, m);
        bn384_copy(base, tmp2);
        free(tmp2);
        i = i + 1;
    }
    free(base);
}

// Binary extended GCD modular inverse: r = a^(-1) mod m.
fn bn384_mod_inv(r: Address, a: Address, m: Address) {
    u = allocate(48); v = allocate(48);
    x1 = allocate(48); x2 = allocate(48);
    bn384_copy(u, a);
    bn384_copy(v, m);
    bn384_zero(x2);
    bn384_set_u32(x1, 1);
    while bn384_is_zero(u) == 0 {
        while bn384_get_bit(u, 0) == 0 {
            bn384_rshift1(u, u);
            if bn384_get_bit(x1, 0) == 0 {
                bn384_rshift1(x1, x1);
            } else {
                bn384_add(x1, x1, m);
                bn384_rshift1(x1, x1);
            }
        }
        while bn384_get_bit(v, 0) == 0 {
            bn384_rshift1(v, v);
            if bn384_get_bit(x2, 0) == 0 {
                bn384_rshift1(x2, x2);
            } else {
                bn384_add(x2, x2, m);
                bn384_rshift1(x2, x2);
            }
        }
        if bn384_cmp(u, v) >= 0 {
            bn384_sub(u, u, v);
            borrow: u32 = bn384_sub(x1, x1, x2);
            if borrow == 1 { bn384_add(x1, x1, m); }
        } else {
            bn384_sub(v, v, u);
            borrow2: u32 = bn384_sub(x2, x2, x1);
            if borrow2 == 1 { bn384_add(x2, x2, m); }
        }
    }
    bn384_copy(r, x2);
    free(u); free(v); free(x1); free(x2);
}

// ===========================================================================
// P-384 curve constants (big-endian, 48 bytes each)
// ===========================================================================

fn p384_p_be() -> Address {
    // p = 2^384 - 2^128 - 2^96 + 2^32 - 1
    buf = allocate(48);
    *(buf +  0) = 255; *(buf +  1) = 255; *(buf +  2) = 255; *(buf +  3) = 255;
    *(buf +  4) = 255; *(buf +  5) = 255; *(buf +  6) = 255; *(buf +  7) = 255;
    *(buf +  8) = 255; *(buf +  9) = 255; *(buf + 10) = 255; *(buf + 11) = 255;
    *(buf + 12) = 255; *(buf + 13) = 255; *(buf + 14) = 255; *(buf + 15) = 255;
    *(buf + 16) = 255; *(buf + 17) = 255; *(buf + 18) = 255; *(buf + 19) = 255;
    *(buf + 20) = 255; *(buf + 21) = 255; *(buf + 22) = 255; *(buf + 23) = 255;
    *(buf + 24) = 255; *(buf + 25) = 255; *(buf + 26) = 255; *(buf + 27) = 255;
    *(buf + 28) = 255; *(buf + 29) = 255; *(buf + 30) = 255; *(buf + 31) = 254;
    *(buf + 32) = 255; *(buf + 33) = 255; *(buf + 34) = 255; *(buf + 35) = 255;
    *(buf + 36) =   0; *(buf + 37) =   0; *(buf + 38) =   0; *(buf + 39) =   0;
    *(buf + 40) =   0; *(buf + 41) =   0; *(buf + 42) =   0; *(buf + 43) =   0;
    *(buf + 44) = 255; *(buf + 45) = 255; *(buf + 46) = 255; *(buf + 47) = 255;
    return buf;
}

fn p384_n_be() -> Address {
    buf = allocate(48);
    *(buf +  0) = 255; *(buf +  1) = 255; *(buf +  2) = 255; *(buf +  3) = 255;
    *(buf +  4) = 255; *(buf +  5) = 255; *(buf +  6) = 255; *(buf +  7) = 255;
    *(buf +  8) = 255; *(buf +  9) = 255; *(buf + 10) = 255; *(buf + 11) = 255;
    *(buf + 12) = 255; *(buf + 13) = 255; *(buf + 14) = 255; *(buf + 15) = 255;
    *(buf + 16) = 255; *(buf + 17) = 255; *(buf + 18) = 255; *(buf + 19) = 255;
    *(buf + 20) = 255; *(buf + 21) = 255; *(buf + 22) = 255; *(buf + 23) = 255;
    *(buf + 24) = 255; *(buf + 25) = 255; *(buf + 26) = 255; *(buf + 27) = 255;
    *(buf + 28) = 199; *(buf + 29) =  99; *(buf + 30) =  77; *(buf + 31) = 129;
    *(buf + 32) = 244; *(buf + 33) =  55; *(buf + 34) =  45; *(buf + 35) = 223;
    *(buf + 36) =  88; *(buf + 37) =  26; *(buf + 38) =  13; *(buf + 39) = 178;
    *(buf + 40) =  72; *(buf + 41) = 176; *(buf + 42) = 167; *(buf + 43) = 122;
    *(buf + 44) = 236; *(buf + 45) = 236; *(buf + 46) =  25; *(buf + 47) = 115;
    return buf;
}

