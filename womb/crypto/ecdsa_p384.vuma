}

fn p384_gy_be() -> Address {
    buf = allocate(48);
    *(buf +  0) =  54; *(buf +  1) =  23; *(buf +  2) = 222; *(buf +  3) =  74;
    *(buf +  4) = 150; *(buf +  5) =  38; *(buf +  6) =  44; *(buf +  7) = 111;
    *(buf +  8) =  93; *(buf +  9) = 158; *(buf + 10) = 152; *(buf + 11) = 191;
    *(buf + 12) = 146; *(buf + 13) = 146; *(buf + 14) = 220; *(buf + 15) =  41;
    *(buf + 16) = 248; *(buf + 17) = 244; *(buf + 18) =  29; *(buf + 19) = 189;
    *(buf + 20) =  40; *(buf + 21) = 154; *(buf + 22) =  20; *(buf + 23) = 124;
    *(buf + 24) = 233; *(buf + 25) = 218; *(buf + 26) =  49; *(buf + 27) =  17;
    *(buf + 28) =  59; *(buf + 29) =  95; *(buf + 30) = 240; *(buf + 31) = 184;
    *(buf + 32) = 192; *(buf + 33) =  10; *(buf + 34) =  96; *(buf + 35) = 177;
    *(buf + 36) = 206; *(buf + 37) =  29; *(buf + 38) = 126; *(buf + 39) = 129;
    *(buf + 40) = 157; *(buf + 41) = 122; *(buf + 42) =  67; *(buf + 43) =  29;
    *(buf + 44) = 124; *(buf + 45) = 144; *(buf + 46) = 234; *(buf + 47) =  14;
    *(buf + 44) =  95; *(buf + 45) = 224; *(buf + 46) = 229; *(buf + 47) = 244;
    return buf;
}

fn swap_endian_48(dst: Address, src: Address) {
    i: u32 = 0;
    while i < 48 {
        *(dst + i) = *(src + 47 - i);
        i = i + 1;
    }
}

// ===========================================================================
// Point operations (affine, mod p)
// ===========================================================================

fn p384_is_on_curve(px: Address, py: Address, p_le: Address, b_le: Address) -> u32 {
    y_sq = allocate(48);
    bn384_mod_mul(y_sq, py, py, p_le);
    x_sq = allocate(48);
    bn384_mod_mul(x_sq, px, px, p_le);
    x_cubed = allocate(48);
    bn384_mod_mul(x_cubed, x_sq, px, p_le);
    three_x = allocate(48);
    bn384_mod_add(three_x, px, px, p_le);
    bn384_mod_add(three_x, three_x, px, p_le);
    neg_3x = allocate(48);
    bn384_mod_sub(neg_3x, p_le, three_x, p_le);
    rhs = allocate(48);
    bn384_mod_add(rhs, x_cubed, neg_3x, p_le);
    bn384_mod_add(rhs, rhs, b_le, p_le);

    result: u32 = 0;
    if bn384_cmp(y_sq, rhs) == 0 { result = 1; }

    free(y_sq); free(x_sq); free(x_cubed); free(three_x);
    free(neg_3x); free(rhs);
    return result;
}

fn p384_point_double(rx: Address, ry: Address, px: Address, py: Address, p_le: Address) {
    if bn384_is_zero(px) == 1 {
        if bn384_is_zero(py) == 1 {
            bn384_zero(rx);
            bn384_zero(ry);
            return;
        }
    }
    // a = p - 3
    a_val = allocate(48);
    bn384_copy(a_val, p_le);
    a_lo: u64 = bn384_load_u64(a_val, 0);
    bn384_store_u64(a_val, 0, a_lo - 3);

    t1 = allocate(48);
    bn384_mod_mul(t1, px, px, p_le);
    t2 = allocate(48);
    bn384_mod_add(t2, t1, t1, p_le);
    bn384_mod_add(t2, t2, t1, p_le);
    bn384_mod_add(t2, t2, a_val, p_le);

    t3 = allocate(48);
    bn384_mod_add(t3, py, py, p_le);
    t3_inv = allocate(48);
    bn384_mod_inv(t3_inv, t3, p_le);
    slope = allocate(48);
    bn384_mod_mul(slope, t2, t3_inv, p_le);

    slope_sq = allocate(48);
    bn384_mod_mul(slope_sq, slope, slope, p_le);
    two_x = allocate(48);
    bn384_mod_add(two_x, px, px, p_le);
    bn384_mod_sub(rx, slope_sq, two_x, p_le);

    x_minus_rx = allocate(48);
    bn384_mod_sub(x_minus_rx, px, rx, p_le);
    slope_x = allocate(48);
    bn384_mod_mul(slope_x, slope, x_minus_rx, p_le);
    bn384_mod_sub(ry, slope_x, py, p_le);

    free(a_val); free(t1); free(t2); free(t3); free(t3_inv);
    free(slope); free(slope_sq); free(two_x); free(x_minus_rx); free(slope_x);
}

fn p384_point_add(rx: Address, ry: Address, px: Address, py: Address, qx: Address, qy: Address, p_le: Address) {
    if bn384_is_zero(px) == 1 {
        if bn384_is_zero(py) == 1 {
            bn384_copy(rx, qx);
            bn384_copy(ry, qy);
            return;
        }
    }
    if bn384_is_zero(qx) == 1 {
        if bn384_is_zero(qy) == 1 {
            bn384_copy(rx, px);
            bn384_copy(ry, py);
            return;
        }
    }
    if bn384_cmp(px, qx) == 0 {
        if bn384_cmp(py, qy) == 0 {
            p384_point_double(rx, ry, px, py, p_le);
            return;
        } else {
            bn384_zero(rx);
            bn384_zero(ry);
            return;
        }
    }

    dy = allocate(48); bn384_mod_sub(dy, qy, py, p_le);
    dx = allocate(48); bn384_mod_sub(dx, qx, px, p_le);
    dx_inv = allocate(48); bn384_mod_inv(dx_inv, dx, p_le);
    slope = allocate(48); bn384_mod_mul(slope, dy, dx_inv, p_le);

    slope_sq = allocate(48); bn384_mod_mul(slope_sq, slope, slope, p_le);
    temp = allocate(48); bn384_mod_sub(temp, slope_sq, px, p_le);
    bn384_mod_sub(rx, temp, qx, p_le);

    x_diff = allocate(48); bn384_mod_sub(x_diff, px, rx, p_le);
    slope_x = allocate(48); bn384_mod_mul(slope_x, slope, x_diff, p_le);
    bn384_mod_sub(ry, slope_x, py, p_le);

    free(dy); free(dx); free(dx_inv); free(slope);
    free(slope_sq); free(temp); free(x_diff); free(slope_x);
}

fn p384_scalar_mul(rx: Address, ry: Address, k: Address, px: Address, py: Address, p_le: Address) {
    bn384_zero(rx);
    bn384_zero(ry);
    tx = allocate(48); ty = allocate(48);
    bits: u32 = bn384_bitlen(k);
    if bits == 0 { free(tx); free(ty); return; }
    i: u32 = bits;
    while i > 0 {
        i = i - 1;
        p384_point_double(tx, ty, rx, ry, p_le);
        bn384_copy(rx, tx);
        bn384_copy(ry, ty);
        if bn384_get_bit(k, i) == 1 {
            p384_point_add(tx, ty, rx, ry, px, py, p_le);
            bn384_copy(rx, tx);
            bn384_copy(ry, ty);
        }
    }
    free(tx); free(ty);
}

// ===========================================================================
// RFC 6979 deterministic nonce for P-384 using HMAC-SHA-512 (hlen = 64).
// The 64-byte HMAC output is reduced mod n with rejection.
// ===========================================================================

fn rfc6979_p384_k(x_be: Address, h_be: Address, n_le: Address, k_le: Address) {
    hlen: u32 = 64;
    qlen: u32 = 48;

    V = allocate(hlen);
    K = allocate(hlen);
    i: u32 = 0;
    while i < hlen { *(V + i) = 1; *(K + i) = 0; i = i + 1; }

    // bits2octets(h): h is 48 bytes already; reduce mod n
    h_le = allocate(48);
    swap_endian_48(h_le, h_be);
    if bn384_cmp(h_le, n_le) >= 0 {
        bn384_sub(h_le, h_le, n_le);
    }
    h_be_canon = allocate(48);
    swap_endian_48(h_be_canon, h_le);
    free(h_le);

    // x is 48 bytes already
    x_be_canon = allocate(48);
    bn384_copy(x_be_canon, x_be);

    // K = HMAC_K(V || 0x00 || x || h)
    buf1 = allocate(hlen + 1 + 48 + 48);
    i = 0;
    while i < hlen { *(buf1 + i) = *(V + i); i = i + 1; }
    *(buf1 + hlen) = 0;
    i = 0;
    while i < 48 { *(buf1 + hlen + 1 + i) = *(x_be_canon + i); i = i + 1; }
    i = 0;
    while i < 48 { *(buf1 + hlen + 1 + 48 + i) = *(h_be_canon + i); i = i + 1; }
    hmac_sha512(K, hlen, buf1, hlen + 1 + 96, V);
    i = 0;
    while i < hlen { *(K + i) = *(V + i); i = i + 1; }
    hmac_sha512(K, hlen, buf1, hlen + 1 + 96, K);
    hmac_sha512(K, hlen, V, hlen, V);
    free(buf1);

    // K = HMAC_K(V || 0x01 || x || h)
    buf2 = allocate(hlen + 1 + 48 + 48);
    i = 0;
    while i < hlen { *(buf2 + i) = *(V + i); i = i + 1; }
    *(buf2 + hlen) = 1;
    i = 0;
    while i < 48 { *(buf2 + hlen + 1 + i) = *(x_be_canon + i); i = i + 1; }
    i = 0;
    while i < 48 { *(buf2 + hlen + 1 + 48 + i) = *(h_be_canon + i); i = i + 1; }
    hmac_sha512(K, hlen, buf2, hlen + 1 + 96, K);
    hmac_sha512(K, hlen, V, hlen, V);
    free(buf2);

    // Generate k by concatenating V-blocks until we have qlen bytes
    T = allocate(qlen);
    have: u32 = 0;
    while have < qlen {
        hmac_sha512(K, hlen, V, hlen, V);
        to_copy: u32 = hlen;
        remaining: u32 = qlen - have;
        if remaining < to_copy { to_copy = remaining; }
        i = 0;
        while i < to_copy { *(T + have + i) = *(V + i); i = i + 1; }
        have = have + to_copy;
    }

    swap_endian_48(k_le, T);
    // Reduce k mod n; reject if k == 0 or k >= n
    accepted: u32 = 0;
    attempts: u32 = 0;
    while accepted == 0 && attempts < 32 {
        if bn384_cmp(k_le, n_le) >= 0 {
            bn384_sub(k_le, k_le, n_le);
        }
        if bn384_is_zero(k_le) == 0 {
            accepted = 1;
        } else {
            buf3 = allocate(hlen + 1);
            i = 0;
            while i < hlen { *(buf3 + i) = *(V + i); i = i + 1; }
            *(buf3 + hlen) = 0;
            hmac_sha512(K, hlen, buf3, hlen + 1, K);
            hmac_sha512(K, hlen, V, hlen, V);
            free(buf3);
            // Regenerate T
            have = 0;
            while have < qlen {
                hmac_sha512(K, hlen, V, hlen, V);
                to_copy: u32 = hlen;
                remaining: u32 = qlen - have;
                if remaining < to_copy { to_copy = remaining; }
                i = 0;
                while i < to_copy { *(T + have + i) = *(V + i); i = i + 1; }
                have = have + to_copy;
            }
            swap_endian_48(k_le, T);
        }
        attempts = attempts + 1;
    }

    free(V); free(K); free(h_be_canon); free(x_be_canon); free(T);
}

// ===========================================================================
// ECDSA P-384 Key Generation: Q = d * G
//   privkey_be (in/out) : 48-byte big-endian private scalar (reduced mod n)
//   pubkey_x_be (out)   : 48-byte big-endian Q.x
//   pubkey_y_be (out)   : 48-byte big-endian Q.y
// ===========================================================================

fn ecdsa_p384_keygen(privkey_be: Address, pubkey_x_be: Address, pubkey_y_be: Address) {
    n_be = p384_n_be();
    n_le = allocate(48);
    swap_endian_48(n_le, n_be);
    free(n_be);

    d_le = allocate(48);
    swap_endian_48(d_le, privkey_be);
    if bn384_cmp(d_le, n_le) >= 0 {
        bn384_sub(d_le, d_le, n_le);
    }
    if bn384_is_zero(d_le) == 1 {
        bn384_zero(d_le);
        *(d_le + 0) = 1;
    }

    gx_be = p384_gx_be(); gy_be = p384_gy_be();
    gx_le = allocate(48); gy_le = allocate(48);
    swap_endian_48(gx_le, gx_be);
    swap_endian_48(gy_le, gy_be);
    free(gx_be); free(gy_be);

    p_be = p384_p_be();
    p_le = allocate(48);
    swap_endian_48(p_le, p_be);
    free(p_be);

    qx_le = allocate(48); qy_le = allocate(48);
    p384_scalar_mul(qx_le, qy_le, d_le, gx_le, gy_le, p_le);

    swap_endian_48(pubkey_x_be, qx_le);
    swap_endian_48(pubkey_y_be, qy_le);
    swap_endian_48(privkey_be, d_le);

    free(n_le); free(d_le); free(gx_le); free(gy_le); free(p_le);
    free(qx_le); free(qy_le);
}

// ===========================================================================
// ECDSA P-384 Sign (uses SHA-384 to match curve strength)
// ===========================================================================

fn ecdsa_p384_sign(msg: Address, msg_len: u32, privkey_be: Address, r_out: Address, s_out: Address) {
    h = allocate(48);
    sha384_oneshot(msg, msg_len, h);

    h_le = allocate(48);
    swap_endian_48(h_le, h);
    d_le = allocate(48);
    swap_endian_48(d_le, privkey_be);

    p_be = p384_p_be(); n_be = p384_n_be();
    gx_be = p384_gx_be(); gy_be = p384_gy_be();
    p_le = allocate(48); n_le = allocate(48);
    gx_le = allocate(48); gy_le = allocate(48);
    swap_endian_48(p_le, p_be);
    swap_endian_48(n_le, n_be);
    swap_endian_48(gx_le, gx_be);
    swap_endian_48(gy_le, gy_be);
    free(p_be); free(n_be); free(gx_be); free(gy_be);

    if bn384_cmp(d_le, n_le) >= 0 { bn384_sub(d_le, d_le, n_le); }
    if bn384_cmp(h_le, n_le) >= 0 { bn384_sub(h_le, h_le, n_le); }

    k_le = allocate(48);
    rfc6979_p384_k(privkey_be, h, n_le, k_le);

    rx = allocate(48); ry = allocate(48);
    p384_scalar_mul(rx, ry, k_le, gx_le, gy_le, p_le);

    r_le = allocate(48);
    bn384_copy(r_le, rx);
    if bn384_cmp(r_le, n_le) >= 0 { bn384_sub(r_le, r_le, n_le); }

    k_inv = allocate(48); bn384_mod_inv(k_inv, k_le, n_le);
    rd = allocate(48); bn384_mod_mul(rd, r_le, d_le, n_le);
    h_rd = allocate(48); bn384_mod_add(h_rd, h_le, rd, n_le);
    s_le = allocate(48); bn384_mod_mul(s_le, k_inv, h_rd, n_le);

    swap_endian_48(r_out, r_le);
    swap_endian_48(s_out, s_le);

    free(h); free(h_le); free(d_le); free(p_le); free(n_le);
    free(gx_le); free(gy_le); free(k_le); free(rx); free(ry);
    free(r_le); free(k_inv); free(rd); free(h_rd); free(s_le);
}

// ===========================================================================
// ECDSA P-384 Verify
// ===========================================================================

fn ecdsa_p384_verify(msg: Address, msg_len: u32, pubkey_x_be: Address, pubkey_y_be: Address, r_be: Address, s_be: Address) -> u32 {
    n_be = p384_n_be();
    n_le = allocate(48);
    swap_endian_48(n_le, n_be);
    free(n_be);

    r_le = allocate(48); s_le = allocate(48);
    swap_endian_48(r_le, r_be);
    swap_endian_48(s_le, s_be);

    if bn384_is_zero(r_le) == 1 { free(n_le); free(r_le); free(s_le); return 0; }
    if bn384_is_zero(s_le) == 1 { free(n_le); free(r_le); free(s_le); return 0; }
    if bn384_cmp(r_le, n_le) >= 0 { free(n_le); free(r_le); free(s_le); return 0; }
    if bn384_cmp(s_le, n_le) >= 0 { free(n_le); free(r_le); free(s_le); return 0; }

    h = allocate(48);
    sha384_oneshot(msg, msg_len, h);
    h_le = allocate(48);
    swap_endian_48(h_le, h);
    free(h);
    if bn384_cmp(h_le, n_le) >= 0 { bn384_sub(h_le, h_le, n_le); }

    p_be = p384_p_be(); b_be = p384_b_be();
    gx_be = p384_gx_be(); gy_be = p384_gy_be();
    p_le = allocate(48); b_le = allocate(48);
    gx_le = allocate(48); gy_le = allocate(48);
    swap_endian_48(p_le, p_be);
    swap_endian_48(b_le, b_be);
    swap_endian_48(gx_le, gx_be);
    swap_endian_48(gy_le, gy_be);
    free(p_be); free(b_be); free(gx_be); free(gy_be);

    qx_le = allocate(48); qy_le = allocate(48);
    swap_endian_48(qx_le, pubkey_x_be);
    swap_endian_48(qy_le, pubkey_y_be);

    if p384_is_on_curve(qx_le, qy_le, p_le, b_le) == 0 {
        free(n_le); free(r_le); free(s_le); free(h_le);
        free(p_le); free(b_le); free(gx_le); free(gy_le);
        free(qx_le); free(qy_le);
        return 0;
    }

    w = allocate(48); bn384_mod_inv(w, s_le, n_le);
    u1 = allocate(48); bn384_mod_mul(u1, h_le, w, n_le);
    u2 = allocate(48); bn384_mod_mul(u2, r_le, w, n_le);

    r1x = allocate(48); r1y = allocate(48);
    p384_scalar_mul(r1x, r1y, u1, gx_le, gy_le, p_le);
    r2x = allocate(48); r2y = allocate(48);
    p384_scalar_mul(r2x, r2y, u2, qx_le, qy_le, p_le);
    ptx = allocate(48); pty = allocate(48);
    p384_point_add(ptx, pty, r1x, r1y, r2x, r2y, p_le);

    result: u32 = 0;
    if bn384_is_zero(ptx) == 0 || bn384_is_zero(pty) == 0 {
        v = allocate(48);
        bn384_copy(v, ptx);
        if bn384_cmp(v, n_le) >= 0 { bn384_sub(v, v, n_le); }
        if bn384_cmp(v, r_le) == 0 { result = 1; }
        free(v);
    }

    free(n_le); free(r_le); free(s_le); free(h_le);
    free(p_le); free(b_le); free(gx_le); free(gy_le);
    free(qx_le); free(qy_le); free(w); free(u1); free(u2);
    free(r1x); free(r1y); free(r2x); free(r2y); free(ptx); free(pty);

    return result;
}

// Expose scalar_mul and byte-swap for callers like ecdh_p384 / key_agreement.
fn p384_scalar_mul_wrap(rx: Address, ry: Address, k: Address, px: Address, py: Address, p: Address) {
    p384_scalar_mul(rx, ry, k, px, py, p);
}

fn swap_endian_48_wrap(dst: Address, src: Address) {
    swap_endian_48(dst, src);
}
