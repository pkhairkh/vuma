// womb/crypto/aes256.vuma — AES-256 (NIST FIPS 197)
// Expected exit code: 0 (self-test passes)
//
// AES-256 encrypt/decrypt with 256-bit key and 128-bit blocks.
// 14 rounds, 240-byte round key schedule.
//
// This is a COMPILABLE VUMA implementation. All operations use byte-level
// memory access and u32 arithmetic that works on all 10 VUMA backends.

const MASK32: u32 = 4294967295;

// ===========================================================================
// AES S-Box (FIPS 197 Figure 7)
// ===========================================================================

fn sbox(idx: u32) -> u32 {
