// ===========================================================================
// AES round constants Rcon[i] (FIPS 197 Section 5.2)
// ===========================================================================

fn rcon(idx: u32) -> u32 {
    if idx == 1 { return 1; }
    if idx == 2 { return 2; }
    if idx == 3 { return 4; }
    if idx == 4 { return 8; }
    if idx == 5 { return 16; }
    if idx == 6 { return 32; }
    if idx == 7 { return 64; }
    return 128;
}

// ===========================================================================
// GF(2^8) multiplication (used in MixColumns)
// ===========================================================================

fn xtime(a: u32) -> u32 {
    hi: u32 = (a >> 7) & 1;
    result: u32 = (a << 1) & 255;
    if hi == 1 {
        result = result ^ 27;  // 0x1B = irred poly
    }
    return result;
}

fn gmul(a: u32, b: u32) -> u32 {
    result: u32 = 0;
    x: u32 = a;
    y: u32 = b;
    i: u32 = 0;
    while i < 8 {
        if (y & 1) == 1 {
            result = result ^ x;
        }
        x = xtime(x);
        y = y >> 1;
        i = i + 1;
    }
    return result & 255;
}

// ===========================================================================
// Key Expansion — AES-256: 240 bytes from 32-byte key
// ===========================================================================

fn aes256_key_expansion(key: Address, roundkeys: Address) {
    // First 32 bytes = key
    i: u32 = 0;
    while i < 32 {
        *(roundkeys + i) = *(key + i);
        i = i + 1;
    }

    // Nk=8 (32-byte key), Nb=4, Nr=14
    // Total 240 bytes = 60 words (4 bytes each)
    // i goes from 8 (word 8) to 59 (word 59)
    i = 8;
    while i < 60 {
        // Read word i-1 (4 bytes)
        t0: u32 = *(roundkeys + (i - 1) * 4);
        t1: u32 = *(roundkeys + (i - 1) * 4 + 1);
        t2: u32 = *(roundkeys + (i - 1) * 4 + 2);
        t3: u32 = *(roundkeys + (i - 1) * 4 + 3);

        // temp = word[i-1]
        if i % 8 == 0 {
            // RotWord
            tmp: u32 = t0;
            t0 = t1;
            t1 = t2;
            t2 = t3;
            t3 = tmp;

            // SubWord
            t0 = sbox(t0);
            t1 = sbox(t1);
            t2 = sbox(t2);
            t3 = sbox(t3);

            // XOR Rcon
            rc: u32 = rcon(i / 8);
            t0 = t0 ^ rc;
        } else if i % 8 == 4 {
            // SubWord only (for AES-256)
            t0 = sbox(t0);
            t1 = sbox(t1);
            t2 = sbox(t2);
            t3 = sbox(t3);
        }

        // word[i] = word[i-8] XOR temp
        w0: u32 = *(roundkeys + (i - 8) * 4);
        w1: u32 = *(roundkeys + (i - 8) * 4 + 1);
        w2: u32 = *(roundkeys + (i - 8) * 4 + 2);
        w3: u32 = *(roundkeys + (i - 8) * 4 + 3);

        *(roundkeys + i * 4) = w0 ^ t0;
        *(roundkeys + i * 4 + 1) = w1 ^ t1;
        *(roundkeys + i * 4 + 2) = w2 ^ t2;
        *(roundkeys + i * 4 + 3) = w3 ^ t3;

        i = i + 1;
    }
}

// ===========================================================================
// AddRoundKey — XOR state with round key
// ===========================================================================

fn add_round_key(state: Address, roundkeys: Address, round: u32) {
    offset: u32 = round * 16;
    i: u32 = 0;
    while i < 16 {
        b: u32 = *(state + i);
        k: u32 = *(roundkeys + offset + i);
        *(state + i) = (b ^ k) & 255;
        i = i + 1;
    }
}

// ===========================================================================
// SubBytes
// ===========================================================================

fn sub_bytes(state: Address) {
    i: u32 = 0;
    while i < 16 {
        b: u32 = *(state + i);
        *(state + i) = sbox(b);
        i = i + 1;
    }
}

// ===========================================================================
// ShiftRows
// State is column-major: state[r + 4*c]
// Row r is shifted left by r positions
// ===========================================================================

fn shift_rows(state: Address) {
    // Row 0: no shift
    // Row 1: shift left by 1
    t: u32 = *(state + 1);
    *(state + 1) = *(state + 5);
    *(state + 5) = *(state + 9);
    *(state + 9) = *(state + 13);
    *(state + 13) = t;

    // Row 2: shift left by 2
    t = *(state + 2);
    *(state + 2) = *(state + 10);
    *(state + 10) = t;
    t = *(state + 6);
    *(state + 6) = *(state + 14);
    *(state + 14) = t;

    // Row 3: shift left by 3 (= shift right by 1)
    t = *(state + 15);
    *(state + 15) = *(state + 11);
    *(state + 11) = *(state + 7);
    *(state + 7) = *(state + 3);
    *(state + 3) = t;
}

// ===========================================================================
// MixColumns
// ===========================================================================

fn mix_columns(state: Address) {
    c: u32 = 0;
    while c < 4 {
        s0: u32 = *(state + 4 * c);
        s1: u32 = *(state + 4 * c + 1);
        s2: u32 = *(state + 4 * c + 2);
        s3: u32 = *(state + 4 * c + 3);

        // MixColumns matrix multiply
        // [2 3 1 1]   [s0]
        // [1 2 3 1] × [s1]
        // [1 1 2 3]   [s2]
        // [3 1 1 2]   [s3]

        r0: u32 = gmul(s0, 2) ^ gmul(s1, 3) ^ gmul(s2, 1) ^ gmul(s3, 1);
        r1: u32 = gmul(s0, 1) ^ gmul(s1, 2) ^ gmul(s2, 3) ^ gmul(s3, 1);
        r2: u32 = gmul(s0, 1) ^ gmul(s1, 1) ^ gmul(s2, 2) ^ gmul(s3, 3);
        r3: u32 = gmul(s0, 3) ^ gmul(s1, 1) ^ gmul(s2, 1) ^ gmul(s3, 2);

        *(state + 4 * c) = r0;
        *(state + 4 * c + 1) = r1;
        *(state + 4 * c + 2) = r2;
        *(state + 4 * c + 3) = r3;

        c = c + 1;
    }
}

// ===========================================================================
// AES-256 Encrypt — single 16-byte block
// ===========================================================================

fn aes256_encrypt_block(plaintext: Address, key: Address, ciphertext: Address) {
    // Expand key (240 bytes)
    roundkeys = allocate(240);
    aes256_key_expansion(key, roundkeys);

    // Copy plaintext to state
    state = allocate(16);
    i: u32 = 0;
    while i < 16 {
        *(state + i) = *(plaintext + i);
        i = i + 1;
    }

    // Initial round key addition
    add_round_key(state, roundkeys, 0);

    // Rounds 1..13
    round: u32 = 1;
    while round < 14 {
        sub_bytes(state);
        shift_rows(state);
        mix_columns(state);
        add_round_key(state, roundkeys, round);
        round = round + 1;
    }

    // Final round (no MixColumns)
    sub_bytes(state);
    shift_rows(state);
    add_round_key(state, roundkeys, 14);

    // Copy state to ciphertext
    i = 0;
    while i < 16 {
        *(ciphertext + i) = *(state + i);
        i = i + 1;
    }

    free(roundkeys);
    free(state);
}

// ===========================================================================
// Self-test: FIPS 197 Appendix C.3
// Key:       000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
// Plaintext: 00112233445566778899aabbccddeeff
// Expected:  8ea2b7ca516745bfeafc49904b496089
// ===========================================================================

fn main() -> i32 {
    // Key (32 bytes)
    key = allocate(32);
    i: u32 = 0;
    while i < 32 {
        *(key + i) = i;
        i = i + 1;
    }

    // Plaintext (16 bytes)
    pt = allocate(16);
    *(pt + 0) = 0x00;
    *(pt + 1) = 0x11;
    *(pt + 2) = 0x22;
    *(pt + 3) = 0x33;
    *(pt + 4) = 0x44;
    *(pt + 5) = 0x55;
    *(pt + 6) = 0x66;
    *(pt + 7) = 0x77;
    *(pt + 8) = 0x88;
    *(pt + 9) = 0x99;
    *(pt + 10) = 0xaa;
    *(pt + 11) = 0xbb;
    *(pt + 12) = 0xcc;
    *(pt + 13) = 0xdd;
    *(pt + 14) = 0xee;
    *(pt + 15) = 0xff;

    // Encrypt
    ct = allocate(16);
    aes256_encrypt_block(pt, key, ct);

    // Check first 4 bytes of ciphertext = 0x8EA2B7CA
    b0: u32 = *(ct + 0);
    b1: u32 = *(ct + 1);
    b2: u32 = *(ct + 2);
    b3: u32 = *(ct + 3);
    h0: u32 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;

    expected: u32 = 2393327434;  // 0x8EA2B7CA

    free(key);
    free(pt);
    free(ct);

    if h0 == expected {
        return 0;
    }
    return 1;
}
