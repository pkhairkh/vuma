fn rcon(idx: u32) -> u32 {
    if idx == 1 { return 1; }
    if idx == 2 { return 2; }
    if idx == 3 { return 4; }
    if idx == 4 { return 8; }
    if idx == 5 { return 16; }
    if idx == 6 { return 32; }
    if idx == 7 { return 64; }
    if idx == 8 { return 128; }
    if idx == 9 { return 27; }
    if idx == 10 { return 54; }
    return 0;
}

fn xtime(a: u32) -> u32 {
    hi: u32 = (a >> 7) & 1;
    result: u32 = (a << 1) & 255;
    if hi == 1 { result = result ^ 27; }
    return result;
}

fn gmul(a: u32, b: u32) -> u32 {
    result: u32 = 0;
    x: u32 = a;
    y: u32 = b;
    i: u32 = 0;
    while i < 8 {
        if (y & 1) == 1 { result = result ^ x; }
        x = xtime(x);
        y = y >> 1;
        i = i + 1;
    }
    return result & 255;
}

// ===========================================================================
// AES-128 Key Expansion (Nk=4, Nr=10, 176 bytes)
// ===========================================================================

fn aes128_key_expansion(key: Address, roundkeys: Address) {
    i: u32 = 0;
    while i < 16 { *(roundkeys + i) = *(key + i); i = i + 1; }

    i = 4;
    while i < 44 {
        t0: u32 = *(roundkeys + (i - 1) * 4);
        t1: u32 = *(roundkeys + (i - 1) * 4 + 1);
        t2: u32 = *(roundkeys + (i - 1) * 4 + 2);
        t3: u32 = *(roundkeys + (i - 1) * 4 + 3);

        if i % 4 == 0 {
            // RotWord
            tmp: u32 = t0;
            t0 = t1; t1 = t2; t2 = t3; t3 = tmp;
            // SubWord
            t0 = sbox(t0); t1 = sbox(t1); t2 = sbox(t2); t3 = sbox(t3);
            t0 = t0 ^ rcon(i / 4);
        }

        w0: u32 = *(roundkeys + (i - 4) * 4);
        w1: u32 = *(roundkeys + (i - 4) * 4 + 1);
        w2: u32 = *(roundkeys + (i - 4) * 4 + 2);
        w3: u32 = *(roundkeys + (i - 4) * 4 + 3);

        *(roundkeys + i * 4) = w0 ^ t0;
        *(roundkeys + i * 4 + 1) = w1 ^ t1;
        *(roundkeys + i * 4 + 2) = w2 ^ t2;
        *(roundkeys + i * 4 + 3) = w3 ^ t3;

        i = i + 1;
    }
}

// ===========================================================================
// AES-128 forward operations
// ===========================================================================

fn add_round_key(state: Address, roundkeys: Address, round: u32) {
    offset: u32 = round * 16;
    i: u32 = 0;
    while i < 16 {
        *(state + i) = (*(state + i) ^ *(roundkeys + offset + i)) & 255;
        i = i + 1;
    }
}

fn sub_bytes(state: Address) {
    i: u32 = 0;
    while i < 16 { *(state + i) = sbox(*(state + i)); i = i + 1; }
}

fn inv_sub_bytes(state: Address) {
    i: u32 = 0;
    while i < 16 { *(state + i) = inv_sbox(*(state + i)); i = i + 1; }
}

fn shift_rows(state: Address) {
    t: u32 = *(state + 1);
    *(state + 1) = *(state + 5); *(state + 5) = *(state + 9);
    *(state + 9) = *(state + 13); *(state + 13) = t;
    t = *(state + 2); *(state + 2) = *(state + 10); *(state + 10) = t;
    t = *(state + 6); *(state + 6) = *(state + 14); *(state + 14) = t;
    t = *(state + 15); *(state + 15) = *(state + 11); *(state + 11) = *(state + 7);
    *(state + 7) = *(state + 3); *(state + 3) = t;
}

fn inv_shift_rows(state: Address) {
    t: u32 = *(state + 13);
    *(state + 13) = *(state + 9); *(state + 9) = *(state + 5);
    *(state + 5) = *(state + 1); *(state + 1) = t;
    t = *(state + 2); *(state + 2) = *(state + 10); *(state + 10) = t;
    t = *(state + 6); *(state + 6) = *(state + 14); *(state + 14) = t;
    t = *(state + 3);
    *(state + 3) = *(state + 7); *(state + 7) = *(state + 11);
    *(state + 11) = *(state + 15); *(state + 15) = t;
}

fn mix_columns(state: Address) {
    c: u32 = 0;
    while c < 4 {
        s0: u32 = *(state + 4 * c); s1: u32 = *(state + 4 * c + 1);
        s2: u32 = *(state + 4 * c + 2); s3: u32 = *(state + 4 * c + 3);
        *(state + 4 * c) = gmul(s0, 2) ^ gmul(s1, 3) ^ gmul(s2, 1) ^ gmul(s3, 1);
        *(state + 4 * c + 1) = gmul(s0, 1) ^ gmul(s1, 2) ^ gmul(s2, 3) ^ gmul(s3, 1);
        *(state + 4 * c + 2) = gmul(s0, 1) ^ gmul(s1, 1) ^ gmul(s2, 2) ^ gmul(s3, 3);
        *(state + 4 * c + 3) = gmul(s0, 3) ^ gmul(s1, 1) ^ gmul(s2, 1) ^ gmul(s3, 2);
        c = c + 1;
    }
}

fn inv_mix_columns(state: Address) {
    c: u32 = 0;
    while c < 4 {
        s0: u32 = *(state + 4 * c); s1: u32 = *(state + 4 * c + 1);
        s2: u32 = *(state + 4 * c + 2); s3: u32 = *(state + 4 * c + 3);
        *(state + 4 * c) = gmul(s0, 14) ^ gmul(s1, 11) ^ gmul(s2, 13) ^ gmul(s3, 9);
        *(state + 4 * c + 1) = gmul(s0, 9) ^ gmul(s1, 14) ^ gmul(s2, 11) ^ gmul(s3, 13);
        *(state + 4 * c + 2) = gmul(s0, 13) ^ gmul(s1, 9) ^ gmul(s2, 14) ^ gmul(s3, 11);
        *(state + 4 * c + 3) = gmul(s0, 11) ^ gmul(s1, 13) ^ gmul(s2, 9) ^ gmul(s3, 14);
        c = c + 1;
    }
}

// ===========================================================================
// AES-128 Encrypt block
// ===========================================================================

fn aes128_encrypt_block(plaintext: Address, key: Address, ciphertext: Address) {
    roundkeys = allocate(176);
    aes128_key_expansion(key, roundkeys);

    state = allocate(16);
    i: u32 = 0;
    while i < 16 { *(state + i) = *(plaintext + i); i = i + 1; }

    add_round_key(state, roundkeys, 0);

    round: u32 = 1;
    while round < 10 {
        sub_bytes(state);
        shift_rows(state);
        mix_columns(state);
        add_round_key(state, roundkeys, round);
        round = round + 1;
    }

    sub_bytes(state);
    shift_rows(state);
    add_round_key(state, roundkeys, 10);

    i = 0;
    while i < 16 { *(ciphertext + i) = *(state + i); i = i + 1; }

    free(roundkeys); free(state);
}

// ===========================================================================
// AES-128 Decrypt block (inverse cipher)
// ===========================================================================

fn aes128_decrypt_block(ciphertext: Address, key: Address, plaintext: Address) {
    roundkeys = allocate(176);
    aes128_key_expansion(key, roundkeys);

    state = allocate(16);
    i: u32 = 0;
    while i < 16 { *(state + i) = *(ciphertext + i); i = i + 1; }

    // Initial round key (last round key)
    add_round_key(state, roundkeys, 10);

    // Rounds 9 down to 1
    round: u32 = 9;
    while round >= 1 {
        inv_shift_rows(state);
        inv_sub_bytes(state);
        add_round_key(state, roundkeys, round);
        inv_mix_columns(state);
        round = round - 1;
    }

    // Final round (no InvMixColumns)
    inv_shift_rows(state);
    inv_sub_bytes(state);
    add_round_key(state, roundkeys, 0);

    i = 0;
    while i < 16 { *(plaintext + i) = *(state + i); i = i + 1; }

    free(roundkeys); free(state);
}

// ===========================================================================
// AES-128-CBC encrypt/decrypt with PKCS#7 padding
// ===========================================================================

fn aes128_cbc_encrypt(plaintext: Address, pt_len: u32, key: Address, iv: Address, ciphertext: Address) -> u32 {
    pad_byte: u32 = 16 - (pt_len % 16);
    if pad_byte == 0 { pad_byte = 16; }
    padded_len: u32 = pt_len + pad_byte;

    padded = allocate(padded_len);
    i: u32 = 0;
    while i < pt_len { *(padded + i) = *(plaintext + i); i = i + 1; }
    while i < padded_len { *(padded + i) = pad_byte & 255; i = i + 1; }

    prev = allocate(16);
    i = 0;
    while i < 16 { *(prev + i) = *(iv + i); i = i + 1; }

    block_idx: u32 = 0;
    while block_idx < padded_len {
        xored = allocate(16);
        i = 0;
        while i < 16 {
            *(xored + i) = (*(padded + block_idx + i) ^ *(prev + i)) & 255;
            i = i + 1;
        }
        ct_block = allocate(16);
        aes128_encrypt_block(xored, key, ct_block);
        i = 0;
        while i < 16 {
            *(ciphertext + block_idx + i) = *(ct_block + i);
            *(prev + i) = *(ct_block + i);
            i = i + 1;
        }
        free(xored); free(ct_block);
        block_idx = block_idx + 16;
    }

    free(padded); free(prev);
    return padded_len;
}

fn aes128_cbc_decrypt(ciphertext: Address, ct_len: u32, key: Address, iv: Address, plaintext: Address) -> u32 {
    prev = allocate(16);
    i: u32 = 0;
    while i < 16 { *(prev + i) = *(iv + i); i = i + 1; }

    block_idx: u32 = 0;
    while block_idx < ct_len {
        pt_block = allocate(16);
        aes128_decrypt_block(ciphertext + block_idx, key, pt_block);
        i = 0;
        while i < 16 {
            *(plaintext + block_idx + i) = (*(pt_block + i) ^ *(prev + i)) & 255;
            i = i + 1;
        }
        i = 0;
        while i < 16 { *(prev + i) = *(ciphertext + block_idx + i); i = i + 1; }
        free(pt_block);
        block_idx = block_idx + 16;
    }

    // Remove PKCS#7 padding
    pad: u32 = *(plaintext + ct_len - 1);
    if pad > 0 {
        if pad <= 16 {
            free(prev);
            return ct_len - pad;
        }
    }

    free(prev);
    return ct_len;
}

// ===========================================================================
// AES-128-CTR (encrypt = decrypt)
// ===========================================================================

fn aes128_ctr_crypt(data: Address, data_len: u32, key: Address, nonce: Address, output: Address) -> u32 {
    counter_block = allocate(16);
    i: u32 = 0;
    while i < 12 { *(counter_block + i) = *(nonce + i); i = i + 1; }
    *(counter_block + 12) = 0; *(counter_block + 13) = 0;
    *(counter_block + 14) = 0; *(counter_block + 15) = 0;

    pos: u32 = 0;
    while pos < data_len {
        keystream = allocate(16);
        aes128_encrypt_block(counter_block, key, keystream);

        block_remaining: u32 = data_len - pos;
        to_xor: u32 = 16;
        if block_remaining < 16 { to_xor = block_remaining; }

        i = 0;
        while i < to_xor {
            *(output + pos + i) = (*(data + pos + i) ^ *(keystream + i)) & 255;
            i = i + 1;
        }
        free(keystream);

        // Increment counter
        *(counter_block + 15) = (*(counter_block + 15) + 1) & 255;
        if *(counter_block + 15) == 0 {
            *(counter_block + 14) = (*(counter_block + 14) + 1) & 255;
        }

        pos = pos + to_xor;
    }

    free(counter_block);
    return data_len;
}
