// womb/crypto/aes128.vuma — AES-128 (NIST FIPS 197)
// 128-bit key, 10 rounds, 176-byte round key schedule.
// Includes encrypt AND decrypt (inverse cipher).
// No main() — importable library module.

const MASK32: u32 = 4294967295;

