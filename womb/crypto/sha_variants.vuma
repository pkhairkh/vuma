// womb/crypto/sha_variants.vuma — SHA truncated/derived variants (FIPS 180-4, FIPS 202, NIST SP 800-185)
// No main() — importable library module.
//
// Implements seven NIST-standard hash/XOF/MAC primitives built from two
// underlying compression cores (SHA-256 / SHA-512 Merkle-Damgard, and
// Keccak-f[1600] sponge):
//
//   1. SHA-224        (FIPS 180-4 §5.3.2)   — 32-bit Merkle-Damgard, 64-byte blocks, 28-byte output
//   2. SHA-512/224    (FIPS 180-4 §5.3.6.1) — 64-bit Merkle-Damgard, 128-byte blocks, 28-byte output
//   3. SHA-512/256    (FIPS 180-4 §5.3.6.2) — 64-bit Merkle-Damgard, 128-byte blocks, 32-byte output
//   4. SHA-3-224      (FIPS 202 §6.3.2)     — Keccak-f[1600], rate=144 bytes (1152 bits), 28-byte output
//   5. SHA-3-384      (FIPS 202 §6.3.4)     — Keccak-f[1600], rate=104 bytes (832 bits),  48-byte output
//   6. cSHAKE-256     (NIST SP 800-185)     — Keccak-f[1600], rate=136 bytes (1088 bits), variable output
//   7. KMAC-256       (NIST SP 800-185)     — cSHAKE256 with N="KMAC", keyed MAC, variable output
//
// SHA-224 / SHA-512/224 / SHA-512/256 / SHA-3-224 / SHA-3-384 each expose
// a streaming API (init/update/final) plus an oneshot wrapper. cSHAKE-256
// and KMAC-256 take additional parameters and expose only their oneshot
// forms, per NIST SP 800-185.
//
// VUMA's parser rejects integer literals >= 2^63 for u64. Constants at or
// above that threshold are expressed as (1 << 63) | lower_63_bits, which
// the parser accepts and evaluates to the correct unsigned u64 value.

// ===========================================================================
// Masks
// ===========================================================================

const MASK32: u32 = 4294967295;
const MASK64: u64 = (1 << 63) | ((1 << 63) - 1);

// ===========================================================================
