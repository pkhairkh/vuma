// womb_build3/sha_variants.vuma — SHA truncated/derived variants (FIPS 180-4, FIPS 202, NIST SP 800-185)
// No main() — importable library module.
//
// Implements:
//   1. SHA-224        (FIPS 180-4 §5.3.2)  — 32-bit, 28-byte output
//   2. SHA-512/224     (FIPS 180-4 §5.3.6.1) — 64-bit, 28-byte output
//   3. SHA-512/256     (FIPS 180-4 §5.3.6.2) — 64-bit, 32-byte output
//   4. SHA-3-224       (FIPS 202)            — Keccak, rate=144, 28-byte output
//   5. SHA-3-384       (FIPS 202)            — Keccak, rate=104, 48-byte output
//   6. cSHAKE-256      (NIST SP 800-185)     — Keccak, rate=136, variable output
//   7. KMAC-256        (NIST SP 800-185)     — cSHAKE-based MAC, variable output
//
// NOTE: VUMA's parser rejects integer literals >= 2^63 for u64. Constants at or
// above that threshold are expressed as (1 << 63) | lower_bits, which the parser
// accepts and evaluates correctly.

// ===========================================================================
// Masks
// ===========================================================================

const MASK32: u32 = 4294967295;
const MASK64: u64 = (1 << 63) | ((1 << 63) - 1);

