fn cam_sbox2_table(idx: u32) -> u32 {
    // RFC 3713 §2.2: SBOX2(x) = (SBOX1(x)) <<< 1  (rotate SBOX1 output left by 1 bit)
    v: u32 = cam_sbox1_table(idx & 255);
    return ((v << 1) | (v >> 7)) & 255;
}

fn cam_sbox3_table(idx: u32) -> u32 {
    // RFC 3713 §2.2: SBOX3(x) = (SBOX1(x)) >>> 1  (rotate SBOX1 output right by 1 bit)
    v: u32 = cam_sbox1_table(idx & 255);
    return ((v >> 1) | (v << 7)) & 255;
}

fn cam_sbox4_table(idx: u32) -> u32 {
    // RFC 3713 §2.2: SBOX4(x) = (SBOX1(x <<< 1)) <<< 1
    // (rotate input left by 1, apply SBOX1, rotate output left by 1)
    x: u32 = idx & 255;
    rot_in: u32 = ((x << 1) | (x >> 7)) & 255;
    v: u32 = cam_sbox1_table(rot_in);
    return ((v << 1) | (v >> 7)) & 255;
}

