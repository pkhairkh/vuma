    if k == 73 { return 2662; }
    if k == 74 { return 3281; }
    if k == 75 { return 233; }
    if k == 76 { return 756; }
    if k == 77 { return 2156; }
    if k == 78 { return 3015; }
    if k == 79 { return 3050; }
    if k == 80 { return 1703; }
    if k == 81 { return 1651; }
    if k == 82 { return 2789; }
