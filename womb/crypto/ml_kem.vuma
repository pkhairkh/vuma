// womb/crypto/ml_kem.vuma — ML-KEM (FIPS 203 / Kyber)
//
// Module-LWE key encapsulation mechanism per NIST FIPS 203 (final, 2024).
// Implements all three parameter sets:
//
//   ML-KEM-512  : k=2, eta1=3, eta2=2, du=10, dv=4   (NIST PQC level 1)
//   ML-KEM-768  : k=3, eta1=2, eta2=2, du=10, dv=4   (NIST PQC level 3)
//   ML-KEM-1024 : k=4, eta1=2, eta2=2, du=11, dv=5   (NIST PQC level 5)
//
// Common parameters: n=256, q=3329, primitive 512th root of unity zeta=17.
//
// Public API (caller-allocated output buffers):
//   ml_kem_seed_entropy(seed, len)         — seed the internal entropy pool
//   ml_kem_keygen_512/768/1024(pk, sk)     — generate keypair
//   ml_kem_encaps_512/768/1024(pk, ct, ss) — encapsulate (ct + 32-byte ss)
//   ml_kem_decaps_512/768/1024(sk, ct, ss) — decapsulate (32-byte ss)
//
// Buffer sizes (bytes):
//                       pk     sk     ct    ss
//   ML-KEM-512 :        800   1632    768    32
//   ML-KEM-768 :       1184   2400   1088    32
//   ML-KEM-1024:       1568   3168   1568    32
//
// External dependencies (linked from sibling crypto modules):
//   shake128(data, len, out, out_len)        — SHAKE-128 XOF (sha3.vuma)
//   shake256(data, len, out, out_len)        — SHAKE-256 XOF (sha3.vuma)
//   sha3_256_oneshot(data, len, out)         — SHA3-256 hash (sha3.vuma)
//   sha3_512_oneshot(data, len, out)         — SHA3-512 hash (sha3.vuma)
//
// Memory layout: polynomials are 256 coefficients, each a u32 in [0, q),
// stored little-endian (4 bytes per coefficient, 1024 bytes per polynomial).
// Vectors are k polynomials concatenated (k*1024 bytes). Matrices are k*k
// polynomials (k*k*1024 bytes). All bit-packing is little-endian per FIPS 203.

// ===========================================================================
// Parameters (FIPS 203 Table 1)
// ===========================================================================

const MLKEM_Q: u32 = 3329;
const MLKEM_N: u32 = 256;
const MLKEM_POLY_BYTES: u32 = 1024;         // 256 * 4
const MLKEM_128_INV: u32 = 3303;            // 128^{-1} mod 3329 (for INTT)
const MLKEM_COEF_BYTES_12: u32 = 384;       // 256 * 12 / 8 (uncompressed t/s)
const MLKEM_RHO_BYTES: u32 = 32;
const MLKEM_SS_BYTES: u32 = 32;
const MLKEM_M_BYTES: u32 = 32;
const MLKEM_Z_BYTES: u32 = 32;
const MLKEM_PK_HASH_BYTES: u32 = 32;

// ML-KEM-512
const MLKEM_512_K: u32 = 2;
const MLKEM_512_ETA1: u32 = 3;
const MLKEM_512_ETA2: u32 = 2;
const MLKEM_512_DU: u32 = 10;
const MLKEM_512_DV: u32 = 4;
const MLKEM_512_PK_SIZE: u32 = 800;         // 384*2 + 32
const MLKEM_512_SK_SIZE: u32 = 1632;        // 384*2 + 800 + 32 + 32
const MLKEM_512_CT_SIZE: u32 = 768;         // 320*2 + 128

// ML-KEM-768
const MLKEM_768_K: u32 = 3;
const MLKEM_768_ETA1: u32 = 2;
const MLKEM_768_ETA2: u32 = 2;
const MLKEM_768_DU: u32 = 10;
const MLKEM_768_DV: u32 = 4;
const MLKEM_768_PK_SIZE: u32 = 1184;        // 384*3 + 32
const MLKEM_768_SK_SIZE: u32 = 2400;        // 384*3 + 1184 + 32 + 32
const MLKEM_768_CT_SIZE: u32 = 1088;        // 320*3 + 128

// ML-KEM-1024
const MLKEM_1024_K: u32 = 4;
const MLKEM_1024_ETA1: u32 = 2;
const MLKEM_1024_ETA2: u32 = 2;
const MLKEM_1024_DU: u32 = 11;
const MLKEM_1024_DV: u32 = 5;
const MLKEM_1024_PK_SIZE: u32 = 1568;       // 384*4 + 32
const MLKEM_1024_SK_SIZE: u32 = 3168;       // 384*4 + 1568 + 32 + 32
const MLKEM_1024_CT_SIZE: u32 = 1568;       // 352*4 + 160

// Entropy pool — fixed memory location populated via ml_kem_seed_entropy().
// The pool holds a 32-byte seed followed by a 4-byte call counter (so each
// invocation of _ml_kem_get_entropy yields a fresh SHAKE-256 stream).
const MLKEM_ENTROPY_POOL: Address = 0x5A5A0000;
const MLKEM_ENTROPY_COUNTER: Address = 0x5A5A0020;

// ===========================================================================
// FIPS 203 Table 4 — zeta table (128 entries)
//   zetas[k] = 17^BitRev_7(k) mod 3329, for k = 0..127
// Computed deterministically from the primitive 512th root of unity zeta=17.
// ===========================================================================

fn mlkem_zeta(k: u32) -> u32 {
    if k == 0 { return 1; }
    if k == 1 { return 1729; }
    if k == 2 { return 2580; }
    if k == 3 { return 3289; }
    if k == 4 { return 2642; }
    if k == 5 { return 630; }
    if k == 6 { return 1897; }
    if k == 7 { return 848; }
    if k == 8 { return 1062; }
    if k == 9 { return 1919; }
    if k == 10 { return 193; }
    if k == 11 { return 797; }
    if k == 12 { return 2786; }
    if k == 13 { return 3260; }
    if k == 14 { return 569; }
    if k == 15 { return 1746; }
    if k == 16 { return 296; }
    if k == 17 { return 2447; }
    if k == 18 { return 1339; }
    if k == 19 { return 1476; }
    if k == 20 { return 3046; }
    if k == 21 { return 56; }
    if k == 22 { return 2240; }
    if k == 23 { return 1333; }
    if k == 24 { return 1426; }
    if k == 25 { return 2094; }
    if k == 26 { return 535; }
    if k == 27 { return 2882; }
    if k == 28 { return 2393; }
    if k == 29 { return 2879; }
    if k == 30 { return 1974; }
    if k == 31 { return 821; }
    if k == 32 { return 289; }
    if k == 33 { return 331; }
    if k == 34 { return 3253; }
    if k == 35 { return 1756; }
    if k == 36 { return 1197; }
    if k == 37 { return 2304; }
    if k == 38 { return 2277; }
