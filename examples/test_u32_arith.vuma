// Test: u32 arithmetic that exercises 32-bit overflow and function calls
// Expected: exit 79 (0x4F)

fn add_u32(a: u32, b: u32) -> u32 {
    return a + b;
}

fn xor_u32(a: u32, b: u32) -> u32 {
    return a ^ b;
}

fn and_u32(a: u32, b: u32) -> u32 {
    return a & b;
}

fn rotr_u32(x: u32, n: u32) -> u32 {
    return (x >> n) | (x << (32 - n));
}

fn main() -> u64 {
    // Test u32 arithmetic that could overflow into upper 32 bits
    a: u32 = 0xFFFFFFFF;
    b: u32 = 1;
    // a + b should wrap to 0 (u32)
    sum: u32 = add_u32(a, b);
    
    // XOR test
    c: u32 = 0x12345678;
    d: u32 = 0xABCDEF00;
    xored: u32 = xor_u32(c, d);
    
    // AND test
    anded: u32 = and_u32(c, d);
    
    // Rotate test
    rotated: u32 = rotr_u32(0x1, 1);
    // rotr(1, 1) = (1 >> 1) | (1 << 31) = 0 | 0x80000000 = 0x80000000
    
    // Combine results
    r1: u32 = sum + rotated; // 0 + 0x80000000 = 0x80000000
    r2: u32 = xored & rotated; // (0x12345678 ^ 0xABCDEF00) & 0x80000000
    r3: u32 = r1 | r2;
    
    // Expected: r3 = 0x80000000
    // Return as exit code: just the low byte = 0x00
    // Let's make it return something identifiable
    result: u32 = rotr_u32(0x4F000000, 24);
    // rotr(0x4F000000, 24) = (0x4F000000 >> 24) | (0x4F000000 << 8) = 0x4F | 0x00000000 = 0x4F
    // Actually: 0x4F000000 >> 24 = 0x4F, 0x4F000000 << 8 = 0xF000000000 ... that's 64-bit
    // Let me think more carefully:
    // rotr_u32(0x4F000000, 24) = (0x4F000000 >> 24) | (0x4F000000 << 8)
    // = 0x4F | 0xF0000000 = 0xF000004F
    // exit code = 0x4F = 79 ✓
    
    return result;
}
