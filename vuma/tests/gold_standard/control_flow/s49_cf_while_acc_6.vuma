// s49_cf_while_acc_6.vuma — while loop accumulates 6*5 = 30
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 6, add 5 each iteration ->
// 6 * 5 = 30 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 30 once fixed. Distinct from s46_cf_while_acc_4
// (4*6 = 24) and s43_cf_while_acc_5 (5*4 = 20).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 6 {
        acc = acc + 5;
        i = i + 1;
    }
    return acc;
}
