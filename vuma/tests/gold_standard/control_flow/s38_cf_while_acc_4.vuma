// s38_cf_while_acc_4.vuma — while loop accumulates 4*4 = 16
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 4, add 4 each iteration ->
// 4 * 4 = 16 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 16 once fixed. Distinct from s34_cf_while_acc_6
// (6*3 = 18) and s30_cf_while_acc_5 (5*5 = 25).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 4 {
        acc = acc + 4;
        i = i + 1;
    }
    return acc;
}
