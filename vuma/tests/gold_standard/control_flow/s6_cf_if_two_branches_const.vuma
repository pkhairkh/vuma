// s6_cf_if_two_branches_const.vuma — if-true picks x=42, return = 42
// Expected exit code: 42
//
// Outer if-true branch sets x = 42; else branch sets x = 99. With a
// literal `true` condition, the true branch wins. On the current
// backend this returns 42 (the if-true body's last assignment is
// preserved). Distinct from s5_cf_if_then_else_3way (two assignments
// inside the if body).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 42;
    } else {
        x = 99;
    }
    return x;
}
