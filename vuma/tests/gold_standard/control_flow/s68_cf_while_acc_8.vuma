// s68_cf_while_acc_8.vuma — while loop accumulates 8*12 = 96
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 8, add 12 each iteration ->
// 8 * 12 = 96 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 96 once fixed. Distinct from s66_cf_while_
// acc_3 (33), s62_cf_while_acc_4 (36) and s58_cf_while_acc_5 (40).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 8 {
        acc = acc + 12;
        i = i + 1;
    }
    return acc;
}
