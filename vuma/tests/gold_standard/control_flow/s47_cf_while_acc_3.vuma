// s47_cf_while_acc_3.vuma — while loop accumulates 3*9 = 27
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 3, add 9 each iteration ->
// 3 * 9 = 27 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 27 once fixed. Distinct from s46_cf_while_acc_4
// (4*6 = 24) and s42_cf_while_acc_3 (3*5 = 15).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 3 {
        acc = acc + 9;
        i = i + 1;
    }
    return acc;
}
