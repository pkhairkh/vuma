// s88_cf_while_acc.vuma — while loop accumulates 3*9 = 27
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 9, add 3 each
// iteration -> 3 * 9 = 27 total. i increments by 1 each
// iteration. Known "while-body assignments don't propagate"
// bug keeps acc at 0 -> exit 0. Will exit 27 once fixed.
// Distinct from s86_cf_while_acc (28), s82_cf_while_acc
// (9) and s78_cf_while_acc (2).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 9 {
        acc = acc + 3;
        i = i + 1;
    }
    return acc;
}
