// s92_cf_for_count.vuma — for loop runs 67 iterations, count = 67
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..67. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 67 once
// fixed. Distinct from s90_cf_for_count (69), s86_cf_for_count (9)
// and s82_cf_for_count (6).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..67 {
        count = count + 1;
    }
    return count;
}
