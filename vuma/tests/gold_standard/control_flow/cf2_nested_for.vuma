// cf2_nested_for — nested for loops count to 9 (3x3).
// Expected exit code: 9
//
// Exposes VUMA bug: for-body assignments to an outer accumulator (even from
// a nested for loop) do not propagate. On buggy codegen, c stays 0.

fn main() -> i32 {
    c: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            c = c + 1;
        }
    }
    return c;
}
