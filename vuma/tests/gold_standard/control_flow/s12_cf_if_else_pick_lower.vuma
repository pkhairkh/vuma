// s12_cf_if_else_pick_lower.vuma — if true { x = 30 } else { x = 180 }; return x
// Observed on current x86_64 backend: 180 (FAIL — known bug)
//
// Constant-true guard selects the if-body assignment (x = 30). On the
// current backend the if-body assignment is silently dropped, so x
// keeps the else-branch value 180 (exit 180). Will exit 30 once the
// if-body drop bug is fixed. Distinct from s7_cf_if_else_pick_higher
// (picks higher value) and s13_cf_if_two_branches_const (values 60/240).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 30;
    } else {
        x = 180;
    }
    return x;
}
