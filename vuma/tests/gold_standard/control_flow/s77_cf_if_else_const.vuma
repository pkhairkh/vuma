// s77_cf_if_else_const.vuma — if true { x = 37 } else { x = 148 }; return x
// Observed on current x86_64 backend: 148 (FAIL — known bug)
//
// If-true branch should set x = 37, else branch sets x = 148.
// With a literal `true` condition the true branch should win ->
// 37. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (148)
// survives instead. Will exit 37 once the if-body drop bug is
// fixed. Distinct from s70_cf_if_else_const (76), s66_cf_if_
// else_const (84) and s74_cf_if_else_const (19).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 37;
    } else {
        x = 148;
    }
    return x;
}
