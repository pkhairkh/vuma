// cf2_for_count — for loop counts the number of iterations (5).
// Expected exit code: 5
//
// Exposes VUMA bug: for-body assignments to an outer counter do not
// propagate. On buggy codegen, c stays 0 and exit is 0 instead of 5.

fn main() -> i32 {
    c: u32 = 0;
    for i in 0..5 {
        c = c + 1;
    }
    return c;
}
