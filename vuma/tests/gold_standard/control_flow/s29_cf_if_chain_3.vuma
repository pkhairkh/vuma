// s29_cf_if_chain_3.vuma — chain of three ifs, last sets x=180
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Three sequential if-true blocks. Each overwrites x: 60, then 120, then 180. With all conditions `true`, x should end at 180. On the current backend the if-true body assignments are dropped, so x stays 0. Distinct from s26_cf_if_chain_3 (three-if chain, different values) and s22_cf_if_assign_true (single if-true, x=88).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 60;
    }
    if true {
        x = 120;
    }
    if true {
        x = 180;
    }
    return x;
}
