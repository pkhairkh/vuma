// cf_for_break — break out of for loop when i==5, return captured value
// Expected exit code: 5
//
// We capture the loop value into an outer variable `result` so the test
// does not depend on whether the for-loop variable leaks to outer scope.
// Exposes: for-body assignment + break propagation bugs.

fn main() -> i32 {
    result: u32 = 0;
    for i in 0..100 {
        if (i == 5) {
            result = i;
            break;
        }
    }
    return result;
}
