// cf2_while_count — while loop increments a counter to 5.
// Expected exit code: 5
//
// Exposes VUMA bug: while-body assignments to the loop counter (and other
// outer variables) may not propagate. On buggy codegen, i remains 0 and the
// loop never terminates (or terminates with i = 0).

fn main() -> i32 {
    i: u32 = 0;
    while (i < 5) {
        i = i + 1;
    }
    return i;
}
