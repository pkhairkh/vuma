// s24_cf_if_else_const.vuma — if true { x = 80 } else { x = 160 }; return x
// Observed on current x86_64 backend: 160 (FAIL — known bug)
//
// If-true branch should set x = 80, else branch sets x = 160. With a
// literal `true` condition the true branch should win -> 80. On the
// current backend the if-true body's single assignment is dropped, so
// the else body's assignment (160) survives instead. Will exit 80 once
// the if-body drop bug is fixed. Distinct from s22_cf_if_else_const
// (values 70/140) and s18_cf_if_else_const (values 55/110).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 80;
    } else {
        x = 160;
    }
    return x;
}
