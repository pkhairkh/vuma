// s63_cf_if_else_const.vuma — if true { x = 64 } else { x = 210 }; return x
// Observed on current x86_64 backend: 210 (FAIL — known bug)
//
// If-true branch should set x = 64, else branch sets x = 210. With
// a literal `true` condition the true branch should win -> 64. On
// the current backend the if-true body's single assignment is
// dropped, so the else body's assignment (210) survives instead.
// Will exit 64 once the if-body drop bug is fixed. Distinct from
// s51_cf_if_else_const (70), s58_cf_if_else_const (64) and s55_cf_
// if_else_const (72).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 64;
    } else {
        x = 210;
    }
    return x;
}
