// s17_cf_if_else_const.vuma — if true { x = 33 } else { x = 88 }; return x
// Observed on current x86_64 backend: 88 (FAIL — known bug)
//
// if-true branch assigns 33, else branch assigns 88. On the current
// backend the if-body assignment is silently dropped when the condition
// is the literal `true`, so x takes the else-branch value 88 (exit 88).
// Will exit 33 once the if-body drop bug is fixed. Distinct from
// s14_cf_if_else_const (values 42/99) and s9_cf_if_else_one_branch
// (values 50/200).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 33;
    } else {
        x = 88;
    }
    return x;
}
