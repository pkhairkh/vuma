// s27_cf_if_chain_2.vuma — chain of two ifs, last sets x=77
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Two sequential if-true blocks. Each overwrites x: 33, then 77. With
// all conditions `true`, x should end at 77. On the current backend the
// if-true body assignments are dropped, so x stays 0. Distinct from
// s26_cf_if_chain_3 (three-if chain, x=180) and s22_cf_if_assign_true
// (single if-true, x=88).

fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 33;
    }
    if true {
        x = 77;
    }
    return x;
}
