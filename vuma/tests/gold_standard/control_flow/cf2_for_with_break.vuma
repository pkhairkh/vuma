// cf2_for_with_break — break out of a for loop and return the loop variable.
// Expected exit code: 3
//
// Exposes VUMA bug: for-body break propagation and outer-scope visibility of
// the for-loop variable `i` may not work. On buggy codegen, the loop runs to
// completion (so i ends at 10) or i is 0 after the loop, neither of which
// matches the expected 3.

fn main() -> i32 {
    for i in 0..10 {
        if (i == 3) {
            break;
        }
    }
    return i;
}
