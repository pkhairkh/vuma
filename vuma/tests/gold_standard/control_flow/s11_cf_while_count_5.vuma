// s11_cf_while_count_5.vuma — while loop counts to 5
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0. While i < 5, increment count and i each
// iteration -> count = 5, i = 5. Known "while-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 5 once fixed.
// Distinct from s9_cf_while_mul2 (multiplies, adds 2) and
// s7_cf_while_acc_5 (different loop body).

fn main() -> i32 {
    count: u32 = 0;
    i: u32 = 0;
    while i < 5 {
        count = count + 1;
        i = i + 1;
    }
    return count;
}
