// cf_for_step — for loop accumulates sum 0..9 (verification duplicate of cf_for_basic)
// Expected exit code: 45
//
// (Task spec listed 25 but noted "(same as 14 but verify)"; #14 expects 45.
// Correct semantic value is 45: sum of 0..9 = 45.)

fn main() -> i32 {
    sum: u32 = 0;
    for i in 0..10 {
        sum = sum + i;
    }
    return sum;
}
