// s100_cf_if_else_const.vuma — if true { x = 118 } else { x = 11 }; return x
// Observed on current x86_64 backend: 11 (FAIL — known bug)
//
// If-true branch should set x = 118, else branch sets x =
// 11. With a literal `true` condition the true branch
// should win -> 118. On the current backend the if-true
// body's single assignment is dropped, so the else body's
// assignment (11) survives instead. Will exit 118 once the
// if-body drop bug is fixed.
// Distinct from s97_cf_if_else_const (122), s94_cf_if_else_const (64), s90_cf_if_else_const (79).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 118;
    } else {
        x = 11;
    }
    return x;
}
