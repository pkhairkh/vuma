// s96_cf_while_acc.vuma — while loop accumulates 1 * 47 = 47
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 47, add 1 each iteration
// -> 1 * 47 = 47 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 47 once fixed. Distinct from s94_cf_while_acc
// (44), s90_cf_while_acc (71) and s86_cf_while_acc (28).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 47 {
        acc = acc + 1;
        i = i + 1;
    }
    return acc;
}
