// cf2_if_return — early return inside an if body.
// Expected exit code: 42
//
// Exposes VUMA bug: return inside an if body may not actually return; on
// buggy codegen, control falls through to the `return 0` and exit is 0.

fn main() -> i32 {
    if true {
        return 42;
    }
    return 0;
}
