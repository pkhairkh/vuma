// s60_cf_while_acc_6.vuma — while loop accumulates 6*7 = 42
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Accumulator starts at 0. While i < 6, add 7 each iteration ->
// 6 * 7 = 42 total. i increments by 1 each iteration. Known
// "while-body assignments don't propagate" bug keeps acc at 0 ->
// exit 0. Will exit 42 once fixed. Distinct from s58_cf_while_acc_5
// (40) and s57_cf_while_acc_4 (32).

fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 6 {
        acc = acc + 7;
        i = i + 1;
    }
    return acc;
}
