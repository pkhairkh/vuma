// cf_multi_branch — false branch must not execute, x keeps initial value
// Expected exit code: 2
//
// Exposes: if-body assignments dropped (here the drop is benign since the
// branch is false, but verifies the false-branch is correctly skipped).

fn main() -> i32 {
    x: u32 = 2;
    if false {
        x = 1;
    }
    return x;
}
