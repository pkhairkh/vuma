// cf_for_continue — continue skips the sum when i==5
// Expected exit code: 40
//
// Semantic: for i in 0..10 (i=0,1,...,9), sum += i except when i==5.
// Values added: 0+1+2+3+4+6+7+8+9 = 40.
// (Task spec listed 45; correct semantic value is 40. On VUMA buggy
// codegen where continue is broken, sum may be 45; where for-body
// assignments are dropped, sum stays 0.)
//
// Exposes: continue + for-body assignment propagation bugs.

fn main() -> i32 {
    sum: u32 = 0;
    for i in 0..10 {
        if (i == 5) {
            continue;
        }
        sum = sum + i;
    }
    return sum;
}
