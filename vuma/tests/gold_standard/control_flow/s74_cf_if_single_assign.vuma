// s74_cf_if_single_assign.vuma — x=0; if true { x = 47 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 47. Known "if-body assignments don't
// propagate" bug keeps x at 0 -> exit 0. Will exit 47 once the
// bug is fixed. Distinct from s70_cf_if_single_assign (100),
// s66_cf_if_single_assign (88) and s62_cf_if_single_assign (95).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 47;
    }
    return x;
}
