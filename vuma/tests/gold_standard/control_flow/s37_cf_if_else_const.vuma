// s37_cf_if_else_const.vuma — if true { x = 75 } else { x = 150 }; return x
// Observed on current x86_64 backend: 150 (FAIL — known bug)
//
// If-true branch should set x = 75, else branch sets the
// observed value. With a literal `true` condition the true branch should win
// -> 75. On the current backend the if-true body's single
// assignment is dropped, so the else body's assignment (150) survives.
// Will exit 75 once the if-body drop bug is fixed.
// Distinct from s33_cf_if_else_const (values 60/120, observed 120) and s30_cf_if_else_const (values 90/180, observed 180).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 75;
    } else {
        x = 150;
    }
    return x;
}
