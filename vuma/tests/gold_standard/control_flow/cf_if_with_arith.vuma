// cf_if_with_arith — if condition uses arithmetic comparison, body returns sum
// Expected exit code: 15
//
// a=10, b=5, a>b is true, return a+b = 15.
// Exposes: if-body return + arithmetic condition bugs.

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 5;
    if (a > b) {
        return a + b;
    }
    return 0;
}
