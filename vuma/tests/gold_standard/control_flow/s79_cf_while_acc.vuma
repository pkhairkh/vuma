// s79_cf_while_acc.vuma — while loop accumulates 13*2 = 26
// Observed on current x86_64 backend: 0 (FAIL — known bug: for/while/if-body assignments don't propagate)
//
// Accumulator starts at 0. While i < 13, add 2 each iteration
// -> 13 * 2 = 26 total. i increments by 1 each iteration.
// Known "while-body assignments don't propagate" bug keeps acc
// at 0 -> exit 0. Will exit 26 once fixed. Distinct from
// s78_cf_while_acc (2), s77_cf_while_acc (3) and s76_cf_while_
// acc (2).
fn main() -> i32 {
    acc: u32 = 0;
    i: u32 = 0;
    while i < 13 {
        acc = acc + 2;
        i = i + 1;
    }
    return acc;
}
