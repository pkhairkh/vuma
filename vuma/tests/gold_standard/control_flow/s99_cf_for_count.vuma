// s99_cf_for_count.vuma — for loop runs 16 iterations, count = 16
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Counter starts at 0 and increments by 1 each iteration of a for
// loop with range 0..16. Known "for-body assignments don't
// propagate" bug keeps count at 0 -> exit 0. Will exit 16 once
// fixed. Distinct from s95_cf_for_count (108), s91_cf_for_count
// (73) and s87_cf_for_count (11).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..16 {
        count = count + 1;
    }
    return count;
}
