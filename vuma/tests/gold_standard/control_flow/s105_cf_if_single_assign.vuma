// s105_cf_if_single_assign.vuma — x=0; if true { x = 215 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
// 
// Single-assignment in an if-true body. With a literal `true` condition x should become 215. Known "if-body assignments don't propagate" bug keeps x at 0 -> exit 0. Will exit 215 once the bug is fixed.
// Distinct from s102_cf_if_single_assign (124), s101_cf_if_single_assign (56), s100_cf_if_single_assign (112).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 215;
    }
    return x;
}
