// s96_cf_if_single_assign.vuma — x=0; if true { x = 83 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 83. Known "if-body assignments don't
// propagate" bug keeps x at 0 -> exit 0. Will exit 83 once the bug
// is fixed. Distinct from s94_cf_if_single_assign (91),
// s90_cf_if_single_assign (78) and s86_cf_if_single_assign (25).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 83;
    }
    return x;
}
