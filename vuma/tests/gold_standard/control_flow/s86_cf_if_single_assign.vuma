// s86_cf_if_single_assign.vuma — x=0; if true { x = 25 }; return x
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single-assignment in an if-true body. With a literal `true`
// condition x should become 25. Known "if-body assignments
// don't propagate" bug keeps x at 0 -> exit 0. Will exit 25
// once the bug is fixed. Distinct from s82_cf_if_single_assign
// (18), s78_cf_if_single_assign (22) and s74_cf_if_single_assign
// (47).
fn main() -> i32 {
    x: u32 = 0;
    if true {
        x = 25;
    }
    return x;
}
