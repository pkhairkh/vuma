// s36_cs_three_cell_or.vuma — cells 128/64/32, OR = 224
// Expected exit code: 224
//
// Three 8-byte cells. Store 128/64/32 via `*ptr = literal`,
// load all three, OR -> 0xE0 = 224. All bitwise operands
// loaded into u64 variables first. Uses `*ptr = literal`
// form (no offsets).
// Distinct from s30_cs_three_cell_xor (xor, 0) and s27_cs_three_cell_or (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 128;             // 0x80
    *c2 = 64;              // 0x40
    *c3 = 32;              // 0x20
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = *c3;
    x: u64 = a | b;        // 0xC0 = 192
    r: u64 = x | d;        // 0xE0 = 224
    free(c1);
    free(c2);
    free(c3);
    return r;
}
