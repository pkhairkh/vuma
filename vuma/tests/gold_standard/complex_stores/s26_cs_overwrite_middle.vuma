// s26_cs_overwrite_middle.vuma — overwrite middle of three, sum = 160 (20 + 80 + 60)
// Expected exit code: 160
//
// Three 8-byte cells. Store 20/40/60 in c1/c2/c3, then overwrite c2 with
// 80. Load all three, sum -> 160. Uses `*ptr = literal` form (no offsets).
// Distinct from s22_cs_three_cells_asc (ascending, no overwrite) and
// s14_cs_overwrite_first (overwrites the first cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 40;
    *c3 = 60;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
