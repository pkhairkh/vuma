// s83_cs_overwrite_middle.vuma — overwrite c2 to 184, load = 184
// Expected exit code: 184
//
// Three 8-byte cells. Store 50 at c1, store 100 at c2 then
// overwrite c2 to 184, store 200 at c3. Load c2 -> 184 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s78_cs_overwrite_first (3), s74_cs_overwrite_last (85)
// and s72_cs_overwrite_middle (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c2 = 184;
    *c3 = 200;
    v: u64 = *c2;          // 184
    free(c1);
    free(c2);
    free(c3);
    return v;
}
