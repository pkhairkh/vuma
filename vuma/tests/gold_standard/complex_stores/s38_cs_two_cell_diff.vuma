// s38_cs_two_cell_diff.vuma — two cells, diff = 140 (200 - 60)
// Expected exit code: 140
//
// Two 8-byte cells. Store 200/60 via `*ptr = literal`, load both,
// subtract -> 140. Uses `*ptr = literal` form (no offsets). Distinct
// from s34_cs_two_cell_diff (65) and s30_cs_three_cell_xor.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 140
    free(c1);
    free(c2);
    return d;
}
