// s75_cs_two_cell_diff.vuma — two cells, diff = 95 (200 - 105)
// Expected exit code: 95
//
// Two 8-byte cells. Store 200/105 via `*ptr = literal`, load
// both, diff -> 95. Uses `*ptr = literal` form (no offsets).
// Distinct from s74_cs_two_cell_sum (187), s70_cs_two_cell_diff
// (90) and s66_cs_two_cell_sum (250).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 105;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a - b;        // 95
    free(c1);
    free(c2);
    return s;
}
