// cs_u32_le_load.vuma — store 4 bytes, reconstruct u32, return low byte
// Expected exit code: 42
//
// Stores 4 little-endian bytes (42, 0, 0, 0), then reconstructs the u32
// value by shifting/anding the loaded bytes, and returns the low byte.
// The reconstructed u32 happens to be 42, so the low byte is 42.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    *(buf + 1) = 0;
    *(buf + 2) = 0;
    *(buf + 3) = 0;
    b0: u32 = *(buf + 0);
    b1: u32 = *(buf + 1);
    b2: u32 = *(buf + 2);
    b3: u32 = *(buf + 3);
    shift8: u32 = 8;
    shift16: u32 = 16;
    shift24: u32 = 24;
    reconstructed: u32 = (b0 | (b1 << shift8) | (b2 << shift16) | (b3 << shift24)) & 4294967295;
    free(buf);
    return reconstructed & 255;
}
