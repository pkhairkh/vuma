// cs_zero_fill.vuma — fill 4 bytes with 0, load
// Expected exit code: 0
//
// Stores four zero bytes (zero-fill pattern), then loads one back.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 0;
    *(buf + 1) = 0;
    *(buf + 2) = 0;
    *(buf + 3) = 0;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
