// cs2_overwrite.vuma — store 42, overwrite with 99, load
// Expected exit code: 99
//
// Back-to-back stores to the same byte offset: the second store must
// overwrite the first. Loads the final value and returns it.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    *(buf + 0) = 99;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
