// s24_cs_overwrite_last.vuma — overwrite last of three cells, sum = 74 (8 + 16 + 50)
// Expected exit code: 74
//
// Three 8-byte cells. Store 8/16/24 in c1/c2/c3, then overwrite c3 (the
// last cell) with 50. Load all three, sum -> 74. Uses `*ptr = literal`
// form (no offsets). Distinct from s22_cs_overwrite_first (overwrites the
// first cell, 5/15/25 -> 70/15/25 = 110) and s18_cs_overwrite_last
// (overwrites the last cell, different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 8;
    *c2 = 16;
    *c3 = 24;
    *c3 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
