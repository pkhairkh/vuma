// s8_cs_five_offsets_scatter.vuma — scatter 5 values across 40 bytes, sum = 75
// Expected exit code: 75  (5 + 10 + 15 + 20 + 25)
//
// 40-byte buffer. Store 5/10/15/20/25 at offsets 0/8/16/24/32. Load all
// five, sum, return 75. Distinct from s6_cs_four_offsets (four offsets)
// and s5_cs_long_scatter (different values).

fn main() -> i32 {
    buf = allocate(40);
    *(buf + 0) = 5;
    *(buf + 8) = 10;
    *(buf + 16) = 15;
    *(buf + 24) = 20;
    *(buf + 32) = 25;
    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    d: u64 = *(buf + 24);
    e: u64 = *(buf + 32);
    t1: u64 = a + b;
    t2: u64 = t1 + c;
    t3: u64 = t2 + d;
    s: u64 = t3 + e;
    free(buf);
    return s;
}
