// s39_cs_three_cell_diff.vuma — three cells, diff = 130 (220 - 50 - 40)
// Expected exit code: 130
//
// Three 8-byte cells. Store 220/50/40 via `*ptr = literal`, load
// all, subtract sequentially -> 130. Uses `*ptr = literal` form
// (no offsets). Distinct from s38_cs_three_cell_sum (220) and
// s34_cs_three_cell_xor.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 50;
    *c3 = 40;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    d: u64 = t - c;        // 130
    free(c1);
    free(c2);
    free(c3);
    return d;
}
