// s15_cs_two_buf_overwrite_both.vuma — two cells, overwrite both, sum = 175
// Expected exit code: 175  (75 + 100)
//
// Two 8-byte cells. Store 25/50 initially, then overwrite BOTH cells with
// 75/100 (last writes win). Load both, sum -> 175. Uses `*ptr = literal`
// form (no offsets). Distinct from s14_cs_two_buf_overwrite_one (overwrites
// only one cell) and s9_cs_two_buf_overwrite_both (values 10/20 -> 50/60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 25;
    *c2 = 50;
    *c1 = 75;
    *c2 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;
    free(c1);
    free(c2);
    return s;
}
