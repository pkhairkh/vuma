// s101_cs_three_cell_sum.vuma — three cells, sum = 150 (30 + 70 + 50)
// Expected exit code: 150
//
// Three 8-byte cells. Store 30/70/50 via `*ptr = literal`, load
// all three, a + b + c -> 150. Uses `*ptr = literal` form (no
// offsets). Distinct from s98_cs_three_cell_sum (114),
// s97_cs_three_cell_sum (40) and s94_cs_three_cell_sum (90).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 70;
    *c3 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a + b + c;    // 150
    free(c1);
    free(c2);
    free(c3);
    return r;
}
