// s36_cs_two_cell_product.vuma — two cells 12 and 15, product = 180
// Expected exit code: 180
//
// Two 8-byte cells. Store 12/15 via `*ptr = literal`, load
// both, multiply -> 180. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s30_cs_two_cell_sum (sum, 110) and s27_cs_two_cell_product (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 12;
    *c2 = 15;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a * b;        // 180
    free(c1);
    free(c2);
    return s;
}
