// s104_cs_three_cell_sum.vuma — store 20+30+37 in 3 cells, load and sum = 87
// Expected exit code: 87
//
// Three 8-byte cells. Store 20, 30, 37; load each and return the sum (87). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_overwrite_last (1), s102_cs_three_cell_sum (26), s102_cs_two_cell_sum (23).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 30;
    *c3 = 37;
    a: u64 = *c1;          // 20
    b: u64 = *c2;          // 30
    c: u64 = *c3;          // 37
    s: u64 = a + b + c;    // 87
    free(c1);
    free(c2);
    free(c3);
    return s;
}
