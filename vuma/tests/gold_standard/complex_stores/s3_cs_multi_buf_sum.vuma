// s3_cs_multi_buf_sum.vuma — 3 buffers each store value, sum loads
// Expected exit code: 90  (15 + 25 + 50)
//
// Three independent 8-byte buffers. Each gets a distinct value; main
// sums all loaded values.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *(a + 0) = 15;
    *(b + 0) = 25;
    *(c + 0) = 50;

    va: u64 = *(a + 0);
    vb: u64 = *(b + 0);
    vc: u64 = *(c + 0);
    s1: u64 = va + vb;
    s2: u64 = s1 + vc;

    free(a);
    free(b);
    free(c);
    return s2;
}
