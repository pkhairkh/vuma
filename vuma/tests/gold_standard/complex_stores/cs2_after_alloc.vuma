// cs2_after_alloc.vuma — allocate, then store 42, load
// Expected exit code: 42
//
// Emphasizes the "store immediately after allocate" code path: a single
// store/load pair bracketed by an allocate on the front and a free on
// the back. Verifies allocate does not leave the buffer in a state that
// breaks subsequent offset-0 stores.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
