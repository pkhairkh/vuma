// s3_cs_overwrite_first.vuma — store A,B,C, overwrite A with D, load all
// Expected exit code: 70  (40 + 10 + 20)  where D=40 replaces A=1
//
// Stores 1, 10, 20 at offsets 0, 8, 16; then overwrites offset 0 with
// 40; loads all three and sums: 40 + 10 + 20 = 70.

fn main() -> i32 {
    buf = allocate(24);
    *(buf + 0) = 1;
    *(buf + 8) = 10;
    *(buf + 16) = 20;
    *(buf + 0) = 40;

    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    s1: u64 = a + b;
    s2: u64 = s1 + c;

    free(buf);
    return s2;
}
