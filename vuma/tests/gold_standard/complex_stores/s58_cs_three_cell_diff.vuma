// s58_cs_three_cell_diff.vuma — three cells, diff = 120 (250 - 80 - 50)
// Expected exit code: 120
// 
// Three 8-byte cells. Store 250/80/50 via `*ptr = literal`, load
// all three, 250 - 80 - 50 = 120. Uses `*ptr = literal` form (no
// offsets). Distinct from s51_cs_two_cell_diff (100), s51_cs_three_
// cell_sum (215) and s51_cs_overwrite_middle (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 80;
    *c3 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;
    r: u64 = t - c;        // 120
    free(c1);
    free(c2);
    free(c3);
    return r;
}
