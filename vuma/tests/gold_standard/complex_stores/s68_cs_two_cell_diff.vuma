// s68_cs_two_cell_diff.vuma — two cells, diff = 85 (170 - 85)
// Expected exit code: 85
//
// Two 8-byte cells. Store 170/85 via `*ptr = literal`, load both,
// diff -> 85. Uses `*ptr = literal` form (no offsets). Distinct
// from s66_cs_two_cell_sum (250), s62_cs_two_cell_diff (140) and
// s58_cs_two_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 170;
    *c2 = 85;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 85
    free(c1);
    free(c2);
    return d;
}
