// s16_cs_two_buf_overwrite_first.vuma — overwrite first of two cells, sum = 235
// Expected exit code: 235  (200 + 35)
//
// Two 8-byte cells. Store 25/35 in c1/c2, then overwrite c1 with 200.
// Load both, sum -> 235. Uses `*ptr = literal` form (no offsets).
// Distinct from s14_cs_two_buf_overwrite_one (values 15/25 -> 100/25 = 125)
// and s12_cs_two_buf_overwrite_one (different operand values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 25;
    *c2 = 35;
    *c1 = 200;
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
