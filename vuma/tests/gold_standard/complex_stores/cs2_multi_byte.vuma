// cs2_multi_byte.vuma — store 1,2,3 at offsets 0,1,2; load all; return sum
// Expected exit code: 6  (1 + 2 + 3)
//
// Three small consecutive byte stores + three independent loads + a sum.
// Verifies that adjacent byte slots don't smear into one another and that
// the sum expression over loaded u32 values is correct.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 1;
    *(buf + 1) = 2;
    *(buf + 2) = 3;
    a: u32 = *(buf + 0);
    b: u32 = *(buf + 1);
    c: u32 = *(buf + 2);
    s1: u32 = a + b;
    s2: u32 = s1 + c;
    free(buf);
    return s2;
}
