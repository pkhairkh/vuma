// s105_cs_three_cell_diff.vuma — store 210, 30, 9 in 3 cells, 210-30-9 = 171
// Expected exit code: 171
// 
// Three 8-byte cells. Store 210, 30, 9; load each, return 210 - 30 - 9 = 171. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_three_cell_sum (26), s101_cs_three_cell_sum (150), s100_cs_three_cell_sum (54).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 210;
    *c2 = 30;
    *c3 = 9;
    a: u64 = *c1;          // 210
    b: u64 = *c2;          // 30
    c: u64 = *c3;          // 9
    d: u64 = a - b - c;    // 171
    free(c1);
    free(c2);
    free(c3);
    return d;
}
