// s60_cs_two_cell_diff.vuma — two cells, diff = 130 (220 - 90)
// Expected exit code: 130
//
// Two 8-byte cells. Store 220/90 via `*ptr = literal`, load both,
// subtract -> 130. Uses `*ptr = literal` form (no offsets). Distinct
// from s58_cs_two_cell_sum (200) and s57_cs_two_cell_sum (230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 130
    free(c1);
    free(c2);
    return d;
}
