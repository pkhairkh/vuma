// s30_cs_two_cell_sum.vuma — two cells, sum = 130 (60 + 70)
// Expected exit code: 130
//
// Two 8-byte cells. Store 60/70 via `*ptr = literal`, load both, sum ->
// 130. Uses `*ptr = literal` form (no offsets). Distinct from
// s26_cs_three_cells_dec (three-cell, 190) and s22_cs_two_buf_sum
// (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 60;
    *c2 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;
    free(c1);
    free(c2);
    return s;
}
