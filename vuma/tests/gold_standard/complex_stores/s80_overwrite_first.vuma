// s80_cs_overwrite_first.vuma — store 1, overwrite with 14, load = 14
// Expected exit code: 14
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite with
// 14 via `*ptr = literal`, load and return 14. Uses `*ptr =
// literal` form (no offsets). Distinct from s78_cs_overwrite_first
// (3), s74_cs_overwrite_last (85) and s73_cs_overwrite_middle (155).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 14;
    r: u64 = *c1;          // 14
    free(c1);
    return r;
}
