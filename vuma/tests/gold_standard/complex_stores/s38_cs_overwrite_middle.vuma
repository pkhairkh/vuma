// s38_cs_overwrite_middle.vuma — overwrite middle to 110, sum = 210 (30 + 110 + 70)
// Expected exit code: 210
//
// Three 8-byte cells. Store 30/50/70 via `*ptr = literal`, then
// overwrite the middle cell with 110. Load all three, sum -> 210.
// Uses `*ptr = literal` form (no offsets). Distinct from s34_cs_
// overwrite_first (250) and s30_cs_two_cell_diff.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 50;
    *c3 = 70;
    *c2 = 110;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 210
    free(c1);
    free(c2);
    free(c3);
    return s;
}
