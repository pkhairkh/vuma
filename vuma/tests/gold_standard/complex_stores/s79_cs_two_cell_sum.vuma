// s79_cs_two_cell_sum.vuma — two cells, sum = 22 (11 + 11)
// Expected exit code: 22
//
// Two 8-byte cells. Store 11/11 via `*ptr = literal`, load
// both, sum -> 22. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_cs_two_cell_sum (2), s77_cs_two_cell_sum
// (3) and s76_cs_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 11;
    *c2 = 11;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 22
    free(c1);
    free(c2);
    return s;
}
