// s52_cs_three_cell_diff.vuma — three cells, diff = 120 (200 - 50 - 30)
// Expected exit code: 120
//
// Three 8-byte cells. Store 200/50/30 via `*ptr = literal`, load all
// three, subtract -> 200 - 50 - 30 = 120. Uses `*ptr = literal` form.
// Distinct from s50_cs_three_cell_diff (130) and s46_cs_two_cell_diff
// (150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 50;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    d1: u64 = a - b;       // 150
    r: u64 = d1 - c;       // 120
    free(c1);
    free(c2);
    free(c3);
    return r;
}
