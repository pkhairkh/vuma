// s70_cs_two_cell_diff.vuma — two cells, diff = 90 (200 - 110)
// Expected exit code: 90
//
// Two 8-byte cells. Store 200/110 via `*ptr = literal`, load
// both, diff -> 90. Uses `*ptr = literal` form (no offsets).
// Distinct from s66_cs_two_cell_sum (250), s65_cs_two_cell_sum
// (175) and s62_cs_two_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 110;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 90
    free(c1);
    free(c2);
    return d;
}
