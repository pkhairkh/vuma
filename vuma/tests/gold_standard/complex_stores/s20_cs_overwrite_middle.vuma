// s20_cs_overwrite_middle.vuma — c1=12, c2: 24->180, c3=40, sum = 232
// Expected exit code: 232  (12 + 180 + 40)
//
// Three 8-byte cells. Store 12 in c1, 24 then overwrite 180 in c2, 40
// in c3. Load all three, sum -> 232. Uses `*ptr = literal` form.
// Distinct from s18_cs_overwrite_last (overwrites last cell) and
// s14_cs_overwrite_first (overwrites first cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 12;
    *c2 = 24;
    *c2 = 180;
    *c3 = 40;
    a: u64 = *c1;         // 12
    b: u64 = *c2;         // 180
    c: u64 = *c3;         // 40
    s: u64 = a + b + c;   // 232
    free(c1);
    free(c2);
    free(c3);
    return s;
}
