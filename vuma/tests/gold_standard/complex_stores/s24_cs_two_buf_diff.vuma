// s24_cs_two_buf_diff.vuma — two cells, diff = 44 (92 - 48)
// Expected exit code: 44
//
// Two 8-byte cells. Store 92/48 via `*ptr = literal`, load both,
// subtract -> 44. Uses `*ptr = literal` form (no offsets). Distinct from
// s22_cs_two_buf_sum (sum, 33+47=80) and s18_cs_two_buf_overwrite_one
// (overwrites one cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 92;
    *c2 = 48;
    v1: u64 = *c1;
    v2: u64 = *c2;
    d: u64 = v1 - v2;
    free(c1);
    free(c2);
    return d;
}
