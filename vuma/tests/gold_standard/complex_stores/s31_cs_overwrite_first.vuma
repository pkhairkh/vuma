// s31_cs_overwrite_first.vuma — overwrite first cell, sum = 150 (100+20+30)
// Expected exit code: 150
//
// Three 8-byte cells. Store 10/20/30 in c1/c2/c3, then overwrite c1 (the
// first cell) with 100. Load all three, sum -> 150. Uses `*ptr = literal`
// form (no offsets). Distinct from s30_cs_overwrite_middle (overwrite
// middle, 120) and s28_cs_overwrite_last (overwrite last, 115).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c1 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
