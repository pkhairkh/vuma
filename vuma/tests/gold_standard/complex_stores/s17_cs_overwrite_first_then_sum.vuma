// s17_cs_overwrite_first_then_sum.vuma — c1: 100->50, c2: 30, sum = 80
// Expected exit code: 80  (50 + 30)
//
// Two 8-byte cells. Store 100 in c1, overwrite with 50 (last write
// wins); store 30 in c2. Load both, sum -> 80. Uses `*ptr = literal`
// form. Distinct from s14_cs_overwrite_first (single-cell overwrite)
// and s9_cs_overwrite_then_sum (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c1 = 50;
    *c2 = 30;
    a: u64 = *c1;         // 50
    b: u64 = *c2;         // 30
    s: u64 = a + b;       // 80
    free(c1);
    free(c2);
    return s;
}
