// s34_cs_three_cell_sum.vuma — three cells, sum = 180 (40 + 60 + 80)
// Expected exit code: 180
//
// Three 8-byte cells. Store 40/60/80 via `*ptr = literal`, load all,
// sum -> 180. Uses `*ptr = literal` form (no offsets). Distinct from
// s30_cs_three_cell_xor (xor) and s27_cs_three_cell_sum (different
// values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 60;
    *c3 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 180
    free(c1);
    free(c2);
    free(c3);
    return s;
}
