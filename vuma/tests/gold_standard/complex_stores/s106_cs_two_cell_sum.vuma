// s106_cs_two_cell_sum.vuma — store 16 + 18 in 2 cells, load and sum = 34
// Expected exit code: 34
//
// Two 8-byte cells. Store 16 at c1, store 18 at c2, load each and return the sum (34). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_two_cell_sum (23), s101_cs_two_cell_xor (192), s100_cs_two_cell_diff (19).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 16;
    *c2 = 18;
    a: u64 = *c1;          // 16
    b: u64 = *c2;          // 18
    s: u64 = a + b;        // 34
    free(c1);
    free(c2);
    return s;
}
