// s33_cs_two_cell_sum.vuma — two cells, sum = 60 + 75 = 135
// Expected exit code: 135
//
// Deterministic test in the complex_stores category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_cs_two_cell_sum (different values) and s26_cs_two_cell_and (and, 15).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 60;
    *c2 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;         // 135
    free(c1);
    free(c2);
    return s;
}
