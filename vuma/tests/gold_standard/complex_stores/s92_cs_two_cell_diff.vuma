// s92_cs_two_cell_diff.vuma — two cells, diff = 15 (210 - 195)
// Expected exit code: 15
//
// Two 8-byte cells. Store 210/195 via `*ptr = literal`, load both,
// a - b -> 15. Uses `*ptr = literal` form (no offsets). Distinct
// from s90_cs_two_cell_diff (4), s86_cs_two_cell_sum (170) and
// s82_cs_two_cell_sum (160).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 210;
    *c2 = 195;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 15
    free(c1);
    free(c2);
    return d;
}
