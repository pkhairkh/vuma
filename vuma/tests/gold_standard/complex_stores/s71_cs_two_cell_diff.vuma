// s71_cs_two_cell_diff.vuma — two cells, diff = 155 (250 - 95)
// Expected exit code: 155
//
// Two 8-byte cells. Store 250/95 via `*ptr = literal`, load both,
// diff -> 155. Uses `*ptr = literal` form (no offsets). Distinct
// from s69_cs_two_cell_sum (145), s70_cs_two_cell_diff (90) and
// s66_cs_two_cell_sum (250).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 250;
    *c2 = 95;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 155
    free(c1);
    free(c2);
    return d;
}
