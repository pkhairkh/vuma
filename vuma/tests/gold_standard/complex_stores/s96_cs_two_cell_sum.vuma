// s96_cs_two_cell_sum.vuma — two cells, sum = 180 (95 + 85)
// Expected exit code: 180
//
// Two 8-byte cells. Store 95/85 via `*ptr = literal`, load both,
// a + b -> 180. Uses `*ptr = literal` form (no offsets). Distinct
// from s94_cs_two_cell_sum (110), s90_cs_two_cell_diff (4) and
// s86_cs_two_cell_sum (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 85;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 180
    free(c1);
    free(c2);
    return s;
}
