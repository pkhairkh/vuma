// s33_cs_three_cell_xor.vuma — three cells, xor = 0xAA ^ 0x55 ^ 0xF0 = 0x0F = 15
// Expected exit code: 15
//
// Deterministic test in the complex_stores category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_cs_three_cell_xor (different values) and s26_cs_three_cell_sum (sum, 75).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 170;              // 0xAA
    *c2 = 85;               // 0x55
    *c3 = 240;              // 0xF0
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a ^ b ^ c;     // 0x0F = 15
    free(c1);
    free(c2);
    free(c3);
    return r;
}
