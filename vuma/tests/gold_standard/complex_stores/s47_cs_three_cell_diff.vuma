// s47_cs_three_cell_diff.vuma — three cells, diff = 110 (220 - 80 - 30)
// Expected exit code: 110
//
// Three 8-byte cells. Store 220/80/30 via `*ptr = literal`, load all,
// subtract sequentially -> 110. Uses `*ptr = literal` form (no
// offsets). Distinct from s46_cs_three_cell_sum (195) and s42_cs_
// three_cell_xor (195).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 80;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 140
    d: u64 = t - c;        // 110
    free(c1);
    free(c2);
    free(c3);
    return d;
}
