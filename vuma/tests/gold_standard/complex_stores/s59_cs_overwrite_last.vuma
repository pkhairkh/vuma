// s59_cs_overwrite_last.vuma — overwrite last to 245, load = 245
// Expected exit code: 245
//
// Single 8-byte cell. Store 40 via `*ptr = literal`, then overwrite
// the cell with 245. Load and return 245. Uses `*ptr = literal` form
// (no offsets). Distinct from s58_cs_two_cell_sum (200), s58_cs_three_
// cell_diff (120) and s58_cs_overwrite_first (200).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 40;
    *c1 = 245;
    a: u64 = *c1;
    free(c1);
    return a;
}
