// s74_cs_overwrite_last.vuma — overwrite c3 to 191, load = 191
// Expected exit code: 191
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c3 to 191. Load c3 -> 191 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s70_cs_overwrite_last (230),
// s66_cs_overwrite_last (175) and s62_cs_overwrite_last (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c3 = 191;
    v: i32 = *c3;          // 191
    free(c1);
    free(c2);
    free(c3);
    return v;
}
