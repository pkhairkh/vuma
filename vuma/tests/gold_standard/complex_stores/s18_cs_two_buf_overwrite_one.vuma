// s18_cs_two_buf_overwrite_one.vuma — overwrite first of two cells, sum = 132
// Expected exit code: 132  (50 + 82)
//
// Two 8-byte cells. Store 18/82 in c1/c2, then overwrite c1 with 50.
// Load both, sum -> 132. Uses `*ptr = literal` form (no offsets).
// Distinct from s14_cs_two_buf_overwrite_one (15/25 -> 100/25 = 125)
// and s9_cs_two_buf_overwrite_both (overwrites BOTH cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 18;
    *c2 = 82;
    *c1 = 50;
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
