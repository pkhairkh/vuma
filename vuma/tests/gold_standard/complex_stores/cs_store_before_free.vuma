// cs_store_before_free.vuma — store, load, free, return loaded
// Expected exit code: 42
//
// Order-of-operations test: store→load→free. The loaded value must be
// captured before free, then returned. Verifies that the load happens
// before the allocation is released.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
