// s3_cs_scatter_3_vals.vuma — store 3 values at offsets 0,8,16, sum
// Expected exit code: 60  (10 + 20 + 30)
//
// Scatters three values across a 24-byte buffer at 8-byte offsets,
// then loads each back and sums them. Tests stride-8 scatter/gather.

fn main() -> i32 {
    buf = allocate(24);
    *(buf + 0) = 10;
    *(buf + 8) = 20;
    *(buf + 16) = 30;

    a: u64 = *(buf + 0);
    b: u64 = *(buf + 8);
    c: u64 = *(buf + 16);
    s1: u64 = a + b;
    s2: u64 = s1 + c;

    free(buf);
    return s2;
}
