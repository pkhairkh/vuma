// s58_cs_overwrite_first.vuma — overwrite first to 100, sum = 200 (100 + 40 + 60)
// Expected exit code: 200
// 
// Three 8-byte cells. Store 20/40/60 via `*ptr = literal`, then
// overwrite the first cell with 100. Load all three, sum -> 200.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_cs_two_
// cell_diff (100), s51_cs_three_cell_sum (215) and s51_cs_overwrite_
// middle (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 40;
    *c3 = 60;
    *c1 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 200
    free(c1);
    free(c2);
    free(c3);
    return s;
}
