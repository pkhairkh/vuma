// s54_cs_overwrite_last.vuma — overwrite last to 150, sum = 250 (40+60+150)
// Expected exit code: 250
//
// Three 8-byte cells. Store 40/60/80 via `*ptr = literal`, then
// overwrite the last cell with 150. Load all three, sum -> 250.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_cs_
// overwrite_last (210) and s49_cs_overwrite_last (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 60;
    *c3 = 80;
    *c3 = 150;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 250
    free(c1);
    free(c2);
    free(c3);
    return s;
}
