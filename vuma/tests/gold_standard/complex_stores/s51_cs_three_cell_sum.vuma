// s51_cs_three_cell_sum.vuma — three cells, sum = 215 (80 + 75 + 60)
// Expected exit code: 215
//
// Three 8-byte cells. Store 80/75/60 via `*ptr = literal`, load all
// three, sum -> 215. Uses `*ptr = literal` form (no offsets).
// Distinct from s50_cs_three_cell_diff (130) and s47_cs_three_cell_
// diff (110).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 80;
    *c2 = 75;
    *c3 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 215
    free(c1);
    free(c2);
    free(c3);
    return s;
}
