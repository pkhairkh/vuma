// s98_cs_two_cell_sum.vuma — two cells, sum = 113 (80 + 33)
// Expected exit code: 113
//
// Two 8-byte cells. Store 80/33 via `*ptr = literal`, load both,
// a + b -> 113. Uses `*ptr = literal` form (no offsets). Distinct
// from s94_cs_two_cell_sum (110), s90_cs_two_cell_diff (4) and
// s86_cs_two_cell_sum (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 33;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 113
    free(c1);
    free(c2);
    return s;
}
