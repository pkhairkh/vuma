// s86_cs_overwrite_first.vuma — overwrite c1 to 230, load = 230
// Expected exit code: 230
//
// Three 8-byte cells. Store 50 at c1, store 80 at c2, then
// overwrite c1 to 230, store 200 at c3. Load c1 -> 230 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s82_cs_overwrite_middle (220), s78_cs_overwrite_first
// (3) and s74_cs_overwrite_last (85).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 80;
    *c1 = 230;
    *c3 = 200;
    v: u64 = *c1;          // 230
    free(c1);
    free(c2);
    free(c3);
    return v;
}
