// s34_cs_overwrite_first.vuma — overwrite first cell to 200, sum with 50 = 250
// Expected exit code: 250
//
// Two 8-byte cells. Store 80 then overwrite to 200 in c1; store 50
// in c2; load both, sum -> 250. Uses `*ptr = literal` form (no
// offsets). Distinct from s30_cs_overwrite_middle (overwrite, 210)
// and s27_cs_overwrite_last (different cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c1 = 200;
    *c2 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 250
    free(c1);
    free(c2);
    return s;
}
