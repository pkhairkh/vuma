// s78_cs_overwrite_first.vuma — store 1, overwrite with 3, load = 3
// Expected exit code: 3
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite with
// 3 via `*ptr = literal`, load and return 3. Uses `*ptr =
// literal` form (no offsets). Distinct from s74_cs_overwrite_last
// (85), s73_cs_overwrite_middle (155) and s72_cs_overwrite_first
// (115).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 3;
    r: u64 = *c1;          // 3
    free(c1);
    return r;
}
