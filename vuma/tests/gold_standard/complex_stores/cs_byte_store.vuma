// cs_byte_store.vuma — store single byte at offset 0
// Expected exit code: 42
//
// Canonical byte-store test: allocate, store 42 at offset 0, load it back,
// free, return. Verifies the most basic store/load roundtrip.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
