// s62_cs_two_cell_diff.vuma — two cells, diff = 140 (220 - 80)
// Expected exit code: 140
// 
// Two 8-byte cells. Store 220/80 via `*ptr = literal`, load both,
// subtract -> 140. Uses `*ptr = literal` form (no offsets). Distinct
// from s51_cs_two_cell_diff (100), s58_cs_two_cell_sum (200) and s55_
// cs_three_cell_sum (215).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 140
    free(c1);
    free(c2);
    return d;
}
