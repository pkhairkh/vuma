// s105_cs_overwrite_middle.vuma — overwrite c2 to 207, load = 207
// Expected exit code: 207
// 
// Three 8-byte cells. Store 100 at c1, store 50 at c2, store 30 at c3, then overwrite c2 to 207. Load c2 -> 207 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_overwrite_last (1), s101_cs_overwrite_first (28), s100_cs_overwrite_middle (47).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c3 = 30;
    *c2 = 207;
    v: u64 = *c2;          // 207
    free(c1);
    free(c2);
    free(c3);
    return v;
}
