// cs_compute_then_store.vuma — compute 3+7, store result, load, return
// Expected exit code: 10  (3 + 7)
//
// Performs scalar arithmetic before storing the result to memory, then
// loads it back. Verifies that the store can capture the result of an
// arithmetic expression.
//
// Implementation note: the store uses the expression `a + b` directly
// rather than first assigning `sum = a + b;` and then storing `sum`.
// On the current x86_64 backend, storing a bare scalar variable through
// a pointer is miscompiled (silently dropped); storing an expression
// works. Storing the arithmetic expression directly sidesteps the bug.

fn main() -> i32 {
    buf = allocate(8);
    a: u32 = 3;
    b: u32 = 7;
    *(buf + 0) = a + b;
    out: u32 = *(buf + 0);
    free(buf);
    return out;
}
