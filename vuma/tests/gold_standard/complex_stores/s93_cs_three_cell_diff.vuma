// s93_cs_three_cell_diff.vuma — three cells, diff = 18 (250 - 200 - 32)
// Expected exit code: 18
//
// Three 8-byte cells. Store 250/200/32 via `*ptr = literal`, load
// all three, a - b - c -> 18. Uses `*ptr = literal` form (no offsets).
// Distinct from s90_cs_three_cell_diff (6), s82_cs_three_cell_diff (125) and s78_cs_three_cell_diff (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 200;
    *c3 = 32;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 18
    free(c1);
    free(c2);
    free(c3);
    return r;
}
