// s15_cs_overwrite_middle.vuma — overwrite middle cell, sum = 145 (25 + 70 + 50)
// Expected exit code: 145
//
// Three 8-byte cells. Store 25/15/50 in c1/c2/c3, then overwrite c2 (the
// middle cell) with 70. Load all three, sum -> 145. Uses `*ptr = literal`
// form (no offsets). Distinct from s14_cs_overwrite_first (overwrites the
// first cell, 99/20/30 = 149) and s9_cs_overwrite_middle (10/100/30 = 140).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 25;
    *c2 = 15;
    *c3 = 50;
    *c2 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
