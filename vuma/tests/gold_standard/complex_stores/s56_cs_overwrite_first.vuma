// s56_cs_overwrite_first.vuma — overwrite first to 25, sum = 155 (25+100+30)
// Expected exit code: 155
//
// Three 8-byte cells. Store 50/100/30 via `*ptr = literal`, then
// overwrite the first cell with 25. Load all three, sum -> 155. Uses
// `*ptr = literal` form (no offsets). Distinct from s54_cs_overwrite_
// last (220) and s50_cs_overwrite_last (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 30;
    *c1 = 25;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 155
    free(c1);
    free(c2);
    free(c3);
    return s;
}
