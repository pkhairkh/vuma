// s90_cs_two_cell_diff.vuma — two cells, diff = 4 (200 - 196)
// Expected exit code: 4
//
// Two 8-byte cells. Store 200/196 via `*ptr = literal`, load both,
// a - b -> 4. Uses `*ptr = literal` form (no offsets). Distinct
// from s86_cs_two_cell_sum (170), s82_cs_two_cell_sum (160) and
// s78_cs_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 196;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 4
    free(c1);
    free(c2);
    return d;
}
