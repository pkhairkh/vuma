// s63_cs_two_cell_sum.vuma — two cells, sum = 205 (130 + 75)
// Expected exit code: 205
//
// Two 8-byte cells. Store 130/75 via `*ptr = literal`, load both,
// sum -> 205. Uses `*ptr = literal` form (no offsets). Distinct
// from s51_cs_three_cell_sum (215), s58_cs_three_cell_diff (120)
// and s55_cs_overwrite_first (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 130;
    *c2 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 205
    free(c1);
    free(c2);
    return s;
}
