// s32_cs_three_cell_or.vuma - three cells, or = 255 (0xAA | 0x55 | 0x0F)
// Expected exit code: 255
//
// three cells, or = 255 (0xAA | 0x55 | 0x0F). All operands loaded into typed
// variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from
// s30_cs_three_cell_xor (xor, 255) and s26_cs_three_cell_or (different
// values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 170;             // 0xAA
    *c2 = 85;              // 0x55
    *c3 = 15;              // 0x0F
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = *c3;
    t: u64 = a | b;
    r: u64 = t | d;        // 0xFF = 255
    free(c1);
    free(c2);
    free(c3);
    return r;
}
