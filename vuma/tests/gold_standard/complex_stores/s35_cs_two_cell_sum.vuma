// s35_cs_two_cell_sum.vuma — two cells, sum = 205 (110 + 95)
// Expected exit code: 205
//
// Two 8-byte cells. Store 110/95 via `*ptr = literal`, load both,
// sum -> 205. Uses `*ptr = literal` form (no offsets). Distinct from
// s34_cs_two_cell_diff (diff, 65) and s30_cs_two_cell_sum (sum, 130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 110;
    *c2 = 95;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 205
    free(c1);
    free(c2);
    return s;
}
