// s53_cs_overwrite_middle.vuma — overwrite middle to 115, sum = 215 (35 + 115 + 65)
// Expected exit code: 215
//
// Three 8-byte cells. Store 35/75/65 via `*ptr = literal`, then
// overwrite the middle cell with 115. Load all three, sum -> 215.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s49_cs_overwrite_middle (190) and s50_cs_overwrite_last (240).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 35;
    *c2 = 75;
    *c3 = 65;
    *c2 = 115;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 215
    free(c1);
    free(c2);
    free(c3);
    return s;
}
