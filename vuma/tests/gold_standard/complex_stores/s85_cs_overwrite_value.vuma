// s85_cs_overwrite_value.vuma — store 11 then 219, load = 219
// Expected exit code: 219
//
// Single 8-byte cell. Store 11 via `*ptr = literal`, overwrite
// with 219 via `*ptr = literal` (literal overwrite, last write
// wins). Load and return 219. Uses `*ptr = literal` form (no
// offsets). Distinct from s82_cs_overwrite_value (215),
// s78_cs_overwrite_value (3) and s74_cs_overwrite_value (85).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 11;
    *c1 = 219;
    r: u64 = *c1;
    free(c1);
    return r;
}
