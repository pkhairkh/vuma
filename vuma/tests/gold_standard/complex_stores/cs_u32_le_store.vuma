// cs_u32_le_store.vuma — store u32 as 4 little-endian bytes, load byte 0
// Expected exit code: 120  (0x78)
//
// Decomposes 0x12345678 into 4 little-endian bytes at offsets 0..3,
// then loads byte 0 (the low byte = 0x78 = 120). All byte values ≤ 255,
// so this avoids the known U8-truncation bug.
// Shifts are loaded into variables to avoid the "bitwise op with immediate
// RHS dropped" bug.

fn main() -> i32 {
    buf = allocate(8);
    val: u32 = 0x12345678;
    mask: u32 = 255;
    shift8: u32 = 8;
    shift16: u32 = 16;
    shift24: u32 = 24;
    *(buf + 0) = val & mask;
    *(buf + 1) = (val >> shift8) & mask;
    *(buf + 2) = (val >> shift16) & mask;
    *(buf + 3) = (val >> shift24) & mask;
    b0: u32 = *(buf + 0);
    free(buf);
    return b0;
}
