// s60_cs_overwrite_last.vuma — overwrite last to 110, sum = 190 (30 + 50 + 110)
// Expected exit code: 190
//
// Three 8-byte cells. Store 30/50/70 via `*ptr = literal`, then
// overwrite the last cell with 110. Load all three, sum -> 190.
// Uses `*ptr = literal` form (no offsets). Distinct from s58_cs_
// overwrite_first (200) and s57_cs_overwrite_first (60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 50;
    *c3 = 70;
    *c3 = 110;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
