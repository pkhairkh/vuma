// s79_cs_three_cell_diff.vuma — three cells, diff = 29 (50 - 8 - 13)
// Expected exit code: 29
//
// Three 8-byte cells. Store 50/8/13 via `*ptr = literal`,
// load all three, a - b - c -> 29. Uses `*ptr = literal` form
// (no offsets). Distinct from s78_cs_three_cell_diff (148),
// s77_cs_three_cell_diff (172) and s76_cs_three_cell_diff
// (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 8;
    *c3 = 13;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 29
    free(c1);
    free(c2);
    free(c3);
    return r;
}
