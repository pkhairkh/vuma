// s99_cs_two_cell_sum.vuma — two cells, sum = 121 (80 + 41)
// Expected exit code: 121
//
// Two 8-byte cells. Store 80/41 via `*ptr = literal`, load both,
// a + b -> 121. Uses `*ptr = literal` form (no offsets). Distinct
// from s95_cs_two_cell_sum (59), s91_cs_two_cell_diff (11) and
// s87_cs_two_cell_sum (180).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 41;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 121
    free(c1);
    free(c2);
    return s;
}
