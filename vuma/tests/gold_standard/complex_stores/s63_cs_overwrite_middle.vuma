// s63_cs_overwrite_middle.vuma — overwrite middle to 90, sum = 160 (10 + 90 + 60)
// Expected exit code: 160
//
// Three 8-byte cells. Store 10/40/60 via `*ptr = literal`, then
// overwrite the middle cell with 90. Load all three, sum -> 160.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_cs_
// overwrite_middle (220), s58_cs_overwrite_first (200) and s55_cs_
// two_cell_diff (100).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 40;
    *c3 = 60;
    *c2 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 160
    free(c1);
    free(c2);
    free(c3);
    return s;
}
