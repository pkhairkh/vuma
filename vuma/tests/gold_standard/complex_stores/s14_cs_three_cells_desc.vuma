// s14_cs_three_cells_desc.vuma — three cells, descending values, sum = 150
// Expected exit code: 150  (75 + 50 + 25)
//
// Three independent 8-byte cells. Store 75/50/25 (descending by 25)
// via `*ptr = literal`. Load all three, sum, return 150. Uses
// separate allocations per "slot" because the current x86_64
// backend drops stores through the `*(ptr + N) = literal` form
// (only `*ptr = literal` and `*ptr = variable + 0` round-trip).
// Distinct from s9_cs_three_cells_asc (ascending 5/15/25 = 45) and
// s10_cs_pattern_4_offsets (uses broken *(p+N) form).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 75;
    *c2 = 50;
    *c3 = 25;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
