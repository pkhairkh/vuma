// s12_cs_three_cells_dec.vuma — three cells, descending values, sum = 90
// Expected exit code: 90  (50 + 30 + 10)
//
// Three independent 8-byte cells. Store 50/30/10 (descending by 20)
// via `*ptr = literal`. Load all three, sum, return 90. Uses
// separate allocations per "slot" because the current x86_64
// backend drops stores through the `*(ptr + N) = literal` form
// (only `*ptr = literal` and `*ptr = variable + 0` round-trip).
// Distinct from s9_cs_three_cells_asc (ascending 5/15/25) and
// s5_conc_three_cells (10/20/30 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 30;
    *c3 = 10;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
