// s92_cs_three_cell_diff.vuma — three cells, diff = 55 (250 - 100 - 95)
// Expected exit code: 55
//
// Three 8-byte cells. Store 250/100/95 via `*ptr = literal`, load
// all three, a - b - c -> 55. Uses `*ptr = literal` form (no offsets).
// Distinct from s90_cs_three_cell_diff (6), s86_cs_three_cell_diff
// (140) and s82_cs_three_cell_diff (125).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 100;
    *c3 = 95;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 55
    free(c1);
    free(c2);
    free(c3);
    return r;
}
