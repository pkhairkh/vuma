// s32_cs_overwrite_first.vuma - overwrite cell, load = 180
// Expected exit code: 180
//
// overwrite cell, load = 180. All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_cs_overwrite_middle
// (different position/value) and s26_cs_overwrite_last (different value).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 90;
    *c1 = 180;
    a: u64 = *c1;
    free(c1);
    return a;
}
