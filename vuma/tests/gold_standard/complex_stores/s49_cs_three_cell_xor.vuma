// s49_cs_three_cell_xor.vuma — three cells, xor = 31 (50 ^ 85 ^ 120)
// Expected exit code: 31
//
// Three 8-byte cells. Store 50/85/120 via `*ptr = literal`, load all,
// xor -> 31. 50 ^ 85 = 103; 103 ^ 120 = 31. Uses `*ptr = literal`
// form (no offsets). Distinct from s46_cs_three_cell_sum (195, sum)
// and s42_cs_three_cell_xor (195, xor with different operands).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 85;
    *c3 = 120;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a ^ b;
    r: u64 = t ^ c;        // 31
    free(c1);
    free(c2);
    free(c3);
    return r;
}
