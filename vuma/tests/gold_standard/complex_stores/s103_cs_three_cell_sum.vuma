// s103_cs_three_cell_sum.vuma — store 1, 2, 53 in 3 cells, load and sum = 1+2+53 = 56
// Expected exit code: 56
//
// Three 8-byte cells. Store 1, 2, 53; load each and return the sum (56). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_three_cell_sum (26), s101_cs_three_cell_sum (150), s100_cs_three_cell_sum (54).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 1;
    *c2 = 2;
    *c3 = 53;
    a: u64 = *c1;          // 1
    b: u64 = *c2;          // 2
    c: u64 = *c3;          // 53
    s: u64 = a + b + c;    // 56
    free(c1);
    free(c2);
    free(c3);
    return s;
}
