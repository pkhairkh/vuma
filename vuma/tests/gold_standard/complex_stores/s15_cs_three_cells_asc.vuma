// s15_cs_three_cells_asc.vuma — three cells, ascending values, sum = 180
// Expected exit code: 180  (30 + 60 + 90)
//
// Three independent 8-byte cells. Store 30/60/90 (ascending by 30) via
// `*ptr = literal`. Load all three, sum, return 180. Uses separate
// allocations per "slot" because the current x86_64 backend drops stores
// through the `*(ptr + N) = literal` form. Distinct from
// s9_cs_three_cells_asc (5/15/25 = 45) and s14_cs_three_cells_desc
// (75/50/25 = 150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c3 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
