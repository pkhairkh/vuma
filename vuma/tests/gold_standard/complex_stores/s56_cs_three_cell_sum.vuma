// s56_cs_three_cell_sum.vuma — three cells, sum = 255 (60 + 90 + 105)
// Expected exit code: 255
//
// Three 8-byte cells. Store 60/90/105 via `*ptr = literal`, load all
// three, sum -> 255. Uses `*ptr = literal` form (no offsets). Distinct
// from s54_cs_three_cell_diff (210) and s50_cs_three_cell_diff (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 90;
    *c3 = 105;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 255
    free(c1);
    free(c2);
    free(c3);
    return s;
}
