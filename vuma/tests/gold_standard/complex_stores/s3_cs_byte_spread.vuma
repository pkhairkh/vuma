// s3_cs_byte_spread.vuma — store 4 values at byte offsets 0,1,2,3
// Expected exit code: 10  (1 + 2 + 3 + 4)
//
// Stores four byte-sized values at consecutive byte offsets in a
// 4-byte buffer, then loads each back and sums them.

fn main() -> i32 {
    buf = allocate(4);
    *(buf + 0) = 1;
    *(buf + 1) = 2;
    *(buf + 2) = 3;
    *(buf + 3) = 4;

    a: u64 = *(buf + 0);
    b: u64 = *(buf + 1);
    c: u64 = *(buf + 2);
    d: u64 = *(buf + 3);
    s1: u64 = a + b;
    s2: u64 = s1 + c;
    s3: u64 = s2 + d;

    free(buf);
    return s3;
}
