// s58_cs_two_cell_sum.vuma — two cells, sum = 200 (130 + 70)
// Expected exit code: 200
// 
// Two 8-byte cells. Store 130/70 via `*ptr = literal`, load both,
// sum -> 200. Uses `*ptr = literal` form (no offsets). Distinct from
// s51_cs_two_cell_diff (100), s51_cs_three_cell_sum (215) and s51_cs_
// overwrite_middle (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 130;
    *c2 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 200
    free(c1);
    free(c2);
    return s;
}
