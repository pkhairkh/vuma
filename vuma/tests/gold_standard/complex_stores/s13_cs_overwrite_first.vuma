// s13_cs_overwrite_first.vuma — overwrite first cell, sum = 143
// Expected exit code: 143  (88 + 22 + 33)
//
// Three 8-byte cells. Store 11/22/33 in c1/c2/c3, then overwrite c1
// (the first cell) with 88. Load all three, sum -> 143. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s9_cs_overwrite_middle (overwrites the middle cell) and
// s6_cs_two_buf_overwrite (two cells, both overwritten).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 11;
    *c2 = 22;
    *c3 = 33;
    *c1 = 88;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
