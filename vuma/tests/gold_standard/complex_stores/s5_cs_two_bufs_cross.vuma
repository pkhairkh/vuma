// s5_cs_two_bufs_cross.vuma — two buffers, cross-load offsets = 100
// Expected exit code: 100  (40 + 60)
//
// Two 16-byte buffers. Buffer A gets 40 at offset 0, buffer B gets
// 60 at offset 8. Load offset 0 of A and offset 8 of B, sum.
// Tests that cross-buffer loads at different offsets work.
// Distinct from s4_cs_two_buf_stores (both buffers use offset 0).

fn main() -> i32 {
    a = allocate(16);
    b = allocate(16);
    *(a + 0) = 40;
    *(b + 8) = 60;
    va: u64 = *(a + 0);
    vb: u64 = *(b + 8);
    s: u64 = va + vb;
    free(a);
    free(b);
    return s;
}
