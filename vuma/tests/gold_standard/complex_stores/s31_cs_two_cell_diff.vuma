// s31_cs_two_cell_diff.vuma — two cells, diff = 150 (200 - 50)
// Expected exit code: 150
//
// Two 8-byte cells. Store 200/50 via `*ptr = literal`, load both,
// subtract -> 150. Uses `*ptr = literal` form (no offsets). Distinct
// from s30_cs_two_cell_sum (sum, 130) and s28_cs_two_buf_and (and, 48).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a - b;
    free(c1);
    free(c2);
    return s;
}
