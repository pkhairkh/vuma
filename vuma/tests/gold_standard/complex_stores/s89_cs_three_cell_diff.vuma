// s89_cs_three_cell_diff.vuma — three cells, diff = 21 (91 - 50 - 20)
// Expected exit code: 21
//
// Three 8-byte cells. Store 91/50/20 via `*ptr = literal`,
// load all three, a - b - d -> 21. Uses `*ptr = literal` form.
// Distinct from s86_cs_three_cell_diff (140), s82_cs_three_cell_
// diff (215) and s78_cs_three_cell_diff (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 91;
    *c2 = 50;
    *c3 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = *c3;
    r: u64 = a - b - d;    // 21
    free(c1);
    free(c2);
    free(c3);
    return r;
}
