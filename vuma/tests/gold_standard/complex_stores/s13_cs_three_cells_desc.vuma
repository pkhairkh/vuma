// s13_cs_three_cells_desc.vuma — three cells, descending values, sum = 105
// Expected exit code: 105  (50 + 35 + 20)
//
// Three independent 8-byte cells. Store 50/35/20 (descending by 15)
// via `*ptr = literal`. Load all three, sum, return 105. Uses
// separate allocations per "slot" because the current x86_64 backend
// drops stores through the `*(ptr + N) = literal` form. Distinct from
// s9_cs_three_cells_asc (ascending 5/15/25 = 45) and
// s6_cs_four_offsets (uses *(buf+N) form).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 35;
    *c3 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
