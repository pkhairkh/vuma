// s52_cs_overwrite_last.vuma — three cells (10, 20, 30), overwrite last to 99, sum = 129
// Expected exit code: 129
//
// Three 8-byte cells. Store 10/20/30 via `*ptr = literal`, then
// overwrite the third cell with 99. Load all three, sum -> 10 + 20 +
// 99 = 129. Uses `*ptr = literal` form. Distinct from
// s50_cs_overwrite_last (240) and s46_cs_three_cell_diff (150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c3 = 99;              // overwrite last
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 129
    free(c1);
    free(c2);
    free(c3);
    return s;
}
