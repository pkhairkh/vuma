// s35_cs_overwrite_middle.vuma — overwrite middle cell, sum = 190 (20+110+60)
// Expected exit code: 190
//
// Three 8-byte cells. Store 20/40/60 in c1/c2/c3, then overwrite c2
// (the middle cell) with 110. Load all three, sum -> 190. Uses
// `*ptr = literal` form (no offsets). Distinct from s34_cs_overwrite_
// first (overwrite, 250) and s30_cs_overwrite_middle (120).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 40;
    *c3 = 60;
    *c2 = 110;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
