// s8_cs_interleaved_bufs.vuma — two 16-byte bufs, alternate stores, sum = 100
// Expected exit code: 100  ((10 + 30) + (20 + 40))
//
// Two 16-byte buffers A and B. Store 10 at A+0, 20 at B+0, 30 at A+8,
// 40 at B+8. SumA = 10 + 30 = 40. SumB = 20 + 40 = 60. Total = 100.
// Distinct from s5_cs_two_bufs_cross (cross-buffer pattern).

fn main() -> i32 {
    a = allocate(16);
    b = allocate(16);
    *(a + 0) = 10;
    *(b + 0) = 20;
    *(a + 8) = 30;
    *(b + 8) = 40;
    a0: u64 = *(a + 0);
    a1: u64 = *(a + 8);
    b0: u64 = *(b + 0);
    b1: u64 = *(b + 8);
    sa: u64 = a0 + a1;     // 40
    sb: u64 = b0 + b1;     // 60
    s: u64 = sa + sb;      // 100
    free(a);
    free(b);
    return s;
}
