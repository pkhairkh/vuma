// s91_cs_overwrite_first.vuma — overwrite c1 to 7, load = 7
// Expected exit code: 7
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at
// c3, then overwrite c1 to 7. Load c1 -> 7 (the overwritten value).
// Uses `*ptr = literal` form. Distinct from s90_cs_overwrite_last
// (8), s86_cs_overwrite_first (230) and s82_cs_overwrite_middle (220).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 7;
    v: u64 = *c1;          // 7
    free(c1);
    free(c2);
    free(c3);
    return v;
}
