// s59_cs_three_cell_sum.vuma — three cells, sum = 205 (80 + 95 + 30)
// Expected exit code: 205
//
// Three 8-byte cells. Store 80/95/30 via `*ptr = literal`, load all
// three, sum -> 205. Uses `*ptr = literal` form (no offsets). Distinct
// from s58_cs_two_cell_sum (200), s58_cs_three_cell_diff (120) and
// s58_cs_overwrite_first (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 80;
    *c2 = 95;
    *c3 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 205
    free(c1);
    free(c2);
    free(c3);
    return s;
}
