// s40_cs_overwrite_first.vuma — overwrite first to 145, sum = 235 (145 + 40 + 50)
// Expected exit code: 235
//
// Three 8-byte cells. Store 30/40/50 via `*ptr = literal`, then
// overwrite the first cell with 145. Load all three, sum -> 235.
// Uses `*ptr = literal` form (no offsets). Distinct from s38_cs_
// overwrite_middle (210) and s34_cs_overwrite_first (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c3 = 50;
    *c1 = 145;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 235
    free(c1);
    free(c2);
    free(c3);
    return s;
}
