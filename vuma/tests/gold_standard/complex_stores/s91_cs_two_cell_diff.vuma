// s91_cs_two_cell_diff.vuma — two cells, diff = 11 (200 - 189)
// Expected exit code: 11
//
// Two 8-byte cells. Store 200/189 via `*ptr = literal`, load both,
// a - b -> 11. Uses `*ptr = literal` form (no offsets). Distinct
// from s90_cs_two_cell_diff (4), s86_cs_two_cell_sum (170) and
// s82_cs_two_cell_sum (160).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 189;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 11
    free(c1);
    free(c2);
    return d;
}
