// s93_cs_two_cell_diff.vuma — two cells, diff = 9 (200 - 191)
// Expected exit code: 9
//
// Two 8-byte cells. Store 200/191 via `*ptr = literal`, load both,
// a - b -> 9. Uses `*ptr = literal` form (no offsets). Distinct from
// s90_cs_two_cell_diff (4), s82_cs_two_cell_sum (160) and s78_cs_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 191;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 9
    free(c1);
    free(c2);
    return d;
}
