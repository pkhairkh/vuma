// s74_cs_three_cell_diff.vuma — three cells, diff = 67 (200 - 80 - 53)
// Expected exit code: 67
//
// Three 8-byte cells. Store 200/80/53 via `*ptr = literal`, load
// all three, diff -> 67. Uses `*ptr = literal` form (no offsets).
// Distinct from s70_cs_three_cell_sum (150), s66_cs_three_cell_diff
// (115) and s62_cs_three_cell_sum (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 80;
    *c3 = 53;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 120
    r: u64 = t - c;        // 67
    free(c1);
    free(c2);
    free(c3);
    return r;
}
