// s10_cs_two_buf_offset_sum.vuma — two 16-byte bufs, sum = 120
// Expected exit code: 120
// Expected exit code (correct): 120  (25 + 35 + 15 + 45)
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// Two 16-byte buffers A and B. Store 25/35 at A+0/A+8, store 15/45 at
// B+0/B+8. Load all four, sum -> 25 + 35 + 15 + 45 = 120. Distinct
// from s6_cs_two_buf_overwrite (overwrites each buf) and
// s5_cs_two_bufs_cross (cross-loads between bufs).

fn main() -> i32 {
    a = allocate(16);
    b = allocate(16);
    *(a + 0) = 25;
    *(a + 8) = 35;
    *(b + 0) = 15;
    *(b + 8) = 45;
    a0: u64 = *(a + 0);
    a1: u64 = *(a + 8);
    b0: u64 = *(b + 0);
    b1: u64 = *(b + 8);
    t1: u64 = a0 + a1;
    t2: u64 = t1 + b0;
    s: u64 = t2 + b1;
    free(a);
    free(b);
    return s;
}
