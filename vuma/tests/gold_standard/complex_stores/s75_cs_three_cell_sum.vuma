// s75_cs_three_cell_sum.vuma — three cells, sum = 153 (50 + 60 + 43)
// Expected exit code: 153
//
// Three 8-byte cells. Store 50/60/43 via `*ptr = literal`, load
// all three, sum -> 153. Uses `*ptr = literal` form (no offsets).
// Distinct from s74_cs_three_cell_diff (67), s70_cs_three_cell_sum
// (150) and s66_cs_three_cell_diff (115).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 60;
    *c3 = 43;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 110
    r: u64 = t + c;        // 153
    free(c1);
    free(c2);
    free(c3);
    return r;
}
