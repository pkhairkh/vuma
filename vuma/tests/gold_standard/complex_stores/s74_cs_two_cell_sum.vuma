// s74_cs_two_cell_sum.vuma — two cells, sum = 187 (100 + 87)
// Expected exit code: 187
//
// Two 8-byte cells. Store 100/87 via `*ptr = literal`, load
// both, sum -> 187. Uses `*ptr = literal` form (no offsets).
// Distinct from s70_cs_two_cell_diff (90), s66_cs_two_cell_sum
// (250) and s62_cs_two_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 87;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 187
    free(c1);
    free(c2);
    return s;
}
