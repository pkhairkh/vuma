// s97_cs_two_cell_sum.vuma — two cells, sum = 24 (14 + 10)
// Expected exit code: 24
//
// Two 8-byte cells. Store 14/10 via `*ptr = literal`, load
// both, a + b -> 24. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s94_cs_two_cell_sum (110), s90_cs_overwrite_last (8), s86_cs_two_cell_sum (170).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 14;
    *c2 = 10;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 24
    free(c1);
    free(c2);
    return s;
}
