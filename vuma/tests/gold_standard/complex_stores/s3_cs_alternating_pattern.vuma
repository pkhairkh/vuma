// s3_cs_alternating_pattern.vuma — alternating store/load across 2 bufs
// Expected exit code: 100  (40 + 60)
//
// Two buffers: store 40 in buf1, store 60 in buf2, then load both and
// sum. Tests alternating writes to different buffers in sequence.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *(buf1 + 0) = 40;
    *(buf2 + 0) = 60;
    a: u64 = *(buf1 + 0);
    b: u64 = *(buf2 + 0);
    s: u64 = a + b;
    free(buf1);
    free(buf2);
    return s;
}
