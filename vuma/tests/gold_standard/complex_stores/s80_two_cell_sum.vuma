// s80_cs_two_cell_sum.vuma — two cells, sum = 12 (6 + 6)
// Expected exit code: 12
//
// Two 8-byte cells. Store 6/6 via `*ptr = literal`, load both,
// sum -> 12. Uses `*ptr = literal` form (no offsets). Distinct
// from s78_cs_two_cell_sum (2), s74_cs_two_cell_sum (95) and
// s73_cs_two_cell_sum (114).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 6;
    *c2 = 6;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 12
    free(c1);
    free(c2);
    return s;
}
