// s31_cs_three_cell_or.vuma — three cells, or = 7 (0x01 | 0x02 | 0x04)
// Expected exit code: 7
//
// Three 8-byte cells. Store 0x01/0x02/0x04 via `*ptr = literal`, load
// all three, OR -> 0x07 = 7. Uses `*ptr = literal` form (no offsets).
// All operands loaded into typed locals before the OR. Distinct from
// s30_cs_three_cell_xor (xor, 119) and s28_cs_three_cells_asc (sum, 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 1;              // 0x01
    *c2 = 2;              // 0x02
    *c3 = 4;              // 0x04
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a | b;
    r: u64 = t | c;        // 0x07 = 7
    free(c1);
    free(c2);
    free(c3);
    return r;
}
