// s68_cs_three_cell_sum.vuma — three cells, sum = 162 (48 + 52 + 62)
// Expected exit code: 162
//
// Three 8-byte cells. Store 48/52/62 via `*ptr = literal`, load
// all three, sum -> 162. Uses `*ptr = literal` form (no offsets).
// Distinct from s66_cs_three_cell_diff (115), s62_cs_three_cell_
// sum (195) and s58_cs_three_cell_diff (120).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 48;
    *c2 = 52;
    *c3 = 62;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 162
    free(c1);
    free(c2);
    free(c3);
    return s;
}
