// s98_cs_three_cell_sum.vuma — three cells, sum = 114 (60 + 40 + 14)
// Expected exit code: 114
//
// Three 8-byte cells. Store 60/40/14 via `*ptr = literal`, load all
// three, a + b + c -> 114. Uses `*ptr = literal` form (no offsets).
// Distinct from s94_cs_three_cell_sum (90), s90_cs_three_cell_diff
// (6) and s86_cs_three_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 40;
    *c3 = 14;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;    // 114
    free(c1);
    free(c2);
    free(c3);
    return s;
}
