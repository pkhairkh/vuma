// s18_cs_overwrite_last.vuma — overwrite last cell, sum = 129 (10 + 20 + 99)
// Expected exit code: 129
//
// Three 8-byte cells. Store 10/20/30 in c1/c2/c3, then overwrite c3
// (the last cell) with 99. Load all three, sum -> 129. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s14_cs_overwrite_first (overwrites the first cell, values
// 10/20/30 -> 99/20/30 = 149) and s9_cs_overwrite_middle (overwrites
// middle cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c3 = 99;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
