// s48_cs_two_cell_sum.vuma — two cells, sum = 240 (115 + 125)
// Expected exit code: 240
//
// Two 8-byte cells. Store 115/125 via `*ptr = literal`, load both,
// sum -> 240. Uses `*ptr = literal` form (no offsets). Distinct
// from s46_cs_two_cell_diff (150) and s42_cs_two_cell_sum (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 115;
    *c2 = 125;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 240
    free(c1);
    free(c2);
    return s;
}
