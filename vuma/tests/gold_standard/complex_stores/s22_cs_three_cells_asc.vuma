// s22_cs_three_cells_asc.vuma — three cells ascending, sum = 102 (12 + 34 + 56)
// Expected exit code: 102
//
// Three 8-byte cells. Store 12/34/56 (ascending by larger step) in
// c1/c2/c3. Load all three, sum -> 102. Uses `*ptr = literal` form
// (no offsets). Distinct from s18_cs_three_cells_inc (11/22/33 = 66)
// and s14_cs_three_cells_desc (30/20/10 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 12;
    *c2 = 34;
    *c3 = 56;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
