// s72_cs_three_cell_sum.vuma — three cells, sum = 190 (70 + 65 + 55)
// Expected exit code: 190
//
// Three 8-byte cells. Store 70/65/55 via `*ptr = literal`, load
// all three, sum -> 190. Uses `*ptr = literal` form (no offsets).
// Distinct from s70_cs_three_cell_sum (150), s69_cs_three_cell_diff
// (225) and s66_cs_three_cell_or (119).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 70;
    *c2 = 65;
    *c3 = 55;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 135
    s: u64 = t + c;        // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
