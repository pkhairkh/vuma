// s6_cs_two_buf_overwrite.vuma — overwrite each of two bufs, sum = 90
// Expected exit code: 90  (40 + 50)
//
// Two 8-byte buffers. Each gets an initial value (10/20), then each
// is overwritten (40/50). Load both, sum -> 90. Distinct from
// s5_cs_two_bufs_cross (cross-store between buffers).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *(a + 0) = 10;
    *(b + 0) = 20;
    *(a + 0) = 40;
    *(b + 0) = 50;
    va: u64 = *(a + 0);
    vb: u64 = *(b + 0);
    s: u64 = va + vb;
    free(a);
    free(b);
    return s;
}
