// s102_cs_two_cell_sum.vuma — store 1 + 22 in 2 cells, load and sum = 23
// Expected exit code: 23
//
// Two 8-byte cells. Store 1 at c1, store 22 at c2, load each and return the sum (23). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_cs_overwrite_first (28), s101_cs_three_cell_sum (150), s101_cs_two_cell_xor (192).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 1;
    *c2 = 22;
    a: u64 = *c1;          // 1
    b: u64 = *c2;          // 22
    s: u64 = a + b;        // 23
    free(c1);
    free(c2);
    return s;
}
