// s104_cs_two_cell_diff.vuma — store 200, 166 in 2 cells, 200-166 = 34
// Expected exit code: 34
//
// Two 8-byte cells. Store 200 at c1, store 166 at c2, load each, return 200 - 166 = 34. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_cs_overwrite_last (1), s102_cs_three_cell_sum (26), s102_cs_two_cell_sum (23).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 166;
    a: u64 = *c1;          // 200
    b: u64 = *c2;          // 166
    d: u64 = a - b;        // 34
    free(c1);
    free(c2);
    return d;
}
