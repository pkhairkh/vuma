// s71_cs_three_cell_sum.vuma — three cells, sum = 170 (55 + 40 + 75)
// Expected exit code: 170
//
// Three 8-byte cells. Store 55/40/75 via `*ptr = literal`, load
// all three, sum -> 170. Uses `*ptr = literal` form (no offsets).
// Distinct from s69_cs_three_cell_diff (225), s70_cs_three_cell_
// sum (150) and s66_cs_three_cell_diff (115).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 55;
    *c2 = 40;
    *c3 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;        // 95
    s: u64 = t + c;        // 170
    free(c1);
    free(c2);
    free(c3);
    return s;
}
