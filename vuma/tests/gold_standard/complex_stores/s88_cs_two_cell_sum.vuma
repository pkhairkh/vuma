// s88_cs_two_cell_sum.vuma — two cells, sum = 175 (100 + 75)
// Expected exit code: 175
//
// Two 8-byte cells. Store 100/75 via `*ptr = literal`, load
// both, sum -> 175. Uses `*ptr = literal` form (no offsets).
// Distinct from s86_cs_two_cell_sum (170), s82_cs_two_cell_
// sum (160) and s78_cs_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 175
    free(c1);
    free(c2);
    return s;
}
