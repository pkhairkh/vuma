// s41_cs_overwrite_middle.vuma - overwrite middle to 120, sum = 225 (40 + 120 + 65)
// Expected exit code: 225
//
// Three 8-byte cells. Store 40/55/65 via `*ptr = literal`, then
// overwrite the middle cell with 120. Load all three, sum -> 225.
// Uses `*ptr = literal` form (no offsets). Distinct from s38_cs_
// overwrite_middle (210) and s34_cs_overwrite_first (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 55;
    *c3 = 65;
    *c2 = 120;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 225
    free(c1);
    free(c2);
    free(c3);
    return s;
}
