// s46_cs_overwrite_first.vuma — overwrite first to 100, sum = 250 (100 + 60 + 90)
// Expected exit code: 250
//
// Three 8-byte cells. Store 30/60/90 via `*ptr = literal`, then
// overwrite the first cell with 100. Load all three, sum -> 250.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_cs_
// overwrite_last (210) and s38_cs_overwrite_middle (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c3 = 90;
    *c1 = 100;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a + b;
    s: u64 = t + c;        // 250
    free(c1);
    free(c2);
    free(c3);
    return s;
}
