// s53_bit_xor_then_and.vuma — (0xCC ^ 0x33) & 0x0F = 0xFF & 0x0F = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: XOR then AND. (204 ^ 51) = 255 (0xFF);
// 255 & 15 = 15 (0x0F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s49_bit_and_then_xor (204) and s50_bit_and_or_chain (48).

fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 51;           // 0x33
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0x0F = 15
    return r;
}
