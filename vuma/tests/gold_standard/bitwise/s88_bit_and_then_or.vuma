// s88_bit_and_then_or.vuma — (0x0F & 0x09) | 0x10 = 0x09 | 0x10 = 0x19 = 25
// Expected exit code: 25
//
// Two-stage bitwise: AND then OR. (15 & 9) = 9 (0x09);
// 9 | 16 = 25 (0x19). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround).
// Distinct from s86_bit_xor_then_and (60), s82_bit_or_
// then_xor (76) and s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 15;           // 0x0F
    b: u64 = 9;            // 0x09
    c: u64 = 16;           // 0x10
    x: u64 = a & b;        // 0x09 = 9
    r: u64 = x | c;        // 0x19 = 25
    return r;
}
