// s100_bit_and_then_or.vuma — (0x33 & 0x25) | 0x04 = 0x21 | 0x04 = 0x25 = 37
// Expected exit code: 37
//
// Two-stage bitwise: AND then OR. (51 & 37) = 33 (0x21);
// 33 | 4 = 37 (0x25). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_bit_or_then_and (41), s94_bit_and_then_shl (224), s90_bit_or_then_xor (19).
fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 37;           // 0x25
    c: u64 = 4;            // 0x04
    x: u64 = a & b;        // 0x21 = 33
    r: u64 = x | c;        // 0x25 = 37
    return r;
}
