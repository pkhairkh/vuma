// s77_bit_xor_then_shl.vuma — (0x12 ^ 0x34) << 1 = 0x26 << 1 = 0x4C = 76
// Expected exit code: 76
//
// Two-stage bitwise: XOR then shift left. 18 ^ 52 = 38 (0x26);
// 38 << 1 = 76 (0x4C). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_xor_then_shl (96), s66_bit_shr_then_or (60) and
// s74_bit_or_then_xor (141).

fn main() -> i32 {
    a: u32 = 18;           // 0x12
    b: u32 = 52;           // 0x34
    c: u32 = 1;
    x: u32 = a ^ b;        // 0x26 = 38
    r: u32 = x << c;       // 0x4C = 76
    return r;
}
