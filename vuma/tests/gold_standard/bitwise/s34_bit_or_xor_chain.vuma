// s34_bit_or_xor_chain.vuma — (0xF0 | 0x0F) ^ 0xAA = 0xFF ^ 0xAA = 0x55 = 85
// Expected exit code: 85
//
// Two-stage bitwise: OR then XOR. (240 | 15) = 255 (0xFF); 255 ^ 170
// = 85 (0x55). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s30_bit_shr_then_or (shr-then-or) and s27_bit_or_and_chain
// (or-and-chain).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 170;          // 0xAA
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0x55 = 85
    return r;
}
