// s26_bit_and_or_xor.vuma — (0xAA & 0x0F) | 0x10 = 0x1A; ^ 0x03 = 25
// Expected exit code: 25
//
// Three-stage bitwise: AND then OR then XOR. (170 & 15) = 10 (0x0A);
// 10 | 16 = 26 (0x1A); 26 ^ 3 = 25 (0x19). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround). Distinct
// from s22_bit_xor_or_xor (xor-or, 252) and s18_bit_and_or_xor
// (and-or-xor, different values, 202).

fn main() -> i32 {
    a: u64 = 170;         // 0xAA
    b: u64 = 15;          // 0x0F
    c: u64 = 16;          // 0x10
    d: u64 = 3;           // 0x03
    x: u64 = a & b;       // 0x0A = 10
    y: u64 = x | c;       // 0x1A = 26
    r: u64 = y ^ d;       // 0x19 = 25
    return r;
}
