// s43_bit_and_chain_3.vuma — 0xFF & 0xF0 & 0xCC = 0xF0 & 0xCC = 0xC0 = 192
// Expected exit code: 192
//
// Three-input AND chain. (255 & 240) = 240; 240 & 204 = 192.
// All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s42_bit_xor_chain_3
// (255) and s38_bit_xor_chain_3 (195).

fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 240;          // 0xF0
    c: u64 = 204;          // 0xCC
    t: u64 = a & b;        // 0xF0 = 240
    r: u64 = t & c;        // 0xC0 = 192
    return r;
}
