// s75_bit_xor_then_and.vuma — (0xB4 ^ 0x69) & 0x78 = 0xDD & 0x78 = 0x58 = 88
// Expected exit code: 88
//
// Two-stage bitwise: XOR then AND. 180 ^ 105 = 221 (0xDD);
// 221 & 120 = 88 (0x58). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_bit_xor_then_or (197), s70_bit_xor_then_shl (96) and
// s66_bit_xor_then_and (51).
fn main() -> i32 {
    a: u32 = 180;          // 0xB4
    b: u32 = 105;          // 0x69
    c: u32 = 120;          // 0x78
    x: u32 = a ^ b;        // 0xDD = 221
    r: u32 = x & c;        // 0x58 = 88
    return r;
}
