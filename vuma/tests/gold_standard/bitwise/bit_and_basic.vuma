// bit_and_basic.vuma — Bitwise AND of two values.
// Expected exit code: 15 (0x0F)
// 0xFF & 0x0F = 0x0F = 15
//
// Workaround note: bitwise ops with an immediate RHS are silently dropped by
// the current codegen, so all operands are loaded into variables first.
fn main() -> i32 {
    val: u64 = 0xFF;
    mask: u64 = 0x0F;
    result: u64 = val & mask;
    return result;
}
