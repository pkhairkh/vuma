// s4_bit_shl_xor.vuma — (1 << 4) ^ 0x10 = 16 ^ 16 = 0
// Expected exit code: 0
//
// 1 << 4 yields 16 (0x10), XORing with 0x10 cancels to 0. The shift
// amount and the XOR operand are both loaded into variables first to
// avoid the immediate-RHS bitwise drop bug.

fn main() -> i32 {
    one: u64 = 1;
    sh: u64 = 4;
    lit: u64 = 16;     // 0x10
    shifted: u64 = one << sh;
    r: u64 = shifted ^ lit;
    return r;
}
