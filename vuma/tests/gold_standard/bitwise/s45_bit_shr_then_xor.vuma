// s45_bit_shr_then_xor.vuma — (0xF0 >> 2) ^ 0x0F = 60 ^ 15 = 51
// Expected exit code: 51
//
// Two-stage bitwise: shift right then XOR. (240 >> 2) = 60 (0x3C);
// 60 ^ 15 = 51 (0x33). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_shl_then_and (shl-then-and, 64) and s38_bit_shr_then_or
// (shr-then-or).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 2;
    c: u64 = 15;           // 0x0F
    s: u64 = a >> b;       // 0x3C = 60
    r: u64 = s ^ c;        // 0x33 = 51
    return r;
}
