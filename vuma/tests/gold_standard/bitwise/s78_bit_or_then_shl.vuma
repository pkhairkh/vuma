// s78_bit_or_then_shl.vuma — (0x00 | 0x01) << 0 = 0x01 << 0 = 0x01 = 1
// Expected exit code: 1
//
// Two-stage bitwise: OR then shift left. (0 | 1) = 1
// (0x01); 1 << 0 = 1 (0x01). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s74_bit_xor_then_or (216),
// s73_bit_xor_then_and (98) and s72_bit_shr_then_xor (240).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 1;            // 0x01
    c: u64 = 0;
    x: u64 = a | b;        // 0x01 = 1
    r: u64 = x << c;       // 0x01 = 1
    return r;
}
