// s13_bit_or_then_xor.vuma — (0xC0 | 0x30) ^ 0x0F = 0xF0 ^ 0x0F = 255
// Expected exit code: 255
//
// OR-then-XOR. (192 | 48) = 0xF0 = 240; 240 ^ 15 = 0xFF = 255. All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s10_bit_xor_then_or (XOR-then-OR,
// different operand order) and s6_bit_or_chain_3 (pure OR chain).

fn main() -> i32 {
    a: u64 = 192;         // 0xC0
    b: u64 = 48;          // 0x30
    c: u64 = 15;          // 0x0F
    x: u64 = a | b;       // 0xF0
    r: u64 = x ^ c;       // 0xFF = 255
    return r;
}
