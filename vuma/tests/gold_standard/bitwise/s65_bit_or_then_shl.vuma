// s65_bit_or_then_shl.vuma — (0x20 | 0x04) << 2 = 0x24 << 2 = 0x90 = 144
// Expected exit code: 144
//
// Two-stage bitwise: OR then shift-left. (32 | 4) = 36 (0x24);
// 36 << 2 = 144 (0x90). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_bit_
// or_then_and (204), s58_bit_or_then_shr (48) and s62_bit_shl_then_
// and (64).

fn main() -> i32 {
    a: u64 = 32;           // 0x20
    b: u64 = 4;            // 0x04
    c: u64 = 2;            // shift amount
    x: u64 = a | b;        // 0x24 = 36
    r: u64 = x << c;       // 0x90 = 144
    return r;
}
