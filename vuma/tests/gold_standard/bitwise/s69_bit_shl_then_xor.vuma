// s69_bit_shl_then_xor.vuma -- (0x03 << 4) ^ 0x55 = 0x30 ^ 0x55 = 0x65 = 101
// Expected exit code: 101
//
// Two-stage bitwise: shift left then XOR. (3 << 4) = 48 (0x30); 48 ^
// 85 = 101 (0x65). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s66_bit_
// shr_then_or (27), s65_bit_and_then_xor (202) and s64_bit_shr_then_
// and (60).
fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 4;            // shift amount
    c: u64 = 85;           // 0x55
    x: u64 = a << b;       // 0x30 = 48
    r: u64 = x ^ c;        // 0x65 = 101
    return r;
}
