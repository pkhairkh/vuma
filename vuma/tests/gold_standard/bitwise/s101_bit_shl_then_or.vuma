// s101_bit_shl_then_or.vuma — (3 << 4) | 7 = 48 | 7 = 55
// Expected exit code: 55
//
// Two-stage bitwise: shift-left then OR. 3 << 4 = 48 (0x30);
// 48 | 7 = 55 (0x37). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s98_bit_shl_then_and (26), s97_bit_shl_then_xor (65) and
// s94_bit_and_then_shl (224).
fn main() -> i32 {
    a: u64 = 3;
    s: u64 = 4;
    b: u64 = 7;
    x: u64 = a << s;       // 0x30 = 48
    r: u64 = x | b;        // 0x37 = 55
    return r;
}
