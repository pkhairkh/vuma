// s30_bit_xor_then_and.vuma — (0xF0 ^ 0x0F) & 0xCC = 0xFF & 0xCC = 0xCC = 204
// Expected exit code: 204
//
// Two-stage bitwise: XOR then AND. (240 ^ 15) = 255 (0xFF); 255 & 204 =
// 204 (0xCC). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s26_bit_shl_then_xor (shl-then-xor, 117) and s22_bit_xor_or_xor
// (xor-or-xor).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 204;          // 0xCC
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0xCC = 204
    return r;
}
