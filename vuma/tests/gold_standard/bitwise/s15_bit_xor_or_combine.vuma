// s15_bit_xor_or_combine.vuma — ((0xF0 ^ 0x30) | 0x0F) = 0xCF = 207
// Expected exit code: 207
//
// Two-stage bitwise chain. (240 ^ 48) = 192 (0xC0); 192 | 15 = 207 (0xCF).
// All operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s14_bit_or_then_xor (OR-then-XOR) and
// s7_bit_and_or_combine (AND-then-OR).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 48;          // 0x30
    c: u64 = 15;          // 0x0F
    x: u64 = a ^ b;       // 0xC0 = 192
    r: u64 = x | c;       // 0xCF = 207
    return r;
}
