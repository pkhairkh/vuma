// s66_bit_or_then_shl.vuma — (0x03 | 0x05) << 4 = 0x07 << 4 = 0x70 = 112
// Expected exit code: 112
//
// Two-stage bitwise: OR then shift left. (3 | 5) = 7 (0x07);
// 7 << 4 = 112 (0x70). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s62_bit_shl_then_and (64), s58_bit_and_then_xor (127) and
// s55_bit_xor_then_shl (180).
fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 5;            // 0x05
    c: u64 = 4;
    x: u64 = a | b;        // 0x07 = 7
    r: u64 = x << c;       // 0x70 = 112
    return r;
}
