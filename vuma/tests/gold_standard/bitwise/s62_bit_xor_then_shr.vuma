// s62_bit_xor_then_shr.vuma — (0xAA ^ 0x55) >> 3 = 0xFF >> 3 = 0x1F = 31
// Expected exit code: 31
// 
// Two-stage bitwise: XOR then shift right. (170 ^ 85) = 255 (0xFF);
// 255 >> 3 = 31 (0x1F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_bit_
// shl_then_xor (79), s58_bit_or_then_shr (48) and s55_bit_or_then_and
// (204).

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 3;
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x >> c;       // 0x1F = 31
    return r;
}
