// s106_bit_and_then_xor.vuma — (0xC0 & 0x7F) ^ 0x19 = 0x40 ^ 0x19 = 0x59 = 89
// Expected exit code: 89
//
// Two-stage bitwise: AND then XOR. (192 & 127) = 64 (0x40); 64 ^ 25 = 89 (0x59). All operands loaded into u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_bit_shl_then_xor (52), s101_bit_and_then_xor (197), s100_bit_and_then_or (37).
fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    b: u64 = 127;          // 0x7F
    c: u64 = 25;           // 0x19
    x: u64 = a & b;        // 0x40 = 64
    r: u64 = x ^ c;        // 0x59 = 89
    return r;
}
