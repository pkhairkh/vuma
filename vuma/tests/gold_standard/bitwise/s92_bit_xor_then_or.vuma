// s92_bit_xor_then_or.vuma — (0xA5 ^ 0x3C) | 0x01 = 0x99 | 0x01 = 0x99 = 153
// Expected exit code: 153
//
// Two-stage bitwise: XOR then OR. (165 ^ 60) = 153 (0x99);
// 153 | 1 = 153 (0x99). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_xor_then_or (21), s86_bit_xor_then_and (60) and
// s82_bit_or_then_xor (76).
fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 60;           // 0x3C
    c: u64 = 1;            // 0x01
    x: u64 = a ^ b;        // 0x99 = 153
    r: u64 = x | c;        // 0x99 = 153
    return r;
}
