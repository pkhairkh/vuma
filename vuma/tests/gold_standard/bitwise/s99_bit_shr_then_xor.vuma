// s99_bit_shr_then_xor.vuma — (0xE0 >> 4) ^ 0x05 = 0x0E ^ 0x05 = 0x0B = 11
// Expected exit code: 11
//
// Two-stage bitwise: shift-right then XOR. 224 >> 4 = 14 (0x0E);
// 14 ^ 5 = 11 (0x0B). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s95_bit_and_then_shr (34), s91_bit_and_then_xor (192) and
// s87_bit_shl_then_xor (64).
fn main() -> i32 {
    a: u64 = 224;          // 0xE0
    s: u64 = 4;
    c: u64 = 5;            // 0x05
    x: u64 = a >> s;       // 0x0E = 14
    r: u64 = x ^ c;        // 0x0B = 11
    return r;
}
