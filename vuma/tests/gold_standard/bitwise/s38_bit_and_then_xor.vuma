// s38_bit_and_then_xor.vuma — (0xF0 & 0xCC) ^ 0x33 = 0xC0 ^ 0x33 = 0xF3 = 243
// Expected exit code: 243
//
// Two-stage bitwise: AND then XOR. (240 & 204) = 192 (0xC0); 192 ^
// 51 = 243 (0xF3). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_bit_xor_then_or (xor-then-or, 255) and s30_bit_and_then_shl
// (and-then-shl).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 204;          // 0xCC
    c: u64 = 51;           // 0x33
    x: u64 = a & b;        // 0xC0 = 192
    r: u64 = x ^ c;        // 0xF3 = 243
    return r;
}
