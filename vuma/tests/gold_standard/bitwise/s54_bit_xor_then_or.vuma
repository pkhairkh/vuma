// s54_bit_xor_then_or.vuma — (0x66 ^ 0x99) | 0x0F = 0xFF | 0x0F = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then OR. (102 ^ 153) = 255 (0xFF);
// 255 | 15 = 255. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_bit_xor_then_shr (31) and s49_bit_xor_then_shl (240).

fn main() -> i32 {
    a: u64 = 102;          // 0x66
    b: u64 = 153;          // 0x99
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x | c;        // 0xFF = 255
    return r;
}
