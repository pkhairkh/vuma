// s21_bit_shr_then_shl.vuma — (0xC0 >> 4) << 3 = 12 << 3 = 96
// Expected exit code: 96
//
// Two-stage bitwise: SHR then SHL. (192 >> 4) = 12 (0x0C); 12 << 3 = 96
// (0x60). All operands loaded into u64 variables first. Distinct from
// s18_bit_shl_xor_shr (shl-xor-shr, three-stage) and s14_bit_shl_then_shr
// (shl-then-shr, opposite direction).

fn main() -> i32 {
    a: u64 = 192;         // 0xC0
    s1: u64 = 4;
    s2: u64 = 3;
    x: u64 = a >> s1;     // 0x0C = 12
    r: u64 = x << s2;     // 0x60 = 96
    return r;
}
