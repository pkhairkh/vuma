// s69_bit_xor_then_or.vuma -- (0xC3 ^ 0x18) | 0x04 = 0xDB | 0x04 = 0xDF = 223
// Expected exit code: 223
//
// Two-stage bitwise: XOR then OR. (195 ^ 24) = 219 (0xDB); 219 | 4 =
// 223 (0xDF). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s66_bit_
// xor_then_and (80), s65_bit_or_then_shl (144) and s64_bit_xor_then_
// or (120).
fn main() -> i32 {
    a: u64 = 195;          // 0xC3
    b: u64 = 24;           // 0x18
    c: u64 = 4;            // 0x04
    x: u64 = a ^ b;        // 0xDB = 219
    r: u64 = x | c;        // 0xDF = 223
    return r;
}
