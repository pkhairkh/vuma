// s18_bit_and_or_xor.vuma — (0xF0 & 0xCC) | 0x0A = 0xC0 | 0x0A = 0xCA = 202
// Expected exit code: 202
//
// Three-stage bitwise: AND then OR. (240 & 204) = 192 (0xC0);
// 192 | 10 = 202 (0xCA). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s14_bit_and_then_or (no XOR framing, different values 0xAA/0x0F/0xF0)
// and s10_bit_xor_then_or (xor-then-or).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 204;         // 0xCC
    c: u64 = 10;          // 0x0A
    x: u64 = a & b;       // 0xC0 = 192
    r: u64 = x | c;       // 0xCA = 202
    return r;
}
