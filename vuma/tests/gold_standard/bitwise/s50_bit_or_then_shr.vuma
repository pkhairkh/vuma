// s50_bit_or_then_shr.vuma — (0xC0 | 0x30) >> 2 = 0xF0 >> 2 = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: OR then shift right. (192 | 48) = 240 (0xF0);
// 240 >> 2 = 60 (0x3C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_bit_and_then_shl (224) and s43_bit_shr_then_and (12).

fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    b: u64 = 48;           // 0x30
    c: u64 = 2;
    x: u64 = a | b;        // 0xF0 = 240
    r: u64 = x >> c;       // 0x3C = 60
    return r;
}
