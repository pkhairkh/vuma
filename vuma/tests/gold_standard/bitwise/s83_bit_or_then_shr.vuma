// s83_bit_or_then_shr.vuma — (0x80 | 0x0C) >> 1 = 0x8C >> 1 = 0x46 = 70
// Expected exit code: 70
//
// Two-stage bitwise: OR then shift right. (128 | 12) = 140 (0x8C);
// 140 >> 1 = 70 (0x46). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_or_then_shl (1), s74_bit_or_then_shr (135)
// and s72_bit_or_then_and (140).
fn main() -> i32 {
    a: u64 = 128;          // 0x80
    b: u64 = 12;           // 0x0C
    c: u64 = 1;            // shift amount
    x: u64 = a | b;        // 0x8C = 140
    r: u64 = x >> c;       // 0x46 = 70
    return r;
}
