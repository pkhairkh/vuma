// s45_bit_xor_then_and.vuma — (0xAA ^ 0x55) & 0x7F = 0xFF & 0x7F = 0x7F = 127
// Expected exit code: 127
//
// Two-stage bitwise: XOR then AND. (170 ^ 85) = 255 (0xFF);
// 255 & 127 = 127 (0x7F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_bit_xor_chain_3 (xor-3-chain, 240) and s38_bit_xor_then_or
// (xor-then-or).

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 127;          // 0x7F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0x7F = 127
    return r;
}
