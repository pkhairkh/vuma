// s84_bit_xor_then_or.vuma — (0x0A ^ 0x0B) | 0x10 = 0x01 | 0x10 = 0x11 = 17
// Expected exit code: 17
//
// Two-stage bitwise: XOR then OR. (10 ^ 11) = 1 (0x01);
// 1 | 16 = 17 (0x11). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s82_bit_or_then_xor (76), s78_bit_or_then_shl (1)
// and s74_bit_xor_then_or (197).
fn main() -> i32 {
    a: u64 = 10;           // 0x0A
    b: u64 = 11;           // 0x0B
    c: u64 = 16;           // 0x10
    x: u64 = a ^ b;        // 0x01 = 1
    r: u64 = x | c;        // 0x11 = 17
    return r;
}
