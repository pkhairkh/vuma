// s105_bit_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0x2C = 0xFF ^ 0x2C = 0xD3 = 211
// Expected exit code: 211
// 
// Two-stage bitwise: OR then XOR. (240 | 15) = 255 (0xFF); 255 ^ 44 = 211 (0xD3). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Operands nonzero & distinct.
// Distinct from s102_bit_or_then_and (59), s101_bit_and_then_xor (197), s100_bit_or_then_and (43).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 44;           // 0x2C
    o: u32 = a | b;        // 0xFF = 255
    r: u32 = o ^ c;        // 0xD3 = 211
    return r;
}
