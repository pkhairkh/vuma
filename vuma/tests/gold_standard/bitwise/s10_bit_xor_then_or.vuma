// s10_bit_xor_then_or.vuma — (0xF0 ^ 0x0F) | 0x10 = 0xFF | 0x10 = 255
// Expected exit code: 255
//
// XOR-then-OR. (240 ^ 15) = 255 (0xFF); 255 | 16 = 255. All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s6_bit_or_chain_3 (pure OR chain) and
// s4_bit_xor3_chain (pure XOR chain).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 15;          // 0x0F
    c: u64 = 16;          // 0x10
    x: u64 = a ^ b;       // 0xFF
    r: u64 = x | c;       // 0xFF = 255
    return r;
}
