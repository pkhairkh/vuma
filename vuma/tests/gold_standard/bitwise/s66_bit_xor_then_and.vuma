// s66_bit_xor_then_and.vuma — (0x66 ^ 0x3C) & 0xF0 = 0x5A & 0xF0 = 0x50 = 80
// Expected exit code: 80
//
// Two-stage bitwise: XOR then AND. (102 ^ 60) = 90 (0x5A);
// 90 & 240 = 80 (0x50). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s62_bit_and_then_or (63), s58_bit_xor_then_and (255) and
// s55_bit_shr_then_xor (15).
fn main() -> i32 {
    a: u64 = 102;          // 0x66
    b: u64 = 60;           // 0x3C
    c: u64 = 240;          // 0xF0
    x: u64 = a ^ b;        // 0x5A = 90
    r: u64 = x & c;        // 0x50 = 80
    return r;
}
