// s86_bit_xor_then_and.vuma — (0x33 ^ 0x0F) & 0x3F = 0x3C & 0x3F = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: XOR then AND. (51 ^ 15) = 60 (0x3C);
// 60 & 63 = 60 (0x3C). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s82_bit_or_then_xor (76), s78_bit_and_then_xor (2) and
// s74_bit_or_then_and (135).
fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 15;           // 0x0F
    c: u64 = 63;           // 0x3F
    x: u64 = a ^ b;        // 0x3C = 60
    r: u64 = x & c;        // 0x3C = 60
    return r;
}
