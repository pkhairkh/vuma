// s81_bit_or_then_shl.vuma — (0x10 | 0x01) << 2 = 0x11 << 2 = 0x44 = 68
// Expected exit code: 68
//
// Two-stage bitwise: OR then shift left. 16 | 1 = 17 (0x11);
// 17 << 2 = 68 (0x44). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_or_then_shl (1), s77_bit_or_then_and (102) and
// s76_bit_or_then_shr (60).
fn main() -> i32 {
    a: u64 = 16;           // 0x10
    b: u64 = 1;            // 0x01
    c: u64 = 2;
    x: u64 = a | b;        // 0x11 = 17
    r: u64 = x << c;       // 0x44 = 68
    return r;
}
