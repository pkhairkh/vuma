// s40_bit_shl_then_and.vuma — (3 << 4) & 0x3C = 0x30 & 0x3C = 0x30 = 48
// Expected exit code: 48
//
// Two-stage bitwise: shift left then AND. (3 << 4) = 48 (0x30);
// 48 & 60 = 48 (0x30). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_or_then_shl (252) and s34_bit_shl_then_and (32).

fn main() -> i32 {
    a: u64 = 3;
    b: u64 = 4;
    c: u64 = 60;           // 0x3C
    s: u64 = a << b;       // 0x30 = 48
    r: u64 = s & c;        // 0x30 = 48
    return r;
}
