// s22_bit_or_xor_chain.vuma — (0xA0 | 0x05) ^ 0x10 = 0xA5 ^ 0x10 = 0xB5 = 181
// Expected exit code: 181
//
// OR then XOR. (160 | 5) = 165 (0xA5); 165 ^ 16 = 181 (0xB5). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_bit_xor_chain_3 (xor-only chain)
// and s14_bit_or_then_xor (or-then-xor, different values).

fn main() -> i32 {
    a: u64 = 160;         // 0xA0
    b: u64 = 5;           // 0x05
    c: u64 = 16;          // 0x10
    x: u64 = a | b;       // 0xA5 = 165
    r: u64 = x ^ c;       // 0xB5 = 181
    return r;
}
