// s56_bit_shl_then_and.vuma — (1 << 5) & 0x3F = 32 & 63 = 32
// Expected exit code: 32
//
// Two-stage bitwise: shift-left then AND. 1 << 5 = 32; 32 & 63 = 32.
// All operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s54_bit_shl_then_xor (235) and
// s50_bit_or_then_shr (15).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 63;           // 0x3F
    x: u64 = a << b;       // 32
    r: u64 = x & c;        // 32
    return r;
}
