// s6_bit_clear_low_nibble.vuma — 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Mask off the low nibble of 0xFF using 0xF0 (240). Result is 240.
// All operands loaded into variables first. Distinct from
// s5_bit_shr_mask (uses shift to extract high nibble).

fn main() -> i32 {
    v: u64 = 255;    // 0xFF
    m: u64 = 240;    // 0xF0
    r: u64 = v & m;  // 0xF0 = 240
    return r;
}
