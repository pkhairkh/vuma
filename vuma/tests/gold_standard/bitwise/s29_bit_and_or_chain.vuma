// s29_bit_and_or_chain.vuma — (0xF0 & 0x70) | 0x05 = 0x70 | 0x05 = 0x75 = 117
// Expected exit code: 117
//
// Two-stage bitwise: AND then OR. (240 & 112) = 112 (0x70); 112 | 5 = 117 (0x75). All operands loaded into u64 variables first. Distinct from s26_bit_and_or_xor (and-or-xor, 25) and s22_bit_or_xor_chain (or-xor chain).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 112;         // 0x70
    c: u64 = 5;           // 0x05
    t: u64 = a & b;       // 0x70 = 112
    r: u64 = t | c;       // 0x75 = 117
    return r;
}
