// s36_bit_or_and_chain.vuma — (0xF0 | 0x0C) & 0x3F = 0xFC & 0x3F = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: OR then AND. (240 | 12) = 252 (0xFC);
// 252 & 0x3F = 60 (0x3C). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s30_bit_and_or_chain (and-or-chain, 0) and s27_bit_or_and_chain (different values).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 12;           // 0x0C
    c: u64 = 63;           // 0x3F
    x: u64 = a | b;        // 0xFC = 252
    r: u64 = x & c;        // 0x3C = 60
    return r;
}
