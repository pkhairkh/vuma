// bit2_insert_field.vuma — Insert value 10 into bits 2-5 of base 0x02.
// Expected exit code: 42
//
// Standard bit-field insertion:
//   result = (base & ~mask) | (value << shift)
// where mask = 0x0F << 2 = 0x3C, shift = 2, value = 10, base = 0x02.
//   (0x02 & ~0x3C) | (10 << 2) = 0x02 | 0x28 = 0x2A = 42.
//
// Workaround note: VUMA's `~` unary is silently dropped during SCG->IR
// lowering, so NOT is computed via XOR with all-ones (0 - 1). All operands
// are also loaded into variables first to avoid the immediate-RHS drop bug.
fn main() -> i32 {
    base: u64 = 0x02;
    value: u64 = 10;
    shift: u64 = 2;
    zero: u64 = 0;
    width_mask: u64 = 0x0F;
    allones: u64 = zero - 1;
    mask: u64 = width_mask << shift;
    inv_mask: u64 = mask ^ allones;
    cleared: u64 = base & inv_mask;
    shifted_val: u64 = value << shift;
    result: u64 = cleared | shifted_val;
    return result;
}
