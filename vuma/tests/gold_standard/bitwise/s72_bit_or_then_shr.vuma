// s72_bit_or_then_shr.vuma — (0xE0 | 0x0E) >> 1 = 0xEE >> 1 = 0x77 = 119
// Expected exit code: 119
//
// Two-stage bitwise: OR then shift right. (224 | 14) = 238 (0xEE);
// 238 >> 1 = 119 (0x77). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_xor_then_shl (96), s69_bit_shl_then_xor (101) and
// s66_bit_xor_then_shl (112).
fn main() -> i32 {
    a: u64 = 224;          // 0xE0
    b: u64 = 14;           // 0x0E
    c: u64 = 1;
    x: u64 = a | b;        // 0xEE = 238
    r: u64 = x >> c;       // 0x77 = 119
    return r;
}
