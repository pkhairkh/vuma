// s65_bit_xor_then_and.vuma — (0x55 ^ 0x0F) & 0xFA = 0x5A & 0xFA = 0x5A = 90
// Expected exit code: 90
//
// Two-stage bitwise: XOR then AND. (85 ^ 15) = 90 (0x5A);
// 90 & 250 = 90 (0x5A). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_bit_
// or_then_and (204), s58_bit_xor_then_and (255) and s62_bit_xor_then_
// shr (31).

fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 15;           // 0x0F
    c: u64 = 250;          // 0xFA
    x: u64 = a ^ b;        // 0x5A = 90
    r: u64 = x & c;        // 0x5A = 90
    return r;
}
