// s86_bit_shl_then_xor.vuma — (0x0F << 3) ^ 0x40 = 0x78 ^ 0x40 = 0x38 = 56
// Expected exit code: 56
//
// Two-stage bitwise: shift left then XOR. (15 << 3) = 120
// (0x78); 120 ^ 64 = 56 (0x38). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_bit_shr_then_and (60), s78_bit_shl_then_or
// (4) and s74_bit_shr_then_xor (55).
fn main() -> i32 {
    a: u64 = 15;           // 0x0F
    b: u64 = 3;            // shift amount
    c: u64 = 64;           // 0x40
    x: u64 = a << b;       // 0x78 = 120
    r: u64 = x ^ c;        // 0x38 = 56
    return r;
}
