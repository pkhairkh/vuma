// s34_bit_xor_then_or.vuma — (0xA5 ^ 0x5A) | 0x0F = 0xFF | 0x0F = 0xFF = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then OR. (165 ^ 90) = 255 (0xFF); 255 | 15
// = 255 (0xFF). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s30_bit_xor_then_and (xor-then-and, 204) and s27_bit_xor_then_shr
// (xor-then-shr).

fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 90;           // 0x5A
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x | c;        // 0xFF = 255
    return r;
}
