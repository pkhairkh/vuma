// s96_bit_and_then_xor.vuma — (0xF0 & 0x70) ^ 0x0A = 0x70 ^ 0x0A = 0x7A = 122
// Expected exit code: 122
//
// Two-stage bitwise: AND then XOR. (240 & 112) = 112 (0x70);
// 112 ^ 10 = 122 (0x7A). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_and_then_shl (224), s90_bit_or_then_xor (19) and
// s86_bit_xor_then_and (60).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 112;          // 0x70
    c: u64 = 10;           // 0x0A
    x: u64 = a & b;        // 0x70 = 112
    r: u64 = x ^ c;        // 0x7A = 122
    return r;
}
