// s99_bit_xor_then_shr.vuma — (0xCC ^ 0x33) >> 2 = 0xFF >> 2 = 0x3F = 63
// Expected exit code: 63
//
// Two-stage bitwise: XOR then shift-right. (204 ^ 51) = 255 (0xFF);
// 255 >> 2 = 63 (0x3F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s95_bit_shl_then_xor (39), s91_bit_xor_then_shl (120) and
// s87_bit_xor_then_and (26).
fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 51;           // 0x33
    s: u64 = 2;
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x >> s;       // 0x3F = 63
    return r;
}
