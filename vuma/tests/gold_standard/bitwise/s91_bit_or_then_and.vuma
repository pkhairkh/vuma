// s91_bit_or_then_and.vuma — (0xF0 | 0x0F) & 0xC3 = 0xFF & 0xC3 = 0xC3 = 195
// Expected exit code: 195
//
// Two-stage bitwise: OR then AND. (240 | 15) = 255 (0xFF);
// 255 & 195 = 195 (0xC3). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_shl_then_and (20), s86_bit_shl_then_xor (33) and
// s82_bit_or_then_xor (76).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 195;          // 0xC3
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x & c;        // 0xC3 = 195
    return r;
}
