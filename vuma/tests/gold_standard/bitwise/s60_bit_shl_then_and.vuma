// s60_bit_shl_then_and.vuma — (1 << 5) & 0xF0 = 0x20 & 0xF0 = 0x20 = 32
// Expected exit code: 32
//
// Two-stage bitwise: shift left then AND. (1 << 5) = 32 (0x20);
// 32 & 240 = 32 (0x20). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_bit_and_then_xor (127) and s57_bit_or_then_shl (240).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 240;          // 0xF0
    x: u64 = a << b;       // 0x20 = 32
    r: u64 = x & c;        // 0x20 = 32
    return r;
}
