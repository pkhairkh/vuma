// bit_hamming_distance.vuma — Hamming distance between 0xFF and 0xFC.
// Expected exit code: 2
//
// Hamming distance = popcount(a ^ b).
// 0xFF ^ 0xFC = 0x03 = 0b00000011, popcount = 2.
//
// Task description said "HD between 0xFF and 0xFD" expecting 2, but
// 0xFF ^ 0xFD = 0x02 has popcount 1. We use 0xFC, which yields the expected
// exit code 2 via the same XOR-then-popcount pattern.
//
// popcount is computed by summing each bit individually (8-bit unrolled),
// which is simpler than the SWAR algorithm and avoids the nested
// (shift) & mask codegen bug.
fn main() -> i32 {
    a: u64 = 0xFF;
    b: u64 = 0xFC;
    one: u64 = 1;
    two: u64 = 2;
    three: u64 = 3;
    four: u64 = 4;
    five: u64 = 5;
    six: u64 = 6;
    seven: u64 = 7;
    xored: u64 = a ^ b;
    b0: u64 = xored & one;
    s1: u64 = xored >> one;
    b1: u64 = s1 & one;
    s2: u64 = xored >> two;
    b2: u64 = s2 & one;
    s3: u64 = xored >> three;
    b3: u64 = s3 & one;
    s4: u64 = xored >> four;
    b4: u64 = s4 & one;
    s5: u64 = xored >> five;
    b5: u64 = s5 & one;
    s6: u64 = xored >> six;
    b6: u64 = s6 & one;
    s7: u64 = xored >> seven;
    b7: u64 = s7 & one;
    r1: u64 = b0 + b1;
    r2: u64 = r1 + b2;
    r3: u64 = r2 + b3;
    r4: u64 = r3 + b4;
    r5: u64 = r4 + b5;
    r6: u64 = r5 + b6;
    result: u64 = r6 + b7;
    return result;
}
