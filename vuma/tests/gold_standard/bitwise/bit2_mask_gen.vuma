// bit2_mask_gen.vuma — Generate a mask of N low bits set: (1 << N) - 1.
// Expected exit code: 7
//
// (1 << 3) - 1 = 8 - 1 = 7 = 0b111.
//
// Workaround note: nested binary expressions where the LHS is a computed
// shift and the RHS is an immediate can be miscompiled, so the shift is
// materialised into its own variable first.
fn main() -> i32 {
    one: u64 = 1;
    three: u64 = 3;
    shifted: u64 = one << three;
    result: u64 = shifted - 1;
    return result;
}
