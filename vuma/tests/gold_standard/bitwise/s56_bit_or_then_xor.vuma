// s56_bit_or_then_xor.vuma — (0xA0 | 0x0A) ^ 0x55 = 0xAA ^ 0x55 = 255
// Expected exit code: 255
//
// Two-stage bitwise: OR then XOR. 160 | 10 = 170 (0xAA); 170 ^ 85 =
// 255 (0xFF). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_xor_then_or (255) and s49_bit_or_then_xor (200).

fn main() -> i32 {
    a: u64 = 160;          // 0xA0
    b: u64 = 10;           // 0x0A
    c: u64 = 85;           // 0x55
    x: u64 = a | b;        // 0xAA = 170
    r: u64 = x ^ c;        // 0xFF = 255
    return r;
}
