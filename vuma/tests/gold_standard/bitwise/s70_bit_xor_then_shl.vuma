// s70_bit_xor_then_shl.vuma — (0x33 ^ 0x35) << 4 = 0x06 << 4 = 0x60 = 96
// Expected exit code: 96
//
// Two-stage bitwise: XOR then shift left. (51 ^ 53) = 6 (0x06);
// 6 << 4 = 96 (0x60). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_bit_or_then_shl (112), s65_bit_or_then_shl (144)
// and s62_bit_shl_then_and (64).
fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 53;           // 0x35
    c: u64 = 4;
    x: u64 = a ^ b;        // 0x06 = 6
    r: u64 = x << c;       // 0x60 = 96
    return r;
}
