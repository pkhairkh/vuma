// s12_bit_and_low_then_shl.vuma — (0xFF & 0x0F) << 4 = 0x0F << 4 = 240
// Expected exit code: 240
//
// Mask low nibble then shift left into high nibble. (255 & 15) = 15
// (0x0F); 15 << 4 = 240 (0xF0). All operands loaded into u64 variables
// first. Distinct from s10_bit_shl_and_mask (shl-then-mask) and
// s6_bit_shl_then_shr (shl-then-shr, no mask).

fn main() -> i32 {
    v: u64 = 255;         // 0xFF
    mask: u64 = 15;       // 0x0F
    sh: u64 = 4;
    masked: u64 = v & mask;   // 0x0F = 15
    r: u64 = masked << sh;    // 0xF0 = 240
    return r;
}
