// s80_bit_shl_then_or.vuma — (0x00 << 0) | 0x09 = 0x00 | 0x09 = 0x09 = 9
// Expected exit code: 9
//
// Two-stage bitwise: shift left then OR. (0 << 0) = 0
// (0x00); 0 | 9 = 9 (0x09). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_bit_shl_then_or (4),
// s74_bit_or_then_xor (190) and s73_bit_shr_then_or (170).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 0;
    c: u64 = 9;            // 0x09
    x: u64 = a << b;       // 0x00 = 0
    r: u64 = x | c;        // 0x09 = 9
    return r;
}
