// s67_bit_and_then_shr.vuma — (0xC0 & 0xF0) >> 4 = 0xC0 >> 4 = 0x0C = 12
// Expected exit code: 12
//
// Two-stage bitwise: AND then shift right. (192 & 240) = 192
// (0xC0); 192 >> 4 = 12 (0x0C). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_bit_shr_then_or (27), s62_bit_shl_then_
// and (64) and s58_bit_and_then_xor (127).
fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    b: u64 = 240;          // 0xF0
    c: u64 = 4;
    x: u64 = a & b;        // 0xC0 = 192
    r: u64 = x >> c;       // 0x0C = 12
    return r;
}
