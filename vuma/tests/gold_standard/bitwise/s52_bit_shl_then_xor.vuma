// s52_bit_shl_then_xor.vuma — (1 << 3) ^ 0x07 = 0x08 ^ 0x07 = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: shift left then XOR. 1 << 3 = 8 (0x08);
// 8 ^ 7 = 15 (0x0F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_bit_xor_then_shr (31) and s46_bit_shr_then_or (60).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 3;
    c: u64 = 7;            // 0x07
    x: u64 = a << b;       // 0x08 = 8
    r: u64 = x ^ c;        // 0x0F = 15
    return r;
}
