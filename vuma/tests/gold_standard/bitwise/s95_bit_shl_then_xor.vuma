// s95_bit_shl_then_xor.vuma — (1 << 4) ^ 0x37 = 0x10 ^ 0x37 = 0x27 = 39
// Expected exit code: 39
//
// Two-stage bitwise: shift-left then XOR. (1 << 4) = 16 (0x10);
// 16 ^ 55 = 39 (0x27). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_shr_then_or (60), s90_bit_shl_then_and (20) and
// s82_bit_shr_then_and (60).
fn main() -> i32 {
    a: u64 = 1;            // 0x01
    s: u64 = 4;
    b: u64 = 55;           // 0x37
    x: u64 = a << s;       // 0x10 = 16
    r: u64 = x ^ b;        // 0x27 = 39
    return r;
}
