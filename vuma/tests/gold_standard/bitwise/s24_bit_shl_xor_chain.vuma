// s24_bit_shl_xor_chain.vuma — (0x01 << 6) ^ 0x20 = 0x40 ^ 0x20 = 0x60 = 96
// Expected exit code: 96
//
// Shift then XOR. 1 << 6 = 64 (0x40); 64 ^ 32 = 96 (0x60). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s22_bit_shl_and_mask (shl-then-and, value
// 16) and s18_bit_shl_xor_shr (shl-then-xor-then-shr).

fn main() -> i32 {
    a: u64 = 1;
    s: u64 = 6;
    c: u64 = 32;          // 0x20
    x: u64 = a << s;      // 0x40 = 64
    r: u64 = x ^ c;       // 0x60 = 96
    return r;
}
