// bit_is_pow2.vuma — Check whether 8 is a power of 2.
// Expected exit code: 1
//
// Power-of-2 test (for n != 0): (n & (n-1)) == 0.
// We compute "is zero" without if/else using the bit-trick:
//   is_zero(x) = 1 - ((x | (0 - x)) >> 63)
// (For any non-zero x in two's complement, x | -x has bit 63 set; for x=0 it
// does not.) We also AND with n's own non-zero-ness so n=0 returns 0.
fn main() -> i32 {
    n: u64 = 8;
    zero: u64 = 0;
    one: u64 = 1;
    sixtythree: u64 = 63;
    nm1: u64 = n - 1;
    x: u64 = n & nm1;
    neg_x: u64 = zero - x;
    y: u64 = x | neg_x;
    high_bit: u64 = y >> sixtythree;
    is_zero: u64 = one - high_bit;
    neg_n: u64 = zero - n;
    z: u64 = n | neg_n;
    n_high: u64 = z >> sixtythree;
    n_nonzero: u64 = n_high;
    result: u64 = is_zero & n_nonzero;
    return result;
}
