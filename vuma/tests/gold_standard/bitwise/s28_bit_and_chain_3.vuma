// s28_bit_and_chain_3.vuma — 0xFF & 0x33 & 0x0F = 0x33 & 0x0F = 0x03 = 3
// Expected exit code: 3
//
// Three-way AND chain. 255 & 51 = 51 (0x33); 51 & 15 = 3 (0x03). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s26_bit_or_chain_3 (or-chain, 119)
// and s22_bit_xor_chain_3 (xor-chain).

fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    b: u64 = 51;          // 0x33
    c: u64 = 15;          // 0x0F
    x: u64 = a & b;       // 0x33 = 51
    r: u64 = x & c;       // 0x03 = 3
    return r;
}
