// bit_log2.vuma — Compute floor(log2(8)) = 3.
// Expected exit code: 3
//
// Counts the number of times n can be shifted right by 1, 2, 4, 8, ... and
// remain non-zero. Each shift contributes its weight (1, 1, 1, 1 for the
// first four 1-bit shifts) to the running sum. Equivalently, this is the
// position of the highest set bit.
//
// is_nonzero(x) is computed via (x | (0 - x)) >> 63 (see bit_is_pow2).
fn main() -> i32 {
    n: u64 = 8;
    zero: u64 = 0;
    one: u64 = 1;
    two: u64 = 2;
    three: u64 = 3;
    four: u64 = 4;
    sixtythree: u64 = 63;
    s1: u64 = n >> one;
    neg_s1: u64 = zero - s1;
    o1: u64 = s1 | neg_s1;
    b1: u64 = o1 >> sixtythree;
    s2: u64 = n >> two;
    neg_s2: u64 = zero - s2;
    o2: u64 = s2 | neg_s2;
    b2: u64 = o2 >> sixtythree;
    s3: u64 = n >> three;
    neg_s3: u64 = zero - s3;
    o3: u64 = s3 | neg_s3;
    b3: u64 = o3 >> sixtythree;
    s4: u64 = n >> four;
    neg_s4: u64 = zero - s4;
    o4: u64 = s4 | neg_s4;
    b4: u64 = o4 >> sixtythree;
    r1: u64 = b1 + b2;
    r2: u64 = r1 + b3;
    result: u64 = r2 + b4;
    return result;
}
