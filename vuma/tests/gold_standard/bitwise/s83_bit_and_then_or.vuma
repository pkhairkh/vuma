// s83_bit_and_then_or.vuma — (0x3E & 0x2F) | 0x80 = 0x2E | 0x80 = 0xAE = 174
// Expected exit code: 174
//
// Two-stage bitwise: AND then OR. (62 & 47) = 46 (0x2E);
// 46 | 128 = 174 (0xAE). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_bit_and_then_or (1), s74_bit_and_then_or (135)
// and s72_bit_and_then_or (60).
fn main() -> i32 {
    a: u64 = 62;           // 0x3E
    b: u64 = 47;           // 0x2F
    c: u64 = 128;          // 0x80
    x: u64 = a & b;        // 0x2E = 46
    r: u64 = x | c;        // 0xAE = 174
    return r;
}
