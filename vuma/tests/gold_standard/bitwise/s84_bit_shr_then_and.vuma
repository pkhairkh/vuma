// s84_bit_shr_then_and.vuma — (0x66 >> 4) & 0x07 = 0x06 & 0x07 = 0x06 = 6
// Expected exit code: 6
//
// Two-stage bitwise: shift right then AND. (102 >> 4) = 6
// (0x06); 6 & 7 = 6 (0x06). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_bit_shr_then_and (60), s78_bit_and_then_xor
// (2) and s74_bit_and_then_shr (49).
fn main() -> i32 {
    a: u64 = 102;          // 0x66
    b: u64 = 4;            // shift amount
    c: u64 = 7;            // 0x07
    x: u64 = a >> b;       // 0x06 = 6
    r: u64 = x & c;        // 0x06 = 6
    return r;
}
