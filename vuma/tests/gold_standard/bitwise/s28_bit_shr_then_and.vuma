// s28_bit_shr_then_and.vuma — (0xFF >> 4) & 0x0F = 0x0F & 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: SHR then AND. (255 >> 4) = 15 (0x0F);
// 15 & 15 = 15. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s26_bit_shl_then_xor (shl-then-xor, 117) and s22_bit_shl_and_mask
// (shl-then-and).

fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    b: u64 = 4;
    c: u64 = 15;          // 0x0F
    x: u64 = a >> b;      // 0x0F = 15
    r: u64 = x & c;       // 0x0F = 15
    return r;
}
