// s76_bit_or_then_shr.vuma — (0xC0 | 0x30) >> 2 = 0xF0 >> 2 = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: OR then shift right. 192 | 48 = 240 (0xF0);
// 240 >> 2 = 60 (0x3C). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_bit_or_then_xor (141), s73_bit_shr_then_or (62) and
// s72_bit_or_then_shr (119).
fn main() -> i32 {
    a: u32 = 192;          // 0xC0
    b: u32 = 48;           // 0x30
    c: u32 = 2;
    x: u32 = a | b;        // 0xF0 = 240
    r: u32 = x >> c;       // 0x3C = 60
    return r;
}
