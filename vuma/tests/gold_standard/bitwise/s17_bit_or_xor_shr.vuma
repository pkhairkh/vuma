// s17_bit_or_xor_shr.vuma — (0xF0 | 0x0C) ^ (0x33 >> 1) = 0xFC ^ 0x19 = 0xE5 = 229
// Expected exit code: 229
//
// Three-stage: OR two values, SHR a third, XOR the results.
// (240 | 12) = 252 (0xFC); (51 >> 1) = 25 (0x19); 252 ^ 25 = 229
// (0xE5). All operands loaded into u64 variables first. Distinct from
// s14_bit_or_then_xor (OR-then-XOR, no shift) and s10_bit_xor_then_or
// (XOR-then-OR).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 12;          // 0x0C
    c: u64 = 51;          // 0x33
    sh: u64 = 1;
    x: u64 = a | b;       // 0xFC = 252
    y: u64 = c >> sh;     // 0x19 = 25
    r: u64 = x ^ y;       // 0xE5 = 229
    return r;
}
