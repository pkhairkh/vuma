// s9_bit_and_chain_4.vuma — 255 & 240 & 204 & 15 = 0
// Expected exit code: 0
//
// Four-way AND chain. 255 & 240 = 240 (0xF0). 240 & 204 = 192
// (0xC0). 192 & 15 = 0 (0xC0 & 0x0F = 0x00). All operands loaded
// into variables first to dodge the immediate-RHS bitwise drop bug.
// Distinct from s6_bit_and_chain_3 (three-way chain).

fn main() -> i32 {
    a: u64 = 255;       // 0xFF
    b: u64 = 240;       // 0xF0
    c: u64 = 204;       // 0xCC
    d: u64 = 15;        // 0x0F
    t1: u64 = a & b;    // 0xF0 = 240
    t2: u64 = t1 & c;   // 0xC0 = 192
    r: u64 = t2 & d;    // 0x00 = 0
    return r;
}
