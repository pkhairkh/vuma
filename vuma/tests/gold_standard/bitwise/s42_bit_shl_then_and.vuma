// s42_bit_shl_then_and.vuma — (1 << 6) & 0x7F = 64 & 127 = 64
// Expected exit code: 64
//
// Two-stage bitwise: shift left then AND. (1 << 6) = 64 (0x40);
// 64 & 127 = 64. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_and_then_xor and s34_bit_shl_then_and.

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 6;
    m: u64 = 127;          // 0x7F
    s: u64 = a << b;       // 64
    r: u64 = s & m;        // 64
    return r;
}
