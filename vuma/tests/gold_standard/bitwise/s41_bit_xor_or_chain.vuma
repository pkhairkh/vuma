// s41_bit_xor_or_chain.vuma - 0x55 ^ 0x0F | 0x30 = 0x5A | 0x30 = 0x7A = 122
// Expected exit code: 122
//
// XOR then OR chain. 85 ^ 15 = 90 (0x5A); 90 | 48 = 122 (0x7A).
// All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s38_bit_xor_chain_3
// (xor-chain-3, 105) and s34_bit_xor_then_or (xor-then-or).

fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 15;           // 0x0F
    c: u64 = 48;           // 0x30
    x: u64 = a ^ b;        // 0x5A = 90
    r: u64 = x | c;        // 0x7A = 122
    return r;
}
