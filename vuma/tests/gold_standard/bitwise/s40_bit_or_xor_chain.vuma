// s40_bit_or_xor_chain.vuma — (0x0F | 0x30) ^ 0x55 = 0x3F ^ 0x55 = 0x6A = 106
// Expected exit code: 106
//
// Two-stage bitwise: OR then XOR. (15 | 48) = 63 (0x3F); 63 ^ 85 =
// 106 (0x6A). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_xor_chain_3 (105) and s34_bit_or_xor_chain (85).

fn main() -> i32 {
    a: u64 = 15;           // 0x0F
    b: u64 = 48;           // 0x30
    c: u64 = 85;           // 0x55
    x: u64 = a | b;        // 0x3F = 63
    r: u64 = x ^ c;        // 0x6A = 106
    return r;
}
