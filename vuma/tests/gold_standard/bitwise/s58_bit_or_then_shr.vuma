// s58_bit_or_then_shr.vuma — (0x80 | 0x40) >> 2 = 0xC0 >> 2 = 0x30 = 48
// Expected exit code: 48
// 
// Two-stage bitwise: OR then shift right. (128 | 64) = 192 (0xC0);
// 192 >> 2 = 48 (0x30). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s51_bit_or_then_and (204), s51_bit_shl_then_xor (79) and s51_bit_
// and_then_shl (120).

fn main() -> i32 {
    a: u64 = 128;          // 0x80
    b: u64 = 64;           // 0x40
    c: u64 = 2;
    x: u64 = a | b;        // 0xC0 = 192
    r: u64 = x >> c;       // 0x30 = 48
    return r;
}
