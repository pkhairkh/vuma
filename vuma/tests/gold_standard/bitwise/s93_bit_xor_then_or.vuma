// s93_bit_xor_then_or.vuma — (0x21 ^ 0x10) | 0x08 = 0x31 | 0x08 = 0x39 = 57
// Expected exit code: 57
//
// Two-stage bitwise: XOR then OR. (33 ^ 16) = 49 (0x31);
// 49 | 8 = 57 (0x39). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_xor_then_or (21), s82_bit_or_then_xor (76) and s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 33;           // 0x21
    b: u64 = 16;           // 0x10
    c: u64 = 8;            // 0x08
    x: u64 = a ^ b;        // 0x31 = 49
    r: u64 = x | c;        // 0x39 = 57
    return r;
}
