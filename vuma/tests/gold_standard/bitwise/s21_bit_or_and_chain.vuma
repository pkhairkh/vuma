// s21_bit_or_and_chain.vuma — (0xF0 | 0x0C) & 0x99 ^ 0x18 = 252 & 153 ^ 24 = 128
// Expected exit code: 128
//
// Three-stage bitwise: OR then AND then XOR. (240 | 12) = 252 (0xFC);
// 252 & 153 = 152 (0x98); 152 ^ 24 = 128 (0x80). All operands loaded
// into u64 variables first. Distinct from s18_bit_and_or_xor (and-or
// prefix, different order) and s14_bit_xor_then_or (xor-or, two-stage).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 12;          // 0x0C
    c: u64 = 153;         // 0x99
    d: u64 = 24;          // 0x18
    x: u64 = a | b;       // 0xFC = 252
    y: u64 = x & c;       // 0x98 = 152
    r: u64 = y ^ d;       // 0x80 = 128
    return r;
}
