// bit_byte_swap.vuma — Byte-swap 0x12345678 to 0x78563412.
// Expected exit code: 18 (low 8 bits of 0x78563412 = 0x12 = 18).
//
// Linux exit codes are 8-bit, so the full 32-bit result is not observable
// as an exit code; only the low byte (0x12 = 18) is. The program computes
// the full 0x78563412 and returns it; the OS truncates to 0x12 on exit.
//
// Byte swap: byte0(input) -> byte3(output), byte3(input) -> byte0(output).
//   out = (in & 0xFF) << 24 | (in >> 8 & 0xFF) << 16
//       | (in >> 16 & 0xFF) << 8 | (in >> 24 & 0xFF)
fn main() -> i32 {
    val: u64 = 0x12345678;
    mFF: u64 = 0xFF;
    eight: u64 = 8;
    sixteen: u64 = 16;
    twentyfour: u64 = 24;
    b0: u64 = val & mFF;
    b1raw: u64 = val >> eight;
    b1: u64 = b1raw & mFF;
    b2raw: u64 = val >> sixteen;
    b2: u64 = b2raw & mFF;
    b3raw: u64 = val >> twentyfour;
    b3: u64 = b3raw & mFF;
    p0: u64 = b0 << twentyfour;
    p1: u64 = b1 << sixteen;
    p2: u64 = b2 << eight;
    p3: u64 = b3;
    s1: u64 = p0 | p1;
    s2: u64 = s1 | p2;
    s3: u64 = s2 | p3;
    return s3;
}
