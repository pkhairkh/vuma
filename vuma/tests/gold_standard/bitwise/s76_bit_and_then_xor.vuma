// s76_bit_and_then_xor.vuma — (0xF0 & 0x70) ^ 0x0F = 0x70 ^ 0x0F = 0x7F = 127
// Expected exit code: 127
//
// Two-stage bitwise: AND then XOR. 240 & 112 = 112 (0x70);
// 112 ^ 15 = 127 (0x7F). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_bit_and_then_shr (49), s73_bit_and_then_shl (72) and
// s72_bit_and_then_or (147).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 112;          // 0x70
    c: u32 = 15;           // 0x0F
    x: u32 = a & b;        // 0x70 = 112
    r: u32 = x ^ c;        // 0x7F = 127
    return r;
}
