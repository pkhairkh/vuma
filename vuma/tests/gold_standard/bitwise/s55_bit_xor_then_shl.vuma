// s55_bit_xor_then_shl.vuma — (0x55 ^ 0x0F) << 1 = 90 << 1 = 180
// Expected exit code: 180
//
// Two-stage bitwise: XOR then shift left. (85 ^ 15) = 90 (0x5A);
// 90 << 1 = 180 (0xB4). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_bit_xor_then_or (255) and s53_bit_xor_then_and (15).

fn main() -> i32 {
    a: u64 = 85;            // 0x55
    b: u64 = 15;            // 0x0F
    c: u64 = 1;
    x: u64 = a ^ b;         // 0x5A = 90
    r: u64 = x << c;        // 0xB4 = 180
    return r;
}
