// s31_bit_xor_chain_3.vuma — 0x55 ^ 0xAA ^ 0x0F = 0xFF ^ 0x0F = 0xF0 = 240
// Expected exit code: 240
//
// Three-way XOR chain. 85 ^ 170 = 255 (0xFF); 255 ^ 15 = 240 (0xF0).
// All operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s30_bit_and_then_shl
// (and-then-shl) and s26_bit_and_or_xor (and-or-xor).

fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 170;          // 0xAA
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0xF0 = 240
    return r;
}
