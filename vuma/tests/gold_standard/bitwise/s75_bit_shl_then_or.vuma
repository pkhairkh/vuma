// s75_bit_shl_then_or.vuma — (5 << 3) | 0xE0 = 0x28 | 0xE0 = 0xE8 = 232
// Expected exit code: 232
//
// Two-stage bitwise: shift left then OR. 5 << 3 = 40 (0x28);
// 40 | 224 = 232 (0xE8). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_bit_and_then_shr (49), s70_bit_shl_then_and (160) and
// s66_bit_or_then_shl (180).
fn main() -> i32 {
    a: u32 = 5;
    b: u32 = 3;
    c: u32 = 224;          // 0xE0
    x: u32 = a << b;       // 0x28 = 40
    r: u32 = x | c;        // 0xE8 = 232
    return r;
}
