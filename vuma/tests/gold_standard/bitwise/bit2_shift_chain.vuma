// bit2_shift_chain.vuma — Chain of left shifts.
// Expected exit code: 16
//
// 1 << 2 << 2 = 4 << 2 = 16.
//
// Workaround note: bitwise ops with an immediate RHS are silently dropped by
// the current codegen, so all shift amounts are loaded into variables first.
fn main() -> i32 {
    val: u64 = 1;
    s1: u64 = 2;
    s2: u64 = 2;
    t1: u64 = val << s1;
    result: u64 = t1 << s2;
    return result;
}
