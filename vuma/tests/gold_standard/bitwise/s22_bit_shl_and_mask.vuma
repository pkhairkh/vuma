// s22_bit_shl_and_mask.vuma — (1 << 4) & 0x3C = 0x10 & 0x3C = 0x10 = 16
// Expected exit code: 16
//
// Shift then mask. 1 << 4 = 16 (0x10); 16 & 60 = 16 (0x10). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s18_bit_shl_xor_shr (shl-then-xor-then-shr)
// and s14_bit_shl_then_or (shl-then-or).

fn main() -> i32 {
    a: u64 = 1;
    s: u64 = 4;
    m: u64 = 60;          // 0x3C
    x: u64 = a << s;      // 0x10 = 16
    r: u64 = x & m;       // 0x10 = 16
    return r;
}
