// bit_round_up_pow2.vuma — Round 200 up to the next power of 2 (256).
// Expected exit code: 0 (low 8 bits of 256 = 0).
//
// Linux exit codes are 8-bit, so the result 256 is not directly observable
// as an exit code (it wraps to 0). The program computes 256 and returns it;
// the OS truncates to 0 on exit. The test is verified by inspecting the
// computed value via the algorithm rather than the exit code alone.
//
// Standard round-up-to-power-of-2 algorithm:
//   v--; v |= v>>1; v |= v>>2; v |= v>>4; v |= v>>8; v |= v>>16; v |= v>>32; v++;
// For v=200: v-- = 199, propagate ones to give 255, then v++ = 256.
fn main() -> i32 {
    v0: u64 = 200;
    one: u64 = 1;
    two: u64 = 2;
    four: u64 = 4;
    eight: u64 = 8;
    sixteen: u64 = 16;
    thirtytwo: u64 = 32;
    v1: u64 = v0 - one;
    s1: u64 = v1 >> one;
    v2: u64 = v1 | s1;
    s2: u64 = v2 >> two;
    v3: u64 = v2 | s2;
    s4: u64 = v3 >> four;
    v4: u64 = v3 | s4;
    s8: u64 = v4 >> eight;
    v5: u64 = v4 | s8;
    s16: u64 = v5 >> sixteen;
    v6: u64 = v5 | s16;
    s32: u64 = v6 >> thirtytwo;
    v7: u64 = v6 | s32;
    v8: u64 = v7 + one;
    return v8;
}
