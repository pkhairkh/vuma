// s39_bit_shl_then_and.vuma — (0x03 << 4) & 0x70 = 0x30 & 0x70 = 0x30 = 48
// Expected exit code: 48
//
// Two-stage bitwise: shift left then AND. (3 << 4) = 48 (0x30);
// 48 & 112 = 48 (0x30). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_or_then_shl (or-then-shl, 252) and s34_bit_shl_then_and.

fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 4;
    c: u64 = 112;          // 0x70
    s: u64 = a << b;       // 0x30 = 48
    r: u64 = s & c;        // 0x30 = 48
    return r;
}
