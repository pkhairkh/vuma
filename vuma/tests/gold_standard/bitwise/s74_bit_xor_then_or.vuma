// s74_bit_xor_then_or.vuma — (0xAB ^ 0xEE) | 0x80 = 0x45 | 0x80 = 0xC5 = 197
// Expected exit code: 197
//
// Two-stage bitwise: XOR then OR. 171 ^ 238 = 69 (0x45);
// 69 | 128 = 197 (0xC5). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s70_bit_xor_then_shl (96), s66_bit_xor_then_and (51) and
// s62_bit_and_then_or (252).
fn main() -> i32 {
    a: u32 = 171;          // 0xAB
    b: u32 = 238;          // 0xEE
    c: u32 = 128;          // 0x80
    x: u32 = a ^ b;        // 0x45 = 69
    r: u32 = x | c;        // 0xC5 = 197
    return r;
}
