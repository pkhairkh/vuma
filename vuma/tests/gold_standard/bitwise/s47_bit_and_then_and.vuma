// s47_bit_and_then_and.vuma — 0xFF & 0xC3 & 0x80 = 0xC3 & 0x80 = 0x80 = 128
// Expected exit code: 128
//
// Two-stage bitwise: AND then AND. (255 & 195) = 195 (0xC3);
// 195 & 128 = 128 (0x80). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_bit_and_then_shl (224) and s42_bit_and_then_xor.

fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 195;          // 0xC3
    c: u64 = 128;          // 0x80
    m: u64 = a & b;        // 0xC3 = 195
    r: u64 = m & c;        // 0x80 = 128
    return r;
}
