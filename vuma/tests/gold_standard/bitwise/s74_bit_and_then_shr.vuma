// s74_bit_and_then_shr.vuma — (0xFF & 0x62) >> 1 = 0x62 >> 1 = 0x31 = 49
// Expected exit code: 49
//
// Two-stage bitwise: AND then shift right. 255 & 98 = 98 (0x62);
// 98 >> 1 = 49 (0x31). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s70_bit_shl_then_and (160), s66_bit_shr_then_or (60) and
// s62_bit_and_then_shl (127).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 98;           // 0x62
    c: u32 = 1;
    x: u32 = a & b;        // 0x62 = 98
    r: u32 = x >> c;       // 0x31 = 49
    return r;
}
