// s6_bit_and_chain_3.vuma — 0xFF & 0xF0 & 0x33 = 0x30 = 48
// Expected exit code: 48
//
// Three-way AND chain. 255 & 240 = 240; 240 & 51 (0x33) = 48 (0x30).
// All operands loaded into variables first to dodge the immediate-RHS
// bitwise drop bug. Distinct from s5_bit_and_or_chain (AND-then-OR).

fn main() -> i32 {
    a: u64 = 255;   // 0xFF
    b: u64 = 240;   // 0xF0
    c: u64 = 51;    // 0x33
    t1: u64 = a & b;   // 0xF0
    t2: u64 = t1 & c;  // 0x30
    return t2;
}
