// bit2_gray_to_binary.vuma — Decode a Gray code value to binary.
// Expected exit code: 7
//
// Inverse Gray code: inv_gray(g) = g ^ (g>>1) ^ (g>>2) ^ (g>>3) ^ ...
// For a 3-bit code, three XOR folds suffice.
// inv_gray(4) = 4 ^ 2 ^ 1 = 0b100 ^ 0b010 ^ 0b001 = 0b111 = 7.
//
// Task description said "decode Gray code 5 -> 7", but inv_gray(5) = 6.
// We use g=4 (the Gray encoding of 7), which yields the expected exit
// code 7 via the same XOR-fold algorithm.
fn main() -> i32 {
    g: u64 = 4;
    one: u64 = 1;
    two: u64 = 2;
    s1: u64 = g >> one;
    s2: u64 = g >> two;
    t1: u64 = g ^ s1;
    result: u64 = t1 ^ s2;
    return result;
}
