// s33_bit_shr_xor_and.vuma — (200 >> 2) ^ 0x0F = 50 ^ 15 = 61; 61 & 0x3F = 61
// Expected exit code: 61
//
// Deterministic test in the bitwise category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_bit_shr_then_or (shr-then-or) and s26_bit_xor_then_shr (xor-then-shr, 63).
fn main() -> i32 {
    a: u64 = 200;
    b: u64 = 2;
    c: u64 = 15;           // 0x0F
    d: u64 = 63;           // 0x3F
    x: u64 = a >> b;       // 50
    y: u64 = x ^ c;        // 0x3D = 61
    r: u64 = y & d;        // 0x3D = 61
    return r;
}
