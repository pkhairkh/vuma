// s36_bit_xor_then_and.vuma — (200 ^ 100) & 0x0F = 0xAC & 0x0F = 0x0C = 12
// Expected exit code: 12
//
// Two-stage bitwise: XOR then AND. (200 ^ 100) = 172
// (0xAC); 172 & 0x0F = 12. All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s30_bit_xor_then_and (xor-then-and, 0) and s27_bit_xor_then_and (different values).

fn main() -> i32 {
    a: u64 = 200;          // 0xC8
    b: u64 = 100;          // 0x64
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xAC = 172
    r: u64 = x & c;        // 0x0C = 12
    return r;
}
