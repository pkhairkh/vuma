// s31_bit_and_then_or.vuma — (0xCC & 0x0F) | 0xF0 = 0x0C | 0xF0 = 0xFC = 252
// Expected exit code: 252
//
// Two-stage bitwise: AND then OR. (204 & 15) = 12 (0x0C); 12 | 240 =
// 252 (0xFC). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s30_bit_shr_then_or (shr-then-or) and s26_bit_or_chain_3 (or-chain).

fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 15;           // 0x0F
    c: u64 = 240;          // 0xF0
    x: u64 = a & b;        // 0x0C = 12
    r: u64 = x | c;        // 0xFC = 252
    return r;
}
