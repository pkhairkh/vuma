// s51_bit_and_then_shl.vuma — (0xFF & 0x0F) << 3 = 0x0F << 3 = 0x78 = 120
// Expected exit code: 120
//
// Two-stage bitwise: AND then shift left. (255 & 15) = 15 (0x0F);
// 15 << 3 = 120 (0x78). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_bit_or_then_shr (60) and s47_bit_and_then_and (128).

fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 15;           // 0x0F
    c: u64 = 3;
    x: u64 = a & b;        // 0x0F = 15
    r: u64 = x << c;       // 0x78 = 120
    return r;
}
