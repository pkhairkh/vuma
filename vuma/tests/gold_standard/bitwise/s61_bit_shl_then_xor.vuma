// s61_bit_shl_then_xor.vuma — (1 << 5) ^ 0x55 = 0x20 ^ 0x55 = 0x75 = 117
// Expected exit code: 117
// 
// Two-stage bitwise: shift left then XOR. (1 << 5) = 32 (0x20);
// 32 ^ 85 = 117 (0x75). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_bit_and_then_xor (127), s58_bit_or_then_shr (48) and s58_bit_
// xor_then_and (255).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 85;           // 0x55
    x: u64 = a << b;       // 0x20 = 32
    r: u64 = x ^ c;        // 0x75 = 117
    return r;
}
