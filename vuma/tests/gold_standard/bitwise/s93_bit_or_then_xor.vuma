// s93_bit_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0xE8 = 0xFF ^ 0xE8 = 0x17 = 23
// Expected exit code: 23
//
// Two-stage bitwise: OR then XOR. (240 | 15) = 255 (0xFF);
// 255 ^ 232 = 23 (0x17). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_or_then_xor (19), s82_bit_or_then_xor (76) and s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 232;          // 0xE8
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0x17 = 23
    return r;
}
