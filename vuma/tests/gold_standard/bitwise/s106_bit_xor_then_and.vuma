// s106_bit_xor_then_and.vuma — (0x52 ^ 0x10) & 0x7F = 0x42 & 0x7F = 0x42 = 66
// Expected exit code: 66
//
// Two-stage bitwise: XOR then AND. (82 ^ 16) = 66 (0x42); 66 & 127 = 66 (0x42). All operands loaded into u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_bit_xor_then_shr (46), s101_bit_xor_then_shl (204), s100_bit_xor_then_and (35).
fn main() -> i32 {
    a: u64 = 82;           // 0x52
    b: u64 = 16;           // 0x10
    c: u64 = 127;          // 0x7F
    x: u64 = a ^ b;        // 0x42 = 66
    r: u64 = x & c;        // 0x42 = 66
    return r;
}
