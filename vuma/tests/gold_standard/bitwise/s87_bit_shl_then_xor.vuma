// s87_bit_shl_then_xor.vuma — (0x0E << 3) ^ 0x30 = 0x70 ^ 0x30 = 0x40 = 64
// Expected exit code: 64
//
// Two-stage bitwise: shift left then XOR. (14 << 3) = 112
// (0x70); 112 ^ 48 = 64 (0x40). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s86_bit_shl_then_xor (56), s82_bit_shr_then_and
// (60) and s78_bit_shl_then_or (4).
fn main() -> i32 {
    a: u64 = 14;           // 0x0E
    b: u64 = 3;            // shift amount
    c: u64 = 48;           // 0x30
    x: u64 = a << b;       // 0x70 = 112
    r: u64 = x ^ c;        // 0x40 = 64
    return r;
}
