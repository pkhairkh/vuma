// s96_bit_or_then_and.vuma — (0xB0 | 0x0F) & 0x33 = 0xBF & 0x33 = 0x33 = 51
// Expected exit code: 51
//
// Two-stage bitwise: OR then AND. (176 | 15) = 191 (0xBF);
// 191 & 51 = 51 (0x33). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_bit_xor_then_and (240), s90_bit_xor_then_or (21) and
// s86_bit_xor_then_and (60).
fn main() -> i32 {
    a: u64 = 176;          // 0xB0
    b: u64 = 15;           // 0x0F
    c: u64 = 51;           // 0x33
    x: u64 = a | b;        // 0xBF = 191
    r: u64 = x & c;        // 0x33 = 51
    return r;
}
