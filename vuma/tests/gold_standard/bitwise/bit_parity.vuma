// bit_parity.vuma — Compute parity of 0xFF.
// Expected exit code: 0
// 0xFF has 8 set bits (even), so parity = 0.
//
// Uses the standard XOR-fold parity algorithm (no loops):
//   v ^= v>>32; v ^= v>>16; v ^= v>>8; v ^= v>>4; v ^= v>>2; v ^= v>>1
//   parity = v & 1
fn main() -> i32 {
    v: u64 = 0xFF;
    one: u64 = 1;
    two: u64 = 2;
    four: u64 = 4;
    eight: u64 = 8;
    sixteen: u64 = 16;
    thirtytwo: u64 = 32;
    s32: u64 = v >> thirtytwo;
    v1: u64 = v ^ s32;
    s16: u64 = v1 >> sixteen;
    v2: u64 = v1 ^ s16;
    s8: u64 = v2 >> eight;
    v3: u64 = v2 ^ s8;
    s4: u64 = v3 >> four;
    v4: u64 = v3 ^ s4;
    s2: u64 = v4 >> two;
    v5: u64 = v4 ^ s2;
    s1: u64 = v5 >> one;
    v6: u64 = v5 ^ s1;
    result: u64 = v6 & one;
    return result;
}
