// s35_bit_and_xor_chain.vuma — (0xCC & 0x0F) ^ 0x30 = 0x0C ^ 0x30 = 0x3C = 60
// Expected exit code: 60
//
// Two-stage bitwise: AND then XOR. (204 & 15) = 12 (0x0C); 12 ^ 48
// = 60 (0x3C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_bit_or_xor_chain (or-xor, 85) and s30_bit_and_then_shl
// (and-then-shl).

fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 15;           // 0x0F
    c: u64 = 48;           // 0x30
    x: u64 = a & b;        // 0x0C = 12
    r: u64 = x ^ c;        // 0x3C = 60
    return r;
}
