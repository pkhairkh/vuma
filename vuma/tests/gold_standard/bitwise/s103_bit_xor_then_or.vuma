// s103_bit_xor_then_or.vuma — (0x01 ^ 0x40) | 0x08 = 0x41 | 0x08 = 0x49 = 73
// Expected exit code: 73
//
// Two-stage bitwise: XOR then OR. (1 ^ 64) = 65 (0x41); 65 | 8 = 73 (0x49). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
fn main() -> i32 {
    a: u32 = 1;           // 0x01
    b: u32 = 64;          // 0x40
    c: u32 = 8;           // 0x08
    x: u32 = a ^ b;       // 0x41 = 65
    r: u32 = x | c;       // 0x49 = 73
    return r;
}
