// s76_bit_xor_then_and.vuma — (0x66 ^ 0x99) & 0xF0 = 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: XOR then AND. 102 ^ 153 = 255 (0xFF);
// 255 & 240 = 240 (0xF0). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_bit_xor_then_or (197), s73_bit_xor_then_and (68) and
// s72_bit_shr_then_xor (13).
fn main() -> i32 {
    a: u32 = 102;          // 0x66
    b: u32 = 153;          // 0x99
    c: u32 = 240;          // 0xF0
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0xF0 = 240
    return r;
}
