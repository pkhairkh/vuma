// s39_bit_xor_then_or.vuma — (0x33 ^ 0x0F) | 0x40 = 0x3C | 0x40 = 0x7C = 124
// Expected exit code: 124
//
// Two-stage bitwise: XOR then OR. (51 ^ 15) = 60 (0x3C); 60 | 64 =
// 124 (0x7C). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_xor_chain_3 (xor-chain, 105) and s34_bit_xor_then_or.

fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 15;           // 0x0F
    c: u64 = 64;           // 0x40
    x: u64 = a ^ b;        // 0x3C = 60
    r: u64 = x | c;        // 0x7C = 124
    return r;
}
