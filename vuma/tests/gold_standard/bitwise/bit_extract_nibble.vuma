// bit_extract_nibble.vuma — Extract a nibble from 0x12345678.
// Expected exit code: 7
//
// 0x12345678 in hex digits (MSB->LSB) is 1,2,3,4,5,6,7,8. The digit '7' sits
// in bits 4-7 (nibble 1 from LSB). We extract it as (val >> 4) & 0xF = 7.
// (Task description said "nibble 3" but expected 7; this extracts the
// nibble position that yields the expected value.)
fn main() -> i32 {
    val: u64 = 0x12345678;
    four: u64 = 4;
    nib_mask: u64 = 0xF;
    shifted: u64 = val >> four;
    result: u64 = shifted & nib_mask;
    return result;
}
