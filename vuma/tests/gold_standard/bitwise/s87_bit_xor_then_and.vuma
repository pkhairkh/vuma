// s87_bit_xor_then_and.vuma — (0x55 ^ 0x0F) & 0x3F = 0x5A & 0x3F = 0x1A = 26
// Expected exit code: 26
//
// Two-stage bitwise: XOR then AND. (85 ^ 15) = 90 (0x5A);
// 90 & 63 = 26 (0x1A). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_bit_xor_then_and (60), s82_bit_or_then_xor (76) and
// s78_bit_and_then_xor (2).
fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 15;           // 0x0F
    c: u64 = 63;           // 0x3F
    x: u64 = a ^ b;        // 0x5A = 90
    r: u64 = x & c;        // 0x1A = 26
    return r;
}
