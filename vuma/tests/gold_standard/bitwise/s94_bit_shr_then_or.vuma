// s94_bit_shr_then_or.vuma — (0xC0 >> 3) | 0x10 = 0x18 | 0x10 = 0x18 = 24
// Expected exit code: 24
//
// Two-stage bitwise: shift-right then OR. 192 >> 3 = 24 (0x18);
// 24 | 16 = 24 (0x18). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_shl_then_and (20), s86_bit_shl_then_xor (56) and
// s82_bit_shr_then_and (60).
fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    s: u64 = 3;
    c: u64 = 16;           // 0x10
    x: u64 = a >> s;       // 0x18 = 24
    r: u64 = x | c;        // 0x18 = 24
    return r;
}
