// s12_bit_or_high_then_xor.vuma — (0xF0 | 0x0F) ^ 0x33 = 0xFF ^ 0x33 = 204
// Expected exit code: 204
//
// OR-then-XOR. (240 | 15) = 255 (0xFF); 255 ^ 51 = 204 (0xCC). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s13_bit_or_then_xor
// (operands 0xC0|0x30=0xF0, ^0x0F=0xFF) and s10_bit_xor_then_or
// (XOR-then-OR, different op order).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 15;          // 0x0F
    c: u64 = 51;          // 0x33
    x: u64 = a | b;       // 0xFF
    r: u64 = x ^ c;       // 0xCC = 204
    return r;
}
