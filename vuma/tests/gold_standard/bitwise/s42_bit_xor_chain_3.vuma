// s42_bit_xor_chain_3.vuma — 0xAA ^ 0x55 ^ 0x0F = 0xF0 = 240
// Expected exit code: 240
//
// Three-way XOR chain. 170 ^ 85 = 255 (0xFF); 255 ^ 15 = 240 (0xF0).
// All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s38_bit_xor_chain_3
// (0x55 ^ 0x33 ^ 0x0F = 105) and s34_bit_xor_then_or.

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 85;           // 0x55
    c: u64 = 15;           // 0x0F
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0xF0 = 240
    return r;
}
