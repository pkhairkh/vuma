// s20_bit_shr_xor_chain.vuma — (0xF0 >> 2) ^ 0x11 = 0x3C ^ 0x11 = 0x2D = 45
// Expected exit code: 45
//
// Shift-right-then-XOR chain. (240 >> 2) = 60 (0x3C); 60 ^ 17 = 45
// (0x2D). All operands loaded into u64 variables first. Distinct from
// s18_bit_shl_xor_shr (shl-xor-shr) and s14_bit_shr_xor_chain (pure
// shr-then-xor, different values).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    sh: u64 = 2;
    b: u64 = 17;          // 0x11
    x: u64 = a >> sh;     // 0x3C = 60
    r: u64 = x ^ b;       // 0x2D = 45
    return r;
}
