// s78_bit_shl_then_or.vuma — (0x00 << 0) | 0x04 = 0x00 | 0x04 = 0x04 = 4
// Expected exit code: 4
//
// Two-stage bitwise: shift left then OR. (0 << 0) = 0
// (0x00); 0 | 4 = 4 (0x04). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s74_bit_or_then_xor (190),
// s73_bit_shr_then_or (170) and s72_bit_or_then_shr (60).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 0;
    c: u64 = 4;            // 0x04
    x: u64 = a << b;       // 0x00 = 0
    r: u64 = x | c;        // 0x04 = 4
    return r;
}
