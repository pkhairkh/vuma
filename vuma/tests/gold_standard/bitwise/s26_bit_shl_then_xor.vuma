// s26_bit_shl_then_xor.vuma — (1 << 5) ^ 0x55 = 0x20 ^ 0x55 = 0x75 = 117
// Expected exit code: 117
//
// Two-stage bitwise: SHL then XOR. (1 << 5) = 32 (0x20); 32 ^ 85 = 117
// (0x75). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s22_bit_shl_and_mask
// (shl-then-and, 0x70) and s18_bit_shl_xor_shr (shl-xor-shr).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 5;
    c: u64 = 85;          // 0x55
    x: u64 = a << b;      // 0x20 = 32
    r: u64 = x ^ c;       // 0x75 = 117
    return r;
}
