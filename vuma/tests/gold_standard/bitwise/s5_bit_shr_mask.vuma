// s5_bit_shr_mask.vuma — (200 >> 2) & 15 = 50 & 15 = 2
// Expected exit code: 2
//
// 200 shifted right by 2 yields 50 (0x32). Masking with 0x0F (15)
// keeps the low nibble = 2. All operands loaded into variables
// first to dodge the immediate-RHS bitwise drop bug.

fn main() -> i32 {
    v: u64 = 200;
    sh: u64 = 2;
    mask: u64 = 15;                // 0x0F
    shifted: u64 = v >> sh;        // 50
    masked: u64 = shifted & mask;  // 2
    return masked;
}
