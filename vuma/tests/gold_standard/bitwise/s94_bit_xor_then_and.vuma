// s94_bit_xor_then_and.vuma — (0xCC ^ 0x33) & 0xF0 = 0xFF & 0xF0 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage bitwise: XOR then AND. (204 ^ 51) = 255 (0xFF);
// 255 & 240 = 240 (0xF0). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_bit_xor_then_or (21), s86_bit_xor_then_and (60) and
// s82_bit_xor_then_shl (120).
fn main() -> i32 {
    a: u64 = 204;          // 0xCC
    b: u64 = 51;           // 0x33
    c: u64 = 240;          // 0xF0
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0xF0 = 240
    return r;
}
