// s41_bit_shl_and_or.vuma - (1 << 4) & 0x1F | 0x40 = 16 | 64 = 80
// Expected exit code: 80
//
// Shift-then-AND-then-OR chain. (1 << 4) = 16 (0x10); 16 & 31 =
// 16; 16 | 64 = 80 (0x50). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_bit_or_then_shl (or-then-shl, 252) and s34_bit_shl_then_and
// (shl-then-and).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 31;           // 0x1F
    d: u64 = 64;           // 0x40
    s: u64 = a << b;       // 16
    t: u64 = s & c;        // 16
    r: u64 = t | d;        // 80
    return r;
}
