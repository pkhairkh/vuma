// s101_bit_and_then_xor.vuma — (0xF0 & 0xC3) ^ 0x05 = 0xC0 ^ 0x05 = 0xC5 = 197
// Expected exit code: 197
//
// Two-stage bitwise: AND then XOR. (240 & 195) = 192 (0xC0);
// 192 ^ 5 = 197 (0xC5). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s98_bit_or_then_xor (22), s97_bit_or_then_and (38) and
// s94_bit_shr_then_or (24).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 195;          // 0xC3
    c: u64 = 5;            // 0x05
    x: u64 = a & b;        // 0xC0 = 192
    r: u64 = x ^ c;        // 0xC5 = 197
    return r;
}
