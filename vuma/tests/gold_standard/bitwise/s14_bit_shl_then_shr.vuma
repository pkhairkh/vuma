// s14_bit_shl_then_shr.vuma — (1 << 6) >> 2 = 64 >> 2 = 16
// Expected exit code: 16
//
// Shift left then shift right. (1 << 6) = 64; 64 >> 2 = 16. All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s10_bit_shl_and_mask
// (shift left then AND-mask) and s9_bit_shl_then_or (shift then OR).

fn main() -> i32 {
    v: u64 = 1;
    sh1: u64 = 6;
    sh2: u64 = 2;
    l: u64 = v << sh1;     // 64
    r: u64 = l >> sh2;     // 16
    return r;
}
