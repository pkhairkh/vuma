// s73_bit_xor_then_and.vuma — (0x55 ^ 0x33) & 0x44 = 0x66 & 0x44 = 0x44 = 68
// Expected exit code: 68
//
// Two-stage bitwise: XOR then AND. (85 ^ 51) = 102 (0x66);
// 102 & 68 = 68 (0x44). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_bit_and_then_xor (36), s69_bit_shl_then_xor (101)
// and s66_bit_xor_then_and (80).
fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 51;           // 0x33
    c: u64 = 68;           // 0x44
    x: u64 = a ^ b;        // 0x66 = 102
    r: u64 = x & c;        // 0x44 = 68
    return r;
}
