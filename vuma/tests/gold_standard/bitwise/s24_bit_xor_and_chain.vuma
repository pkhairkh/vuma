// s24_bit_xor_and_chain.vuma — (0xCC ^ 0x33) & 0x55 = 0xFF & 0x55 = 0x55 = 85
// Expected exit code: 85
//
// XOR then AND. (204 ^ 51) = 255 (0xFF); 255 & 85 = 85 (0x55). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_bit_xor_or_xor (xor-then-or, value
// 252) and s14_bit_xor_chain_3 (xor-only chain).

fn main() -> i32 {
    a: u64 = 204;         // 0xCC
    b: u64 = 51;          // 0x33
    c: u64 = 85;          // 0x55
    x: u64 = a ^ b;       // 0xFF = 255
    r: u64 = x & c;       // 0x55 = 85
    return r;
}
