// s21_bit_and_xor_or.vuma — (0xCC & 0x0F) ^ 0xF0 | 0x03 = 12 ^ 240 | 3 = 255
// Expected exit code: 255
//
// Three-stage bitwise: AND then XOR then OR. (204 & 15) = 12 (0x0C);
// 12 ^ 240 = 252 (0xFC); 252 | 3 = 255 (0xFF). All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s18_bit_and_or_xor (and-or, no xor middle) and
// s14_bit_xor_then_or (xor-then-or, no leading and).

fn main() -> i32 {
    a: u64 = 204;         // 0xCC
    b: u64 = 15;          // 0x0F
    c: u64 = 240;         // 0xF0
    d: u64 = 3;           // 0x03
    x: u64 = a & b;       // 0x0C = 12
    y: u64 = x ^ c;       // 0xFC = 252
    r: u64 = y | d;       // 0xFF = 255
    return r;
}
