// s60_bit_shr_then_or.vuma — (0xF0 >> 3) | 0x10 = 0x1E | 0x10 = 0x1E = 30
// Expected exit code: 30
//
// Two-stage bitwise: shift right then OR. (240 >> 3) = 30 (0x1E);
// 30 | 16 = 30 (0x1E). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_bit_or_then_shr (48) and s57_bit_shr_then_xor (60).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 3;
    c: u64 = 16;           // 0x10
    x: u64 = a >> b;       // 0x1E = 30
    r: u64 = x | c;        // 0x1E = 30
    return r;
}
