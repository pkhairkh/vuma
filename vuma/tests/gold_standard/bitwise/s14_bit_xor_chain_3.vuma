// s14_bit_xor_chain_3.vuma — 0xAA ^ 0x55 ^ 0xFF = 0xFF ^ 0xFF = 0
// Expected exit code: 0
//
// Three-way XOR chain. (170 ^ 85) = 255 (0xFF); 255 ^ 255 = 0. All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s4_bit_xor3_chain (different
// operands) and s9_bit_and_chain_4 (AND chain, not XOR).

fn main() -> i32 {
    a: u64 = 170;         // 0xAA
    b: u64 = 85;          // 0x55
    c: u64 = 255;         // 0xFF
    x: u64 = a ^ b;       // 0xFF
    r: u64 = x ^ c;       // 0x00 = 0
    return r;
}
