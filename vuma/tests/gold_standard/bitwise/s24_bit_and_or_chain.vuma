// s24_bit_and_or_chain.vuma — (0xF0 & 0x70) | 0x03 = 0x70 | 0x03 = 0x73 = 115
// Expected exit code: 115
//
// AND then OR. (240 & 112) = 112 (0x70); 112 | 3 = 115 (0x73). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_bit_or_xor_chain (or-then-xor,
// value 181) and s18_bit_and_or_xor (and-then-or, value 202).

fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 112;         // 0x70
    c: u64 = 3;           // 0x03
    x: u64 = a & b;       // 0x70 = 112
    r: u64 = x | c;       // 0x73 = 115
    return r;
}
