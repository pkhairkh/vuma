// s71_bit_xor_then_and.vuma — (0x5A ^ 0xA5) & 0x1E = 0xFF & 0x1E = 0x1E = 30
// Expected exit code: 30
//
// Two-stage bitwise: XOR then AND. (90 ^ 165) = 255 (0xFF);
// 255 & 30 = 30 (0x1E). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s69_bit_shl_then_xor (101), s70_bit_and_then_xor (126) and s66_bit_
// or_then_shl (112).
fn main() -> i32 {
    a: u64 = 90;           // 0x5A
    b: u64 = 165;          // 0xA5
    m: u64 = 30;           // 0x1E
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & m;        // 0x1E = 30
    return r;
}
