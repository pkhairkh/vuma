// s69_struct_two_instances_sum.vuma -- two instances, sum = 185 (90 + 95)
// Expected exit code: 185
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 90/95 via `*p = literal`, load both fields, sum -> 185. Uses
// `*p = literal` form (no offsets). Distinct from s66_struct_two_
// instances_diff (130), s65_struct_two_instances_sum (180) and s64_
// struct_two_instances_sum (235).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 95;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 185
    free(p1);
    free(p2);
    return s;
}
