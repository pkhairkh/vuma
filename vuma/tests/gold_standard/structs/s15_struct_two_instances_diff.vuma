// s15_struct_two_instances_diff.vuma — two struct instances, diff = 60 (90 - 30)
// Expected exit code: 60
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 90/30 via `*p = literal`, load both, subtract -> 60. Uses
// `*p = literal` form (no offsets). Distinct from
// s14_struct_two_instances_sum (sum framing, 22+55 = 77) and
// s11_struct_two_instances_sum (sum framing, different values).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 30;
    a1: u64 = *p1;
    a2: u64 = *p2;
    d: u64 = a1 - a2;
    free(p1);
    free(p2);
    return d;
}
