// s92_struct_two_instances_diff.vuma — two instances, diff = 88 (200 - 112)
// Expected exit code: 88
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 200/112 via `*p = literal`, load both fields,
// a - b -> 88. Uses `*p = literal` form (no offsets). Distinct
// from s90_struct_two_instances_diff (39), s86_struct_two_
// instances_sum (210) and s82_struct_two_instances_sum (165).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 112;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 88
    free(p1);
    free(p2);
    return d;
}
