// s36_struct_overwrite_field.vuma — store 30, overwrite to 215, load = 215
// Expected exit code: 215
//
// Single 8-byte allocation treated as a one-field struct.
// Store 30, then overwrite the field with 215 via `*p1 =
// literal`. Load and return 215. Uses `*p1 = literal`
// form (no offsets).
// Distinct from s30_struct_overwrite_field (220) and s27_struct_overwrite_field (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 30;
    *p1 = 215;
    a: u64 = *p1;
    free(p1);
    return a;
}
