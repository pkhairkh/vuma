// s81_struct_field_load.vuma — single field, store 217, load = 217
// Expected exit code: 217
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 217 via `*p = literal`, load the field, return 217.
// Uses `*p = literal` form (no offsets). Distinct from
// s78_struct_field_load (1), s77_struct_field_load (164) and
// s76_struct_field_load (176).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 217;
    a: u64 = *p1;
    free(p1);
    return a;
}
