// s72_struct_two_instances_sum.vuma — two instances, sum = 135 (65 + 70)
// Expected exit code: 135
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 65/70 via `*p = literal`, load both fields,
// sum -> 135. Uses `*p = literal` form (no offsets). Distinct
// from s70_struct_two_instances_sum (250), s69_struct_two_
// instances_sum (185) and s66_struct_two_instances_diff (130).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 65;
    *p2 = 70;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 135
    free(p1);
    free(p2);
    return s;
}
