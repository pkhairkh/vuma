// s73_struct_field_load.vuma — store 118, load = 118
// Expected exit code: 118
//
// Single 8-byte allocation treated as a one-field struct. Store
// 118 via `*p = literal`, load the field, return 118. Uses `*p
// = literal` form (no offsets). Distinct from s70_struct_field_
// load (95), s69_struct_field_load (190) and s66_struct_field_
// load (205).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 118;
    a: u64 = *p;
    free(p);
    return a;
}
