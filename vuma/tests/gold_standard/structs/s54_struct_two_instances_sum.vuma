// s54_struct_two_instances_sum.vuma — two instances, sum = 255 (110 + 145)
// Expected exit code: 255
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 110/145 via `*p = literal`, load both fields, sum -> 255.
// Uses `*p = literal` form (no offsets). Distinct from s50_struct_
// two_instances_sum (220) and s49_struct_two_instances_sum (235).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 110;
    *p2 = 145;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 255
    free(p1);
    free(p2);
    return s;
}
