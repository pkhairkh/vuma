// s79_struct_two_instances_sum.vuma — two instances, sum = 15 (5 + 10)
// Expected exit code: 15
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 5/10 via `*p = literal`, load both fields,
// sum -> 15. Uses `*p = literal` form (no offsets). Distinct
// from s78_struct_two_instances_sum (3),
// s77_struct_two_instances_sum (2) and s76_struct_two_instances_
// sum (3).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 5;
    *p2 = 10;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 15
    free(p1);
    free(p2);
    return s;
}
