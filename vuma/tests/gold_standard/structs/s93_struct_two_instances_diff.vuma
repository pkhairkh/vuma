// s93_struct_two_instances_diff.vuma — two instances, diff = 62 (200 - 138)
// Expected exit code: 62
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 200/138 via `*p = literal`, load both fields,
// a - b -> 62. Uses `*p = literal` form (no offsets). Distinct
// from s90_struct_two_instances_diff (39), s82_struct_two_instances_sum (165) and s78_struct_two_instances_sum (3).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 138;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 62
    free(p1);
    free(p2);
    return d;
}
