// struct_pass_to_func.vuma — pass struct address to function
// Expected exit code: 42
//
// main allocates a struct and passes its Address to a helper function.
// The helper stores 42 at offset 0 of the struct. main then loads
// the field and returns it. Exercises Address-typed parameters and
// struct mutation through a passed-in address.

fn store_val(p: Address) -> i32 {
    *(p + 0) = 42;
    return 0;
}

fn main() -> i32 {
    p = allocate(16);
    store_val(p);
    val: u64 = *(p + 0);
    free(p);
    return val;
}
