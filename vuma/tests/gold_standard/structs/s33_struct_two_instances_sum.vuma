// s33_struct_two_instances_sum.vuma — two instances, sum = 70 + 130 = 200
// Expected exit code: 200
//
// Deterministic test in the structs category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_struct_two_instances_sum (80+100=180) and s26_struct_two_instances_diff (diff, 102).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 70;
    *p2 = 130;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 200
    free(p1);
    free(p2);
    return s;
}
