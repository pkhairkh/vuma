// s39_struct_field_load.vuma — store 205, load = 205
// Expected exit code: 205
//
// Single 8-byte allocation treated as a one-field struct. Store
// 205 via `*p = literal`, load and return 205. Uses `*p =
// literal` form (no offsets). Distinct from s38_struct_field_load
// (215) and s34_struct_field_load (198).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 205;
    a: u64 = *p1;
    free(p1);
    return a;
}
