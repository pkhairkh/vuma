// s19_struct_field_load.vuma — store 91, load, return 91
// Expected exit code: 91
//
// Single 8-byte allocation treated as a one-field struct instance.
// Store 91 via `*p = literal`, load it back, return 91. Uses
// `*p = literal` form (no offsets). Distinct from
// s18_struct_field_load (value 88) and s14_struct_field_load
// (value 200).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 91;
    v: u64 = *p;
    free(p);
    return v;
}
