// s73_struct_overwrite_field.vuma — store 50 then overwrite to 149
// Expected exit code: 149
//
// Single 8-byte allocation treated as a one-field struct. Store
// 50 via `*p = literal`, then overwrite the same field to 149
// via `*p = literal`, load -> 149. Uses `*p = literal` form.
// Distinct from s70_struct_overwrite_field (155), s69_struct_
// overwrite_field (145) and s71_struct_field_load (137).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 50;
    *p = 149;
    a: u64 = *p;
    free(p);
    return a;
}
