// s95_struct_overwrite_field.vuma — overwrite field to 23, load = 23
// Expected exit code: 23
//
// Single 8-byte struct allocation. Store 5 via `*p = literal`, then
// overwrite to 23, load -> 23 (the overwritten value). Uses
// `*p = literal` form. Distinct from s94_struct_overwrite_field (92),
// s90_struct_overwrite_field (47) and s82_struct_overwrite_field
// (210).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 23;
    v: u64 = *p;           // 23
    free(p);
    return v;
}
