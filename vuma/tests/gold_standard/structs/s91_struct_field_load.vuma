// s91_struct_field_load.vuma — store 51, load = 51
// Expected exit code: 51
//
// Single 8-byte struct allocation. Store 51 via `*p = literal`,
// load and return 51. Uses `*p = literal` form. Distinct from
// s90_struct_field_load (52), s86_struct_field_load (240) and
// s82_struct_field_load (195).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 51;
    v: u64 = *p;           // 51
    free(p);
    return v;
}
