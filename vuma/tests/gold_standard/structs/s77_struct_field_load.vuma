// s77_struct_field_load.vuma — store 164, load = 164
// Expected exit code: 164
//
// Single 8-byte allocation treated as a one-field struct. Store
// 164 via `*p = literal`, load the field, return 164. Uses `*p
// = literal` form (no offsets). Distinct from s70_struct_field_
// load (95), s66_struct_field_load (205) and s74_struct_field_
// load (193).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 164;
    a: u64 = *p;
    free(p);
    return a;
}
