// s98_struct_overwrite_field.vuma — overwrite field to 83, load = 83
// Expected exit code: 83
//
// Single 8-byte struct allocation. Store 5 via `*p = literal`, then
// overwrite to 83, load -> 83 (the overwritten value). Uses
// `*p = literal` form. Distinct from s94_struct_overwrite_field
// (92), s90_struct_overwrite_field (47) and s86_struct_overwrite_
// field (220).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 83;
    v: u64 = *p;           // 83
    free(p);
    return v;
}
