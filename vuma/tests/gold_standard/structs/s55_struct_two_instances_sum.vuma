// s55_struct_two_instances_sum.vuma — two instances, sum = 240 (95 + 145)
// Expected exit code: 240
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 95/145 via `*p = literal`, load both fields, sum -> 240.
// Uses `*p = literal` form (no offsets). Distinct from s50_struct_
// two_instances_sum (220) and s53_struct_two_instances_diff (135).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 145;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 240
    free(p1);
    free(p2);
    return s;
}
