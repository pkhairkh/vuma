// s37_struct_overwrite_field.vuma — overwrite field, load = 155
// Expected exit code: 155
//
// Deterministic test in the structs category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_struct_overwrite_field (value 220) and s30_struct_overwrite_field (different values).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 80;
    *p1 = 155;
    a: u64 = *p1;          // 155
    free(p1);
    return a;
}
