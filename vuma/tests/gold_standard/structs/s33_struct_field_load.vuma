// s33_struct_field_load.vuma — store 178, load = 178
// Expected exit code: 178
//
// Deterministic test in the structs category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_struct_field_load (value 168) and s26_struct_field_load (different value).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 178;
    a: u64 = *p1;
    free(p1);
    return a;
}
