// s79_struct_field_load.vuma — single field, store 43, load = 43
// Expected exit code: 43
//
// One 8-byte allocation treated as a single-field struct
// instance. Store 43 via `*p = literal`, load the field,
// return 43. Uses `*p = literal` form (no offsets). Distinct
// from s78_struct_field_load (1), s77_struct_field_load (2) and
// s76_struct_field_load (3).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 43;
    a: u64 = *p1;
    free(p1);
    return a;
}
