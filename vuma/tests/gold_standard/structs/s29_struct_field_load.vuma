// s29_struct_field_load.vuma — store 188, load = 188
// Expected exit code: 188
//
// Single 8-byte allocation treated as a one-field struct. Store the literal 188 via `*p = literal`, load it back, return. Uses `*p = literal` form (no offsets). Distinct from s26_struct_field_load (value 222) and s22_struct_field_load (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 188;
    a: u64 = *p1;
    free(p1);
    return a;
}
