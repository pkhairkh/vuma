// s44_struct_two_instances_sum.vuma — two instances, sum = 215 (95 + 120)
// Expected exit code: 215
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 95/120 via `*p = literal`, load both fields, sum -> 215. Uses
// `*p = literal` form (no offsets). Distinct from s42_struct_two_
// instances_sum (205) and s38_struct_two_instances_sum (225).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 120;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 215
    free(p1);
    free(p2);
    return s;
}
