// struct_compute.vuma — store a and b, return a*a + b*b
// Expected exit code: 25
//
// Allocates a 2-field struct with a=3 (offset 0) and b=4 (offset 8).
// Loads both fields, computes a*a + b*b = 9 + 16 = 25, returns it.
// Verifies that struct fields can be operands in arithmetic
// computations (Pythagorean sum of squares).

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 3;
    *(p + 8) = 4;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    aa: u64 = a * a;
    bb: u64 = b * b;
    sum: u64 = aa + bb;
    free(p);
    return sum;
}
