// s12_struct_overwrite_field.vuma — overwrite single field, final = 175
// Expected exit code: 175
//
// 8-byte allocation treated as a one-field struct. Store 7 via
// `*p = 7`, then overwrite with 175 via `*p = 175` (literal
// overwrite, last write wins). Load and return 175. Uses `*p =
// literal` form (no offsets). Distinct from s9_struct_overwrite_field
// (values 5/90) and s13_struct_overwrite_field (different values).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 7;
    *p = 175;
    v: u64 = *p;
    free(p);
    return v;
}
