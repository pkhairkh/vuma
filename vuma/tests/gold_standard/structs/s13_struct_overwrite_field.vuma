// s13_struct_overwrite_field.vuma — store 13, overwrite 97, load 97
// Expected exit code: 97
//
// Single 8-byte allocation treated as a one-field struct. Store 13
// via `*p = literal`, overwrite with 97 (last write wins). Load and
// return 97. Uses `*p = literal` form (no offsets). Distinct from
// s9_struct_overwrite_field (values 8/200) and s4_struct_overwrite_field
// (uses *(p+N) form).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 13;
    *p = 97;
    v: u64 = *p;
    free(p);
    return v;
}
