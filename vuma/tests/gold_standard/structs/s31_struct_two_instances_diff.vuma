// s31_struct_two_instances_diff.vuma — two instances, diff = 150 (220 - 70)
// Expected exit code: 150
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 220/70 via `*p = literal`, load both fields, subtract -> 150.
// Uses `*p = literal` form (no offsets). Distinct from
// s30_struct_two_instances_sum (sum, 180) and s28_struct_two_instances_and
// (and, 48).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 220;
    *p2 = 70;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a - b;        // 150
    free(p1);
    free(p2);
    return s;
}
