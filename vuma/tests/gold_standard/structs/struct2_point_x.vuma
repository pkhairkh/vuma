// struct2_point_x.vuma — Point{x=10, y=20}, return x
// Expected exit code: 10
//
// Allocates a Point {x: u64, y: u64} struct (16 bytes), stores x=10 at
// offset 0 and y=20 at offset 8 via *(p + N), then loads x and returns
// it. Verifies the canonical struct field-access pattern at offset 0.

struct Point {
    x: u64,
    y: u64,
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 10;
    *(p + 8) = 20;
    x: u64 = *(p + 0);
    free(p);
    return x;
}
