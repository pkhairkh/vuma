// s81_struct_two_instances_sum.vuma — two instances, sum = 195 (100 + 95)
// Expected exit code: 195
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 100/95 via `*p = literal`, load both fields,
// sum -> 195. Uses `*p = literal` form (no offsets). Distinct
// from s78_struct_two_instances_sum (3),
// s77_struct_two_instances_sum (154) and s76_struct_two_instances_
// sum (172).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 95;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 195
    free(p1);
    free(p2);
    return s;
}
