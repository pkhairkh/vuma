// struct_modify_in_func.vuma — function modifies a struct field
// Expected exit code: 99
//
// main allocates a struct and stores 42 at offset 0. It then calls a
// helper that overwrites offset 0 with 99. main loads the field back
// and returns the new value (99), confirming that writes through a
// passed Address are visible to the caller.

fn set_field(p: Address) -> i32 {
    *(p + 0) = 99;
    return 0;
}

fn main() -> i32 {
    p = allocate(16);
    *(p + 0) = 42;
    set_field(p);
    val: u64 = *(p + 0);
    free(p);
    return val;
}
