// s7_struct_overwrite_field_2.vuma — overwrite middle field, sum = 10+50+30 = 90
// Expected exit code: 90
//
// 24-byte struct (three u64 fields). Store 10/20/30 at offsets
// 0/8/16, then overwrite offset 8 (middle field) with 50. Load all
// three, sum -> 10 + 50 + 30 = 90. Uses pointer-arithmetic aliases.
// Distinct from s6_struct_three_field_middle (overwrites with 80,
// sum 100) and s5_struct_overwrite_one_field (overwrites one field,
// different values).

struct Triple {
    a: u64,
    b: u64,
    c: u64,
}

fn main() -> i32 {
    p = allocate(24);
    f0 = p;
    f1 = p + 8;
    f2 = p + 16;
    *f0 = 10;
    *f1 = 20;
    *f2 = 30;
    *f1 = 50;
    a: u64 = *f0;
    b: u64 = *f1;
    c: u64 = *f2;
    t1: u64 = a + b;
    s: u64 = t1 + c;
    free(p);
    return s;
}
