// s19_struct_two_instances_diff.vuma — two struct instances, diff = 45 (75 - 30)
// Expected exit code: 45
//
// Two 8-byte allocations, each treated as a one-field struct
// instance. Store 75/30 via `*p = literal`, load both, subtract
// (a1 - a2) -> 45. Uses `*p = literal` form (no offsets). Distinct
// from s18_struct_two_instances_sum (26/48 = 74, sum) and
// s14_struct_two_instances_sum (22/55 = 77, sum).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 75;
    *p2 = 30;
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 - a2;
    free(p1);
    free(p2);
    return s;
}
