// s37_struct_two_instances_diff.vuma — two instances, diff = 200 - 55 = 145
// Expected exit code: 145
//
// Deterministic test in the structs category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_struct_two_instances_sum (sum, 200) and s30_struct_two_instances_sum (80+100=180).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 55;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 145
    free(p1);
    free(p2);
    return d;
}
