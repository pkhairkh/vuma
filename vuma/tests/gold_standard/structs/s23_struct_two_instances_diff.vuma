// s23_struct_two_instances_diff.vuma — two struct instances, diff = 150 (200 - 50)
// Expected exit code: 150
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 200/50 via `*p = literal`, load both, diff -> 150. Uses `*p =
// literal` form (no offsets). Distinct from s22_struct_two_instances_sum
// (44 + 56 = 100) and s24_struct_two_instances_diff (90 - 46 = 44).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 50;
    a1: u64 = *p1;
    a2: u64 = *p2;
    d: u64 = a1 - a2;     // 150
    free(p1);
    free(p2);
    return d;
}

