// s105_struct_overwrite_field.vuma — overwrite to 207, load = 207
// Expected exit code: 207
// 
// Single 8-byte struct allocation. Store 10, then overwrite to 207, load and return 207 (the overwritten value). Uses `*p = literal` form. Straight-line code only.
// Distinct from s102_struct_overwrite_field (6), s101_struct_overwrite_field (19), s100_struct_overwrite_field (17).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    *p = 207;
    v: u64 = *p;           // 207
    free(p);
    return v;
}
