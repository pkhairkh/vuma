// struct_four_fields.vuma — four-field struct, sum all fields
// Expected exit code: 10
//
// Allocates a Quad {a, b, c, d: u64} struct (32 bytes), stores
// a=1, b=2, c=3, d=4 at offsets 0, 8, 16, 24, then sums them.
// 1 + 2 + 3 + 4 = 10.

struct Quad {
    a: u64,
    b: u64,
    c: u64,
    d: u64,
}

fn main() -> i32 {
    q = allocate(32);
    *(q + 0) = 1;
    *(q + 8) = 2;
    *(q + 16) = 3;
    *(q + 24) = 4;
    a: u64 = *(q + 0);
    b: u64 = *(q + 8);
    c: u64 = *(q + 16);
    d: u64 = *(q + 24);
    sum: u64 = a + b + c + d;
    free(q);
    return sum;
}
