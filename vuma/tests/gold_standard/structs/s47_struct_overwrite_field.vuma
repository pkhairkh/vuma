// s47_struct_overwrite_field.vuma — store 35, overwrite to 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as one struct instance. Store 35
// via `*p = literal`, then overwrite with 175. Load and return 175.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_struct
// _overwrite_field (155) and s42_struct_overwrite_field (140).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 35;
    *p1 = 175;
    a: u64 = *p1;
    free(p1);
    return a;
}
