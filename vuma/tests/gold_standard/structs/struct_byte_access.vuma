// struct_byte_access.vuma — store as bytes, load as u64
// Expected exit code: 66 (0x42)
//
// Allocates an 8-byte buffer. Stores the byte pattern 0x42 in byte 0
// and 0 in bytes 1..3, simulating writing a u64 value of 0x42. Then
// loads it back as a u64 (returns 66, the decimal value of 0x42).
// Demonstrates byte-level struct field access and zero-extension
// to a wider type on load.

fn main() -> i32 {
    p = allocate(8);
    // Store 0x42 (=66) byte-by-byte (little-endian)
    *(p + 0) = 66;
    *(p + 1) = 0;
    *(p + 2) = 0;
    *(p + 3) = 0;
    // Load as u64 (zero-extended from byte 0)
    val: u64 = *(p + 0);
    free(p);
    return val;
}
