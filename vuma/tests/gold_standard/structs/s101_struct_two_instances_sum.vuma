// s101_struct_two_instances_sum.vuma — two instances, sum = 205 (110 + 95)
// Expected exit code: 205
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 110/95 via `*p = literal`, load both fields,
// a + b -> 205. Uses `*p = literal` form (no offsets). Distinct
// from s98_struct_two_instances_diff (84),
// s97_struct_two_instances_sum (12) and s94_struct_two_instances_
// diff (58).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 110;
    *p2 = 95;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
