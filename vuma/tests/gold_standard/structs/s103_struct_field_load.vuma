// s103_struct_field_load.vuma — store 11, load = 11
// Expected exit code: 11
//
// Single 8-byte struct allocation. Store 11 via `*p = literal`, load and return 11. Uses `*p = literal` form. Straight-line code only.
// Distinct from s102_struct_field_load (5), s101_struct_field_load (71), s100_struct_field_load (8).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 11;
    v: u64 = *p;           // 11
    free(p);
    return v;
}
