// s98_struct_field_load.vuma — store 82, load = 82
// Expected exit code: 82
//
// Single 8-byte struct allocation. Store 82 via `*p = literal`,
// load and return 82. Uses `*p = literal` form. Distinct from
// s94_struct_field_load (63), s90_struct_field_load (52) and
// s86_struct_field_load (145).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 82;
    v: u64 = *p;           // 82
    free(p);
    return v;
}
