// struct_reuse.vuma — free a struct, allocate a new one, reuse the slot
// Expected exit code: 42
//
// Allocates p1, stores 99, frees it. Then allocates p2 (which the
// allocator may place in the same slot as the freed p1), stores 42,
// and loads it back. Verifies that freed memory can be reallocated
// and used normally — no allocator corruption or use-after-free.

fn main() -> i32 {
    p1 = allocate(8);
    *(p1 + 0) = 99;
    free(p1);
    p2 = allocate(8);
    *(p2 + 0) = 42;
    val: u64 = *(p2 + 0);
    free(p2);
    return val;
}
