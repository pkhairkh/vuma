// s96_struct_two_instances_sum.vuma — two instances, sum = 195 (95 + 100)
// Expected exit code: 195
//
// Two 8-byte struct allocations. Store 95/100 via `*ptr = literal`,
// load both, a + b -> 195. Uses `*ptr = literal` form. Distinct from
// s94_struct_two_instances_diff (58),
// s90_struct_two_instances_diff (39) and
// s86_struct_two_instances_sum (210).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 195
    free(p1);
    free(p2);
    return s;
}
