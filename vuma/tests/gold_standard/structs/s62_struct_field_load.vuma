// s62_struct_field_load.vuma — store 182, load = 182
// Expected exit code: 182
// 
// Single 8-byte allocation treated as a one-field struct. Store 182
// via `*p = literal`, load the field, return 182. Uses `*p =
// literal` form (no offsets). Distinct from s51_struct_field_load
// (178), s58_struct_field_load (165) and s55_struct_field_load (175).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 182;
    a: u64 = *p;
    free(p);
    return a;
}
