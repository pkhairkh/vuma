// s100_struct_overwrite_field.vuma — overwrite field to 17, load = 17
// Expected exit code: 17
//
// Single 8-byte struct allocation. Store 5 via `*p =
// literal`, then overwrite to 17, load -> 17 (the overwritten
// value). Uses `*p = literal` form.
// Distinct from s97_struct_overwrite_field (9), s94_struct_overwrite_field (92), s90_struct_overwrite_field (47).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 17;
    v: u64 = *p;           // 17
    free(p);
    return v;
}
