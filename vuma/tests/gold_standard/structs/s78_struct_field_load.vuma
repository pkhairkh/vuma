// s78_struct_field_load.vuma — single field, store 1, load = 1
// Expected exit code: 1
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 1 via `*p = literal`, load the field, return 1.
// Uses `*p = literal` form (no offsets). Distinct from s74_struct_
// field_load (185), s73_struct_field_load (215) and s72_struct_
// field_load (225).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 1;
    a: u64 = *p1;
    free(p1);
    return a;
}
