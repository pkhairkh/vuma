// s59_struct_field_load.vuma — store 188, load = 188
// Expected exit code: 188
//
// Single 8-byte allocation treated as a one-field struct. Store 188
// via `*p = literal`, load the field, return 188. Uses `*p = literal`
// form (no offsets). Distinct from s58_struct_two_instances_diff (110),
// s58_struct_field_load (165) and s58_struct_overwrite_field (220).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 188;
    a: u64 = *p;
    free(p);
    return a;
}
