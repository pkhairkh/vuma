// s16_struct_field_value.vuma — single-field struct, load field = 195
// Expected exit code: 195
//
// 8-byte allocation treated as a one-field struct. Store 195 via
// `*p = 195`, load it back, return 195. Uses `*p = literal` form (no
// offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s14_struct_field_load (value 56) and s9_struct_field_load (value 33).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 195;
    a: u64 = *p;
    free(p);
    return a;
}
