// s29_struct_two_instances_sum.vuma — two instances, sum = 125 (70 + 55)
// Expected exit code: 125
//
// Two 8-byte allocations, each treated as a one-field struct instance. Store 70/55 via `*p = literal`, load both, sum -> 125. Uses `*p = literal` form (no offsets). Distinct from s26_struct_two_instances_xor (xor, 85^51=102) and s22_struct_two_instances_sum (44+56=100).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 70;
    *p2 = 55;
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 + a2;     // 125
    free(p1);
    free(p2);
    return s;
}
