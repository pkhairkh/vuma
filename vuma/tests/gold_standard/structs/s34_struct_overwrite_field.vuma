// s34_struct_overwrite_field.vuma — overwrite field, load = 230
// Expected exit code: 230
//
// Single 8-byte allocation treated as a one-field struct. Store 25,
// then overwrite the field with 230 via `*p = literal`. Load and
// return 230. Uses `*p = literal` form (no offsets). Distinct from
// s30_struct_overwrite_field (220) and s27_struct_overwrite_field
// (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 25;
    *p1 = 230;
    a: u64 = *p1;
    free(p1);
    return a;
}
