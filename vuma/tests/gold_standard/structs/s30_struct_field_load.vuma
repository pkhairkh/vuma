// s30_struct_field_load.vuma — store 168, load = 168
// Expected exit code: 168
//
// Single 8-byte allocation treated as a one-field struct. Store 168 via
// `*p = literal`, load and return 168. Uses `*p = literal` form (no
// offsets). Distinct from s26_struct_field_load (different value) and
// s22_struct_field_load (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 168;
    a: u64 = *p1;
    free(p1);
    return a;
}
