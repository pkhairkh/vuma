// struct_conditional.vuma — store value based on bool variable (no if)
// Expected exit code: 42
//
// Uses a bool variable (true = 1) to compute a value to store in the
// struct via arithmetic only (no if/else — those are known-broken in
// VUMA). The computed value 1 * 42 = 42 is stored at offset 0 and
// returned. Demonstrates that bool-typed scalars participate in
// struct-field value computation.

fn main() -> i32 {
    p = allocate(8);
    flag: bool = true;
    v: u64 = flag;
    val: u64 = v * 42;
    *(p + 0) = val;
    result: u64 = *(p + 0);
    free(p);
    return result;
}
