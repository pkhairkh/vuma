// s11_struct_overwrite_middle_field.vuma — overwrite middle field, sum = 139
// Expected exit code: 139
// Expected exit code (correct): 139  (10 + 99 + 30)
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// 24-byte struct (three u64 fields). Store 10/20/30 at offsets 0/8/16,
// then overwrite the middle field (offset 8) with 99. Load all three,
// sum -> 10 + 99 + 30 = 139. Distinct from s10_struct_partial_overwrite
// (overwrites some fields) and s8_struct_overwrite_middle (different
// vals, no sum).

struct Triple {
    a: u64,
    b: u64,
    c: u64,
}

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 10;
    *(p + 8) = 20;
    *(p + 16) = 30;
    *(p + 8) = 99;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    t: u64 = a + b;
    s: u64 = t + c;
    free(p);
    return s;
}
