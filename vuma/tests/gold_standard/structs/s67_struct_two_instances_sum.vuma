// s67_struct_two_instances_sum.vuma — two instances, sum = 230 (110 + 120)
// Expected exit code: 230
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 110/120 via `*p = literal`, load both
// fields, sum -> 230. Uses `*p = literal` form (no offsets).
// Distinct from s66_struct_two_instances_diff (130), s62_
// struct_two_instances_sum (230) and s58_struct_two_instances_
// diff (110).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 110;
    *p2 = 120;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 230
    free(p1);
    free(p2);
    return s;
}
