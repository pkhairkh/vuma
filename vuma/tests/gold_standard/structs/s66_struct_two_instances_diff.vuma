// s66_struct_two_instances_diff.vuma — two instances, diff = 130 (220 - 90)
// Expected exit code: 130
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 220/90 via `*p = literal`, load both fields,
// diff -> 130. Uses `*p = literal` form (no offsets). Distinct
// from s62_struct_two_instances_sum (230), s58_struct_two_
// instances_diff (110) and s55_struct_two_instances_sum (240).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 220;
    *p2 = 90;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = a - b;        // 130
    free(p1);
    free(p2);
    return d;
}
