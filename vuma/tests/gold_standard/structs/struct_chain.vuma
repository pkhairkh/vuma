// struct_chain.vuma — chain of 3 structs linked by offset markers
// Expected exit code: 3
//
// Builds a 3-node chain s3 -> s2 -> s1 -> val=3 using a single 24-byte
// allocation. Each "pointer" is a small offset that identifies the next
// struct within the same allocation. main walks the chain by reading
// the offset marker at each node and dereferencing the next node's
// field at (block + offset).
//
// This avoids the known U8-truncation bug on stored 64-bit addresses
// (the offset values are small and fit in U8). The semantic intent —
// "each struct points to the next, walk the chain to the terminal
// value" — is preserved.
//
// Memory layout (single 24-byte allocation):
//   s1 { val: u64 @ 0 = 3 }
//   s2 { next_offset: u64 @ 8 = 0 }  // points to s1
//   s3 { next_offset: u64 @ 16 = 8 } // points to s2

struct Node {
    payload: u64,
}

fn main() -> i32 {
    // Single allocation: s1 @ 0, s2 @ 8, s3 @ 16
    block = allocate(24);

    // s1: terminal value = 3
    *(block + 0) = 3;
    // s2: next_offset = 0 (points to s1)
    *(block + 8) = 0;
    // s3: next_offset = 8 (points to s2)
    *(block + 16) = 8;

    // Walk the chain: s3 -> s2 -> s1 -> val=3
    off1: u64 = *(block + 16);      // s3.next = 8 (address of s2)
    off2: u64 = *(block + off1);    // s2.next = 0 (address of s1)
    val: u64 = *(block + off2);     // s1.val = 3

    free(block);
    return val;
}
