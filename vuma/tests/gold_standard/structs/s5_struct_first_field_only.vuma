// s5_struct_first_field_only.vuma — multi-field struct, return first only
// Expected exit code: 42
//
// 24-byte struct. Stores 42/99/77, but only reads back the first
// field (offset 0). Verifies that loading one field doesn't get
// tangled with other fields' stores. Distinct from s4_struct_point_x
// (2-field struct, similar pattern but different layout/size).

struct Triple {
    a: u64,
    b: u64,
    c: u64,
}

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 42;
    *(p + 8) = 99;
    *(p + 16) = 77;
    v: u64 = *(p + 0);
    free(p);
    return v;
}
