// struct2_large.vuma — 64-byte struct; store 42 at offset 56, load
// Expected exit code: 42
//
// Allocates a 64-byte struct (8 × u64 fields). Stores 42 only in the
// last field (offset 56) and returns it. Verifies that field access
// works at large constant offsets, not just the first few fields.
// 42 is within the U8 range, so the known *(buf + offset)
// U8-truncation bug does not affect it.

struct Large {
    f0: u64,
    f1: u64,
    f2: u64,
    f3: u64,
    f4: u64,
    f5: u64,
    f6: u64,
    f7: u64,
}

fn main() -> i32 {
    p = allocate(64);
    *(p + 56) = 42;
    val: u64 = *(p + 56);
    free(p);
    return val;
}
