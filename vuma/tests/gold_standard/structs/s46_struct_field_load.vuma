// s46_struct_field_load.vuma — store 185, load = 185
// Expected exit code: 185
//
// Single 8-byte allocation treated as one struct instance. Store 185
// via `*p = literal`, load and return 185. Uses `*ptr = literal`
// form. Distinct from s42_struct_field_load (175) and s38_struct_
// field_load (165).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 185;
    a: u64 = *p1;
    free(p1);
    return a;
}
