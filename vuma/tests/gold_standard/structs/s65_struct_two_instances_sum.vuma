// s65_struct_two_instances_sum.vuma — two instances, sum = 180 (85 + 95)
// Expected exit code: 180
//
// Two 8-byte allocations treated as two instances of a one-field
// struct. Store 85/95 via `*p = literal`, load both, sum -> 180.
// Uses `*p = literal` form (no offsets). Distinct from s51_struct_
// two_instances_sum (210), s58_struct_two_instances_diff (110) and
// s62_struct_two_instances_sum (230).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 85;
    *p2 = 95;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 180
    free(p1);
    free(p2);
    return s;
}
