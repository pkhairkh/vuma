// s70_struct_field_load.vuma — store 95, load = 95
// Expected exit code: 95
//
// Single 8-byte allocation treated as a one-field struct. Store
// 95 via `*p = literal`, load the field, return 95. Uses `*p
// = literal` form (no offsets). Distinct from s66_struct_field_
// load (205), s65_struct_field_load (169) and s62_struct_field_
// load (182).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 95;
    a: u64 = *p;
    free(p);
    return a;
}
