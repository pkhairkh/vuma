// s75_struct_field_load.vuma — store 143, load = 143
// Expected exit code: 143
//
// Single 8-byte allocation treated as a one-field struct. Store
// 143 via `*p = literal`, load the field, return 143. Uses `*p
// = literal` form (no offsets). Distinct from s70_struct_field_
// load (95), s66_struct_field_load (205) and s62_struct_field_
// load (182).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 143;
    a: u64 = *p;
    free(p);
    return a;
}
