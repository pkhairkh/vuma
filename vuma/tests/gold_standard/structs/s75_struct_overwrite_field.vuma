// s75_struct_overwrite_field.vuma — overwrite field to 53, load = 53
// Expected exit code: 53
//
// Single 8-byte allocation treated as a one-field struct. Store
// 100 then 53 via `*p = literal` (overwrite), load and return
// 53. Uses `*p = literal` form (no offsets). Distinct from
// s74_struct_overwrite_field (69), s70_struct_overwrite_field
// (155) and s66_struct_overwrite_field (245).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 100;
    *p = 53;
    a: u64 = *p;           // 53
    free(p);
    return a;
}
