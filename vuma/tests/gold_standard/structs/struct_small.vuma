// struct_small.vuma — 8-byte struct (single u64), store and load
// Expected exit code: 7
//
// Allocates a minimal 8-byte struct (a single u64 field). Stores 7
// at offset 0, loads it, returns it. Verifies that the smallest
// possible struct (one field) round-trips correctly.

struct Small {
    val: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *(p + 0) = 7;
    val: u64 = *(p + 0);
    free(p);
    return val;
}
