// s28_struct_two_instances_and.vuma — two instances, and = 48 (0xF0 & 0x3C)
// Expected exit code: 48
//
// Two 8-byte allocations, each treated as a one-field struct instance.
// Store 0xF0/0x3C via `*p = literal`, load both, AND -> 48. Uses `*p =
// literal` form (no offsets). All operands loaded into typed locals
// before the AND. Distinct from s26_struct_two_instances_xor (xor, 102)
// and s22_struct_two_instances_sum (sum, 100).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 240;           // 0xF0
    *p2 = 60;            // 0x3C
    a1: u64 = *p1;
    a2: u64 = *p2;
    s: u64 = a1 & a2;     // 0x30 = 48
    free(p1);
    free(p2);
    return s;
}
