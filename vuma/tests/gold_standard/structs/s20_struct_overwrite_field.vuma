// s20_struct_overwrite_field.vuma — store 22 then overwrite 122, load = 122
// Expected exit code: 122
//
// 8-byte allocation treated as a one-field struct. Store 22, overwrite
// with 122 (last write wins). Load and return 122. Uses `*p = literal`
// form. Distinct from s18_struct_overwrite_field (different values) and
// s14_struct_overwrite_field (17 then 73).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 22;
    *p = 122;
    a: u64 = *p;
    free(p);
    return a;
}
