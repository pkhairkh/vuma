// s52_struct_field_load.vuma — store 175, load = 175
// Expected exit code: 175
//
// Single 8-byte allocation treated as a one-field struct. Store 175
// via `*p = literal`, load the field, return 175. Uses `*p = literal`
// form (no offsets). Distinct from s50_struct_field_load (168) and
// s46_struct_field_load (180).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 175;
    a: u64 = *p;
    free(p);
    return a;
}
