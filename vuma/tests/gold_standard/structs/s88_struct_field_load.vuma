// s88_struct_field_load.vuma — single field, store 155, load = 155
// Expected exit code: 155
//
// One 8-byte allocation treated as a single-field struct
// instance. Store 155 via `*p = literal`, load the field,
// return 155. Uses `*p = literal` form (no offsets).
// Distinct from s86_struct_field_load (145), s82_struct_
// field_load (25) and s78_struct_field_load (1).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 155;
    a: u64 = *p1;
    free(p1);
    return a;
}
