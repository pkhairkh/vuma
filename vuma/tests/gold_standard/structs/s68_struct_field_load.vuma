// s68_struct_field_load.vuma — store 163, load 163
// Expected exit code: 163
//
// Single 8-byte allocation treated as a one-field struct. Store
// 163 via `*p = literal`, load and return 163. Uses `*p = literal`
// form (no offsets). Distinct from s66_struct_field_load (205),
// s62_struct_field_load (182) and s58_struct_field_load (165).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 163;
    a: u64 = *p;           // 163
    free(p);
    return a;
}
