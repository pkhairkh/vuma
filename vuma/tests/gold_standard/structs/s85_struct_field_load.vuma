// s85_struct_field_load.vuma — single-field struct, load field = 91
// Expected exit code: 91
//
// 8-byte allocation treated as a one-field struct. Store 91
// via `*p = 91`, load it back, return 91. Uses `*p = literal`
// form (no offsets) to avoid the *(ptr+N) store-drop bug.
// Distinct from s82_struct_field_load, s78_struct_field_load
// and s74_struct_field_load.
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 91;
    a: u64 = *p;
    free(p);
    return a;
}
