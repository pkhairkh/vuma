// s104_struct_field_load.vuma — store 93, load = 93
// Expected exit code: 93
//
// Single 8-byte struct allocation. Store 93 via `*p = literal`, load and return 93. Uses `*p = literal` form. Straight-line code only.
// Distinct from s102_struct_field_load (5), s102_struct_overwrite_field (6), s102_struct_two_instances_sum (7).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 93;
    v: u64 = *p;           // 93
    free(p);
    return v;
}
