// s32_struct_overwrite_field.vuma - overwrite field, load = 215
// Expected exit code: 215
//
// overwrite field, load = 215. All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_struct_overwrite_field
// (value 220) and s26_struct_overwrite_field (different value).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 35;
    *p1 = 215;
    a: u64 = *p1;
    free(p1);
    return a;
}
