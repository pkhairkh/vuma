// s49_struct_overwrite_field.vuma — store 50, overwrite to 145, load = 145
// Expected exit code: 145
//
// Single 8-byte allocation treated as one struct instance. Store 50
// via `*p = literal`, then overwrite with 145. Load and return 145.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_struct
// _overwrite_field (155) and s42_struct_overwrite_field (140).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 50;
    *p1 = 145;
    a: u64 = *p1;
    free(p1);
    return a;
}
