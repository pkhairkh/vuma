// s81_struct_overwrite_field.vuma — store 100, overwrite with 209, load = 209
// Expected exit code: 209
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 100 via `*p = literal`, overwrite with 209 via `*p =
// literal`, load the field, return 209. Uses `*p = literal`
// form (no offsets). Distinct from s78_struct_overwrite_field (2),
// s77_struct_overwrite_field (151) and s76_struct_overwrite_field
// (84).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 100;
    *p1 = 209;
    a: u64 = *p1;
    free(p1);
    return a;
}
