// s56_struct_two_instances_sum.vuma — two instances, sum = 250 (100 + 150)
// Expected exit code: 250
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 100/150 via `*p = literal`, load both fields, sum -> 250.
// Uses `*p = literal` form (no offsets). Distinct from s54_struct_two_
// instances_sum (255) and s50_struct_two_instances_sum (220).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 150;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 250
    free(p1);
    free(p2);
    return s;
}
