// s5_struct_overwrite_one_field.vuma — overwrite middle field, sum = 110
// Expected exit code: 110  (10 + 88 + 12)
//
// 24-byte struct (three u64 fields). Stores 10/20/12, then
// overwrites the middle field (offset 8) with 88. Loads all three,
// sums, returns 10 + 88 + 12 = 110. Distinct from s4_struct_overwrite_field
// (overwrites first field of 2-field struct).

struct Triple {
    a: u64,
    b: u64,
    c: u64,
}

fn main() -> i32 {
    p = allocate(24);
    *(p + 0) = 10;
    *(p + 8) = 20;
    *(p + 16) = 12;
    *(p + 8) = 88;
    a: u64 = *(p + 0);
    b: u64 = *(p + 8);
    c: u64 = *(p + 16);
    s: u64 = a + b + c;
    free(p);
    return s;
}
