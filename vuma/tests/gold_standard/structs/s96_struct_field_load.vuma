// s96_struct_field_load.vuma — store 149, load = 149
// Expected exit code: 149
//
// Single 8-byte struct allocation. Store 149 via `*p = literal`,
// load and return 149. Uses `*p = literal` form. Distinct from
// s94_struct_field_load (63), s90_struct_field_load (52) and
// s86_struct_field_load (145).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 149;
    v: u64 = *p;           // 149
    free(p);
    return v;
}
