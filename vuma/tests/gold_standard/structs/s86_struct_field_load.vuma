// s86_struct_field_load.vuma — single field, store 145, load = 145
// Expected exit code: 145
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 145 via `*p = literal`, load the field, return 145.
// Uses `*p = literal` form (no offsets). Distinct from s78_struct_
// field_load (1), s74_struct_field_load (185) and s72_struct_
// field_load (225).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 145;
    a: u64 = *p1;
    free(p1);
    return a;
}
