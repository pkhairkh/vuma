// s93_struct_field_load.vuma — store 66, load = 66
// Expected exit code: 66
//
// Single 8-byte struct allocation. Store 66 via `*p = literal`,
// load and return 66. Uses `*p = literal` form. Distinct from
// s90_struct_field_load (52), s82_struct_field_load (25) and s78_struct_field_load (1).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 66;
    v: u64 = *p;           // 66
    free(p);
    return v;
}
