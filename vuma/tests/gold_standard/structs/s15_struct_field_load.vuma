// s15_struct_field_load.vuma — single-field struct, load field = 42
// Expected exit code: 42
//
// 8-byte allocation treated as a one-field struct. Store 42 via `*p = 42`,
// load it back, return 42. Uses `*p = literal` form (no offsets) to avoid
// the *(ptr+N) store-drop bug. Distinct from s14_struct_field_load
// (value 56) and s13_struct_field_load (value 49).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p = allocate(8);
    *p = 42;
    a: u64 = *p;
    free(p);
    return a;
}
