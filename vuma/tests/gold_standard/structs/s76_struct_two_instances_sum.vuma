// s76_struct_two_instances_sum.vuma — two instances, sum = 172 (100 + 72)
// Expected exit code: 172
//
// Two 8-byte allocations treated as two independent struct
// instances. Store 100/72 via `*p = literal`, load both fields,
// sum -> 172. Uses `*p = literal` form (no offsets). Distinct
// from s74_struct_two_instances_sum (137), s73_struct_two_
// instances_sum (114) and s72_struct_two_instances_sum (135).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 72;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 172
    free(p1);
    free(p2);
    return s;
}
