// s89_struct_field_load.vuma — single field, store 50, load = 50
// Expected exit code: 50
//
// One 8-byte allocation treated as a single-field struct instance.
// Store 50 via `*p = literal`, load the field, return 50.
// Uses `*p = literal` form (no offsets). Distinct from
// s86_struct_field_load (145), s82_struct_field_load (185) and
// s78_struct_field_load (1).
struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 50;
    a: u64 = *p1;
    free(p1);
    return a;
}
