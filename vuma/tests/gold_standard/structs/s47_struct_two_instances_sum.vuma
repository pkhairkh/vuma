// s47_struct_two_instances_sum.vuma — two instances, sum = 215 (145 + 70)
// Expected exit code: 215
//
// Two 8-byte allocations treated as two independent struct instances.
// Store 145/70 via `*p = literal`, load both fields, sum -> 215.
// Uses `*p = literal` form (no offsets). Distinct from s46_struct_
// two_instances_diff (140) and s42_struct_two_instances_sum (205).

struct Single {
    a: u64,
}

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 145;
    *p2 = 70;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 215
    free(p1);
    free(p2);
    return s;
}
