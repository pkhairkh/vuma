// s80_u32_xor_then_shr.vuma — (0x01 ^ 0x38) >> 0 = 0x39 >> 0 = 0x39 = 57
// Expected exit code: 57
//
// Two-stage bitwise: XOR then shift right. (1 ^ 56) = 57
// (0x39); 57 >> 0 = 57 (0x39). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_u32_or_then_shr (4),
// s74_u32_or_then_shl (96) and s73_u32_xor_then_and (98).
fn main() -> i32 {
    a: u32 = 1;           // 0x01
    b: u32 = 56;          // 0x38
    c: u32 = 0;
    x: u32 = a ^ b;        // 0x39 = 57
    r: u32 = x >> c;       // 0x39 = 57
    return r;
}
