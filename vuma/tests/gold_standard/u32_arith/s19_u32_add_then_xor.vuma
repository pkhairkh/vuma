// s19_u32_add_then_xor.vuma — (100 + 50) ^ 51 = 150 ^ 51 = 165
// Expected exit code: 165
//
// ADD-then-XOR. 100 + 50 = 150 (0x96); 150 ^ 51 = 165 (0xA5). The XOR
// mask is loaded into a u32 variable first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_u32_add_xor_chain (add-xor chain)
// and s14_u32_or_then_xor (or-then-xor).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 50;
    k: u32 = 51;          // 0x33
    p: u32 = a + b;       // 150 (0x96)
    r: u32 = p ^ k;       // 165 (0xA5)
    return r;
}
