// s11_u32_or_xor_chain.vuma — (0x10 | 0x20) ^ 0x0F = 63
// Expected exit code: 63
//
// Two-stage u32 chain. (0x10 | 0x20) = 0x30 (48); 48 ^ 0x0F = 0x3F (63).
// All operands loaded into u32 variables first. Distinct from
// s10_u32_or_then_and (or-then-and) and s7_u32_or_mask (single OR with
// mask).

fn main() -> i32 {
    a: u32 = 16;          // 0x10
    b: u32 = 32;          // 0x20
    c: u32 = 15;          // 0x0F
    o: u32 = a | b;       // 0x30 = 48
    r: u32 = o ^ c;       // 0x3F = 63
    return r;
}
