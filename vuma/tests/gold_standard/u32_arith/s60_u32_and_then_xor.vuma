// s60_u32_and_then_xor.vuma — (0xFF & 0xAA) ^ 0x0F = 0xAA ^ 0x0F = 0xA5 = 165
// Expected exit code: 165
//
// Two-stage bitwise: AND then XOR. (255 & 170) = 170 (0xAA);
// 170 ^ 15 = 165 (0xA5). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_u32_xor_then_and (255) and s57_u32_add_then_xor (153).

fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 170;          // 0xAA
    c: u32 = 15;           // 0x0F
    x: u32 = a & b;        // 0xAA = 170
    r: u32 = x ^ c;        // 0xA5 = 165
    return r;
}
