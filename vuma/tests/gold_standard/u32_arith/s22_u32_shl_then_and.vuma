// s22_u32_shl_then_and.vuma — (1 << 5) & 0x3C = 0x20 & 0x3C = 0x20 = 32
// Expected exit code: 32
//
// Shift then mask. 1 << 5 = 32 (0x20); 32 & 60 = 32 (0x20, since 0x3C
// covers bits 2..5). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s18_u32_shl_then_or (shl-then-or) and s14_u32_xor_then_shl (xor-shl).

fn main() -> i32 {
    a: u32 = 1;
    s: u32 = 5;
    m: u32 = 60;          // 0x3C
    x: u32 = a << s;      // 0x20 = 32
    r: u32 = x & m;       // 0x20 = 32
    return r;
}
