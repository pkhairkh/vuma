// s99_u32_xor_then_or.vuma — (0x0A ^ 0x05) | 0x10 = 0x0F | 0x10 = 0x1F = 31
// Expected exit code: 31
//
// Two-stage bitwise: XOR then OR. (10 ^ 5) = 15 (0x0F);
// 15 | 16 = 31 (0x1F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s95_u32_xor_then_and (44), s91_u32_xor_then_and (144) and
// s87_u32_xor_then_and (42).
fn main() -> i32 {
    a: u32 = 10;           // 0x0A
    b: u32 = 5;            // 0x05
    c: u32 = 16;           // 0x10
    x: u32 = a ^ b;        // 0x0F = 15
    r: u32 = x | c;        // 0x1F = 31
    return r;
}
