// s94_u32_xor_then_shl.vuma — (0x07 ^ 0x03) << 3 = 0x04 << 3 = 0x20 = 32
// Expected exit code: 32
//
// Two-stage bitwise: XOR then shift-left. (7 ^ 3) = 4 (0x04);
// 4 << 3 = 32 (0x20). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_xor_then_or (58), s86_u32_xor_then_and (51) and
// s82_u32_xor_then_shr (45).
fn main() -> i32 {
    a: u32 = 7;            // 0x07
    b: u32 = 3;            // 0x03
    s: u32 = 3;
    x: u32 = a ^ b;        // 0x04 = 4
    r: u32 = x << s;       // 0x20 = 32
    return r;
}
