// s87_u32_shl_then_or.vuma — (0x06 << 4) | 0x05 = 0x60 | 0x05 = 0x65 = 101
// Expected exit code: 101
//
// Two-stage bitwise: shift left then OR. (6 << 4) = 96 (0x60);
// 96 | 5 = 101 (0x65). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_u32_shl_then_or (83), s82_u32_shl_then_or (76) and
// s78_u32_shl_then_or (4).
fn main() -> i32 {
    a: u32 = 6;            // 0x06
    b: u32 = 4;            // shift amount
    c: u32 = 5;            // 0x05
    x: u32 = a << b;       // 0x60 = 96
    r: u32 = x | c;        // 0x65 = 101
    return r;
}
