// s21_u32_shl_then_xor.vuma — (0x05 << 5) ^ 0x0F = 0xA0 ^ 0x0F = 0xAF = 175
// Expected exit code: 175
//
// SHL-then-XOR. (5 << 5) = 160 (0xA0); 160 ^ 15 = 175 (0xAF). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s18_u32_shl_then_or (shl-then-or, 197)
// and s14_u32_xor_then_shl (xor-then-shl, opposite order).

fn main() -> i32 {
    a: u32 = 5;           // 0x05
    s: u32 = 5;
    b: u32 = 15;          // 0x0F
    x: u32 = a << s;      // 0xA0 = 160
    r: u32 = x ^ b;       // 0xAF = 175
    return r;
}
