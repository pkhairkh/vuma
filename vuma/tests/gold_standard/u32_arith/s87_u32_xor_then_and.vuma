// s87_u32_xor_then_and.vuma — (0xA5 ^ 0x0F) & 0x3F = 0xAA & 0x3F = 0x2A = 42
// Expected exit code: 42
//
// Two-stage bitwise: XOR then AND. (165 ^ 15) = 170 (0xAA);
// 170 & 63 = 42 (0x2A). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_u32_xor_then_and (51), s82_u32_xor_then_and (45) and
// s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 165;          // 0xA5
    b: u32 = 15;           // 0x0F
    c: u32 = 63;           // 0x3F
    x: u32 = a ^ b;        // 0xAA = 170
    r: u32 = x & c;        // 0x2A = 42
    return r;
}
