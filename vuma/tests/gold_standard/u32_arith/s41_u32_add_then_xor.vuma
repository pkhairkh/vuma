// s41_u32_add_then_xor.vuma - (100 + 50) ^ 0x0F = 150 ^ 15 = 0x99 = 153
// Expected exit code: 153
//
// Two-stage computation: add then XOR. (100 + 50) = 150 (0x96);
// 150 ^ 15 = 153 (0x99). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_add_then_and (144) and s34_u32_add_then_xor (153, same
// result, different operands 120+33).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 50;
    c: u32 = 15;           // 0x0F
    s: u32 = a + b;        // 150 = 0x96
    r: u32 = s ^ c;        // 0x99 = 153
    return r;
}
