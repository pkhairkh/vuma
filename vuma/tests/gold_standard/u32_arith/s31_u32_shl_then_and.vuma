// s31_u32_shl_then_and.vuma — (1 << 4) & 0x1F = 16 & 31 = 16
// Expected exit code: 16
//
// SHL then AND. (1 << 4) = 16; 16 & 31 = 16. All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s30_u32_shl_then_or (shl-then-or) and
// s28_u32_and_then_shl (and-then-shl, 96).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 31;           // 0x1F
    x: u32 = a << b;      // 16
    r: u32 = x & c;       // 16
    return r;
}
