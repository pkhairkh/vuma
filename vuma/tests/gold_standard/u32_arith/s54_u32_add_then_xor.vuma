// s54_u32_add_then_xor.vuma — (100 + 155) ^ 0x0F = 255 ^ 15 = 240
// Expected exit code: 240
//
// Two-stage u32 computation: add then XOR. 100 + 155 = 255;
// 255 ^ 15 = 240 (0xF0). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_u32_add_then_shr (15) and s49_u32_and_then_shr (16).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 155;
    c: u32 = 15;           // 0x0F
    s: u32 = a + b;        // 255
    r: u32 = s ^ c;        // 0xF0 = 240
    return r;
}
