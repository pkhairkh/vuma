// s60_u32_xor_then_or.vuma — (0x6A ^ 0x55) | 0x80 = 0x3F | 0x80 = 0xBF = 191
// Expected exit code: 191
//
// Two-stage bitwise: XOR then OR. (106 ^ 85) = 63 (0x3F);
// 63 | 128 = 191 (0xBF). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s58_u32_or_then_xor (207) and s57_u32_or_then_xor (149).

fn main() -> i32 {
    a: u32 = 106;          // 0x6A
    b: u32 = 85;           // 0x55
    c: u32 = 128;          // 0x80
    x: u32 = a ^ b;        // 0x3F = 63
    r: u32 = x | c;        // 0xBF = 191
    return r;
}
