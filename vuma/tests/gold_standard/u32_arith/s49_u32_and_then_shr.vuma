// s49_u32_and_then_shr.vuma — (0xFF & 0x3C) >> 2 = 0x3C >> 2 = 0x0F = 15
// Expected exit code: 15
//
// Two-stage bitwise: AND then shift right. (255 & 60) = 60 (0x3C);
// 60 >> 2 = 15 (0x0F). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_u32_or_then_and (195, or-then-and) and s42_u32_mul_then_xor
// (9, mul-then-xor).

fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 60;           // 0x3C
    c: u32 = 2;
    m: u32 = a & b;        // 0x3C = 60
    r: u32 = m >> c;       // 0x0F = 15
    return r;
}
