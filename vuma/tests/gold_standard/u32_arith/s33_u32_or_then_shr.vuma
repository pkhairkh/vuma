// s33_u32_or_then_shr.vuma — (0xE0 | 0x1C) >> 1 = 0xFC >> 1 = 0x7E = 126
// Expected exit code: 126
//
// Deterministic test in the u32_arith category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_u32_and_then_add (and-then-add) and s26_u32_shl_then_or (shl-then-or, 41).
fn main() -> i32 {
    a: u32 = 224;          // 0xE0
    b: u32 = 28;           // 0x1C
    c: u32 = 1;
    x: u32 = a | b;        // 0xFC = 252
    r: u32 = x >> c;       // 0x7E = 126
    return r;
}
