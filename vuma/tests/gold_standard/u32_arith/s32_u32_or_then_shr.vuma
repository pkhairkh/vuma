// s32_u32_or_then_shr.vuma - (0xF0 | 0x0C) >> 2 = 0xFC >> 2 = 0x3F = 63
// Expected exit code: 63
//
// (0xF0 | 0x0C) >> 2 = 0xFC >> 2 = 0x3F = 63. All operands loaded into typed
// variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from
// s30_u32_xor_then_shr (xor-then-shr, 63) and s26_u32_shl_then_or (shl-then-
// or).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 12;           // 0x0C
    c: u32 = 2;
    x: u32 = a | b;        // 0xFC = 252
    r: u32 = x >> c;       // 0x3F = 63
    return r;
}
