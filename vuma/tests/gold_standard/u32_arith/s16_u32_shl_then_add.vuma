// s16_u32_shl_then_add.vuma — (1 << 4) + 10 = 16 + 10 = 26
// Expected exit code: 26
//
// Shift left then add. (1 << 4) = 16; 16 + 10 = 26. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s13_u32_shl_then_add (different operands, 1<<3 + 5 = 13)
// and s4_u32_shift_add (different operands).

fn main() -> i32 {
    v: u32 = 1;
    sh: u32 = 4;
    a: u32 = 10;
    l: u32 = v << sh;     // 16
    r: u32 = l + a;       // 26
    return r;
}
