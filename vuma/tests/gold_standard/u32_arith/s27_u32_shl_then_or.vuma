// s27_u32_shl_then_or.vuma — (0x05 << 3) | 0x09 = 0x28 | 0x09 = 0x29 = 41
// Expected exit code: 41
//
// SHL then OR. (5 << 3) = 40 (0x28); 40 | 9 = 41 (0x29). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s26_u32_xor_then_shl (xor-then-shl) and
// s22_u32_shl_then_and (shl-then-and).

fn main() -> i32 {
    a: u32 = 5;           // 0x05
    b: u32 = 3;
    c: u32 = 9;           // 0x09
    x: u32 = a << b;      // 0x28 = 40
    r: u32 = x | c;       // 0x29 = 41
    return r;
}
