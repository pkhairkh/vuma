// s40_u32_xor_then_and.vuma — (0xC3 ^ 0x18) & 0x7F = 0xDB & 0x7F = 0x5B = 91
// Expected exit code: 91
//
// Two-stage bitwise: XOR then AND. (195 ^ 24) = 219 (0xDB); 219 &
// 127 = 91 (0x5B). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_and_then_or (202) and s34_u32_xor_then_or (255).

fn main() -> i32 {
    a: u32 = 195;          // 0xC3
    b: u32 = 24;           // 0x18
    c: u32 = 127;          // 0x7F
    x: u32 = a ^ b;        // 0xDB = 219
    r: u32 = x & c;        // 0x5B = 91
    return r;
}
