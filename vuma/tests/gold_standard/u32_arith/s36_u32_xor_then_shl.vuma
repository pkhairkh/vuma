// s36_u32_xor_then_shl.vuma — (0x33 ^ 0x0F) << 2 = 0x3C << 2 = 0xF0 = 240
// Expected exit code: 240
//
// Two-stage computation: XOR then SHL. (0x33 ^ 0x0F) =
// 0x3C = 60; 60 << 2 = 0xF0 = 240. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop
// bug workaround).
// Distinct from s30_u32_xor_then_shr (xor-then-shr, 0) and s27_u32_xor_then_shl (different values).

fn main() -> i32 {
    a: u32 = 51;           // 0x33
    b: u32 = 15;           // 0x0F
    s: u32 = 2;
    x: u32 = a ^ b;        // 0x3C = 60
    r: u32 = x << s;       // 0xF0 = 240
    return r;
}
