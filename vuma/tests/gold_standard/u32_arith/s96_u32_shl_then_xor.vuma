// s96_u32_shl_then_xor.vuma — (0x02 << 5) ^ 0x12 = 0x40 ^ 0x12 = 0x52 = 82
// Expected exit code: 82
//
// Two-stage bitwise: shift-left then XOR. (2 << 5) = 64 (0x40);
// 64 ^ 18 = 82 (0x52). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_xor_then_shl (32), s90_u32_shl_then_xor (74) and
// s86_u32_shl_then_or (83).
fn main() -> i32 {
    a: u32 = 2;            // 0x02
    s: u32 = 5;
    c: u32 = 18;           // 0x12
    x: u32 = a << s;       // 0x40 = 64
    r: u32 = x ^ c;        // 0x52 = 82
    return r;
}
