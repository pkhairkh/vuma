// s42_u32_shl_then_add.vuma — (1 << 4) + 10 = 16 + 10 = 26
// Expected exit code: 26
//
// Two-stage bitwise/arith: shift left then add. (1 << 4) = 16;
// 16 + 10 = 26. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_shl_then_xor (37) and s34_u32_shl_then_or (69).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 10;
    s: u32 = a << b;       // 16
    r: u32 = s + c;        // 26
    return r;
}
