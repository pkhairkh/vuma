// s97_u32_shr_then_and.vuma — (0xF0 >> 3) & 0x06 = 0x1E & 0x06 = 0x06 = 6
// Expected exit code: 6
//
// Two-stage bitwise: shift-right then AND. (240 >> 3) = 30
// (0x1E); 30 & 6 = 6 (0x06). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_u32_and_then_or (106), s90_u32_and_then_shr (75), s86_u32_and_then_shr (24).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    s: u32 = 3;
    b: u32 = 6;            // 0x06
    x: u32 = a >> s;       // 0x1E = 30
    r: u32 = x & b;        // 0x06 = 6
    return r;
}
