// s43_u32_xor_then_and.vuma — (0xF0 ^ 0x0F) & 0xCC = 0xFF & 0xCC = 0xCC = 204
// Expected exit code: 204
//
// Two-stage bitwise: XOR then AND. (240 ^ 15) = 255 (0xFF);
// 255 & 204 = 204 (0xCC). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_u32_xor_then_or (255) and s38_u32_and_then_or (170).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 204;          // 0xCC
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0xCC = 204
    return r;
}
