// s58_u32_and_then_shr.vuma — (0xFF & 0xF0) >> 2 = 0xF0 >> 2 = 0x3C = 60
// Expected exit code: 60
// 
// Two-stage bitwise: AND then shift right. (255 & 240) = 240 (0xF0);
// 240 >> 2 = 60 (0x3C). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// or_then_shr (120), s51_u32_and_then_or (95) and s51_u32_xor_then_
// shl (204).

fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 240;          // 0xF0
    c: u32 = 2;
    x: u32 = a & b;        // 0xF0 = 240
    r: u32 = x >> c;       // 0x3C = 60
    return r;
}
