// s102_u32_xor_then_shr.vuma — (0x01 ^ 0x2C) >> 1 = 0x2D >> 1 = 0x16 = 22
// Expected exit code: 22
//
// Two-stage bitwise: XOR then shift-right. (1 ^ 44) = 45 (0x2D); 45 >> 1 = 22 (0x16). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_u32_or_then_shr (48), s101_u32_shl_then_xor (8), s101_u32_xor_then_and (240).
fn main() -> i32 {
    a: u32 = 1;          // 0x01
    b: u32 = 44;          // 0x2C
    c: u32 = 1;
    x: u32 = a ^ b;        // 0x2D = 45
    r: u32 = x >> c;       // 0x16 = 22
    return r;
}
