// s71_u32_xor_then_shr.vuma — (0xB4 ^ 0x3C) >> 1 = 0x88 >> 1 = 0x44 = 68
// Expected exit code: 68
//
// Two-stage bitwise: XOR then shift right. (180 ^ 60) = 136
// (0x88); 136 >> 1 = 68 (0x44). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s69_u32_and_then_shr (126), s70_u32_and_then_shl
// (60) and s66_u32_xor_then_and (204).
fn main() -> i32 {
    a: u32 = 180;          // 0xB4
    b: u32 = 60;           // 0x3C
    s: u32 = 1;
    x: u32 = a ^ b;        // 0x88 = 136
    r: u32 = x >> s;       // 0x44 = 68
    return r;
}
