// s77_u32_xor_then_and.vuma — (0xA5 ^ 0x3C) & 0x7F = 0x99 & 0x7F = 0x19 = 25
// Expected exit code: 25
//
// Two-stage bitwise: XOR then AND. 165 ^ 60 = 153 (0x99);
// 153 & 127 = 25 (0x19). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_or_then_and (36), s66_u32_and_then_shr (127) and
// s74_u32_xor_then_or (174).

fn main() -> i32 {
    a: u32 = 165;          // 0xA5
    b: u32 = 60;           // 0x3C
    c: u32 = 127;          // 0x7F
    x: u32 = a ^ b;        // 0x99 = 153
    r: u32 = x & c;        // 0x19 = 25
    return r;
}
