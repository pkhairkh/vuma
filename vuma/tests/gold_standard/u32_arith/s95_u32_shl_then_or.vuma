// s95_u32_shl_then_or.vuma — (1 << 6) | 0x01 = 0x40 | 0x01 = 0x41 = 65
// Expected exit code: 65
//
// Two-stage bitwise: shift-left then OR. (1 << 6) = 64 (0x40);
// 64 | 1 = 65 (0x41). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_and_then_or (106), s90_u32_shl_then_xor (74) and
// s82_u32_shl_then_or (80).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    s: u32 = 6;
    b: u32 = 1;            // 0x01
    x: u32 = a << s;       // 0x40 = 64
    r: u32 = x | b;        // 0x41 = 65
    return r;
}
