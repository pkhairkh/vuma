// s49_u32_shl_then_xor.vuma — (0x0F << 3) ^ 0x40 = 0x78 ^ 0x40 = 0x38 = 56
// Expected exit code: 56
//
// Two-stage bitwise: shift left then XOR. (15 << 3) = 120 (0x78);
// 120 ^ 64 = 56 (0x38). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_u32_and_then_or (63, and-then-or) and s42_u32_shl_then_add
// (26, shl-then-add).

fn main() -> i32 {
    a: u32 = 15;           // 0x0F
    b: u32 = 3;
    c: u32 = 64;           // 0x40
    s: u32 = a << b;       // 0x78 = 120
    r: u32 = s ^ c;        // 0x38 = 56
    return r;
}
