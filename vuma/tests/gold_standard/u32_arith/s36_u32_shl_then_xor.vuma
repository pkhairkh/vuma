// s36_u32_shl_then_xor.vuma — (1 << 3) ^ 0x77 = 8 ^ 119 = 127
// Expected exit code: 127
//
// Two-stage computation: SHL then XOR. (1 << 3) = 8; 8 ^
// 119 = 127 (0x7F). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround).
// Distinct from s30_u32_shl_then_or (shl-then-or, 0) and s27_u32_shl_then_xor (different values).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 3;
    c: u32 = 119;          // 0x77
    x: u32 = a << b;       // 8
    r: u32 = x ^ c;        // 0x7F = 127
    return r;
}
