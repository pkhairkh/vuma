// s26_u32_xor_then_shl.vuma — (0x0F ^ 0x33) << 2 = 0x3C << 2 = 0xF0 = 240
// Expected exit code: 240
//
// XOR then SHL. (15 ^ 51) = 60 (0x3C); 60 << 2 = 240 (0xF0). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_u32_shl_then_and (shl-then-and)
// and s18_u32_shl_then_or (shl-then-or).

fn main() -> i32 {
    a: u32 = 15;          // 0x0F
    b: u32 = 51;          // 0x33
    c: u32 = 2;
    x: u32 = a ^ b;       // 0x3C = 60
    r: u32 = x << c;      // 0xF0 = 240
    return r;
}
