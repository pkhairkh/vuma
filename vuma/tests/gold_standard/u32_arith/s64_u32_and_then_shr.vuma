// s64_u32_and_then_shr.vuma — (0xFF & 0xFE) >> 1 = 0xFE >> 1 = 0x7F = 127
// Expected exit code: 127
//
// Two-stage bitwise: AND then shift right. (255 & 254) = 254 (0xFE);
// 254 >> 1 = 127 (0x7F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s62_u32_
// and_then_xor (90), s62_u32_shl_then_xor (35) and s62_u32_xor_then_
// or (252).

fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 254;          // 0xFE
    c: u32 = 1;
    x: u32 = a & b;        // 0xFE = 254
    r: u32 = x >> c;       // 0x7F = 127
    return r;
}
