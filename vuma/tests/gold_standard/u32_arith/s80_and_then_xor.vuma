// s80_u32_and_then_xor.vuma — (0x00 & 0x00) ^ 0x26 = 0x00 ^ 0x26 = 0x26 = 38
// Expected exit code: 38
//
// Two-stage bitwise: AND then XOR. (0 & 0) = 0
// (0x00); 0 ^ 38 = 38 (0x26). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_u32_and_then_xor (1),
// s74_u32_and_then_shr (28) and s73_u32_xor_then_and (98).
fn main() -> i32 {
    a: u32 = 0;           // 0x00
    b: u32 = 0;           // 0x00
    c: u32 = 38;          // 0x26
    x: u32 = a & b;        // 0x00 = 0
    r: u32 = x ^ c;        // 0x26 = 38
    return r;
}
