// s81_u32_shl_then_or.vuma — (0x05 << 3) | 0x02 = 0x28 | 0x02 = 0x2A = 42
// Expected exit code: 42
//
// Two-stage bitwise: shift left then OR. 5 << 3 = 40 (0x28);
// 40 | 2 = 42 (0x2A). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_u32_shl_then_or (2), s77_u32_xor_then_and (25) and
// s76_u32_xor_then_and (125).
fn main() -> i32 {
    a: u32 = 5;            // 0x05
    b: u32 = 3;
    c: u32 = 2;            // 0x02
    x: u32 = a << b;       // 0x28 = 40
    r: u32 = x | c;        // 0x2A = 42
    return r;
}
