// s100_u32_shl_then_or.vuma — (0x0E << 1) | 0x01 = 0x1C | 0x01 = 0x1D = 29
// Expected exit code: 29
//
// Two-stage bitwise: shift-left then OR. (14 << 1) = 28
// (0x1C); 28 | 1 = 29 (0x1D). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_u32_or_then_and (13), s94_u32_and_then_or (106), s90_u32_and_then_shr (75).
fn main() -> i32 {
    a: u32 = 14;           // 0x0E
    s: u32 = 1;
    b: u32 = 1;            // 0x01
    x: u32 = a << s;       // 0x1C = 28
    r: u32 = x | b;        // 0x1D = 29
    return r;
}
