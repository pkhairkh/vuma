// s92_u32_and_then_shr.vuma — (0xFF & 0xC3) >> 1 = 0xC3 >> 1 = 0x61 = 97
// Expected exit code: 97
//
// Two-stage bitwise: AND then shift-right. (255 & 195) = 195
// (0xC3); 195 >> 1 = 97 (0x61). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s90_u32_and_then_shr (75), s86_u32_and_then_shr
// (53) and s82_u32_or_then_and (46).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 195;          // 0xC3
    c: u32 = 1;
    x: u32 = a & b;        // 0xC3 = 195
    r: u32 = x >> c;       // 0x61 = 97
    return r;
}
