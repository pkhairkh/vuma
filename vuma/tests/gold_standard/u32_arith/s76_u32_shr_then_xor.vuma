// s76_u32_shr_then_xor.vuma — (0xF0 >> 1) ^ 0x6C = 0x78 ^ 0x6C = 0x14 = 20
// Expected exit code: 20
//
// Two-stage bitwise: shift right then XOR. 240 >> 1 = 120 (0x78);
// 120 ^ 108 = 20 (0x14). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s74_u32_shl_then_xor (143), s73_u32_shr_then_or (118)
// and s72_u32_shl_then_or (104).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 1;
    c: u32 = 108;          // 0x6C
    x: u32 = a >> b;       // 0x78 = 120
    r: u32 = x ^ c;        // 0x14 = 20
    return r;
}
