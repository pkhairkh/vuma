// s93_u32_and_then_shr.vuma — (0xFF & 0xA4) >> 1 = 0xA4 >> 1 = 0x52 = 82
// Expected exit code: 82
//
// Two-stage bitwise: AND then shift-right. (255 & 164) = 164
// (0xA4); 164 >> 1 = 82 (0x52). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s90_u32_and_then_shr (75), s82_u32_or_then_and (15) and s78_u32_and_then_xor (1).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 164;          // 0xA4
    c: u32 = 1;
    x: u32 = a & b;        // 0xA4 = 164
    r: u32 = x >> c;       // 0x52 = 82
    return r;
}
