// s62_u32_xor_then_or.vuma — (0x33 ^ 0x0F) | 0xC0 = 0x3C | 0xC0 = 0xFC = 252
// Expected exit code: 252
// 
// Two-stage bitwise: XOR then OR. (51 ^ 15) = 60 (0x3C);
// 60 | 192 = 252 (0xFC). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// xor_then_shl (204), s58_u32_xor_then_and (255) and s55_u32_or_then_
// and (204).

fn main() -> i32 {
    a: u32 = 51;           // 0x33
    b: u32 = 15;           // 0x0F
    c: u32 = 192;          // 0xC0
    x: u32 = a ^ b;        // 0x3C = 60
    r: u32 = x | c;        // 0xFC = 252
    return r;
}
