// s28_u32_shr_then_or.vuma — (0xF0 >> 2) | 0x03 = 0x3C | 0x03 = 0x3F = 63
// Expected exit code: 63
//
// SHR then OR. (240 >> 2) = 60 (0x3C); 60 | 3 = 63 (0x3F). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s26_u32_mul_then_xor (mul-then-xor)
// and s22_u32_shl_then_or (shl-then-or).

fn main() -> i32 {
    a: u32 = 240;         // 0xF0
    b: u32 = 2;
    c: u32 = 3;           // 0x03
    x: u32 = a >> b;      // 0x3C = 60
    r: u32 = x | c;       // 0x3F = 63
    return r;
}
