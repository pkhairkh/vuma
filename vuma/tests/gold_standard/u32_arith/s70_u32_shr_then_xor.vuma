// s70_u32_shr_then_xor.vuma — (0xF0 >> 1) ^ 0xCC = 0x78 ^ 0xCC = 0xB4 = 180
// Expected exit code: 180
//
// Two-stage bitwise: shift right then XOR. (240 >> 1) = 120
// (0x78); 120 ^ 204 = 180 (0xB4). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_u32_xor_then_and (51), s65_u32_xor_then_shl
// (210) and s62_u32_xor_then_or (252).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 1;
    c: u32 = 204;          // 0xCC
    x: u32 = a >> b;       // 0x78 = 120
    r: u32 = x ^ c;        // 0xB4 = 180
    return r;
}
