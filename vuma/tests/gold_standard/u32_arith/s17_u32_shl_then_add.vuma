// s17_u32_shl_then_add.vuma — (0x05 << 3) + 7 = 40 + 7 = 47
// Expected exit code: 47
//
// Shift-left then add. (5 << 3) = 40 (0x28); 40 + 7 = 47. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s14_u32_shl_then_add (shl-then-add,
// different values) and s10_u32_shl_then_xor (shl-then-XOR).

fn main() -> i32 {
    a: u32 = 5;           // 0x05
    sh: u32 = 3;
    b: u32 = 7;
    x: u32 = a << sh;     // 0x28 = 40
    r: u32 = x + b;       // 47
    return r;
}
