// s24_u32_shl_then_or.vuma — (1 << 6) | 0x01 = 0x40 | 0x01 = 0x41 = 65
// Expected exit code: 65
//
// Shift then OR. 1 << 6 = 64 (0x40); 64 | 1 = 65 (0x41, sets bit 0).
// All operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s22_u32_shl_then_and
// (shl-then-and, value 32) and s14_u32_xor_then_shl (xor-shl).

fn main() -> i32 {
    a: u32 = 1;
    s: u32 = 6;
    c: u32 = 1;           // 0x01
    x: u32 = a << s;      // 0x40 = 64
    r: u32 = x | c;       // 0x41 = 65
    return r;
}
