// s67_u32_or_then_xor.vuma — (0x10 | 0x20) ^ 0x55 = 0x30 ^ 0x55 = 0x65 = 101
// Expected exit code: 101
//
// Two-stage bitwise: OR then XOR. (16 | 32) = 48 (0x30);
// 48 ^ 85 = 101 (0x65). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_u32_xor_then_and (51), s62_u32_or_then_xor (252)
// and s58_u32_xor_then_and (255).
fn main() -> i32 {
    a: u32 = 16;           // 0x10
    b: u32 = 32;           // 0x20
    c: u32 = 85;           // 0x55
    x: u32 = a | b;        // 0x30 = 48
    r: u32 = x ^ c;        // 0x65 = 101
    return r;
}
