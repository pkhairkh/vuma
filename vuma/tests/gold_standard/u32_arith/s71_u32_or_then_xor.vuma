// s71_u32_or_then_xor.vuma — (0x30 | 0x09) ^ 0xC0 = 0x39 ^ 0xC0 = 0xF9 = 249
// Expected exit code: 249
//
// Two-stage bitwise: OR then XOR. (48 | 9) = 57 (0x39); 57 ^ 192
// = 249 (0xF9). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s69_u32_xor_then_or (181), s70_u32_or_then_and (253) and s66_u32
// _or_then_and (240).
fn main() -> i32 {
    a: u32 = 48;           // 0x30
    b: u32 = 9;            // 0x09
    c: u32 = 192;          // 0xC0
    x: u32 = a | b;        // 0x39 = 57
    r: u32 = x ^ c;        // 0xF9 = 249
    return r;
}
