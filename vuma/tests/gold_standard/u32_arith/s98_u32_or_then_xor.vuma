// s98_u32_or_then_xor.vuma — (0x50 | 0x07) ^ 0x01 = 0x57 ^ 0x01 = 0x56 = 86
// Expected exit code: 86
//
// Two-stage bitwise: OR then XOR. (80 | 7) = 87 (0x57);
// 87 ^ 1 = 86 (0x56). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_or_then_xor (243), s90_u32_xor_then_or (58) and
// s86_u32_shl_then_or (83).
fn main() -> i32 {
    a: u32 = 80;           // 0x50
    b: u32 = 7;            // 0x07
    c: u32 = 1;            // 0x01
    x: u32 = a | b;        // 0x57 = 87
    r: u32 = x ^ c;        // 0x56 = 86
    return r;
}
