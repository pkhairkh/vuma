// s57_u32_add_then_xor.vuma — (100 + 50) ^ 15 = 150 ^ 15 = 153
// Expected exit code: 153
//
// Two-stage u32 mixed: add then XOR. 100 + 50 = 150 (0x96);
// 150 ^ 15 = 153 (0x99). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_u32_add_then_xor (240) and s50_u32_add_then_xor (210).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 50;
    c: u32 = 15;
    x: u32 = a + b;        // 150
    r: u32 = x ^ c;        // 153
    return r;
}
