// s85_u32_or_then_sub.vuma — (0xF0 | 0x0C) - 200 = 0xFC - 200 = 52
// Expected exit code: 52
//
// Two-stage u32 bitwise-then-arithmetic: OR then subtract.
// (240 | 12) = 252 (0xFC); 252 - 200 = 52. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s82_u32_or_then_and,
// s78_u32_or_then_sub and s74_u32_or_then_sub.
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 12;           // 0x0C
    c: u32 = 200;
    s: u32 = a | b;        // 0xFC = 252
    r: u32 = s - c;        // 52
    return r;
}
