// s100_u32_and_then_xor.vuma — (0xF0 & 0x70) ^ 0x04 = 0x70 ^ 0x04 = 0x74 = 116
// Expected exit code: 116
//
// Two-stage bitwise: AND then XOR. (240 & 112) = 112
// (0x70); 112 ^ 4 = 116 (0x74). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s97_u32_or_then_and (13), s94_u32_and_then_or (106), s90_u32_and_then_shr (75).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 112;          // 0x70
    c: u32 = 4;            // 0x04
    x: u32 = a & b;        // 0x70 = 112
    r: u32 = x ^ c;        // 0x74 = 116
    return r;
}
