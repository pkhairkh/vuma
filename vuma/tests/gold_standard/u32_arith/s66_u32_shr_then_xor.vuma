// s66_u32_shr_then_xor.vuma — (200 >> 2) ^ 0x05 = 50 ^ 5 = 0x37 = 55
// Expected exit code: 55
//
// Two-stage bitwise: shift right then XOR. (200 >> 2) = 50
// (0x32); 50 ^ 5 = 55 (0x37). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s62_u32_shl_then_xor (35), s58_u32_or_then_xor
// (207) and s55_u32_shr_then_xor (165).
fn main() -> i32 {
    a: u32 = 200;          // 0xC8
    b: u32 = 2;
    c: u32 = 5;            // 0x05
    x: u32 = a >> b;       // 0x32 = 50
    r: u32 = x ^ c;        // 0x37 = 55
    return r;
}
