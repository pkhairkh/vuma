// s97_u32_xor_then_shr.vuma — (0x55 ^ 0x11) >> 2 = 0x44 >> 2 = 0x11 = 17
// Expected exit code: 17
//
// Two-stage bitwise: XOR then shift-right. (85 ^ 17) = 68
// (0x44); 68 >> 2 = 17 (0x11). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_u32_and_then_or (106), s90_u32_and_then_shr (75), s86_u32_and_then_shr (24).
fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 17;           // 0x11
    s: u32 = 2;
    x: u32 = a ^ b;        // 0x44 = 68
    r: u32 = x >> s;       // 0x11 = 17
    return r;
}
