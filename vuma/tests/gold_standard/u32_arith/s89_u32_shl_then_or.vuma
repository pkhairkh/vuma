// s89_u32_shl_then_or.vuma — (77 << 0) | 0 = 77 | 0 = 77
// Expected exit code: 77
//
// Two-stage bitwise: shift left then OR. (77 << 0) = 77;
// 77 | 0 = 77. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_u32_shl_then_or (210), s82_u32_shl_then_or (200) and
// s78_u32_shl_then_or (3).
fn main() -> i32 {
    a: u32 = 77;
    s: u32 = 0;
    m: u32 = 0;
    x: u32 = a << s;       // 77
    r: u32 = x | m;        // 77
    return r;
}
