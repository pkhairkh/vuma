// s91_u32_or_then_shr.vuma — (0x80 | 0x40) >> 3 = 0xC0 >> 3 = 0x18 = 24
// Expected exit code: 24
//
// Two-stage bitwise: OR then shift-right. (128 | 64) = 192 (0xC0);
// 192 >> 3 = 24 (0x18). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_and_then_shr (75), s86_u32_and_then_shr (53) and
// s82_u32_or_then_and (46).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 64;           // 0x40
    s: u32 = 3;
    x: u32 = a | b;        // 0xC0 = 192
    r: u32 = x >> s;       // 0x18 = 24
    return r;
}
