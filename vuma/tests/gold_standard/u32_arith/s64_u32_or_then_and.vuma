// s64_u32_or_then_and.vuma — (0x33 | 0x0C) & 0x3F = 0x3F & 0x3F = 0x3F = 63
// Expected exit code: 63
//
// Two-stage bitwise: OR then AND. (51 | 12) = 63 (0x3F);
// 63 & 63 = 63 (0x3F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s62_u32_
// and_then_xor (90), s62_u32_shl_then_xor (35) and s62_u32_xor_then_
// or (252).

fn main() -> i32 {
    a: u32 = 51;           // 0x33
    b: u32 = 12;           // 0x0C
    c: u32 = 63;           // 0x3F
    x: u32 = a | b;        // 0x3F = 63
    r: u32 = x & c;        // 0x3F = 63
    return r;
}
