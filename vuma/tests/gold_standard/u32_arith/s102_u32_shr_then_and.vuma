// s102_u32_shr_then_and.vuma — (0x0A >> 1) & 0x05 = 0x05 & 0x05 = 0x05 = 5
// Expected exit code: 5
//
// Two-stage bitwise: shift-right then AND. (10 >> 1) = 5 (0x05); 5 & 5 = 5 (0x05). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_u32_or_then_shr (48), s101_u32_shl_then_xor (8), s101_u32_xor_then_and (240).
fn main() -> i32 {
    a: u32 = 10;          // 0x0A
    b: u32 = 5;          // 0x05
    c: u32 = 1;
    s: u32 = a >> c;       // 0x05 = 5
    r: u32 = s & b;        // 0x05 = 5
    return r;
}
