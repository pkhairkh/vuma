// u32_xor — u32 XOR: 0xFF ^ 0xFA
// Expected exit code: 5
//
// 0xFF ^ 0xFA = 0x05 = 5. Uses variables for both operands because VUMA
// may drop bitwise ops with immediate RHS.

fn main() -> i32 {
    a: u32 = 255;     // 0xFF
    b: u32 = 250;     // 0xFA
    result: u32 = a ^ b;
    return result;
}
