// s84_u32_shr_then_xor.vuma — (0x80 >> 1) ^ 0x02 = 0x40 ^ 0x02 = 0x42 = 66
// Expected exit code: 66
//
// Two-stage bitwise: shift right then XOR. (128 >> 1) = 64
// (0x40); 64 ^ 2 = 66 (0x42). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_u32_or_then_and (15), s78_u32_or_then_shr
// (4) and s74_u32_or_then_xor (217).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 1;            // shift amount
    c: u32 = 2;            // 0x02
    x: u32 = a >> b;       // 0x40 = 64
    r: u32 = x ^ c;        // 0x42 = 66
    return r;
}
