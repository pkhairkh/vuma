// u32_2_sub — u32 subtraction with masking: (100 - 70) & 0xFFFFFFFF
// Expected exit code: 30
//
// 100 - 70 = 30. No underflow. Masked to u32 = 30. Loads both operands
// into variables.

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 70;
    diff: u32 = (a - b) & 4294967295;
    return diff;
}
