// s13_u32_xor_with_mask.vuma — 0xF0 ^ 0x0F = 255
// Expected exit code: 255
//
// XOR of complementary nibbles. 240 ^ 15 = 0xFF = 255. Both operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s9_u32_and_mask (AND, not XOR) and
// s6_u32_xor_with_self (XOR with self -> 0).

fn main() -> i32 {
    a: u32 = 240;         // 0xF0
    b: u32 = 15;          // 0x0F
    r: u32 = a ^ b;       // 0xFF = 255
    return r;
}
