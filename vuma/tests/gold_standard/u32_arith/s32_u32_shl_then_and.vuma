// s32_u32_shl_then_and.vuma - (0x0F << 3) & 0x7F = 0x78 & 0x7F = 0x78 = 120
// Expected exit code: 120
//
// (0x0F << 3) & 0x7F = 0x78 & 0x7F = 0x78 = 120. All operands loaded into
// typed variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from s30_u32_shl_then_or
// (shl-then-or) and s26_u32_xor_then_shl (xor-then-shl).

fn main() -> i32 {
    a: u32 = 15;           // 0x0F
    b: u32 = 3;
    c: u32 = 127;          // 0x7F
    x: u32 = a << b;       // 0x78 = 120
    r: u32 = x & c;        // 0x78 = 120
    return r;
}
