// s14_u32_sub_chain_3.vuma — 100 - 25 - 25 = 50
// Expected exit code: 50
//
// Three-way u32 subtraction built via chained intermediates.
// Distinct from s9_u32_mul_pair (pair multiply) and
// s9_u32_shift_right_2 (shift right).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 25;
    c: u32 = 25;
    t1: u32 = a - b;      // 75
    r: u32 = t1 - c;      // 50
    return r;
}
