// s30_u32_shl_then_or.vuma — (1 << 4) | 0x0F = 0x10 | 0x0F = 0x1F = 31
// Expected exit code: 31
//
// SHL then OR. (1 << 4) = 16 (0x10); 16 | 15 = 31 (0x1F). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s26_u32_add_then_and (add-then-and, 44)
// and s22_u32_shl_then_and (shl-then-and).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 15;          // 0x0F
    x: u32 = a << b;      // 0x10 = 16
    r: u32 = x | c;       // 0x1F = 31
    return r;
}
