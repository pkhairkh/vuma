// s18_u32_shl_then_or.vuma — (0x03 << 6) | 0x05 = 0xC0 | 0x05 = 0xC5 = 197
// Expected exit code: 197
//
// SHL-then-OR. (3 << 6) = 192 (0xC0); 192 | 5 = 197 (0xC5). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s13_u32_shl_then_add
// (shl-then-add) and s14_u32_xor_then_shl (xor-then-shl).

fn main() -> i32 {
    a: u32 = 3;           // 0x03
    s: u32 = 6;
    b: u32 = 5;           // 0x05
    x: u32 = a << s;      // 0xC0 = 192
    r: u32 = x | b;       // 0xC5 = 197
    return r;
}
