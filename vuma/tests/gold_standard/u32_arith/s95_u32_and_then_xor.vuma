// s95_u32_and_then_xor.vuma — (0x0F & 0x07) ^ 0x50 = 0x07 ^ 0x50 = 0x57 = 87
// Expected exit code: 87
//
// Two-stage bitwise: AND then XOR. (15 & 7) = 7 (0x07);
// 7 ^ 80 = 87 (0x57). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_or_then_xor (243), s90_u32_and_then_shr (75) and
// s82_u32_or_then_and (15).
fn main() -> i32 {
    a: u32 = 15;           // 0x0F
    b: u32 = 7;            // 0x07
    c: u32 = 80;           // 0x50
    x: u32 = a & b;        // 0x07 = 7
    r: u32 = x ^ c;        // 0x57 = 87
    return r;
}
