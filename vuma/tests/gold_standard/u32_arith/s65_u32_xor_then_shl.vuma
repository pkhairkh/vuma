// s65_u32_xor_then_shl.vuma — (0x5A ^ 0x33) << 1 = 0x69 << 1 = 0xD2 = 210
// Expected exit code: 210
//
// Two-stage bitwise: XOR then shift-left. (90 ^ 51) = 105 (0x69);
// 105 << 1 = 210 (0xD2). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// xor_then_shl (204), s58_u32_xor_then_and (255) and s62_u32_xor_then_
// or (252).

fn main() -> i32 {
    a: u32 = 90;           // 0x5A
    b: u32 = 51;           // 0x33
    c: u32 = 1;            // shift amount
    x: u32 = a ^ b;        // 0x69 = 105
    r: u32 = x << c;       // 0xD2 = 210
    return r;
}
