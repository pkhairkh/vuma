// s99_u32_shl_then_xor.vuma — (0x03 << 4) ^ 0x05 = 0x30 ^ 0x05 = 0x35 = 53
// Expected exit code: 53
//
// Two-stage bitwise: shift-left then XOR. 3 << 4 = 48 (0x30);
// 48 ^ 5 = 53 (0x35). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s95_u32_shl_then_or (65), s91_u32_shl_then_and (18) and
// s87_u32_shl_then_or (101).
fn main() -> i32 {
    a: u32 = 3;            // 0x03
    s: u32 = 4;
    c: u32 = 5;            // 0x05
    x: u32 = a << s;       // 0x30 = 48
    r: u32 = x ^ c;        // 0x35 = 53
    return r;
}
