// s102_u32_or_then_and.vuma — (0x01 | 0x12) & 0x13 = 0x13 & 0x13 = 0x13 = 19
// Expected exit code: 19
//
// Two-stage bitwise: OR then AND. (1 | 18) = 19 (0x13); 19 & 19 = 19 (0x13). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_u32_or_then_shr (48), s101_u32_shl_then_xor (8), s101_u32_xor_then_and (240).
fn main() -> i32 {
    a: u32 = 1;          // 0x01
    b: u32 = 18;          // 0x12
    c: u32 = 19;          // 0x13
    o: u32 = a | b;        // 0x13 = 19
    r: u32 = o & c;        // 0x13 = 19
    return r;
}
