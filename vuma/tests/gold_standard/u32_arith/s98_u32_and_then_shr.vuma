// s98_u32_and_then_shr.vuma — (0xFF & 0xB2) >> 1 = 0xB2 >> 1 = 0x59 = 89
// Expected exit code: 89
//
// Two-stage bitwise: AND then shift-right. (255 & 178) = 178 (0xB2);
// 178 >> 1 = 89 (0x59). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_and_then_or (106), s90_u32_and_then_shr (75) and
// s86_u32_and_then_shr (24).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 178;          // 0xB2
    s: u32 = 1;
    x: u32 = a & b;        // 0xB2 = 178
    r: u32 = x >> s;       // 0x59 = 89
    return r;
}
