// s14_u32_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0x55 = 0xFF ^ 0x55 = 0xAA = 170
// Expected exit code: 170
//
// OR-then-XOR. (240 | 15) = 255 (0xFF); 255 ^ 85 = 170 (0xAA). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s10_u32_or_then_and
// (OR-then-AND) and s9_u32_and_mask (single AND-mask).

fn main() -> i32 {
    a: u32 = 240;         // 0xF0
    b: u32 = 15;          // 0x0F
    c: u32 = 85;          // 0x55
    x: u32 = a | b;       // 0xFF
    r: u32 = x ^ c;       // 0xAA = 170
    return r;
}
