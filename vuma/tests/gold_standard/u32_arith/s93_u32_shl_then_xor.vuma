// s93_u32_shl_then_xor.vuma — (10 << 3) ^ 0x01 = 0x50 ^ 0x01 = 0x51 = 81
// Expected exit code: 81
//
// Two-stage bitwise: shift-left then XOR. 10 << 3 = 80 (0x50);
// 80 ^ 1 = 81 (0x51). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_u32_shl_then_xor (74), s82_u32_shl_then_or (80) and s78_u32_shl_then_or (2).
fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 3;
    c: u32 = 1;            // 0x01
    x: u32 = a << b;       // 0x50 = 80
    r: u32 = x ^ c;        // 0x51 = 81
    return r;
}
