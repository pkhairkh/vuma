// s36_u32_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0xAA = 0xFF ^ 0xAA = 0x55 = 85
// Expected exit code: 85
//
// Two-stage computation: OR then XOR. (240 | 15) = 255
// (0xFF); 255 ^ 170 = 85 (0x55). All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s30_u32_or_then_shr (or-then-shr, 0) and s27_u32_or_then_xor (different values).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 170;          // 0xAA
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x ^ c;        // 0x55 = 85
    return r;
}
