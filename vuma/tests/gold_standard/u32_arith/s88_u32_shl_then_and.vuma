// s88_u32_shl_then_and.vuma — (0x0F << 4) & 0x70 = 0xF0 & 0x70 = 0x70 = 112
// Expected exit code: 112
//
// Two-stage bitwise: shift left then AND. (15 << 4) = 240
// (0xF0); 240 & 112 = 112 (0x70). All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s86_u32_shl_then_or (83),
// s82_u32_shl_then_or (80) and s78_u32_shl_then_or (2).
fn main() -> i32 {
    a: u32 = 15;           // 0x0F
    b: u32 = 4;            // shift amount
    c: u32 = 112;          // 0x70
    x: u32 = a << b;       // 0xF0 = 240
    r: u32 = x & c;        // 0x70 = 112
    return r;
}
