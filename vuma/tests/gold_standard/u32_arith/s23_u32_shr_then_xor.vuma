// s23_u32_shr_then_xor.vuma — (0xF0 >> 2) ^ 0x0F = 0x3C ^ 0x0F = 0x33 = 51
// Expected exit code: 51
//
// SHR then XOR. (240 >> 2) = 60 (0x3C); 60 ^ 15 = 51 (0x33). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_u32_sub_then_xor (sub-then-xor,
// value 153) and s22_u32_xor_then_or (xor-then-or, value 218).

fn main() -> i32 {
    a: u32 = 240;         // 0xF0
    sh: u32 = 2;
    b: u32 = 15;          // 0x0F
    x: u32 = a >> sh;     // 0x3C = 60
    r: u32 = x ^ b;       // 0x33 = 51
    return r;
}

