// s35_u32_shr_then_xor.vuma — (0xF0 >> 2) ^ 0x33 = 60 ^ 51 = 15
// Expected exit code: 15
//
// Two-stage bitwise: shift right then XOR. (240 >> 2) = 60 (0x3C);
// 60 ^ 51 = 15 (0x0F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_u32_xor_then_and (xor-then-and, 170) and s30_u32_xor_then_
// shr (xor-then-shr).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 2;
    c: u32 = 51;           // 0x33
    s: u32 = a >> b;       // 0x3C = 60
    r: u32 = s ^ c;        // 0x0F = 15
    return r;
}
