// s95_u32_xor_then_and.vuma — (0xAA ^ 0x55) & 0x2C = 0xFF & 0x2C = 0x2C = 44
// Expected exit code: 44
//
// Two-stage bitwise: XOR then AND. (170 ^ 85) = 255 (0xFF);
// 255 & 44 = 44 (0x2C). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_u32_xor_then_shl (32), s90_u32_xor_then_or (58) and
// s82_u32_xor_then_shr (45).
fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 85;           // 0x55
    c: u32 = 44;           // 0x2C
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0x2C = 44
    return r;
}
