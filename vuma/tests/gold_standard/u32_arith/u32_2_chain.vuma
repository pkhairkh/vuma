// u32_2_chain — chained arithmetic: (10 + 2) * 3 - 4 = 32
// Expected exit code: 32
//
// 10 + 2 = 12; 12 * 3 = 36; 36 - 4 = 32. Uses intermediate variables
// for each step to verify that arithmetic chains through multiple
// temporary locals.

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 2;
    s1: u32 = a + b;
    s2: u32 = s1 * 3;
    s3: u32 = s2 - 4;
    return s3;
}
