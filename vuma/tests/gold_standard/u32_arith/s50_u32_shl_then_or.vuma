// s50_u32_shl_then_or.vuma — (1 << 4) | 0x0F = 16 | 15 = 31
// Expected exit code: 31
//
// Two-stage bitwise: shift left then OR. (1 << 4) = 16; 16 | 15 =
// 31 (0x1F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_u32_or_then_and (195) and s43_u32_shl_then_add (68).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 15;           // 0x0F
    x: u32 = a << b;       // 0x10 = 16
    r: u32 = x | c;        // 0x1F = 31
    return r;
}
