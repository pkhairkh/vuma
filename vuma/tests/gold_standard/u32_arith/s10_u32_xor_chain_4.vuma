// s10_u32_xor_chain_4.vuma — 0x12 ^ 0x34 ^ 0x56 ^ 0x78 = 0x08 = 8
// Expected exit code: 8
//
// Four-way XOR chain. 0x12 ^ 0x34 = 0x26 (38); 0x26 ^ 0x56 = 0x70
// (112); 0x70 ^ 0x78 = 0x08 (8). All operands loaded into u32
// variables first. Distinct from s6_u32_xor_with_self (self-xor) and
// s5_u32_xor_two_stages (two stages).

fn main() -> i32 {
    a: u32 = 18;          // 0x12
    b: u32 = 52;          // 0x34
    c: u32 = 86;          // 0x56
    d: u32 = 120;         // 0x78
    t1: u32 = a ^ b;      // 0x26
    t2: u32 = t1 ^ c;     // 0x70
    r: u32 = t2 ^ d;      // 0x08 = 8
    return r;
}
