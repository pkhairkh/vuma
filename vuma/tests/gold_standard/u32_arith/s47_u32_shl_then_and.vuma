// s47_u32_shl_then_and.vuma — (0x09 << 4) & 0xF0 = 0x90 & 0xF0 = 0x90 = 144
// Expected exit code: 144
//
// Two-stage bitwise: shift left then AND. (9 << 4) = 144 (0x90);
// 144 & 240 = 144 (0x90). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_u32_and_then_or (63) and s42_u32_shl_then_add (26).

fn main() -> i32 {
    a: u32 = 9;            // 0x09
    b: u32 = 4;
    c: u32 = 240;          // 0xF0
    s: u32 = a << b;       // 0x90 = 144
    r: u32 = s & c;        // 0x90 = 144
    return r;
}
