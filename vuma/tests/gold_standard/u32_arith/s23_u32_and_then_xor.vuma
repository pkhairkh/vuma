// s23_u32_and_then_xor.vuma — (0xFF & 0x3C) ^ 0x03 = 0x3C ^ 0x03 = 0x3F = 63
// Expected exit code: 63
//
// AND then XOR. (255 & 60) = 60 (0x3C); 60 ^ 3 = 63 (0x3F). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_u32_xor_then_or (xor-then-or,
// value 218) and s22_u32_shl_then_and (shl-then-and, value 32).

fn main() -> i32 {
    a: u32 = 255;         // 0xFF
    b: u32 = 60;          // 0x3C
    c: u32 = 3;           // 0x03
    x: u32 = a & b;       // 0x3C = 60
    r: u32 = x ^ c;       // 0x3F = 63
    return r;
}

