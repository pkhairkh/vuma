// s41_u32_shl_then_or.vuma - (1 << 4) | 0x22 = 16 | 34 = 0x32 = 50
// Expected exit code: 50
//
// Two-stage bitwise: shift left then OR. (1 << 4) = 16 (0x10);
// 16 | 34 = 50 (0x32). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_shl_then_xor (37) and s34_u32_shl_then_or (69).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    c: u32 = 34;           // 0x22
    s: u32 = a << b;       // 16
    r: u32 = s | c;        // 0x32 = 50
    return r;
}
