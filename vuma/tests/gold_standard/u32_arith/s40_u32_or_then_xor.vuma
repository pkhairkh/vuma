// s40_u32_or_then_xor.vuma — (0x30 | 0x0F) ^ 0x44 = 0x3F ^ 0x44 = 0x7B = 123
// Expected exit code: 123
//
// Two-stage bitwise: OR then XOR. (48 | 15) = 63 (0x3F); 63 ^ 68 =
// 123 (0x7B). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_u32_add_then_and (144) and s34_u32_add_then_xor (165).

fn main() -> i32 {
    a: u32 = 48;           // 0x30
    b: u32 = 15;           // 0x0F
    c: u32 = 68;           // 0x44
    x: u32 = a | b;        // 0x3F = 63
    r: u32 = x ^ c;        // 0x7B = 123
    return r;
}
