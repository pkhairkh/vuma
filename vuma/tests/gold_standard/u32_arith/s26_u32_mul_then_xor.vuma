// s26_u32_mul_then_xor.vuma — (12 * 5) ^ 0x33 = 60 ^ 51 = 15
// Expected exit code: 15
//
// Mul then XOR. 12 * 5 = 60 (0x3C); 60 ^ 51 = 15 (0x0F). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s22_u32_xor_then_or (xor-then-or, 218) and
// s18_u32_add_xor_chain (add-xor chain).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 5;
    c: u32 = 51;          // 0x33
    m: u32 = a * b;       // 60 = 0x3C
    r: u32 = m ^ c;       // 0x0F = 15
    return r;
}
