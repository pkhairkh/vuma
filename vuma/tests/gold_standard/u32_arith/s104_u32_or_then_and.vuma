// s104_u32_or_then_and.vuma — (0x22 | 0x02) & 0x3F = 0x22 & 0x3F = 0x22 = 34
// Expected exit code: 34
//
// Two-stage bitwise: OR then AND. (34 | 2) = 34 (0x22); 34 & 63 = 34 (0x22). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_u32_or_then_and (19), s102_u32_shr_then_and (5), s102_u32_xor_then_shr (22).
fn main() -> i32 {
    a: u32 = 34;          // 0x22
    b: u32 = 2;          // 0x02
    c: u32 = 63;          // 0x3F
    o: u32 = a | b;        // 0x22 = 34
    r: u32 = o & c;        // 0x22 = 34
    return r;
}
