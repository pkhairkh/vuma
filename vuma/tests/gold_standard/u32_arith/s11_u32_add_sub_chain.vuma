// s11_u32_add_sub_chain.vuma — 50 + 30 - 10 - 5 = 65
// Expected exit code: 65
//
// Four-operand u32 chain. 50 + 30 = 80; 80 - 10 = 70; 70 - 5 = 65.
// All operands loaded into u32 variables first. Distinct from
// s10_u32_add_chain_4 (4-add chain, no sub) and s7_u32_add_chain_4
// (different vals).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 30;
    c: u32 = 10;
    d: u32 = 5;
    t1: u32 = a + b;     // 80
    t2: u32 = t1 - c;    // 70
    r: u32 = t2 - d;     // 65
    return r;
}
