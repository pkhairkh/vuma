// s20_u32_shl_then_xor.vuma — (0x09 << 2) ^ 0x10 = 0x24 ^ 0x10 = 0x34 = 52
// Expected exit code: 52
//
// Shift-left-then-XOR. (9 << 2) = 36 (0x24); 36 ^ 16 = 52 (0x34). All
// operands loaded into u32 variables first. Distinct from
// s18_u32_add_xor_chain (add-then-xor) and s14_u32_xor_then_shl
// (xor-then-shl).

fn main() -> i32 {
    a: u32 = 9;           // 0x09
    sh: u32 = 2;
    b: u32 = 16;          // 0x10
    x: u32 = a << sh;     // 0x24 = 36
    r: u32 = x ^ b;       // 0x34 = 52
    return r;
}
