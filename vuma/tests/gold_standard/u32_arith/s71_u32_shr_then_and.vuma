// s71_u32_shr_then_and.vuma — (0xF8 >> 2) & 0x3F = 0x3E & 0x3F = 0x3E = 62
// Expected exit code: 62
//
// Two-stage bitwise: shift right then AND. (248 >> 2) = 62
// (0x3E); 62 & 63 = 62 (0x3E). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s69_u32_shl_then_xor (83), s70_u32_shr_then_xor
// (180) and s66_u32_shr_then_xor (240).
fn main() -> i32 {
    a: u32 = 248;          // 0xF8
    b: u32 = 2;
    m: u32 = 63;           // 0x3F
    x: u32 = a >> b;       // 0x3E = 62
    r: u32 = x & m;        // 0x3E = 62
    return r;
}
