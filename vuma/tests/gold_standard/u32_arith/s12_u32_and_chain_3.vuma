// s12_u32_and_chain_3.vuma — 0xFF & 0xAA & 0x0F = 0x0A = 10
// Expected exit code: 10
//
// Three-way AND chain. 255 & 170 = 170 (0xAA); 170 & 15 = 10 (0x0A).
// All operands loaded into u32 variables first. Distinct from
// s9_u32_and_mask (two-way AND) and s10_u32_or_then_and (OR-then-AND).

fn main() -> i32 {
    a: u32 = 255;         // 0xFF
    b: u32 = 170;         // 0xAA
    c: u32 = 15;          // 0x0F
    t1: u32 = a & b;      // 0xAA = 170
    r: u32 = t1 & c;      // 0x0A = 10
    return r;
}
