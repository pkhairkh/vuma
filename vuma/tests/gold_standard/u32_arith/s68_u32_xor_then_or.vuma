// s68_u32_xor_then_or.vuma — (0x22 ^ 0x11) | 0x80 = 0x33 | 0x80 = 0xB3 = 179
// Expected exit code: 179
//
// Two-stage bitwise: XOR then OR. (34 ^ 17) = 51 (0x33);
// 51 | 128 = 179 (0xB3). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s66_u32_xor_then_and (51), s62_u32_xor_then_or (252) and
// s58_u32_or_then_xor (207).
fn main() -> i32 {
    a: u32 = 34;           // 0x22
    b: u32 = 17;           // 0x11
    c: u32 = 128;          // 0x80
    x: u32 = a ^ b;        // 0x33 = 51
    r: u32 = x | c;        // 0xB3 = 179
    return r;
}
