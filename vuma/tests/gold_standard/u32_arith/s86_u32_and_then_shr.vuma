// s86_u32_and_then_shr.vuma — (0xC0 & 0xF0) >> 3 = 0xC0 >> 3 = 0x18 = 24
// Expected exit code: 24
//
// Two-stage bitwise: AND then shift right. (192 & 240) = 192
// (0xC0); 192 >> 3 = 24 (0x18). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_u32_xor_then_shr (45), s78_u32_or_then_shr
// (4) and s74_u32_shr_then_xor (55).
fn main() -> i32 {
    a: u32 = 192;          // 0xC0
    b: u32 = 240;          // 0xF0
    c: u32 = 3;            // shift amount
    x: u32 = a & b;        // 0xC0 = 192
    r: u32 = x >> c;       // 0x18 = 24
    return r;
}
