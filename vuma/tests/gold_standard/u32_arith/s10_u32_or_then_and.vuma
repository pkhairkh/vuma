// s10_u32_or_then_and.vuma — (0xF0 | 0x0F) & 0xAA = 0xFF & 0xAA = 170
// Expected exit code: 170
//
// OR-then-AND. (240 | 15) = 255 (0xFF); 255 & 170 = 170 (0xAA). All
// operands loaded into u32 variables first. Distinct from
// s5_u32_add_then_shift (add-then-shift) and s6_u32_xor_with_self.

fn main() -> i32 {
    a: u32 = 240;         // 0xF0
    b: u32 = 15;          // 0x0F
    c: u32 = 170;         // 0xAA
    x: u32 = a | b;       // 0xFF
    r: u32 = x & c;       // 0xAA = 170
    return r;
}
