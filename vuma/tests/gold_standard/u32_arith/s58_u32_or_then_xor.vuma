// s58_u32_or_then_xor.vuma — (0x80 | 0x40) ^ 0x0F = 0xC0 ^ 0x0F = 0xCF = 207
// Expected exit code: 207
// 
// Two-stage bitwise: OR then XOR. (128 | 64) = 192 (0xC0);
// 192 ^ 15 = 207 (0xCF). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// or_then_shr (120), s51_u32_and_then_or (95) and s51_u32_xor_then_
// shl (204).

fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 64;           // 0x40
    c: u32 = 15;           // 0x0F
    x: u32 = a | b;        // 0xC0 = 192
    r: u32 = x ^ c;        // 0xCF = 207
    return r;
}
