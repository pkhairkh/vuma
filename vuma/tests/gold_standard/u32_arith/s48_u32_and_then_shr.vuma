// s48_u32_and_then_shr.vuma — (0xF8 & 0xE0) >> 5 = 0xE0 >> 5 = 0x07 = 7
// Expected exit code: 7
//
// Two-stage bitwise: AND then shift right. (248 & 224) = 224
// (0xE0); 224 >> 5 = 7 (0x07). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s46_u32_xor_then_shr (127) and s42_u32_and_then_
// shr.

fn main() -> i32 {
    a: u32 = 248;          // 0xF8
    b: u32 = 224;          // 0xE0
    c: u32 = 5;
    x: u32 = a & b;        // 0xE0 = 224
    r: u32 = x >> c;       // 0x07 = 7
    return r;
}
