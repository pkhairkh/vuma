// s105_u32_shr_then_xor.vuma — (0xF0 >> 2) ^ 0xED = 0x3C ^ 0xED = 0xD1 = 209
// Expected exit code: 209
// 
// Two-stage bitwise: shift-right then XOR. (240 >> 2) = 60 (0x3C); 60 ^ 237 = 209 (0xD1). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Operands nonzero & distinct.
// Distinct from s102_u32_shr_then_and (5), s101_u32_or_then_shr (48), s100_u32_shl_then_or (29).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    n: u32 = 2;
    c: u32 = 237;          // 0xED
    s: u32 = a >> n;       // 0x3C = 60
    r: u32 = s ^ c;        // 0xD1 = 209
    return r;
}
