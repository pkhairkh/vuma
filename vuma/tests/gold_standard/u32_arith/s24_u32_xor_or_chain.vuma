// s24_u32_xor_or_chain.vuma — (0x55 ^ 0x33) | 0x80 = 0x66 | 0x80 = 0xE6 = 230
// Expected exit code: 230
//
// XOR then OR. (85 ^ 51) = 102 (0x66); 102 | 128 = 230 (0xE6). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_u32_xor_then_or (xor-then-or,
// value 218) and s18_u32_xor_then_and (xor-then-and, value 96).

fn main() -> i32 {
    a: u32 = 85;          // 0x55
    b: u32 = 51;          // 0x33
    c: u32 = 128;         // 0x80
    x: u32 = a ^ b;       // 0x66 = 102
    r: u32 = x | c;       // 0xE6 = 230
    return r;
}
