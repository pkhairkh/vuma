// s12_u32_mul_then_mod.vuma — (7 * 9) % 10 = 63 % 10 = 3
// Expected exit code: 3
//
// Multiply then take modulo. 7 * 9 = 63; 63 % 10 = 3. All operands
// loaded into u32 variables first. Distinct from s4_u32_mod_then_mul
// (mod-then-mul, reverse order) and s8_u32_mul_sub (mul-then-sub).

fn main() -> i32 {
    a: u32 = 7;
    b: u32 = 9;
    m: u32 = 10;
    p: u32 = a * b;       // 63
    r: u32 = p % m;       // 3
    return r;
}
