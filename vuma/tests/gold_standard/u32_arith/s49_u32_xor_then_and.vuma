// s49_u32_xor_then_and.vuma — (0xF0 ^ 0x0F) & 0x33 = 0xFF & 0x33 = 0x33 = 51
// Expected exit code: 51
//
// Two-stage bitwise: XOR then AND. (240 ^ 15) = 255 (0xFF);
// 255 & 51 = 51 (0x33). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s48_u32_xor_then_and (240, 0xAA^0x55 & 0xF0) and s46_u32_xor_
// then_shr (127, xor-then-shr).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 51;           // 0x33
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0x33 = 51
    return r;
}
