// s30_u32_xor_then_shr.vuma — (0xCC ^ 0x33) >> 2 = 0xFF >> 2 = 0x3F = 63
// Expected exit code: 63
//
// XOR then SHR. (204 ^ 51) = 255 (0xFF); 255 >> 2 = 63 (0x3F). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s26_u32_xor_then_shl (xor-then-shl,
// 240) and s22_u32_shl_then_xor (shl-then-xor).

fn main() -> i32 {
    a: u32 = 204;          // 0xCC
    b: u32 = 51;           // 0x33
    c: u32 = 2;
    x: u32 = a ^ b;       // 0xFF = 255
    r: u32 = x >> c;      // 0x3F = 63
    return r;
}
