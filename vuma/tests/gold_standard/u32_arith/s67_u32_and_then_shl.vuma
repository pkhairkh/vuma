// s67_u32_and_then_shl.vuma — (0xFF & 0x0F) << 3 = 0x0F << 3 = 0x78 = 120
// Expected exit code: 120
//
// Two-stage bitwise: AND then shift left. (255 & 15) = 15
// (0x0F); 15 << 3 = 120 (0x78). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_u32_or_then_and (24), s62_u32_shl_then_
// and (64) and s58_u32_and_then_or (112).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 15;           // 0x0F
    c: u32 = 3;
    x: u32 = a & b;        // 0x0F = 15
    r: u32 = x << c;       // 0x78 = 120
    return r;
}
