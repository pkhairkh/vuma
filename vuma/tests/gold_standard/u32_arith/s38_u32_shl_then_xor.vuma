// s38_u32_shl_then_xor.vuma — (1 << 5) ^ 0x05 = 32 ^ 5 = 37
// Expected exit code: 37
//
// Two-stage bitwise: shift left then XOR. (1 << 5) = 32 (0x20);
// 32 ^ 5 = 37 (0x25). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s34_u32_shl_then_or (69) and s30_u32_shl_then_xor.

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;
    c: u32 = 5;            // 0x05
    s: u32 = a << b;       // 32
    r: u32 = s ^ c;        // 37
    return r;
}
