// s19_u32_xor_then_or.vuma — (0x55 ^ 0x0F) | 0x30 = 0x5A | 0x30 = 0x7A = 122
// Expected exit code: 122
//
// XOR-then-OR. (85 ^ 15) = 90 (0x5A); 90 | 48 = 122 (0x7A). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s18_u32_xor_then_and
// (xor-then-and) and s14_u32_or_then_xor (or-then-xor).

fn main() -> i32 {
    a: u32 = 85;          // 0x55
    b: u32 = 15;          // 0x0F
    c: u32 = 48;          // 0x30
    x: u32 = a ^ b;       // 0x5A = 90
    r: u32 = x | c;       // 0x7A = 122
    return r;
}
