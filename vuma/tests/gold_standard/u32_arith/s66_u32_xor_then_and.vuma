// s66_u32_xor_then_and.vuma — (0x55 ^ 0xAA) & 0x33 = 0xFF & 0x33 = 0x33 = 51
// Expected exit code: 51
//
// Two-stage bitwise: XOR then AND. (85 ^ 170) = 255 (0xFF);
// 255 & 51 = 51 (0x33). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s62_u32_xor_then_or (252), s58_u32_xor_then_and (255) and
// s55_u32_xor_then_shl (204).
fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 170;          // 0xAA
    c: u32 = 51;           // 0x33
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0x33 = 51
    return r;
}
