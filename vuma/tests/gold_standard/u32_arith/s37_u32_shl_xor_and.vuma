// s37_u32_shl_xor_and.vuma — ((3 << 4) ^ 0x10) & 0x7F = (0x30 ^ 0x10) & 0x7F = 0x20 & 0x7F = 0x20 = 32
// Expected exit code: 32
//
// Deterministic test in the u32_arith category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_u32_shl_xor_shr (shl-xor-shr, 49) and s30_u32_shl_then_or (shl-then-or).
fn main() -> i32 {
    a: u32 = 3;            // 0x03
    b: u32 = 4;
    c: u32 = 16;           // 0x10
    d: u32 = 127;          // 0x7F
    x: u32 = a << b;       // 0x30 = 48
    y: u32 = x ^ c;        // 0x20 = 32
    r: u32 = y & d;        // 0x20 = 32
    return r;
}
