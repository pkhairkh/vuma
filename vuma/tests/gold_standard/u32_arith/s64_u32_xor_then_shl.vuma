// s64_u32_xor_then_shl.vuma — (0x55 ^ 0x0F) << 1 = 0x5A << 1 = 0xB4 = 180
// Expected exit code: 180
//
// Two-stage bitwise: XOR then shift left. (85 ^ 15) = 90 (0x5A);
// 90 << 1 = 180 (0xB4). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s62_u32_
// and_then_xor (90), s62_u32_shl_then_xor (35) and s62_u32_xor_then_
// or (252).

fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 15;           // 0x0F
    c: u32 = 1;
    x: u32 = a ^ b;        // 0x5A = 90
    r: u32 = x << c;       // 0xB4 = 180
    return r;
}
