// s63_u32_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0xAA = 0xFF ^ 0xAA = 0x55 = 85
// Expected exit code: 85
//
// Two-stage bitwise: OR then XOR. (240 | 15) = 255 (0xFF);
// 255 ^ 170 = 85 (0x55). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s51_u32_or_then_shr (120), s58_u32_or_then_xor (207) and s55_u32_
// mul_then_xor (75).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 170;          // 0xAA
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x ^ c;        // 0x55 = 85
    return r;
}
