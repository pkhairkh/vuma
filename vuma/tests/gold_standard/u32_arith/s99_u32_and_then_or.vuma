// s99_u32_and_then_or.vuma — (0xFF & 0x33) | 0x08 = 0x33 | 0x08 = 0x3B = 59
// Expected exit code: 59
//
// Two-stage bitwise: AND then OR. (255 & 51) = 51 (0x33);
// 51 | 8 = 59 (0x3B). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s95_u32_and_then_xor (87), s91_u32_or_then_shr (24) and
// s87_u32_and_then_shr (20).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 51;           // 0x33
    c: u32 = 8;            // 0x08
    x: u32 = a & b;        // 0x33 = 51
    r: u32 = x | c;        // 0x3B = 59
    return r;
}
