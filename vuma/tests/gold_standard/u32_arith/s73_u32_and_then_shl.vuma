// s73_u32_and_then_shl.vuma — (0xFF & 0x07) << 4 = 0x07 << 4 = 0x70 = 112
// Expected exit code: 112
//
// Two-stage bitwise: AND then shift left. (255 & 7) = 7 (0x07);
// 7 << 4 = 112 (0x70). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_and_then_shl (100), s69_u32_and_then_shr (126)
// and s66_u32_or_then_and (24).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 7;            // 0x07
    c: u32 = 4;
    x: u32 = a & b;        // 0x07 = 7
    r: u32 = x << c;       // 0x70 = 112
    return r;
}
