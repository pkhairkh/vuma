// s88_u32_xor_then_or.vuma — (0xF0 ^ 0x0F) | 0x30 = 0xFF | 0x30 = 0xFF = 255
// Expected exit code: 255
//
// Two-stage bitwise: XOR then OR. (240 ^ 15) = 255 (0xFF);
// 255 | 48 = 255 (0xFF). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s86_u32_xor_then_and (51),
// s82_u32_xor_then_shr (45) and s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 48;           // 0x30
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x | c;        // 0xFF = 255
    return r;
}
