// s75_u32_or_then_xor.vuma — (0x70 | 0x0F) ^ 0x31 = 0x7F ^ 0x31 = 0x4E = 78
// Expected exit code: 78
//
// Two-stage bitwise: OR then XOR. 112 | 15 = 127 (0x7F);
// 127 ^ 49 = 78 (0x4E). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s74_u32_or_then_xor (217), s70_u32_or_then_and (240) and
// s66_u32_or_then_and (240).
fn main() -> i32 {
    a: u32 = 112;          // 0x70
    b: u32 = 15;           // 0x0F
    c: u32 = 49;           // 0x31
    x: u32 = a | b;        // 0x7F = 127
    r: u32 = x ^ c;        // 0x4E = 78
    return r;
}
