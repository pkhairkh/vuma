// s97_u32_or_then_and.vuma — (0xF0 | 0x0F) & 0x0D = 0xFF & 0x0D = 0x0D = 13
// Expected exit code: 13
//
// Two-stage bitwise: OR then AND. (240 | 15) = 255 (0xFF);
// 255 & 13 = 13 (0x0D). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_u32_and_then_or (106), s90_u32_and_then_shr (75), s86_u32_xor_then_and (51).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    c: u32 = 13;           // 0x0D
    x: u32 = a | b;        // 0xFF = 255
    r: u32 = x & c;        // 0x0D = 13
    return r;
}
