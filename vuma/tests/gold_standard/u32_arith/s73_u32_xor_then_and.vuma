// s73_u32_xor_then_and.vuma — (0x5C ^ 0x36) & 0x66 = 0x6A & 0x66 = 0x62 = 98
// Expected exit code: 98
//
// Two-stage bitwise: XOR then AND. (92 ^ 54) = 106 (0x6A);
// 106 & 102 = 98 (0x62). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_or_then_and (36), s69_u32_xor_then_or (181) and
// s66_u32_xor_then_and (51).
fn main() -> i32 {
    a: u32 = 92;           // 0x5C
    b: u32 = 54;           // 0x36
    c: u32 = 102;          // 0x66
    x: u32 = a ^ b;        // 0x6A = 106
    r: u32 = x & c;        // 0x62 = 98
    return r;
}
