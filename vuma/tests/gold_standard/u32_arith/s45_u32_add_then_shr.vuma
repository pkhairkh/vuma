// s45_u32_add_then_shr.vuma — (200 + 40) >> 2 = 240 >> 2 = 60
// Expected exit code: 60
//
// Two-stage arith/bitwise: add then shift right. 200 + 40 = 240;
// 240 >> 2 = 60. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_u32_mul_then_xor (mul-then-xor, 9) and s34_u32_add_then_shr.

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 40;
    c: u32 = 2;
    s: u32 = a + b;        // 240
    r: u32 = s >> c;       // 60
    return r;
}
