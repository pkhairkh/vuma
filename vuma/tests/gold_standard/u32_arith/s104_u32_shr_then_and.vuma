// s104_u32_shr_then_and.vuma — (0xAC >> 2) & 0x2F = 0x2B & 0x2F = 0x2B = 43
// Expected exit code: 43
//
// Two-stage bitwise: shift-right then AND. (172 >> 2) = 43 (0x2B); 43 & 47 = 43 (0x2B). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_u32_or_then_and (19), s102_u32_shr_then_and (5), s102_u32_xor_then_shr (22).
fn main() -> i32 {
    a: u32 = 172;          // 0xAC
    b: u32 = 47;          // 0x2F
    c: u32 = 2;
    s: u32 = a >> c;       // 0x2B = 43
    r: u32 = s & b;        // 0x2B = 43
    return r;
}
