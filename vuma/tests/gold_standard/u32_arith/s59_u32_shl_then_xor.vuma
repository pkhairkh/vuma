// s59_u32_shl_then_xor.vuma — (1 << 5) ^ 0x07 = 32 ^ 7 = 39
// Expected exit code: 39
//
// Two-stage bitwise: shift left then XOR. (1 << 5) = 32 (0x20);
// 32 ^ 7 = 39 (0x27). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s58_u32_
// xor_then_and (255), s58_u32_or_then_xor (207) and s58_u32_and_then_
// shr (60).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;
    c: u32 = 7;            // 0x07
    x: u32 = a << b;       // 0x20 = 32
    r: u32 = x ^ c;        // 0x27 = 39
    return r;
}
