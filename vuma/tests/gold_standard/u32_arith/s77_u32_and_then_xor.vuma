// s77_u32_and_then_xor.vuma — (0xF0 & 0xCC) ^ 0x22 = 0xC0 ^ 0x22 = 0xE2 = 226
// Expected exit code: 226
//
// Two-stage bitwise: AND then XOR. 240 & 204 = 192 (0xC0);
// 192 ^ 34 = 226 (0xE2). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_u32_and_then_shl (127), s66_u32_xor_then_and (51)
// and s74_u32_or_then_xor (217).

fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 204;          // 0xCC
    c: u32 = 34;           // 0x22
    x: u32 = a & b;        // 0xC0 = 192
    r: u32 = x ^ c;        // 0xE2 = 226
    return r;
}
