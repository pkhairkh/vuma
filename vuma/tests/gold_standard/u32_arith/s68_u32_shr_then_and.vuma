// s68_u32_shr_then_and.vuma — (0xCC >> 4) & 0x0F = 0x0C & 0x0F = 0x0C = 12
// Expected exit code: 12
//
// Two-stage bitwise: shift-right then AND. (204 >> 4) = 12
// (0x0C); 12 & 15 = 12 (0x0C). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_u32_or_then_and (24), s62_u32_shl_then_xor
// (35) and s58_u32_xor_then_and (255).
fn main() -> i32 {
    a: u32 = 204;          // 0xCC
    b: u32 = 4;
    c: u32 = 15;           // 0x0F
    x: u32 = a >> b;       // 0x0C = 12
    r: u32 = x & c;        // 0x0C = 12
    return r;
}
