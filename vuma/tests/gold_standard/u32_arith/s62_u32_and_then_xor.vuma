// s62_u32_and_then_xor.vuma — (0xFF & 0x55) ^ 0x0F = 0x55 ^ 0x0F = 0x5A = 90
// Expected exit code: 90
// 
// Two-stage bitwise: AND then XOR. (255 & 85) = 85 (0x55);
// 85 ^ 15 = 90 (0x5A). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_u32_
// and_then_or (95), s58_u32_and_then_shr (60) and s55_u32_shr_then_
// xor (31).

fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 85;           // 0x55
    c: u32 = 15;           // 0x0F
    x: u32 = a & b;        // 0x55 = 85
    r: u32 = x ^ c;        // 0x5A = 90
    return r;
}
