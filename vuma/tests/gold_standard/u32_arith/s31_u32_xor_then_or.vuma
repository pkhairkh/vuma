// s31_u32_xor_then_or.vuma — (0xAA ^ 0x55) | 0x0F = 0xFF | 0x0F = 0xFF = 255
// Expected exit code: 255
//
// XOR then OR. (170 ^ 85) = 255 (0xFF); 255 | 15 = 255 (0xFF). All
// operands loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s30_u32_xor_then_shr (xor-then-shr, 63)
// and s28_u32_or_then_xor (or-then-xor, 102).

fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 85;           // 0x55
    c: u32 = 15;           // 0x0F
    x: u32 = a ^ b;       // 0xFF = 255
    r: u32 = x | c;       // 0xFF = 255
    return r;
}
