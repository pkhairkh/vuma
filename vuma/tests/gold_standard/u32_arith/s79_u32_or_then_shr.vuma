// s79_u32_or_then_shr.vuma — (0x62 | 0x10) >> 1 = 0x72 >> 1 = 0x39 = 57
// Expected exit code: 57
//
// Two-stage u32 bitwise: OR then shift right. (98 | 16) =
// 114 (0x72); 114 >> 1 = 57 (0x39). All operands loaded into
// u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_u32_or_then_shr (4),
// s77_u32_or_then_shr (1) and s76_u32_or_then_shr (2).
fn main() -> i32 {
    a: u32 = 98;           // 0x62
    b: u32 = 16;           // 0x10
    c: u32 = 1;
    x: u32 = a | b;        // 0x72 = 114
    r: u32 = x >> c;       // 0x39 = 57
    return r;
}
