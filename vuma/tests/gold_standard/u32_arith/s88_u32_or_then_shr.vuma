// s88_u32_or_then_shr.vuma — (0x10 | 0x07) >> 1 = 0x17 >> 1 = 0x0B = 11
// Expected exit code: 11
//
// Two-stage bitwise: OR then shift right. (16 | 7) = 23
// (0x17); 23 >> 1 = 11 (0x0B). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s86_u32_and_then_shr (24),
// s82_u32_or_then_and (15) and s78_u32_or_then_shr (4).
fn main() -> i32 {
    a: u32 = 16;           // 0x10
    b: u32 = 7;            // 0x07
    c: u32 = 1;            // shift amount
    x: u32 = a | b;        // 0x17 = 23
    r: u32 = x >> c;       // 0x0B = 11
    return r;
}
