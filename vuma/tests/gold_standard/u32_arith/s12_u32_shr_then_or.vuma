// s12_u32_shr_then_or.vuma — (0xF0 >> 4) | 0x0F = 0x0F | 0x0F = 15
// Expected exit code: 15
//
// Shift right then OR. (240 >> 4) = 15 (0x0F); 15 | 15 = 15. All
// operands loaded into u32 variables first. Distinct from
// s10_u32_or_then_and (OR-then-AND) and s7_u32_or_mask (pure OR).

fn main() -> i32 {
    v: u32 = 240;         // 0xF0
    sh: u32 = 4;
    m: u32 = 15;          // 0x0F
    shifted: u32 = v >> sh;   // 0x0F = 15
    r: u32 = shifted | m;     // 0x0F = 15
    return r;
}
