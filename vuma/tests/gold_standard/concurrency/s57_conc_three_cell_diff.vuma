// s57_conc_three_cell_diff.vuma — three cells, diff = 110 (220 - 70 - 40)
// Expected exit code: 110
//
// Three independent 8-byte cells. Store 220/70/40 via `*ptr =
// literal`, load each, subtract sequentially -> 110. Uses `*ptr =
// literal` form. Distinct from s54_conc_three_cell_diff (110) and
// s50_conc_three_cell_diff (100).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 70;
    *c3 = 40;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    s: i32 = v1 - v2;      // 150
    r: i32 = s - v3;       // 110
    free(c1);
    free(c2);
    free(c3);
    return r;
}
