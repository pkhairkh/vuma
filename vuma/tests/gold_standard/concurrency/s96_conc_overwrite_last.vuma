// s96_conc_overwrite_last.vuma — overwrite c2 to 185, load = 185
// Expected exit code: 185
//
// Two independent 8-byte cells. Store 100 at c1, store 50 at c2,
// then overwrite c2 to 185. Load c2 -> 185. Uses `*ptr = literal`
// form. Distinct from s94_conc_overwrite_first (49),
// s90_conc_overwrite_last (11) and s86_conc_overwrite_last (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c2 = 185;
    v: i32 = *c2;          // 185
    free(c1);
    free(c2);
    return v;
}
