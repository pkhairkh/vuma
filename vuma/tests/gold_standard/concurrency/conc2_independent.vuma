// conc2_independent.vuma — two independent cells, return one
// Expected exit code: 42
//
// Two cells allocated with independent lifetimes. cell1 stores 42,
// cell2 stores 7 (an arbitrary independent value). We load cell1 and
// return it, demonstrating that writes to cell2 do not perturb cell1
// (no aliasing). Single-threaded, but the property verified
// (independent cells behave independently) is what IVE checks across
// threads too.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell1 = allocate(8);
    cell2 = allocate(8);
    *cell1 = 42;
    *cell2 = 7;
    val1: i32 = *cell1;
    free(cell1);
    free(cell2);
    return val1;
}
