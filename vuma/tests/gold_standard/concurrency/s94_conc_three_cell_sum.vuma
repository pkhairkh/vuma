// s94_conc_three_cell_sum.vuma — three cells, sum = 77 (40 + 20 + 17)
// Expected exit code: 77
//
// Three independent 8-byte cells. Store 40/20/17 via `*ptr =
// literal`, load all three, a + b + c -> 77. Uses `*ptr = literal`
// form. Distinct from s90_conc_three_cell_diff (10),
// s86_conc_three_cell_diff (150) and s82_conc_three_cell_diff (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 20;
    *c3 = 17;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 + v2 + v3; // 77
    free(c1);
    free(c2);
    free(c3);
    return r;
}
