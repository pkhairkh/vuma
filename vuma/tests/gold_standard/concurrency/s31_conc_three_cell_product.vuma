// s31_conc_three_cell_product.vuma — three cells, product = 210 (5*6*7)
// Expected exit code: 210
//
// Three independent 8-byte cells. Store 5/6/7 via `*ptr = literal`, load
// all three, multiply -> 210. Uses `*ptr = literal` form. Distinct from
// s30_conc_three_cell_sum (sum, 180) and s28_conc_three_cell_sum
// (sum, 120).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 5;
    *c2 = 6;
    *c3 = 7;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 * v2;
    s: i32 = t * v3;        // 210
    free(c1);
    free(c2);
    free(c3);
    return s;
}
