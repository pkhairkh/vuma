// conc_copy.vuma — copy value from cell1 to cell2, return cell2
// Expected exit code: 42
//
// Single-step copy: store 42 in cell1, load it into a scalar, store
// that scalar into cell2, load cell2 and return. This is the
// fundamental "publish a value through shared memory" pattern that
// every producer-consumer queue relies on.
//
// KNOWN WORKAROUND: storing a loaded variable via `*ptr = loaded_var`
// is silently dropped by the current x86_64 codegen. Storing an inline
// binary expression like `*ptr = loaded_var + 0` triggers a different
// codegen path that DOES emit the store correctly. This test uses the
// inline `+ 0` form; once the Store of a Register value is fixed, the
// `+ 0` becomes a no-op and the test still passes.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell1 = allocate(8);
    cell2 = allocate(8);
    *cell1 = 42;
    v1: i32 = *cell1;
    *cell2 = v1 + 0;       // copy cell1 -> cell2 (inline +0 workaround)
    v2: i32 = *cell2;
    free(cell1);
    free(cell2);
    return v2;
}
