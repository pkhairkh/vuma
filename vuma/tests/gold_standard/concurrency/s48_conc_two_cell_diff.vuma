// s48_conc_two_cell_diff.vuma — two cells, diff = 180 (230 - 50)
// Expected exit code: 180
//
// Two independent 8-byte cells. Store 230/50 via `*ptr = literal`,
// load both, subtract -> 180. Uses `*ptr = literal` form. Distinct
// from s46_conc_two_cell_sum (200) and s42_conc_two_cell_diff.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 230;
    *c2 = 50;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 180
    free(c1);
    free(c2);
    return d;
}
