// s89_conc_two_cell_sum.vuma — two cells, sum = 4 (3 + 1)
// Expected exit code: 4
//
// Two independent 8-byte cells. Store 3/1 via `*ptr =
// literal`, load both, sum -> 4. Uses `*ptr = literal` form.
// Distinct from s86_conc_two_cell_sum (210), s82_conc_two_cell_
// sum (190) and s78_conc_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 3;
    *c2 = 1;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 4
    free(c1);
    free(c2);
    return s;
}
