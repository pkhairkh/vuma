// s65_conc_overwrite_last.vuma — overwrite last to 65, sum = 145 (80 + 65)
// Expected exit code: 145
//
// Two independent 8-byte cells. Store 80/40 via `*ptr = literal`,
// overwrite the last cell with 65, load both, sum -> 145. Uses
// `*ptr = literal` form. Distinct from s51_conc_overwrite_last (200),
// s58_conc_overwrite_middle (200) and s62_conc_overwrite_first (150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 40;
    *c2 = 65;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 145
    free(c1);
    free(c2);
    return s;
}
