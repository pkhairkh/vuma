// s60_conc_two_cell_sum.vuma — two cells, sum = 225 (145 + 80)
// Expected exit code: 225
//
// Two independent 8-byte cells. Store 145/80 via `*ptr = literal`,
// load both, sum -> 225. Uses `*ptr = literal` form. Distinct from
// s58_conc_two_cell_diff (140) and s57_conc_two_cell_sum (235).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 145;
    *c2 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 225
    free(c1);
    free(c2);
    return s;
}
