// s63_conc_two_cell_sum.vuma — two cells, sum = 245 (155 + 90)
// Expected exit code: 245
//
// Two independent 8-byte cells. Store 155/90 via `*ptr = literal`,
// load both, sum -> 245. Uses `*ptr = literal` form. Distinct from
// s51_conc_two_cell_sum (225), s58_conc_two_cell_diff (140) and
// s55_conc_two_cell_sum (245).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 155;
    *c2 = 90;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 245
    free(c1);
    free(c2);
    return s;
}
