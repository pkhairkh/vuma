// s38_conc_three_cell_sum.vuma — three cells, sum = 170 (40 + 55 + 75)
// Expected exit code: 170
//
// Three independent 8-byte cells. Store 40/55/75 via `*ptr =
// literal`, load all, sum -> 170. Uses `*ptr = literal` form.
// Distinct from s34_conc_three_cell_sum (180) and s30_conc_two_
// cell_diff.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 55;
    *c3 = 75;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 170
    free(c1);
    free(c2);
    free(c3);
    return s;
}
