// s70_conc_two_cell_sum.vuma — two cells, sum = 105 (60 + 45)
// Expected exit code: 105
//
// Two independent 8-byte cells. Store 60/45 via `*ptr =
// literal`, load both, sum -> 105. Uses `*ptr = literal` form.
// Distinct from s66_conc_two_cell_diff (125), s65_conc_two_cell_
// sum (240) and s62_conc_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 60;
    *c2 = 45;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 105
    free(c1);
    free(c2);
    return s;
}
