// s62_conc_overwrite_first.vuma — overwrite first to 100, sum = 150 (100 + 20 + 30)
// Expected exit code: 150
// 
// Three independent 8-byte cells. Store 10/20/30 via `*ptr =
// literal`, then overwrite the first cell with 100. Load all three,
// sum -> 150. Uses `*ptr = literal` form. Distinct from s51_conc_
// overwrite_last (200), s58_conc_overwrite_middle (200) and s55_conc_
// two_cell_sum (225).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c1 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 150
    free(c1);
    free(c2);
    free(c3);
    return s;
}
