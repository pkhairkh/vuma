// s78_conc_overwrite_last.vuma — store 1, overwrite with 3, load = 3
// Expected exit code: 3
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite with
// 3 via `*ptr = literal`, load and return 3. Uses `*ptr =
// literal` form. Distinct from s74_conc_overwrite_last (165),
// s73_conc_overwrite_last (175) and s72_conc_overwrite_last (145).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 3;
    r: i32 = *c1;          // 3
    free(c1);
    return r;
}
