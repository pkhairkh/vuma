// s70_conc_three_cell_diff.vuma — three cells, diff = 160 (200 - 30 - 10)
// Expected exit code: 160
//
// Three independent 8-byte cells. Store 200/30/10 via `*ptr =
// literal`, load all three, diff -> 200 - 30 - 10 = 160. Uses
// `*ptr = literal` form. Distinct from s66_conc_three_cell_sum
// (240), s65_conc_three_cell_diff (135) and s62_conc_three_cell_
// diff (110).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 30;
    *c3 = 10;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 170
    d: i32 = t - v3;       // 160
    free(c1);
    free(c2);
    free(c3);
    return d;
}
