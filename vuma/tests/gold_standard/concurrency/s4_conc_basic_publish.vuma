// s4_conc_basic_publish.vuma — store/load roundtrip simulating publish/observe
// Expected exit code: 42
//
// Smallest concurrency primitive: a single cell that one would-be
// thread "publishes" to (writes 42) and another "observes" (loads
// and returns). Single-threaded, uses non-atomic *ptr per the
// documented bridge gap for atomic_store/load.

fn main() -> i32 {
    cell = allocate(8);
    *cell = 42;
    v: i32 = *cell;
    free(cell);
    return v;
}
