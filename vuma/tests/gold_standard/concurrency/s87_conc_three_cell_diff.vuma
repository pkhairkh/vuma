// s87_conc_three_cell_diff.vuma — three cells, diff = 135 (235 - 80 - 20)
// Expected exit code: 135
//
// Three independent 8-byte cells. Store 235/80/20 via `*ptr =
// literal`, load all three, a - b - c -> 135. Uses `*ptr =
// literal` form. Distinct from s86_conc_three_cell_diff (150),
// s82_conc_three_cell_diff (135) and s78_conc_three_cell_diff
// (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 235;
    *c2 = 80;
    *c3 = 20;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 135
    free(c1);
    free(c2);
    free(c3);
    return r;
}
