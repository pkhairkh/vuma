// s101_conc_overwrite_first.vuma — overwrite c1 to 27, load = 27
// Expected exit code: 27
//
// Three independent 8-byte cells. Store 100 at c1, store 200 at c2,
// store 50 at c3, then overwrite c1 to 27. Load c1 -> 27 (the
// overwritten value). Uses `*ptr = literal` form. Distinct from
// s98_conc_overwrite_first (118), s97_conc_overwrite_middle (23)
// and s94_conc_overwrite_first (49).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 27;
    v: i32 = *c1;          // 27
    free(c1);
    free(c2);
    free(c3);
    return v;
}
