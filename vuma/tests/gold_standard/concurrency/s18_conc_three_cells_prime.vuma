// s18_conc_three_cells_prime.vuma — three cells, prime values, sum = 49 (13 + 17 + 19)
// Expected exit code: 49
//
// Three independent 8-byte cells. Each gets a distinct small prime
// literal (13/17/19). All three loaded back and summed. Distinct from
// s14_conc_three_cells_even (even values 20/40/60 = 120) and
// s10_conc_four_cells (4 cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 13;
    *c2 = 17;
    *c3 = 19;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
