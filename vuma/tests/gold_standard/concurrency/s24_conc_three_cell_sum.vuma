// s24_conc_three_cell_sum.vuma — three cells, sum = 99 (22 + 33 + 44)
// Expected exit code: 99
//
// Three independent 8-byte cells. Each gets a distinct ascending literal
// (22/33/44, step 11). All three loaded back and summed. Distinct from
// s22_conc_three_cell_dec (descending 60/50/40 = 150) and
// s18_conc_three_cells_prime (13/17/19 = 49).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 22;
    *c2 = 33;
    *c3 = 44;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
