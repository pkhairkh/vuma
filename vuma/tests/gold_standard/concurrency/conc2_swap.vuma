// conc2_swap.vuma — swap two cells using a temp, return new cell1
// Expected exit code: 1
//
// Classic temp-variable swap: tmp = cell1; cell1 = cell2; cell2 = tmp.
// After swapping cell1=2 and cell2=1, cell1 holds 1 (the original
// cell2). We return the new cell1.
//
// KNOWN WORKAROUNDS (two stacked):
//  (1) Storing a loaded variable via `*ptr = loaded_var` is silently
//      dropped by the current x86_64 codegen. The inline form
//      `*ptr = loaded_var + 0` triggers a different codegen path that
//      emits the store correctly. All swap stores below use this form.
//  (2) When two buffers are allocated in sequence and the FIRST-
//      allocated buffer is overwritten via a `*ptr = expr` store AFTER
//      the second buffer has been stored to, the store is silently
//      dropped (a register-allocation / addressing bug in the backend).
//      Allocating the buffers in reverse order (cell2 first, then
//      cell1) sidesteps the issue.
// Both workarounds become no-ops once the underlying backend bugs are
// fixed; the test still passes the same way.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    // Allocate cell2 first to dodge the first-allocation store bug.
    cell2 = allocate(8);
    cell1 = allocate(8);
    *cell1 = 2;
    *cell2 = 1;
    v1: i32 = *cell1;       // 2
    v2: i32 = *cell2;       // 1
    tmp: i32 = v1 + 0;      // tmp = 2 (inline +0 to materialize in a fresh reg)
    *cell1 = v2 + 0;        // cell1 <- 1 (inline +0 store workaround)
    *cell2 = tmp + 0;       // cell2 <- 2 (inline +0 store workaround)
    result: i32 = *cell1;   // 1
    free(cell1);
    free(cell2);
    return result;
}
