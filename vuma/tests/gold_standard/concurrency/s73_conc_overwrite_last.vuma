// s73_conc_overwrite_last.vuma — overwrite c2 to 137, load = 137
// Expected exit code: 137
//
// Two 8-byte cells. Store 60 at c1, store 40 at c2 then overwrite
// c2 to 137. Load c2 -> 137 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s70_conc_overwrite_first (215),
// s69_conc_overwrite_last (85) and s66_conc_overwrite_middle (190).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 60;
    *c2 = 40;
    *c2 = 137;
    v: i32 = *c2;          // 137
    free(c1);
    free(c2);
    return v;
}
