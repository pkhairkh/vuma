// s9_conc_triple_publish.vuma — three publishes to one cell, observe final = 120
// Expected exit code: 120
//
// Single 8-byte cell. Three sequential writes (30, 60, 120). Reader
// observes only the final value 120. Single-threaded; simulates a
// shared variable being mutated across multiple "producer" steps.
// Distinct from s5_conc_triple_overwrite (writes 11/22/99).

fn main() -> i32 {
    cell = allocate(8);
    *cell = 30;
    *cell = 60;
    *cell = 120;
    v: i32 = *cell;
    free(cell);
    return v;
}
