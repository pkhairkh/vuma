// s64_conc_three_cell_sum.vuma — three cells, sum = 154 (44 + 77 + 33)
// Expected exit code: 154
//
// Three independent 8-byte cells. Store 44/77/33 via `*ptr = literal`,
// load all three, sum -> 154. Uses `*ptr = literal` form. Distinct from
// s62_conc_overwrite_first (150), s62_conc_three_cell_diff (110) and
// s62_conc_two_cell_sum (230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 44;
    *c2 = 77;
    *c3 = 33;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 154
    free(c1);
    free(c2);
    free(c3);
    return s;
}
