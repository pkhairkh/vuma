// s22_conc_overwrite_last.vuma — overwrite last cell, sum = 80 (20 + 30 + 30)
// Expected exit code: 80
//
// Three independent 8-byte cells. Store 20/30/40, then overwrite the
// last cell with 30. Load all three, sum -> 80. Uses `*ptr = literal`
// form (no offsets). Distinct from s18_conc_overwrite_first (overwrites
// the first cell) and s14_conc_overwrite_last (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 30;
    *c3 = 40;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
