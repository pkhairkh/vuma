// s104_conc_two_cell_diff.vuma — store 180, 3 in 2 cells, 180-3 = 177
// Expected exit code: 177
//
// Two independent 8-byte cells. Store 180 at c1, store 3 at c2, load each, return 180 - 3 = 177. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_conc_overwrite_middle (1), s102_conc_three_cell_diff (198), s102_conc_two_cell_sum (22).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 180;
    *c2 = 3;
    a: i32 = *c1;          // 180
    b: i32 = *c2;          // 3
    d: i32 = a - b;        // 177
    free(c1);
    free(c2);
    return d;
}
