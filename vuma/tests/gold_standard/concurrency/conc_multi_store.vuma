// conc_multi_store.vuma — store 3 values in 3 cells, load all, return sum
// Expected exit code: 7
//
// Three independent cells, each holding one addend (1, 2, 4). The
// program loads all three and returns their sum (1 + 2 + 4 = 7). This
// mirrors a "fan-in" reduction: each cell could be written by a
// different producer in a real multi-threaded program; here the
// producer writes are all in main, but the load-and-sum reduction is
// the same shape.
//
// Stores are decimal immediates (the codegen drops hex-literal stores
// via `*ptr = 0xNN`).
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell1 = allocate(8);
    cell2 = allocate(8);
    cell3 = allocate(8);
    *cell1 = 1;
    *cell2 = 2;
    *cell3 = 4;
    v1: i32 = *cell1;
    v2: i32 = *cell2;
    v3: i32 = *cell3;
    s1: i32 = v1 + v2;
    s2: i32 = s1 + v3;
    free(cell1);
    free(cell2);
    free(cell3);
    return s2;
}
