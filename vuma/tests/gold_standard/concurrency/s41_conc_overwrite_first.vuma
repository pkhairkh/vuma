// s41_conc_overwrite_first.vuma - overwrite first to 165, sum = 205 (165 + 40)
// Expected exit code: 205
//
// Two independent 8-byte cells. Store 70 then overwrite to 165 in
// c1; store 40 in c2. Load both, sum -> 205. Uses `*ptr = literal`
// form. Distinct from s38_conc_overwrite_first (185) and s34_conc_
// overwrite_last (130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 70;
    *c2 = 40;
    *c1 = 165;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 205
    free(c1);
    free(c2);
    return s;
}
