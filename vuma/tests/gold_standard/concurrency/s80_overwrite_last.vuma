// s80_conc_overwrite_last.vuma — store 1, overwrite with 18, load = 18
// Expected exit code: 18
//
// Single 8-byte cell. Store 1 via `*ptr = literal`, overwrite with
// 18 via `*ptr = literal`, load and return 18. Uses `*ptr =
// literal` form. Distinct from s78_conc_overwrite_last (3),
// s74_conc_overwrite_last (165) and s73_conc_overwrite_last (175).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 1;
    *c1 = 18;
    r: i32 = *c1;          // 18
    free(c1);
    return r;
}
