// s105_conc_overwrite_first.vuma — overwrite c1 to 209, load = 209
// Expected exit code: 209
// 
// Three independent 8-byte cells. Store 100 at c1, store 50 at c2, store 30 at c3, then overwrite c1 to 209. Load c1 -> 209 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_conc_overwrite_middle (1), s101_conc_overwrite_first (27), s100_conc_overwrite_first (47).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c3 = 30;
    *c1 = 209;
    v: i32 = *c1;          // 209
    free(c1);
    free(c2);
    free(c3);
    return v;
}
