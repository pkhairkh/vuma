// s79_conc_two_cell_sum.vuma — two cells, sum = 9 (4 + 5)
// Expected exit code: 9
//
// Two independent 8-byte cells. Store 4/5 via `*ptr =
// literal`, load both, sum -> 9. Uses `*ptr = literal` form.
// Distinct from s78_conc_two_cell_sum (2), s77_conc_two_cell_
// sum (3) and s76_conc_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 4;
    *c2 = 5;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 9
    free(c1);
    free(c2);
    return s;
}
