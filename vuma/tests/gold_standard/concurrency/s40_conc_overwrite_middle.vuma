// s40_conc_overwrite_middle.vuma — overwrite middle to 140, sum = 250 (25 + 140 + 85)
// Expected exit code: 250
//
// Two independent 8-byte cells. Store 25/55/85 via `*ptr = literal`,
// then overwrite the middle cell with 140. Load all three, sum ->
// 250. Uses `*ptr = literal` form. Distinct from s38_conc_overwrite_
// first (185) and s34_conc_overwrite_last (130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 25;
    *c2 = 55;
    *c3 = 85;
    *c2 = 140;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 250
    free(c1);
    free(c2);
    free(c3);
    return s;
}
