// s71_conc_overwrite_last.vuma — overwrite c3 to 188, load = 188
// Expected exit code: 188
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c3 to 188. Load c3 -> 188 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s69_conc_overwrite_last (85),
// s70_conc_overwrite_first (215) and s66_conc_overwrite_middle
// (190).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c3 = 188;
    v: i32 = *c3;          // 188
    free(c1);
    free(c2);
    free(c3);
    return v;
}
