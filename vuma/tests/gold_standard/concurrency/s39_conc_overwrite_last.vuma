// s39_conc_overwrite_last.vuma — overwrite last to 130, sum = 220 (90 + 130)
// Expected exit code: 220
//
// Two independent 8-byte cells. Store 90 then 40 in c2, then
// overwrite c2 to 130; store 90 in c1. Load both, sum -> 220.
// Uses `*ptr = literal` form. Distinct from s38_conc_overwrite_
// first (185) and s34_conc_overwrite_last (130).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 90;
    *c2 = 40;
    *c2 = 130;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 220
    free(c1);
    free(c2);
    return s;
}
