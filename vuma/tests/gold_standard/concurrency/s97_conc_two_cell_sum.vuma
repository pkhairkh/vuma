// s97_conc_two_cell_sum.vuma — two cells, sum = 23 (15 + 8)
// Expected exit code: 23
//
// Two independent 8-byte cells. Store 15/8 via `*ptr =
// literal`, load both, a + b -> 23. Uses `*ptr = literal`
// form.
// Distinct from s94_conc_two_cell_sum (120), s90_conc_overwrite_last (11), s86_conc_two_cell_sum (210).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 15;
    *c2 = 8;
    v1: i32 = *c1;
    v2: i32 = *c2;
    r: i32 = v1 + v2;      // 23
    free(c1);
    free(c2);
    return r;
}
