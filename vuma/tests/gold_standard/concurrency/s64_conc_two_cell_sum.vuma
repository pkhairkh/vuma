// s64_conc_two_cell_sum.vuma — two cells, sum = 210 (118 + 92)
// Expected exit code: 210
//
// Two independent 8-byte cells. Store 118/92 via `*ptr = literal`,
// load both, sum -> 210. Uses `*ptr = literal` form. Distinct from
// s62_conc_overwrite_first (150), s62_conc_three_cell_diff (110) and
// s62_conc_two_cell_sum (230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 118;
    *c2 = 92;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 210
    free(c1);
    free(c2);
    return s;
}
