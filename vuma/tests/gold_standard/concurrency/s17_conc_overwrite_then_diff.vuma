// s17_conc_overwrite_then_diff.vuma — c1: 90->10, c2: 50, diff = 50 - 10 = 40
// Expected exit code: 40
//
// Two 8-byte cells. Store 90 in c1, overwrite with 10 (last write
// wins); store 50 in c2. Load both, subtract c1 from c2 -> 40.
// Distinct from s14_conc_overwrite_middle (three-cell overwrite) and
// s10_conc_two_cells_diff (no overwrite).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 90;
    *c1 = 10;
    *c2 = 50;
    v1: i32 = *c1;        // 10
    v2: i32 = *c2;        // 50
    r: i32 = v2 - v1;     // 40
    free(c1);
    free(c2);
    return r;
}
