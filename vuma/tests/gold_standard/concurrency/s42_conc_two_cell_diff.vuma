// s42_conc_two_cell_diff.vuma — two cells, diff = 150 (200 - 50)
// Expected exit code: 150
//
// Two independent 8-byte cells. Store 200/50 via `*ptr = literal`,
// load both, subtract -> 150. Uses `*ptr = literal` form. Distinct
// from s38_conc_two_cell_sum (205) and s34_conc_two_cell_diff (65).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 50;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 150
    free(c1);
    free(c2);
    return d;
}
