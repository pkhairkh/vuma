// s79_conc_three_cell_diff.vuma — three cells, diff = 16 (35 - 11 - 8)
// Expected exit code: 16
//
// Three independent 8-byte cells. Store 35/11/8 via `*ptr =
// literal`, load all three, a - b - c -> 16. Uses `*ptr =
// literal` form. Distinct from s78_conc_three_cell_diff (148),
// s77_conc_three_cell_diff (172) and s76_conc_three_cell_diff
// (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 35;
    *c2 = 11;
    *c3 = 8;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 16
    free(c1);
    free(c2);
    free(c3);
    return r;
}
