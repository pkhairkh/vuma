// s93_conc_three_cell_diff.vuma — three cells, diff = 33 (250 - 200 - 17)
// Expected exit code: 33
//
// Three independent 8-byte cells. Store 250/200/17 via `*ptr =
// literal`, load all three, a - b - c -> 33. Uses `*ptr = literal`
// form. Distinct from s90_conc_three_cell_diff (10), s82_conc_three_cell_diff (135) and s78_conc_three_cell_diff (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 200;
    *c3 = 17;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 33
    free(c1);
    free(c2);
    free(c3);
    return r;
}
