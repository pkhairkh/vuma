// s100_conc_three_cell_sum.vuma — three cells, sum = 52 (26 + 14 + 12)
// Expected exit code: 52
//
// Three independent 8-byte cells. Store 26/14/12 via `*ptr
// = literal`, load all, a + b + c -> 52. Uses `*ptr =
// literal` form.
// Distinct from s97_conc_overwrite_middle (44), s94_conc_three_cell_sum (77), s90_conc_overwrite_last (11).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 26;
    *c2 = 14;
    *c3 = 12;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 + v2 + v3; // 52
    free(c1);
    free(c2);
    free(c3);
    return r;
}
