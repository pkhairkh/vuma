// s13_conc_three_cells.vuma — three cells, sum loads = 84 (18 + 28 + 38)
// Expected exit code: 84
//
// Three independent 8-byte cells with distinct literal values 18, 28,
// 38. All loaded back and summed -> 84. Simulates three independent
// "shared variables" without atomic ops. Uses `*ptr = literal` form
// (no offsets). Distinct from s9_conc_two_cell_sum (two cells) and
// s5_conc_three_cells (values 10/20/30 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 18;
    *c2 = 28;
    *c3 = 38;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
