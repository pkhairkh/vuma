// s88_conc_two_cell_sum.vuma — two cells, sum = 220 (140 + 80)
// Expected exit code: 220
//
// Two independent 8-byte cells. Store 140/80 via `*ptr =
// literal`, load both, sum -> 220. Uses `*ptr = literal`
// form. Distinct from s86_conc_two_cell_sum (210), s82_
// conc_two_cell_sum (190) and s78_conc_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 140;
    *c2 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 220
    free(c1);
    free(c2);
    return s;
}
