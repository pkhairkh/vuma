// s17_conc_two_cell_product.vuma — two cells, 12 * 7 = 84
// Expected exit code: 84
//
// Two independent 8-byte cells. Each gets a distinct literal (12 / 7).
// Both loaded back and multiplied -> 84. Distinct from
// s11_conc_two_cell_product (12 * 15 = 180) and s10_conc_two_cells_diff
// (subtraction).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 12;
    *c2 = 7;
    v1: i32 = *c1;
    v2: i32 = *c2;
    p: i32 = v1 * v2;     // 84
    free(c1);
    free(c2);
    return p;
}
