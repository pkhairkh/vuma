// s61_conc_overwrite_first.vuma — store 25, overwrite to 165, plus 60 -> 225
// Expected exit code: 225
// 
// Two independent 8-byte cells. Store 25 to c1, then overwrite c1
// with 165 via `*ptr = literal`; store 60 to c2. Load both, sum
// -> 225. Uses `*ptr = literal` form. Distinct from s58_conc_two_
// cell_diff (140), s58_conc_three_cell_sum (230) and s58_conc_
// overwrite_middle (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 25;
    *c1 = 165;
    *c2 = 60;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 225
    free(c1);
    free(c2);
    return s;
}
