// s99_conc_two_cell_sum.vuma — two cells, sum = 124 (80 + 44)
// Expected exit code: 124
//
// Two independent 8-byte cells. Store 80/44 via `*ptr = literal`,
// load both, a + b -> 124. Uses `*ptr = literal` form. Distinct
// from s95_conc_two_cell_diff (45), s91_conc_two_cell_diff (3) and
// s87_conc_two_cell_sum (205).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 44;
    v1: i32 = *c1;
    v2: i32 = *c2;
    r: i32 = v1 + v2;      // 124
    free(c1);
    free(c2);
    return r;
}
