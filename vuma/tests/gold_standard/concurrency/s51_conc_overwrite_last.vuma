// s51_conc_overwrite_last.vuma — overwrite last to 100, sum = 200 (40 + 60 + 100)
// Expected exit code: 200
//
// Three independent 8-byte cells. Store 40/60/80 via `*ptr =
// literal`, then overwrite the last cell with 100. Load all three,
// sum -> 200. Uses `*ptr = literal` form. Distinct from s50_conc_
// overwrite_first (230) and s47_conc_overwrite_first (160).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 40;
    *c2 = 60;
    *c3 = 80;
    *c3 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 200
    free(c1);
    free(c2);
    free(c3);
    return s;
}
