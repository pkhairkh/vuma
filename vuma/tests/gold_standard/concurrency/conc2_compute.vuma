// conc2_compute.vuma — store 10, load, return
// Expected exit code: 10
//
// "Atomic-compute" pattern in its simplest form: the value 10 is
// published to a cell and then read back. Real atomic-compute
// primitives (atomic_fetch_add, CAS-based RMW loops) build on this
// store-load round trip; this test isolates just the publish/observe
// half with a pre-computed value to dodge the *ptr = variable
// store-dropped bug entirely.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell = allocate(8);
    *cell = 10;
    result: i32 = *cell;
    free(cell);
    return result;
}
