// s20_conc_overwrite_first.vuma — c1: 20->100, c2=50, c3=30, sum = 180
// Expected exit code: 180  (100 + 50 + 30)
//
// Three independent 8-byte cells. Store 20 in c1, overwrite with 100,
// 50 in c2, 30 in c3. Load all three, sum -> 180. Uses `*ptr = literal`
// form. Distinct from s18_conc_overwrite_first (different values) and
// s14_conc_overwrite_middle (overwrites middle cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c1 = 100;
    *c2 = 50;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    s: i32 = v1 + v2 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
