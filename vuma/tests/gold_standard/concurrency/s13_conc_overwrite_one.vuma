// s13_conc_overwrite_one.vuma — overwrite one cell, sum = 120
// Expected exit code: 120  (80 + 40)
//
// Two 8-byte cells. Store 30/40, then overwrite c1 with 80. Load
// both, sum -> 120. Simulates one "shared variable" being updated
// after initialisation. Uses `*ptr = literal` form (no offsets).
// Distinct from s9_conc_overwrite_two_cells (both cells overwritten)
// and s6_conc_overwrite_then_sum (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    *c1 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
