// s95_conc_three_cell_sum.vuma — three cells, sum = 31 (13 + 17 + 1)
// Expected exit code: 31
//
// Three independent 8-byte cells. Store 13/17/1 via `*ptr = literal`,
// load all three, a + b + c -> 31. Uses `*ptr = literal` form.
// Distinct from s94_conc_three_cell_sum (77),
// s90_conc_three_cell_diff (10) and s82_conc_three_cell_diff (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 13;
    *c2 = 17;
    *c3 = 1;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 + v2 + v3; // 31
    free(c1);
    free(c2);
    free(c3);
    return r;
}
