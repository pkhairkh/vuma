// s75_conc_three_cell_sum.vuma — three cells, sum = 141 (50 + 60 + 31)
// Expected exit code: 141
//
// Three independent 8-byte cells. Store 50/60/31 via `*ptr =
// literal`, load all three, sum -> 141. Uses `*ptr = literal`
// form. Distinct from s74_conc_three_cell_diff (29),
// s70_conc_three_cell_diff (160) and s66_conc_three_cell_diff (190).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 60;
    *c3 = 31;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;      // 110
    r: i32 = t + v3;       // 141
    free(c1);
    free(c2);
    free(c3);
    return r;
}
