// s27_conc_three_cell_xor.vuma — three cells, xor = 105 (0x0F ^ 0x33 ^ 0x55)
// Expected exit code: 105
//
// Three independent 8-byte cells. Each gets a distinct literal at offset
// 0 (15/51/85). All loaded back and XORed. All operands loaded into
// typed locals before the XOR (immediate-RHS bitwise drop bug
// workaround). Distinct from s26_conc_three_cell_or (or) and
// s22_conc_three_cell_dec (sum, decrementing).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 15;             // 0x0F
    *c2 = 51;             // 0x33
    *c3 = 85;             // 0x55
    v1: u64 = *c1;
    v2: u64 = *c2;
    v3: u64 = *c3;
    t: u64 = v1 ^ v2;     // 0x3C = 60
    s: u64 = t ^ v3;      // 0x69 = 105
    free(c1);
    free(c2);
    free(c3);
    return s;
}
