// s48_conc_three_cell_sum.vuma — three cells, sum = 195 (45 + 65 + 85)
// Expected exit code: 195
//
// Three independent 8-byte cells. Store 45/65/85 via `*ptr =
// literal`, load all, sum -> 195. Uses `*ptr = literal` form.
// Distinct from s46_conc_three_cell_xor (240) and s42_conc_three_
// cell_sum (225).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 45;
    *c2 = 65;
    *c3 = 85;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 195
    free(c1);
    free(c2);
    free(c3);
    return s;
}
