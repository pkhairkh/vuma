// s47_conc_overwrite_first.vuma — overwrite first to 80, sum = 160 (80 + 35 + 45)
// Expected exit code: 160
//
// Three independent 8-byte cells. Store 25/35/45 via `*ptr = literal`,
// then overwrite the first cell with 80. Load all three, sum -> 160.
// Uses `*ptr = literal` form. Distinct from s46_conc_overwrite_
// last (180) and s42_conc_overwrite_middle (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 25;
    *c2 = 35;
    *c3 = 45;
    *c1 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 160
    free(c1);
    free(c2);
    free(c3);
    return s;
}
