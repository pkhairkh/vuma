// s49_conc_three_cell_sum.vuma — three cells, sum = 165 (45 + 55 + 65)
// Expected exit code: 165
//
// Three independent 8-byte cells. Store 45/55/65 via `*ptr =
// literal`, load all, sum -> 165. Uses `*ptr = literal` form.
// Distinct from s46_conc_three_cell_xor (240, xor) and s42_conc_
// three_cell_sum (225, sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 45;
    *c2 = 55;
    *c3 = 65;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 165
    free(c1);
    free(c2);
    free(c3);
    return s;
}
