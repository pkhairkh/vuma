// s102_conc_three_cell_diff.vuma — store 200,1,1 in 3 cells, 200-1-1 = 198
// Expected exit code: 198
//
// Three independent 8-byte cells. Store 200, 1, 1; load each, return 200 - 1 - 1 = 198. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_conc_overwrite_first (27), s101_conc_three_cell_diff (110), s101_conc_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 1;
    *c3 = 1;
    a: i32 = *c1;          // 200
    b: i32 = *c2;          // 1
    c: i32 = *c3;          // 1
    d: i32 = a - b - c;    // 198
    free(c1);
    free(c2);
    free(c3);
    return d;
}
