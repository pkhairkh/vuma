// s47_conc_three_cell_or.vuma — three cells, or = 224 (0x80 | 0x40 | 0x20)
// Expected exit code: 224
//
// Three independent 8-byte cells. Store 128/64/32 via `*ptr = literal`,
// load all, or -> 224 (0xE0). Uses `*ptr = literal` form. Distinct
// from s46_conc_three_cell_xor (240) and s42_conc_three_cell_sum
// (225).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 128;             // 0x80
    *c2 = 64;              // 0x40
    *c3 = 32;              // 0x20
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 | v2;
    s: i32 = t | v3;       // 0xE0 = 224
    free(c1);
    free(c2);
    free(c3);
    return s;
}
