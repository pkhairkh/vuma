// s35_conc_two_cell_sum.vuma — two cells, sum = 140 (65 + 75)
// Expected exit code: 140
//
// Two independent 8-byte cells. Store 65/75 via `*ptr = literal`,
// load both, sum -> 140. Uses `*ptr = literal` form. Distinct from
// s34_conc_two_cell_diff (diff, 65) and s30_conc_two_cell_product
// (product, 156).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 65;
    *c2 = 75;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 140
    free(c1);
    free(c2);
    return s;
}
