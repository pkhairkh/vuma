// s51_conc_two_cell_sum.vuma — two cells, sum = 225 (110 + 115)
// Expected exit code: 225
//
// Two independent 8-byte cells. Store 110/115 via `*ptr = literal`,
// load both, sum -> 225. Uses `*ptr = literal` form. Distinct from
// s50_conc_two_cell_sum (215) and s47_conc_two_cell_diff (90).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 110;
    *c2 = 115;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 225
    free(c1);
    free(c2);
    return s;
}
