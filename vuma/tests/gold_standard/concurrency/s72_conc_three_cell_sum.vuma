// s72_conc_three_cell_sum.vuma — three cells, sum = 175 (60 + 70 + 45)
// Expected exit code: 175
//
// Three independent 8-byte cells. Store 60/70/45 via `*ptr =
// literal`, load all three, sum -> 175. Uses `*ptr = literal`
// form. Distinct from s70_conc_three_cell_diff (160),
// s69_conc_three_cell_xor (95) and s66_conc_three_cell_diff (110).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 70;
    *c3 = 45;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;      // 130
    s: i32 = t + v3;       // 175
    free(c1);
    free(c2);
    free(c3);
    return s;
}
