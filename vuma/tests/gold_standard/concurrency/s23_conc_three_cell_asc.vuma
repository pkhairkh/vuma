// s23_conc_three_cell_asc.vuma — three cells ascending, sum = 120 (20 + 40 + 60)
// Expected exit code: 120
//
// Three independent 8-byte cells. Each gets a distinct ascending literal
// (20/40/60). All three loaded back and summed. Distinct from
// s22_conc_three_cell_dec (desc, 60/50/40 = 150) and s20_conc_three_cells_sum
// (15/30/45 = 90).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 40;
    *c3 = 60;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;     // 120
    free(c1);
    free(c2);
    free(c3);
    return s;
}

