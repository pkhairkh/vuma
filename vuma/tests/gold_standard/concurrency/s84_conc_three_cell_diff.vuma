// s84_conc_three_cell_diff.vuma — three cells, diff = 13 (25 - 8 - 4)
// Expected exit code: 13
//
// Three independent 8-byte cells. Store 25/8/4 via `*ptr =
// literal`, load all three, a - b - c -> 13. Uses `*ptr =
// literal` form. Distinct from s82_conc_three_cell_diff (135),
// s74_conc_three_cell_diff (29) and s72_conc_three_cell_sum (175).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 25;
    *c2 = 8;
    *c3 = 4;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 13
    free(c1);
    free(c2);
    free(c3);
    return r;
}
