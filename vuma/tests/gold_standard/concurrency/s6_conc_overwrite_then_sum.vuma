// s6_conc_overwrite_then_sum.vuma — overwrite one cell, sum = 90 (55 + 35)
// Expected exit code: 90
//
// Two 8-byte cells. Each gets an initial value (10/35), then cell 1
// is overwritten with 55. Load both, sum -> 90. Distinct from
// s5_conc_overwrite_observed (single-cell overwrite observation).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 10;
    *c2 = 35;
    *c1 = 55;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
