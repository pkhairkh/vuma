// s21_conc_two_cell_diff.vuma — two cells, diff = 70 (100 - 30)
// Expected exit code: 70
//
// Two independent 8-byte cells. Each gets a distinct literal (100/30).
// Both loaded back, diff -> 70. Uses `*ptr = literal` form (no offsets).
// Distinct from s18_conc_two_cell_sum (sum, 29+46 = 75) and
// s14_conc_two_cell_diff (diff, different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;
    free(c1);
    free(c2);
    return d;
}
