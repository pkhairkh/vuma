// s14_conc_two_cell_diff.vuma — two cells, sum loads = 51 (17 + 34)
// Expected exit code: 51
//
// Two independent 8-byte cells. Each gets a different literal at
// offset 0 (17/34). Both loaded back and summed. Distinct from
// s10_conc_two_cells_diff (values 35/45 = 80) and s6_conc_two_cell
// (values 30/40).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 17;
    *c2 = 34;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
