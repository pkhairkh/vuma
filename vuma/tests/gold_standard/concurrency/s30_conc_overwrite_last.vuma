// s30_conc_overwrite_last.vuma — overwrite last cell, sum = 130 (10+20+100)
// Expected exit code: 130
//
// Three independent 8-byte cells. Store 10/20/30, then overwrite the last
// cell with 100. Load all three, sum -> 130. Uses `*ptr = literal` form.
// Distinct from s26_conc_overwrite_first (overwrites the first cell, 110)
// and s22_conc_overwrite_last (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c3 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;        // 130
    free(c1);
    free(c2);
    free(c3);
    return s;
}
