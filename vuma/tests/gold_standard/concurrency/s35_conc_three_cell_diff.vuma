// s35_conc_three_cell_diff.vuma — three cells, diff = 100 (220 - 80 - 40)
// Expected exit code: 100
//
// Three independent 8-byte cells. Store 220/80/40 via `*ptr =
// literal`, load all, subtract sequentially -> 100. Uses `*ptr =
// literal` form. Distinct from s34_conc_three_cell_sum (sum, 180)
// and s30_conc_three_cell_sum (sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 80;
    *c3 = 40;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    d: i32 = t - v3;       // 100
    free(c1);
    free(c2);
    free(c3);
    return d;
}
