// s14_conc_three_cells_even.vuma — three cells, even values, sum = 120
// Expected exit code: 120  (20 + 40 + 60)
//
// Three independent 8-byte cells. Each gets a distinct even literal
// (20/40/60). All three loaded back and summed. Distinct from
// s10_conc_four_cells (4 cells) and s5_conc_three_cells (10/20/30).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 20;
    *c2 = 40;
    *c3 = 60;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
