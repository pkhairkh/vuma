// conc2_two_vars.vuma — two cells, store 42 in one, load from it
// Expected exit code: 42
//
// Two independent "atomic-like" cells allocated side-by-side. Stores
// 42 in cell1, 99 in cell2 (to confirm both cells are live and
// independent), then loads from cell1 and returns it. Mirrors the
// head+tail counter pair in a ring buffer.
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn main() -> i32 {
    cell1 = allocate(8);
    cell2 = allocate(8);
    *cell1 = 42;
    *cell2 = 99;
    val: i32 = *cell1;
    free(cell1);
    free(cell2);
    return val;
}
