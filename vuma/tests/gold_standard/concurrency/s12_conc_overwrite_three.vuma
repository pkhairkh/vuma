// s12_conc_overwrite_three.vuma — overwrite cell 3 times, load = 200
// Expected exit code: 200
//
// Single 8-byte cell. Store 5, then overwrite with 50, then
// overwrite with 200. Load returns 200 (last write wins). Three
// sequential writes to the same cell. Distinct from
// s10_conc_overwrite_one (two writes 10/80) and s5_conc_triple_overwrite
// (3 writes, different values).

fn main() -> i32 {
    c = allocate(8);
    *c = 5;
    *c = 50;
    *c = 200;
    v: i32 = *c;
    free(c);
    return v;
}
