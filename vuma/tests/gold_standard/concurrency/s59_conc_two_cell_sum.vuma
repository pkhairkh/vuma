// s59_conc_two_cell_sum.vuma — two cells, sum = 195 (115 + 80)
// Expected exit code: 195
//
// Two independent 8-byte cells. Store 115/80 via `*ptr = literal`,
// load both, sum -> 195. Uses `*ptr = literal` form. Distinct from
// s58_conc_two_cell_diff (140), s58_conc_three_cell_sum (230) and
// s58_conc_overwrite_middle (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 115;
    *c2 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 195
    free(c1);
    free(c2);
    return s;
}
