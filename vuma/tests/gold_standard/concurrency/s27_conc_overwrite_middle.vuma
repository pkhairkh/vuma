// s27_conc_overwrite_middle.vuma — overwrite middle, sum = 170 (100 + 20 + 50)
// Expected exit code: 170
//
// Three independent 8-byte cells. Store 100/10/50, then overwrite the
// middle cell with 20. Load all three, sum -> 170. Uses `*ptr = literal`
// form (no offsets). Distinct from s26_conc_overwrite_first (overwrites
// the first cell) and s22_conc_overwrite_last (overwrites the last).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 10;
    *c3 = 50;
    *c2 = 20;
    v1: u64 = *c1;
    v2: u64 = *c2;
    v3: u64 = *c3;
    s: u64 = v1 + v2 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
