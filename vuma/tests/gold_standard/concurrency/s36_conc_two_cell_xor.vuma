// s36_conc_two_cell_xor.vuma — cells 0xAA and 0x55, XOR = 0xFF = 255
// Expected exit code: 255
//
// Two 8-byte cells. Store 170/85 (0xAA/0x55) via `*ptr =
// literal`, load both, XOR -> 0xFF = 255. All bitwise
// operands loaded into typed locals first. Uses `*ptr =
// literal` form.
// Distinct from s30_conc_two_cell_xor (xor, 0) and s27_conc_two_cell_xor (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 170;             // 0xAA
    *c2 = 85;              // 0x55
    v1: i32 = *c1;
    v2: i32 = *c2;
    r: i32 = v1 ^ v2;      // 0xFF = 255
    free(c1);
    free(c2);
    return r;
}
