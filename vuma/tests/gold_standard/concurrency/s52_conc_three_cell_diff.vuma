// s52_conc_three_cell_diff.vuma — three cells, diff = 160 (240 - 60 - 20)
// Expected exit code: 160
//
// Three independent 8-byte cells. Store 240/60/20 via `*ptr =
// literal`, load all three, subtract -> 240 - 60 - 20 = 160. Uses
// `*ptr = literal` form. Distinct from s50_conc_three_cell_diff (120)
// and s46_conc_two_cell_sum (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 240;
    *c2 = 60;
    *c3 = 20;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    d1: i32 = v1 - v2;     // 180
    r: i32 = d1 - v3;      // 160
    free(c1);
    free(c2);
    free(c3);
    return r;
}
