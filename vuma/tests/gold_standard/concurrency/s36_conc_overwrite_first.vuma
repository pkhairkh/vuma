// s36_conc_overwrite_first.vuma — c1: 30 then 200; c2: 25; sum = 225
// Expected exit code: 225
//
// Two 8-byte cells. Store 30 then overwrite to 200 in c1;
// store 25 in c2; load both, sum -> 225. Uses `*ptr =
// literal` form.
// Distinct from s30_conc_overwrite_last (overwrite, 210) and s27_conc_overwrite_first (different cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 30;
    *c1 = 200;
    *c2 = 25;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 225
    free(c1);
    free(c2);
    return s;
}
