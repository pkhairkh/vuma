// s92_conc_three_cell_diff.vuma — three cells, diff = 57 (250 - 105 - 88)
// Expected exit code: 57
//
// Three independent 8-byte cells. Store 250/105/88 via `*ptr =
// literal`, load all three, a - b - c -> 57. Uses `*ptr = literal`
// form. Distinct from s90_conc_three_cell_diff (10),
// s86_conc_three_cell_diff (150) and s82_conc_three_cell_diff (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 105;
    *c3 = 88;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 57
    free(c1);
    free(c2);
    free(c3);
    return r;
}
