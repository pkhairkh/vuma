// s9_conc_overwrite_two_cells.vuma — overwrite BOTH cells, sum = 170
// Expected exit code: 170  (90 + 80)
//
// Two 8-byte cells. Each gets an initial value (15/25), then both
// are overwritten (90/80). Load both, sum -> 170. Distinct from
// s6_conc_overwrite_then_sum (overwrites only ONE cell).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 15;
    *c2 = 25;
    *c1 = 90;
    *c2 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
