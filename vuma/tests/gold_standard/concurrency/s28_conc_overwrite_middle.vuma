// s28_conc_overwrite_middle.vuma — overwrite middle cell, load = 65
// Expected exit code: 65
//
// Single 8-byte cell. Store 5 via `*ptr = literal`, then overwrite
// with 65 via `*ptr = literal`. Load and return 65. Uses `*ptr =
// literal` form. Distinct from s26_conc_overwrite_first (overwrite
// first of three, 110) and s22_conc_overwrite_last (overwrite last).

fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 5;
    *c1 = 65;
    v1: i32 = *c1;
    free(c1);
    return v1;
}
