// s86_conc_overwrite_last.vuma — overwrite c2 to 195, load = 195
// Expected exit code: 195
//
// Two 8-byte cells. Store 40 at c1, store 70 at c2, then
// overwrite c2 to 195. Load c2 -> 195 (the overwritten value).
// Uses `*ptr = literal` form. Distinct from s82_conc_overwrite_
// first (175), s78_conc_overwrite_last (3) and s74_conc_overwrite_
// last (165).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 40;
    *c2 = 70;
    *c2 = 195;
    r: i32 = *c2;          // 195
    free(c1);
    free(c2);
    return r;
}
