// s38_conc_two_cell_sum.vuma — two cells, sum = 205 (130 + 75)
// Expected exit code: 205
//
// Two independent 8-byte cells. Store 130/75 via `*ptr = literal`,
// load both, sum -> 205. Uses `*ptr = literal` form. Distinct from
// s34_conc_two_cell_diff (65) and s30_conc_three_cell_sum.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 130;
    *c2 = 75;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 205
    free(c1);
    free(c2);
    return s;
}
