// s66_conc_three_cell_sum.vuma — three cells, sum = 240 (60 + 80 + 100)
// Expected exit code: 240
//
// Three independent 8-byte cells. Store 60/80/100 via `*ptr =
// literal`, load all three, sum -> 240. Uses `*ptr = literal`
// form. Distinct from s62_conc_three_cell_diff (110), s58_conc_
// three_cell_sum (230) and s55_conc_three_cell_diff (115).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 60;
    *c2 = 80;
    *c3 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;      // 140
    s: i32 = t + v3;       // 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
