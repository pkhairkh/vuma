// s50_conc_two_cell_sum.vuma — two cells, sum = 215 (95 + 120)
// Expected exit code: 215
//
// Two independent 8-byte cells. Store 95/120 via `*ptr = literal`,
// load both, sum -> 215. Uses `*ptr = literal` form. Distinct from
// s46_conc_two_cell_sum (200) and s43_conc_two_cell_sum (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 120;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 215
    free(c1);
    free(c2);
    return s;
}
