// s76_conc_three_cell_diff.vuma — three cells, diff = 37 (250 - 130 - 83)
// Expected exit code: 37
//
// Three independent 8-byte cells. Store 250/130/83 via `*ptr =
// literal`, load all three, diff -> 37. Uses `*ptr = literal`
// form. Distinct from s74_conc_three_cell_diff (29),
// s73_conc_three_cell_diff (131) and s72_conc_three_cell_sum (175).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 130;
    *c3 = 83;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;      // 120
    r: i32 = t - v3;       // 37
    free(c1);
    free(c2);
    free(c3);
    return r;
}
