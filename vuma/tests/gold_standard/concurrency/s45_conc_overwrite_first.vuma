// s45_conc_overwrite_first.vuma — overwrite first to 100, sum = 250 (100 + 60 + 90)
// Expected exit code: 250
//
// Three independent 8-byte cells. Store 30/60/90 via `*ptr =
// literal`, then overwrite the first cell with 100. Load all three,
// sum -> 250. Uses `*ptr = literal` form. Distinct from
// s42_conc_overwrite_middle (220) and s38_conc_overwrite_first (185).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c3 = 90;
    *c1 = 100;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 250
    free(c1);
    free(c2);
    free(c3);
    return s;
}
