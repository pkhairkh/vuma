// s99_conc_overwrite_last.vuma — overwrite c3 to 125, load = 125
// Expected exit code: 125
//
// Three independent 8-byte cells. Store 100 at c1, store 200 at c2,
// store 50 at c3, then overwrite c3 to 125. Load c3 -> 125 (the
// overwritten value). Uses `*ptr = literal` form. Distinct from
// s95_conc_overwrite_last (41), s91_conc_overwrite_last (9) and
// s87_conc_overwrite_last (215).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c3 = 125;
    v: i32 = *c3;          // 125
    free(c1);
    free(c2);
    free(c3);
    return v;
}
