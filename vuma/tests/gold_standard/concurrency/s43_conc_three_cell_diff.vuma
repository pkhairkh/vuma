// s43_conc_three_cell_diff.vuma — three cells, diff = 100 (200 - 70 - 30)
// Expected exit code: 100
//
// Three independent 8-byte cells. Store 200/70/30 via `*ptr =
// literal`, load all, subtract sequentially -> 100. Uses `*ptr =
// literal` form. Distinct from s42_conc_three_cell_sum (210) and
// s38_conc_three_cell_sum (220).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 70;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    d: i32 = v1 - v2 - v3; // 100
    free(c1);
    free(c2);
    free(c3);
    return d;
}
