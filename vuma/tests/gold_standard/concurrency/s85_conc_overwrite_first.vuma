// s85_conc_overwrite_first.vuma — store 22 then 187, load = 187
// Expected exit code: 187
//
// Single 8-byte cell. Store 22 via `*ptr = literal`, overwrite
// with 187 via `*ptr = literal` (last write wins). Load and
// return 187. Uses non-atomic `*ptr` per the bridge-gap
// workaround. Distinct from s82_conc_overwrite_first (215),
// s78_conc_overwrite_first (3) and s74_conc_overwrite_first (85).
fn main() -> i32 {
    cell = allocate(8);
    *cell = 22;
    *cell = 187;
    val: i32 = *cell;
    free(cell);
    return val;
}
