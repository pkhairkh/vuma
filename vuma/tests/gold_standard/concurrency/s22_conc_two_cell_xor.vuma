// s22_conc_two_cell_xor.vuma — two cells, xor = 75 (41 ^ 98)
// Expected exit code: 75
//
// Two independent 8-byte cells. Each gets a distinct literal at offset 0
// (41/98). Both loaded back and XORed. All operands loaded into typed
// locals before the XOR (immediate-RHS bitwise drop bug workaround).
// Distinct from s18_conc_two_cell_sum (28/52 = 80) and
// s14_conc_two_cell_diff (17/34 = 51, sub).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 41;
    *c2 = 98;
    v1: u64 = *c1;
    v2: u64 = *c2;
    s: u64 = v1 ^ v2;     // 0x29 ^ 0x62 = 0x4B = 75
    free(c1);
    free(c2);
    return s;
}
