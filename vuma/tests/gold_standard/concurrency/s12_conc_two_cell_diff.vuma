// s12_conc_two_cell_diff.vuma — two cells, sum loads = 100 (45 + 55)
// Expected exit code: 100
//
// Two independent 8-byte cells. Each gets a different literal at
// offset 0 (45/55). Both loaded back and summed. Simulates two
// independent "shared variables" without atomic ops. Distinct from
// s10_conc_two_cells_diff (values 35/45) and s9_conc_two_cell_sum
// (values 25/35 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 45;
    *c2 = 55;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
