// s61_conc_three_cell_diff.vuma — three cells, diff = 125 (200 - 50 - 25)
// Expected exit code: 125
// 
// Three independent 8-byte cells. Store 200/50/25 via `*ptr =
// literal`, load all three, 200 - 50 - 25 = 125. Uses `*ptr =
// literal` form. Distinct from s58_conc_two_cell_diff (140), s58_
// conc_three_cell_sum (230) and s58_conc_overwrite_middle (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 50;
    *c3 = 25;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    r: i32 = t - v3;     // 125
    free(c1);
    free(c2);
    free(c3);
    return r;
}
