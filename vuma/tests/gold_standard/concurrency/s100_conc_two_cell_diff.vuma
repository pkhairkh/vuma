// s100_conc_two_cell_diff.vuma — two cells, diff = 36 (50 - 14)
// Expected exit code: 36
//
// Two independent 8-byte cells. Store 50/14 via `*ptr =
// literal`, load both, a - b -> 36. Uses `*ptr = literal`
// form.
// Distinct from s97_conc_overwrite_middle (44), s94_conc_overwrite_first (49), s90_conc_two_cell_diff (5).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 50;
    *c2 = 14;
    v1: i32 = *c1;
    v2: i32 = *c2;
    r: i32 = v1 - v2;      // 36
    free(c1);
    free(c2);
    return r;
}
