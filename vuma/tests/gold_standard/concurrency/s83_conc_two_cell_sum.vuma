// s83_conc_two_cell_sum.vuma — two cells, sum = 162 (88 + 74)
// Expected exit code: 162
//
// Two independent 8-byte cells. Store 88/74 via `*ptr =
// literal`, load both, sum -> 162. Uses `*ptr = literal` form.
// Distinct from s78_conc_two_cell_sum (2), s74_conc_two_cell_
// sum (105) and s72_conc_two_cell_sum (135).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 88;
    *c2 = 74;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 162
    free(c1);
    free(c2);
    return s;
}
