// s53_conc_overwrite_last.vuma — overwrite last to 90, sum = 200 (50 + 60 + 90)
// Expected exit code: 200
//
// Three independent 8-byte cells. Store 50/60/70 via `*ptr =
// literal`, then overwrite the last cell with 90. Load all three,
// sum -> 200. Uses `*ptr = literal` form. Distinct from s49_conc_
// overwrite_first (190) and s50_conc_overwrite_first (230).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 60;
    *c3 = 70;
    *c3 = 90;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 200
    free(c1);
    free(c2);
    free(c3);
    return s;
}
