// s30_conc_two_cell_product.vuma — two cells, product = 156 (12 * 13)
// Expected exit code: 156
//
// Two independent 8-byte cells. Store 12/13 via `*ptr = literal`, load
// both, multiply -> 156. Uses `*ptr = literal` form. Distinct from
// s26_conc_two_cell_and (and, 15) and s22_conc_two_cell_xor (xor).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 12;
    *c2 = 13;
    v1: i32 = *c1;
    v2: i32 = *c2;
    p: i32 = v1 * v2;       // 156
    free(c1);
    free(c2);
    return p;
}
