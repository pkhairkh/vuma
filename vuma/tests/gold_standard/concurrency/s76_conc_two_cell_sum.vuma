// s76_conc_two_cell_sum.vuma — two cells, sum = 82 (41 + 41)
// Expected exit code: 82
//
// Two independent 8-byte cells. Store 41/41 via `*ptr = literal`,
// load both, sum -> 82. Uses `*ptr = literal` form. Distinct from
// s74_conc_two_cell_sum (132), s73_conc_two_cell_sum (111) and
// s72_conc_two_cell_diff (155).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 41;
    *c2 = 41;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 82
    free(c1);
    free(c2);
    return s;
}
