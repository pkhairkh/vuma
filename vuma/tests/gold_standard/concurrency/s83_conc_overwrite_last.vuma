// s83_conc_overwrite_last.vuma — overwrite c2 to 151, load = 151
// Expected exit code: 151
//
// Two 8-byte cells. Store 30 at c1, store 60 at c2 then
// overwrite c2 to 151. Load c2 -> 151 (the overwritten value).
// Uses `*ptr = literal` form. Distinct from s78_conc_overwrite_
// last (3), s74_conc_overwrite_last (165) and s72_conc_overwrite_
// first (115).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c2 = 151;
    r: i32 = *c2;          // 151
    free(c1);
    free(c2);
    return r;
}
