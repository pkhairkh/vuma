// s15_conc_three_cells_step5.vuma — three cells, step-5 values, sum = 30
// Expected exit code: 30  (5 + 10 + 15)
//
// Three independent 8-byte cells. Store 5/10/15 (step 5) via `*ptr = literal`.
// Load all three, sum, return 30. Distinct from s14_conc_three_cells_even
// (20/40/60 = 120) and s5_conc_three_cells (10/20/30 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 5;
    *c2 = 10;
    *c3 = 15;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
