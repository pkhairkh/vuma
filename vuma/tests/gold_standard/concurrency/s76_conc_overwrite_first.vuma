// s76_conc_overwrite_first.vuma — overwrite c1 to 139, load = 139
// Expected exit code: 139
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c1 to 139. Load c1 -> 139 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s74_conc_overwrite_first (222),
// s73_conc_overwrite_last (137) and s72_conc_overwrite_last (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c1 = 139;
    v: i32 = *c1;          // 139
    free(c1);
    free(c2);
    free(c3);
    return v;
}
