// s7_conc_three_independent.vuma — 3 separate cells, sum = 11+22+33 = 66
// Expected exit code: 66
//
// Three independent 8-byte allocations, each treated as a separate
// "shared variable" without atomic ops. Values 11/22/33, sum = 66.
// Distinct from s5_conc_three_cells (three cells in one buf) and
// s6_conc_two_cell (two cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 11;
    *c2 = 22;
    *c3 = 33;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
