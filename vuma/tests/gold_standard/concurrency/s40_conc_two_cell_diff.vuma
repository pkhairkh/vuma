// s40_conc_two_cell_diff.vuma — two cells, diff = 120 (200 - 80)
// Expected exit code: 120
//
// Two independent 8-byte cells. Store 200/80 via `*ptr = literal`,
// load both, diff -> 120. Uses `*ptr = literal` form. Distinct from
// s38_conc_two_cell_sum (205) and s34_conc_two_cell_diff (65).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 200;
    *c2 = 80;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 120
    free(c1);
    free(c2);
    return d;
}
