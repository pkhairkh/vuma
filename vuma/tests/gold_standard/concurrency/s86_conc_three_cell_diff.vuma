// s86_conc_three_cell_diff.vuma — three cells, diff = 150 (245 - 75 - 20)
// Expected exit code: 150
//
// Three independent 8-byte cells. Store 245/75/20 via `*ptr =
// literal`, load all three, a - b - c -> 150. Uses `*ptr =
// literal` form. Distinct from s82_conc_three_cell_diff (135),
// s78_conc_three_cell_diff (148) and s74_conc_three_cell_diff
// (55).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 245;
    *c2 = 75;
    *c3 = 20;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    r: i32 = v1 - v2 - v3; // 150
    free(c1);
    free(c2);
    free(c3);
    return r;
}
