// s24_conc_overwrite_first.vuma — overwrite first cell, sum = 125 (70 + 22 + 33)
// Expected exit code: 125
//
// Three independent 8-byte cells. Store 11/22/33, then overwrite the
// first cell with 70. Load all three, sum -> 125. Uses `*ptr = literal`
// form (no offsets). Distinct from s22_conc_overwrite_last (overwrites
// the last cell, 20/30/40 -> 30 = 80) and s18_conc_overwrite_first
// (overwrites the first cell, different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 11;
    *c2 = 22;
    *c3 = 33;
    *c1 = 70;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t1: i32 = v1 + v2;
    s: i32 = t1 + v3;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
