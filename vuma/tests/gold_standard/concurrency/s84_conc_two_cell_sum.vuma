// s84_conc_two_cell_sum.vuma — two cells, sum = 12 (7 + 5)
// Expected exit code: 12
//
// Two independent 8-byte cells. Store 7/5 via `*ptr =
// literal`, load both, sum -> 12. Uses `*ptr = literal` form.
// Distinct from s82_conc_two_cell_sum (190), s78_conc_two_cell_
// sum (2) and s74_conc_two_cell_sum (132).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 7;
    *c2 = 5;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 12
    free(c1);
    free(c2);
    return s;
}
