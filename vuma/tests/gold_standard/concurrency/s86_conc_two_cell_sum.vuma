// s86_conc_two_cell_sum.vuma — two cells, sum = 210 (120 + 90)
// Expected exit code: 210
//
// Two independent 8-byte cells. Store 120/90 via `*ptr =
// literal`, load both, sum -> 210. Uses `*ptr = literal` form.
// Distinct from s82_conc_two_cell_sum (190), s78_conc_two_cell_
// sum (2) and s74_conc_two_cell_sum (105).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 120;
    *c2 = 90;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 210
    free(c1);
    free(c2);
    return s;
}
