// s69_conc_two_cell_sum.vuma -- two cells, sum = 170 (80 + 90)
// Expected exit code: 170
//
// Two independent 8-byte cells. Store 80/90 via `*ptr = literal`,
// load both, sum -> 170. Uses `*ptr = literal` form. Distinct from
// s66_conc_two_cell_diff (125), s65_conc_two_cell_sum (240) and s64_
// conc_two_cell_diff (144).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 80;
    *c2 = 90;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;      // 170
    free(c1);
    free(c2);
    return s;
}
