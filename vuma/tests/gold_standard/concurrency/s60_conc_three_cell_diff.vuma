// s60_conc_three_cell_diff.vuma — three cells, diff = 120 (210 - 60 - 30)
// Expected exit code: 120
//
// Three independent 8-byte cells. Store 210/60/30 via `*ptr =
// literal`, load all three, 210 - 60 - 30 = 120. Uses `*ptr =
// literal` form. Distinct from s58_conc_three_cell_sum (230) and
// s57_conc_three_cell_diff (110).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 210;
    *c2 = 60;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 - v2;
    r: i32 = t - v3;       // 120
    free(c1);
    free(c2);
    free(c3);
    return r;
}
