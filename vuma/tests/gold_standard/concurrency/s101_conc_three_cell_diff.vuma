// s101_conc_three_cell_diff.vuma — three cells, diff = 110 (220 - 80 - 30)
// Expected exit code: 110
//
// Three independent 8-byte cells. Store 220/80/30 via `*ptr =
// literal`, load all three, a - b - c -> 110. Uses `*ptr = literal`
// form. Distinct from s98_conc_three_cell_sum (119),
// s97_conc_three_cell_diff (35) and s94_conc_three_cell_sum (77).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 220;
    *c2 = 80;
    *c3 = 30;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    d: i32 = v1 - v2 - v3; // 110
    free(c1);
    free(c2);
    free(c3);
    return d;
}
