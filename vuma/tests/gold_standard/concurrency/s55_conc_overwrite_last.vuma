// s55_conc_overwrite_last.vuma — overwrite last to 145, sum = 235 (30+60+145)
// Expected exit code: 235
//
// Three independent 8-byte cells. Store 30/60/80 via `*ptr =
// literal`, then overwrite the last cell with 145. Load all three,
// sum -> 235. Uses `*ptr = literal` form. Distinct from
// s54_conc_overwrite_middle (220) and s53_conc_overwrite_last (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 30;
    *c2 = 60;
    *c3 = 80;
    *c3 = 145;
    v1: i32 = *c1;
    v2: i32 = *c2;
    v3: i32 = *c3;
    t: i32 = v1 + v2;
    s: i32 = t + v3;       // 235
    free(c1);
    free(c2);
    free(c3);
    return s;
}
