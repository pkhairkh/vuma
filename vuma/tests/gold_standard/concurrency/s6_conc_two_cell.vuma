// s6_conc_two_cell.vuma — two cells, sum loads = 70 (30 + 40)
// Expected exit code: 70
//
// Two independent 8-byte cells. Each gets a different literal at
// offset 0. Both loaded back and summed. Simulates two independent
// "shared variables" without atomic ops. Distinct from
// s5_conc_three_cells (three cells) and s5_conc_triple_overwrite.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 30;
    *c2 = 40;
    v1: i32 = *c1;
    v2: i32 = *c2;
    s: i32 = v1 + v2;
    free(c1);
    free(c2);
    return s;
}
