// s72_conc_two_cell_diff.vuma — two cells, diff = 155 (250 - 95)
// Expected exit code: 155
//
// Two independent 8-byte cells. Store 250/95 via `*ptr =
// literal`, load both, diff -> 155. Uses `*ptr = literal` form.
// Distinct from s70_conc_two_cell_sum (105), s69_conc_two_cell_
// sum (170) and s66_conc_two_cell_xor (255).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 250;
    *c2 = 95;
    v1: i32 = *c1;
    v2: i32 = *c2;
    d: i32 = v1 - v2;      // 155
    free(c1);
    free(c2);
    return d;
}
