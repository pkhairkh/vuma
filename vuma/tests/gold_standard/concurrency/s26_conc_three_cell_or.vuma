// s26_conc_three_cell_or.vuma — three cells, or = 7 (0x01 | 0x02 | 0x04)
// Expected exit code: 7
//
// Three independent 8-byte cells. Each gets a distinct single-bit literal
// (1/2/4). All three loaded back and ORed. Uses `*ptr = literal` form.
// Distinct from s22_conc_three_cell_dec (descending sum, 150) and
// s18_conc_three_cells_prime (13/17/19 = 49).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 1;
    *c2 = 2;
    *c3 = 4;
    v1: u64 = *c1;
    v2: u64 = *c2;
    v3: u64 = *c3;
    t: u64 = v1 | v2;
    s: u64 = t | v3;      // 7
    free(c1);
    free(c2);
    free(c3);
    return s;
}
