// s102_conc_overwrite_middle.vuma — overwrite c2 to 1, load = 1
// Expected exit code: 1
//
// Three independent 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c2 to 1. Load c2 -> 1 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_conc_overwrite_first (27), s101_conc_three_cell_diff (110), s101_conc_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c2 = 1;
    v: i32 = *c2;          // 1
    free(c1);
    free(c2);
    free(c3);
    return v;
}
