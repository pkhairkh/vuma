// conc_pass_shared.vuma — main allocates, passes to function, function stores
// Expected exit code: 42
//
// Same shape as conc_func_atomic but with the emphasis on the
// "main owns the allocation, helper writes through the shared Address"
// ownership pattern. This mirrors how a real program would set up a
// shared atomic counter: the parent thread allocates the cell, then
// passes its Address to a worker (here, a single function call).
//
// Uses non-atomic `*ptr` per the bridge-gap workaround documented in
// conc_atomic_basic.vuma.

fn fill_cell(cell: Address) -> i32 {
    *cell = 42;
    return 0;
}

fn main() -> i32 {
    shared = allocate(8);
    fill_cell(shared);
    val: i32 = *shared;
    free(shared);
    return val;
}
