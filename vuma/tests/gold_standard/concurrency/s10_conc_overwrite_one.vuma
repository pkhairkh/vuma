// s10_conc_overwrite_one.vuma — overwrite one cell, load = 80
// Expected exit code: 80
//
// Single 8-byte cell. Store 10, then overwrite with 80. Load returns
// 80 (last write wins). Distinct from s5_conc_triple_overwrite (3
// overwrites) and s6_conc_overwrite_then_sum (overwrite then sum with
// another cell).

fn main() -> i32 {
    c = allocate(8);
    *c = 10;
    *c = 80;
    v: i32 = *c;
    free(c);
    return v;
}
