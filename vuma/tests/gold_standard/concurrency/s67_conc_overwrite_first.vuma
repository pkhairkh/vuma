// s67_conc_overwrite_first.vuma — overwrite c1 to 235, load = 235
// Expected exit code: 235
//
// Three independent 8-byte cells. Store 100/50/80 then
// overwrite c1 to 235. Load c1 -> 235 (the overwritten value).
// Uses `*ptr = literal` form. Distinct from s66_conc_overwrite_
// middle (190), s62_conc_overwrite_first (150) and s58_conc_
// overwrite_middle (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 50;
    *c3 = 80;
    *c1 = 235;
    v: i32 = *c1;          // 235
    free(c1);
    free(c2);
    free(c3);
    return v;
}
