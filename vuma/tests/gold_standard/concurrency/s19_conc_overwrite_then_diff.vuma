// s19_conc_overwrite_then_diff.vuma — store 100->30 and 50, diff = 20 (50 - 30)
// Expected exit code: 20
//
// Two 8-byte cells. Store 100 in c1 then overwrite to 30; store 50 in
// c2. Load both, subtract (b - a) -> 20. Uses `*ptr = literal` form.
// Distinct from s18_conc_overwrite_first (overwrite first of three,
// sum) and s14_conc_overwrite_middle (overwrite middle of three).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c1 = 30;
    *c2 = 50;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = b - a;
    free(c1);
    free(c2);
    return s;
}
