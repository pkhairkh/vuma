// s44_ls_overwrite_value.vuma — overwrite node to 155, load = 155
// Expected exit code: 155
//
// Single 8-byte allocation treated as one "node". Store 60 via
// `*ptr = literal`, then overwrite with 155. Load and return 155.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_ls_
// overwrite_value (140) and s38_ls_overwrite_first (170).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 60;
    *n1 = 155;
    v: u64 = *n1;
    free(n1);
    return v;
}
