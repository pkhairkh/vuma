// s14_ls_single_load.vuma — single 8-byte node, load = 27
// Expected exit code: 27
//
// 8-byte allocation treated as a single "node". Store 27 via
// `*p = 27`, load it back, return 27. Uses `*p = literal` form
// (no offsets) to avoid the *(ptr+N) store-drop bug. Distinct from
// s9_ls_node_load (value 15) and s9_ls_overwrite_node (overwrites
// with 50).

fn main() -> i32 {
    node = allocate(8);
    *node = 27;
    v: u64 = *node;
    free(node);
    return v;
}
