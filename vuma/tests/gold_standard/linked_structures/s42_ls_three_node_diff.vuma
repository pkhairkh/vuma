// s42_ls_three_node_diff.vuma — three nodes, diff = 120 (220 - 60 - 40)
// Expected exit code: 120
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 220/60/40 via `*ptr = literal`, load all, subtract -> 120.
// Uses `*ptr = literal` form (no offsets). Distinct from s38_ls_
// three_node_diff (160) and s34_ls_three_node_diff (120, same
// total but different operands 180/40/20).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 220;
    *n2 = 60;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;
    free(n1);
    free(n2);
    free(n3);
    return d;
}
