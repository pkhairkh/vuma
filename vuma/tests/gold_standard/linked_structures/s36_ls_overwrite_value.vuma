// s36_ls_overwrite_value.vuma — store 40, overwrite to 220, load = 220
// Expected exit code: 220
//
// Single 8-byte "node" allocation. Store 40, then
// overwrite the node value with 220 via `*n1 = literal`.
// Load and return 220. Uses `*n1 = literal` form (no
// offsets).
// Distinct from s30_ls_overwrite_value (overwrite, 0) and s27_ls_overwrite_value (different value).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 40;
    *n1 = 220;
    a: u64 = *n1;
    free(n1);
    return a;
}
