// s32_ls_overwrite_middle.vuma - overwrite middle node, sum = 250 (30 + 200 + 20)
// Expected exit code: 250
//
// overwrite middle node, sum = 250 (30 + 200 + 20). All operands loaded into
// typed variables before any bitwise op (immediate-RHS drop workaround where
// applicable); stores use the `*ptr = literal` (or `*ptr = variable + 0`)
// form with no `*(ptr + offset)` indexing. Distinct from
// s30_ls_overwrite_middle (different value) and s26_ls_overwrite_first
// (different position).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 30;
    *n2 = 120;
    *n3 = 20;
    *n2 = 200;             // overwrite middle
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;        // 30 + 200 + 20 = 250
    free(n1);
    free(n2);
    free(n3);
    return s;
}
