// s6_ls_two_blocks_independent.vuma — two independent 2-node blocks, sum = 100
// Expected exit code: 100  (10 + 40 + 20 + 30)
//
// Two 16-byte allocations, each treated as two 8-byte nodes. Block A
// holds 10/40; block B holds 20/30. Load all four, sum -> 100. Distinct
// from s5_ls_five_node_chain (single block).

fn main() -> i32 {
    a = allocate(16);
    b = allocate(16);
    *(a + 0) = 10;
    *(a + 8) = 40;
    *(b + 0) = 20;
    *(b + 8) = 30;
    a0: u64 = *(a + 0);
    a1: u64 = *(a + 8);
    b0: u64 = *(b + 0);
    b1: u64 = *(b + 8);
    s: u64 = a0 + a1 + b0 + b1;
    free(a);
    free(b);
    return s;
}
