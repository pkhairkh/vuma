// s95_ls_three_node_diff.vuma — three nodes, diff = 53 (100 - 30 - 17)
// Expected exit code: 53
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 100/30/17 via `*ptr = literal`, load all three,
// a - b - c -> 53. Uses `*ptr = literal` form (no offsets). Distinct
// from s94_ls_three_node_sum (100), s90_ls_three_node_diff (26) and
// s82_ls_three_node_diff (140).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 100;
    *n2 = 30;
    *n3 = 17;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    d: u64 = a - b - c;    // 53
    free(n1);
    free(n2);
    free(n3);
    return d;
}
