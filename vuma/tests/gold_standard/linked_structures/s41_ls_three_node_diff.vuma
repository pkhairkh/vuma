// s41_ls_three_node_diff.vuma - three nodes, diff = 150 (230 - 60 - 20)
// Expected exit code: 150
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 230/60/20 via `*ptr = literal`, load all, subtract -> 150.
// Uses `*ptr = literal` form (no offsets). Distinct from s34_ls_
// three_node_diff (120) and s30_ls_three_node_diff.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 230;
    *n2 = 60;
    *n3 = 20;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;
    free(n1);
    free(n2);
    free(n3);
    return d;
}
