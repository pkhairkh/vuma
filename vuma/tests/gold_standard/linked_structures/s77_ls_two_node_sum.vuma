// s77_ls_two_node_sum.vuma — two nodes, sum = 163 (130 + 33)
// Expected exit code: 163
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 130/33 via `*ptr = literal`, load both, sum -> 163.
// Uses `*ptr = literal` form (no offsets). Distinct from s70_ls_
// two_node_sum (90), s66_ls_two_node_diff (125) and s74_ls_two_
// node_sum (213).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 130;
    *n2 = 33;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 163
    free(n1);
    free(n2);
    return s;
}
