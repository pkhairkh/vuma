// s40_ls_overwrite_last.vuma — overwrite last to 175, sum = 225 (50 + 175)
// Expected exit code: 225
//
// Two 8-byte allocations treated as two nodes. Store 50/30, then
// overwrite n2 to 175. Load both, sum -> 225. Uses `*ptr = literal`
// form (no offsets). Distinct from s38_ls_overwrite_first (165) and
// s34_ls_overwrite_last (190).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 50;
    *n2 = 30;
    *n2 = 175;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 225
    free(n1);
    free(n2);
    return s;
}
