// s94_ls_two_node_sum.vuma — two nodes, sum = 145 (70 + 75)
// Expected exit code: 145
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 70/75 via `*ptr = literal`, load both, a + b -> 145. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s90_ls_two_node_diff (24), s86_ls_two_node_sum (185) and
// s82_ls_two_node_sum (180).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 70;
    *n2 = 75;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 145
    free(n1);
    free(n2);
    return s;
}
