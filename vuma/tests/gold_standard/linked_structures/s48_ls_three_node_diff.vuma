// s48_ls_three_node_diff.vuma — three nodes, diff = 140 (240 - 60 - 40)
// Expected exit code: 140
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 240/60/40 via `*ptr = literal`, load all, subtract twice
// -> 140. Uses `*ptr = literal` form (no offsets). Distinct from
// s46_ls_three_node_sum (180) and s42_ls_three_node_diff (120).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 240;
    *n2 = 60;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    s: u64 = t - c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
