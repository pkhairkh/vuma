// s85_ls_single_node.vuma — single node, store 144, load = 144
// Expected exit code: 144
//
// Single 8-byte allocation treated as a "node". Store 144 via
// `*ptr = literal`, load it back, return 144. Uses `*ptr =
// literal` form (no offsets). Distinct from s82_ls_single_node,
// s78_ls_single_node and s74_ls_single_node.
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 144;
    r: u64 = *n1;
    free(n1);
    return r;
}
