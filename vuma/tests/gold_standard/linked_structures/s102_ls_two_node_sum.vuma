// s102_ls_two_node_sum.vuma — store 1, 3 in 2 nodes, load and sum = 4
// Expected exit code: 4
//
// Two 8-byte "nodes". Store 1 at n1, store 3 at n2, load each and return the sum (4). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_ls_overwrite_value (41), s101_ls_three_node_sum (150), s101_ls_two_node_sum (205).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 1;
    *n2 = 3;
    a: u64 = *n1;          // 1
    b: u64 = *n2;          // 3
    s: u64 = a + b;        // 4
    free(n1);
    free(n2);
    return s;
}
