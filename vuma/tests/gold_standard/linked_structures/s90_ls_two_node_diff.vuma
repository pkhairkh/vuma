// s90_ls_two_node_diff.vuma — two nodes, diff = 24 (200 - 176)
// Expected exit code: 24
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 200/176 via `*ptr = literal`, load both, a - b -> 24. Uses
// `*ptr = literal` form (no offsets). Distinct from s86_ls_two_
// node_sum (185), s82_ls_two_node_sum (180) and s78_ls_two_node_
// sum (2).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 176;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 24
    free(n1);
    free(n2);
    return d;
}
