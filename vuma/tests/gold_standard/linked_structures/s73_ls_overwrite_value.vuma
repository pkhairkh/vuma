// s73_ls_overwrite_value.vuma — store 50 then overwrite to 137
// Expected exit code: 137
//
// One 8-byte allocation treated as a single "node". Store 50
// then overwrite to 137 via `*ptr = literal`, load -> 137.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s70_ls_overwrite_value (210), s69_ls_overwrite_value (105)
// and s66_ls_overwrite_value (230).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 137;
    v: u64 = *n1;          // 137
    free(n1);
    return v;
}
