// s97_ls_three_node_sum.vuma — three nodes, sum = 22 (6 + 8 + 8)
// Expected exit code: 22
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 6/8/8 via `*ptr = literal`, load all,
// a + b + c -> 22. Uses `*ptr = literal` form.
// Distinct from s94_ls_three_node_sum (100), s90_ls_overwrite_value (32), s86_ls_overwrite_value (225).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 6;
    *n2 = 8;
    *n3 = 8;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;    // 22
    free(n1);
    free(n2);
    free(n3);
    return s;
}
