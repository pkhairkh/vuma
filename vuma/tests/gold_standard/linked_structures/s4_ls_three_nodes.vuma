// s4_ls_three_nodes.vuma — three 8-byte nodes, sum values = 90
// Expected exit code: 90  (10 + 20 + 60)
//
// 24-byte allocation treated as three 8-byte nodes at offsets
// 0, 8, 16. Stores 10/20/60, loads all three, sums, returns 90.

fn main() -> i32 {
    block = allocate(24);
    *(block + 0) = 10;
    *(block + 8) = 20;
    *(block + 16) = 60;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    s: u64 = a + b + c;
    free(block);
    return s;
}
