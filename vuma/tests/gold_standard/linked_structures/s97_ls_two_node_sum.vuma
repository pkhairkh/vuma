// s97_ls_two_node_sum.vuma — two nodes, sum = 14 (8 + 6)
// Expected exit code: 14
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 8/6 via `*ptr = literal`, load both, a + b -> 14.
// Uses `*ptr = literal` form (no offsets).
// Distinct from s94_ls_two_node_sum (145), s90_ls_overwrite_value (32), s86_ls_two_node_sum (185).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 8;
    *n2 = 6;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 14
    free(n1);
    free(n2);
    return s;
}
