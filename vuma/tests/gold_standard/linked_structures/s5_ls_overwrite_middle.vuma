// s5_ls_overwrite_middle.vuma — three nodes, overwrite middle, sum = 130
// Expected exit code: 130  (20 + 88 + 22)
//
// 24-byte allocation, three 8-byte nodes. Store 20/30/22 at
// offsets 0/8/16, then overwrite offset 8 (middle node) with 88.
// Sum = 20 + 88 + 22 = 130. Distinct from s4_ls_overwrite_node
// (overwrites first node).

fn main() -> i32 {
    block = allocate(24);
    *(block + 0) = 20;
    *(block + 8) = 30;
    *(block + 16) = 22;
    *(block + 8) = 88;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    s: u64 = a + b + c;
    free(block);
    return s;
}
