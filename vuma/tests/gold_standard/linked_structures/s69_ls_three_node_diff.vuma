// s69_ls_three_node_diff.vuma -- three nodes, diff = 185 (220 - 25 - 10)
// Expected exit code: 185
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 220/25/10 via `*ptr = literal`, load all, diff -> 220 - 25 -
// 10 = 185. Uses `*ptr = literal` form (no offsets). Distinct from
// s66_ls_three_node_sum (190), s65_ls_three_node_sum (160) and s64_
// ls_three_node_diff (200).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 220;
    *n2 = 25;
    *n3 = 10;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 195
    r: u64 = t - c;        // 185
    free(n1);
    free(n2);
    free(n3);
    return r;
}
