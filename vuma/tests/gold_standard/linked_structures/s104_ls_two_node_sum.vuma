// s104_ls_two_node_sum.vuma — store 15, 21 in 2 nodes, load and sum = 36
// Expected exit code: 36
//
// Two 8-byte "nodes". Store 15 at n1, store 21 at n2, load each and return the sum (36). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_overwrite_value (1), s102_ls_three_node_sum (5), s102_ls_two_node_sum (4).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 15;
    *n2 = 21;
    a: u64 = *n1;          // 15
    b: u64 = *n2;          // 21
    s: u64 = a + b;        // 36
    free(n1);
    free(n2);
    return s;
}
