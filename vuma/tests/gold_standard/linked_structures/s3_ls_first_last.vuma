// s3_ls_first_last.vuma — head stores offset to tail, tail stores value
// Expected exit code: 55
//
// Linked structure where the head node (offset 0) stores a pointer-
// offset to the tail node (offset 16), and the tail stores a value.
// main reads the offset from the head, dereferences the tail, and
// returns the tail's value (55). All stored offsets/values <= 255.

fn main() -> i32 {
    block = allocate(24);
    // head.next_offset = 16
    *(block + 0) = 16;
    // head.val = 0 (unused placeholder)
    *(block + 8) = 0;
    // tail.val = 55
    *(block + 16) = 55;

    off: u64 = *(block + 0);
    tail_val: u64 = *(block + off);

    free(block);
    return tail_val;
}
