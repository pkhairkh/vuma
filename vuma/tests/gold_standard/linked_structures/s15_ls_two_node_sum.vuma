// s15_ls_two_node_sum.vuma — two nodes, sum = 42 (14 + 28)
// Expected exit code: 42
//
// Two 8-byte allocations treated as two independent "nodes". Store 14/28
// via `*ptr = literal`, load both, sum -> 42. Uses `*ptr = literal` form
// (no offsets). Distinct from s14_ls_three_node_sum (three nodes, 11+22+33
// = 66) and s13_ls_two_node_sum (two nodes, different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 14;
    *n2 = 28;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
