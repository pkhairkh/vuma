// s81_ls_three_node_diff.vuma — three nodes, diff = 160 (235 - 65 - 10)
// Expected exit code: 160
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 235/65/10 via `*ptr = literal`, load all three,
// a - b - c -> 160. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ls_three_node_diff (147),
// s77_ls_three_node_diff (132) and s76_ls_three_node_diff (35).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 235;
    *n2 = 65;
    *n3 = 10;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 160
    free(n1);
    free(n2);
    free(n3);
    return r;
}
