// s54_ls_three_node_diff.vuma — three nodes, diff = 100 (240-90-50)
// Expected exit code: 100
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 240/90/50 via `*ptr = literal`, load all three, subtract
// sequentially -> 100. Uses `*ptr = literal` form (no offsets).
// Distinct from s50_ls_three_node_diff (120) and s49_ls_three_
// node_diff (110).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 240;
    *n2 = 90;
    *n3 = 50;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    s: u64 = t - c;        // 100
    free(n1);
    free(n2);
    free(n3);
    return s;
}
