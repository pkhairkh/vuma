// s99_ls_overwrite_value.vuma — overwrite n1 to 128, load = 128
// Expected exit code: 128
//
// Single 8-byte allocation treated as a "node". Store 5 via
// `*ptr = literal`, then overwrite to 128, load -> 128 (the
// overwritten value). Uses `*ptr = literal` form. Distinct from
// s95_ls_overwrite_value (48), s91_ls_overwrite_value (33) and
// s87_ls_overwrite_value (215).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 128;
    v: u64 = *n1;          // 128
    free(n1);
    return v;
}
