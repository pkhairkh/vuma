// s53_ls_two_node_diff.vuma — two nodes, diff = 145 (210 - 65)
// Expected exit code: 145
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 210/65 via `*ptr = literal`, load both, diff -> 145. Uses
// `*ptr = literal` form (no offsets). Distinct from s49_ls_three_
// node_diff (110) and s50_ls_three_node_diff (130).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 210;
    *n2 = 65;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 145
    free(n1);
    free(n2);
    return d;
}
