// s78_ls_two_node_sum.vuma — two nodes, sum = 2 (1 + 1)
// Expected exit code: 2
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 1/1 via `*ptr = literal`, load both, sum -> 2.
// Uses `*ptr = literal` form (no offsets). Distinct from s74_ls_
// two_node_sum (90), s73_ls_two_node_sum (114) and s72_ls_two_node_
// sum (175).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 1;
    *n2 = 1;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 2
    free(n1);
    free(n2);
    return s;
}
