// s68_ls_three_node_diff.vuma — three nodes, diff = 65 (210 - 90 - 55)
// Expected exit code: 65
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 210/90/55 via `*ptr = literal`, load all three, diff ->
// 210 - 90 - 55 = 65. Uses `*ptr = literal` form. Distinct from
// s66_ls_three_node_sum (190), s62_ls_three_node_diff (120) and
// s58_ls_three_node_diff (120).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 210;
    *n2 = 90;
    *n3 = 55;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 120
    r: u64 = t - c;        // 65
    free(n1);
    free(n2);
    free(n3);
    return r;
}
