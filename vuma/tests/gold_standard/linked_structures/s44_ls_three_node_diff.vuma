// s44_ls_three_node_diff.vuma — three nodes, diff = 130 (200 - 45 - 25)
// Expected exit code: 130
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 200/45/25 via `*ptr = literal`, load all, subtract -> 130.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_ls_
// three_node_diff (120, operands 220/60/40) and s38_ls_three_node_
// diff (160).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 45;
    *n3 = 25;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;        // 130
    free(n1);
    free(n2);
    free(n3);
    return d;
}
