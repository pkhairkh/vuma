// s24_ls_overwrite_first.vuma — overwrite first node, sum = 116 (80 + 36)
// Expected exit code: 116
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 18/36 via `*ptr = literal`, then overwrite the first node with 80.
// Load both, sum -> 116. Uses `*ptr = literal` form (no offsets).
// Distinct from s22_ls_overwrite_last (overwrites the last node,
// 22/45 -> 22/73 = 95) and s18_ls_overwrite_first (overwrites the first
// node, different values).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 18;
    *n2 = 36;
    *n1 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
