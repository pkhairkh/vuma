// s90_ls_overwrite_value.vuma — overwrite n1 to 32, load = 32
// Expected exit code: 32
//
// Single 8-byte "node". Store 5, then overwrite to 32, load -> 32
// (the overwritten value). Uses `*ptr = literal` form. Distinct
// from s86_ls_overwrite_value (245), s82_ls_overwrite_value (242)
// and s78_ls_overwrite_value (3).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 32;
    v: u64 = *n1;          // 32
    free(n1);
    return v;
}
