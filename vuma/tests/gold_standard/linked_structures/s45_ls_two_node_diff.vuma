// s45_ls_two_node_diff.vuma — two nodes, diff = 160 (200 - 40)
// Expected exit code: 160
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 200/40 via `*ptr = literal`, load both, subtract -> 160.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_ls_
// two_node_sum (sum, 200) and s38_ls_two_node_diff (diff, 120).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;
    free(n1);
    free(n2);
    return d;
}
