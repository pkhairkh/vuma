// s29_ls_two_node_diff.vuma — two nodes, diff = 60 (100 - 40)
// Expected exit code: 60
//
// Two 8-byte allocations treated as two independent "nodes". Store 100/40 via `*ptr = literal`, load both, subtract -> 60. Uses `*ptr = literal` form (no offsets). All operands loaded into typed locals before the SUB. Distinct from s26_ls_two_node_xor (xor, 240^15=255) and s22_ls_two_node_sum (37+53=90).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 100;
    *n2 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a - b;       // 60
    free(n1);
    free(n2);
    return s;
}
