// s17_ls_overwrite_then_load.vuma — store 15 then 95, load = 95
// Expected exit code: 95
//
// Single 8-byte "node". Store literal 15, then overwrite with literal
// 95 (last write wins). Load and return 95. Uses `*p = literal` form.
// Distinct from s14_ls_overwrite_first (17 then 73) and
// s9_ls_overwrite_node (different values).

fn main() -> i32 {
    n = allocate(8);
    *n = 15;
    *n = 95;
    v: u64 = *n;
    free(n);
    return v;
}
