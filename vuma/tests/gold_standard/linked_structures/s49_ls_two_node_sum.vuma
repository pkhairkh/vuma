// s49_ls_two_node_sum.vuma — two nodes, sum = 200 (95 + 105)
// Expected exit code: 200
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 95/105 via `*ptr = literal`, load both, sum -> 200. Uses
// `*ptr = literal` form (no offsets). Distinct from s46_ls_three_
// node_sum (180, three nodes) and s42_ls_two_node_sum (200, sum
// with different operands).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 95;
    *n2 = 105;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
