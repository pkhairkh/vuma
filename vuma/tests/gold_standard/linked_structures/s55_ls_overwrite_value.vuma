// s55_ls_overwrite_value.vuma — store 65, overwrite to 220, load = 220
// Expected exit code: 220
//
// Single 8-byte allocation treated as a one-field "node". Store 65
// via `*p = literal`, then overwrite the field with 220. Load and
// return 220. Uses `*p = literal` form (no offsets). Distinct from
// s50_ls_overwrite_value (190) and s53_ls_overwrite_value (195).

fn main() -> i32 {
    n = allocate(8);
    *n = 65;
    *n = 220;
    a: u64 = *n;
    free(n);
    return a;
}
