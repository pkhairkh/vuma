// s7_ls_two_blocks_sum.vuma — two 16-byte blocks, sum = 50 + 60 = 110
// Expected exit code: 110
//
// Two independent 16-byte allocations. Each block holds one 8-byte
// value at offset 0 (block1 = 50, block2 = 60). Load both, sum ->
// 110. Simulates two independent "linked list heads" each carrying
// a payload. Distinct from s6_ls_two_blocks_independent (two blocks
// but different values 20/40) and s5_ls_five_node_chain (one big
// block).

fn main() -> i32 {
    b1 = allocate(16);
    b2 = allocate(16);
    *b1 = 50;
    *b2 = 60;
    v1: u64 = *b1;
    v2: u64 = *b2;
    s: u64 = v1 + v2;
    free(b1);
    free(b2);
    return s;
}
