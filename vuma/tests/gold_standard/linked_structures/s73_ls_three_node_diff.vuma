// s73_ls_three_node_diff.vuma — three nodes, diff = 131 (200 - 47 - 22)
// Expected exit code: 131
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 200/47/22 via `*ptr = literal`, load all
// three, diff -> 200 - 47 - 22 = 131. Uses `*ptr = literal`
// form (no offsets). Distinct from s70_ls_three_node_diff
// (150), s69_ls_three_node_diff (185) and s66_ls_three_node_
// sum (190).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 47;
    *n3 = 22;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 153
    d: u64 = t - c;        // 131
    free(n1);
    free(n2);
    free(n3);
    return d;
}
