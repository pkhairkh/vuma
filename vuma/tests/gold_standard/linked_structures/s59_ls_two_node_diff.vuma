// s59_ls_two_node_diff.vuma — two nodes, diff = 150 (240 - 90)
// Expected exit code: 150
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 240/90 via `*ptr = literal`, load both, subtract -> 150. Uses
// `*ptr = literal` form (no offsets). Distinct from s58_ls_two_node_
// sum (220), s58_ls_three_node_diff (100) and s58_ls_overwrite_value
// (180).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 240;
    *n2 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 150
    free(n1);
    free(n2);
    return d;
}
