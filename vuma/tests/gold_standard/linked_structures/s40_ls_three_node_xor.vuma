// s40_ls_three_node_xor.vuma — three nodes, xor = 112 (100 ^ 60 ^ 40)
// Expected exit code: 112
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 100/60/40 via `*ptr = literal`, load all, XOR -> 112.
// 100 ^ 60 = 88 (0x58); 88 ^ 40 = 112 (0x70). Uses `*ptr = literal`
// form (no offsets). Distinct from s38_ls_three_node_diff (160) and
// s34_ls_three_node_diff (120).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 100;
    *n2 = 60;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a ^ b;        // 0x58 = 88
    r: u64 = t ^ c;        // 0x70 = 112
    free(n1);
    free(n2);
    free(n3);
    return r;
}
