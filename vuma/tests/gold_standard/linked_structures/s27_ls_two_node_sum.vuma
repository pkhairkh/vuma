// s27_ls_two_node_sum.vuma — two nodes, sum = 135 (65 + 70)
// Expected exit code: 135
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 65/70 via `*ptr = literal`, load both, sum -> 135. Uses `*ptr =
// literal` form (no offsets). Distinct from s26_ls_two_node_xor (xor,
// 240^15=255) and s22_ls_two_node_sum (37+53=90).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 65;
    *n2 = 70;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;       // 135
    free(n1);
    free(n2);
    return s;
}
