// s47_ls_overwrite_first.vuma — overwrite node to 145, load = 145
// Expected exit code: 145
//
// Single 8-byte allocation treated as one "node". Store 25 via
// `*ptr = literal`, then overwrite with 145. Load and return 145.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_ls_
// overwrite_value (160) and s42_ls_overwrite_value (140).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 25;
    *n1 = 145;
    v: u64 = *n1;
    free(n1);
    return v;
}
