// s85_ls_overwrite_value.vuma — store 19, overwrite with 207, load = 207
// Expected exit code: 207
//
// Single 8-byte allocation treated as a "node". Store 19 via
// `*ptr = literal`, overwrite with 207 via `*ptr = literal`,
// load and return 207. Uses `*ptr = literal` form (no
// offsets). Distinct from s82_ls_overwrite_value (215),
// s78_ls_overwrite_value (3) and s74_ls_overwrite_value (85).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 19;
    *n1 = 207;
    r: u64 = *n1;
    free(n1);
    return r;
}
