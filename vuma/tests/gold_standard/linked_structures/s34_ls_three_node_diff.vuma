// s34_ls_three_node_diff.vuma — three nodes, diff = 120 (200 - 50 - 30)
// Expected exit code: 120
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 200/50/30 via `*ptr = literal`, load all, subtract -> 120.
// Uses `*ptr = literal` form (no offsets). Distinct from s30_ls_
// three_node_diff (different values) and s27_ls_three_node_diff.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 50;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    d: u64 = t - c;
    free(n1);
    free(n2);
    free(n3);
    return d;
}
