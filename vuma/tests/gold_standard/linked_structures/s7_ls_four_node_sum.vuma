// s7_ls_four_node_sum.vuma — four 8-byte nodes, sum = 5+15+25+35 = 80
// Expected exit code: 80
//
// 32-byte allocation treated as four 8-byte "nodes" at offsets
// 0, 8, 16, 24. Stores 5/15/25/35, loads all four, sums, returns 80.
// Uses pointer-arithmetic aliases (n0 = block, n1 = block + 8, ...)
// so all stores/loads go through `*pN`. Distinct from
// s5_ls_four_node_chain (values 10/20/30/40 -> 100) and
// s6_ls_three_node_chain (3 nodes).

fn main() -> i32 {
    block = allocate(32);
    n0 = block;
    n1 = block + 8;
    n2 = block + 16;
    n3 = block + 24;
    *n0 = 5;
    *n1 = 15;
    *n2 = 25;
    *n3 = 35;
    a: u64 = *n0;
    b: u64 = *n1;
    c: u64 = *n2;
    d: u64 = *n3;
    t1: u64 = a + b;
    t2: u64 = c + d;
    s: u64 = t1 + t2;
    free(block);
    return s;
}
