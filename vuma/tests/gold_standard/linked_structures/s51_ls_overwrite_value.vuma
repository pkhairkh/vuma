// s51_ls_overwrite_value.vuma — store 50, overwrite to 195, load = 195
// Expected exit code: 195
//
// Single 8-byte allocation treated as one "node". Store 50 via
// `*ptr = literal`, then overwrite with 195. Load and return 195.
// Uses `*ptr = literal` form (no offsets). Distinct from s50_ls_
// overwrite_value (185) and s47_ls_overwrite_first (145).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 195;
    a: u64 = *n1;
    free(n1);
    return a;
}
