// s65_ls_overwrite_value.vuma — overwrite to 165, load = 165
// Expected exit code: 165
//
// Single 8-byte allocation treated as one "node". Store 60 via
// `*p = literal`, overwrite with 165, load and return 165. Uses
// `*p = literal` form (no offsets). Distinct from s51_ls_overwrite_
// value (195), s58_ls_overwrite_value (180) and s62_ls_overwrite_
// value (175).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 60;
    *n1 = 165;
    a: u64 = *n1;
    free(n1);
    return a;
}
