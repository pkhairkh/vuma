// s66_ls_overwrite_value.vuma — overwrite node to 230, load = 230
// Expected exit code: 230
//
// Single 8-byte allocation treated as one "node". Store 50 then
// 230 via `*ptr = literal` (overwrite), load and return 230. Uses
// `*ptr = literal` form. Distinct from s62_ls_overwrite_value
// (175), s58_ls_overwrite_value (180) and s55_ls_overwrite_value
// (220).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 230;
    v: u64 = *n1;          // 230
    free(n1);
    return v;
}
