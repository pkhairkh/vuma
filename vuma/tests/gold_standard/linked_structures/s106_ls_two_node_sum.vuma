// s106_ls_two_node_sum.vuma — store 5, 7 in 2 nodes, load and sum = 12
// Expected exit code: 12
//
// Two 8-byte "nodes". Store 5 at n1, store 7 at n2, load each and return the sum (12). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_two_node_sum (4), s101_ls_two_node_sum (205), s100_ls_two_node_diff (16).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 5;
    *n2 = 7;
    a: u64 = *n1;          // 5
    b: u64 = *n2;          // 7
    s: u64 = a + b;        // 12
    free(n1);
    free(n2);
    return s;
}
