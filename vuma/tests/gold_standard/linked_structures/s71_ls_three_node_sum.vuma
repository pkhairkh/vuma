// s71_ls_three_node_sum.vuma — three nodes, sum = 170 (45 + 50 + 75)
// Expected exit code: 170
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 45/50/75 via `*ptr = literal`, load all three, sum ->
// 170. Uses `*ptr = literal` form (no offsets). Distinct from
// s69_ls_three_node_diff (185), s70_ls_three_node_diff (150) and
// s66_ls_three_node_sum (190).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 45;
    *n2 = 50;
    *n3 = 75;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;        // 95
    s: u64 = t + c;        // 170
    free(n1);
    free(n2);
    free(n3);
    return s;
}
