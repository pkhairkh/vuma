// s37_ls_three_node_sum.vuma — three nodes, sum = 65 + 90 + 100 = 255
// Expected exit code: 255
//
// Deterministic test in the linked_structures category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_ls_three_node_diff (diff, 120) and s30_ls_three_node_diff (different values).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 65;
    *n2 = 90;
    *n3 = 100;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;     // 255
    free(n1);
    free(n2);
    free(n3);
    return s;
}
