// s66_ls_three_node_sum.vuma — three nodes, sum = 190 (60 + 90 + 40)
// Expected exit code: 190
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 60/90/40 via `*ptr = literal`, load all three,
// sum -> 190. Uses `*ptr = literal` form (no offsets). Distinct
// from s62_ls_three_node_diff (120), s58_ls_two_node_sum (220)
// and s55_ls_three_node_diff (115).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 60;
    *n2 = 90;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;        // 150
    s: u64 = t + c;        // 190
    free(n1);
    free(n2);
    free(n3);
    return s;
}
