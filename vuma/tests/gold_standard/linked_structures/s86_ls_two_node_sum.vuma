// s86_ls_two_node_sum.vuma — two nodes, sum = 185 (105 + 80)
// Expected exit code: 185
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 105/80 via `*ptr = literal`, load both, sum -> 185.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s82_ls_two_node_sum (180), s78_ls_two_node_sum (2) and
// s74_ls_two_node_sum (130).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 105;
    *n2 = 80;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 185
    free(n1);
    free(n2);
    return s;
}
