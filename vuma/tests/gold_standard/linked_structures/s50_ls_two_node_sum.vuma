// s50_ls_two_node_sum.vuma — two nodes, sum = 255 (125 + 130)
// Expected exit code: 255
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 125/130 via `*ptr = literal`, load both, sum -> 255. Uses
// `*ptr = literal` form (no offsets). Distinct from s46_ls_two_
// node_diff (120) and s43_ls_two_node_sum (215).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 125;
    *n2 = 130;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 255
    free(n1);
    free(n2);
    return s;
}
