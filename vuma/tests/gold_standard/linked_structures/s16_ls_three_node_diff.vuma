// s16_ls_three_node_diff.vuma — three nodes, 25/50/75, (c-b)+a = 50
// Expected exit code: 50
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 25/50/75 via `*ptr = literal`, load all three, compute (c - b) + a
// -> (75 - 50) + 25 = 50. Uses `*ptr = literal` form (no offsets).
// Distinct from s12_ls_two_node_diff (two-node diff) and
// s14_ls_three_node_sum (sum, not diff).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 25;
    *n2 = 50;
    *n3 = 75;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    d: u64 = c - b;       // 75 - 50 = 25
    s: u64 = d + a;       // 25 + 25 = 50
    free(n1);
    free(n2);
    free(n3);
    return s;
}
