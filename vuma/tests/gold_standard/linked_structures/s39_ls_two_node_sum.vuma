// s39_ls_two_node_sum.vuma — two nodes, sum = 195 (100 + 95)
// Expected exit code: 195
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 100/95 via `*ptr = literal`, load both, sum -> 195. Uses
// `*ptr = literal` form (no offsets). Distinct from s38_ls_two_
// node_sum (175) and s34_ls_two_node_sum (125).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 100;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
