// s3_ls_multi_field_read.vuma — read three fields of a node, sum them
// Expected exit code: 90  (10 + 20 + 60)
//
// Single 24-byte allocation treated as a 3-field node (a, b, c), each
// 8 bytes. main loads all three fields and returns their sum.

fn main() -> i32 {
    node = allocate(24);
    *(node + 0) = 10;
    *(node + 8) = 20;
    *(node + 16) = 60;

    a: u64 = *(node + 0);
    b: u64 = *(node + 8);
    c: u64 = *(node + 16);
    s1: u64 = a + b;
    s2: u64 = s1 + c;

    free(node);
    return s2;
}
