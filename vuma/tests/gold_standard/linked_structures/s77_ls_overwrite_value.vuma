// s77_ls_overwrite_value.vuma — overwrite node to 162, load = 162
// Expected exit code: 162
//
// Single 8-byte allocation treated as one "node". Store 100 then
// 162 via `*ptr = literal` (overwrite), load and return 162.
// Uses `*ptr = literal` form (no offsets). Distinct from s70_ls_
// overwrite_value (210), s66_ls_overwrite_value (220) and s74_ls_
// overwrite_value (149).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 100;
    *n1 = 162;
    a: u64 = *n1;          // 162
    free(n1);
    return a;
}
