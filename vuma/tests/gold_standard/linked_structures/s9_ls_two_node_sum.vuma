// s9_ls_two_node_sum.vuma — two independent nodes, sum = 40 (15 + 25)
// Expected exit code: 40
//
// Two 8-byte allocations, each treated as a single "node". Store
// 15/25 via `*p = literal`, load both, sum -> 40. Uses `*p =
// literal` form (no offsets). Distinct from s4_ls_two_nodes (uses
// *(block+N) form, values 10/20 = 30) and s6_ls_two_blocks_independent
// (two 2-node blocks via offsets).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 15;
    *n2 = 25;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
