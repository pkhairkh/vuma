// s7_ls_overwrite_last.vuma — overwrite last node, sum = 10+20+90 = 120
// Expected exit code: 120
//
// 24-byte allocation treated as three 8-byte "nodes" at offsets
// 0/8/16. Stores 10/20/30, then overwrites node 2 (offset 16) with
// 90. Load all three, sum -> 10 + 20 + 90 = 120. Uses
// pointer-arithmetic aliases. Distinct from s5_ls_overwrite_middle
// (overwrites middle node, not last) and s6_ls_overwrite_first
// (overwrites first node).

fn main() -> i32 {
    block = allocate(24);
    n0 = block;
    n1 = block + 8;
    n2 = block + 16;
    *n0 = 10;
    *n1 = 20;
    *n2 = 30;
    *n2 = 90;
    a: u64 = *n0;
    b: u64 = *n1;
    c: u64 = *n2;
    t1: u64 = a + b;
    s: u64 = t1 + c;
    free(block);
    return s;
}
