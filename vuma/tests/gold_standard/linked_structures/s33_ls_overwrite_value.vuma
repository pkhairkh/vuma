// s33_ls_overwrite_value.vuma — overwrite node value, load = 190
// Expected exit code: 190
//
// Deterministic test in the linked_structures category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_ls_overwrite_middle (overwrites middle) and s26_ls_overwrite_first (overwrites first).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 80;
    *n1 = 190;
    a: u64 = *n1;            // 190
    free(n1);
    return a;
}
