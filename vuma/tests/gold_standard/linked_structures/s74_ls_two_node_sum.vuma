// s74_ls_two_node_sum.vuma — two nodes, sum = 213 (100 + 113)
// Expected exit code: 213
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 100/113 via `*ptr = literal`, load both, sum -> 213.
// Uses `*ptr = literal` form (no offsets). Distinct from s70_ls_
// two_node_sum (90), s66_ls_two_node_diff (125) and s62_ls_two_
// node_sum (225).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 100;
    *n2 = 113;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 213
    free(n1);
    free(n2);
    return s;
}
