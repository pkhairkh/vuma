// s102_ls_three_node_sum.vuma — store 1+1+3 in 3 nodes, load and sum = 5
// Expected exit code: 5
//
// Three 8-byte "nodes". Store 1, 1, 3; load each and return the sum (5). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_ls_overwrite_value (41), s101_ls_three_node_sum (150), s101_ls_two_node_sum (205).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 1;
    *n2 = 1;
    *n3 = 3;
    a: u64 = *n1;          // 1
    b: u64 = *n2;          // 1
    c: u64 = *n3;          // 3
    s: u64 = a + b + c;    // 5
    free(n1);
    free(n2);
    free(n3);
    return s;
}
