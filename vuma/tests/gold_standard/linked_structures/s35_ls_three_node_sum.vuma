// s35_ls_three_node_sum.vuma — three nodes, sum = 165 (45 + 55 + 65)
// Expected exit code: 165
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 45/55/65 via `*ptr = literal`, load all, sum -> 165. Uses
// `*ptr = literal` form (no offsets). Distinct from s34_ls_three_
// node_diff (diff, 120) and s30_ls_three_node_diff (different op).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 45;
    *n2 = 55;
    *n3 = 65;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;        // 165
    free(n1);
    free(n2);
    free(n3);
    return s;
}
