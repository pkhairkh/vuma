// s46_ls_three_node_sum.vuma — three nodes, sum = 180 (50 + 60 + 70)
// Expected exit code: 180
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 50/60/70 via `*ptr = literal`, load all, sum -> 180. Uses
// `*ptr = literal` form (no offsets). Distinct from s42_ls_three_
// node_diff (120) and s38_ls_three_node_diff (160).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 50;
    *n2 = 60;
    *n3 = 70;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
