// s26_ls_three_node_sum.vuma — three nodes, sum = 120 (30 + 40 + 50)
// Expected exit code: 120
//
// Three 8-byte allocations treated as three independent "nodes". Store
// 30/40/50 via `*ptr = literal`, load all three, sum -> 120. Uses
// `*ptr = literal` form (no offsets). Distinct from s22_ls_two_node_sum
// (two-node sum, 90) and s14_ls_three_node_sum (11/22/33 = 66).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 30;
    *n2 = 40;
    *n3 = 50;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
