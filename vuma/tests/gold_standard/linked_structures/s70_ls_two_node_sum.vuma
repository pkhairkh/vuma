// s70_ls_two_node_sum.vuma — two nodes, sum = 90 (50 + 40)
// Expected exit code: 90
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 50/40 via `*ptr = literal`, load both, sum -> 90.
// Uses `*ptr = literal` form (no offsets). Distinct from s66_ls_
// two_node_diff (125), s65_ls_two_node_diff (140) and s62_ls_
// two_node_sum (225).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 50;
    *n2 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 90
    free(n1);
    free(n2);
    return s;
}
