// s92_ls_overwrite_value.vuma — overwrite n1 to 64, load = 64
// Expected exit code: 64
//
// Single 8-byte "node". Store 5, then overwrite to 64, load -> 64
// (the overwritten value). Uses `*ptr = literal` form. Distinct
// from s90_ls_overwrite_value (32), s86_ls_overwrite_value (245)
// and s82_ls_overwrite_value (242).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 64;
    v: u64 = *n1;          // 64
    free(n1);
    return v;
}
