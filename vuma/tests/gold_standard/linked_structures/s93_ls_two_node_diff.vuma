// s93_ls_two_node_diff.vuma — two nodes, diff = 19 (200 - 181)
// Expected exit code: 19
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 200/181 via `*ptr = literal`, load both, a - b -> 19. Uses
// `*ptr = literal` form (no offsets). Distinct from s90_ls_two_node_diff (24), s82_ls_two_node_sum (180)
// and s78_ls_two_node_sum (2).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 181;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 19
    free(n1);
    free(n2);
    return d;
}
