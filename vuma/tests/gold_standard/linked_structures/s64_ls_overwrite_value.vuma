// s64_ls_overwrite_value.vuma — store 55, overwrite to 195, load = 195
// Expected exit code: 195
//
// Single 8-byte allocation treated as one "node". Store 55 via
// `*ptr = literal`, then overwrite with 195. Load and return 195.
// Uses `*ptr = literal` form (no offsets). Distinct from s62_ls_
// overwrite_value (175), s62_ls_three_node_diff (120) and s62_ls_two_
// node_sum (225).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 55;
    *n1 = 195;
    a: u64 = *n1;
    free(n1);
    return a;
}
