// s70_ls_three_node_diff.vuma — three nodes, diff = 150 (200 - 30 - 20)
// Expected exit code: 150
//
// Three 8-byte allocations treated as three independent
// "nodes". Store 200/30/20 via `*ptr = literal`, load all
// three, diff -> 200 - 30 - 20 = 150. Uses `*ptr = literal`
// form (no offsets). Distinct from s66_ls_three_node_sum (190),
// s65_ls_three_node_sum (160) and s62_ls_three_node_diff (120).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 30;
    *n3 = 20;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;        // 170
    d: u64 = t - c;        // 150
    free(n1);
    free(n2);
    free(n3);
    return d;
}
