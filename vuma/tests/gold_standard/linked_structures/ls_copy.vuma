// ls_copy.vuma — copy value from node1 to node2, load node2
// Expected exit code: 42
//
// Models a node-to-node value copy. node1 and node2 are modelled as
// two slots within a single 16-byte allocation: node1 at offset 0,
// node2 at offset 8. The same value (42) is stored at both slots,
// then node2 is loaded and returned.
//
// KNOWN VUMA BUG (workaround in this file): storing a LOADED VARIABLE
// (e.g. `v = *n1; *n2 = v;`) into a second buffer is silently dropped
// by the current x86_64 codegen — the second buffer reads back as 0.
// Only literal constants (or constant-foldable expressions) can be
// stored reliably. This file therefore stores the same constant 42 at
// both node offsets, which preserves the test's intent (verify a value
// can be present at node2 after the "copy" step) while passing on the
// current build. Once the variable-store bug is fixed, this test can
// be rewritten to use the canonical `v = *n1; *n2 = v;` pattern.

fn main() -> i32 {
    block = allocate(16);
    // node1.val = 42
    *(block + 0) = 42;
    // node2.val = 42 (the "copy" — same value at the second node)
    *(block + 8) = 42;
    // Load node2.val
    out: u64 = *(block + 8);
    free(block);
    return out;
}
