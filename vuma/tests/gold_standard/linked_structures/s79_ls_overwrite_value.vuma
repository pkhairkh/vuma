// s79_ls_overwrite_value.vuma — store 1, overwrite with 25, load = 25
// Expected exit code: 25
//
// Single 8-byte allocation treated as a "node". Store 1 via
// `*ptr = literal`, overwrite with 25 via `*ptr = literal`,
// load and return 25. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ls_overwrite_value (3),
// s77_ls_overwrite_value (2) and s76_ls_overwrite_value (3).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 1;
    *n1 = 25;
    r: u64 = *n1;          // 25
    free(n1);
    return r;
}
