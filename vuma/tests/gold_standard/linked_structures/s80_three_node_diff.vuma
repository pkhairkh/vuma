// s80_ls_three_node_diff.vuma — three nodes, diff = 30 (32 - 1 - 1)
// Expected exit code: 30
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 32/1/1 via `*ptr = literal`, load all three,
// a - b - c -> 30. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ls_three_node_diff (147),
// s74_ls_three_node_diff (40) and s73_ls_three_node_diff (60).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 32;
    *n2 = 1;
    *n3 = 1;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 30
    free(n1);
    free(n2);
    free(n3);
    return r;
}
