// s4_ls_two_nodes.vuma — two 8-byte nodes, sum values = 110
// Expected exit code: 110  (40 + 70)
//
// 16-byte allocation treated as two 8-byte "nodes": node1.val = 40
// (offset 0), node2.val = 70 (offset 8). Load both, sum, return 110.
// Verifies that two adjacent nodes in the same allocation can be
// read independently.

fn main() -> i32 {
    block = allocate(16);
    *(block + 0) = 40;
    *(block + 8) = 70;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    s: u64 = a + b;
    free(block);
    return s;
}
