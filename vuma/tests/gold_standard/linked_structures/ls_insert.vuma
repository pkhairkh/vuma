// ls_insert.vuma — create node, "insert" (store value), load
// Expected exit code: 42
//
// Models the insert step of a linked-structure workflow: allocate a
// fresh node, store a value into it (the "insert"), then load the
// value back to verify the insert succeeded. Returns 42.

fn main() -> i32 {
    node = allocate(16);
    // "Insert" a value into the new node
    *(node + 0) = 42;
    val: u64 = *(node + 0);
    free(node);
    return val;
}
