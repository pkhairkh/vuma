// s28_ls_overwrite_last.vuma — overwrite last node, load = 95
// Expected exit code: 95
//
// Single 8-byte allocation treated as a one-field "node". Store 5 via
// `*ptr = literal`, then overwrite with 95 via `*ptr = literal`. Load
// and return 95. Uses `*ptr = literal` form (no offsets). Distinct from
// s26_ls_overwrite_first (overwrite-first, three-node sum, 150) and
// s22_ls_overwrite_last (overwrite-last, different shape).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 95;
    a: u64 = *n1;
    free(n1);
    return a;
}
