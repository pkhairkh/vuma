// s94_ls_overwrite_value.vuma — overwrite n1 to 73, load = 73
// Expected exit code: 73
//
// Single 8-byte "node". Store 5, then overwrite to 73, load -> 73
// (the overwritten value). Uses `*ptr = literal` form. Distinct
// from s90_ls_overwrite_value (32), s86_ls_overwrite_value (225)
// and s82_ls_overwrite_value (215).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 73;
    v: u64 = *n1;          // 73
    free(n1);
    return v;
}
