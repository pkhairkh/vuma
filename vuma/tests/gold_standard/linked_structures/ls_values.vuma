// ls_values.vuma — 3 nodes with values 1, 2, 3, return sum
// Expected exit code: 6
//
// Creates three independent 8-byte nodes, stores distinct values
// (1, 2, 3) in each, sums the loaded values: 1 + 2 + 3 = 6.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *(n1 + 0) = 1;
    *(n2 + 0) = 2;
    *(n3 + 0) = 3;
    v1: u64 = *(n1 + 0);
    v2: u64 = *(n2 + 0);
    v3: u64 = *(n3 + 0);
    sum: u64 = v1 + v2 + v3;
    free(n1);
    free(n2);
    free(n3);
    return sum;
}
