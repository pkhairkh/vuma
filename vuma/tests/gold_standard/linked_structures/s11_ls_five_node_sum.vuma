// s11_ls_five_node_sum.vuma — 5 nodes, sum = 150
// Expected exit code (correct): 150  (10 + 20 + 30 + 40 + 50)
// Observed on current x86_64 backend: non-deterministic (FAIL — known
//   U8-truncation bug on `*(p+offset)` stores/loads with u64 type)
//
// 40-byte allocation treated as five 8-byte "nodes" at offsets
// 0/8/16/24/32. Stores 10/20/30/40/50, loads all five, sums -> 150.
// Distinct from s10_ls_four_node_chain (4 nodes, vals 10/20/30/40)
// and s5_ls_five_node_chain (5 nodes, vals 5/15/25/35/45).

fn main() -> i32 {
    block = allocate(40);
    *(block + 0) = 10;
    *(block + 8) = 20;
    *(block + 16) = 30;
    *(block + 24) = 40;
    *(block + 32) = 50;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    c: u64 = *(block + 16);
    d: u64 = *(block + 24);
    e: u64 = *(block + 32);
    t1: u64 = a + b;
    t2: u64 = t1 + c;
    t3: u64 = t2 + d;
    s: u64 = t3 + e;
    free(block);
    return s;
}
