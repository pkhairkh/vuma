// s62_ls_three_node_diff.vuma — three nodes, diff = 120 (240 - 80 - 40)
// Expected exit code: 120
// 
// Three 8-byte allocations treated as three independent "nodes".
// Store 240/80/40 via `*ptr = literal`, load all three, 240 - 80 -
// 40 = 120. Uses `*ptr = literal` form (no offsets). Distinct from
// s51_ls_three_node_sum (235), s58_ls_three_node_diff (100) and s55_
// ls_three_node_diff (110).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 240;
    *n2 = 80;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a - b;
    r: u64 = t - c;        // 120
    free(n1);
    free(n2);
    free(n3);
    return r;
}
