// s92_ls_two_node_diff.vuma — two nodes, diff = 63 (200 - 137)
// Expected exit code: 63
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 200/137 via `*ptr = literal`, load both, a - b -> 63. Uses
// `*ptr = literal` form (no offsets). Distinct from s90_ls_two_
// node_diff (24), s86_ls_two_node_sum (185) and s82_ls_two_node_
// sum (180).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 137;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 63
    free(n1);
    free(n2);
    return d;
}
