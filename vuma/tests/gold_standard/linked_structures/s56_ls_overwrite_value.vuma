// s56_ls_overwrite_value.vuma — store 60, overwrite to 195, load = 195
// Expected exit code: 195
//
// Single 8-byte allocation treated as one "node". Store 60 via
// `*ptr = literal`, then overwrite with 195. Load and return 195.
// Uses `*ptr = literal` form (no offsets). Distinct from s54_ls_
// overwrite_value (220) and s50_ls_overwrite_value (200).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 60;
    *n1 = 195;
    a: u64 = *n1;
    free(n1);
    return a;
}
