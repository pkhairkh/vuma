// s78_ls_overwrite_value.vuma — store 1, overwrite with 3, load = 3
// Expected exit code: 3
//
// Single 8-byte allocation treated as a "node". Store 1 via
// `*ptr = literal`, overwrite with 3 via `*ptr = literal`, load
// and return 3. Uses `*ptr = literal` form (no offsets). Distinct
// from s74_ls_overwrite_value (85), s73_ls_overwrite_value (155) and
// s72_ls_overwrite_value (115).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 1;
    *n1 = 3;
    r: u64 = *n1;          // 3
    free(n1);
    return r;
}
