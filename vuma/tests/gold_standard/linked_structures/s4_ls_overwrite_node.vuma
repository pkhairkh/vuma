// s4_ls_overwrite_node.vuma — overwrite node2.val, sum = 200
// Expected exit code: 200  (50 + 150)
//
// 16-byte allocation as two nodes. Initial: node1.val = 50,
// node2.val = 70. Then overwrite node2.val with 150. Load both,
// sum = 50 + 150 = 200. Tests node-targeted overwrite.

fn main() -> i32 {
    block = allocate(16);
    *(block + 0) = 50;
    *(block + 8) = 70;
    // Overwrite node2.val
    *(block + 8) = 150;
    a: u64 = *(block + 0);
    b: u64 = *(block + 8);
    s: u64 = a + b;
    free(block);
    return s;
}
