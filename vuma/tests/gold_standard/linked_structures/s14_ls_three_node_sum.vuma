// s14_ls_three_node_sum.vuma — three nodes, sum = 66 (11 + 22 + 33)
// Expected exit code: 66
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 11/22/33 via `*ptr = literal`, load all three, sum -> 66.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s9_ls_two_node_sum (two nodes, 15/25 = 40) and
// s10_ls_four_node_chain (four nodes via broken *(block+N) form).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 11;
    *n2 = 22;
    *n3 = 33;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;
    free(n1);
    free(n2);
    free(n3);
    return s;
}
