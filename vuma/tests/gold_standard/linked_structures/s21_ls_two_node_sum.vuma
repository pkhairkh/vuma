// s21_ls_two_node_sum.vuma — two nodes, sum = 81 (23 + 58)
// Expected exit code: 81
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 23/58 via `*ptr = literal`, load both, sum -> 81. Uses `*ptr = literal`
// form (no offsets). Distinct from s18_ls_two_node_sum (19/61 = 80) and
// s14_ls_three_node_sum (11/22/33 = 66).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 23;
    *n2 = 58;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
