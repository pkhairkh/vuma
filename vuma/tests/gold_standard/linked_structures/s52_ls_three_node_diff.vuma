// s52_ls_three_node_diff.vuma — three nodes, diff = 150 (250 - 70 - 30)
// Expected exit code: 150
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 250/70/30 via `*ptr = literal`, load all three, subtract ->
// 250 - 70 - 30 = 150. Uses `*ptr = literal` form. Distinct from
// s50_ls_three_node_diff (130) and s47_ls_three_node_diff (110).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 70;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    d1: u64 = a - b;       // 180
    r: u64 = d1 - c;       // 150
    free(n1);
    free(n2);
    free(n3);
    return r;
}
