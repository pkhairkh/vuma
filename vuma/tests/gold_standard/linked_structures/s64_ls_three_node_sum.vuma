// s64_ls_three_node_sum.vuma — three nodes, sum = 200 (68 + 77 + 55)
// Expected exit code: 200
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 68/77/55 via `*ptr = literal`, load all three, sum -> 200.
// Uses `*ptr = literal` form (no offsets). Distinct from s62_ls_
// overwrite_value (175), s62_ls_three_node_diff (120) and s62_ls_two_
// node_sum (225).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 68;
    *n2 = 77;
    *n3 = 55;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    t: u64 = a + b;
    s: u64 = t + c;        // 200
    free(n1);
    free(n2);
    free(n3);
    return s;
}
