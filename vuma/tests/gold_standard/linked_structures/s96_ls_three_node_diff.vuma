// s96_ls_three_node_diff.vuma — three nodes, diff = 115 (250 - 95 - 40)
// Expected exit code: 115
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 250/95/40 via `*ptr = literal`, load all three,
// 250 - 95 - 40 -> 115. Uses `*ptr = literal` form (no offsets).
// Distinct from s94_ls_three_node_sum (100),
// s90_ls_three_node_diff (26) and s86_ls_three_node_diff (130).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 95;
    *n3 = 40;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    d: u64 = a - b - c;    // 115
    free(n1);
    free(n2);
    free(n3);
    return d;
}
