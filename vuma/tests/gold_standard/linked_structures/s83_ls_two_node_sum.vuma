// s83_ls_two_node_sum.vuma — two nodes, sum = 194 (120 + 74)
// Expected exit code: 194
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 120/74 via `*ptr = literal`, load both, sum -> 194.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s78_ls_two_node_sum (2), s74_ls_two_node_sum (130) and
// s72_ls_two_node_sum (225).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 120;
    *n2 = 74;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 194
    free(n1);
    free(n2);
    return s;
}
