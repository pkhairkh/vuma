// s104_ls_overwrite_value.vuma — overwrite n1 to 62, load = 62
// Expected exit code: 62
//
// Single 8-byte "node". Store 99, then overwrite to 62, load -> 62 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_overwrite_value (1), s102_ls_three_node_sum (5), s102_ls_two_node_sum (4).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 99;
    *n1 = 62;
    v: u64 = *n1;          // 62
    free(n1);
    return v;
}
