// s59_ls_overwrite_value.vuma — store 30, overwrite to 200, load = 200
// Expected exit code: 200
//
// Single 8-byte allocation treated as one "node". Store 30 via
// `*ptr = literal`, then overwrite the node value with 200. Load and
// return 200. Uses `*ptr = literal` form (no offsets). Distinct from
// s58_ls_two_node_sum (220), s58_ls_three_node_diff (100) and s58_ls_
// overwrite_value (180).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 30;
    *n1 = 200;
    v: u64 = *n1;
    free(n1);
    return v;
}
