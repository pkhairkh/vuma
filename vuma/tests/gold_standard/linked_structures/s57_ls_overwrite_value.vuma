// s57_ls_overwrite_value.vuma — overwrite node value, load = 90
// Expected exit code: 90
//
// Single 8-byte allocation treated as one "node". Store 180 via
// `*ptr = literal`, overwrite with 90 via `*ptr = literal`, load
// -> 90. Uses `*ptr = literal` form (no offsets). Distinct from
// s54_ls_overwrite_value (200) and s50_ls_overwrite_value (185).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 180;
    *n1 = 90;              // overwrite
    v: u64 = *n1;          // 90
    free(n1);
    return v;
}
