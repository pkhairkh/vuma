// s63_ls_overwrite_value.vuma — store 50, overwrite to 235, load = 235
// Expected exit code: 235
//
// Single 8-byte allocation treated as one "node". Store 50 via
// `*ptr = literal`, then overwrite with 235. Load and return 235.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_ls_
// overwrite_value (195), s58_ls_overwrite_value (180) and s55_ls_
// overwrite_value (185).

fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 50;
    *n1 = 235;
    a: u64 = *n1;
    free(n1);
    return a;
}
