// s101_ls_overwrite_value.vuma — overwrite n1 to 41, load = 41
// Expected exit code: 41
//
// Single 8-byte "node". Store 5 via `*ptr = literal`, then
// overwrite to 41, load -> 41 (the overwritten value). Uses
// `*ptr = literal` form. Distinct from s98_ls_overwrite_value (55),
// s97_ls_overwrite_value (14) and s94_ls_overwrite_value (73).
fn main() -> i32 {
    n1 = allocate(8);
    *n1 = 5;
    *n1 = 41;
    v: u64 = *n1;          // 41
    free(n1);
    return v;
}
