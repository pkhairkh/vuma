// ls_func_node.vuma — function creates node, stores 42, returns value
// Expected exit code: 42
//
// Tests a function that allocates a node, stores 42 at offset 0,
// loads it back, and returns the loaded value. main calls the
// function and returns its result. The allocation is created and
// freed entirely inside the function.

fn make_and_load() -> u32 {
    node = allocate(16);
    *(node + 0) = 42;
    v: u64 = *(node + 0);
    free(node);
    return v;
}

fn main() -> i32 {
    v: u32 = make_and_load();
    return v;
}
