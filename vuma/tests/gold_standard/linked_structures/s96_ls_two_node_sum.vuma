// s96_ls_two_node_sum.vuma — two nodes, sum = 155 (65 + 90)
// Expected exit code: 155
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 65/90 via `*ptr = literal`, load both, a + b -> 155. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s94_ls_two_node_sum (145), s90_ls_two_node_diff (24) and
// s86_ls_two_node_sum (185).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 65;
    *n2 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 155
    free(n1);
    free(n2);
    return s;
}
