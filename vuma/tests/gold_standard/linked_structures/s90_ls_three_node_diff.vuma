// s90_ls_three_node_diff.vuma — three nodes, diff = 26 (250 - 200 - 24)
// Expected exit code: 26
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 250/200/24 via `*ptr = literal`, load all three,
// a - b - c -> 26. Uses `*ptr = literal` form (no offsets). Distinct
// from s86_ls_three_node_diff (60), s82_ls_three_node_diff (110)
// and s78_ls_three_node_diff (148).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 250;
    *n2 = 200;
    *n3 = 24;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    r: u64 = a - b - c;    // 26
    free(n1);
    free(n2);
    free(n3);
    return r;
}
