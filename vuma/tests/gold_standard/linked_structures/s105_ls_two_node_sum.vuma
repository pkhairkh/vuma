// s105_ls_two_node_sum.vuma — store 28, 18 in 2 nodes, load and sum = 46
// Expected exit code: 46
// 
// Two 8-byte "nodes". Store 28 at n1, store 18 at n2, load each and return the sum (46). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_two_node_sum (4), s101_ls_two_node_sum (205), s100_ls_two_node_diff (16).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 28;
    *n2 = 18;
    a: u64 = *n1;          // 28
    b: u64 = *n2;          // 18
    s: u64 = a + b;        // 46
    free(n1);
    free(n2);
    return s;
}
