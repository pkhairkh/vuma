// s35_ls_two_node_diff.vuma — two nodes, diff = 110 (200 - 90)
// Expected exit code: 110
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 200/90 via `*ptr = literal`, load both, subtract -> 110.
// Uses `*ptr = literal` form (no offsets). Distinct from s34_ls_
// two_node_sum (sum, 125) and s30_ls_two_node_sum (sum).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 200;
    *n2 = 90;
    a: u64 = *n1;
    b: u64 = *n2;
    d: u64 = a - b;        // 110
    free(n1);
    free(n2);
    return d;
}
