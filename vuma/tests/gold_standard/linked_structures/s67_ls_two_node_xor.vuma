// s67_ls_two_node_xor.vuma — two nodes, xor = 255 (170 ^ 85)
// Expected exit code: 255
//
// Two 8-byte allocations treated as two independent "nodes".
// Store 170/85 via `*ptr = literal`, load both, xor -> 255
// (0xFF). Uses `*ptr = literal` form (no offsets). Distinct
// from s66_ls_two_node_diff (125), s62_ls_two_node_sum (225)
// and s58_ls_two_node_sum (220).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 170;             // 0xAA
    *n2 = 85;              // 0x55
    a: u64 = *n1;
    b: u64 = *n2;
    r: u64 = a ^ b;        // 0xFF = 255
    free(n1);
    free(n2);
    return r;
}
