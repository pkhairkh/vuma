// ls_multi_field.vuma — node with 3 fields, return sum
// Expected exit code: 3
//
// Allocates a single 24-byte node with three 8-byte fields at
// offsets 0, 8, 16. Stores 1 in each field, loads them all back,
// and returns the sum: 1 + 1 + 1 = 3.

fn main() -> i32 {
    node = allocate(24);
    *(node + 0) = 1;
    *(node + 8) = 1;
    *(node + 16) = 1;
    v1: u64 = *(node + 0);
    v2: u64 = *(node + 8);
    v3: u64 = *(node + 16);
    sum: u64 = v1 + v2 + v3;
    free(node);
    return sum;
}
