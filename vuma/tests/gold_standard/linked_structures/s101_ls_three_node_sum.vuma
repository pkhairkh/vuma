// s101_ls_three_node_sum.vuma — three nodes, sum = 150 (40 + 50 + 60)
// Expected exit code: 150
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 40/50/60 via `*ptr = literal`, load all three, a + b + c
// -> 150. Uses `*ptr = literal` form (no offsets). Distinct from
// s98_ls_three_node_sum (54), s97_ls_three_node_sum (22) and
// s94_ls_three_node_sum (100).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 40;
    *n2 = 50;
    *n3 = 60;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    s: u64 = a + b + c;    // 150
    free(n1);
    free(n2);
    free(n3);
    return s;
}
