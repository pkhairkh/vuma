// s106_ls_three_node_diff.vuma — store 200,80,84 in 3 nodes, 200-80-84 = 36
// Expected exit code: 36
//
// Three 8-byte "nodes". Store 200, 80, 84; load each, return 200 - 80 - 84 = 36. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ls_three_node_sum (5), s101_ls_three_node_sum (150), s100_ls_three_node_sum (58).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 80;
    *n3 = 84;
    a: u64 = *n1;          // 200
    b: u64 = *n2;          // 80
    c: u64 = *n3;          // 84
    d: u64 = a - b - c;    // 36
    free(n1);
    free(n2);
    free(n3);
    return d;
}
