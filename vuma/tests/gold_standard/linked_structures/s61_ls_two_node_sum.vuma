// s61_ls_two_node_sum.vuma — two nodes, sum = 205 (110 + 95)
// Expected exit code: 205
// 
// Two 8-byte allocations treated as two independent "nodes".
// Store 110/95 via `*ptr = literal`, load both, sum -> 205. Uses
// `*ptr = literal` form (no offsets). Distinct from s58_ls_two_
// node_sum (220), s58_ls_three_node_diff (100) and s58_ls_
// overwrite_value (180).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 110;
    *n2 = 95;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;        // 205
    free(n1);
    free(n2);
    return s;
}
