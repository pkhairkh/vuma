// s103_ls_two_node_diff.vuma — store 100, 1 in 2 nodes, load and diff = 100-1 = 99
// Expected exit code: 99
//
// Two 8-byte "nodes". Store 100 at n1, store 1 at n2, load each and return the difference (99). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s100_ls_two_node_diff (16).
fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 100;
    *n2 = 1;
    a: u64 = *n1;          // 100
    b: u64 = *n2;          // 1
    d: u64 = a - b;        // 99
    free(n1);
    free(n2);
    return d;
}
