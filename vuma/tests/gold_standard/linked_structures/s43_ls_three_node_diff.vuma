// s43_ls_three_node_diff.vuma — three nodes, diff = 100 (200 - 70 - 30)
// Expected exit code: 100
//
// Three 8-byte allocations treated as three independent "nodes".
// Store 200/70/30 via `*ptr = literal`, load all, subtract
// sequentially -> 100. Uses `*ptr = literal` form. Distinct from
// s42_ls_three_node_diff (90) and s38_ls_three_node_diff (110).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    n3 = allocate(8);
    *n1 = 200;
    *n2 = 70;
    *n3 = 30;
    a: u64 = *n1;
    b: u64 = *n2;
    c: u64 = *n3;
    d: u64 = a - b - c;    // 100
    free(n1);
    free(n2);
    free(n3);
    return d;
}
