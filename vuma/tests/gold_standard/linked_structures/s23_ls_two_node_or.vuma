// s23_ls_two_node_or.vuma — two nodes, or = 67 (64 | 3 = 0x40 | 0x03)
// Expected exit code: 67
//
// Two 8-byte allocations treated as two independent "nodes". Store
// 64/3 via `*ptr = literal`, load both, OR -> 67. Uses `*ptr = literal`
// form (no offsets). Distinct from s22_ls_two_node_sum (37 + 53 = 90)
// and s24_ls_two_node_diff (90 - 50 = 40).

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 64;             // 0x40
    *n2 = 3;              // 0x03
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a | b;       // 0x43 = 67
    free(n1);
    free(n2);
    return s;
}

