// s38_ls_overwrite_first.vuma — overwrite first node to 140, sum = 165 (140 + 25)
// Expected exit code: 165
//
// Two 8-byte allocations treated as two nodes. Store 70 then
// overwrite to 140 in n1; store 25 in n2. Load both, sum -> 165.
// Uses `*ptr = literal` form (no offsets). Distinct from s34_ls_
// overwrite_last (190) and s30_ls_overwrite_first.

fn main() -> i32 {
    n1 = allocate(8);
    n2 = allocate(8);
    *n1 = 70;
    *n2 = 25;
    *n1 = 140;
    a: u64 = *n1;
    b: u64 = *n2;
    s: u64 = a + b;
    free(n1);
    free(n2);
    return s;
}
