// s52_arith_div_then_mod.vuma — 200 / 7 = 28
// Expected exit code: 28
//
// Single-stage u32 division. 200 / 7 = 28 (integer division, since
// 28 * 7 = 196 <= 200 < 203 = 29 * 7). All operands loaded into u32
// variables first. Straight-line arithmetic. Distinct from
// s50_arith_div_then_add (130) and s46_arith_sub_then_div (30).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 7;
    r: u32 = a / b;        // 28
    return r;
}
