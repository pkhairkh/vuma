// s10_arith_quad_then_sub.vuma — (10+20+30+40) - 50 = 50
// Expected exit code: 50
//
// Four-way sum (100) minus 50 = 50. Distinct from s5_arith_quad_sum
// (pure sum, no subtraction) and s4_arith_double_add (two-way sum).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 30;
    d: u32 = 40;
    e: u32 = 50;
    t1: u32 = a + b;      // 30
    t2: u32 = t1 + c;     // 60
    t3: u32 = t2 + d;     // 100
    r: u32 = t3 - e;      // 50
    return r;
}
