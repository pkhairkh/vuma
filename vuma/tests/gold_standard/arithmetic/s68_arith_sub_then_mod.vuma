// s68_arith_sub_then_mod.vuma — (200 - 30) % 63 = 170 % 63 = 44
// Expected exit code: 44
//
// Two-stage arithmetic: subtract then modulo. 200 - 30 = 170;
// 170 % 63 = 44. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s66_arith_sub_then_div (28), s62_arith_
// sub_then_add (180) and s58_arith_mul_then_div (35).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 30;
    c: i32 = 63;
    d: i32 = a - b;        // 170
    r: i32 = d % c;        // 44
    return r;
}
