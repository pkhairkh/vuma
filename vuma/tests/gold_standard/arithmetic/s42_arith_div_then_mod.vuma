// s42_arith_div_then_mod.vuma — (200 / 7) mod 5 = 28 mod 5 = 3
// Expected exit code: 3
//
// Two-stage u32 computation: divide, then modulo. 200 / 7 = 28
// (integer division); 28 mod 5 = 3. All operands loaded into u32
// variables first. Straight-line arithmetic. Distinct from
// s38_arith_mul_then_div (mul-then-div, 20) and s34_arith_div_then_
// add (div-then-add, 60).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 7;
    c: u32 = 5;
    q: u32 = a / b;       // 28
    r: u32 = q % c;       // 3
    return r;
}
