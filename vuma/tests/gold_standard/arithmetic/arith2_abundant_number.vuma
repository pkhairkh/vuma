// arith2_abundant_number — abundant number check
// Expected exit code: 1
//
// A number is abundant if the sum of its proper divisors exceeds it.
// For 12: divisors 1, 2, 3, 4, 6 → sum = 16 > 12 → abundant.
// We compute diff = sum - n = 4 (positive) and return diff/diff = 1
// to encode the boolean "is abundant" in straight-line code (no if).

fn main() -> i32 {
    n: u32 = 12;
    d1: u32 = 1;
    d2: u32 = 2;
    d3: u32 = 3;
    d4: u32 = 4;
    d6: u32 = 6;
    sum: u32 = d1 + d2 + d3 + d4 + d6;   // 16
    diff: u32 = sum - n;                 // 4 (positive → abundant)
    is_abundant: u32 = diff / diff;      // 4 / 4 = 1
    return is_abundant;
}
