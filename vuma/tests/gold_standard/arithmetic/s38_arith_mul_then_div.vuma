// s38_arith_mul_then_div.vuma — (15 * 8) / 6 = 120 / 6 = 20
// Expected exit code: 20
//
// Two-stage u32 computation: multiply then divide. (15 * 8) = 120;
// 120 / 6 = 20. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s34_arith_mul_then_mod
// (mul-then-mod, 7) and s30_arith_div_then_mul (div-then-mul).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 8;
    c: u32 = 6;
    m: u32 = a * b;       // 120
    r: u32 = m / c;       // 20
    return r;
}
