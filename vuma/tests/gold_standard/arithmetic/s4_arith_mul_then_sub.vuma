// s4_arith_mul_then_sub.vuma — 9 * 5 - 10 = 35
// Expected exit code: 35
//
// Mix of multiplication and subtraction. 9 * 5 = 45, then 45 - 10 = 35.
// All values within U8 range, straight-line code.

fn main() -> i32 {
    a: u32 = 9;
    b: u32 = 5;
    c: u32 = 10;
    p: u32 = a * b;
    r: u32 = p - c;
    return r;
}
