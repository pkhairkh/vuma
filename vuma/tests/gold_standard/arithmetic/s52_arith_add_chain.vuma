// s52_arith_add_chain.vuma — 30 + 40 + 50 = 120
// Expected exit code: 120
//
// Three-way u32 addition chain. 30 + 40 = 70; 70 + 50 = 120. All
// operands loaded into u32 variables first. Straight-line arithmetic.
// Distinct from s50_arith_add_then_div (50) and s46_arith_sub_then_div
// (30).

fn main() -> i32 {
    a: u32 = 30;
    b: u32 = 40;
    c: u32 = 50;
    s1: u32 = a + b;       // 70
    s2: u32 = s1 + c;      // 120
    return s2;
}
