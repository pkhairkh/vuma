// s21_arith_sub_then_mul.vuma — (100 - 40) * 4 = 60 * 4 = 240
// Expected exit code: 240
//
// Two-stage sub-then-mul. (100 - 40) = 60; 60 * 4 = 240. All operands
// loaded into u32 variables first. Distinct from s16_arith_sub_div_chain
// (sub-then-div) and s14_arith_sub_then_mul (different values, 180-30*4).

fn main() -> i32 {
    a: u32 = 100;
    b: u32 = 40;
    m: u32 = 4;
    s: u32 = a - b;       // 60
    r: u32 = s * m;       // 240
    return r;
}
