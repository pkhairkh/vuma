// s78_arith_mul_then_mod.vuma — (2 * 6) % 13 = 12 % 13 = 12
// Expected exit code: 12
//
// Two-stage arithmetic: multiply then modulo. 2 * 6 = 12;
// 12 % 13 = 12. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s74_arith_mul_then_sub (250),
// s73_arith_mul_then_sub (180) and s72_arith_mul_then_add (255).
fn main() -> i32 {
    a: i32 = 2;
    b: i32 = 6;
    c: i32 = 13;
    p: i32 = a * b;        // 12
    r: i32 = p % c;        // 12
    return r;
}
