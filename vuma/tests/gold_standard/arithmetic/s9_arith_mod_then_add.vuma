// s9_arith_mod_then_add.vuma — (255 % 10) + 7 = 5 + 7 = 12
// Expected exit code: 12
//
// Modulo first (255 % 10 = 5), then add 7 -> 12. All values inside
// U8 range. Distinct from s6_arith_div_mod_combined (div-then-mod)
// and s4_arith_mod_then_mul (mod-then-mul).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 10;
    c: u32 = 7;
    d: u32 = a % b;       // 5
    e: u32 = d + c;       // 12
    return e;
}
