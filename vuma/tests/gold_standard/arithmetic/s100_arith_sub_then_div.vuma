// s100_arith_sub_then_div.vuma — (255 - 27) / 2 = 228 / 2 = 114
// Expected exit code: 114
//
// Two-stage arithmetic: subtract then divide. 255 - 27 =
// 228; 228 / 2 = 114. All operands kept as i32 locals.
// Straight-line arithmetic.
// Distinct from s97_arith_add_then_div (72), s94_arith_div_then_add (80), s90_arith_sub_then_div (56).
fn main() -> i32 {
    a: i32 = 255;
    b: i32 = 27;
    c: i32 = 2;
    s: i32 = a - b;        // 228
    q: i32 = s / c;        // 114
    return q;
}
