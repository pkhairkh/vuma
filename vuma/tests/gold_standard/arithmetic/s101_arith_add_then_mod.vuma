// s101_arith_add_then_mod.vuma — (120 + 50) % 119 = 170 % 119 = 51
// Expected exit code: 51
//
// Two-stage arithmetic: add then modulo. 120 + 50 = 170;
// 170 % 119 = 51. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s98_arith_add_then_mod (16),
// s97_arith_add_then_div (72) and s94_arith_div_then_add (80).
fn main() -> i32 {
    a: i32 = 120;
    b: i32 = 50;
    c: i32 = 119;
    s: i32 = a + b;        // 170
    r: i32 = s % c;        // 51
    return r;
}
