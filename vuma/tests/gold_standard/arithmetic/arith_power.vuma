// arith_power — power function via repeated multiplication: 2^10 = 1024
// Expected exit code: 0  (low 8 bits of 1024 = 0x00)
//
// 2^10 = 1024 = 0x400. The exit code is the low byte, which is 0.

fn main() -> i32 {
    base: u32 = 2;
    exp: u32 = 10;
    result: u32 = 1;
    i: u32 = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    return result & 255;
}
