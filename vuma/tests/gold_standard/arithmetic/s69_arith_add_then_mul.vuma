// s69_arith_add_then_mul.vuma -- (30 + 70) * 2 = 100 * 2 = 200
// Expected exit code: 200
//
// Two-stage arithmetic: add then multiply. 30 + 70 = 100; 100 * 2 =
// 200. All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s66_arith_mul_then_sub (168), s65_arith_add_then_mod
// (70) and s64_arith_add_then_mul (180).
fn main() -> i32 {
    a: i32 = 30;
    b: i32 = 70;
    c: i32 = 2;
    s: i32 = a + b;        // 100
    r: i32 = s * c;        // 200
    return r;
}
