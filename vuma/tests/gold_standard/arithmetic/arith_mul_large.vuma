// arith_mul_large — large u64 multiplication that fits in u64
// Expected exit code: 129
//
// Computes 1000001 * 1000001 = 1000002000001 (fits in u64). The exit code
// is the low 8 bits, which equals 129 (since 1000001 mod 256 = 65 and
// 65 * 65 mod 256 = 4225 mod 256 = 129).

fn main() -> i32 {
    a: u64 = 1000001;
    b: u64 = 1000001;
    product: u64 = a * b;        // 1000002000001
    low8: u32 = product & 255;
    return low8;
}
