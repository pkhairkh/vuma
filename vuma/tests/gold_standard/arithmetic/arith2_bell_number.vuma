// arith2_bell_number — Bell number B(3)
// Expected exit code: 5
//
// B(n) = sum_{k=1..n} S(n,k) where S is the Stirling number of the
// second kind.  For n = 3:
//   S(3,1) = 1, S(3,2) = 3, S(3,3) = 1   →   B(3) = 1 + 3 + 1 = 5
// Straight-line code only.

fn main() -> i32 {
    n: u32 = 3;
    s1: u32 = 1;   // S(3,1) = 1
    s2: u32 = 3;   // S(3,2) = 3
    s3: u32 = 1;   // S(3,3) = 1
    bell: u32 = s1 + s2 + s3;   // 5
    return bell;
}
