// s12_arith_div_then_add.vuma — (60 / 5) + 90 = 12 + 90 = 102
// Expected exit code: 102
//
// Divide then add. 60 / 5 = 12; 12 + 90 = 102. Two-stage arithmetic
// with one intermediate. Distinct from s9_arith_mod_then_add
// (mod-then-add) and s8_arith_div_mod_sum (div-mod-sum).

fn main() -> i32 {
    n: u32 = 60;
    d: u32 = 5;
    c: u32 = 90;
    q: u32 = n / d;      // 12
    r: u32 = q + c;      // 102
    return r;
}
