// s44_arith_mul_sub_div.vuma — ((12 * 7) - 4) / 5 = 80 / 5 = 16
// Expected exit code: 16
//
// Three-stage u32 computation: multiply, then subtract, then divide.
// 12 * 7 = 84; 84 - 4 = 80; 80 / 5 = 16. All operands loaded into u32
// variables first. Straight-line arithmetic. Distinct from
// s42_arith_mul_add_div (mul-add-div, 25) and s38_arith_mul_then_div
// (mul-then-div, 20).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 7;
    c: u32 = 4;
    d: u32 = 5;
    p: u32 = a * b;       // 84
    s: u32 = p - c;       // 80
    r: u32 = s / d;       // 16
    return r;
}
