// s54_arith_add_then_mul.vuma — (15 + 40) * 2 = 55 * 2 = 110
// Expected exit code: 110
//
// Two-stage u32 computation: add then multiply. 15 + 40 = 55;
// 55 * 2 = 110. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s50_arith_mul_then_sub
// (76) and s49_arith_add_then_mod (180).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 40;
    c: u32 = 2;
    s: u32 = a + b;        // 55
    r: u32 = s * c;        // 110
    return r;
}
