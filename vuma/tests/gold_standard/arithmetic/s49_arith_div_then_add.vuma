// s49_arith_div_then_add.vuma — (240 / 6) + 12 = 40 + 12 = 52
// Expected exit code: 52
//
// Two-stage u32 computation: divide then add. 240 / 6 = 40;
// 40 + 12 = 52. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s46_arith_sub_then_div
// (30, sub-then-div) and s42_arith_mul_add_div (25, mul-add-div).

fn main() -> i32 {
    a: u32 = 240;
    b: u32 = 6;
    c: u32 = 12;
    q: u32 = a / b;        // 40
    r: u32 = q + c;        // 52
    return r;
}
