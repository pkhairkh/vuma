// s29_arith_sub_then_mod.vuma — (200 - 30) % 7 = 170 % 7 = 2
// Expected exit code: 2
//
// Two-stage u32 computation: sub then mod. 200 - 30 = 170; 170 % 7 = 2 (since 7 * 24 = 168). All operands loaded into u32 variables first. Distinct from s26_arith_div_mod_chain (div-mod-add, 32) and s22_arith_mul_mod_add (mul-mod-add).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 30;
    c: u32 = 7;
    d: u32 = a - b;       // 170
    r: u32 = d % c;       // 2
    return r;
}
