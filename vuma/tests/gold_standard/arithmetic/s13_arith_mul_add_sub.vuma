// s13_arith_mul_add_sub.vuma — (7 * 9) + (50 - 23) = 63 + 27 = 90
// Expected exit code: 90
//
// Two sub-expressions combined with an add: a multiply (7*9=63) and a
// subtract (50-23=27), summed -> 90. All operands loaded into u32
// variables first. Distinct from s9_arith_div_then_mul (single chain)
// and s10_arith_quad_then_sub (single sub at the end).

fn main() -> i32 {
    a: u32 = 7;
    b: u32 = 9;
    c: u32 = 50;
    d: u32 = 23;
    m: u32 = a * b;       // 63
    s: u32 = c - d;       // 27
    r: u32 = m + s;       // 90
    return r;
}
