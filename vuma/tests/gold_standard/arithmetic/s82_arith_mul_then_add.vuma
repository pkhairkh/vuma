// s82_arith_mul_then_add.vuma — 9 * 10 + 25 = 90 + 25 = 115
// Expected exit code: 115
//
// Two-stage arithmetic: multiply then add. 9 * 10 = 90;
// 90 + 25 = 115. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_sub_then_mul (78),
// s74_arith_mul_then_sub (90) and s72_arith_mul_then_add (140).
fn main() -> i32 {
    a: i32 = 9;
    b: i32 = 10;
    c: i32 = 25;
    p: i32 = a * b;        // 90
    r: i32 = p + c;        // 115
    return r;
}
