// s76_arith_add_then_mod.vuma — (140 + 88) % 200 = 228 % 200 = 28
// Expected exit code: 28
//
// Two-stage arithmetic: add then modulus. 140 + 88 = 228;
// 228 % 200 = 28. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s74_arith_add_then_div (17),
// s73_arith_add_then_mod (23) and s72_arith_div_then_add (85).
fn main() -> i32 {
    a: i32 = 140;
    b: i32 = 88;
    c: i32 = 200;
    s: i32 = a + b;        // 228
    r: i32 = s % c;        // 28
    return r;
}
