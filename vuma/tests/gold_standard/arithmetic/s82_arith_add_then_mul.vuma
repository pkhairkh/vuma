// s82_arith_add_then_mul.vuma — (40 + 60) * 2 = 100 * 2 = 200
// Expected exit code: 200
//
// Two-stage arithmetic: add then multiply. 40 + 60 = 100;
// 100 * 2 = 200. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_add_then_div (11),
// s74_arith_add_then_div (170) and s72_arith_add_then_mod (60).
fn main() -> i32 {
    a: i32 = 40;
    b: i32 = 60;
    c: i32 = 2;
    s: i32 = a + b;        // 100
    r: i32 = s * c;        // 200
    return r;
}
