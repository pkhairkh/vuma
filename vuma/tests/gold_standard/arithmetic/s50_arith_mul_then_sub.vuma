// s50_arith_mul_then_sub.vuma — (18 * 7) - 50 = 126 - 50 = 76
// Expected exit code: 76
//
// Two-stage u32 computation: multiply then subtract. 18 * 7 = 126;
// 126 - 50 = 76. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s46_arith_mul_mod_add
// (49) and s43_arith_sub_then_mul (200).

fn main() -> i32 {
    a: u32 = 18;
    b: u32 = 7;
    c: u32 = 50;
    p: u32 = a * b;        // 126
    r: u32 = p - c;        // 76
    return r;
}
