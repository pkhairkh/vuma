// s85_arith_add_then_mul.vuma — (30 + 25) * 3 = 55 * 3 = 165
// Expected exit code: 165
//
// Two-stage arithmetic: add then multiply. 30 + 25 = 55;
// 55 * 3 = 165. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s82_arith_add_then_mul (200),
// s78_arith_add_then_mul and s74_arith_add_then_mul.
fn main() -> i32 {
    a: i32 = 30;
    b: i32 = 25;
    c: i32 = 3;
    s: i32 = a + b;        // 55
    r: i32 = s * c;        // 165
    return r;
}
