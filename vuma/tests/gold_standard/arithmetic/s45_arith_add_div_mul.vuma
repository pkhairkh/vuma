// s45_arith_add_div_mul.vuma — ((40 + 8) / 4) * 3 = 12 * 3 = 36
// Expected exit code: 36
//
// Three-stage u32 computation: add, then divide, then multiply.
// 40 + 8 = 48; 48 / 4 = 12; 12 * 3 = 36. All operands loaded into
// u32 variables first. Straight-line arithmetic. Distinct from
// s42_arith_div_then_mod (div-then-mod, 3) and s34_arith_mul_then_mod
// (mul-then-mod, 4).

fn main() -> i32 {
    a: u32 = 40;
    b: u32 = 8;
    c: u32 = 4;
    d: u32 = 3;
    s: u32 = a + b;       // 48
    q: u32 = s / c;       // 12
    r: u32 = q * d;       // 36
    return r;
}
