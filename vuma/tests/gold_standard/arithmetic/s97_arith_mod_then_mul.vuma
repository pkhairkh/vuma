// s97_arith_mod_then_mul.vuma — (200 % 7) * 17 = 4 * 17 = 68
// Expected exit code: 68
//
// Two-stage arithmetic: modulo then multiply. 200 % 7 = 4
// (7 * 28 = 196, remainder 4); 4 * 17 = 68. All operands
// kept as i32 locals. Straight-line arithmetic.
// Distinct from s94_arith_div_then_add (80), s90_arith_add_then_mod (53), s86_arith_add_then_div (10).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 7;
    c: i32 = 17;
    m: i32 = a % b;        // 4
    r: i32 = m * c;        // 68
    return r;
}
