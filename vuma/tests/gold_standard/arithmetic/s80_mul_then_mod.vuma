// s80_arith_mul_then_mod.vuma — (17 * 2) % 50 = 34 % 50 = 34
// Expected exit code: 34
//
// Two-stage arithmetic: multiply then modulo. 17 * 2 = 34;
// 34 % 50 = 34. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_mul_then_mod (12),
// s74_arith_mul_then_sub (250) and s73_arith_mul_then_sub (180).
fn main() -> i32 {
    a: i32 = 17;
    b: i32 = 2;
    c: i32 = 50;
    p: i32 = a * b;        // 34
    r: i32 = p % c;        // 34
    return r;
}
