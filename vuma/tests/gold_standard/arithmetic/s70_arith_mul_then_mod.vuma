// s70_arith_mul_then_mod.vuma — (20 * 15) % 200 = 300 % 200 = 100
// Expected exit code: 100
//
// Two-stage arithmetic: multiply then modulus. 20 * 15 = 300;
// 300 % 200 = 100. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s66_arith_add_then_mod (10),
// s65_arith_add_then_mod (70) and s62_arith_add_then_div (50).
fn main() -> i32 {
    a: i32 = 20;
    b: i32 = 15;
    c: i32 = 200;
    p: i32 = a * b;        // 300
    r: i32 = p % c;        // 100
    return r;
}
