// s106_arith_add_then_mul.vuma — (14 + 15) * 3 = 29 * 3 = 87
// Expected exit code: 87
//
// Two-stage arithmetic: add then multiply. 14 + 15 = 29; 29 * 3 = 87. All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s102_arith_add_then_div (74), s101_arith_add_then_mod (51), s100_arith_add_then_mul (117).
fn main() -> i32 {
    a: i32 = 14;
    b: i32 = 15;
    c: i32 = 3;
    s: i32 = a + b;        // 29
    r: i32 = s * c;        // 87
    return r;
}
