// arith2_deficient_number — deficient number check
// Expected exit code: 1
//
// A number is deficient if the sum of its proper divisors is less than it.
// For 7 (prime): the only proper divisor is 1, sum = 1 < 7 → deficient.
// We compute diff = n - sum = 6 (positive → deficient) and return
// diff/diff = 1 to encode the boolean in straight-line code (no if).

fn main() -> i32 {
    n: u32 = 7;
    sum: u32 = 1;                // only proper divisor of a prime
    diff: u32 = n - sum;         // 6 (positive → deficient)
    is_deficient: u32 = diff / diff;   // 6 / 6 = 1
    return is_deficient;
}
