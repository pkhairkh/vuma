// s32_arith_add_then_div.vuma - (200 + 40) / 6 = 240 / 6 = 40
// Expected exit code: 40
//
// (200 + 40) / 6 = 240 / 6 = 40. All operands loaded into typed variables
// before any bitwise op (immediate-RHS drop workaround where applicable);
// stores use the `*ptr = literal` (or `*ptr = variable + 0`) form with no
// `*(ptr + offset)` indexing. Distinct from s30_arith_div_then_mul (div-
// then-mul, 64) and s26_arith_add_then_div (different operands).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 40;
    c: u32 = 6;
    s: u32 = a + b;        // 240
    r: u32 = s / c;        // 40
    return r;
}
