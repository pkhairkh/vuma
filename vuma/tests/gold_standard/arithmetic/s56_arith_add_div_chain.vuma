// s56_arith_add_div_chain.vuma — (40 + 60) / 4 = 100 / 4 = 25
// Expected exit code: 25
//
// Two-stage u32 computation: add then divide. 40 + 60 = 100; 100 / 4
// = 25. All operands loaded into u32 variables first. Straight-line
// arithmetic. Distinct from s54_arith_mul_then_add (110) and
// s50_arith_div_then_add (90).

fn main() -> i32 {
    a: u32 = 40;
    b: u32 = 60;
    c: u32 = 4;
    s: u32 = a + b;         // 100
    r: u32 = s / c;         // 25
    return r;
}
