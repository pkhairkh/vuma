// arith_mul_table — multiplication table via nested loops
// Expected exit code: 36
//
// Computes the sum of products i*j for i in 1..=3 and j in 1..=3 using
// nested while loops with the verified counter pattern.
// Products: 1,2,3,2,4,6,3,6,9 — sum = 36.

fn main() -> i32 {
    total: u32 = 0;
    i: u32 = 1;
    one: u32 = 1;
    four: u32 = 4;
    while i < four {
        j: u32 = 1;
        while j < four {
            total = total + i * j;
            j = j + 1;
        }
        i = i + 1;
    }
    return total;
}
