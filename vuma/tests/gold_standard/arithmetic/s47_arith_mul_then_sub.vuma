// s47_arith_mul_then_sub.vuma — 25 * 9 - 65 = 225 - 65 = 160
// Expected exit code: 160
//
// Three-stage u32 computation: multiply then subtract. 25 * 9 = 225;
// 225 - 65 = 160. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s46_arith_add_then_mul
// (add-then-mul, 200) and s42_arith_mul_add_div (25).

fn main() -> i32 {
    a: u32 = 25;
    b: u32 = 9;
    c: u32 = 65;
    p: u32 = a * b;        // 225
    r: u32 = p - c;        // 160
    return r;
}
