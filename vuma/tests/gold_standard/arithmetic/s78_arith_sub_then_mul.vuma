// s78_arith_sub_then_mul.vuma — (40 - 1) * 2 = 39 * 2 = 78
// Expected exit code: 78
//
// Two-stage arithmetic: subtract then multiply. 40 - 1 = 39;
// 39 * 2 = 78. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s74_arith_mod_then_add (130),
// s73_arith_div_then_sub (190) and s72_arith_sub_then_div (160).
fn main() -> i32 {
    a: i32 = 40;
    b: i32 = 1;
    c: i32 = 2;
    d: i32 = a - b;        // 39
    r: i32 = d * c;        // 78
    return r;
}
