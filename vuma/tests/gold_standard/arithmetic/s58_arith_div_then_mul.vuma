// s58_arith_div_then_mul.vuma — (200 / 5) * 3 = 40 * 3 = 120
// Expected exit code: 120
// 
// Two-stage u32 computation: divide then multiply. 200 / 5 = 40;
// 40 * 3 = 120. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_sub_then_mul
// (240), s51_arith_add_mod_then_add (140) and s51_arith_mul_add_div
// (30).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 5;
    c: u32 = 3;
    q: u32 = a / b;        // 40
    r: u32 = q * c;        // 120
    return r;
}
