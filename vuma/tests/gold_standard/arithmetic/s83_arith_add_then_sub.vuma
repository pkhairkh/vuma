// s83_arith_add_then_sub.vuma — (90 + 80) - 18 = 170 - 18 = 152
// Expected exit code: 152
//
// Two-stage arithmetic: add then subtract. 90 + 80 = 170;
// 170 - 18 = 152. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_add_then_sub (3),
// s74_arith_add_then_sub (5) and s72_arith_add_then_sub (7).
fn main() -> i32 {
    a: i32 = 90;
    b: i32 = 80;
    c: i32 = 18;
    s: i32 = a + b;        // 170
    r: i32 = s - c;        // 152
    return r;
}
