// s28_arith_add_then_mul.vuma — (50 + 10) * 2 = 60 * 2 = 120
// Expected exit code: 120
//
// Two-stage u32 computation: add then mul. 50 + 10 = 60; 60 * 2 = 120.
// All operands loaded into u32 variables first. Distinct from
// s26_arith_add_mul_sub (add-mul-sub, 85) and s22_arith_add_then_mul
// (add-then-mul, 160).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 10;
    c: u32 = 2;
    s: u32 = a + b;       // 60
    r: u32 = s * c;       // 120
    return r;
}
