// s89_arith_sub_then_div.vuma — (173 - 5) / 2 = 168 / 2 = 84
// Expected exit code: 84
//
// Two-stage arithmetic: subtract then divide. 173 - 5 = 168;
// 168 / 2 = 84. All operands kept as i32 locals. Straight-
// line arithmetic. Distinct from s86_arith_sub_then_mod (180),
// s82_arith_sub_then_mod (3) and s78_arith_sub_then_mul (3).
fn main() -> i32 {
    a: i32 = 173;
    b: i32 = 5;
    d: i32 = 2;
    s: i32 = a - b;        // 168
    r: i32 = s / d;        // 84
    return r;
}
