// s81_arith_mul_then_mod.vuma — (14 * 13) % 100 = 182 % 100 = 82
// Expected exit code: 82
//
// Two-stage arithmetic: multiply then modulo. 14 * 13 = 182;
// 182 % 100 = 82. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_mul_then_mod (12),
// s77_arith_mul_then_div (57) and s76_arith_mul_then_add (121).
fn main() -> i32 {
    a: i32 = 14;
    b: i32 = 13;
    c: i32 = 100;
    p: i32 = a * b;        // 182
    r: i32 = p % c;        // 82
    return r;
}
