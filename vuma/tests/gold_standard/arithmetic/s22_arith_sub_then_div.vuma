// s22_arith_sub_then_div.vuma — (200 - 50) / 5 = 150 / 5 = 30
// Expected exit code: 30
//
// Two-stage u32 computation: sub then div. 200 - 50 = 150; 150 / 5 = 30.
// All operands loaded into u32 variables first. Distinct from
// s18_arith_div_mod_sum (div-then-mod-then-sum, value 41) and
// s14_arith_mul_then_div (mul-then-div).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 50;
    c: u32 = 5;
    d: u32 = a - b;       // 150
    r: u32 = d / c;       // 30
    return r;
}
