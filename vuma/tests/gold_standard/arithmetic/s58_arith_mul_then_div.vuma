// s58_arith_mul_then_div.vuma — (20 * 7) / 4 = 140 / 4 = 35
// Expected exit code: 35
// 
// Two-stage u32 computation: multiply then divide. 20 * 7 = 140;
// 140 / 4 = 35. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s51_arith_sub_then_mul
// (240), s51_arith_add_mod_then_add (140) and s51_arith_mul_add_div
// (30).

fn main() -> i32 {
    a: u32 = 20;
    b: u32 = 7;
    c: u32 = 4;
    p: u32 = a * b;        // 140
    r: u32 = p / c;        // 35
    return r;
}
