// arith2_continued_fraction_sqrt2 — CF of sqrt(2), first term
// Expected exit code: 1
//
// The continued fraction of sqrt(2) is [1; 2, 2, 2, ...] (periodic).
// The first partial quotient a0 = floor(sqrt(2)) = 1 (since 1^2 ≤ 2 < 2^2).
// This test verifies 1 ≤ 2 < 4 and returns a0 = 1.
// Straight-line code only.

fn main() -> i32 {
    two: u32 = 2;
    four: u32 = 4;
    // floor(sqrt(2)) = 1 because 1*1 = 1 <= 2 < 4 = 2*2
    a0: u32 = 1;
    lo: u32 = a0 * a0;        // 1
    hi: u32 = (a0 + 1) * (a0 + 1);   // 4
    // lo <= 2 < hi — exercise the comparisons (results are dead but real code)
    diff_lo: u32 = two - lo;   // 1
    diff_hi: u32 = hi - two;   // 2
    return a0;
}
