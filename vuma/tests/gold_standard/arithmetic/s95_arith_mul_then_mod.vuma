// s95_arith_mul_then_mod.vuma — (15 * 9) % 122 = 135 % 122 = 13
// Expected exit code: 13
//
// Two-stage arithmetic: multiply then modulo. 15 * 9 = 135;
// 135 % 122 = 13. All operands kept as i32 locals; intermediate 135
// stays within 0-255. Straight-line arithmetic. Distinct from
// s94_arith_mul_then_mod (43), s90_arith_mul_then_sub (54) and
// s82_arith_mul_then_add (115).
fn main() -> i32 {
    a: i32 = 15;
    b: i32 = 9;
    c: i32 = 122;
    p: i32 = a * b;        // 135
    r: i32 = p % c;        // 13
    return r;
}
