// s15_arith_add_sub_mul.vuma — (40 + 20 - 10) * 2 = 50 * 2 = 100
// Expected exit code: 100
//
// Three-stage computation: add then subtract then multiply. (40 + 20) = 60;
// 60 - 10 = 50; 50 * 2 = 100. All operands loaded into u32 variables first.
// Distinct from s10_arith_add_then_mul (add-then-mul, no subtract) and
// s14_arith_sub_then_mul (sub-then-mul, no add).

fn main() -> i32 {
    a: u32 = 40;
    b: u32 = 20;
    c: u32 = 10;
    m: u32 = 2;
    s: u32 = a + b;       // 60
    d: u32 = s - c;       // 50
    r: u32 = d * m;       // 100
    return r;
}
