// s17_arith_div_then_mul.vuma — (200 / 5) * 3 = 40 * 3 = 120
// Expected exit code: 120
//
// Two-stage computation: divide then multiply. (200 / 5) = 40;
// 40 * 3 = 120. Distinct from s14_arith_mul_then_div (mul-then-div)
// and s10_arith_div_then_add (div-then-add).

fn main() -> i32 {
    a: u32 = 200;
    d: u32 = 5;
    m: u32 = 3;
    q: u32 = a / d;       // 40
    r: u32 = q * m;       // 120
    return r;
}
