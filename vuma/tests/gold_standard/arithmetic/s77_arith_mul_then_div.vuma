// s77_arith_mul_then_div.vuma — (19 * 9) / 3 = 171 / 3 = 57
// Expected exit code: 57
//
// Two-stage arithmetic: multiply then divide. 19 * 9 = 171;
// 171 / 3 = 57. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s70_arith_mul_then_mod (100),
// s66_arith_mul_then_sub (168) and s74_arith_mul_then_sub (109).

fn main() -> i32 {
    a: i32 = 19;
    b: i32 = 9;
    c: i32 = 3;
    m: i32 = a * b;        // 171
    r: i32 = m / c;        // 57
    return r;
}
