// s52_arith_mul_then_sub.vuma — 12 * 8 - 5 = 96 - 5 = 91
// Expected exit code: 91
//
// Two-stage u32 computation: multiply then subtract. 12 * 8 = 96;
// 96 - 5 = 91. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s50_arith_mul_then_sub (76)
// and s46_arith_mul_then_sub (60).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 8;
    c: u32 = 5;
    p: u32 = a * b;        // 96
    r: u32 = p - c;        // 91
    return r;
}
