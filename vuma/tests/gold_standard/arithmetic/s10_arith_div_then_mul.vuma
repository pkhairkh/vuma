// s10_arith_div_then_mul.vuma — (200 / 8) * 2 = 25 * 2 = 50
// Expected exit code: 50
//
// Two-stage computation: divide then multiply. 200 / 8 = 25; 25 * 2 = 50.
// Distinct from s6_arith_div_mod_combined (div+mod on same dividend) and
// s4_arith_div_chain (chained divisions).

fn main() -> i32 {
    n: u32 = 200;
    d: u32 = 8;
    m: u32 = 2;
    q: u32 = n / d;       // 25
    r: u32 = q * m;       // 50
    return r;
}
