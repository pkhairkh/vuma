// s64_arith_add_then_mul.vuma — (50 + 10) * 3 = 60 * 3 = 180
// Expected exit code: 180
//
// Two-stage u32 computation: add then multiply. 50 + 10 = 60;
// 60 * 3 = 180. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s62_arith_add_then_div (50),
// s62_arith_mul_then_add (135) and s62_arith_sub_then_add (180).

fn main() -> i32 {
    a: u32 = 50;
    b: u32 = 10;
    c: u32 = 3;
    s: u32 = a + b;        // 60
    r: u32 = s * c;        // 180
    return r;
}
