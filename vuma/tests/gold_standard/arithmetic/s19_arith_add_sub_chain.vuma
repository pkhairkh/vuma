// s19_arith_add_sub_chain.vuma — ((60 + 40) - 25) - 10 = 100 - 25 - 10 = 65
// Expected exit code: 65
//
// Three-stage u32 computation: add then sub then sub. 60 + 40 = 100;
// 100 - 25 = 75; 75 - 10 = 65. All operands loaded into u32 variables
// first. Distinct from s18_arith_add_mul_mod (add-mul-mod, different
// ops) and s14_arith_div_then_add (div-then-add).

fn main() -> i32 {
    a: u32 = 60;
    b: u32 = 40;
    c: u32 = 25;
    d: u32 = 10;
    p: u32 = a + b;       // 100
    q: u32 = p - c;       // 75
    r: u32 = q - d;       // 65
    return r;
}
