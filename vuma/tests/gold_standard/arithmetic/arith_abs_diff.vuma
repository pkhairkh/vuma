// arith_abs_diff — absolute difference: |a - b|
// Expected exit code: 5
//
// |3 - 8| = 5. Uses if/else to select the larger operand, then subtracts.

fn main() -> i32 {
    a: u32 = 3;
    b: u32 = 8;
    diff: u32 = 0;
    if a > b {
        diff = a - b;
    } else {
        diff = b - a;
    }
    return diff;
}
