// s59_arith_add_then_div.vuma — (200 + 55) / 5 = 255 / 5 = 51
// Expected exit code: 51
//
// Two-stage u32 computation: add then divide. 200 + 55 = 255;
// 255 / 5 = 51. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_add_then_sub
// (150), s58_arith_div_then_mul (120) and s58_arith_mul_then_div (35).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 55;
    c: u32 = 5;
    s: u32 = a + b;        // 255
    q: u32 = s / c;        // 51
    return q;
}
