// arith_sub_negative — result goes negative under u64 wrapping
// Expected exit code: 254
//
// Computes 1 - 3 in u64 arithmetic. With two's-complement wrapping, this
// produces 0xFFFFFFFFFFFFFFFE. The low 8 bits are 0xFE = 254.

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 3;
    diff: u64 = a - b;             // 0xFFFFFFFFFFFFFFFE
    low8: u32 = diff & 255;
    return low8;
}
