// s39_arith_div_then_add.vuma — (200 / 8) + 15 = 25 + 15 = 40
// Expected exit code: 40
//
// Two-stage u32 computation: divide then add. (200 / 8) = 25;
// 25 + 15 = 40. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s38_arith_mul_then_div
// (mul-then-div, 20) and s34_arith_div_then_add (55).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 8;
    c: u32 = 15;
    q: u32 = a / b;       // 25
    r: u32 = q + c;       // 40
    return r;
}
