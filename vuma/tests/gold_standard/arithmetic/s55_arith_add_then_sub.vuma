// s55_arith_add_then_sub.vuma — (180 + 50) - 90 = 230 - 90 = 140
// Expected exit code: 140
//
// Two-stage u32 computation: add then subtract. 180 + 50 = 230;
// 230 - 90 = 140. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s54_arith_add_then_mul
// (110) and s53_arith_add_then_mod (6).

fn main() -> i32 {
    a: u32 = 180;
    b: u32 = 50;
    c: u32 = 90;
    s: u32 = a + b;        // 230
    r: u32 = s - c;        // 140
    return r;
}
