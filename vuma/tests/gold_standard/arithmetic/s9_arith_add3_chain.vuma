// s9_arith_add3_chain.vuma — (10 + 20 + 30) = 60
// Expected exit code: 60
//
// Three-way add chain via intermediates. All values inside U8
// range. Distinct from s5_arith_quad_sum (4-operand chain) and
// s4_arith_double_add (two operands).

fn main() -> i32 {
    a: u32 = 10;
    b: u32 = 20;
    c: u32 = 30;
    t1: u32 = a + b;     // 30
    r: u32 = t1 + c;     // 60
    return r;
}
