// s86_arith_add_then_div.vuma — (200 + 50) / 25 = 250 / 25 = 10
// Expected exit code: 10
//
// Two-stage arithmetic: add then divide. 200 + 50 = 250;
// 250 / 25 = 10. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s82_arith_add_then_mul (200),
// s78_arith_add_then_div (11) and s74_arith_add_then_div (170).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 50;
    c: i32 = 25;
    s: i32 = a + b;        // 250
    r: i32 = s / c;        // 10
    return r;
}
