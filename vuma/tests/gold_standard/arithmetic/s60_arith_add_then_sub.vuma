// s60_arith_add_then_sub.vuma — (180 + 50) - 70 = 230 - 70 = 160
// Expected exit code: 160
//
// Two-stage u32 computation: add then subtract. 180 + 50 = 230;
// 230 - 70 = 160. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_add_then_sub
// (150) and s57_arith_add_then_sub (120).

fn main() -> i32 {
    a: u32 = 180;
    b: u32 = 50;
    c: u32 = 70;
    s: u32 = a + b;        // 230
    r: u32 = s - c;        // 160
    return r;
}
