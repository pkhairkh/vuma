// s53_arith_mul_then_add.vuma — (12 * 13) + 40 = 156 + 40 = 196
// Expected exit code: 196
//
// Two-stage u32 computation: multiply then add. 12 * 13 = 156;
// 156 + 40 = 196. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s49_arith_mul_then_sub
// (100) and s50_arith_mul_then_sub (76).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 13;
    c: u32 = 40;
    p: u32 = a * b;        // 156
    r: u32 = p + c;        // 196
    return r;
}
