// s46_arith_add_then_mul.vuma — (20 + 30) * 4 = 50 * 4 = 200
// Expected exit code: 200
//
// Three-stage u32 computation: add then multiply. 20 + 30 = 50;
// 50 * 4 = 200. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s42_arith_mul_add_div
// (mul-add-div, 25) and s38_arith_add_sub_mul (180).

fn main() -> i32 {
    a: u32 = 20;
    b: u32 = 30;
    c: u32 = 4;
    s: u32 = a + b;        // 50
    r: u32 = s * c;        // 200
    return r;
}
