// s66_arith_sub_then_div.vuma — (200 - 60) / 5 = 140 / 5 = 28
// Expected exit code: 28
//
// Two-stage arithmetic: subtract then divide. 200 - 60 = 140;
// 140 / 5 = 28. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s62_arith_add_then_div (50),
// s58_arith_div_then_mul (120) and s55_arith_div_then_mul (165).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 60;
    c: i32 = 5;
    d: i32 = a - b;        // 140
    r: i32 = d / c;        // 28
    return r;
}
