// s57_arith_sub_div_chain.vuma — (200 - 50) / 5 = 150 / 5 = 30
// Expected exit code: 30
//
// Two-stage u32 computation: subtract then divide. 200 - 50 = 150;
// 150 / 5 = 30. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s54_arith_sub_then_div
// (33) and s50_arith_div_then_mod (200).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 50;
    c: u32 = 5;
    s: u32 = a - b;        // 150
    r: u32 = s / c;        // 30
    return r;
}
