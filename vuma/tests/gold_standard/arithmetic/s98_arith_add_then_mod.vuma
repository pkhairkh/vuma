// s98_arith_add_then_mod.vuma — (40 + 50) % 74 = 90 % 74 = 16
// Expected exit code: 16
//
// Two-stage arithmetic: add then modulus. 40 + 50 = 90; 90 % 74 = 16.
// All operands kept as i32 locals. Straight-line arithmetic.
// Distinct from s94_arith_div_then_add (80), s90_arith_add_then_mod
// (53) and s86_arith_add_then_div (10).
fn main() -> i32 {
    a: i32 = 40;
    b: i32 = 50;
    m: i32 = 74;
    x: i32 = a + b;        // 90
    r: i32 = x % m;        // 16
    return r;
}
