// s67_arith_sub_then_mod.vuma — (200 - 35) % 80 = 165 % 80 = 5
// Expected exit code: 5
//
// Two-stage arithmetic: subtract then modulus. 200 - 35 = 165;
// 165 % 80 = 5. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s66_arith_add_then_mod (10),
// s62_arith_sub_then_add (180) and s58_arith_add_then_sub (150).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 35;
    c: i32 = 80;
    d: i32 = a - b;        // 165
    r: i32 = d % c;        // 5
    return r;
}
