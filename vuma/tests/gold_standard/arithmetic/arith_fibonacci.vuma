// arith_fibonacci — Fibonacci sequence: fib(10) = 55
// Expected exit code: 55
//
// Iterative Fibonacci: fib(0)=0, fib(1)=1, fib(n)=fib(n-1)+fib(n-2).
// fib(10) = 55.

fn main() -> i32 {
    n: u32 = 10;
    a: u32 = 0;
    b: u32 = 1;
    i: u32 = 0;
    while i < n {
        next: u32 = a + b;
        a = b;
        b = next;
        i = i + 1;
    }
    return a;
}
