// s6_arith_mul_chain_3.vuma — 3 * 4 * 5 = 60
// Expected exit code: 60
//
// Three-way multiplication chain via intermediates. All values inside
// U8 range. Distinct from s5_arith_mul_then_add3 (mul then add) and
// s4_arith_mul_then_sub.

fn main() -> i32 {
    a: u32 = 3;
    b: u32 = 4;
    c: u32 = 5;
    p1: u32 = a * b;     // 12
    p2: u32 = p1 * c;    // 60
    return p2;
}
