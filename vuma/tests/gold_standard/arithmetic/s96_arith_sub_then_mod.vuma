// s96_arith_sub_then_mod.vuma — (200 - 17) % 60 = 183 % 60 = 3
// Expected exit code: 3
//
// Two-stage arithmetic: subtract then modulo. 200 - 17 = 183;
// 183 % 60 = 3. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s94_arith_sub_then_mul (210),
// s90_arith_sub_then_div (56) and s86_arith_sub_then_mod (50).
fn main() -> i32 {
    a: i32 = 200;
    b: i32 = 17;
    c: i32 = 60;
    s: i32 = a - b;        // 183
    r: i32 = s % c;        // 3
    return r;
}
