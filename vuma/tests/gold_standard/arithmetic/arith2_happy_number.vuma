// arith2_happy_number — happy number check
// Expected exit code: 1
//
// A happy number reaches 1 under repeated sum-of-squares-of-digits.
// 1 → 1² = 1 (fixed point) → happy.
// We compute one iteration (1 → 1), confirm sum == n, return 1.
// Straight-line code only.

fn main() -> i32 {
    n: u32 = 1;
    // One happy iteration: sum of squares of digits
    d: u32 = n % 10;        // 1
    sq: u32 = d * d;         // 1
    diff: u32 = sq - n;      // 0 (1 is a fixed point)
    one: u32 = 1;
    is_happy: u32 = one - diff;   // 1 - 0 = 1
    return is_happy;
}
