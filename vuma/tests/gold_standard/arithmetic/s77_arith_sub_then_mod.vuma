// s77_arith_sub_then_mod.vuma — (240 - 17) % 77 = 223 % 77 = 69
// Expected exit code: 69
//
// Two-stage arithmetic: subtract then modulus. 240 - 17 = 223;
// 223 % 77 = 69 (223 = 2*77 + 69). All operands kept as i32
// locals. Straight-line arithmetic. Distinct from s70_arith_sub_
// then_mul (220), s66_arith_sub_then_mul (140) and s74_arith_
// add_then_div (17).

fn main() -> i32 {
    a: i32 = 240;
    b: i32 = 17;
    c: i32 = 77;
    d: i32 = a - b;        // 223
    r: i32 = d % c;        // 69
    return r;
}
