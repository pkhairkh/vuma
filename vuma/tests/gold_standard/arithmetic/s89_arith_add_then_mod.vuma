// s89_arith_add_then_mod.vuma — (64 + 65) % 71 = 129 % 71 = 58
// Expected exit code: 58
//
// Two-stage arithmetic: add then modulo. 64 + 65 = 129;
// 129 % 71 = 58. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s86_arith_add_then_div (10),
// s82_arith_add_then_mul (200) and s78_arith_add_then_div (11).
fn main() -> i32 {
    a: i32 = 64;
    b: i32 = 65;
    m: i32 = 71;
    s: i32 = a + b;        // 129
    r: i32 = s % m;        // 58
    return r;
}
