// s55_arith_mul_then_sub.vuma — 12 * 11 - 25 = 132 - 25 = 107
// Expected exit code: 107
//
// Two-stage u32 computation: multiply then subtract. 12 * 11 = 132;
// 132 - 25 = 107. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s54_arith_mul_then_add
// (125) and s53_arith_mul_then_add (196).

fn main() -> i32 {
    a: u32 = 12;
    b: u32 = 11;
    c: u32 = 25;
    p: u32 = a * b;        // 132
    r: u32 = p - c;        // 107
    return r;
}
