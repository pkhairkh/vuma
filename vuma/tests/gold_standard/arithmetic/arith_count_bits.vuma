// arith_count_bits — count set bits (popcount)
// Expected exit code: 7
//
// popcount(127) = popcount(0b1111111) = 7. Uses Brian Kernighan's algorithm:
// repeatedly clear the lowest set bit.

fn main() -> i32 {
    n: u32 = 127;
    zero: u32 = 0;
    count: u32 = 0;
    while n != zero {
        n = n & (n - 1);
        count = count + 1;
    }
    return count;
}
