// s33_arith_div_mod_combined.vuma — 255 / 10 = 25, 255 % 10 = 5, sum = 30
// Expected exit code: 30
//
// Deterministic test in the arithmetic category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_arith_sub_then_mod (sub-then-mod) and s26_arith_div_mod_chain (div-mod-chain, 3).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 10;
    q: u32 = a / b;          // 25
    m: u32 = a % b;          // 5
    r: u32 = q + m;          // 30
    return r;
}
