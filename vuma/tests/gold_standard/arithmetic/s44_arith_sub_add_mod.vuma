// s44_arith_sub_add_mod.vuma — ((250 - 100) + 20) % 9 = 170 % 9 = 8
// Expected exit code: 8
//
// Three-stage u32 computation: subtract, then add, then modulo.
// 250 - 100 = 150; 150 + 20 = 170; 170 % 9 = 8. All operands loaded
// into u32 variables first. Straight-line arithmetic. Distinct from
// s42_arith_div_then_mod (div-then-mod, 3) and s38_arith_mul_then_mod
// (mul-then-mod, 4).

fn main() -> i32 {
    a: u32 = 250;
    b: u32 = 100;
    c: u32 = 20;
    d: u32 = 9;
    s: u32 = a - b;       // 150
    t: u32 = s + c;       // 170
    r: u32 = t % d;       // 8
    return r;
}
