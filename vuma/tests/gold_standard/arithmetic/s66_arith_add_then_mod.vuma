// s66_arith_add_then_mod.vuma — (140 + 70) % 100 = 210 % 100 = 10
// Expected exit code: 10
//
// Two-stage arithmetic: add then modulus. 140 + 70 = 210;
// 210 % 100 = 10. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s62_arith_sub_then_add (180),
// s58_arith_mul_then_div (35) and s55_arith_mul_then_sub (107).
fn main() -> i32 {
    a: i32 = 140;
    b: i32 = 70;
    c: i32 = 100;
    s: i32 = a + b;        // 210
    r: i32 = s % c;        // 10
    return r;
}
