// s41_arith_div_sub_add.vuma - (250 / 5) - 20 + 40 = 50 - 20 + 40 = 70
// Expected exit code: 70
//
// Three-stage u32 computation: divide, then subtract, then add.
// 250 / 5 = 50; 50 - 20 = 30; 30 + 40 = 70. All operands loaded
// into u32 variables first. Straight-line arithmetic. Distinct
// from s38_arith_mul_then_div (mul-then-div, 20) and s34_arith_
// mul_then_mod (mul-then-mod).

fn main() -> i32 {
    a: u32 = 250;
    b: u32 = 5;
    c: u32 = 20;
    d: u32 = 40;
    s: u32 = a / b;       // 50
    t: u32 = s - c;       // 30
    r: u32 = t + d;       // 70
    return r;
}
