// s46_arith_sub_then_div.vuma — (250 - 10) / 8 = 240 / 8 = 30
// Expected exit code: 30
//
// Three-stage u32 computation: subtract then divide. 250 - 10 = 240;
// 240 / 8 = 30. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s42_arith_div_then_mod
// (div-then-mod, 4) and s38_arith_sub_then_mod (sub-then-mod).

fn main() -> i32 {
    a: u32 = 250;
    b: u32 = 10;
    c: u32 = 8;
    d: u32 = a - b;        // 240
    r: u32 = d / c;        // 30
    return r;
}
