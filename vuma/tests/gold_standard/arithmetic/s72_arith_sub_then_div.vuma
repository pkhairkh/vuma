// s72_arith_sub_then_div.vuma — (250 - 130) / 5 = 120 / 5 = 24
// Expected exit code: 24
//
// Two-stage arithmetic: subtract then divide. 250 - 130 = 120;
// 120 / 5 = 24. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s70_arith_sub_then_mul (220),
// s69_arith_sub_then_mod (25) and s66_arith_sub_then_mul (240).
fn main() -> i32 {
    a: i32 = 250;
    b: i32 = 130;
    c: i32 = 5;
    d: i32 = a - b;        // 120
    r: i32 = d / c;        // 24
    return r;
}
