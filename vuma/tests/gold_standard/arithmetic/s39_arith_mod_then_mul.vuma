// s39_arith_mod_then_mul.vuma — (170 % 50) * 4 = 20 * 4 = 80
// Expected exit code: 80
//
// Two-stage u32 computation: modulo then multiply. (170 % 50) = 20;
// 20 * 4 = 80. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s38_arith_sub_then_mod
// (sub-then-mod, 50) and s34_arith_mod_then_add (50).

fn main() -> i32 {
    a: u32 = 170;
    b: u32 = 50;
    c: u32 = 4;
    m: u32 = a % b;       // 20
    r: u32 = m * c;       // 80
    return r;
}
