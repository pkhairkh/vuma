// s27_arith_sub_div_chain.vuma — (200 - 50) / 10 = 150 / 10 = 15
// Expected exit code: 15
//
// SUB then DIV. 200 - 50 = 150; 150 / 10 = 15. All operands loaded into
// u32 variables first. Distinct from s26_arith_sub_then_div (different
// operands) and s22_arith_sub_then_div (different operands).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 50;
    c: u32 = 10;
    d: u32 = a - b;       // 150
    r: u32 = d / c;       // 15
    return r;
}
