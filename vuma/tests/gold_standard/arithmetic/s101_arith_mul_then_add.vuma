// s101_arith_mul_then_add.vuma — (7 * 13) + 40 = 91 + 40 = 131
// Expected exit code: 131
//
// Two-stage arithmetic: multiply then add. 7 * 13 = 91; 91 + 40
// = 131. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s98_arith_mul_then_sub (17),
// s97_arith_mod_then_mul (68) and s94_arith_mul_then_mod (43).
fn main() -> i32 {
    a: i32 = 7;
    b: i32 = 13;
    c: i32 = 40;
    p: i32 = a * b;        // 91
    r: i32 = p + c;        // 131
    return r;
}
