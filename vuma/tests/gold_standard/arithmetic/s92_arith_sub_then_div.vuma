// s92_arith_sub_then_div.vuma — (250 - 10) / 6 = 240 / 6 = 40
// Expected exit code: 40
//
// Two-stage arithmetic: subtract then divide. 250 - 10 = 240;
// 240 / 6 = 40. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s90_arith_sub_then_div (56),
// s86_arith_sub_then_div (180) and s82_arith_sub_then_div (15).
fn main() -> i32 {
    a: i32 = 250;
    b: i32 = 10;
    c: i32 = 6;
    s: i32 = a - b;        // 240
    r: i32 = s / c;        // 40
    return r;
}
