// s14_arith_mul_then_div.vuma — (15 * 6) / 5 = 90 / 5 = 18
// Expected exit code: 18
//
// Two-stage computation: multiply then divide. (15 * 6) = 90;
// 90 / 5 = 18. All operands loaded into u32 variables first.
// Distinct from s10_arith_div_then_mul (div-then-mul) and
// s4_arith_double_add (two-way sum).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 6;
    c: u32 = 5;
    p: u32 = a * b;       // 90
    r: u32 = p / c;       // 18
    return r;
}
