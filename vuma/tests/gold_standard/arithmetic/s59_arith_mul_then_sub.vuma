// s59_arith_mul_then_sub.vuma — (15 * 12) - 40 = 180 - 40 = 140
// Expected exit code: 140
//
// Two-stage u32 computation: multiply then subtract. 15 * 12 = 180;
// 180 - 40 = 140. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s58_arith_add_then_sub
// (150), s58_arith_div_then_mul (120) and s58_arith_mul_then_div (35).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 12;
    c: u32 = 40;
    p: u32 = a * b;        // 180
    r: u32 = p - c;        // 140
    return r;
}
