// s9_arith_div_then_mul.vuma — (200 / 4) * 3 = 50 * 3 = 150
// Expected exit code: 150
//
// Division first (200 / 4 = 50), then multiply by 3 -> 150. All
// values inside U8 range. Distinct from s4_arith_mul_then_sub
// (mul-then-sub) and s4_arith_div_chain (two divisions).

fn main() -> i32 {
    a: u32 = 200;
    b: u32 = 4;
    c: u32 = 3;
    d: u32 = a / b;       // 50
    e: u32 = d * c;       // 150
    return e;
}
