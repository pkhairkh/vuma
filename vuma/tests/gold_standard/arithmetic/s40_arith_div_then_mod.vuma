// s40_arith_div_then_mod.vuma — (224 / 7) % 13 = 32 % 13 = 6
// Expected exit code: 6
//
// Two-stage u32 computation: divide then modulo. (224 / 7) = 32;
// 32 % 13 = 6. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s38_arith_mul_then_div
// (20) and s34_arith_div_then_add (55).

fn main() -> i32 {
    a: u32 = 224;
    b: u32 = 7;
    c: u32 = 13;
    q: u32 = a / b;       // 32
    r: u32 = q % c;       // 6
    return r;
}
