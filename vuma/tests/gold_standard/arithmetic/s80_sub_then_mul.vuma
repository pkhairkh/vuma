// s80_arith_sub_then_mul.vuma — (32 - 1) * 2 = 31 * 2 = 62
// Expected exit code: 62
//
// Two-stage arithmetic: subtract then multiply. 32 - 1 = 31;
// 31 * 2 = 62. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s78_arith_sub_then_mul (78),
// s74_arith_mod_then_add (130) and s73_arith_div_then_sub (190).
fn main() -> i32 {
    a: i32 = 32;
    b: i32 = 1;
    c: i32 = 2;
    d: i32 = a - b;        // 31
    r: i32 = d * c;        // 62
    return r;
}
