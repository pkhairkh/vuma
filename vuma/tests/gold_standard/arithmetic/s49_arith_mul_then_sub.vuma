// s49_arith_mul_then_sub.vuma — (15 * 10) - 50 = 150 - 50 = 100
// Expected exit code: 100
//
// Two-stage u32 computation: multiply then subtract. 15 * 10 = 150;
// 150 - 50 = 100. All operands loaded into u32 variables first.
// Straight-line arithmetic. Distinct from s46_arith_add_then_mul
// (200, add-then-mul) and s42_arith_mul_add_div (25, mul-add-div).

fn main() -> i32 {
    a: u32 = 15;
    b: u32 = 10;
    c: u32 = 50;
    p: u32 = a * b;        // 150
    r: u32 = p - c;        // 100
    return r;
}
