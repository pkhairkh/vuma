// s69_arith_sub_then_mod.vuma -- (250 - 30) % 195 = 220 % 195 = 25
// Expected exit code: 25
//
// Two-stage arithmetic: subtract then modulo. 250 - 30 = 220;
// 220 % 195 = 25. All operands kept as i32 locals. Straight-line
// arithmetic. Distinct from s66_arith_sub_then_div (28), s65_arith_
// mul_then_sub (80) and s64_arith_sub_then_div (60).
fn main() -> i32 {
    a: i32 = 250;
    b: i32 = 30;
    c: i32 = 195;
    d: i32 = a - b;        // 220
    r: i32 = d % c;        // 25
    return r;
}
