// s30_arith_sub_then_mod.vuma — (180 - 35) % 50 = 145 % 50 = 45
// Expected exit code: 45
//
// Two-stage u32 computation: subtract then modulo. 180 - 35 = 145;
// 145 % 50 = 45. All operands loaded into u32 variables first.
// Distinct from s26_arith_div_mod_chain (div-mod chain, 32) and
// s22_arith_sub_then_div (sub-then-div).

fn main() -> i32 {
    a: u32 = 180;
    b: u32 = 35;
    c: u32 = 50;
    d: u32 = a - b;       // 145
    r: u32 = d % c;       // 45
    return r;
}
