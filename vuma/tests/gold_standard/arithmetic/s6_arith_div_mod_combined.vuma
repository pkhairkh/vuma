// s6_arith_div_mod_combined.vuma — (98 / 7) + (98 % 11) = 14 + 10 = 24
// Expected exit code: 24
//
// Same dividend (98). Divide by 7 -> 14. Modulo 11 -> 10 (since
// 11 * 8 = 88, 98 - 88 = 10). Sum = 24. Distinct from s5_arith_div_then_mod
// (different dividend / divisors) and s4_arith_div_chain.

fn main() -> i32 {
    n: u32 = 98;
    d1: u32 = 7;
    d2: u32 = 11;
    q: u32 = n / d1;       // 14
    r: u32 = n % d2;       // 10
    s: u32 = q + r;        // 24
    return s;
}
