// s18_ptr_single_store_load.vuma — store 67, load 67
// Expected exit code: 67
//
// Single 8-byte cell. Store literal 67, load back, return. Most
// basic store-load round trip via pointer. Distinct from
// s14_ptr_single_store_load (value 88) and s10_ptr_alias_load
// (alias framing, value 55).

fn main() -> i32 {
    p = allocate(8);
    *p = 67;
    v: i32 = *p;
    free(p);
    return v;
}
