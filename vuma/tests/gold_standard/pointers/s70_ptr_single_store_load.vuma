// s70_ptr_single_store_load.vuma — store 100, load 100
// Expected exit code: 100
//
// Single 8-byte cell. Store 100 via `*p = literal`, load and
// return 100. Uses `*ptr = literal` form. Distinct from s66_ptr_
// single_store_load (195), s65_ptr_single_store_load (178) and
// s62_ptr_single_store_load (165).
fn main() -> i32 {
    p = allocate(8);
    *p = 100;
    r: i32 = *p;
    free(p);
    return r;
}
