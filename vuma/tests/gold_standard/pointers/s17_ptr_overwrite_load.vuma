// s17_ptr_overwrite_load.vuma — store 5 then 75, load = 75
// Expected exit code: 75
//
// Single 8-byte cell. Store literal 5, then overwrite with literal 75
// (last write wins). Load and return 75. Uses `*p = literal` form.
// Distinct from s14_ptr_overwrite_via_workaround (uses workaround form)
// and s9_ptr_overwrite_via_workaround (different values).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 75;
    v: i32 = *p;
    free(p);
    return v;
}
