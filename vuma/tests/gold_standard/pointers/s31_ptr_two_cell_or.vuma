// s31_ptr_two_cell_or.vuma — two cells, or = 153 (0x11 | 0x88 = 0x99)
// Expected exit code: 153
//
// Two 8-byte cells. Store 0x11/0x88 via `*ptr = literal`, load both,
// OR -> 0x99 = 153. Uses `*ptr = literal` form (no offsets). All
// operands loaded into typed locals before the OR. Distinct from
// s30_ptr_two_cell_xor (xor, 102) and s26_ptr_two_cell_or (different
// pair).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 17;             // 0x11
    *p2 = 136;            // 0x88
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a | b;       // 0x99 = 153
    free(p1);
    free(p2);
    return d;
}
