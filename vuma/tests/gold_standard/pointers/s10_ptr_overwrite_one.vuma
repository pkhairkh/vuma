// s10_ptr_overwrite_one.vuma — store 10 then overwrite with 70, load = 70
// Expected exit code: 70
//
// Single 8-byte cell. Store 10, then overwrite with 70 via `*ptr`
// form (deterministic). Load returns 70 (last write wins). Distinct
// from s4_ptr_overwrite_chain (3 overwrites) and s6_ptr_alias_two
// (alias-based overwrite).

fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    *p = 70;
    v: i32 = *p;
    free(p);
    return v;
}
