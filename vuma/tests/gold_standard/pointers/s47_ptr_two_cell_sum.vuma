// s47_ptr_two_cell_sum.vuma — two cells, sum = 220 (105 + 115)
// Expected exit code: 220
//
// Two 8-byte cells. Store 105/115 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form. Distinct from s46_ptr_
// two_cell_diff (120) and s42_ptr_two_cell_sum (230).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 105;
    *p2 = 115;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
