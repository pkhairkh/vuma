// s60_ptr_two_cell_sum.vuma — two cells, sum = 210 (115 + 95)
// Expected exit code: 210
//
// Two 8-byte cells. Store 115/95 via `*ptr = literal`, load both,
// sum -> 210. Uses `*ptr = literal` form. Distinct from s58_ptr_
// two_cell_sum (190) and s57_ptr_two_cell_sum (235).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 115;
    *p2 = 95;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 210
    free(p1);
    free(p2);
    return s;
}
