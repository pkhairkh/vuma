// s44_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 165
// Expected exit code: 165
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 165 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 165 (the overwritten value). Distinct from s42_ptr_
// var_plus_zero_store (145) and s38_ptr_var_plus_zero_store (135).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 165;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
