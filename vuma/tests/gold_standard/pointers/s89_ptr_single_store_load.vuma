// s89_ptr_single_store_load.vuma — store 41, load = 41
// Expected exit code: 41
//
// Single 8-byte cell. Store 41 via `*p = literal`, load, return
// 41. Uses `*p = literal` form. Distinct from
// s86_ptr_single_store_load (235), s82_ptr_single_store_load (200)
// and s78_ptr_single_store_load (3).
fn main() -> i32 {
    p = allocate(8);
    *p = 41;
    r: i32 = *p;
    free(p);
    return r;
}
