// s19_ptr_basic_store_load.vuma — store 67, load, return 67
// Expected exit code: 67
//
// Single 8-byte cell. Store 67 via `*ptr = literal`, load it back,
// return 67. Round-trip a single literal through a pointer. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s18_ptr_single_store_load (value 29) and s14_ptr_single_store_load
// (value 17).

fn main() -> i32 {
    p = allocate(8);
    *p = 67;
    a: u64 = *p;
    free(p);
    return a;
}
