// ptr_xor_exchange.vuma — XOR-swap two values via buffers
// Expected exit code: 1
//
// Stores 1 in buf_a and 2 in buf_b (each at offset 0 via *buf), then
// XOR-swaps their contents in registers (a = a^b; b = a^b; a = a^b)
// without a temp variable. Writes the swapped values back to the
// buffers and returns *b (which now holds 1).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *a = 1;
    *b = 2;
    va: i32 = *a;
    vb: i32 = *b;
    va = va ^ vb;
    vb = va ^ vb;
    va = va ^ vb;
    *a = va;
    *b = vb;
    result: i32 = *b;
    free(a);
    free(b);
    return result;
}
