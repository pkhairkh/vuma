// s49_ptr_single_store_load.vuma — store 158, load 158
// Expected exit code: 158
//
// Single 8-byte cell. Store 158 via `*p = literal`, load and return
// 158. Uses `*ptr = literal` form. Distinct from s48_ptr_single_
// store_load (165) and s46_ptr_single_store_load (165).

fn main() -> i32 {
    p = allocate(8);
    *p = 158;
    r: i32 = *p;
    free(p);
    return r;
}
