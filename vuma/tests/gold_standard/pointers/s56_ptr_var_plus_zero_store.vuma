// s56_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 225
// Expected exit code: 225
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 225 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 225 (the overwritten value).
// Distinct from s54_ptr_var_plus_zero_store (235) and s50_ptr_var_
// plus_zero_store (185).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 225;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
