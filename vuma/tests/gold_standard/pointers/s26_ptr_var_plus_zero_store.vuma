// s26_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 75
// Expected exit code: 75
//
// Single 8-byte cell. Store literal 7 via `*p = 7`. Load 75 into a local,
// then overwrite the cell via `*p = variable + 0` (the documented
// workaround for the silent-drop bug on `*p = variable`). Load and
// return 75 (the overwritten value). Distinct from
// s22_ptr_overwrite_via_workaround (different value) and
// s16_ptr_var_plus_zero_store (value 180).

fn main() -> i32 {
    p = allocate(8);
    *p = 7;
    v: i32 = 75;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
