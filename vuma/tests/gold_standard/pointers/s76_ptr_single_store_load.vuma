// s76_ptr_single_store_load.vuma — store 169, load = 169
// Expected exit code: 169
//
// Single 8-byte cell. Store 169 via `*p = literal`, load and
// return 169. Uses `*p = literal` form (no offsets). Distinct
// from s74_ptr_single_store_load (161), s73_ptr_single_store_
// load (149) and s72_ptr_single_store_load (130).
fn main() -> i32 {
    p = allocate(8);
    *p = 169;
    v: i32 = *p;
    free(p);
    return v;
}
