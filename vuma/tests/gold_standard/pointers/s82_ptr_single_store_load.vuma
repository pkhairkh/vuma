// s82_ptr_single_store_load.vuma — store 35, load = 35
// Expected exit code: 35
//
// Single 8-byte cell. Store 35 via `*p = literal`, load and
// return 35. Uses `*p = literal` form (no offsets). Distinct
// from s78_ptr_single_store_load (1), s74_ptr_single_store_load
// (161) and s72_ptr_single_store_load (155).
fn main() -> i32 {
    p = allocate(8);
    *p = 35;
    v: i32 = *p;
    free(p);
    return v;
}
