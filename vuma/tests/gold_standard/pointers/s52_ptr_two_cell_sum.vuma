// s52_ptr_two_cell_sum.vuma — two cells, sum = 250 (120 + 130)
// Expected exit code: 250
//
// Two 8-byte cells. Store 120/130 via `*ptr = literal`, load both,
// sum -> 250. Uses `*ptr = literal` form. Distinct from s50_ptr_two_
// cell_sum (215) and s47_ptr_two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 120;
    *p2 = 130;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 250
    free(p1);
    free(p2);
    return s;
}
