// ptr2_func_load.vuma — main stores 42; function loads and returns
// Expected exit code: 42
//
// main allocates an 8-byte buffer, stores the literal 42 at offset 0
// via *buf, then passes the Address to a helper that loads the value
// back and returns it. main frees the buffer and returns the helper's
// result. Verifies that a caller-side store is visible inside a
// callee through a passed-in Address.

fn load_val(p: Address) -> i32 {
    v: i32 = *p;
    return v;
}

fn main() -> i32 {
    buf = allocate(8);
    *buf = 42;
    val: i32 = load_val(buf);
    free(buf);
    return val;
}
