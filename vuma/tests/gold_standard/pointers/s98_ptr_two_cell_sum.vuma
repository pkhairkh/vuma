// s98_ptr_two_cell_sum.vuma — two cells, sum = 79 (40 + 39)
// Expected exit code: 79
//
// Two 8-byte cells. Store 40/39 via `*ptr = literal`, load both,
// a + b -> 79. Uses `*ptr = literal` form (no offsets). Distinct
// from s94_ptr_two_cell_sum (130), s90_ptr_two_cell_diff (28) and
// s86_ptr_two_cell_diff (215).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 40;
    *p2 = 39;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 79
    free(p1);
    free(p2);
    return s;
}
