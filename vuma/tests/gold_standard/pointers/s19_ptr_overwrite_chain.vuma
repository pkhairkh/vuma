// s19_ptr_overwrite_chain.vuma — store 50 -> 100 -> 25, load 25
// Expected exit code: 25
//
// Single 8-byte cell. Store 50, overwrite with 100, overwrite with 25.
// Load -> 25 (last write wins). Uses `*ptr = literal` form (no
// offsets). Distinct from s18_ptr_overwrite_via_workaround (two
// overwrites) and s14_ptr_overwrite_via_workaround (different values).

fn main() -> i32 {
    p = allocate(8);
    *p = 50;
    *p = 100;
    *p = 25;
    a: u64 = *p;
    free(p);
    return a;
}
