// ptr_store_struct.vuma — store 3 "struct fields", load and sum
// Expected exit code: 6
//
// Simulates a 3-field struct (a=1, b=2, c=3) by storing each field in
// its own buffer at offset 0 via *buf, then loading all three and
// summing. Sum = 1 + 2 + 3 = 6.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *a = 1;
    *b = 2;
    *c = 3;
    va: i32 = *a;
    vb: i32 = *b;
    vc: i32 = *c;
    sum: i32 = va + vb + vc;
    free(a);
    free(b);
    free(c);
    return sum;
}
