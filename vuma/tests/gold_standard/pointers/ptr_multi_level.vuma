// ptr_multi_level.vuma — 3-level pointer chain
// Expected exit code: 3
//
// Creates a 3-buffer pointer chain: buf1 -> buf2 -> buf3. Stores 3 at
// the end (buf3, at offset 0 via *buf). Loads ***buf1 to retrieve the
// value (dereferencing through buf1 -> buf2 -> buf3 -> 3).
//
// NOTE: This is a gold-standard SPEC test. It exercises the
// address-of + multi-level deref codegen path, which is NOT yet
// supported on x86_64 (no AddressOf lowering; the Store IR hardcodes
// U8 width, truncating 64-bit addresses). The binary will likely
// crash today; the test will turn green once the codegen for
// AddressOf / wider stores / multi-level deref is implemented.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    buf3 = allocate(8);
    *buf1 = buf2;
    *buf2 = buf3;
    *buf3 = 3;
    val: i32 = ***buf1;
    free(buf1);
    free(buf2);
    free(buf3);
    return val;
}
