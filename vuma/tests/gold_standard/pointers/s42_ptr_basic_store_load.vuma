// s42_ptr_basic_store_load.vuma — store 75, load 75
// Expected exit code: 75
//
// Single 8-byte cell. Store 75 via `*p = literal`, load and return
// 75. Uses `*ptr = literal` form. Distinct from s38_ptr_single_
// store_load (135) and s34_ptr_single_store_load (113).

fn main() -> i32 {
    p = allocate(8);
    *p = 75;
    r: i32 = *p;
    free(p);
    return r;
}
