// ptr_round_trip.vuma — round-trip store/load across two buffers
// Expected exit code: 123
//
// Stores 123 in buf1 (at offset 0 via *buf), loads it back into v1,
// stores v1 in buf2, loads buf2 into v2, and returns v2. Verifies
// that a value survives a double round-trip through pointer
// stores/loads across two distinct buffers.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    *buf1 = 123;
    v1: i32 = *buf1;
    *buf2 = v1;
    v2: i32 = *buf2;
    free(buf1);
    free(buf2);
    return v2;
}
