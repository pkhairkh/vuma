// s80_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 49
// Expected exit code: 49
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 49
// into a local, then overwrite the cell via `*p = variable + 0`
// (the documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 49 (the overwritten value).
// Distinct from s78_ptr_var_plus_zero_store (3),
// s74_ptr_var_plus_zero_store (245) and s73_ptr_var_plus_zero_
// store (119).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 49;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
