// s31_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 99
// Expected exit code: 99
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 99 into a local,
// then overwrite the cell via `*p = variable + 0` (the documented
// workaround for the silent-drop bug on `*p = variable`). Load and
// return 99 (the overwritten value). Distinct from
// s30_ptr_var_plus_zero_store (value 91) and s26_ptr_var_plus_zero_store
// (value 75).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 99;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
