// s12_ptr_var_plus_zero_overwrite.vuma — store 30, overwrite via var+0 = 180
// Expected exit code: 180
//
// Single 8-byte cell. Store literal 30 via `*p = 30`. Load 180 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 180 (the overwritten value). Distinct from
// s9_ptr_overwrite_via_workaround (values 10/20) and
// s13_ptr_var_plus_zero_roundtrip (round-trip, no overwrite).

fn main() -> i32 {
    p = allocate(8);
    *p = 30;
    v: i32 = 180;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
