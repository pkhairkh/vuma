// s91_ptr_single_store_load.vuma — store 44, load = 44
// Expected exit code: 44
//
// Single 8-byte cell. Store 44 via `*ptr = literal`, load and
// return 44. Uses `*ptr = literal` form. Distinct from s90_ptr_
// single_store_load (45), s86_ptr_single_store_load (240) and
// s82_ptr_single_store_load (195).
fn main() -> i32 {
    p = allocate(8);
    *p = 44;
    r: i32 = *p;
    free(p);
    return r;
}
