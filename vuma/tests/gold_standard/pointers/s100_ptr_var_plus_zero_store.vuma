// s100_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 22
// Expected exit code: 22
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 22
// into a local, then overwrite the cell via `*p = variable +
// 0` (the documented workaround for the silent-drop bug on
// `*p = variable`). Load and return 22 (the overwritten
// value).
// Distinct from s97_ptr_var_plus_zero_store (13), s94_ptr_var_plus_zero_store (117), s90_ptr_var_plus_zero_store (46).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 22;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
