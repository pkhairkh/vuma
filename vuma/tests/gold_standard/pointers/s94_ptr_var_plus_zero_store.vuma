// s94_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 117
// Expected exit code: 117
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 117 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 117 (the overwritten value). Distinct
// from s90_ptr_var_plus_zero_store (46), s86_ptr_var_plus_zero_
// store (190) and s82_ptr_var_plus_zero_store (95).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 117;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
