// s9_ptr_single_store_load.vuma — store 44, load 44
// Expected exit code: 44
//
// Single 8-byte cell. Store literal 44, load back, return. Most
// basic store-load round trip via pointer. Distinct from
// s4_ptr_basic_store_load (value 42) and s6_ptr_store_load_basic
// (value 55).

fn main() -> i32 {
    p = allocate(8);
    *p = 44;
    v: i32 = *p;
    free(p);
    return v;
}
