// s41_ptr_single_store_load.vuma - store 155, load = 155
// Expected exit code: 155
//
// Single 8-byte cell. Store 155 via `*p = literal`, load and return
// 155. Uses `*p = literal` form (no offsets). Distinct from s34_ptr_
// single_store_load (145) and s30_ptr_single_store_load.

fn main() -> i32 {
    p = allocate(8);
    *p = 155;
    r: i32 = *p;
    free(p);
    return r;
}
