// s28_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 88
// Expected exit code: 88
//
// Single 8-byte cell. Store literal 7 via `*p = 7`. Load 88 into a local,
// then overwrite the cell via `*p = variable + 0` (the documented
// workaround for the silent-drop bug on `*p = variable`). Load and
// return 88 (the overwritten value). Distinct from
// s26_ptr_var_plus_zero_store (value 75) and s22_ptr_overwrite_via_workaround
// (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 7;
    v: i32 = 88;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
