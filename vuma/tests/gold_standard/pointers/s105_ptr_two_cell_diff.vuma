// s105_ptr_two_cell_diff.vuma — store 250, 41 in 2 cells, 250-41 = 209
// Expected exit code: 209
// 
// Two 8-byte cells. Store 250 at p1, store 41 at p2, load each, return 250 - 41 = 209. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ptr_two_cell_diff (127), s101_ptr_two_cell_or (192), s100_ptr_two_cell_sum (37).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 250;
    *p2 = 41;
    a: i32 = *p1;          // 250
    b: i32 = *p2;          // 41
    d: i32 = a - b;        // 209
    free(p1);
    free(p2);
    return d;
}
