// s64_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 173
// Expected exit code: 173
//
// Single 8-byte cell. Store literal 9 via `*p = 9`. Load 173 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 173 (the overwritten value). Distinct from s51_ptr_
// var_plus_zero_store (172), s58_ptr_var_plus_zero_store (205), s55_ptr_
// var_plus_zero_store (172) and s62_ptr_var_plus_zero_store (188).

fn main() -> i32 {
    p = allocate(8);
    *p = 9;
    v: i32 = 173;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
