// s33_ptr_basic_store_load.vuma — store 88, load = 88
// Expected exit code: 88
//
// Deterministic test in the pointers category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_ptr_single_store_load (value 175) and s26_ptr_single_store_load (different value).
fn main() -> i32 {
    p = allocate(8);
    *p = 88;
    r: i32 = *p;
    free(p);
    return r;
}
