// s46_ptr_two_cell_diff.vuma — two cells, diff = 120 (190 - 70)
// Expected exit code: 120
//
// Two 8-byte cells. Store 190/70 via `*ptr = literal`, load both,
// subtract -> 120. Uses `*ptr = literal` form. Distinct from s42_
// ptr_two_cell_sum (230) and s38_ptr_two_cell_diff (40).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 190;
    *p2 = 70;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 120
    free(p1);
    free(p2);
    return d;
}
