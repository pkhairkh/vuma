// s20_ptr_overwrite_load.vuma — store 6 then 66, load = 66
// Expected exit code: 66
//
// Single 8-byte cell. Store literal 6, then overwrite with literal 66
// (last write wins). Load and return 66. Uses `*p = literal` form.
// Distinct from s18_ptr_single_store_load (single store) and
// s14_ptr_overwrite_via_workaround (uses workaround form).

fn main() -> i32 {
    p = allocate(8);
    *p = 6;
    *p = 66;
    v: i32 = *p;
    free(p);
    return v;
}
