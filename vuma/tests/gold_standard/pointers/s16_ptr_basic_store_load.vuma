// s16_ptr_basic_store_load.vuma — single cell, store 73, load = 73
// Expected exit code: 73
//
// Single 8-byte cell. Store 73 via `*p = 73`, load it back, return 73.
// Uses `*p = literal` form (no offsets) to avoid the *(ptr+N) store-drop
// bug. Distinct from s14_ptr_single_store_load (value 42) and
// s4_ptr_basic_store_load (value 100).

fn main() -> i32 {
    p = allocate(8);
    *p = 73;
    v: i32 = *p;
    free(p);
    return v;
}
