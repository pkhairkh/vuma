// s101_ptr_single_store_load.vuma — store 67, load = 67
// Expected exit code: 67
//
// Single 8-byte cell. Store 67 via `*ptr = literal`, load and
// return 67. Uses `*ptr = literal` form. Distinct from
// s98_ptr_single_store_load (78), s97_ptr_single_store_load (4)
// and s94_ptr_single_store_load (68).
fn main() -> i32 {
    p = allocate(8);
    *p = 67;
    r: i32 = *p;
    free(p);
    return r;
}
