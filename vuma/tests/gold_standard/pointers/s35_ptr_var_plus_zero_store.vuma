// s35_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 137
// Expected exit code: 137
//
// Single 8-byte cell. Store literal 12 via `*p = 12`. Load 137 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 137 (the overwritten value).
// Distinct from s34_ptr_var_plus_zero_store (value 113) and s30_ptr_
// var_plus_zero_store (value 91).

fn main() -> i32 {
    p = allocate(8);
    *p = 12;
    v: i32 = 137;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
