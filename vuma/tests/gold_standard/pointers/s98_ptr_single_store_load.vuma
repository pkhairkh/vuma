// s98_ptr_single_store_load.vuma — store 78, load = 78
// Expected exit code: 78
//
// Single 8-byte cell. Store 78 via `*ptr = literal`, load and
// return 78. Uses `*ptr = literal` form. Distinct from
// s94_ptr_single_store_load (68), s90_ptr_single_store_load (45)
// and s86_ptr_single_store_load (180).
fn main() -> i32 {
    p = allocate(8);
    *p = 78;
    r: i32 = *p;
    free(p);
    return r;
}
