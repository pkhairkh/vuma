// s52_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 205
// Expected exit code: 205
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 205 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 205 (the overwritten value).
// Distinct from s50_ptr_var_plus_zero_store (188) and s46_ptr_var_
// plus_zero_store (175).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 205;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
