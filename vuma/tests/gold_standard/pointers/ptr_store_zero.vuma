// ptr_store_zero.vuma — store and load zero
// Expected exit code: 0
//
// Stores 0 at offset 0 via *buf, loads it back, returns. Verifies
// that zero round-trips through a pointer store/load correctly
// (no accidental sign-extension or stuck-bit issues).

fn main() -> i32 {
    buf = allocate(8);
    *buf = 0;
    val: i32 = *buf;
    free(buf);
    return val;
}
