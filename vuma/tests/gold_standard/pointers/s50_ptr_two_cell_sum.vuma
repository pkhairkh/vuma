// s50_ptr_two_cell_sum.vuma — two cells, sum = 215 (95 + 120)
// Expected exit code: 215
//
// Two 8-byte cells. Store 95/120 via `*ptr = literal`, load both,
// sum -> 215. Uses `*ptr = literal` form. Distinct from s46_ptr_two_
// cell_diff (120) and s43_ptr_two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 120;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 215
    free(p1);
    free(p2);
    return s;
}
