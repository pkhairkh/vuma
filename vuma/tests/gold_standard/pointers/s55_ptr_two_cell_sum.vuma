// s55_ptr_two_cell_sum.vuma — two cells, sum = 255 (90 + 165)
// Expected exit code: 255
//
// Two 8-byte cells. Store 90/165 via `*ptr = literal`, load both,
// sum -> 255. Uses `*ptr = literal` form. Distinct from s50_ptr_two_
// cell_sum (215) and s53_ptr_two_cell_diff (150).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 165;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 255
    free(p1);
    free(p2);
    return s;
}
