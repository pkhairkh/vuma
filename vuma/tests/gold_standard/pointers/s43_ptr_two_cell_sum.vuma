// s43_ptr_two_cell_sum.vuma — two cells, sum = 220 (95 + 125)
// Expected exit code: 220
//
// Two 8-byte cells. Store 95/125 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form. Distinct from s42_ptr_
// two_cell_sum (200) and s38_ptr_two_cell_diff (95).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 125;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
