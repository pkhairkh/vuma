// s38_ptr_two_cell_diff.vuma — two cells, diff = 105 (200 - 95)
// Expected exit code: 105
//
// Two 8-byte cells. Store 200/95 via `*ptr = literal`, load both,
// subtract -> 105. Uses `*ptr = literal` form (no offsets). Distinct
// from s34_ptr_two_cell_diff (120) and s30_ptr_single_store_load.

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 95;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 105
    free(p1);
    free(p2);
    return d;
}
