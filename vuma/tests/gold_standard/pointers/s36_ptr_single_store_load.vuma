// s36_ptr_single_store_load.vuma — store 165, load = 165
// Expected exit code: 165
//
// Single 8-byte cell. Store the literal 165 via `*p =
// literal`, load it back, return 165. Uses `*p = literal`
// form (no offsets).
// Distinct from s30_ptr_single_store_load (value 0) and s27_ptr_single_store_load (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    v: i32 = *p;
    free(p);
    return v;
}
