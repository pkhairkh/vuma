// s12_ptr_overwrite_three_times.vuma — store 5, 50, 200; load = 200
// Expected exit code: 200
//
// Single 8-byte cell. Three sequential literal overwrites via
// `*p = literal` form (5 -> 50 -> 200). Load returns 200 (last write
// wins). Deterministic on the current backend. Distinct from
// s10_ptr_overwrite_one (two overwrites 10/70) and
// s4_ptr_overwrite_chain (three overwrites 11/22/99).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 50;
    *p = 200;
    v: i32 = *p;
    free(p);
    return v;
}
