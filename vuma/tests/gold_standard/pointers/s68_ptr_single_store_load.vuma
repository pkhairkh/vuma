// s68_ptr_single_store_load.vuma — store 168, load 168
// Expected exit code: 168
//
// Single 8-byte cell. Store 168 via `*p = literal`, load and
// return 168. Uses `*ptr = literal` form. Distinct from s62_ptr_
// single_store_load (165), s58_ptr_single_store_load (155) and
// s55_ptr_single_store_load (185).
fn main() -> i32 {
    p = allocate(8);
    *p = 168;
    r: i32 = *p;
    free(p);
    return r;
}
