// s105_ptr_single_store_load.vuma — store 109, load = 109
// Expected exit code: 109
// 
// Single 8-byte cell. Store 109 via `*p = 109`, load and return 109. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ptr_single_store_load (6), s101_ptr_single_store_load (67), s100_ptr_single_store_load (5).
fn main() -> i32 {
    p = allocate(8);
    *p = 109;
    r: i32 = *p;          // 109
    free(p);
    return r;
}
