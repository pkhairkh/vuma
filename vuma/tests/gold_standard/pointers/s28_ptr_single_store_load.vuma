// s28_ptr_single_store_load.vuma — store 137, load = 137
// Expected exit code: 137
//
// Single 8-byte cell. Store the literal 137 via `*ptr = literal`, load
// it back, return. Uses `*ptr = literal` form (no offsets). Distinct
// from s26_ptr_single_store_load (value 123) and s22_ptr_single_store_load
// (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 137;
    r: i32 = *p;
    free(p);
    return r;
}
