// ptr_ptr_arith.vuma — pointer access with offset variable in scope
// Expected exit code: 10
//
// Declares an offset variable (set to 0) alongside a pointer access.
// Stores 10 at the buffer's offset 0 via *buf, loads it back via
// *buf, and returns the value. Demonstrates that an offset variable
// can coexist with offset-0 pointer accesses (the safe pattern that
// avoids the *(buf + computed_offset) codegen bug).

fn main() -> i32 {
    buf = allocate(8);
    off: u32 = 0;
    *buf = 10;
    val: i32 = *buf;
    free(buf);
    return val;
}
