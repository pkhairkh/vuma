// s75_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 211
// Expected exit code: 211
//
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 211
// into a local, then overwrite the cell via `*p = variable + 0`
// (the documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 211 (the overwritten value).
// Distinct from s74_ptr_var_plus_zero_store (223), s70_ptr_var_
// plus_zero_store (235) and s66_ptr_var_plus_zero_store (215).
fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 211;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
