// s58_ptr_two_cell_sum.vuma — two cells, sum = 190 (100 + 90)
// Expected exit code: 190
// 
// Two 8-byte cells. Store 100/90 via `*ptr = literal`, load both,
// sum -> 190. Uses `*ptr = literal` form. Distinct from s51_ptr_
// single_store_load (142), s51_ptr_two_cell_diff (70) and s51_ptr_
// var_plus_zero_store (172).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 90;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 190
    free(p1);
    free(p2);
    return s;
}
