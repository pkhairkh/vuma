// s89_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 47
// Expected exit code: 47
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 47
// into a local, then overwrite the cell via `*p = variable + 0`
// (the documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 47 (the overwritten value).
// Distinct from s86_ptr_var_plus_zero_store (190), s82_ptr_var_
// plus_zero_store (95) and s74_ptr_var_plus_zero_store (245).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 47;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
