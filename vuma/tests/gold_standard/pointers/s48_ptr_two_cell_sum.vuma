// s48_ptr_two_cell_sum.vuma — two cells, sum = 200 (70 + 130)
// Expected exit code: 200
//
// Two 8-byte cells. Store 70/130 via `*ptr = literal`, load both,
// sum -> 200. Uses `*ptr = literal` form. Distinct from s46_ptr_
// two_cell_diff (120) and s42_ptr_two_cell_sum (230).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 70;
    *p2 = 130;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 200
    free(p1);
    free(p2);
    return s;
}
