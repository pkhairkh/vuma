// s27_ptr_single_store_load.vuma — store 42, load = 42
// Expected exit code: 42
//
// Single 8-byte cell. Store the literal 42 via `*ptr = literal`, load it
// back, return. Uses `*ptr = literal` form (no offsets). Distinct from
// s26_ptr_single_store_load (different value, 123) and
// s22_ptr_single_store_load (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 42;
    r: i32 = *p;
    free(p);
    return r;
}
