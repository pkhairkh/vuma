// s13_ptr_var_plus_zero_roundtrip.vuma — store 44, load, store back via workaround = 44
// Expected exit code: 44
//
// Single 8-byte cell. Store literal 44 via `*p = 44`, load it into a
// local, then store that local back via the documented
// `*p = variable + 0` workaround (plain `*p = variable` is silently
// dropped by the current backend). Load again and return -> 44.
// Exercises the workaround form as a round-trip. Distinct from
// s9_ptr_workaround_roundtrip (value 70) and s8_ptr_var_plus_zero
// (no preceding literal store).

fn main() -> i32 {
    p = allocate(8);
    *p = 44;
    tmp: i32 = *p;
    *p = tmp + 0;
    r: i32 = *p;
    free(p);
    return r;
}
