// s82_ptr_two_cell_diff.vuma — two cells, diff = 205 (230 - 25)
// Expected exit code: 205
//
// Two 8-byte cells. Store 230/25 via `*ptr = literal`, load
// both, a - b -> 205. Uses `*ptr = literal` form (no offsets).
// Distinct from s78_ptr_two_cell_diff (2), s74_ptr_two_cell_
// diff (60) and s72_ptr_two_cell_diff (40).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 230;
    *p2 = 25;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 205
    free(p1);
    free(p2);
    return d;
}
