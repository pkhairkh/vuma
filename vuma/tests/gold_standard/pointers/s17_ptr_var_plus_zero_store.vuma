// s17_ptr_var_plus_zero_store.vuma — exercise the *ptr = variable + 0 workaround
// Expected exit code: 42
//
// Allocate a cell, load a constant into a variable, store it via the
// documented `*ptr = variable + 0` workaround (the plain
// `*ptr = variable` form is silently dropped by the current backend).
// Read back and return 42. Distinct from s13_ptr_var_plus_zero_roundtrip
// (preceded by literal store) and s5_ptr_var_plus_zero_store (value 88).

fn main() -> i32 {
    p = allocate(8);
    v: i32 = 42;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
