// ptr_reuse_after_free.vuma — reuse allocation slot after free
// Expected exit code: 42
//
// Allocates buf1, frees it, then allocates buf2. Stores 42 in buf2
// (at offset 0 via *buf), loads it back. Verifies that freed memory
// can be reallocated and used normally (no use-after-free, no
// allocator corruption).

fn main() -> i32 {
    buf1 = allocate(64);
    free(buf1);
    buf2 = allocate(64);
    *buf2 = 42;
    val: i32 = *buf2;
    free(buf2);
    return val;
}
