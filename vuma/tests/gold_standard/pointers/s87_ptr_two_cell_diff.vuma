// s87_ptr_two_cell_diff.vuma — two cells, diff = 195 (235 - 40)
// Expected exit code: 195
//
// Two 8-byte cells. Store 235/40 via `*ptr = literal`, load
// both, a - b -> 195. Uses `*ptr = literal` form (no offsets).
// Distinct from s86_ptr_two_cell_diff (215), s82_ptr_two_cell_
// diff (205) and s78_ptr_two_cell_diff (2).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 235;
    *p2 = 40;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 195
    free(p1);
    free(p2);
    return d;
}
