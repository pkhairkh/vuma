// s30_ptr_single_store_load.vuma — store 145, load = 145
// Expected exit code: 145
//
// Single 8-byte cell. Store the literal 145 via `*ptr = literal`, load
// it back, return. Uses `*ptr = literal` form (no offsets). Distinct
// from s26_ptr_single_store_load (different value) and
// s22_ptr_single_store_load (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 145;
    r: i32 = *p;
    free(p);
    return r;
}
