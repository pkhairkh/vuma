// s42_ptr_two_cell_sum.vuma — two cells, sum = 230 (100 + 130)
// Expected exit code: 230
//
// Two 8-byte cells. Store 100/130 via `*ptr = literal`, load both,
// sum -> 230. Uses `*ptr = literal` form. Distinct from s38_ptr_
// two_cell_diff (40) and s34_ptr_two_cell_sum (165).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 130;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 230
    free(p1);
    free(p2);
    return s;
}
