// s61_ptr_two_cell_sum.vuma — two cells, sum = 180 (100 + 80)
// Expected exit code: 180
// 
// Two 8-byte cells. Store 100/80 via `*p = literal`, load both, sum
// -> 180. Uses `*ptr = literal` form. Distinct from s58_ptr_single
// _store_load (155), s58_ptr_two_cell_sum (190) and s58_ptr_var_
// plus_zero_store (205).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p2 = 80;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 180
    free(p1);
    free(p2);
    return s;
}
