// s65_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 170
// Expected exit code: 170
//
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 170 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 170 (the overwritten value). Distinct
// from s51_ptr_var_plus_zero_store (172), s58_ptr_var_plus_zero_store
// (205) and s62_ptr_var_plus_zero_store (188).

fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 170;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
