// s73_ptr_single_store_load.vuma — store 149, load = 149
// Expected exit code: 149
//
// Single 8-byte cell. Store 149 via `*p = literal`, load the
// cell, return 149. Uses `*p = literal` form. Distinct from
// s70_ptr_single_store_load (100), s69_ptr_single_store_load
// (225) and s66_ptr_single_store_load (195).
fn main() -> i32 {
    p = allocate(8);
    *p = 149;
    v: i32 = *p;
    free(p);
    return v;
}
