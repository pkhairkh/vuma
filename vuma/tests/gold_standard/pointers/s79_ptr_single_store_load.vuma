// s79_ptr_single_store_load.vuma — store 10, load = 10
// Expected exit code: 10
//
// Single 8-byte cell. Store 10 via `*p = literal`, load and
// return 10. Uses `*p = literal` form (no offsets). Distinct
// from s78_ptr_single_store_load (1), s77_ptr_single_store_load
// (2) and s76_ptr_single_store_load (3).
fn main() -> i32 {
    p = allocate(8);
    *p = 10;
    v: i32 = *p;
    free(p);
    return v;
}
