// s41_ptr_two_cell_diff.vuma - two cells, diff = 125 (210 - 85)
// Expected exit code: 125
//
// Two 8-byte cells. Store 210/85 via `*ptr = literal`, load both,
// subtract -> 125. Uses `*ptr = literal` form (no offsets). Distinct
// from s38_ptr_two_cell_diff (105) and s34_ptr_two_cell_diff (120).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 210;
    *p2 = 85;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 125
    free(p1);
    free(p2);
    return d;
}
