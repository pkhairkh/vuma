// s58_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 205
// Expected exit code: 205
// 
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 205 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 205 (the overwritten value). Distinct
// from s51_ptr_single_store_load (142), s51_ptr_two_cell_diff (70)
// and s51_ptr_var_plus_zero_store (172).

fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 205;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
