// s99_ptr_single_store_load.vuma — store 132, load = 132
// Expected exit code: 132
//
// Single 8-byte cell. Store 132 via `*ptr = literal`, load and
// return 132. Uses `*ptr = literal` form. Distinct from
// s95_ptr_single_store_load (27), s91_ptr_single_store_load (44)
// and s87_ptr_single_store_load (165).
fn main() -> i32 {
    p = allocate(8);
    *p = 132;
    r: i32 = *p;
    free(p);
    return r;
}
