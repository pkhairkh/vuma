// s19_ptr_two_cell_product.vuma — two cells, product = 126 (9 * 14)
// Expected exit code: 126
//
// Two 8-byte cells. Store 9/14 via `*ptr = literal`, load both,
// multiply -> 126. Uses `*ptr = literal` form (no offsets). Distinct
// from s18_ptr_two_cell_sum (29/46 = 75, sum) and
// s14_ptr_two_cell_sum (33/44 = 77, sum).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 9;
    *p2 = 14;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a * b;
    free(p1);
    free(p2);
    return s;
}
