// s9_ptr_workaround_roundtrip.vuma — store 70, load, store back via workaround = 70
// Expected exit code: 70
//
// Single 8-byte cell. Store literal 70 via `*p = 70`, load it into
// a local, then store that local back via the documented
// `*p = variable + 0` workaround (plain `*p = variable` is silently
// dropped by the current backend). Load again and return -> 70.
// Exercises the workaround form as a round-trip. Distinct from
// s5_ptr_var_plus_zero_store (value 88, no preceding literal store)
// and s4_ptr_basic_store_load (literal-only round-trip).

fn main() -> i32 {
    p = allocate(8);
    *p = 70;
    tmp: i32 = *p;
    *p = tmp + 0;
    r: i32 = *p;
    free(p);
    return r;
}
