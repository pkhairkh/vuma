// s15_ptr_two_cell_diff.vuma — two cells, diff = 66 (88 - 22)
// Expected exit code: 66
//
// Two 8-byte cells. Store 88/22 via `*ptr = literal`, load both, subtract
// -> 66. Uses `*ptr = literal` form (no offsets). Distinct from
// s14_ptr_two_cell_sum (sum framing, 33+44 = 77) and s11_ptr_two_buf_xor
// (XOR framing).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 88;
    *p2 = 22;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a - b;
    free(p1);
    free(p2);
    return s;
}
