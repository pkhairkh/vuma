// s7_ptr_offset_16_load.vuma — store 77 via ptr = p + 16, load = 77
// Expected exit code: 77
//
// Single 24-byte buffer. Compute q = p + 16 (pointer arithmetic to
// the third 8-byte slot), then store/load via `*q`. Verifies that
// pointer arithmetic + `*q` round-trips a value through offset 16.
// Distinct from s6_ptr_offset_via_var (offset 8 via variable) and
// s4_ptr_offset_store (literal offset, different value).

fn main() -> i32 {
    p = allocate(24);
    q = p + 16;
    *q = 77;
    v: i32 = *q;
    free(p);
    return v;
}
