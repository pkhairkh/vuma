// s21_ptr_overwrite_via_workaround.vuma — overwrite via *p = variable + 0 = 91
// Expected exit code: 91
//
// Single 8-byte cell. Store literal 16 via `*p = 16`. Load 91 into a
// local, then overwrite the cell via `*p = variable + 0` (the documented
// workaround for the silent-drop bug on `*p = variable`). Load and
// return 91 (the overwritten value). Distinct from
// s18_ptr_overwrite_via_workaround (13 then 84) and
// s14_ptr_overwrite_via_workaround (7 then 77).

fn main() -> i32 {
    p = allocate(8);
    *p = 16;
    v: i32 = 91;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
