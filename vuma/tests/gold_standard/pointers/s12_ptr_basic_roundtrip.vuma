// s12_ptr_basic_roundtrip.vuma — store 95, load 95
// Expected exit code: 95
//
// Single 8-byte cell. Store literal 95 via `*p = 95`, load it back,
// return 95. Most basic store-load round trip through a pointer.
// Uses `*p = literal` form (no offsets, deterministic on the current
// backend). Distinct from s9_ptr_single_store_load (value 44) and
// s13_ptr_store_load_basic (value 55).

fn main() -> i32 {
    p = allocate(8);
    *p = 95;
    v: i32 = *p;
    free(p);
    return v;
}
