// s38_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 135
// Expected exit code: 135
//
// Single 8-byte cell. Store literal 5 via `*p = 5`. Load 135 into
// a local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 135 (the overwritten value).
// Distinct from s34_ptr_var_plus_zero_store (113) and s30_ptr_var_
// plus_zero_store (91).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 135;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
