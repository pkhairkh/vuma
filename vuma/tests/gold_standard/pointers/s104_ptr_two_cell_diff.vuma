// s104_ptr_two_cell_diff.vuma — store 200, 141 in 2 cells, 200-141 = 59
// Expected exit code: 59
//
// Two 8-byte cells. Store 200 at p1, store 141 at p2, load each, return 200 - 141 = 59. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ptr_single_store_load (6), s102_ptr_two_cell_diff (127), s102_ptr_var_plus_zero_store (7).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 200;
    *p2 = 141;
    a: i32 = *p1;          // 200
    b: i32 = *p2;          // 141
    d: i32 = a - b;        // 59
    free(p1);
    free(p2);
    return d;
}
