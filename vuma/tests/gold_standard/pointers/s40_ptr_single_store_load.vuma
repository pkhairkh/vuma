// s40_ptr_single_store_load.vuma — store 215, load = 215
// Expected exit code: 215
//
// Single 8-byte cell. Store 215 via `*ptr = literal`, load and
// return 215. Uses `*ptr = literal` form (no offsets). Distinct from
// s38_ptr_single_store_load (165) and s34_ptr_single_store_load.

fn main() -> i32 {
    p = allocate(8);
    *p = 215;
    v: i32 = *p;
    free(p);
    return v;
}
