// s49_ptr_two_cell_sum.vuma — two cells, sum = 205 (115 + 90)
// Expected exit code: 205
//
// Two 8-byte cells. Store 115/90 via `*ptr = literal`, load both,
// sum -> 205. Uses `*ptr = literal` form. Distinct from s48_ptr_
// two_cell_sum (200, 70+130) and s46_ptr_two_cell_diff (120, diff).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 115;
    *p2 = 90;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
