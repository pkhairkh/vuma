// s14_ptr_single_store_load.vuma — store 88, load 88
// Expected exit code: 88
//
// Single 8-byte cell. Store literal 88, load back, return. Most
// basic store-load round trip via pointer. Distinct from
// s9_ptr_single_store_load (value 44) and s10_ptr_alias_load
// (alias framing, value 55).

fn main() -> i32 {
    p = allocate(8);
    *p = 88;
    v: i32 = *p;
    free(p);
    return v;
}
