// s106_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 87
// Expected exit code: 87
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 87 into a local, then overwrite the cell via `*p = variable + 0` (the documented workaround for the silent-drop bug on `*p = variable`). Load and return 87 (the overwritten value). Straight-line code only.
// Distinct from s102_ptr_var_plus_zero_store (7), s101_ptr_var_plus_zero_store (88), s100_ptr_var_plus_zero_store (22).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 87;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
