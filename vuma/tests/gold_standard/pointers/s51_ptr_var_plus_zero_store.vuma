// s51_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 172
// Expected exit code: 172
//
// Single 8-byte cell. Store literal 8 via `*p = 8`. Load 172 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 172 (the overwritten value).
// Distinct from s50_ptr_var_plus_zero_store (188) and s47_ptr_var_
// plus_zero_store (215).

fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    v: i32 = 172;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
