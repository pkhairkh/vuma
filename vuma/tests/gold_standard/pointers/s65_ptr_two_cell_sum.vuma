// s65_ptr_two_cell_sum.vuma — two cells, sum = 220 (135 + 85)
// Expected exit code: 220
//
// Two 8-byte cells. Store 135/85 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form (no offsets). Distinct from
// s51_ptr_two_cell_diff (70), s58_ptr_two_cell_sum (190) and s62_ptr_
// two_cell_diff (140).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 135;
    *p2 = 85;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
