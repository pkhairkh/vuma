// s95_ptr_two_cell_sum.vuma — two cells, sum = 26 (13 + 13)
// Expected exit code: 26
//
// Two 8-byte cells. Store 13/13 via `*ptr = literal`, load both,
// a + b -> 26. Uses `*ptr = literal` form (no offsets). Distinct from
// s94_ptr_two_cell_sum (130), s90_ptr_two_cell_diff (28) and
// s82_ptr_two_cell_diff (205).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 13;
    *p2 = 13;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 26
    free(p1);
    free(p2);
    return s;
}
