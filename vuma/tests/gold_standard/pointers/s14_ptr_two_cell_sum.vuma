// s14_ptr_two_cell_sum.vuma — two cells, sum = 77 (33 + 44)
// Expected exit code: 77
//
// Two 8-byte cells. Store 33/44 via `*ptr = literal`, load both,
// sum -> 77. Uses `*ptr = literal` form (no offsets). Distinct from
// s9_ptr_single_store_load (single cell) and s10_ptr_round_trip_two
// (two cells, 25/35 = 60).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 33;
    *p2 = 44;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;
    free(p1);
    free(p2);
    return s;
}
