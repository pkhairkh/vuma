// s39_ptr_single_store_load.vuma — store 145, load = 145
// Expected exit code: 145
//
// Single 8-byte cell. Store 145 via `*p = literal`, load and return
// 145. Uses `*p = literal` form (no offsets). Distinct from s34_ptr_
// single_store_load (145, same value, different set) and s38_ptr_
// single_store_load (165).

fn main() -> i32 {
    p = allocate(8);
    *p = 145;
    r: i32 = *p;
    free(p);
    return r;
}
