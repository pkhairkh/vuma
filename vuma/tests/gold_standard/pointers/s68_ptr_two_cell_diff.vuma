// s68_ptr_two_cell_diff.vuma — two cells, diff = 148 (230 - 82)
// Expected exit code: 148
//
// Two 8-byte cells. Store 230/82 via `*ptr = literal`, load both,
// diff -> 148. Uses `*ptr = literal` form. Distinct from s66_ptr_
// two_cell_sum (200), s62_ptr_two_cell_diff (140) and s58_ptr_two_
// cell_sum (190).
fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 230;
    *p2 = 82;
    a: i32 = *p1;
    b: i32 = *p2;
    d: i32 = a - b;        // 148
    free(p1);
    free(p2);
    return d;
}
