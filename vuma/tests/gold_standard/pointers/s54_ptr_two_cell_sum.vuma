// s54_ptr_two_cell_sum.vuma — two cells, sum = 245 (85 + 160)
// Expected exit code: 245
//
// Two 8-byte cells. Store 85/160 via `*ptr = literal`, load both,
// sum -> 245. Uses `*ptr = literal` form. Distinct from s50_ptr_two_
// cell_sum (215) and s49_ptr_two_cell_sum (225).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 85;
    *p2 = 160;
    a: i32 = *p1;
    b: i32 = *p2;
    s: i32 = a + b;        // 245
    free(p1);
    free(p2);
    return s;
}
