// s106_ptr_single_store_load.vuma — store 14, load = 14
// Expected exit code: 14
//
// Single 8-byte cell. Store 14 via `*ptr = literal`, load and return 14. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_ptr_single_store_load (6), s101_ptr_single_store_load (67), s100_ptr_single_store_load (5).
fn main() -> i32 {
    p = allocate(8);
    *p = 14;
    r: i32 = *p;
    free(p);
    return r;
}
