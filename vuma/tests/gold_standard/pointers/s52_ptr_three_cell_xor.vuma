// s52_ptr_three_cell_xor.vuma — three cells, XOR = 240 (60 ^ 195 ^ 15)
// Expected exit code: 240
//
// Three 8-byte cells. Store 60/195/15 via `*ptr = literal`, load all
// three, XOR -> 60 ^ 195 = 255 (0xFF); 255 ^ 15 = 240 (0xF0). All
// bitwise operands loaded into i32 variables first. Distinct from
// s50_ptr_two_cell_sum (215) and s46_ptr_two_cell_diff (120).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 60;
    *p2 = 195;
    *p3 = 15;
    a: i32 = *p1;
    b: i32 = *p2;
    c: i32 = *p3;
    x: i32 = a ^ b;        // 0xFF = 255
    r: i32 = x ^ c;        // 0xF0 = 240
    free(p1);
    free(p2);
    free(p3);
    return r;
}
