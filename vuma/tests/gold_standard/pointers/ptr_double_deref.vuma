// ptr_double_deref.vuma — double dereference through stored address
// Expected exit code: 42
//
// Allocates buf1 and buf2. Stores 42 in buf2. Stores the address of
// buf2 into buf1 (at offset 0). Then dereferences buf1 twice (**buf1)
// to read buf2's value.
//
// NOTE: This is a gold-standard SPEC test. It exercises the
// address-of + double-deref codegen path, which is NOT yet supported
// on x86_64 (there is no AddressOf lowering in
// src/codegen/src/x86_64/mod.rs and the Store IR hardcodes U8 width,
// truncating 64-bit addresses). The binary will likely crash or
// return a non-42 value today; the test will turn green once the
// codegen for AddressOf / wider stores / double-deref is implemented.

fn main() -> i32 {
    buf1 = allocate(64);
    buf2 = allocate(64);
    *buf2 = 42;
    *buf1 = buf2;
    val: i32 = **buf1;
    free(buf1);
    free(buf2);
    return val;
}
