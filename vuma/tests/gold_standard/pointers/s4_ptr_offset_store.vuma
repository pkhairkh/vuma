// s4_ptr_offset_store.vuma — store 60 at offset 8, load it back
// Expected exit code: 60
//
// 16-byte allocation; store 60 at offset 8 (skipping the first 8
// bytes), load it back from the same offset. Tests offset addressing.

fn main() -> i32 {
    p = allocate(16);
    *(p + 8) = 60;
    v: i32 = *(p + 8);
    free(p);
    return v;
}
