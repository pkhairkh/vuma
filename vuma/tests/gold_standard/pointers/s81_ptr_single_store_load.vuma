// s81_ptr_single_store_load.vuma — store 222, load = 222
// Expected exit code: 222
//
// Single 8-byte cell. Store 222 via `*p = literal`, load and
// return 222. Uses `*p = literal` form (no offsets). Distinct
// from s78_ptr_single_store_load (1),
// s77_ptr_single_store_load (194) and s76_ptr_single_store_load
// (169).
fn main() -> i32 {
    p = allocate(8);
    *p = 222;
    v: i32 = *p;
    free(p);
    return v;
}
