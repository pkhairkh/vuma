// s33_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 73
// Expected exit code: 73
//
// Deterministic test in the pointers category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_ptr_var_plus_zero_store (value 91) and s26_ptr_var_plus_zero_store (value 75).
fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    v: i32 = 73;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
