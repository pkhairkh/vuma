// ptr_store_load_u8.vuma — store/load u8 max value
// Expected exit code: 255
//
// Stores the u8 maximum (255) at offset 0 via *buf, loads it back as
// u32, and returns it. Verifies that the high bit of the byte is
// preserved through the round-trip.

fn main() -> i32 {
    buf = allocate(8);
    *buf = 255;
    val: u32 = *buf;
    free(buf);
    return val;
}
