// s59_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 245
// Expected exit code: 245
//
// Single 8-byte cell. Store literal 12 via `*p = 12`. Load 245 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p = variable`).
// Load and return 245 (the overwritten value). Distinct from s58_ptr_
// single_store_load (155), s58_ptr_two_cell_sum (190) and s58_ptr_var_
// plus_zero_store (205).

fn main() -> i32 {
    p = allocate(8);
    *p = 12;
    v: i32 = 245;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
