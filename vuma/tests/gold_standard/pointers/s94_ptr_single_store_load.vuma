// s94_ptr_single_store_load.vuma — store 68, load = 68
// Expected exit code: 68
//
// Single 8-byte cell. Store 68 via `*ptr = literal`, load and
// return 68. Uses `*ptr = literal` form. Distinct from
// s90_ptr_single_store_load (45), s86_ptr_single_store_load (180)
// and s82_ptr_single_store_load (35).
fn main() -> i32 {
    p = allocate(8);
    *p = 68;
    r: i32 = *p;
    free(p);
    return r;
}
