// s95_ptr_single_store_load.vuma — store 27, load = 27
// Expected exit code: 27
//
// Single 8-byte cell. Store 27 via `*ptr = literal`, load and
// return 27. Uses `*ptr = literal` form. Distinct from
// s94_ptr_single_store_load (68), s90_ptr_single_store_load (45) and
// s82_ptr_single_store_load (35).
fn main() -> i32 {
    p = allocate(8);
    *p = 27;
    r: i32 = *p;
    free(p);
    return r;
}
