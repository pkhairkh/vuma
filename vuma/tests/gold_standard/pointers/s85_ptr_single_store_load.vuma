// s85_ptr_single_store_load.vuma — store 56, load, return 56
// Expected exit code: 56
//
// Single 8-byte cell. Store 56 via `*ptr = literal`, load it
// back, return 56. Uses `*ptr = literal` form (no offsets) to
// avoid the *(ptr+N) store-drop bug. Distinct from
// s82_ptr_single_store_load, s78_ptr_single_store_load and
// s74_ptr_single_store_load.
fn main() -> i32 {
    p = allocate(8);
    *p = 56;
    r: i32 = *p;
    free(p);
    return r;
}
