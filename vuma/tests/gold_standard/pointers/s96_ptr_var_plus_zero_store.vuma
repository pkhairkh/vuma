// s96_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 134
// Expected exit code: 134
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load 134 into a
// local, then overwrite the cell via `*p = variable + 0` (the
// documented workaround for the silent-drop bug on `*p =
// variable`). Load and return 134 (the overwritten value). Distinct
// from s94_ptr_var_plus_zero_store (117),
// s90_ptr_var_plus_zero_store (46) and s86_ptr_var_plus_zero_store
// (190).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 134;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
