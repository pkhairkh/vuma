// s88_ptr_var_plus_zero_store.vuma — store via *p = v + 0 = 205
// Expected exit code: 205
//
// Single 8-byte cell. Store literal 1 via `*p = 1`. Load
// 205 into a local, then overwrite the cell via `*p =
// variable + 0` (the documented workaround for the silent-
// drop bug on `*p = variable`). Load and return 205 (the
// overwritten value). Distinct from s86_ptr_var_plus_zero_
// store (190), s82_ptr_var_plus_zero_store (95) and s78_
// ptr_var_plus_zero_store (3).
fn main() -> i32 {
    p = allocate(8);
    *p = 1;
    v: i32 = 205;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
