// s46_ptr_single_store_load.vuma — store 165, load 165
// Expected exit code: 165
//
// Single 8-byte cell. Store 165 via `*p = literal`, load and return
// 165. Uses `*ptr = literal` form. Distinct from s42_ptr_basic_
// store_load (75) and s38_ptr_single_store_load (135).

fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    r: i32 = *p;
    free(p);
    return r;
}
