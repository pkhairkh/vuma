// s20_ptr_var_plus_zero_store.vuma — exercise the *ptr = variable + 0 workaround
// Expected exit code: 150
//
// Allocate a cell, load a constant into a variable, store it via the
// documented `*ptr = variable + 0` workaround (the plain
// `*ptr = variable` form is silently dropped by the current backend).
// Read back and return 150. Distinct from s17_ptr_var_plus_zero_store
// (value 42) and s13_ptr_var_plus_zero_roundtrip (preceded by literal
// store).

fn main() -> i32 {
    p = allocate(8);
    v: i32 = 150;
    *p = v + 0;
    r: i32 = *p;
    free(p);
    return r;
}
