// s31_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
//
// XOR of the maximum u8 value with one. 255 ^ 1 = 254. All operands
// loaded into u32 variables first. Distinct from s30_edge_zero_xor_max
// (0 ^ 255 = 255) and s28_edge_max_xor_self (255 ^ 255 = 0).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a ^ b;       // 254
    return r;
}
