// s87_edge_max_and_low.vuma — 255 & 13 = 13
// Expected exit code: 13
//
// AND the max byte value 255 (0xFF) with the low-bit mask 13
// (0x0D). 255 & 13 = 13. All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_edge_max_and_low (9), s82_edge_max_and_seven (7) and
// s78_edge_max_and (6).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 13;           // 0x0D
    r: u32 = a & b;        // 0x0D = 13
    return r;
}
