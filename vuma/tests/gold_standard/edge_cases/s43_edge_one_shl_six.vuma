// s43_edge_one_shl_six.vuma — 1 << 6 = 64
// Expected exit code: 64
//
// Shift 1 left by 6. 1 << 6 = 64. All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s42_edge_one_shl_four (16) and s38_edge_one_shl_
// seven (128).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 6;
    r: u32 = a << b;       // 64
    return r;
}
