// s81_edge_max_xor.vuma — 255 ^ 27 = 228
// Expected exit code: 228
//
// XOR the max u8 value 255 with 27 (0x1B). 255 ^ 27 = 228
// (0xE4). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s78_edge_max_xor (250), s77_edge_max_xor_twenty (235) and
// s76_edge_max_xor_twelve (243).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 27;           // 0x1B
    r: u32 = a ^ b;        // 228
    return r;
}
