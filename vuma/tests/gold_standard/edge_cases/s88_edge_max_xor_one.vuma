// s88_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
//
// XOR the max byte value 255 (0xFF) with 1 (0x01). 255 ^ 1
// = 254 (0xFE). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_edge_zero_xor_high (250), s82_edge_zero_xor_
// high (128) and s78_edge_max_xor (250).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 1;            // 0x01
    r: u32 = a ^ b;        // 0xFE = 254
    return r;
}
