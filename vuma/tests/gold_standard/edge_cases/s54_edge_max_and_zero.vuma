// s54_edge_max_and_zero.vuma — 255 & 0 = 0
// Expected exit code: 0
//
// AND the max u8 value with zero. 255 & 0 = 0. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s50_edge_zero_or_max (255) and
// s49_edge_max_xor_self (0).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 0;
    r: u32 = a & b;        // 0
    return r;
}
