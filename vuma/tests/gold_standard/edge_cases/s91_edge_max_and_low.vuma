// s91_edge_max_and_low.vuma — 255 & 7 = 7 (AND with max keeps low bits)
// Expected exit code: 7
//
// Edge case: AND with the max byte (0xFF) is the identity. 255 & 7
// = 7 (0x07). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_edge_max_xor_val (23), s86_edge_max_and_low (9) and
// s82_edge_max_and_seven (7).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 7;            // 0x07
    r: u32 = a & b;        // 0x07 = 7
    return r;
}
