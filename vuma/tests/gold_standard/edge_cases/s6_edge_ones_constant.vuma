// s6_edge_ones_constant.vuma — 1 + 1 + 1 + 1 = 4
// Expected exit code: 4
//
// Four 1s summed via intermediates. Stresses that the codegen keeps
// each 1 distinct rather than folding. Distinct from
// s5_edge_quad_doubled (doubled pairs).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 1;
    c: u32 = 1;
    d: u32 = 1;
    t1: u32 = a + b;
    t2: u32 = t1 + c;
    r: u32 = t2 + d;
    return r;
}
