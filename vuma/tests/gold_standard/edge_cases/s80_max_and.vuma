// s80_edge_max_and.vuma — 255 & 200 = 200
// Expected exit code: 200
//
// AND the max u8 value 255 with 200. 255 & 200 = 200 (0xC8).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s78_edge_max_and (6),
// s74_edge_max_and_two (2) and s73_edge_max_and_eleven (11).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 200;
    r: u32 = a & b;        // 200
    return r;
}
