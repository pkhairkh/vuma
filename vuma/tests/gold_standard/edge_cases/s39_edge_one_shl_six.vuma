// s39_edge_one_shl_six.vuma — 1 << 6 = 64
// Expected exit code: 64
//
// Single-bit shift to bit 6. 1 << 6 = 64 (0x40). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s38_edge_one_shl_seven (128) and
// s34_edge_one_shl_five (32).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 6;
    r: u32 = a << b;       // 64
    return r;
}
