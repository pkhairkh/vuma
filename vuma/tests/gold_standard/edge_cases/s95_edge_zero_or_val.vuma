// s95_edge_zero_or_val.vuma — 0 | 37 = 37 (OR with zero is identity)
// Expected exit code: 37
//
// Edge case: OR with zero is the identity. 0 | 37 = 37. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s94_edge_zero_xor_val (75),
// s90_edge_zero_or_val (22) and s82_edge_zero_xor_high (128).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 37;           // 0x25
    r: u32 = a | b;        // 0x25 = 37
    return r;
}
