// s74_edge_max_and_two.vuma — 255 & 2 = 2
// Expected exit code: 2
//
// AND the max u8 value 255 (0xFF) with 2 (0x02). 255 & 2 = 2.
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s70_edge_one_shl_
// two (4), s66_edge_zero_xor_max (255) and s62_edge_zero_xor_
// high_bit (128).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a & b;        // 2
    return r;
}
