// s21_edge_zero_xor_zero.vuma — 0 ^ 0 = 0
// Expected exit code: 0
//
// Bitwise XOR of zero with zero -> zero (identity). All operands loaded
// into u32 variables first. Distinct from s18_edge_zero_and_max (0 & 255
// = 0, annihilator) and s10_edge_zero_xor (0 ^ 255 = 255).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 0;
    r: u32 = a ^ b;       // 0
    return r;
}
