// s69_edge_max_and_170.vuma -- 255 & 170 = 170
// Expected exit code: 170
//
// AND the boundary value 255 with 170. 255 & 170 = 170 (0xAA). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s66_edge_zero_xor_max (255),
// s65_edge_max_and_three (3) and s64_edge_max_shr_four (15).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 170;
    r: u32 = a & b;        // 170
    return r;
}
