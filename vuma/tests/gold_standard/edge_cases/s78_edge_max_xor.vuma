// s78_edge_max_xor.vuma — 255 ^ 5 = 250
// Expected exit code: 250
//
// XOR the max u8 value 255 with 5. 255 ^ 5 = 250 (0xFA). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s74_edge_max_xor_nine (246),
// s73_edge_max_xor_ten (245) and s72_edge_max_xor_eight (247).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 5;
    r: u32 = a ^ b;        // 250
    return r;
}
