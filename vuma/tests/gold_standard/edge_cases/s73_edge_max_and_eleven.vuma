// s73_edge_max_and_eleven.vuma — 255 & 11 = 11
// Expected exit code: 11
//
// AND the max u8 value 255 with 11. 255 & 11 = 11 (0x0B). All
// operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s70_edge_max_xor_
// seven (248), s69_edge_max_xor_six (249) and s66_edge_max_xor_
// three (252).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 11;
    r: u32 = a & b;        // 11
    return r;
}
