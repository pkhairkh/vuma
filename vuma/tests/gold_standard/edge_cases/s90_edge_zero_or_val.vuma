// s90_edge_zero_or_val.vuma — 0 | 22 = 22 (OR with zero is identity)
// Expected exit code: 22
//
// Edge case: OR with zero is the identity. 0 | 22 = 22. All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s86_edge_zero_xor_high (233),
// s82_edge_max_and_seven (7) and s78_edge_max_and (6).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 22;           // 0x16
    r: u32 = a | b;        // 0x16 = 22
    return r;
}
