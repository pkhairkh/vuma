// s43_edge_max_xor_two.vuma — 255 ^ 2 = 253
// Expected exit code: 253
//
// XOR the max u8 value with 2 (toggles bit 1). 255 ^ 2 = 253. All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s42_edge_zero_or_max (255)
// and s34_edge_max_minus_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a ^ b;        // 253
    return r;
}
