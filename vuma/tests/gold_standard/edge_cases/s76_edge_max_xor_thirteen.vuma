// s76_edge_max_xor_thirteen.vuma — 255 ^ 13 = 242
// Expected exit code: 242
//
// XOR the max u8 value 255 with 13. 255 ^ 13 = 242 (0xF2). All
// operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s74_edge_max_xor_
// nine (246), s73_edge_max_xor_ten (245) and s72_edge_max_xor_
// nine (246).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 13;
    r: u32 = a ^ b;        // 242
    return r;
}
