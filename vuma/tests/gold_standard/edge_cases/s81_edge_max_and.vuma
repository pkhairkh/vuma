// s81_edge_max_and.vuma — 255 & 21 = 21
// Expected exit code: 21
//
// AND the max u8 value 255 with 21 (0x15). 255 & 21 = 21.
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s78_edge_max_and
// (6), s77_edge_half_max_xor_one (126) and s76_edge_max_and_sixty_
// four (64).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 21;           // 0x15
    r: u32 = a & b;        // 21
    return r;
}
