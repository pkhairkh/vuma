// s97_edge_one_xor_val.vuma — 1 ^ 88 = 89 (XOR with one flips bit 0)
// Expected exit code: 89
//
// Edge case: XOR with one flips the lowest bit of the other
// operand. 1 ^ 88 = 89 (0x59). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_edge_max_and_val (108), s90_edge_one_xor_val (25), s86_edge_max_and_low (9).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 88;           // 0x58
    r: u32 = a ^ b;        // 0x59 = 89
    return r;
}
