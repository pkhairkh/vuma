// s93_edge_one_xor_val.vuma — 1 ^ 34 = 35 (XOR with one flips bit 0)
// Expected exit code: 35
//
// Edge case: XOR with one toggles the lowest bit. 1 ^ 34 = 35
// (0x23). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s90_edge_one_xor_val (25), s82_edge_max_and_seven (7) and s78_edge_max_and (6).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 34;           // 0x22
    r: u32 = a ^ b;        // 0x23 = 35
    return r;
}
