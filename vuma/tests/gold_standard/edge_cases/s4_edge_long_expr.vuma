// s4_edge_long_expr.vuma — long chain of additions: 1+2+3+4+5+6+7 = 28
// Expected exit code: 28
//
// 7 literals added in a left-to-right chain via intermediate
// variables. Stresses the codegen's register/stack-slot allocation
// for many simultaneously-live locals.

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 2;
    c: u32 = 3;
    d: u32 = 4;
    e: u32 = 5;
    f: u32 = 6;
    g: u32 = 7;
    t1: u32 = a + b;
    t2: u32 = t1 + c;
    t3: u32 = t2 + d;
    t4: u32 = t3 + e;
    t5: u32 = t4 + f;
    total: u32 = t5 + g;
    return total;
}
