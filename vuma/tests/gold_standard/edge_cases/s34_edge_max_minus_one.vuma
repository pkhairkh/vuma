// s34_edge_max_minus_one.vuma — 255 - 1 = 254
// Expected exit code: 254
//
// Subtract one from the maximum u8 value. 255 - 1 = 254. All
// operands loaded into u32 variables first. Distinct from
// s30_edge_max_and_zero (255 & 0 = 0) and s27_edge_max_div_one
// (255 / 1 = 255).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a - b;        // 254
    return r;
}
