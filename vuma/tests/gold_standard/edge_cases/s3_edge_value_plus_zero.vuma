// s3_edge_value_plus_zero.vuma — store variable + 0 to bypass drop bug
// Expected exit code: 77
//
// Edge case: store a variable through the `*ptr = variable + 0` idiom
// instead of `*ptr = variable` (the latter is dropped by a known VUMA
// bug). Verifies the workaround still works for the round-trip.

fn main() -> i32 {
    buf = allocate(8);
    src: u32 = 77;
    *(buf + 0) = src + 0;
    v: u64 = *(buf + 0);
    free(buf);
    return v;
}
