// s42_edge_max_xor_self.vuma — 255 ^ 255 = 0
// Expected exit code: 0
//
// XOR the max u8 value with itself. 255 ^ 255 = 0. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s38_edge_max_div_two (127) and s34_
// edge_max_minus_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 255;
    r: u32 = a ^ b;        // 0
    return r;
}
