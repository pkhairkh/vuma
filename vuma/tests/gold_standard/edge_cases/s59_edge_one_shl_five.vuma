// s59_edge_one_shl_five.vuma — 1 << 5 = 32
// Expected exit code: 32
//
// Shift a single bit into position 5. 1 << 5 = 32 (0x20). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s58_edge_max_shr_one (127),
// s58_edge_one_shl_seven (128) and s58_edge_zero_or_zero (0).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;
    r: u32 = a << b;       // 32
    return r;
}
