// s27_edge_zero_and_one.vuma — 0 & 1 = 0
// Expected exit code: 0
//
// AND of zero and one. 0 & 1 = 0. All operands loaded into u32 variables
// first. Distinct from s26_edge_max_minus_one (255-1=254) and
// s22_edge_one_and_max (1&255=1).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 1;
    r: u32 = a & b;       // 0
    return r;
}
