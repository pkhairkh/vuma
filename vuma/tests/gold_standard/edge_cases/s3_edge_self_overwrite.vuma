// s3_edge_self_overwrite.vuma — store A, overwrite with B, return B
// Expected exit code: 99
//
// Edge case: write to the same memory location twice and verify the
// second value survives. Tests that the second store isn't dropped.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 1;
    *(buf + 0) = 99;
    v: u64 = *(buf + 0);
    free(buf);
    return v;
}
