// s80_edge_max_xor.vuma — 255 ^ 21 = 234
// Expected exit code: 234
//
// XOR the max u8 value 255 with 21. 255 ^ 21 = 234 (0xEA). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s78_edge_max_xor (250),
// s74_edge_max_xor_nine (246) and s73_edge_max_xor_ten (245).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 21;
    r: u32 = a ^ b;        // 234
    return r;
}
