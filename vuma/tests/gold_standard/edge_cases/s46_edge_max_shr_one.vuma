// s46_edge_max_shr_one.vuma — 255 >> 1 = 127
// Expected exit code: 127
//
// Right-shift the max u8 value by one. 255 >> 1 = 127. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s42_edge_one_shl_four (16) and s38_
// edge_max_div_two (127).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a >> b;       // 127
    return r;
}
