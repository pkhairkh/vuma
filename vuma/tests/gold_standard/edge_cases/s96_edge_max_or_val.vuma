// s96_edge_max_or_val.vuma — 255 | 200 = 255 (OR with max sets all bits)
// Expected exit code: 255
//
// Edge case: OR with the max byte (0xFF) sets every bit -> result
// is always 255 (one's-complement saturation). 255 | 200 = 255.
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s94_edge_zero_xor_val
// (75), s90_edge_max_xor_val (23) and s86_edge_max_and_low (9).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 200;          // 0xC8
    r: u32 = a | b;        // 0xFF = 255
    return r;
}
