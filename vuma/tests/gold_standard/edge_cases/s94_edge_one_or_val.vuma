// s94_edge_one_or_val.vuma — 1 | 87 = 87 (OR with one sets bit 0)
// Expected exit code: 87
//
// Edge case: OR with one sets the lowest bit. 1 | 87 = 87 (0x57).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s90_edge_one_xor_val
// (25), s86_edge_one_shl_five (32) and s82_edge_one_shl_six (64).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 87;           // 0x57
    r: u32 = a | b;        // 0x57 = 87
    return r;
}
