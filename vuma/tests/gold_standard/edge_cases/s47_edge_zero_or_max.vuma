// s47_edge_zero_or_max.vuma — 0 | 255 = 255
// Expected exit code: 255
//
// OR zero with the max u8 value. 0 | 255 = 255. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s46_edge_zero_and_max (0 & 255 = 0)
// and s42_edge_max_xor_self (255 ^ 255 = 0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a | b;        // 255
    return r;
}
