// s71_edge_max_and_low.vuma — 255 & 0x33 = 0x33 = 51
// Expected exit code: 51
//
// AND the max u8 value 255 (0xFF) with the mask 0x33 (51).
// 255 & 51 = 51 (0x33). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s69_edge_max_and_170 (170), s70_edge_max_xor_seven (248) and s66
// _edge_max_xor_three (252).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 51;           // 0x33
    r: u32 = a & b;        // 0x33 = 51
    return r;
}
