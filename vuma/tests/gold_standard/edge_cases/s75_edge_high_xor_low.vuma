// s75_edge_high_xor_low.vuma — 0x80 ^ 0x01 = 0x81 = 129
// Expected exit code: 129
//
// XOR the high bit 0x80 (128) with the low bit 0x01 (1).
// 128 ^ 1 = 129 (0x81). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_edge_max_xor_nine (246), s70_edge_max_xor_seven (248) and
// s62_edge_max_xor_high_bit (128).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 1;            // 0x01
    r: u32 = a ^ b;        // 0x81 = 129
    return r;
}
