// edge2_alloc_min — allocate(8), store 42, load, return
// Expected exit code: 42
//
// Edge case: minimum useful allocation size (8 bytes — one u64 slot).
// Stores 42 at offset 0 and loads it back. Verifies that an 8-byte
// buffer supports the basic byte-store / byte-load round trip.

fn main() -> i32 {
    buf = allocate(8);
    *buf = 42;
    val: i32 = *buf;
    free(buf);
    return val;
}
