// s9_edge_max_then_zero.vuma — store 255 then 0, observe 0
// Expected exit code: 0
//
// Allocate a cell, store 255 (max U8) via `*p = 255`, then store 0
// via `*p = 0` (overwrites). Load and return 0. Edge case: ensures
// that the LAST store wins even when going from the max value to
// zero. Uses `*p = literal` form (no offsets). Distinct from
// s4_edge_double_overwrite (uses *(p+N) form, values 200/100/33,
// currently broken on backend).

fn main() -> i32 {
    p = allocate(8);
    *p = 255;
    *p = 0;
    v: u64 = *p;
    free(p);
    return v;
}
