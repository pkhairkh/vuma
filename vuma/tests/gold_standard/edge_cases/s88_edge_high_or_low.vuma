// s88_edge_high_or_low.vuma — 0xF0 | 0x0F = 0xFF = 255
// Expected exit code: 255
//
// OR the high-nibble value 240 (0xF0) with the low-nibble
// mask 15 (0x0F). 240 | 15 = 255 (0xFF). All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s86_edge_max_and_low (9),
// s82_edge_max_and_seven (7) and s78_edge_max_and (6).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 15;           // 0x0F
    r: u32 = a | b;        // 0xFF = 255
    return r;
}
