// s44_edge_max_minus_two.vuma — 255 - 2 = 253
// Expected exit code: 253
//
// Subtract two from the max u8 value. 255 - 2 = 253. All operands
// loaded into u32 variables first. Distinct from s42_edge_one_shl_
// four (16) and s38_edge_max_minus_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a - b;        // 253
    return r;
}
