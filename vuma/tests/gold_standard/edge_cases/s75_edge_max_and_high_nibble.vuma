// s75_edge_max_and_high_nibble.vuma — 255 & 0xF0 = 240
// Expected exit code: 240
//
// AND the max u8 value 255 (0xFF) with 0xF0 (high-nibble mask).
// 255 & 240 = 240 (0xF0). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_edge_max_and_two (2), s70_edge_one_shl_two (4) and
// s66_edge_zero_xor_max (255).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 240;          // 0xF0
    r: u32 = a & b;        // 240
    return r;
}
