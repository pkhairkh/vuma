// s65_edge_max_xor_sixteen.vuma — 255 ^ 16 = 239
// Expected exit code: 239
//
// XOR the max u8 value with 16 (0x10). 255 ^ 16 = 239 (0xEF). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s51_edge_max_shr_three (31),
// s58_edge_max_shr_one (127) and s62_edge_max_shr_two (63).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 16;
    r: u32 = a ^ b;        // 239
    return r;
}
