// s8_edge_max_xor_zero.vuma — 255 ^ 255 = 0
// Expected exit code: 0
//
// Self-XOR of the maximum U8 value: 255 ^ 255 = 0. Edge case:
// any value XORed with itself cancels to zero. Distinct from
// s6_edge_max_byte (returns 255 directly, no XOR).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 255;
    r: u32 = a ^ b;
    return r;
}
