// s3_edge_zero_then_value.vuma — store 0 then 42, return 42
// Expected exit code: 42
//
// Edge case: initialize to 0 then overwrite with a non-zero value.
// Verifies overwriting a zero doesn't leave the zero in place.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 0;
    *(buf + 0) = 42;
    v: u64 = *(buf + 0);
    free(buf);
    return v;
}
