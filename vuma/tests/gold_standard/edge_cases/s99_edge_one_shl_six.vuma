// s99_edge_one_shl_six.vuma — 1 << 6 = 64 (SHL with one shifts bit 0 to position 6)
// Expected exit code: 64
//
// Edge case: shift-left of one by six positions moves bit 0 to
// position 6. 1 << 6 = 64 (0x40). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s95_edge_one_xor_val (50), s91_edge_one_or_val
// (101) and s87_edge_one_shl_four (16).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    s: u32 = 6;
    r: u32 = a << s;       // 0x40 = 64
    return r;
}
