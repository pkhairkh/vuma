// s4_edge_double_overwrite.vuma — three sequential overwrites, final=33
// Expected exit code: 33
//
// Allocate a cell, store 200, then 100, then 33 (each clobbers the
// previous). Load and return 33. Edge case: ensures that the LAST
// store to a cell wins, even when intermediate stores use the full
// U8 range.

fn main() -> i32 {
    p = allocate(8);
    *(p + 0) = 200;
    *(p + 0) = 100;
    *(p + 0) = 33;
    v: u64 = *(p + 0);
    free(p);
    return v;
}
