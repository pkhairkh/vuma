// s65_edge_max_and_three.vuma — 255 & 3 = 3
// Expected exit code: 3
//
// AND the max u8 value with 3 (0x03) to keep only the low two bits.
// 255 & 3 = 3 (0x03). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_
// edge_zero_and_max (0), s58_edge_zero_or_zero (0) and s62_edge_one_
// shl_four (16).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 3;
    r: u32 = a & b;        // 3
    return r;
}
