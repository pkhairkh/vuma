// s82_edge_one_shl_six.vuma — 1 << 6 = 64
// Expected exit code: 64
//
// Shift the value 1 left by 6. 1 << 6 = 64 (0x40). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s78_edge_max_xor (250),
// s74_edge_one_shl_two (4) and s72_edge_one_shl_seven (128).
fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 6;
    r: u32 = a << b;       // 0x40 = 64
    return r;
}
