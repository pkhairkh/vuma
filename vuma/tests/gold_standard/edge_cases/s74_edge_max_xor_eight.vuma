// s74_edge_max_xor_eight.vuma — 255 ^ 8 = 247
// Expected exit code: 247
//
// XOR the max u8 value 255 with 8. 255 ^ 8 = 247 (0xF7). All
// operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s70_edge_max_xor_
// seven (248), s66_edge_max_xor_three (252) and s62_edge_max_xor_
// high_bit (128).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 8;
    r: u32 = a ^ b;        // 247
    return r;
}
