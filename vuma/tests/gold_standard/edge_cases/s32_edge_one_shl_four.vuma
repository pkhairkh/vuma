// s32_edge_one_shl_four.vuma - 1 << 4 = 16
// Expected exit code: 16
//
// 1 << 4 = 16. All operands loaded into typed variables before any bitwise
// op (immediate-RHS drop workaround where applicable); stores use the `*ptr
// = literal` (or `*ptr = variable + 0`) form with no `*(ptr + offset)`
// indexing. Distinct from s30_edge_one_shl_three (1 << 3 = 8) and
// s26_edge_one_shl_four (different set).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    r: u32 = a << b;      // 16
    return r;
}
