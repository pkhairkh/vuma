// s101_edge_max_xor_val.vuma — 255 ^ 100 = 155 (XOR with max flips all bits)
// Expected exit code: 155
//
// Edge case: XOR with the max byte (0xFF) flips every bit
// (one's complement). 255 ^ 100 = 155 (0x9B). All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s98_edge_max_and_val (46),
// s97_edge_max_and_val (89) and s94_edge_max_and_val (108).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 100;          // 0x64
    r: u32 = a ^ b;        // 0x9B = 155
    return r;
}
