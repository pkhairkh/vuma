// s58_edge_one_shl_seven.vuma — 1 << 7 = 128
// Expected exit code: 128
// 
// Shift the literal 1 left by 7. 1 << 7 = 128 (0x80). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s51_edge_zero_and_max (0), s51_edge_one_
// shl_six (64) and s51_edge_max_shr_three (31).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 7;
    r: u32 = a << b;       // 128
    return r;
}
