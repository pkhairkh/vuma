// edge_many_params — function with 4 params, return sum
// Expected exit code: 10
//
// Edge case: a function taking 4 parameters (1+2+3+4 = 10). Stresses
// the calling convention's register-vs-stack split.

fn add4(a: u32, b: u32, c: u32, d: u32) -> u32 {
    return a + b + c + d;
}

fn main() -> i32 {
    v: u32 = add4(1, 2, 3, 4);
    return v;
}
