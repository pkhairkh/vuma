// s10_edge_one_minus_one.vuma — 1 - 1 = 0
// Expected exit code: 0
//
// One minus itself -> 0. Tests the codegen's handling of subtraction
// yielding zero (no underflow). Distinct from s5_edge_zero_sum
// (sum of zeros) and s6_edge_zero_mul (mul by zero).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 1;
    r: u32 = a - b;
    return r;
}
