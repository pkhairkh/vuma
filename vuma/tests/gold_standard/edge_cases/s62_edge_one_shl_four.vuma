// s62_edge_one_shl_four.vuma — 1 << 4 = 16
// Expected exit code: 16
// 
// Shift the literal 1 left by 4. 1 << 4 = 16 (0x10). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s51_edge_one_shl_six (64), s58_edge_one_
// shl_seven (128) and s55_edge_one_shl_six (64).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    r: u32 = a << b;       // 16
    return r;
}
