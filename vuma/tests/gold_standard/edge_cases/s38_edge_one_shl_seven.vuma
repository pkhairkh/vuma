// s38_edge_one_shl_seven.vuma — 1 << 7 = 128
// Expected exit code: 128
//
// Single-bit shift to the top of a byte. 1 << 7 = 128 (0x80). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s34_edge_one_shl_five (32)
// and s30_edge_one_shl_three (8).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 7;
    r: u32 = a << b;       // 128
    return r;
}
