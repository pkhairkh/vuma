// s72_edge_low_shl_one.vuma — 7 << 1 = 14
// Expected exit code: 14
//
// Shift the low literal 7 left by 1. 7 << 1 = 14 (0x0E). All
// operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s70_edge_one_shl_
// two (4), s69_edge_one_shl_three (8) and s66_edge_one_shl_five
// (32).
fn main() -> i32 {
    a: u32 = 7;
    b: u32 = 1;
    r: u32 = a << b;       // 14
    return r;
}
