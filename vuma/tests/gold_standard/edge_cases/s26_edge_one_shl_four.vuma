// s26_edge_one_shl_four.vuma — 1 << 4 = 16
// Expected exit code: 16
//
// Single-bit shift into nibble position. 1 << 4 = 16 (0x10). All
// operands loaded into u32 variables first. Distinct from
// s20_edge_one_shl_seven (1 << 7 = 128) and s21_edge_one_plus_zero
// (1 + 0 = 1).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    r: u32 = a << b;      // 16
    return r;
}
