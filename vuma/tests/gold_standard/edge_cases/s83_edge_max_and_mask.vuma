// s83_edge_max_and_mask.vuma — 255 & 157 = 157
// Expected exit code: 157
//
// AND the max byte value 255 (0xFF) with the mask 157 (0x9D).
// 255 & 157 = 157 (0x9D). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_edge_max_and (6), s74_edge_max_and_low (5) and
// s72_edge_max_and_low (5).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 157;          // 0x9D
    r: u32 = a & b;        // 0x9D = 157
    return r;
}
