// s33_edge_one_shl_seven.vuma — 1 << 7 = 128
// Expected exit code: 128
//
// Deterministic test in the edge_cases category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_edge_one_shl_three (1<<3=8) and s26_edge_max_div_one (255/1=255).
fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 7;
    r: u32 = a << b;       // 128
    return r;
}
