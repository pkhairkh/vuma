// s79_edge_max_xor.vuma — 255 ^ 215 = 40
// Expected exit code: 40
//
// XOR the max u8 value 255 with 215. 255 ^ 215 = 40 (0x28).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s78_edge_max_xor
// (250), s77_edge_max_xor (245) and s76_edge_max_xor (247).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 215;
    r: u32 = a ^ b;        // 40
    return r;
}
