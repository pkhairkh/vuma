// s68_edge_max_and_ten.vuma — 255 & 10 = 10
// Expected exit code: 10
//
// AND the boundary value 255 with 10. 255 & 10 = 10 (0x0A). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s66_edge_max_xor_three
// (252), s62_edge_max_shr_two (63) and s58_edge_max_shr_one (127).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 10;
    r: u32 = a & b;        // 10
    return r;
}
