// s14_edge_xor_self.vuma — 0x55 ^ 0x55 = 0
// Expected exit code: 0
//
// XOR a value with itself -> 0 (XOR cancellation). Distinct from
// s10_edge_max_xor_zero (255 ^ 0 = 255, XOR with zero) and
// s9_edge_max_then_zero (max then literal zero).

fn main() -> i32 {
    a: u32 = 85;          // 0x55
    b: u32 = 85;          // 0x55
    r: u32 = a ^ b;       // 0
    return r;
}
