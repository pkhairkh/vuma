// s30_edge_one_shl_three.vuma — 1 << 3 = 8
// Expected exit code: 8
//
// Single-bit shift to produce a power of two. 1 << 3 = 8. All operands
// loaded into u32 variables first. Distinct from s26_edge_one_shl_four
// (1 << 4 = 16) and s22_edge_one_and_max (1 & 255 = 1).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 3;
    r: u32 = a << b;      // 8
    return r;
}
