// s19_edge_zero_or_max.vuma — 0 | 255 = 255
// Expected exit code: 255
//
// Bitwise OR with the all-ones byte -> all-ones. Identity element for
// OR is 0; OR with 255 sets every bit. All operands loaded into u32
// variables first. Distinct from s18_edge_zero_and_max (0 & 255 = 0)
// and s14_edge_zero_minus_zero (0 - 0 = 0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a | b;       // 255
    return r;
}
