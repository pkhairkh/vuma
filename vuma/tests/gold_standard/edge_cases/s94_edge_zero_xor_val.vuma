// s94_edge_zero_xor_val.vuma — 0 ^ 75 = 75 (XOR with zero is identity)
// Expected exit code: 75
//
// Edge case: XOR with zero is the identity. 0 ^ 75 = 75. All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s90_edge_zero_or_val (22),
// s86_edge_zero_xor_high (250) and s82_edge_zero_xor_high (128).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 75;           // 0x4B
    r: u32 = a ^ b;        // 0x4B = 75
    return r;
}
