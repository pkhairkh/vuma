// s101_edge_one_shl_val.vuma — 1 << 4 = 16 (single-bit set)
// Expected exit code: 16
//
// Edge case: shift-left of 1 by a small constant sets a single
// bit. 1 << 4 = 16 (0x10). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s98_edge_one_or_val (15), s97_edge_one_xor_val (17) and
// s94_edge_one_or_val (87).
fn main() -> i32 {
    a: u32 = 1;
    s: u32 = 4;
    r: u32 = a << s;       // 0x10 = 16
    return r;
}
