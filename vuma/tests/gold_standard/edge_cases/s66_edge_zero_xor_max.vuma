// s66_edge_zero_xor_max.vuma — 0 ^ 255 = 255
// Expected exit code: 255
//
// XOR the boundary values 0 and 255. 0 ^ 255 = 255. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s62_edge_zero_xor_high_bit
// (128), s58_edge_zero_or_zero (0) and s55_edge_zero_and_max (0).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a ^ b;        // 255
    return r;
}
