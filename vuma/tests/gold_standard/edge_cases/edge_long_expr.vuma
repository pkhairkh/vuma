// edge_long_expr — long arithmetic expression: 1 + 2 + 3 + 4
// Expected exit code: 10
//
// Edge case: a single chained expression evaluated left-to-right.
// 1 + 2 = 3; 3 + 3 = 6; 6 + 4 = 10.

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 2;
    c: u32 = 3;
    d: u32 = 4;
    s1: u32 = a + b;
    s2: u32 = s1 + c;
    s3: u32 = s2 + d;
    return s3;
}
