// s63_edge_one_shl_five.vuma — 1 << 5 = 32
// Expected exit code: 32
//
// Shift the literal 1 left by 5. 1 << 5 = 32 (0x20). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s51_edge_one_shl_six (64), s58_edge_
// one_shl_seven (128) and s55_edge_one_shl_six (64).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;
    r: u32 = a << b;       // 32
    return r;
}
