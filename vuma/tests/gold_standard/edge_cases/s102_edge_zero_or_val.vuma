// s102_edge_zero_or_val.vuma — 0 | 18 = 18 (OR with zero is identity)
// Expected exit code: 18
//
// Edge case: OR with zero is the identity. 0 | 18 = 18. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_edge_max_xor_val (155), s101_edge_one_shl_val (16), s101_edge_zero_and_val (0).
fn main() -> i32 {
    a: u32 = 18;
    z: u32 = 0;
    r: u32 = z | a;        // 18
    return r;
}
