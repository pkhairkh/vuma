// s14_edge_zero_minus_zero.vuma — 0 - 0 = 0
// Expected exit code: 0
//
// Zero minus zero (identity under subtraction). All operands loaded
// into u32 variables first. Distinct from s10_edge_one_minus_one
// (1 - 1 = 0) and s9_edge_max_then_zero (max then zero).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 0;
    r: u32 = a - b;
    return r;
}
