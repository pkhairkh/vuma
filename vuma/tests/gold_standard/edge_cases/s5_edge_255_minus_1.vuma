// s5_edge_255_minus_1.vuma — 255 - 1 = 254
// Expected exit code: 254
//
// Subtraction at the U8 boundary: 255 (max U8) minus 1 = 254. No
// memory access, so the *(buf+offset) U8-truncation bug doesn't
// apply. Distinct from s3_edge_u8_max_minus_one (different framing).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a - b;
    return r;
}
