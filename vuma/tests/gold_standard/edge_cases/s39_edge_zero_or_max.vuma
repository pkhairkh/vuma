// s39_edge_zero_or_max.vuma — 0 | 255 = 255
// Expected exit code: 255
//
// Bitwise OR of zero with the max u8 value. 0 | 255 = 255. All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s38_edge_zero_plus_one (1)
// and s34_edge_zero_or_max.

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a | b;        // 255
    return r;
}
