// s60_edge_max_shr_two.vuma — 255 >> 2 = 63
// Expected exit code: 63
//
// Shift the max u8 value right by 2. 255 >> 2 = 63 (0x3F). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s58_edge_max_shr_one (127)
// and s57_edge_max_xor_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a >> b;       // 63
    return r;
}
