// s18_edge_max_xor_zero.vuma — 255 ^ 0 = 255
// Expected exit code: 255
//
// Max U8 XOR'd with zero -> identity (255). All operands loaded into
// u32 variables first. Distinct from s10_edge_max_xor_zero (same
// arithmetic, different category framing — this entry keeps the
// canonical max^0 form) and s9_edge_max_then_zero (max then literal
// zero).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 0;
    r: u32 = a ^ b;       // 255
    return r;
}
