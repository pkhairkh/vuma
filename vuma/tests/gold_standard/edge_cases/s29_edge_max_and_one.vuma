// s29_edge_max_and_one.vuma — 255 & 1 = 1
// Expected exit code: 1
//
// AND with single-bit mask: 255 & 1 = 1 (extracts the LSB of the max u8 value). All operands loaded into u32 variables first. Distinct from s26_edge_zero_or_one (0 | 1 = 1) and s22_edge_zero_xor_zero (0 ^ 0 = 0).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a & b;       // 1
    return r;
}
