// s66_edge_max_xor_three.vuma — 255 ^ 3 = 252
// Expected exit code: 252
//
// XOR the max u8 value 255 with 3. 255 ^ 3 = 252 (0xFC). All
// operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s62_edge_max_shr_
// two (63), s58_edge_max_shr_one (127) and s55_edge_max_xor_
// one (254).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 3;
    r: u32 = a ^ b;        // 252
    return r;
}
