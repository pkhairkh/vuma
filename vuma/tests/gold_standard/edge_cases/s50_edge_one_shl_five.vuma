// s50_edge_one_shl_five.vuma — 1 << 5 = 32
// Expected exit code: 32
//
// Shift the literal 1 left by 5. 1 << 5 = 32. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s46_edge_one_shl_three (8) and
// s43_edge_one_shl_six (64).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;
    r: u32 = a << b;       // 32
    return r;
}
