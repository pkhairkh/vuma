// s98_edge_zero_xor_val.vuma — 0 ^ 13 = 13 (XOR with zero is identity)
// Expected exit code: 13
//
// Edge case: XOR with zero is the identity. 0 ^ 13 = 13. All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s94_edge_zero_xor_val (75),
// s90_edge_zero_or_val (22) and s86_edge_zero_xor_high (250).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 13;           // 0x0D
    r: u32 = a ^ b;        // 0x0D = 13
    return r;
}
