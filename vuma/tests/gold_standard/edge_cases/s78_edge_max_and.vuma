// s78_edge_max_and.vuma — 255 & 6 = 6
// Expected exit code: 6
//
// AND the max u8 value 255 with 6. 255 & 6 = 6 (0x06).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s74_edge_max_and_two
// (2), s73_edge_max_and_eleven (11) and s72_edge_max_and_low (5).
fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 6;
    r: u32 = a & b;        // 6
    return r;
}
