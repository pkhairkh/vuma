// s98_edge_one_or_val.vuma — 1 | 14 = 15 (OR with one sets bit 0)
// Expected exit code: 15
//
// Edge case: OR with one sets the lowest bit. 1 | 14 = 15 (0x0F).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s94_edge_one_or_val
// (87), s90_edge_one_xor_val (25) and s86_edge_one_shl_five (32).
fn main() -> i32 {
    a: u32 = 1;            // 0x01
    b: u32 = 14;           // 0x0E
    r: u32 = a | b;        // 0x0F = 15
    return r;
}
