// edge2_store_max — store 255 (u8 max), load, return
// Expected exit code: 255
//
// Edge case: the maximum u8 value (0xFF). Verifies the high bit of the
// byte survives the round trip without spurious sign-extension.

fn main() -> i32 {
    buf = allocate(8);
    *buf = 255;
    val: i32 = *buf;
    free(buf);
    return val;
}
