// s56_edge_max_minus_two.vuma — 255 - 2 = 253
// Expected exit code: 253
//
// Subtract 2 from the max u8 value -> 253. All operands loaded into
// u32 variables first. Straight-line arithmetic. Distinct from
// s54_edge_max_and_zero (0) and s50_edge_max_xor_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a - b;        // 253
    return r;
}
