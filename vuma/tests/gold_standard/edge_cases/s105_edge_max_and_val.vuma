// s105_edge_max_and_val.vuma — 255 & 165 = 165 (AND with all-ones is identity)
// Expected exit code: 165
// 
// Edge case: AND with the max byte (0xFF) is the identity. 255 & 165 = 165. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_edge_max_and_val (38), s101_edge_max_xor_val (155), s100_edge_and_self (85).
fn main() -> i32 {
    m: u32 = 255;          // 0xFF
    a: u32 = 165;
    r: u32 = m & a;        // 165
    return r;
}
