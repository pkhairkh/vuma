// s57_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
//
// XOR the max u8 value with one. 255 ^ 1 = 254 (flips the LSB of
// all-ones). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s54_
// edge_max_and_zero (0) and s50_edge_max_xor_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a ^ b;        // 254
    return r;
}
