// s53_edge_max_xor_eight.vuma — 255 ^ 8 = 247
// Expected exit code: 247
//
// XOR the max u8 value with 8 (toggle bit 3). 255 ^ 8 = 247. All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s49_edge_max_xor_one (254)
// and s50_edge_max_xor_one (254).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 8;
    r: u32 = a ^ b;        // 247
    return r;
}
