// s49_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
//
// XOR the max u8 value with one. 255 ^ 1 = 254 (0xFE). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s46_edge_max_shr_one (255 >> 1 = 127)
// and s42_edge_max_xor_self (255 ^ 255 = 0).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a ^ b;        // 254
    return r;
}
