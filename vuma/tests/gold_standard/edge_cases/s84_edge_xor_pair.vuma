// s84_edge_xor_pair.vuma — 0x55 ^ 0x19 = 0x4C = 76
// Expected exit code: 76
//
// XOR the alternating-bit value 85 (0x55) with the value 25
// (0x19). 85 ^ 25 = 76 (0x4C). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s82_edge_max_and_seven (7), s78_edge_max_and
// (6) and s74_edge_max_and_two (2).
fn main() -> i32 {
    a: u32 = 85;           // 0x55
    b: u32 = 25;           // 0x19
    r: u32 = a ^ b;        // 0x4C = 76
    return r;
}
