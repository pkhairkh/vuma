// s54_edge_one_shl_seven.vuma — 1 << 7 = 128
// Expected exit code: 128
//
// Single-bit shift to the MSB of a byte. 1 << 7 = 128 (0x80).
// All operands loaded into u32 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s50_edge_one_shl_
// five (32) and s49_edge_one_shl_six (64).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 7;
    r: u32 = a << b;       // 128
    return r;
}
