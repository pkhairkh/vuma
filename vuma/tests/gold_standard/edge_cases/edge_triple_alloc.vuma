// edge_triple_alloc — three allocations, store in middle, load from middle
// Expected exit code: 42
//
// Edge case: three live allocations at once. Stores 42 in the middle
// buffer (buf2) and loads it back from the same buffer. Verifies that
// having multiple allocations on either side does not corrupt the
// middle one's offset-0 slot.

fn main() -> i32 {
    buf1 = allocate(8);
    buf2 = allocate(8);
    buf3 = allocate(8);
    *buf1 = 1;
    *buf2 = 42;
    *buf3 = 3;
    val: i32 = *buf2;
    free(buf1);
    free(buf2);
    free(buf3);
    return val;
}
