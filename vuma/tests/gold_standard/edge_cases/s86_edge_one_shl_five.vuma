// s86_edge_one_shl_five.vuma — 1 << 5 = 32
// Expected exit code: 32
//
// Shift the value 1 left by 5. 1 << 5 = 32 (0x20). All operands
// loaded into u32 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s82_edge_one_shl_six (64),
// s78_edge_max_xor (250) and s74_edge_one_shl_two (4).
fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 5;            // shift amount
    r: u32 = a << b;       // 0x20 = 32
    return r;
}
