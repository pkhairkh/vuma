// s49_edge_max_and_low.vuma — 255 & 0x0F = 15
// Expected exit code: 15
//
// AND the max u8 value with the low-nibble mask. 255 & 15 = 15
// (0x0F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s46_
// edge_zero_and_max (0 & 255 = 0) and s42_edge_one_shl_four (16).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 15;           // 0x0F
    r: u32 = a & b;        // 15
    return r;
}
