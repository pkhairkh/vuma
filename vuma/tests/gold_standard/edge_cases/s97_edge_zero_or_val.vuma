// s97_edge_zero_or_val.vuma — 0 | 17 = 17 (OR with zero preserves bits)
// Expected exit code: 17
//
// Edge case: OR with zero preserves the other operand.
// 0 | 17 = 17 (0x11). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_edge_max_and_val (108), s90_edge_zero_or_val (22), s86_edge_max_and_low (9).
fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 17;           // 0x11
    r: u32 = a | b;        // 0x11 = 17
    return r;
}
