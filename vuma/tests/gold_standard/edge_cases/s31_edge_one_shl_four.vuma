// s31_edge_one_shl_four.vuma — 1 << 4 = 16
// Expected exit code: 16
//
// Single-bit shift to produce a power of two. 1 << 4 = 16. All operands
// loaded into u32 variables first. Distinct from s30_edge_one_shl_three
// (1 << 3 = 8) and s28_edge_one_shl_three (1 << 3 = 8).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 4;
    r: u32 = a << b;      // 16
    return r;
}
