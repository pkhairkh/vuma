// s43_edge_max_shr_two.vuma — 255 >> 2 = 63
// Expected exit code: 63
//
// Shift the max u8 value right by 2. 255 >> 2 = 63. All operands
// loaded into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s42_edge_max_xor_self (0) and
// s38_edge_max_div_two (127).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 2;
    r: u32 = a >> b;       // 63
    return r;
}
