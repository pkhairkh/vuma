// s18_edge_one_mul_one.vuma — 1 * 1 = 1
// Expected exit code: 1
//
// Multiplicative identity: 1 * 1 = 1. All operands loaded into u32
// variables first. Distinct from s10_edge_one_minus_one (1 - 1 = 0)
// and s5_edge_one_shift_left (1 << 4 = 16).

fn main() -> i32 {
    a: u32 = 1;
    b: u32 = 1;
    r: u32 = a * b;       // 1
    return r;
}
