// s62_edge_zero_xor_high_bit.vuma — 0 ^ 128 = 128
// Expected exit code: 128
// 
// XOR zero with the high-bit-only value 0x80. 0 ^ 128 = 128
// (0x80). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s51_edge_zero_and_max (0), s58_edge_zero_or_zero (0) and s55_edge_
// zero_and_max (0).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 128;
    r: u32 = a ^ b;        // 128
    return r;
}
