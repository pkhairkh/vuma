// s46_edge_zero_and_max.vuma — 0 & 255 = 0
// Expected exit code: 0
//
// AND zero with the max u8 value. 0 & 255 = 0. All operands loaded
// into u32 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s42_edge_max_xor_self (255 ^ 255 = 0)
// and s38_edge_zero_plus_one (1).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 255;
    r: u32 = a & b;        // 0
    return r;
}
