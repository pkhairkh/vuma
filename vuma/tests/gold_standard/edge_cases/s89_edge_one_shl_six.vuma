// s89_edge_one_shl_six.vuma — (1 << 6) ^ 91 = 64 ^ 91 = 27
// Expected exit code: 27
//
// Shift 1 left by 6 (-> 64), then XOR with 91 (0x5B)
// to reach 27. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_edge_one_shl_five (32), s82_edge_one_shl_six (64) and
// s78_edge_max_xor (250).
fn main() -> i32 {
    a: u32 = 1;
    s: u32 = 6;            // shift amount
    m: u32 = 91;            // 0x5B
    x: u32 = a << s;       // 64
    r: u32 = x ^ m;        // 27
    return r;
}
