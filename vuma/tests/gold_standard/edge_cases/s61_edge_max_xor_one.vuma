// s61_edge_max_xor_one.vuma — 255 ^ 1 = 254
// Expected exit code: 254
// 
// Flip the low bit of the max u8 value. 255 ^ 1 = 254 (0xFE). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s58_edge_zero_or_zero (0),
// s58_edge_one_shl_seven (128) and s58_edge_max_shr_one (127).

fn main() -> i32 {
    a: u32 = 255;
    b: u32 = 1;
    r: u32 = a ^ b;        // 254
    return r;
}
