// s68_edge_half_max_xor_five.vuma — 127 ^ 5 = 122
// Expected exit code: 122
//
// XOR the half-max value 127 with 5. 127 ^ 5 = 122 (0x7A). All
// operands loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s66_edge_one_shl_five (32),
// s62_edge_one_shl_four (16) and s58_edge_one_shl_seven (128).
fn main() -> i32 {
    a: u32 = 127;
    b: u32 = 5;
    r: u32 = a ^ b;        // 122
    return r;
}
