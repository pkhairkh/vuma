// s104_edge_one_or_val.vuma — 1 | 150 = 151 (OR with one sets the low bit)
// Expected exit code: 151
//
// Edge case: OR with one sets the low bit. 1 | 150 = 151. All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_edge_zero_or_val (18), s102_edge_max_and_val (38), s102_edge_one_xor_val (39).
fn main() -> i32 {
    a: u32 = 150;
    o: u32 = 1;
    r: u32 = o | a;        // 151
    return r;
}
