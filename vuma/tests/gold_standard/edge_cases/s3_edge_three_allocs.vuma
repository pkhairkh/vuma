// s3_edge_three_allocs.vuma — 3 allocs, store distinct vals, sum loads
// Expected exit code: 60  (10 + 20 + 30)
//
// Edge case: three independent allocations of the same size. Each
// gets a distinct small value; main sums the loaded values.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *(a + 0) = 10;
    *(b + 0) = 20;
    *(c + 0) = 30;

    va: u64 = *(a + 0);
    vb: u64 = *(b + 0);
    vc: u64 = *(c + 0);
    s1: u64 = va + vb;
    s2: u64 = s1 + vc;

    free(a);
    free(b);
    free(c);
    return s2;
}
