// s84_edge_max_and_mask.vuma — 0xFF & 0x18 = 0x18 = 24
// Expected exit code: 24
//
// AND the max byte value 255 (0xFF) with the mask 24 (0x18).
// 255 & 24 = 24. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s82_edge_one_shl_six (64), s78_edge_max_xor (250) and
// s72_edge_max_and_low (5).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 24;           // 0x18
    r: u32 = a & b;        // 0x18 = 24
    return r;
}
