// edge_const_fold — constant expression: 40 + 2
// Expected exit code: 42
//
// Edge case: a literal constant expression that could be folded at
// compile time. Loads both constants into variables to avoid any
// immediate-RHS bitop-drop bug.

fn main() -> i32 {
    a: u32 = 40;
    b: u32 = 2;
    result: u32 = a + b;
    return result;
}
