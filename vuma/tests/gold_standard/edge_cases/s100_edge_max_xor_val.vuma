// s100_edge_max_xor_val.vuma — 0xFF ^ 0xCB = 0x34 = 52 (XOR with max byte)
// Expected exit code: 52
//
// Edge case: XOR with the max byte (0xFF) inverts the bits
// of the other operand. 255 ^ 203 = 52 (0x34). All operands
// loaded into u32 variables first (immediate-RHS bitwise
// drop bug workaround).
// Distinct from s97_edge_max_and_val (90), s94_edge_max_and_val (108), s90_edge_max_xor_val (23).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 203;          // 0xCB
    r: u32 = a ^ b;        // 0x34 = 52
    return r;
}
