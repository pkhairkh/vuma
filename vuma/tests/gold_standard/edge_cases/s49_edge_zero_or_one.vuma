// s49_edge_zero_or_one.vuma — 0 | 1 = 1
// Expected exit code: 1
//
// OR zero with one. 0 | 1 = 1. All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s46_edge_zero_and_max (0 & 255 = 0) and s42_edge_
// zero_or_max (0 | 255 = 255).

fn main() -> i32 {
    a: u32 = 0;
    b: u32 = 1;
    r: u32 = a | b;        // 1
    return r;
}
