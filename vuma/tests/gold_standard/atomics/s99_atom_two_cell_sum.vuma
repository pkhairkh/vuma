// s99_atom_two_cell_sum.vuma — two cells, atomic sum = 70 (40 + 30)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 70
//
// Two 8-byte cells. atomic_store 40/30, atomic_load each, a + b
// -> 70. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 70 once atomics are wired through. Distinct
// from s95_atom_two_cell_sum (51), s91_atom_two_cell_diff (5) and
// s87_atom_two_cell_sum (195).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c2, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 70
    free(c1);
    free(c2);
    return s;
}
