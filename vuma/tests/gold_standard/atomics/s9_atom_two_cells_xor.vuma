// s9_atom_two_cells_xor.vuma — two atomic cells, XOR loads = 88 (100 ^ 60)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 88
//
// Two 8-byte cells. atomic_store 100 in c1, 60 in c2. Load both,
// XOR -> 100 ^ 60 = 0x64 ^ 0x3C = 0x58 = 88. Current backend
// returns 0 ^ 0 = 0. Distinct from s5_atom_two_cells_diff (sum,
// not XOR).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 60);
    a = atomic_load(c1);
    b = atomic_load(c2);
    r = a ^ b;
    free(c1);
    free(c2);
    return r;
}
