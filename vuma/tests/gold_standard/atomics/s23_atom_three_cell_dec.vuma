// s23_atom_three_cell_dec.vuma — three cells descending, sum = 180 (100 + 60 + 20)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 180
//
// Three 8-byte cells. atomic_store 100/60/20 (descending) in c1/c2/c3.
// atomic_load all three, sum -> 180. On the current backend atomic_load
// returns 0 -> exit 0. Distinct from s22_atom_three_cell_inc (asc,
// 11/22/33 = 66) and s21_atom_three_cells_asc (asc, 10/30/50 = 90).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 60);
    atomic_store(c3, 20);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t = a + b;
    s = t + c;            // 180
    free(c1);
    free(c2);
    free(c3);
    return s;
}

