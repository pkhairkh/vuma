// s100_atom_overwrite_value.vuma — overwrite c1 to 53, atomic load = 53
// Expected exit code: 53
//
// Single 8-byte cell. atomic_store 7, then atomic_store
// 53 (overwrite), then atomic_load -> 53. On the current
// backend the load returns 0 -> exit 0. Will exit 53
// once atomics are wired through.
// Distinct from s97_atom_overwrite_value (52), s94_atom_overwrite_value (201), s90_atom_overwrite_value (13).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 7);
    atomic_store(c1, 53);
    v = atomic_load(c1);              // 53
    free(c1);
    return v;
}
