// s49_atom_two_cell_sum.vuma — two cells, atomic sum = 240 (130 + 110)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 240
//
// Two 8-byte cells. atomic_store 130/110, atomic_load each, sum -> 240.
// On the current backend the loads return 0 -> exit 0. Will exit 240
// once atomics are wired through. Distinct from s46_atom_two_cell_xor
// (255, xor) and s42_atom_two_cell_sum (175, sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 130);
    atomic_store(c2, 110);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 240
    free(c1);
    free(c2);
    return s;
}
