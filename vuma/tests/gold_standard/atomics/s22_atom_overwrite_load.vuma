// s22_atom_overwrite_load.vuma — atomic_store 17 then 88, load = 88
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 88
//
// Single 8-byte cell. atomic_store 17, then overwrite with 88.
// atomic_load should observe 88 (last write wins). On the current
// backend the load returns 0 (atomic_store/load not bridged) -> exit 0.
// Will exit 88 once atomics are wired. Distinct from
// s18_atom_overwrite_then_load (7 then 71) and s14_atom_overwrite_load
// (17 then 73).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 17);
    atomic_store(c, 88);
    v = atomic_load(c);
    free(c);
    return v;
}
