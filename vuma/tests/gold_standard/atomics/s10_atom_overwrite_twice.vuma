// s10_atom_overwrite_twice.vuma — atomic_store 10, 80, 90, load sees 90
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 90
//
// Single 8-byte cell. atomic_store 10, then 80, then 90. Load should
// observe 90 (last write wins, three writes total). On the current
// backend the load returns 0. Distinct from s6_atom_overwrite_load
// (two writes) and s5_atom_overwrite_load (two writes, different vals).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 10);
    atomic_store(c, 80);
    atomic_store(c, 90);
    v = atomic_load(c);
    free(c);
    return v;
}
