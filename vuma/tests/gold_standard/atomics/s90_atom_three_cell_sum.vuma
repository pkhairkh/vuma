// s90_atom_three_cell_sum.vuma — three cells, atomic sum = 12 (4 + 5 + 3)
// Expected exit code: 12
//
// Three 8-byte cells. atomic_store 4/5/3, atomic_load each, sum
// -> 12. On the current backend the loads return 0 -> 0 + 0 + 0 = 0
// -> exit 0. Will exit 12 once atomics are wired through. Distinct
// from s86_atom_three_cell_diff (60), s82_atom_three_cell_diff (110)
// and s78_atom_three_cell_diff (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 4);
    atomic_store(c2, 5);
    atomic_store(c3, 3);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b + c;               // 12
    free(c1);
    free(c2);
    free(c3);
    return s;
}
