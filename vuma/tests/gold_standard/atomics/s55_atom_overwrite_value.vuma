// s55_atom_overwrite_value.vuma — store 80, overwrite to 220, load = 220
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 220
//
// Single 8-byte cell. atomic_store 80, then overwrite with 220,
// atomic_load -> 220. On the current backend the load returns 0 ->
// exit 0. Will exit 220 once atomics are wired through. Distinct from
// s54_atom_overwrite_value (200) and s53_atom_overwrite_value (235).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 80);
    atomic_store(c, 220);
    v = atomic_load(c);
    free(c);
    return v;
}
