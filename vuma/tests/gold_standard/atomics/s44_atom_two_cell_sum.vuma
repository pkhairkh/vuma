// s44_atom_two_cell_sum.vuma — two cells, atomic sum = 170 (115 + 55)
// Expected exit code: 170
//
// Two 8-byte cells. atomic_store 115/55, atomic_load each, sum -> 170.
// On the current backend the loads return 0 -> exit 0. Will exit 170
// once atomics are wired through. Distinct from s42_atom_two_cell_sum
// (175) and s38_atom_two_cell_sum (170, same total but different
// operands 120/50).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 115);
    atomic_store(c2, 55);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 170
    free(c1);
    free(c2);
    return s;
}
