// s19_atom_two_cell_diff.vuma — atomic_store 41/89, diff = 48 (89 - 41)
// Expected exit code: 48
// Expected exit code (correct, post-bridge-fix): 48  (89 - 41)
//
// Two 8-byte cells. atomic_store 41/89 into each, then atomic_load
// both and subtract (b - a). On the current backend all loads return 0
// (atomic_store/load not bridged through to x86_64) -> exit 0. Will
// exit 48 once atomic ops are wired through. Distinct from
// s18_atom_two_cell_sum (23/67 = 90, sum) and s14_atom_two_cell_sum
// (33/44 = 77, sum).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 41);
    atomic_store(c2, 89);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = b - a;
    free(c1);
    free(c2);
    return s;
}
