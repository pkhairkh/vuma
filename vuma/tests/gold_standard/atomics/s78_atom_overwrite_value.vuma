// s78_atom_overwrite_value.vuma — overwrite to 3, atomic_load = 3
// Expected exit code: 3
//
// Single 8-byte cell. atomic_store 1, then atomic_store 3.
// atomic_load should return 3. On the current backend the load
// returns 0 -> exit 0. Will exit 3 once atomics are wired
// through. Distinct from s74_atom_overwrite_value (23),
// s73_atom_overwrite_value (131) and s72_atom_overwrite_value (144).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c1, 3);
    r = atomic_load(c1);
    free(c1);
    return r;
}
