// s16_atom_triple_sum.vuma — three cells, atomic_store 60/70/80, sum = 210
// Expected exit code: 210
// Expected exit code (correct, post-bridge-fix): 210  (60 + 70 + 80)
//
// Three 8-byte cells. atomic_store 60/70/80 into each, then atomic_load
// all three and sum. On the current backend all loads return 0 -> exit 0.
// Will exit 210 once atomics are wired through. Distinct from
// s14_atom_store_three_load (values 33/44/55 = 132) and s7_atom_three_cells_prod
// (three-cell product framing).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c2, 70);
    atomic_store(c3, 80);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
