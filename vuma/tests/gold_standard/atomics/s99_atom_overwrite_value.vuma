// s99_atom_overwrite_value.vuma — overwrite c1 to 99, atomic load = 99
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 99
//
// Single 8-byte cell. atomic_store 5, then atomic_store 99
// (overwrite), then atomic_load -> 99. On the current backend the
// load returns 0 -> exit 0. Will exit 99 once atomics are wired
// through. Distinct from s95_atom_overwrite_value (7),
// s91_atom_overwrite_value (14) and s87_atom_overwrite_value (240).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 99);
    v = atomic_load(c1);              // 99
    free(c1);
    return v;
}
