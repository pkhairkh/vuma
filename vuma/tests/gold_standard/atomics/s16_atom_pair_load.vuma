// s16_atom_pair_load.vuma — two cells, atomic_store 11/22, sum = 33
// Expected exit code: 33
// Expected exit code (correct, post-bridge-fix): 33  (11 + 22)
//
// Two 8-byte cells. atomic_store 11 in c1, 22 in c2, then atomic_load
// both and sum. On the current backend both loads return 0 -> exit 0.
// Will exit 33 once atomics are bridged. Distinct from
// s14_atom_two_cell_sum (values 18/81 = 99) and s13_atom_two_cells_sum
// (values 30/60 = 90).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 11);
    atomic_store(c2, 22);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a + b;
    free(c1);
    free(c2);
    return s;
}
