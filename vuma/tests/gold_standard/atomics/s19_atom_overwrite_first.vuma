// s19_atom_overwrite_first.vuma — atomic_store 70 then overwrite to 25, load = 25
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 25
//
// One 8-byte cell. atomic_store 70, then atomic_store 25 (overwriting
// the first value), then atomic_load. Final stored value should be 25.
// On the current backend all loads return 0 (atomic_store/load not
// bridged) -> exit 0. Will exit 25 once atomic ops are wired. Distinct
// from s18_atom_overwrite_then_load (50 then 120) and
// s14_atom_overwrite_first (40 then 90).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 70);
    atomic_store(c1, 25);
    a = atomic_load(c1);
    free(c1);
    return a;
}
