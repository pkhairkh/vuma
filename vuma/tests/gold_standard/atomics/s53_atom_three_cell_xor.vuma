// s53_atom_three_cell_xor.vuma — three cells, atomic xor = 221 (0x44 ^ 0x88 ^ 0x11)
// Expected exit code: 221
//
// Three 8-byte cells. atomic_store 68/136/17 (0x44/0x88/0x11),
// atomic_load each, xor -> 221 (0xDD). On the current backend the
// loads return 0 -> exit 0. Will exit 221 once atomics are wired
// through. Distinct from s49_atom_three_cell_xor (216) and
// s50_atom_three_cell_xor (204).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 68);             // 0x44
    atomic_store(c2, 136);            // 0x88
    atomic_store(c3, 17);             // 0x11
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;                   // 0xCC = 204
    s: i32 = t ^ c;                   // 0xDD = 221
    free(c1);
    free(c2);
    free(c3);
    return s;
}
