// s37_atom_overwrite_value.vuma — overwrite cell, atomic load = 175
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Atomics test. On the current x86_64 backend atomic_load returns 0, so the
// documented correct value (175) is not observed. Will exit
// 175 once the atomics bridge is wired through.
// Distinct from s33_atom_overwrite_first (overwrite-first, 100) and s30_atom_overwrite_first (different values).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c1, 175);
    a = atomic_load(c1);
    r: i32 = a;                     // 175
    free(c1);
    return r;
}
