// s81_atom_overwrite_value.vuma — overwrite to 131, atomic_load = 131
// Expected exit code: 131
//
// Single 8-byte cell. atomic_store 100, then atomic_store 131.
// atomic_load should return 131. On the current backend the load
// returns 0 -> exit 0. Will exit 131 once atomics are wired
// through. Distinct from s78_atom_overwrite_value (3),
// s77_atom_overwrite_value (47) and s76_atom_overwrite_value (72).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 131);
    r = atomic_load(c1);
    free(c1);
    return r;
}
