// s30_atom_three_cell_sum.vuma — three cells, atomic sum = 200 (50+70+80)
// Expected exit code: 200
//
// Three 8-byte cells. atomic_store 50/70/80, atomic_load each, sum ->
// 200. On the current backend the loads return 0 -> exit 0. Will exit
// 200 once atomics are wired through. Distinct from
// s26_atom_three_cell_sum (sum, 180) and s22_atom_three_cell_inc
// (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c2, 70);
    atomic_store(c3, 80);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;
    s: i32 = t + c;                 // 200
    free(c1);
    free(c2);
    free(c3);
    return s;
}
