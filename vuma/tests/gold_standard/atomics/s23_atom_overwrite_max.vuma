// s23_atom_overwrite_max.vuma — atomic_store 11 then 250, load = 250
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 250
//
// Single 8-byte cell. atomic_store 11, then overwrite with 250.
// atomic_load should observe 250 (last write wins). On the current
// backend the load returns 0 (atomic_store/load not bridged) -> exit 0.
// Distinct from s22_atom_overwrite_load (17 then 88) and s21_atom_overwrite_chain
// (10/30/50 chain).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 11);
    atomic_store(c, 250);
    v = atomic_load(c);
    free(c);
    return v;
}

