// s68_atom_two_cell_sum.vuma — two cells, atomic sum = 189 (145 + 44)
// Expected exit code: 189
//
// Two 8-byte cells. atomic_store 145/44, atomic_load each, sum
// -> 189. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 189 once atomics are wired through.
// Distinct from s66_atom_two_cell_sum (correct 200), s62_atom_two_
// cell_diff (170) and s58_atom_two_cell_sum (165).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 145);
    atomic_store(c2, 44);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 189
    free(c1);
    free(c2);
    return s;
}
