// s17_atom_three_cell_dec.vuma — three cells, atomic_store 90/60/30, sum = 180
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 180  (90 + 60 + 30)
//
// Three 8-byte cells. atomic_store 90/60/30 (descending by 30) into
// each, then atomic_load all three and sum. On the current backend all
// loads return 0 -> exit 0. Will exit 180 once atomics are wired.
// Distinct from s14_atom_store_three_load (33/44/55 = 132) and
// s10_atom_three_cells (10/20/30 = 60).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 90);
    atomic_store(c2, 60);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
