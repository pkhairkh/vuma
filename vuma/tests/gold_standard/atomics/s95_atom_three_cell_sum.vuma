// s95_atom_three_cell_sum.vuma — three cells, atomic sum = 25 (5 + 8 + 12)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 25
//
// Three 8-byte cells. atomic_store 5/8/12, atomic_load each, sum
// -> 25. On the current backend the loads return 0 -> 0 + 0 + 0 = 0
// -> exit 0. Will exit 25 once atomics are wired through. Distinct
// from s94_atom_three_cell_sum (98), s90_atom_three_cell_sum (12) and
// s82_atom_three_cell_diff (26).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c2, 8);
    atomic_store(c3, 12);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a + b + c;               // 25
    free(c1);
    free(c2);
    free(c3);
    return s;
}
