// s106_atom_two_cell_sum.vuma — atomic_store 2 cells (14, 44), load and sum = 14+44 = 58
// Expected exit code: 58
//
// Two 8-byte cells. atomic_store 14 to c1, atomic_store 44 to c2, atomic_load each and return the sum (58). On the current backend atomic_load returns 0 -> sum 0 -> exit 0. Will exit 58 once atomics are wired through.
// Distinct from s102_atom_two_cell_sum (37), s101_atom_two_cell_sum (230), s100_atom_two_cell_sum (31).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 14);
    atomic_store(c2, 44);
    a = atomic_load(c1);          // 14
    b = atomic_load(c2);          // 44
    s = a + b;                    // 58
    free(c1);
    free(c2);
    return s;
}
