// s52_atom_two_cell_sum.vuma — two cells, atomic sum = 180 (80 + 100)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 180
//
// Two 8-byte cells. atomic_store 80/100, atomic_load each, sum -> 180.
// On the current backend the loads return 0 -> exit 0. Will exit 180
// once atomics are wired through. Distinct from s50_atom_two_cell_sum
// (175) and s46_atom_two_cell_xor (255).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c2, 100);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 180
    free(c1);
    free(c2);
    return s;
}
