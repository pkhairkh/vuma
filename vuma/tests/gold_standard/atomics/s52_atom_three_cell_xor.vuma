// s52_atom_three_cell_xor.vuma — three cells, atomic XOR = 224 (0x80 ^ 0x40 ^ 0x20)
// Expected exit code: 224
//
// Three 8-byte cells. atomic_store 128/64/32, atomic_load each,
// XOR -> 128 ^ 64 = 192 (0xC0); 192 ^ 32 = 224 (0xE0). On the current
// backend the loads return 0 -> exit 0. Will exit 224 once atomics
// are wired through. Distinct from s50_atom_three_cell_xor (204) and
// s47_atom_three_cell_sum (240).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 128);
    atomic_store(c2, 64);
    atomic_store(c3, 32);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    x: i32 = a ^ b;        // 0xC0 = 192
    r: i32 = x ^ c;        // 0xE0 = 224
    free(c1);
    free(c2);
    free(c3);
    return r;
}
