// s34_atom_two_cell_sum.vuma — two cells, atomic sum = 165 (90 + 75)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 165
//
// Two 8-byte cells. atomic_store 90/75, atomic_load each, sum -> 165.
// On the current backend the loads return 0 -> exit 0. Will exit 165
// once atomics are wired through. Distinct from s30_atom_two_cell_xor
// (xor, 255) and s27_atom_two_cell_xor (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 90);
    atomic_store(c2, 75);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 165
    free(c1);
    free(c2);
    return s;
}
