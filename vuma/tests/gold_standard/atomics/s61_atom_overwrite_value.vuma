// s61_atom_overwrite_value.vuma — overwrite to 230, atomic_load = 230
// Expected exit code: 230
// 
// Single 8-byte cell. atomic_store 40, then atomic_store 230.
// atomic_load should return 230. On the current backend the load
// returns 0 -> exit 0. Will exit 230 once atomics are wired
// through. Distinct from s58_atom_two_cell_sum (165), s58_atom_three
// _cell_diff (120) and s58_atom_overwrite_high (210).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c1, 230);
    v = atomic_load(c1);
    free(c1);
    return v;
}
