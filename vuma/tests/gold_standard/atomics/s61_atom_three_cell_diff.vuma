// s61_atom_three_cell_diff.vuma — three cells, atomic diff = 100 (240 - 90 - 50)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 100
// 
// Three 8-byte cells. atomic_store 240/90/50, atomic_load each,
// 240 - 90 - 50 = 100. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 100 once atomics are wired
// through. Distinct from s58_atom_two_cell_sum (165), s58_atom_three
// _cell_diff (120) and s58_atom_overwrite_high (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 240);
    atomic_store(c2, 90);
    atomic_store(c3, 50);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;
    r: i32 = t - c;        // 100
    free(c1);
    free(c2);
    free(c3);
    return r;
}
