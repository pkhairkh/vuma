// s62_atom_overwrite_low.vuma — overwrite to 240, atomic_load = 240
// Expected exit code: 240
// 
// Single 8-byte cell. atomic_store 60, then atomic_store 240.
// atomic_load should return 240. On the current backend the load
// returns 0 -> exit 0. Will exit 240 once atomics are wired
// through. Distinct from s51_atom_overwrite_value (245), s58_atom_
// overwrite_high (210) and s55_atom_overwrite_value (220).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c1, 240);
    v = atomic_load(c1);
    free(c1);
    return v;
}
