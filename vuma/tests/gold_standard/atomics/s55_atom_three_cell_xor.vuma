// s55_atom_three_cell_xor.vuma — three cells, atomic XOR = 204 (0x66^0x99^0x33)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 204
//
// Three 8-byte cells. atomic_store 102/153/51, atomic_load each, XOR
// sequentially -> 204 (0xCC). On the current backend the loads return
// 0 -> exit 0. Will exit 204 once atomics are wired through. Distinct
// from s54_atom_three_cell_sum (180) and s53_atom_three_cell_xor (221).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 102);            // 0x66
    atomic_store(c2, 153);            // 0x99
    atomic_store(c3, 51);             // 0x33
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;                   // 0xFF = 255
    s: i32 = t ^ c;                   // 0xCC = 204
    free(c1);
    free(c2);
    free(c3);
    return s;
}
