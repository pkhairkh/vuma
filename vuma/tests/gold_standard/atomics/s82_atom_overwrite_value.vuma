// s82_atom_overwrite_value.vuma — overwrite to 30, atomic_load = 30
// Expected exit code: 30
//
// Single 8-byte cell. atomic_store 6, then atomic_store 30.
// atomic_load should return 30. On the current backend the load
// returns 0 -> exit 0. Will exit 30 once atomics are wired
// through. Distinct from s78_atom_overwrite_value (3),
// s74_atom_overwrite_value (23) and s72_atom_overwrite_value (144).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 6);
    atomic_store(c1, 30);
    r = atomic_load(c1);
    free(c1);
    return r;
}
