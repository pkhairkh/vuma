// s41_atom_three_cell_sum.vuma - three cells, atomic sum = 240 (50 + 80 + 110)
// Expected exit code: 240
//
// Three 8-byte cells. atomic_store 50/80/110, atomic_load each,
// sum -> 240. On the current backend the loads return 0 -> exit 0.
// Will exit 240 once atomics are wired through. Distinct from
// s38_atom_three_cell_sum (150) and s34_atom_three_cell_xor (xor).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c2, 80);
    atomic_store(c3, 110);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;
    s: i32 = t + c;                  // 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
