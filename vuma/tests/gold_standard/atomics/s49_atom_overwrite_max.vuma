// s49_atom_overwrite_max.vuma — overwrite to 255, atomic_load = 255
// Expected exit code: 255
//
// Single 8-byte cell. atomic_store 90, then atomic_store 255.
// atomic_load should return 255. On the current backend the load
// returns 0 -> exit 0. Will exit 255 once atomics are wired through.
// Distinct from s46_atom_overwrite_value (200) and s42_atom_overwrite_
// max (255, start 90).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 90);
    atomic_store(c1, 255);
    v = atomic_load(c1);
    free(c1);
    return v;
}
