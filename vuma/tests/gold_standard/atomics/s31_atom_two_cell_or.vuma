// s31_atom_two_cell_or.vuma — two cells, atomic or = 255 (0xF0 | 0x0F)
// Expected exit code: 255
//
// Two 8-byte cells. atomic_store 240/15, atomic_load each, OR -> 255.
// On the current backend the load returns 0 -> exit 0. Will exit 255
// once atomics are wired through. Distinct from s30_atom_two_cell_xor
// (xor, 255) and s28_atom_two_cell_and (and, 48).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 240);          // 0xF0
    atomic_store(c2, 15);           // 0x0F
    a = atomic_load(c1);
    b = atomic_load(c2);
    r: i32 = a | b;                 // 0xFF = 255
    free(c1);
    free(c2);
    return r;
}
