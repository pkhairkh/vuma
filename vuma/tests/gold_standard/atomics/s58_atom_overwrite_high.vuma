// s58_atom_overwrite_high.vuma — overwrite to 210, atomic_load = 210
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 210
// 
// Single 8-byte cell. atomic_store 40, then atomic_store 210.
// atomic_load should return 210. On the current backend the load
// returns 0 -> exit 0. Will exit 210 once atomics are wired
// through. Distinct from s51_atom_two_cell_diff (60), s51_atom_
// three_cell_sum (250) and s51_atom_overwrite_value (245).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c1, 210);
    v = atomic_load(c1);
    free(c1);
    return v;
}
