// s57_atom_two_cell_sum.vuma — two cells, atomic sum = 180 (80 + 100)
// Expected exit code: 180
//
// Two 8-byte cells. atomic_store 80/100, atomic_load each, add
// -> 180. On the current backend the loads return 0 -> exit 0.
// Will exit 180 once atomics are wired through. Distinct from
// s54_atom_two_cell_or (127) and s50_atom_two_cell_sum (175).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c2, 100);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 180
    free(c1);
    free(c2);
    return s;
}
