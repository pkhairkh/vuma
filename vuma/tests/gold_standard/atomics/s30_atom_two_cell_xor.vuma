// s30_atom_two_cell_xor.vuma — two cells, atomic xor = 255 (0xAA ^ 0x55)
// Expected exit code: 255
//
// Two 8-byte cells. atomic_store 170/85, atomic_load each, XOR -> 255.
// On the current backend the load returns 0 -> exit 0. Will exit 255
// once atomics are wired through. Distinct from s26_atom_two_cell_or
// (or, 0xFF) and s22_atom_two_cell_xor (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 170);          // 0xAA
    atomic_store(c2, 85);           // 0x55
    a = atomic_load(c1);
    b = atomic_load(c2);
    r: i32 = a ^ b;                 // 0xFF = 255
    free(c1);
    free(c2);
    return r;
}
