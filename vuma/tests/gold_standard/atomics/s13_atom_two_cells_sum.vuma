// s13_atom_two_cells_sum.vuma — two atomic cells, sum loads = 120 (50 + 70)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 120
//
// Two 8-byte cells. atomic_store 50 in c1, 70 in c2. Load both, sum
// -> 120. Current backend returns 0 + 0 = 0. Distinct from
// s9_atom_two_cells_xor (XOR, not sum) and s5_atom_two_cells_diff
// (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c2, 70);
    a = atomic_load(c1);
    b = atomic_load(c2);
    r = a + b;
    free(c1);
    free(c2);
    return r;
}
