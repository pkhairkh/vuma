// s66_atom_two_cell_sum.vuma — two cells, atomic sum = 200 (130 + 70)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 200
//
// Two 8-byte cells. atomic_store 130/70, atomic_load each, sum
// -> 200. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 200 once atomics are wired through.
// Distinct from s62_atom_two_cell_diff (170), s58_atom_two_cell_
// sum (165) and s55_atom_two_cell_sum (250).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 130);
    atomic_store(c2, 70);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 200
    free(c1);
    free(c2);
    return s;
}
