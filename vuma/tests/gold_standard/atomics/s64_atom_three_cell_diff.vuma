// s64_atom_three_cell_diff.vuma — three cells, atomic diff = 125 (220 - 60 - 35)
// Expected exit code: 125
//
// Three 8-byte cells. atomic_store 220/60/35, atomic_load each,
// 220 - 60 - 35 = 125. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 125 once atomics are wired
// through. Distinct from s62_atom_overwrite_low (240), s62_atom_three_
// cell_sum (205) and s62_atom_two_cell_diff (170).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 220);
    atomic_store(c2, 60);
    atomic_store(c3, 35);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 160
    d: i32 = t - c;                   // 125
    free(c1);
    free(c2);
    free(c3);
    return d;
}
