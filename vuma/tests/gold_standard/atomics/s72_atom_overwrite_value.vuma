// s72_atom_overwrite_value.vuma — overwrite to 145, atomic_load = 145
// Expected exit code: 145
//
// Single 8-byte cell. atomic_store 60, then atomic_store 145.
// atomic_load should return 145. On the current backend the load
// returns 0 -> exit 0. Will exit 145 once atomics are wired
// through. Distinct from s70_atom_overwrite_value (185),
// s69_atom_overwrite_value (225) and s66_atom_overwrite_high (230).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c1, 145);
    v = atomic_load(c1);
    free(c1);
    return v;
}
