// s56_atom_two_cell_sum.vuma — two cells, atomic sum = 255 (120 + 135)
// Expected exit code: 255
//
// Two 8-byte cells. atomic_store 120/135, atomic_load each, sum ->
// 255. On the current backend the loads return 0 -> exit 0. Will exit
// 255 once atomics are wired through. Distinct from s54_atom_two_cell_
// or (127) and s50_atom_two_cell_sum (175).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 120);
    atomic_store(c2, 135);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                  // 255
    free(c1);
    free(c2);
    return s;
}
