// s65_atom_two_cell_diff.vuma — two cells, atomic diff = 135 (200 - 65)
// Expected exit code: 135
//
// Two 8-byte cells. atomic_store 200/65, atomic_load each, diff
// -> 135. On the current backend the loads return 0 -> 0 - 0 = 0
// -> exit 0. Will exit 135 once atomics are wired through. Distinct
// from s51_atom_two_cell_diff (60), s58_atom_two_cell_sum (165)
// and s62_atom_two_cell_diff (170).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 65);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 135
    free(c1);
    free(c2);
    return d;
}
