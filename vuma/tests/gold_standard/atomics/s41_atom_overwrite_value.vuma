// s41_atom_overwrite_value.vuma - overwrite to 190, atomic_load = 190
// Expected exit code: 190
//
// Single 8-byte cell. atomic_store 45, then atomic_store 190.
// atomic_load should return 190. On the current backend the load
// returns 0 -> exit 0. Will exit 190 once atomics are wired
// through. Distinct from s38_atom_overwrite_max (255) and s37_atom_
// overwrite_value (same shape, different value).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 45);
    atomic_store(c1, 190);
    v = atomic_load(c1);
    free(c1);
    return v;
}
