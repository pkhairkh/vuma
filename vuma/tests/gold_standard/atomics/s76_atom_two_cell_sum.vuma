// s76_atom_two_cell_sum.vuma — two cells, atomic sum = 57 (31 + 26)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 57
//
// Two 8-byte cells. atomic_store 31/26, atomic_load each, sum
// -> 57. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 57 once atomics are wired through.
// Distinct from s74_atom_two_cell_sum (179), s73_atom_two_cell_sum
// (111) and s72_atom_two_cell_sum (155).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 31);
    atomic_store(c2, 26);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 57
    free(c1);
    free(c2);
    return s;
}
