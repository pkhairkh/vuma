// s29_atom_three_cell_xor.vuma — atomic_store 1/2/4, xor = 7 (0x01 ^ 0x02 ^ 0x04)
// Expected exit code: 7
//
// Three 8-byte cells. atomic_store 1/2/4 into each (distinct single-bit values), then atomic_load all three and XOR. On the current backend all loads return 0 -> exit 0. Will exit 7 once atomic ops are wired through. Distinct from s26_atom_three_cell_sum (sum, 50+60+70=180) and s22_atom_three_cell_inc (inc-pattern).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c2, 2);
    atomic_store(c3, 4);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t = a ^ b;
    s = t ^ c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
