// s94_atom_two_cell_diff.vuma — two cells, atomic diff = 33 (100 - 67)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 33
//
// Two 8-byte cells. atomic_store 100/67, atomic_load each, a - b
// -> 33. On the current backend the loads return 0 -> 0 - 0 = 0 ->
// exit 0. Will exit 33 once atomics are wired through. Distinct from
// s90_atom_two_cell_diff (1), s86_atom_two_cell_sum (200) and
// s82_atom_two_cell_sum (24).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 67);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 33
    free(c1);
    free(c2);
    return d;
}
