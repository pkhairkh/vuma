// s69_atom_overwrite_value.vuma -- overwrite to 225, atomic_load = 225
// Expected exit code: 225
//
// Single 8-byte cell. atomic_store 50, then atomic_store 225.
// atomic_load should return 225. On the current backend the load
// returns 0 -> exit 0. Will exit 225 once atomics are wired through.
// Distinct from s66_atom_overwrite_high (230), s65_atom_overwrite_
// high (195) and s64_atom_overwrite_high (250).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 225);
    v = atomic_load(c1);
    free(c1);
    return v;
}
