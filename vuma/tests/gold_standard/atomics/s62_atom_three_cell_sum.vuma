// s62_atom_three_cell_sum.vuma — three cells, atomic sum = 205 (80 + 95 + 30)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 205
// 
// Three 8-byte cells. atomic_store 80/95/30, atomic_load each,
// 80 + 95 + 30 = 205. On the current backend the loads return 0
// -> 0 + 0 + 0 = 0 -> exit 0. Will exit 205 once atomics are wired
// through. Distinct from s51_atom_three_cell_sum (250), s58_atom_
// three_cell_diff (120) and s55_atom_two_cell_sum (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c2, 95);
    atomic_store(c3, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;                   // 175
    s: i32 = t + c;                   // 205
    free(c1);
    free(c2);
    free(c3);
    return s;
}
