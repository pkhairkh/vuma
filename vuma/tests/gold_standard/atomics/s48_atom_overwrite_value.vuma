// s48_atom_overwrite_value.vuma — store 35, overwrite 195, load = 195
// Expected exit code: 195
//
// Single 8-byte cell. atomic_store 35, then atomic_store 195 to
// overwrite. atomic_load returns 195 (the overwritten value). On
// the current backend the load returns 0 -> exit 0. Will exit 195
// once atomics are wired through. Distinct from s46_atom_overwrite_
// value and s42_atom_overwrite_twice.

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 35);
    atomic_store(c1, 195);
    a = atomic_load(c1);              // 195
    free(c1);
    return a;
}
