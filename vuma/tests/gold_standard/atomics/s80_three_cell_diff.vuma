// s80_atom_three_cell_diff.vuma — three cells, atomic diff = 5 (7 - 1 - 1)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 5
//
// Three 8-byte cells. atomic_store 7/1/1, atomic_load each,
// a - b - c -> 5. On the current backend the loads return 0
// -> 0 - 0 - 0 = 0 -> exit 0. Will exit 5 once atomics are
// wired through. Distinct from s78_atom_three_cell_diff (148),
// s74_atom_three_cell_diff (40) and s73_atom_three_cell_diff (60).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 7);
    atomic_store(c2, 1);
    atomic_store(c3, 1);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    r: i32 = a - b - c;               // 5
    free(c1);
    free(c2);
    free(c3);
    return r;
}
