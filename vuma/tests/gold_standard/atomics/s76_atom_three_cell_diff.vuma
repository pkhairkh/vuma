// s76_atom_three_cell_diff.vuma — three cells, atomic diff = 32 (200 - 60 - 108)
// Expected exit code: 32
//
// Three 8-byte cells. atomic_store 200/60/108, atomic_load each,
// diff -> 200 - 60 - 108 = 32. On the current backend the loads
// return 0 -> 0 - 0 - 0 = 0 -> exit 0. Will exit 32 once atomics
// are wired through. Distinct from s74_atom_three_cell_diff (88),
// s73_atom_three_cell_diff (131) and s72_atom_three_cell_diff (205).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 60);
    atomic_store(c3, 108);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 140
    r: i32 = t - c;                   // 32
    free(c1);
    free(c2);
    free(c3);
    return r;
}
