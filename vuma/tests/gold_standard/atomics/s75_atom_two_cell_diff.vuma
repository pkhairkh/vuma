// s75_atom_two_cell_diff.vuma — two cells, atomic diff = 172 (200 - 28)
// Expected exit code: 172
//
// Two 8-byte cells. atomic_store 200/28, atomic_load each, diff
// -> 172. On the current backend the loads return 0 -> 0 - 0 = 0
// -> exit 0. Will exit 172 once atomics are wired through.
// Distinct from s74_atom_two_cell_sum (179), s70_atom_two_cell_sum
// (75) and s66_atom_two_cell_sum (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 28);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a - b;                   // 172
    free(c1);
    free(c2);
    return s;
}
