// s43_atom_overwrite_value.vuma — overwrite 100 -> 200, load 200
// Expected exit code: 200
//
// Single 8-byte cell. atomic_store 100, then overwrite to 200,
// atomic_load -> 200. On the current backend the load returns 0 ->
// exit 0. Will exit 200 once atomics are wired through. Distinct
// from s42_atom_overwrite_max (255) and s38_atom_overwrite_max (255).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 200);
    v = atomic_load(c1);             // 200
    free(c1);
    return v;
}
