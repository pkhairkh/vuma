// s72_atom_two_cell_sum.vuma — two cells, atomic sum = 115 (80 + 35)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 115
//
// Two 8-byte cells. atomic_store 80/35, atomic_load each, sum
// -> 115. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 115 once atomics are wired through.
// Distinct from s70_atom_two_cell_sum (75), s69_atom_two_cell_sum
// (105) and s66_atom_two_cell_xor (255).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c2, 35);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 115
    free(c1);
    free(c2);
    return s;
}
