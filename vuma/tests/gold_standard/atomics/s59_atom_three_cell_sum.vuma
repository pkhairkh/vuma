// s59_atom_three_cell_sum.vuma — three cells, atomic sum = 225 (60 + 75 + 90)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 225
//
// Three 8-byte cells. atomic_store 60/75/90, atomic_load each, sum ->
// 225. On the current backend the loads return 0 -> exit 0. Will exit
// 225 once atomics are wired through. Distinct from s58_atom_two_cell_
// sum (165), s58_atom_three_cell_diff (120) and s58_atom_overwrite_
// high (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c2, 75);
    atomic_store(c3, 90);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;                   // 135
    s: i32 = t + c;                   // 225
    free(c1);
    free(c2);
    free(c3);
    return s;
}
