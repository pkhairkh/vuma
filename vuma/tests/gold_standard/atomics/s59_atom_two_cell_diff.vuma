// s59_atom_two_cell_diff.vuma — two cells, atomic diff = 110 (200 - 90)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 110
//
// Two 8-byte cells. atomic_store 200/90, atomic_load each, 200 - 90 =
// 110. On the current backend the loads return 0 -> 0 - 0 = 0 -> exit
// 0. Will exit 110 once atomics are wired through. Distinct from
// s58_atom_two_cell_sum (165), s58_atom_three_cell_diff (120) and
// s58_atom_overwrite_high (210).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 90);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 110
    free(c1);
    free(c2);
    return d;
}
