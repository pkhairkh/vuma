// s77_atom_three_cell_diff.vuma — three cells, atomic diff = 171 (250 - 60 - 19)
// Expected exit code: 171
//
// Three 8-byte cells. atomic_store 250/60/19, atomic_load each,
// diff -> 250 - 60 - 19 = 171. On the current backend the loads
// return 0 -> 0 - 0 - 0 = 0 -> exit 0. Will exit 171 once atomics
// are wired through. Distinct from s70_atom_three_cell_diff (110),
// s66_atom_three_cell_diff (90) and s74_atom_three_cell_diff (88).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 250);
    atomic_store(c2, 60);
    atomic_store(c3, 19);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 190
    r: i32 = t - c;                   // 171
    free(c1);
    free(c2);
    free(c3);
    return r;
}
