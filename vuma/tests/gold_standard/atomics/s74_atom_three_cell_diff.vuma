// s74_atom_three_cell_diff.vuma — three cells, atomic diff = 88 (200 - 60 - 52)
// Expected exit code: 88
//
// Three 8-byte cells. atomic_store 200/60/52, atomic_load each,
// diff -> 200 - 60 - 52 = 88. On the current backend the loads
// return 0 -> 0 - 0 - 0 = 0 -> exit 0. Will exit 88 once atomics
// are wired through. Distinct from s70_atom_three_cell_diff (110),
// s66_atom_three_cell_diff (90) and s62_atom_three_cell_sum (205).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 60);
    atomic_store(c3, 52);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 140
    r: i32 = t - c;                   // 88
    free(c1);
    free(c2);
    free(c3);
    return r;
}
