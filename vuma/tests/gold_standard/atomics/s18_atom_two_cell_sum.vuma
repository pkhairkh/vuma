// s18_atom_two_cell_sum.vuma — atomic_store 23/67, sum = 90
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 90  (23 + 67)
//
// Two 8-byte cells. atomic_store 23/67 into each, then atomic_load
// both and sum. On the current backend all loads return 0
// (atomic_store/load not bridged through to x86_64) -> exit 0. Will
// exit 90 once atomic ops are wired through. Distinct from
// s14_atom_two_cell_sum (values 33/44 = 77) and s10_atom_zero_one_pair
// (0 then 50).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 23);
    atomic_store(c2, 67);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a + b;
    free(c1);
    free(c2);
    return s;
}
