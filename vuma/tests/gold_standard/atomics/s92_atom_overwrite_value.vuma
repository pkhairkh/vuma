// s92_atom_overwrite_value.vuma — overwrite c1 to 41, atomic load = 41
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Single 8-byte cell. atomic_store 5, then atomic_store 41
// (overwrite), then atomic_load -> 41. On the current backend the
// load returns 0 -> exit 0. Will exit 41 once atomics are wired
// through. Distinct from s90_atom_overwrite_value (13),
// s86_atom_overwrite_value (245) and s82_atom_overwrite_value (242).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 41);
    v = atomic_load(c1);              // 41
    free(c1);
    return v;
}
