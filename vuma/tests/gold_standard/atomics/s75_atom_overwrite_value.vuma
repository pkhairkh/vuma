// s75_atom_overwrite_value.vuma — overwrite to 254, atomic_load = 254
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 254
//
// Single 8-byte cell. atomic_store 100, then atomic_store 254.
// atomic_load should return 254. On the current backend the load
// returns 0 -> exit 0. Will exit 254 once atomics are wired
// through. Distinct from s74_atom_overwrite_value (23),
// s70_atom_overwrite_value (185) and s66_atom_overwrite_high (230).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 254);
    v = atomic_load(c1);
    free(c1);
    return v;
}
