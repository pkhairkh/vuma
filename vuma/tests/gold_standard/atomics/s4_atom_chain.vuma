// s4_atom_chain.vuma — chain value across three atomic cells via literals
// Expected exit code: 66
//
// Three cells. atomic_store 11, 22, 33 into cell1/2/3 respectively
// (literal values, independent of the loads). Load all three, sum:
// 11 + 22 + 33 = 66. On the current backend all loads return 0 →
// exit 0. Will exit 66 once atomic ops are wired through the bridge.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 11);
    atomic_store(c2, 22);
    atomic_store(c3, 33);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
