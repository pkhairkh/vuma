// s7_atom_load_distinct.vuma — two atomic cells, diff = 80 - 15 = 65
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 65  (80 - 15)
//
// Two 8-byte cells. atomic_store 80/15, then atomic_load both and
// subtract. On the current backend all loads return 0 -> 0 - 0 = 0.
// Will exit 65 once atomic ops are wired through. Distinct from
// s5_atom_two_cells_diff (sum, not diff) and s6_atom_two_cells_sum.

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 80);
    atomic_store(c2, 15);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d = a - b;
    free(c1);
    free(c2);
    return d;
}
