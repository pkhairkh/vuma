// s44_atom_overwrite_max.vuma — overwrite to 250, atomic_load = 250
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 250
//
// Single 8-byte cell. atomic_store 70, then atomic_store 250 (near-max
// u8). atomic_load should return 250. On the current backend the load
// returns 0 -> exit 0. Will exit 250 once atomics are wired through.
// Distinct from s42_atom_overwrite_max (start 90, overwrite 255) and
// s38_atom_overwrite_max (start 80, overwrite 255).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 70);
    atomic_store(c1, 250);
    v = atomic_load(c1);
    free(c1);
    return v;
}
