// s71_atom_three_cell_sum.vuma — three cells, atomic sum = 190 (90+65+35)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 190
//
// Three 8-byte cells. atomic_store 90/65/35, atomic_load each,
// sum -> 190. On the current backend the loads return 0 -> 0+0+0
// = 0 -> exit 0. Will exit 190 once atomics are wired through.
// Distinct from s69_atom_three_cell_diff (105), s70_atom_three_
// cell_diff (110) and s66_atom_three_cell_diff (90).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 90);
    atomic_store(c2, 65);
    atomic_store(c3, 35);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a + b;                   // 155
    s: i32 = t + c;                   // 190
    free(c1);
    free(c2);
    free(c3);
    return s;
}
