// s72_atom_three_cell_diff.vuma — three cells, atomic diff = 180 (250 - 50 - 20)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 180
//
// Three 8-byte cells. atomic_store 250/50/20, atomic_load each,
// diff -> 250 - 50 - 20 = 180. On the current backend the loads
// return 0 -> 0 - 0 - 0 = 0 -> exit 0. Will exit 180 once atomics
// are wired through. Distinct from s70_atom_three_cell_diff (110),
// s69_atom_three_cell_diff (105) and s66_atom_three_cell_or (119).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 250);
    atomic_store(c2, 50);
    atomic_store(c3, 20);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a - b;                   // 200
    r: i32 = t - c;                   // 180
    free(c1);
    free(c2);
    free(c3);
    return r;
}
