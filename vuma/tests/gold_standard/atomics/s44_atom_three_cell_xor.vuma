// s44_atom_three_cell_xor.vuma — three cells, atomic xor = 165 (0xC3 ^ 0x5A ^ 0x3C)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 165
//
// Three 8-byte cells. atomic_store 195/90/60, atomic_load each, xor ->
// 165 (0xA5). On the current backend the loads return 0 -> exit 0.
// Will exit 165 once atomics are wired through. Distinct from
// s42_atom_three_cell_xor (0xA5 ^ 0x3C ^ 0x5A = 195) and s38_atom_
// three_cell_sum (sum, 150).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 195);   // 0xC3
    atomic_store(c2, 90);    // 0x5A
    atomic_store(c3, 60);    // 0x3C
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a ^ b;
    s: i32 = t ^ c;          // 0xA5 = 165
    free(c1);
    free(c2);
    free(c3);
    return s;
}
