// s4_atom_basic_store_load.vuma — atomic_store/load roundtrip
// Expected exit code: 42
//
// Smallest atomic pattern: allocate an 8-byte cell, atomic_store 42,
// atomic_load it back, return. Per the documented KNOWN CODEGEN GAP
// (bridge_scg_to_codegen doesn't recognise Expr::AtomicStore/Load),
// atomic_store never writes and atomic_load always returns 0, so the
// program exits 0 on the current backend. This test will start
// exiting 42 once the bridge is taught to lower atomic ops.

fn main() -> i32 {
    cell = allocate(8);
    atomic_store(cell, 42);
    v = atomic_load(cell);
    free(cell);
    return v;
}
