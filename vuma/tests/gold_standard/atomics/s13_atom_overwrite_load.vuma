// s13_atom_overwrite_load.vuma — atomic store twice, load sees last = 150
// Expected exit code: 150
//
// Single 8-byte cell. atomic_store 30, then atomic_store 150
// (overwrite). atomic_load should yield 150 (last write wins).
// Current backend returns 0. Distinct from s9_atom_overwrite_load
// (values 20/200) and s6_atom_overwrite_load (values 10/60).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 30);
    atomic_store(c, 150);
    v = atomic_load(c);
    free(c);
    return v;
}
