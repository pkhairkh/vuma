// s9_atom_overwrite_load.vuma — atomic store twice, load sees last = 200
// Expected exit code: 200
//
// Single 8-byte cell. atomic_store 20, then atomic_store 200
// (overwrite). atomic_load should yield 200 (last write wins).
// Current backend returns 0. Distinct from s6_atom_overwrite_load
// (values 10/60) and s5_atom_overwrite_load (values 11/55).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 20);
    atomic_store(c, 200);
    v = atomic_load(c);
    free(c);
    return v;
}
