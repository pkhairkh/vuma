// s82_atom_two_cell_sum.vuma — two cells, atomic sum = 24 (14 + 10)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 24
//
// Two 8-byte cells. atomic_store 14/10, atomic_load each, sum
// -> 24. On the current backend the loads return 0 -> 0 + 0 = 0
// -> exit 0. Will exit 24 once atomics are wired through.
// Distinct from s78_atom_two_cell_sum (2), s74_atom_two_cell_sum
// (90) and s72_atom_two_cell_sum (120).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 14);
    atomic_store(c2, 10);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 24
    free(c1);
    free(c2);
    return s;
}
