// s67_atom_three_cell_or.vuma — three cells, atomic or = 119 (17 | 34 | 68)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 119
//
// Three 8-byte cells. atomic_store 17/34/68, atomic_load each,
// or -> 17 | 34 | 68 = 119 (0x77). On the current backend the
// loads return 0 -> 0 | 0 | 0 = 0 -> exit 0. Will exit 119 once
// atomics are wired through. Distinct from s66_atom_three_cell_
// diff (correct 90), s62_atom_three_cell_sum (205) and s58_
// atom_three_cell_diff (120).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 17);
    atomic_store(c2, 34);
    atomic_store(c3, 68);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    t: i32 = a | b;                   // 0x33 = 51
    r: i32 = t | c;                   // 0x77 = 119
    free(c1);
    free(c2);
    free(c3);
    return r;
}
