// s47_atom_overwrite_high.vuma — overwrite to 235, atomic_load = 235
// Expected exit code: 235
//
// Single 8-byte cell. atomic_store 25, then atomic_store 235.
// atomic_load should return 235. On the current backend the load
// returns 0 -> exit 0. Will exit 235 once atomics are wired
// through. Distinct from s46_atom_overwrite_value (start 100, ow
// 200) and s42_atom_overwrite_max (start 90, ow 255).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 25);
    atomic_store(c1, 235);
    v = atomic_load(c1);
    free(c1);
    return v;
}
