// s90_atom_overwrite_value.vuma — overwrite c1 to 13, atomic load = 13
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 13
//
// Single 8-byte cell. atomic_store 5, then atomic_store 13
// (overwrite), then atomic_load -> 13. On the current backend the
// load returns 0 -> exit 0. Will exit 13 once atomics are wired
// through. Distinct from s86_atom_overwrite_value (245),
// s82_atom_overwrite_value (242) and s78_atom_overwrite_value (3).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 13);
    v = atomic_load(c1);              // 13
    free(c1);
    return v;
}
