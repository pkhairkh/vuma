// s17_atom_two_cell_xor.vuma — two cells, atomic_store 0x55/0x33, xor = 0x66 = 102
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 102  (0x55 ^ 0x33)
//
// Two 8-byte cells. atomic_store 0x55 (85) in c1, 0x33 (51) in c2,
// then atomic_load both and XOR. On the current backend both loads
// return 0 (atomic_store/load not bridged through to x86_64) -> exit 0.
// Will exit 102 once atomics are wired through. Distinct from
// s14_atom_two_cell_sum (sum, 18+81) and s10_atom_two_cells_xor
// (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 85);
    atomic_store(c2, 51);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a ^ b;
    free(c1);
    free(c2);
    return s;
}
