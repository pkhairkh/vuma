// s39_atom_overwrite_max.vuma — overwrite to 255, atomic_load = 255
// Expected exit code: 255
//
// Single 8-byte cell. atomic_store 95, then atomic_store 255 (max
// u8). atomic_load should return 255. On the current backend the
// load returns 0 -> exit 0. Will exit 255 once atomics are wired
// through. Distinct from s38_atom_overwrite_max (same shape,
// different seed) and s34_atom_overwrite_max.

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 95);
    atomic_store(c1, 255);
    v = atomic_load(c1);
    free(c1);
    return v;
}
