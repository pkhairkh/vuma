// s17_atom_overwrite_chain.vuma — atomic_store 5 then 50 then 200, load sees 200
// Expected exit code: 200
//
// Single 8-byte cell. atomic_store 5, overwrite with 50, overwrite
// with 200 (last write wins). atomic_load should observe 200. On the
// current backend the load returns 0 -> exit 0. Will exit 200 once
// atomics are wired. Distinct from s14_atom_overwrite_load (two writes,
// 17/73) and s10_atom_overwrite_twice (three writes 10/80/90).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 5);
    atomic_store(c, 50);
    atomic_store(c, 200);
    v = atomic_load(c);
    free(c);
    return v;
}
