// s23_atom_two_cell_diff.vuma — two cells, diff = 120 (200 - 80)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 120
//
// Two 8-byte cells. atomic_store 200/80, atomic_load both, subtract
// -> 120. On the current backend atomic_load returns 0 (atomic_store/load
// not bridged) -> exit 0. Will exit 120 once atomics are wired. Distinct
// from s22_atom_two_cell_xor (xor, 41 ^ 98 = 75) and s18_atom_two_cell_sum
// (sum, 18 + 82 = 100).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 80);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d = a - b;            // 120
    free(c1);
    free(c2);
    return d;
}

