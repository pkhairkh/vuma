// s67_atom_overwrite_low.vuma — overwrite to 245, atomic_load = 245
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 245
//
// Single 8-byte cell. atomic_store 40, then atomic_store 245.
// atomic_load should return 245. On the current backend the
// load returns 0 -> exit 0. Will exit 245 once atomics are
// wired through. Distinct from s66_atom_overwrite_high (correct
// 230), s62_atom_overwrite_low (240) and s58_atom_overwrite_
// high (210).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c1, 245);
    v = atomic_load(c1);
    free(c1);
    return v;
}
