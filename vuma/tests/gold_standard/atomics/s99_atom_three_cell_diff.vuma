// s99_atom_three_cell_diff.vuma — three cells, atomic diff = 17 (100 - 60 - 23)
// Expected exit code: 17
//
// Three 8-byte cells. atomic_store 100/60/23, atomic_load each,
// a - b - c -> 17. On the current backend the loads return 0 ->
// 0 - 0 - 0 = 0 -> exit 0. Will exit 17 once atomics are wired
// through. Distinct from s95_atom_three_cell_sum (25),
// s91_atom_three_cell_sum (21) and s87_atom_three_cell_diff (150).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c2, 60);
    atomic_store(c3, 23);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    d: i32 = a - b - c;               // 17
    free(c1);
    free(c2);
    free(c3);
    return d;
}
