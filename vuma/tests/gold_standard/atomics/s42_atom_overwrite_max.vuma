// s42_atom_overwrite_max.vuma — overwrite to 255, atomic_load = 255
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 255
//
// Single 8-byte cell. atomic_store 90, then atomic_store 255 (max
// u8). atomic_load should return 255. On the current backend the
// load returns 0 -> exit 0. Will exit 255 once atomics are wired
// through. Distinct from s38_atom_overwrite_max (start 80) and
// s34_atom_overwrite_max (start 50, overwrite 250).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 90);
    atomic_store(c1, 255);
    v = atomic_load(c1);
    free(c1);
    return v;
}
