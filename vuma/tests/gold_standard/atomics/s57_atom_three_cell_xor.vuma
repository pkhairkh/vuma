// s57_atom_three_cell_xor.vuma — three cells, atomic XOR = 30 (60^90^120)
// Expected exit code: 30
//
// Three 8-byte cells. atomic_store 60/90/120, atomic_load each, XOR
// -> 30 (60 ^ 90 = 102; 102 ^ 120 = 30). On the current backend the
// loads return 0 -> exit 0. Will exit 30 once atomics are wired
// through. Distinct from s54_atom_three_cell_sum (180) and s50_atom_
// three_cell_xor (200).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c2, 90);
    atomic_store(c3, 120);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    s: i32 = a ^ b ^ c;              // 30
    free(c1);
    free(c2);
    free(c3);
    return s;
}
