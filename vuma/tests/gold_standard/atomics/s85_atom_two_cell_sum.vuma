// s85_atom_two_cell_sum.vuma — two cells, atomic sum = 150 (60 + 90)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 150
//
// Two 8-byte cells. atomic_store 60/90, atomic_load each,
// sum -> 150. On the current backend the loads return 0 ->
// 0 + 0 = 0 -> exit 0. Will exit 150 once atomics are wired
// through. Distinct from s82_atom_two_cell_sum (24),
// s78_atom_two_cell_sum (2) and s74_atom_two_cell_sum (90).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 60);
    atomic_store(c2, 90);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 150
    free(c1);
    free(c2);
    return s;
}
