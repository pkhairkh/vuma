// s21_atom_overwrite_chain.vuma — atomic_store 20->40->80, load = 80
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 80
//
// Single 8-byte cell. atomic_store 20, overwrite with 40, overwrite with
// 80 (last write wins). atomic_load returns 80 on a correct backend. On
// the current backend all loads return 0 -> exit 0. Will exit 80 once
// atomic ops are wired. Distinct from s14_atom_overwrite_load (single
// overwrite) and s10_atom_overwrite_twice (two overwrites, different vals).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 20);
    atomic_store(c, 40);
    atomic_store(c, 80);
    v = atomic_load(c);
    free(c);
    return v;
}
