// s64_atom_overwrite_high.vuma — overwrite to 250, atomic_load = 250
// Expected exit code: 250
//
// Single 8-byte cell. atomic_store 40, then atomic_store 250.
// atomic_load should return 250. On the current backend the load
// returns 0 -> exit 0. Will exit 250 once atomics are wired
// through. Distinct from s62_atom_overwrite_low (240), s62_atom_three_
// cell_sum (205) and s62_atom_two_cell_diff (170).

fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c1, 250);
    v = atomic_load(c1);
    free(c1);
    return v;
}
