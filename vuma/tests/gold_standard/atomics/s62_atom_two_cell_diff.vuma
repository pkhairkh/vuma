// s62_atom_two_cell_diff.vuma — two cells, atomic diff = 170 (200 - 30)
// Expected exit code: 170
// 
// Two 8-byte cells. atomic_store 200/30, atomic_load each, diff
// -> 170. On the current backend the loads return 0 -> 0 - 0 = 0
// -> exit 0. Will exit 170 once atomics are wired through. Distinct
// from s51_atom_two_cell_diff (60), s58_atom_two_cell_sum (165)
// and s55_atom_two_cell_sum (250).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 200);
    atomic_store(c2, 30);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                   // 170
    free(c1);
    free(c2);
    return d;
}
