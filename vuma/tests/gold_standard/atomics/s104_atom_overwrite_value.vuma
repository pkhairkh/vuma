// s104_atom_overwrite_value.vuma — atomic_store 1 then overwrite 49, atomic_load = 49
// Expected exit code: 49
//
// Single 8-byte cell. atomic_store 1, then atomic_store 49 (overwrite), then atomic_load -> 49. On the current backend the load returns 0 -> exit 0. Will exit 49 once atomics are wired through.
// Distinct from s102_atom_overwrite_value (38), s102_atom_three_cell_diff (197), s102_atom_two_cell_sum (37).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 1);
    atomic_store(c1, 49);
    v = atomic_load(c1);              // 49
    free(c1);
    return v;
}
