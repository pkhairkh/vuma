// s88_atom_overwrite_value.vuma — overwrite to 235, atomic_load = 235
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 235
//
// Single 8-byte cell. atomic_store 7, then atomic_store
// 235. atomic_load should return 235. On the current
// backend the load returns 0 -> exit 0. Will exit 235 once
// atomics are wired through. Distinct from s86_atom_
// overwrite_value (240), s82_atom_overwrite_value (30) and
// s78_atom_overwrite_value (3).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 7);
    atomic_store(c1, 235);
    r = atomic_load(c1);
    free(c1);
    return r;
}
