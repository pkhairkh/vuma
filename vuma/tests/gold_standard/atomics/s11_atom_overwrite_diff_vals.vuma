// s11_atom_overwrite_diff_vals.vuma — atomic_store 100 then 50, load sees 50
// Expected exit code: 50
//
// Single 8-byte cell. atomic_store 100, then overwrite with 50. Load
// should observe 50 (last write wins; overwrite goes high-to-low).
// On the current backend the load returns 0. Distinct from
// s7_atom_overwrite_first (high-to-low, different vals 200/100) and
// s10_atom_overwrite_twice (three writes).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 100);
    atomic_store(c, 50);
    v = atomic_load(c);
    free(c);
    return v;
}
