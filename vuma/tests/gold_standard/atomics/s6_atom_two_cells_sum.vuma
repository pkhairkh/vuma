// s6_atom_two_cells_sum.vuma — two atomic stores + loads, sum = 90 (40 + 50)
// Expected exit code: 90
// Expected exit code (correct, post-bridge-fix): 90  (40 + 50)
//
// Two 8-byte cells. atomic_store 40/50 into each, then atomic_load
// both and sum. On the current backend all loads return 0 -> exit 0.
// Will exit 90 once atomic ops are wired through. Distinct from
// s5_atom_three_cells_sum (three cells).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 40);
    atomic_store(c2, 50);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s = a + b;
    free(c1);
    free(c2);
    return s;
}
