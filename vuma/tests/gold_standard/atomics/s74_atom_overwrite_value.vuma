// s74_atom_overwrite_value.vuma — overwrite to 23, atomic_load = 23
// Expected exit code: 23
//
// Single 8-byte cell. atomic_store 100, then atomic_store 23.
// atomic_load should return 23. On the current backend the load
// returns 0 -> exit 0. Will exit 23 once atomics are wired
// through. Distinct from s70_atom_overwrite_value (185),
// s66_atom_overwrite_high (230) and s62_atom_overwrite_low (240).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 100);
    atomic_store(c1, 23);
    v = atomic_load(c1);
    free(c1);
    return v;
}
