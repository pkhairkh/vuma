// s51_atom_two_cell_diff.vuma — two cells, atomic diff = 60 (160 - 100)
// Expected exit code: 60
//
// Two 8-byte cells. atomic_store 160/100, atomic_load each, subtract
// -> 60. On the current backend the loads return 0 -> 0 - 0 = 0 ->
// exit 0. Will exit 60 once atomics are wired through. Distinct from
// s50_atom_two_cell_sum (175) and s47_atom_two_cell_or (204).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 160);
    atomic_store(c2, 100);
    a = atomic_load(c1);
    b = atomic_load(c2);
    d: i32 = a - b;                  // 60
    free(c1);
    free(c2);
    return d;
}
