// s88_atom_two_cell_sum.vuma — two cells, atomic sum = 215 (135 + 80)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 215
//
// Two 8-byte cells. atomic_store 135/80, atomic_load each,
// sum -> 215. On the current backend the loads return 0 ->
// 0 + 0 = 0 -> exit 0. Will exit 215 once atomics are wired
// through. Distinct from s86_atom_two_cell_sum (200),
// s82_atom_two_cell_sum (24) and s78_atom_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 135);
    atomic_store(c2, 80);
    a = atomic_load(c1);
    b = atomic_load(c2);
    s: i32 = a + b;                   // 215
    free(c1);
    free(c2);
    return s;
}
