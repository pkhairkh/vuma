// s93_atom_overwrite_value.vuma — overwrite c1 to 27, atomic load = 27
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 27
//
// Single 8-byte cell. atomic_store 5, then atomic_store 27
// (overwrite), then atomic_load -> 27. On the current backend the
// load returns 0 -> exit 0. Will exit 27 once atomics are wired
// through. Distinct from s90_atom_overwrite_value (13), s82_atom_overwrite_value (30) and s78_atom_overwrite_value (3).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 27);
    v = atomic_load(c1);              // 27
    free(c1);
    return v;
}
