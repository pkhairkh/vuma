// s98_atom_overwrite_value.vuma — overwrite c1 to 36, atomic load = 36
// Expected exit code: 36
//
// Single 8-byte cell. atomic_store 5, then atomic_store 36
// (overwrite), then atomic_load -> 36. On the current backend the
// load returns 0 -> exit 0. Will exit 36 once atomics are wired
// through. Distinct from s94_atom_overwrite_value (201),
// s90_atom_overwrite_value (13) and s86_atom_overwrite_value (240).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 5);
    atomic_store(c1, 36);
    v = atomic_load(c1);              // 36
    free(c1);
    return v;
}
