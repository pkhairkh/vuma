// s8_atom_overwrite_then_load.vuma — atomic store twice, load sees last = 66
// Expected exit code: 66
//
// Single 8-byte cell. atomic_store 33, then atomic_store 66. Load should
// observe 66 (last write wins). On the current backend the load returns 0.
// Distinct from s6_atom_overwrite_load (different values 10/60).

fn main() -> i32 {
    c = allocate(8);
    atomic_store(c, 33);
    atomic_store(c, 66);
    v = atomic_load(c);
    free(c);
    return v;
}
