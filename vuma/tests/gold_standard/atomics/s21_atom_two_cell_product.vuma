// s21_atom_two_cell_product.vuma — atomic_store 8/9, product = 72
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 72  (8 * 9)
//
// Two 8-byte cells. atomic_store 8/9 into each, then atomic_load both
// and multiply. On the current backend all loads return 0 (atomic_store/
// load not bridged) -> exit 0. Will exit 72 once atomic ops are wired.
// Distinct from s14_atom_two_cell_sum (sum, 33/44) and s10_atom_two_stores
// (two stores, no product).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    atomic_store(c1, 8);
    atomic_store(c2, 9);
    a = atomic_load(c1);
    b = atomic_load(c2);
    p = a * b;
    free(c1);
    free(c2);
    return p;
}
