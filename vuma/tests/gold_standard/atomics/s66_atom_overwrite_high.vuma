// s66_atom_overwrite_high.vuma — overwrite to 230, atomic_load = 230
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 230
//
// Single 8-byte cell. atomic_store 50, then atomic_store 230.
// atomic_load should return 230. On the current backend the load
// returns 0 -> exit 0. Will exit 230 once atomics are wired
// through. Distinct from s62_atom_overwrite_low (240), s58_atom_
// overwrite_high (210) and s55_atom_overwrite_value (220).
fn main() -> i32 {
    c1 = allocate(8);
    atomic_store(c1, 50);
    atomic_store(c1, 230);
    v = atomic_load(c1);
    free(c1);
    return v;
}
