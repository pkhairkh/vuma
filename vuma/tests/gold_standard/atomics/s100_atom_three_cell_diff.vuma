// s100_atom_three_cell_diff.vuma — three cells, atomic diff = 43 (95 - 30 - 22)
// Expected exit code: 0 (current buggy backend)
// Expected exit code (correct, post-bridge-fix): 43
//
// Three 8-byte cells. atomic_store 95/30/22,
// atomic_load each, a - b - c -> 43. On the current
// backend the loads return 0 -> 0 - 0 - 0 = 0 -> exit 0.
// Will exit 43 once atomics are wired through.
// Distinct from s97_atom_three_cell_diff (46), s94_atom_overwrite_value (201), s90_atom_overwrite_value (13).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    atomic_store(c1, 95);
    atomic_store(c2, 30);
    atomic_store(c3, 22);
    a = atomic_load(c1);
    b = atomic_load(c2);
    c = atomic_load(c3);
    d: i32 = a - b - c;               // 43
    free(c1);
    free(c2);
    free(c3);
    return d;
}
