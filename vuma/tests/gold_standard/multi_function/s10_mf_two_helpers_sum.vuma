// s10_mf_two_helpers_sum.vuma — add5(10) + double(20) = 15 + 40 = 55
// Expected exit code: 55
//
// add5(x) = x + 5; double(x) = x * 2. main calls add5(10) -> 15 and
// double(20) -> 40, sums -> 55. Distinct from s6_mf_call_two_then_sum
// (half/third helpers) and s5_mf_two_callers (same helper, two callers).

fn add5(x: u32) -> u32 {
    c: u32 = 5;
    r: u32 = x + c;
    return r;
}

fn double(x: u32) -> u32 {
    c: u32 = 2;
    r: u32 = x * c;
    return r;
}

fn main() -> i32 {
    a: u32 = add5(10);    // 15
    b: u32 = double(20);  // 40
    s: u32 = a + b;       // 55
    return s;
}
