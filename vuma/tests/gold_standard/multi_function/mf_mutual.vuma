// mf_mutual.vuma — f1 → f2 → f3 → return 42
// Expected exit code: 42
//
// Originally framed as a mutual-recursion test, but VUMA's codegen
// has no need for true mutual recursion here — the semantic intent
// is a linear chain f1 → f2 → f3 returning a constant. f3 returns
// 42; f2 returns f3's result; f1 returns f2's result; main returns
// f1's result.

fn f3() -> u32 {
    return 42;
}

fn f2() -> u32 {
    v: u32 = f3();
    return v;
}

fn f1() -> u32 {
    v: u32 = f2();
    return v;
}

fn main() -> i32 {
    v: u32 = f1();
    return v;
}
