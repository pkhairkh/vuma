// s88_mf_three_chain.vuma — f3(f2(f1(0))) = f3(f2(15)) = f3(50) = 125
// Expected exit code: 125
//
// Three single-arg helpers chained. f1(x) = x + 15; f2(x)
// = x + 35; f3(x) = x + 75. main calls f3(f2(f1(0))) -> 0
// + 15 + 35 + 75 = 125. Distinct from s86_mf_three_chain
// (130), s82_mf_three_chain (155) and s78_mf_three_chain
// (5).
fn f1(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 35;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 75;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(0);          // 15
    b: u32 = f2(a);          // 50
    c: u32 = f3(b);          // 125
    return c;
}
