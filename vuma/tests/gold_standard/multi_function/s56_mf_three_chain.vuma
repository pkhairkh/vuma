// s56_mf_three_chain.vuma — h(5)=15, g(15)=45, f(45)=55
// Expected exit code: 55
//
// Three single-arg helpers chained sequentially. h(x) = x + 10;
// g(x) = x * 3; f(x) = x + 10. main calls h(5) -> 15, g(15) -> 45,
// f(45) -> 55. Distinct from s54_mf_three_chain (35) and
// s50_mf_three_chain (50).

fn h(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn g(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn f(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = h(5);             // 15
    b: u32 = g(a);             // 45
    r: u32 = f(b);             // 55
    return r;
}
