// s80_mf_three_chain.vuma — f3(f2(f1(1))) = f3(f2(9)) = f3(16) = 48
// Expected exit code: 48
//
// Three single-arg helpers chained. f1(x) = x + 8; f2(x) = x + 7;
// f3(x) = x + 32. main calls f3(f2(f1(1))) -> 1 + 8 + 7
// + 32 = 48. Distinct from s78_mf_three_chain (5),
// s74_mf_three_chain (111) and s73_mf_three_chain (89).
fn f1(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 32;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(1);          // 9
    b: u32 = f2(a);            // 16
    c: u32 = f3(b);            // 48
    return c;
}
