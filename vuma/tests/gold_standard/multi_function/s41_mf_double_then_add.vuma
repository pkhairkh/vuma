// s41_mf_double_then_add.vuma - dbl(25) + add_nine(25) = 50 + 34 = 84
// Expected exit code: 84
//
// Two single-arg helpers called on the same literal then summed.
// dbl(x) = x * 2; add_nine(x) = x + 9. main calls dbl(25) -> 50
// and add_nine(25) -> 34; sum = 84. Distinct from s38_mf_double_
// then_add (97) and s34_mf_double_then_add (80).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_nine(x: u32) -> u32 {
    n: u32 = 9;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(25);         // 50
    b: u32 = add_nine(25);    // 34
    r: u32 = a + b;           // 84
    return r;
}
