// s53_mf_two_helpers_add.vuma — inc_five(40) + inc_three(50) = 45 + 53 = 98
// Expected exit code: 98
//
// Two single-arg helpers called on different literals then summed.
// inc_five(x) = x + 5; inc_three(x) = x + 3. main calls inc_five(40)
// -> 45 and inc_three(50) -> 53; sum = 98. Distinct from s49_mf_two_
// helpers_add (68) and s50_mf_two_helpers_mul (110).

fn inc_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn inc_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = inc_five(40);     // 45
    b: u32 = inc_three(50);    // 53
    r: u32 = a + b;            // 98
    return r;
}
