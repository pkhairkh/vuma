// s62_mf_three_chain.vuma — sub_four(40)=36, double(36)=72, add_eight(72)=80
// Expected exit code: 80
// 
// Three single-arg helpers chained: sub_four(x)=x-4, double(x)=x*2,
// add_eight(x)=x+8. main calls sub_four(40) -> 36, double(36) -> 72,
// add_eight(72) -> 80. Distinct from s51_mf_three_chain (53), s58_mf_
// three_chain (50) and s55_mf_three_chain (53).

fn sub_four(x: u32) -> u32 {
    n: u32 = 4;
    r: u32 = x - n;
    return r;
}
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = sub_four(40);      // 36
    b: u32 = double(a);         // 72
    r: u32 = add_eight(b);      // 80
    return r;
}
