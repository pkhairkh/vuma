// s88_mf_two_helpers_add.vuma — f1(40) + f2(50) = 60 + 110 = 170
// Expected exit code: 170
//
// Two single-arg helpers. f1(x) = x + 20; f2(y) = y + 60.
// main calls both and adds: f1(40) + f2(50) = 60 + 110 =
// 170. Distinct from s86_mf_two_helpers_add (150), s82_mf_
// two_helpers_add (105) and s78_mf_two_helpers_add (4).
fn f1(x: u32) -> u32 {
    k: u32 = 20;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 60;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(40);         // 60
    b: u32 = f2(50);         // 110
    s: u32 = a + b;          // 170
    return s;
}
