// s74_mf_two_helpers_add.vuma — add_thirty(70)=100, add_forty_four(40)=84; 100+84=184
// Expected exit code: 184
//
// Two single-arg helpers called on different literals then summed.
// add_thirty(x) = x + 30; add_forty_four(x) = x + 44. main calls
// add_thirty(70) -> 100 and add_forty_four(40) -> 84; sum = 184.
// Distinct from s70_mf_two_helpers_add (210), s66_mf_two_helpers_
// sub (185) and s62_mf_two_helpers_add (150).
fn add_thirty(x: u32) -> u32 {
    n: u32 = 30;
    r: u32 = x + n;
    return r;
}
fn add_forty_four(x: u32) -> u32 {
    n: u32 = 44;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_thirty(70);       // 100
    b: u32 = add_forty_four(40);   // 84
    r: u32 = a + b;                // 184
    return r;
}
