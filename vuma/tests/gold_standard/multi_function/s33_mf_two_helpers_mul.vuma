// s33_mf_two_helpers_mul.vuma — mul2(40) + mul3(15) = 80 + 45 = 125
// Expected exit code: 125
//
// Deterministic test in the multi_function category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_mf_two_helpers_sum (add4+mul3=79) and s26_mf_two_helpers_sum (add3+mul2=53).
fn mul2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn mul3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = mul2(40);    // 80
    b: u32 = mul3(15);    // 45
    r: u32 = a + b;       // 125
    return r;
}
