// s11_mf_two_calls_diff.vuma — half(80) + quad(5) = 40 + 20 = 60
// Expected exit code: 60
//
// Two helpers: half(x) = x / 2; quad(x) = x * 4. main calls half(80)
// -> 40 and quad(5) -> 20, sums -> 60. Distinct from s10_mf_two_helpers_sum
// (add5/double helpers) and s6_mf_pass_intermediate (pass-through).

fn half(x: u32) -> u32 {
    c: u32 = 2;
    r: u32 = x / c;
    return r;
}

fn quad(x: u32) -> u32 {
    c: u32 = 4;
    r: u32 = x * c;
    return r;
}

fn main() -> i32 {
    a: u32 = half(80);   // 40
    b: u32 = quad(5);    // 20
    s: u32 = a + b;      // 60
    return s;
}
