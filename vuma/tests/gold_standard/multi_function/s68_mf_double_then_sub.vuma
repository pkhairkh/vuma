// s68_mf_double_then_sub.vuma — sub_35(double(90)) = sub_35(180) = 145
// Expected exit code: 145
//
// Two single-arg helpers chained. double(x) = x * 2; sub_35(x)
// = x - 35. main calls sub_35(double(90)) -> 180 - 35 = 145.
// Distinct from s66_mf_double_then_sub (140), s62_mf_double_then_
// add (115) and s58_mf_double_then_add (120).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_35(x: u32) -> u32 {
    n: u32 = 35;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(90);        // 180
    r: u32 = sub_35(a);         // 145
    return r;
}
