// s14_mf_two_helpers_chain.vuma — outer(inner(5)) = (5+10)*2 = 30
// Expected exit code: 30
//
// Two single-arg helpers chained: inner(x) = x + 10, outer(x) = x * 2.
// main calls inner(5) -> 15, then outer(15) -> 30. Each call uses
// an intermediate local. Distinct from s9_mf_two_helpers_sub
// (sub5(sub3(20)) = 12) and s9_mf_pass_two_then_mul (mul3(add1(7))).

fn inner(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn outer(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inner(5);    // 15
    b: u32 = outer(a);    // 30
    return b;
}
