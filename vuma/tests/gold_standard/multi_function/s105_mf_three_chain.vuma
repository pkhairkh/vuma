// s105_mf_three_chain.vuma — f3(f2(f1(105))) = 105 + 1 + 1 + 1 = 108
// Expected exit code: 108
// 
// Three single-arg helpers f1(x)=x+1, f2(x)=x+1, f3(x)=x+1. main calls them in sequence (flat form, no nested-call arguments), threading the result: a = f1(105) = 106; b = f2(a) = 107; c = f3(b) = 108.
// Distinct from s102_mf_three_chain (13), s101_mf_three_chain (20), s100_mf_three_chain (131).
fn f1(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(105);        // 106
    b: u32 = f2(a);          // 107
    c: u32 = f3(b);          // 108
    return c;
}
