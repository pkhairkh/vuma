// s85_mf_pass_through.vuma — main -> f1(160) -> f2(v) -> return 160
// Expected exit code: 160
//
// Two-function pass-through chain: main passes 160 to f1,
// which passes it to f2, which returns it. The value should
// arrive back at main unchanged. Distinct from
// s82_mf_pass_through, s78_mf_pass_through and
// s74_mf_pass_through.
fn f2(x: u32) -> u32 {
    return x;
}

fn f1(x: u32) -> u32 {
    v: u32 = f2(x);
    return v;
}

fn main() -> i32 {
    v: u32 = f1(160);
    return v;
}
