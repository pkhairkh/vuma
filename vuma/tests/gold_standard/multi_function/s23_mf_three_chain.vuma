// s23_mf_three_chain.vuma — sub3(dbl(inc(5))) = sub3(dbl(6)) = sub3(12) = 9
// Expected exit code: 9
//
// Three single-arg helpers chained: inc(x) = x + 1; dbl(x) = x * 2;
// sub3(x) = x - 3. main calls inc(5) -> 6, then dbl(6) -> 12, then
// sub3(12) -> 9. Distinct from s22_mf_three_chain (dbl, inc, sub2 -> 15)
// and s24_mf_three_chain (different ops -> 17).

fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(5);      // 6
    b: u32 = dbl(a);      // 12
    c: u32 = sub3(b);     // 9
    return c;
}

