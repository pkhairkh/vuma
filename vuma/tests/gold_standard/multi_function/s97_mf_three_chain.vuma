// s97_mf_three_chain.vuma — f3(f2(f1(70))) = 70 + 8 + 8 + 8 = 94
// Expected exit code: 94
//
// Three single-arg helpers, each adds 8. main calls them in
// sequence, threading the result: a = f1(70) = 78; b =
// f2(a) = 86; c = f3(b) = 94.
// Distinct from s94_mf_three_chain (70), s90_mf_three_chain (34), s86_mf_three_chain (130).
fn f1(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(70);         // 78
    b: u32 = f2(a);          // 86
    c: u32 = f3(b);          // 94
    return c;
}
