// s51_mf_two_helpers_add.vuma — add_four(40) + add_six(30) = 44 + 36 = 80
// Expected exit code: 80
//
// Two single-arg helpers called on different literals then summed.
// add_four(x) = x + 4; add_six(x) = x + 6. main calls add_four(40)
// -> 44 and add_six(30) -> 36; sum = 80. Distinct from s50_mf_two_
// helpers_mul (110) and s47_mf_two_helpers_sub (62).

fn add_four(x: u32) -> u32 {
    n: u32 = 4;
    r: u32 = x + n;
    return r;
}
fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_four(40);     // 44
    b: u32 = add_six(30);      // 36
    r: u32 = a + b;            // 80
    return r;
}
