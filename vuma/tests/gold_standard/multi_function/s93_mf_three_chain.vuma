// s93_mf_three_chain.vuma — f3(f2(f1(44))) = 44 + 10 + 10 + 10 = 74
// Expected exit code: 74
//
// Three single-arg helpers, each adds 10. main calls them in
// sequence, threading the result: a = f1(44) = 54; b = f2(a) = 64;
// c = f3(b) = 74. Distinct from s90_mf_three_chain (34), s82_mf_three_chain (155) and s78_mf_three_chain (5).
fn f1(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(44);         // 54
    b: u32 = f2(a);          // 64
    c: u32 = f3(b);          // 74
    return c;
}
