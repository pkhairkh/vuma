// s54_mf_two_helpers_add.vuma — dbl(40) + triple(15) = 80 + 45 = 125
// Expected exit code: 125
//
// Two single-arg helpers called on different literals then summed.
// dbl(x) = x * 2; triple(x) = x * 3. main calls dbl(40) -> 80 and
// triple(15) -> 45; sum = 125. Distinct from s50_mf_two_helpers_mul
// (110) and s49_mf_two_helpers_add (120).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn triple(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(40);          // 80
    b: u32 = triple(15);       // 45
    r: u32 = a + b;            // 125
    return r;
}
