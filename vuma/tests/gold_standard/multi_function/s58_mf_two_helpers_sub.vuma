// s58_mf_two_helpers_sub.vuma — sub_five(80) + sub_three(40) = 75 + 37 = 112
// Expected exit code: 112
// 
// Two single-arg helpers called on different literals then summed.
// sub_five(x) = x - 5; sub_three(x) = x - 3. main calls sub_five(80)
// -> 75 and sub_three(40) -> 37; sum = 112. Distinct from s51_mf_two_
// helpers_add (80), s51_mf_three_chain (53) and s51_mf_double_then_
// add (120).

fn sub_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}
fn sub_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = sub_five(80);      // 75
    b: u32 = sub_three(40);     // 37
    r: u32 = a + b;             // 112
    return r;
}
