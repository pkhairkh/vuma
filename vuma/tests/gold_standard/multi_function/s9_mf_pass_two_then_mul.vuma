// s9_mf_pass_two_then_mul.vuma — mul3(add1(7)) = (7+1)*3 = 24
// Expected exit code: 24
//
// add1(x) = x + 1, mul3(x) = x * 3. main calls add1(7) -> 8, then
// passes that result into mul3 -> 24. Different operations in each
// helper. Distinct from s5_mf_diff_op_funcs (mul2(add3(7)) = 20).

fn add1(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn mul3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add1(7);   // 8
    b: u32 = mul3(a);   // 24
    return b;
}
