// s61_mf_three_chain.vuma — add_eight(15)=23, mul_two(23)=46, sub_six(46)=40
// Expected exit code: 40
// 
// Three single-arg helpers chained: add_eight(x)=x+8, mul_two(x)=
// x*2, sub_six(x)=x-6. main calls add_eight(15) -> 23, mul_two(23)
// -> 46, sub_six(46) -> 40. Distinct from s58_mf_two_helpers_sub
// (112), s58_mf_three_chain (50) and s58_mf_triple_then_add (120).

fn add_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}
fn mul_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_eight(15);    // 23
    b: u32 = mul_two(a);       // 46
    r: u32 = sub_six(b);       // 40
    return r;
}
