// mf_tree_call.vuma — main calls two helpers, sums results (3+4=7)
// Expected exit code: 7
//
// Tests a call-tree shape: main calls two independent leaf helpers
// and sums their results. helper_a returns 3, helper_b returns 4.

fn helper_a() -> u32 {
    return 3;
}

fn helper_b() -> u32 {
    return 4;
}

fn main() -> i32 {
    a: u32 = helper_a();
    b: u32 = helper_b();
    v: u32 = a + b;
    return v;
}
