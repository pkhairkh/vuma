// s60_mf_two_helpers_add.vuma — add_five(70) + add_three(50) = 75 + 53 = 128
// Expected exit code: 128
//
// Two single-arg helpers called on different literals then summed.
// add_five(x) = x + 5; add_three(x) = x + 3. main calls add_five(70)
// -> 75 and add_three(50) -> 53; sum = 128. Distinct from s58_mf_
// two_helpers_sub (112) and s57_mf_two_helpers_add (100).

fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn add_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_five(70);      // 75
    b: u32 = add_three(50);     // 53
    r: u32 = a + b;             // 128
    return r;
}
