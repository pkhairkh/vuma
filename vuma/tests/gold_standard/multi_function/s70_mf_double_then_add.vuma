// s70_mf_double_then_add.vuma — add_eleven(double(42)) = add_eleven(84) = 95
// Expected exit code: 95
//
// Two single-arg helpers chained. double(x) = x * 2; add_eleven(x)
// = x + 11. main calls add_eleven(double(42)) -> 84 + 11 = 95.
// Distinct from s66_mf_double_then_sub (140), s65_mf_double_then_
// sub (140) and s62_mf_double_then_add (115).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_eleven(x: u32) -> u32 {
    n: u32 = 11;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(42);        // 84
    r: u32 = add_eleven(a);     // 95
    return r;
}
