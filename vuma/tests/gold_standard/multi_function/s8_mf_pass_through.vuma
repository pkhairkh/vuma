// s8_mf_pass_through.vuma — mul2(add1(10)) = mul2(11) = 22
// Expected exit code: 22
//
// Two helpers chained: add1(x)=x+1, mul2(x)=x*2. main calls
// mul2(add1(10)) -> mul2(11) -> 22. Distinct from s3_mf_pass_through_chain
// (longer chain, all adders).

fn add1(x: u32) -> u32 {
    one: u32 = 1;
    r: u32 = x + one;
    return r;
}

fn mul2(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x * two;
    return r;
}

fn main() -> i32 {
    a: u32 = add1(10);   // 11
    b: u32 = mul2(a);    // 22
    return b;
}
