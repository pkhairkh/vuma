// mf_different_types.vuma — helper takes u8, returns u32, main returns i32
// Expected exit code: 42
//
// Tests that a helper can take a u8 parameter, return a u32, and that
// main can return that u32 as an i32 (via implicit conversion). The
// u8 value 42 is widened to u32 and then to i32.

fn widen(x: u8) -> u32 {
    return x;
}

fn main() -> i32 {
    v: u32 = widen(42);
    return v;
}
