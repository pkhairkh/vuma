// s43_mf_double_then_add.vuma — dbl(50) + add_six(50) = 100 + 56 = 156
// Expected exit code: 156
//
// Two single-arg helpers called on the same literal then summed.
// dbl(x) = x * 2; add_six(x) = x + 6. main calls dbl(50) -> 100
// and add_six(50) -> 56; sum = 156. Distinct from s42_mf_double_
// then_sub (112) and s38_mf_double_then_add (97).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(50);         // 100
    b: u32 = add_six(50);     // 56
    r: u32 = a + b;           // 156
    return r;
}
