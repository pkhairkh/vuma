// s101_mf_double_then_sub.vuma — dbl_then_dec(20) = 2*20 - 1 = 39
// Expected exit code: 39
//
// Single-arg helper dbl_then_dec(x) = 2*x - 1. main calls
// dbl_then_dec(20) -> 39. Distinct from s98_mf_two_calls_sub (30),
// s97_mf_two_helpers_sub (88) and s94_mf_two_calls_sub (23).
fn dbl_then_dec(x: u32) -> u32 {
    two: u32 = 2;
    one: u32 = 1;
    d: u32 = x * two;
    r: u32 = d - one;
    return r;
}

fn main() -> i32 {
    v: u32 = dbl_then_dec(20);   // 39
    return v;
}
