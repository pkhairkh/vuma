// s48_mf_double_then_add.vuma — dbl(40)=80, then 80 + 45 = 125
// Expected exit code: 125
//
// One single-arg helper dbl(x) = x * 2 called on 40 -> 80, then
// main adds a literal 45 -> 125. Distinct from s46_mf_double_then_
// add (115) and s42_mf_double_then_sub.

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(40);      // 80
    k: u32 = 45;
    r: u32 = a + k;        // 125
    return r;
}
