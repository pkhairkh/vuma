// mf_multi_param.vuma — helper takes 3 params (2,3,5), returns sum
// Expected exit code: 10
//
// Tests passing three parameters to a single function and returning
// their sum: 2 + 3 + 5 = 10.

fn add3(a: u32, b: u32, c: u32) -> u32 {
    return a + b + c;
}

fn main() -> i32 {
    v: u32 = add3(2, 3, 5);
    return v;
}
