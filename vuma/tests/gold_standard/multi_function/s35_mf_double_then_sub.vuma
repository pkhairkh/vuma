// s35_mf_double_then_sub.vuma — dbl(50) - sub_three(50) = 100 - 47 = 53
// Expected exit code: 53
//
// Two single-arg helpers called on the same literal then
// subtracted. dbl(x) = x * 2; sub_three(x) = x - 3. main calls
// dbl(50) -> 100 and sub_three(50) -> 47; diff = 53. Distinct from
// s34_mf_double_then_add (dbl+add_five = 80) and s30_mf_double_then_
// add (different values).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(50);          // 100
    b: u32 = sub_three(50);    // 47
    r: u32 = a - b;            // 53
    return r;
}
