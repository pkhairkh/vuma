// s65_mf_three_chain.vuma — add_five(60)=65, mul_two(65)=130, sub_three(130)=127
// Expected exit code: 127
//
// Three single-arg helpers chained: add_five(x)=x+5, mul_two(x)=x*2,
// sub_three(x)=x-3. main calls add_five(60) -> 65, mul_two(65) -> 130,
// sub_three(130) -> 127. Distinct from s51_mf_three_chain (53), s58_mf_
// three_chain (50) and s62_mf_three_chain (80).

fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn mul_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_five(60);     // 65
    b: u32 = mul_two(a);       // 130
    r: u32 = sub_three(b);     // 127
    return r;
}
