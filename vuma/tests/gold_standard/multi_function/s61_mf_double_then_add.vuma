// s61_mf_double_then_add.vuma — double(35)=70, add_ten(70)=80
// Expected exit code: 80
// 
// Two single-arg helpers chained: double(x)=x*2, add_ten(x)=x+10.
// main calls double(35) -> 70, add_ten(70) -> 80. Distinct from
// s58_mf_two_helpers_sub (112), s58_mf_three_chain (50) and s58_mf_
// triple_then_add (120).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_ten(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(35);       // 70
    r: u32 = add_ten(a);       // 80
    return r;
}
