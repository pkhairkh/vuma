// s76_mf_double_then_add.vuma — double(55)=110, add_twelve(40)=52; 110+52=162
// Expected exit code: 162
//
// Two single-arg helpers. double(x) = x * 2; add_twelve(x) = x + 12.
// main calls double(55) -> 110 and add_twelve(40) -> 52; sum = 162.
// Distinct from s74_mf_double_then_add (226), s73_mf_double_then_
// add (114) and s72_mf_double_then_add (99).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_twelve(x: u32) -> u32 {
    n: u32 = 12;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(55);          // 110
    b: u32 = add_twelve(40);      // 52
    r: u32 = a + b;               // 162
    return r;
}
