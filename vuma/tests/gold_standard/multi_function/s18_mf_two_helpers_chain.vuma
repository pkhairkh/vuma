// s18_mf_two_helpers_chain.vuma — outer(inner(5)) = (5+12)*3 = 17*3 = 51
// Expected exit code: 51
//
// Two single-arg helpers chained: inner(x) = x + 12, outer(x) = x * 3.
// main calls inner(5) -> 17, then outer(17) -> 51. Each call uses an
// intermediate local. Distinct from s14_mf_two_helpers_chain
// (inner+10, outer*2 -> 30) and s9_mf_pass_two_then_mul (mul3(add1(7))).

fn inner(x: u32) -> u32 {
    n: u32 = 12;
    r: u32 = x + n;
    return r;
}
fn outer(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inner(5);    // 17
    b: u32 = outer(a);    // 51
    return b;
}
