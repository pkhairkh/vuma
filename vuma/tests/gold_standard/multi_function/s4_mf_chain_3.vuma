// s4_mf_chain_3.vuma — chain of 3 functions: f3(f2(f1(5))) = 5+1+2+3 = 11
// Expected exit code: 11
//
// f1(x) = x + 1, f2(x) = x + 2, f3(x) = x + 3. main calls
// f1(5) → 6 into a local, then f2 of that local → 8, then f3 → 11.
// Each call uses an intermediate variable.

fn f1(x: u32) -> u32 {
    one: u32 = 1;
    r: u32 = x + one;
    return r;
}
fn f2(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x + two;
    return r;
}
fn f3(x: u32) -> u32 {
    three: u32 = 3;
    r: u32 = x + three;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(5);
    b: u32 = f2(a);
    c: u32 = f3(b);
    return c;
}
