// s71_mf_double_then_add.vuma — add_forty(double(48)) = add_forty(96) = 136
// Expected exit code: 136
//
// Two single-arg helpers chained. double(x) = x * 2; add_forty(x)
// = x + 40. main calls add_forty(double(48)) -> 96 + 40 = 136.
// Distinct from s69_mf_double_then_add (170), s70_mf_double_then_
// add (95) and s66_mf_double_then_sub (140).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_forty(x: u32) -> u32 {
    n: u32 = 40;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(48);        // 96
    r: u32 = add_forty(a);      // 136
    return r;
}
