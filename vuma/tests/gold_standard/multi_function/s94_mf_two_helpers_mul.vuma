// s94_mf_two_helpers_mul.vuma — f1(7) * f2(5) = 12 * 8 = 96
// Expected exit code: 96
//
// Two single-arg helpers. f1(x) = x + 5; f2(y) = y + 3. main calls
// both and multiplies: f1(7) * f2(5) = 12 * 8 = 96. Distinct from
// s90_mf_two_helpers_sub (2), s86_mf_two_helpers_add (150) and
// s82_mf_two_helpers_add (105).
fn f1(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 3;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(7);          // 12
    b: u32 = f2(5);          // 8
    p: u32 = a * b;          // 96
    return p;
}
