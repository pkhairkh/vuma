// s98_mf_three_chain.vuma — f3(f2(f1(45))) = 45 + 7 + 7 + 7 = 66
// Expected exit code: 66
//
// Three single-arg helpers, each adds 7. main calls them in
// sequence, threading the result: a = f1(45) = 52; b = f2(a) = 59;
// c = f3(b) = 66. Distinct from s94_mf_three_chain (70),
// s90_mf_three_chain (34) and s86_mf_three_chain (130).
fn f1(x: u32) -> u32 {
    k: u32 = 7;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 7;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 7;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(45);         // 52
    b: u32 = f2(a);          // 59
    c: u32 = f3(b);          // 66
    return c;
}
