// s29_mf_two_helpers_diff.vuma — sub5(50) - sub3(20) = 45 - 17 = 28
// Expected exit code: 28
//
// Two single-arg helpers, each called once from main, results subtracted. sub5(x) = x - 5; sub3(x) = x - 3. main calls sub5(50) -> 45 and sub3(20) -> 17; diff = 28. Distinct from s26_mf_two_helpers_sum (add3(20)+mul2(15)=53) and s22_mf_two_helpers_diff (dbl(15)-half(40)=10).

fn sub5(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}
fn sub3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = sub5(50);    // 45
    b: u32 = sub3(20);    // 17
    r: u32 = a - b;       // 28
    return r;
}
