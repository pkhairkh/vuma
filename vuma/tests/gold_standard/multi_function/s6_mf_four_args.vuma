// s6_mf_four_args.vuma — sum4(5, 10, 15, 20) = 50
// Expected exit code: 50
//
// Helper takes four u32 params, sums them, returns the result.
// main calls sum4(5, 10, 15, 20) -> 50. Distinct from
// s5_fn_three_args_sum (three args).

fn sum4(a: u32, b: u32, c: u32, d: u32) -> u32 {
    t1: u32 = a + b;
    t2: u32 = t1 + c;
    r: u32 = t2 + d;
    return r;
}

fn main() -> i32 {
    v: u32 = sum4(5, 10, 15, 20);
    return v;
}
