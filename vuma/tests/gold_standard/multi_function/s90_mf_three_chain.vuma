// s90_mf_three_chain.vuma — f3(f2(f1(4))) = 4 + 10 + 10 + 10 = 34
// Expected exit code: 34
//
// Three single-arg helpers, each adds 10. main calls them in
// sequence, threading the result: a = f1(4) = 14; b = f2(a) = 24;
// c = f3(b) = 34. Distinct from s86_mf_three_chain (130),
// s82_mf_three_chain (155) and s78_mf_three_chain (5).
fn f1(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 10;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(4);          // 14
    b: u32 = f2(a);          // 24
    c: u32 = f3(b);          // 34
    return c;
}
