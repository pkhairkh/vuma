// s82_mf_three_chain.vuma — f3(f2(f1(0))) = f3(f2(5)) = f3(55) = 155
// Expected exit code: 155
//
// Three single-arg helpers chained. f1(x) = x + 5; f2(x) = x +
// 50; f3(x) = x + 100. main calls f3(f2(f1(0))) -> 0 + 5 + 50
// + 100 = 155. Distinct from s78_mf_three_chain (5), s74_mf_
// three_chain (111) and s72_mf_three_chain (160).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 50;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 100;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(0);          // 5
    b: u32 = f2(a);          // 55
    c: u32 = f3(b);          // 155
    return c;
}
