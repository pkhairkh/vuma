// s92_mf_three_chain.vuma — f3(f2(f1(5))) = 5 + 19 + 19 + 19 = 62
// Expected exit code: 62
//
// Three single-arg helpers, each adds 19. main calls them in
// sequence, threading the result: a = f1(5) = 24; b = f2(a) = 43;
// c = f3(b) = 62. Distinct from s90_mf_three_chain (34),
// s86_mf_three_chain (130) and s82_mf_three_chain (155).
fn f1(x: u32) -> u32 {
    k: u32 = 19;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 19;
    r: u32 = x + k;
    return r;
}
fn f3(x: u32) -> u32 {
    k: u32 = 19;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(5);          // 24
    b: u32 = f2(a);          // 43
    c: u32 = f3(b);          // 62
    return c;
}
