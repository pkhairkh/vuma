// s21_mf_helper_double.vuma — double(22) = 44, return
// Expected exit code: 44
//
// Helper double(x) = x * 2. main calls double(22) -> 44 and returns it.
// Single helper, single call. Distinct from s18_mf_helper_double
// (double(15) = 30) and s14_mf_helper_double (double(20) = 40).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = double(22);
    return v;
}
