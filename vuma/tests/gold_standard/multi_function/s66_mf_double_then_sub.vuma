// s66_mf_double_then_sub.vuma — sub_thirty(double(85)) = sub_thirty(170) = 140
// Expected exit code: 140
//
// Two single-arg helpers chained. double(x) = x * 2; sub_thirty(x)
// = x - 30. main calls sub_thirty(double(85)) -> 170 - 30 = 140.
// Distinct from s62_mf_double_then_add (115), s58_mf_double_then_
// add (120) and s55_mf_double_then_add (158).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_thirty(x: u32) -> u32 {
    n: u32 = 30;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(85);        // 170
    r: u32 = sub_thirty(a);     // 140
    return r;
}
