// mf_func_returns_func.vuma — helper calls another helper, returns its result
// Expected exit code: 42
//
// Tests that a function can return the result of a call to another
// function. outer() calls inner() which returns 42; outer returns
// inner's result; main returns outer's result.

fn inner() -> u32 {
    return 42;
}

fn outer() -> u32 {
    v: u32 = inner();
    return v;
}

fn main() -> i32 {
    v: u32 = outer();
    return v;
}
