// s83_mf_three_chain.vuma — f3(f2(f1(0))) = f3(f2(8)) = f3(38) = 213
// Expected exit code: 213
//
// Three single-arg helpers chained. f1(x) = x + 8; f2(x) = x +
// 30; f3(x) = x + 175. main calls f3(f2(f1(0))) -> 0 + 8 + 30
// + 175 = 213. Distinct from s78_mf_three_chain (5), s74_mf_
// three_chain (111) and s72_mf_three_chain (160).
fn f1(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 30;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 175;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(0);          // 8
    b: u32 = f2(a);          // 38
    c: u32 = f3(b);          // 213
    return c;
}
