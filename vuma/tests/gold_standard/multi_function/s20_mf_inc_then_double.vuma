// s20_mf_inc_then_double.vuma — dbl(inc(20)) = dbl(21) = 42
// Expected exit code: 42
//
// Two single-arg helpers composed: inc(x) = x + 1, dbl(x) = x * 2.
// main calls inc(20) -> 21, then dbl(21) -> 42. Distinct from
// s18_mf_helper_double (single helper) and s17_mf_inc_then_double
// (different input).

fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(20);     // 21
    b: u32 = dbl(a);      // 42
    return b;
}
