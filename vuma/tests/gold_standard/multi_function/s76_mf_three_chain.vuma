// s76_mf_three_chain.vuma — f3(f2(f1(40))) = f3(f2(45)) = f3(55) = 101
// Expected exit code: 101
//
// Three single-arg helpers chained. f1(x) = x + 5; f2(x) = x + 10;
// f3(x) = x + 46. main calls f3(f2(f1(40))) -> 40 + 5 + 10 + 46
// = 101. Distinct from s74_mf_three_chain (111), s73_mf_three_
// chain (89) and s72_mf_three_chain (141).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 46;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(40);           // 45
    b: u32 = f2(a);            // 55
    c: u32 = f3(b);            // 101
    return c;
}
