// s47_mf_double_then_sub.vuma — dbl(45) - sub_ten(45) = 90 - 35 = 55
// Expected exit code: 55
//
// Two single-arg helpers called on the same literal then subtracted.
// dbl(x) = x * 2; sub_ten(x) = x - 10. main calls dbl(45) -> 90
// and sub_ten(45) -> 35; diff = 55. Distinct from s46_mf_double_
// then_add (115) and s42_mf_double_then_sub (112).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_ten(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(45);          // 90
    b: u32 = sub_ten(45);      // 35
    r: u32 = a - b;            // 55
    return r;
}
