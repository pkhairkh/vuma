// s60_mf_double_then_add.vuma — dbl(50) + 35 = 100 + 35 = 135
// Expected exit code: 135
//
// Single helper dbl(x) = x * 2 called on 50 -> 100, then add literal
// 35 -> 135. Distinct from s58_mf_triple_then_add (120) and s57_mf_
// double_then_sub (90).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(50);          // 100
    b: u32 = 35;
    r: u32 = a + b;            // 135
    return r;
}
