// s27_mf_two_helpers_sum.vuma — f(5) + g(5) = 15 + 25 = 40
// Expected exit code: 40
//
// Two single-arg helpers summed in main. f(x) = x + 10; g(x) = x + 20.
// main calls f(5) + g(5) -> 15 + 25 = 40. Distinct from
// s26_mf_two_helpers_sum (different helpers) and s22_mf_two_helpers_diff
// (sub).

fn f(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn g(x: u32) -> u32 {
    n: u32 = 20;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f(5);        // 15
    b: u32 = g(5);        // 25
    s: u32 = a + b;       // 40
    return s;
}
