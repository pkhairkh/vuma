// s75_mf_double_then_add.vuma — double(60)=120, add_twentythree(40)=63; 120+63=183
// Expected exit code: 183
//
// Two single-arg helpers. double(x) = x * 2; add_twentythree(x) = x + 23.
// main calls double(60) -> 120 and add_twentythree(40) -> 63;
// sum = 183. Distinct from s74_mf_double_then_add (226),
// s70_mf_double_then_add (95) and s66_mf_double_then_sub (140).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_twentythree(x: u32) -> u32 {
    n: u32 = 23;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(60);          // 120
    b: u32 = add_twentythree(40); // 63
    r: u32 = a + b;               // 183
    return r;
}
