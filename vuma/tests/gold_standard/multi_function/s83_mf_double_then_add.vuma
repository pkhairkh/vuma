// s83_mf_double_then_add.vuma — double(100) + 8 = 200 + 8 = 208
// Expected exit code: 208
//
// Helper double(x) = x + x. main doubles 100 then adds 8:
// double(100) + 8 = 200 + 8 = 208. Distinct from s78_mf_double_
// then_add (3), s74_mf_double_then_add (155) and s72_mf_double_
// then_add (85).
fn double(x: u32) -> u32 {
    r: u32 = x + x;
    return r;
}

fn main() -> i32 {
    d: u32 = double(100);    // 200
    k: u32 = 8;
    s: u32 = d + k;          // 208
    return s;
}
