// s3_mf_sum_three_funcs.vuma — 3 funcs each add 5, sum results
// Expected exit code: 15  (5 + 5 + 5)
//
// Three functions each return 5. main calls all three, sums results.

fn g1() -> u32 {
    return 5;
}
fn g2() -> u32 {
    return 5;
}
fn g3() -> u32 {
    return 5;
}

fn main() -> i32 {
    a: u32 = g1();
    b: u32 = g2();
    c: u32 = g3();
    s1: u32 = a + b;
    s2: u32 = s1 + c;
    return s2;
}
