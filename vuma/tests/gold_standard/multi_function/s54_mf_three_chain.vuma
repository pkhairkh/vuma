// s54_mf_three_chain.vuma — h(5)=15, g(15)=30, f(30)=35
// Expected exit code: 35
//
// Three single-arg helpers chained sequentially. h(x) = x + 10;
// g(x) = x * 2; f(x) = x + 5. main calls h(5) -> 15, g(15) -> 30,
// f(30) -> 35. Distinct from s50_mf_three_chain (50) and
// s49_mf_three_chain (60).

fn h(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn g(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn f(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = h(5);             // 15
    b: u32 = g(a);             // 30
    r: u32 = f(b);             // 35
    return r;
}
