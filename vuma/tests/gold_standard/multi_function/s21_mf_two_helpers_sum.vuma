// s21_mf_two_helpers_sum.vuma — inc(6) + dbl(11) = 7 + 22 = 29
// Expected exit code: 29
//
// Two distinct single-arg helpers, each called once from main, results
// summed. inc(x) = x + 1; dbl(x) = x * 2. main calls inc(6) -> 7,
// dbl(11) -> 22; sum = 29. Distinct from s18_mf_two_helpers_chain
// (chained, not summed, 51) and s14_mf_two_helpers_chain (chained, 30).

fn inc(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(6);      // 7
    b: u32 = dbl(11);     // 22
    s: u32 = a + b;       // 29
    return s;
}
