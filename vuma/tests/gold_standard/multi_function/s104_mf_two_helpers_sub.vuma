// s104_mf_two_helpers_sub.vuma — f(200) - g(96) = 201 - 97 = 104
// Expected exit code: 104
//
// Two helpers f(x)=x+1, g(x)=x+1. main calls f(200) - g(96) = 201 - 97 = 104. Two-helper subtraction.
// Distinct from s102_mf_three_chain (13), s102_mf_two_calls_add (6), s102_mf_two_helpers_sub (1).
fn f(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn g(x: u32) -> u32 {
    k: u32 = 1;
    return x + k;
}

fn main() -> i32 {
    a: u32 = f(200);          // 201
    b: u32 = g(96);          // 97
    r: u32 = a - b;          // 104
    return r;
}
