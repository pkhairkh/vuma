// mf_address_return.vuma — helper allocates, stores 42, returns Address
// Expected exit code: 42
//
// Tests a function that allocates a buffer, stores 42 at offset 0,
// and returns the Address. main then loads the field back. Verifies
// that Address return values cross the call/return boundary intact.

fn make_buf() -> Address {
    buf = allocate(16);
    *(buf + 0) = 42;
    return buf;
}

fn main() -> i32 {
    p = make_buf();
    v: u64 = *(p + 0);
    free(p);
    return v;
}
