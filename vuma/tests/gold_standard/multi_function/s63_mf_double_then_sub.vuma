// s63_mf_double_then_sub.vuma — double(45)=90, sub_ten(45)=35; 90-35=55
// Expected exit code: 55
//
// Two single-arg helpers called on the same literal then differenced:
// double(x) = x * 2; sub_ten(x) = x - 10. main calls double(45) ->
// 90 and sub_ten(45) -> 35; 90 - 35 = 55. Distinct from s51_mf_double_
// then_add (120), s58_mf_triple_then_add (120) and s55_mf_double_then_
// add (120).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_ten(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(45);        // 90
    b: u32 = sub_ten(45);       // 35
    r: u32 = a - b;             // 55
    return r;
}
