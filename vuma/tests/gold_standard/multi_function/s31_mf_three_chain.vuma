// s31_mf_three_chain.vuma — triple(double(5)) = triple(10) = 30
// Expected exit code: 30
//
// Two single-arg helpers chained via a nested call. double(x) = x * 2;
// triple(x) = x * 3. main calls triple(double(5)) -> triple(10) -> 30.
// Distinct from s30_mf_three_chain (inc(double(5)) = 11) and
// s28_mf_three_chain (three-chain, 16).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn triple(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(5);   // 10
    r: u32 = triple(a);   // 30
    return r;
}
