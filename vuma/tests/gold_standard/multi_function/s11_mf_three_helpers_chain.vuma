// s11_mf_three_helpers_chain.vuma — dec(dbl(inc(5))) = dec(dbl(6)) = dec(12) = 11
// Expected exit code: 11
//
// Three helpers chained: inc(x) = x + 1; dbl(x) = x * 2; dec(x) = x - 1.
// main calls inc(5) -> 6, then dbl(6) -> 12, then dec(12) -> 11.
// Distinct from s10_mf_three_chain_diff (three different helpers) and
// s8_mf_call_chain_3 (3-deep chain, different ops).

fn inc(x: u32) -> u32 {
    c: u32 = 1;
    r: u32 = x + c;
    return r;
}

fn dbl(x: u32) -> u32 {
    c: u32 = 2;
    r: u32 = x * c;
    return r;
}

fn dec(x: u32) -> u32 {
    c: u32 = 1;
    r: u32 = x - c;
    return r;
}

fn main() -> i32 {
    a: u32 = inc(5);     // 6
    b: u32 = dbl(a);     // 12
    c: u32 = dec(b);     // 11
    return c;
}
