// s75_mf_two_helpers_add.vuma — add_twentytwo(70)=92, add_thirtyseven(60)=97; 92+97=189
// Expected exit code: 189
//
// Two single-arg helpers called on different literals then summed.
// add_twentytwo(x) = x + 22; add_thirtyseven(x) = x + 37. main
// calls add_twentytwo(70) -> 92 and add_thirtyseven(60) -> 97;
// sum = 189. Distinct from s74_mf_two_helpers_add (184),
// s70_mf_two_helpers_add (210) and s66_mf_two_helpers_sub (185).
fn add_twentytwo(x: u32) -> u32 {
    n: u32 = 22;
    r: u32 = x + n;
    return r;
}
fn add_thirtyseven(x: u32) -> u32 {
    n: u32 = 37;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_twentytwo(70);       // 92
    b: u32 = add_thirtyseven(60);     // 97
    r: u32 = a + b;                   // 189
    return r;
}
