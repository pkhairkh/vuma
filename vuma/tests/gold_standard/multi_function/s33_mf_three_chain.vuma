// s33_mf_three_chain.vuma — f3(f2(f1(30))) = f3(f2(35)) = f3(70) = 67
// Expected exit code: 67
//
// Deterministic test in the multi_function category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_mf_three_chain (different ops) and s26_mf_three_chain_inc (inc chain).
fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(30);      // 35
    b: u32 = f2(a);       // 70
    c: u32 = f3(b);       // 67
    return c;
}
