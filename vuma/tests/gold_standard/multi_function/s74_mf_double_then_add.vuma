// s74_mf_double_then_add.vuma — add_sixteen(double(80)) + add_sixteen(50) = 160 + 66 = 226
// Expected exit code: 226
//
// Two single-arg helpers. double(x) = x * 2; add_sixteen(x) = x + 16.
// main calls double(80) -> 160 and add_sixteen(50) -> 66; sum = 226.
// Distinct from s70_mf_double_then_add (95), s66_mf_double_then_sub
// (140) and s62_mf_double_then_add (115).
fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn add_sixteen(x: u32) -> u32 {
    n: u32 = 16;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(80);          // 160
    b: u32 = add_sixteen(50);     // 66
    r: u32 = a + b;               // 226
    return r;
}
