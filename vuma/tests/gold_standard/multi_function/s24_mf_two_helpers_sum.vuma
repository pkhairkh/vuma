// s24_mf_two_helpers_sum.vuma — dbl(18) + half(80) = 36 + 40 = 76
// Expected exit code: 76
//
// Two single-arg helpers, each called once from main, results added.
// dbl(x) = x * 2; half(x) = x / 2. main calls dbl(18) -> 36 and
// half(80) -> 40; sum = 76. Distinct from s22_mf_two_helpers_diff
// (dbl(15) - half(40) = 30 - 20 = 10) and s14_mf_two_helpers_sub
// (two-helper sub, different values).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn half(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x / n;
    return r;
}

fn main() -> i32 {
    a: u32 = dbl(18);     // 36
    b: u32 = half(80);    // 40
    r: u32 = a + b;       // 76
    return r;
}
