// s44_mf_three_chain.vuma — f1(20)=25, f2(25)=75, f3(75)=70
// Expected exit code: 70
//
// Three single-arg helpers chained: f1(x)=x+5, f2(x)=x*3, f3(x)=x-5.
// main calls f3(f2(f1(20))) -> f1(20)=25, f2(25)=75, f3(75)=70.
// Distinct from s42_mf_three_chain (55) and s38_mf_three_chain (65).

fn f1(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(20);    // 25
    b: u32 = f2(a);     // 75
    c: u32 = f3(b);     // 70
    return c;
}
