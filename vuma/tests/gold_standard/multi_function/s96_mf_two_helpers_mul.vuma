// s96_mf_two_helpers_mul.vuma — f1(6) * f2(7) = 14 * 9 = 126
// Expected exit code: 126
//
// Two helpers: f1(x) = x + 8; f2(x) = x + 2. main calls both and
// multiplies: f1(6) = 14; f2(7) = 9; 14 * 9 = 126. Distinct from
// s94_mf_two_helpers_mul (96), s90_mf_two_helpers_sub (2) and
// s86_mf_double_then_add (65).
fn f1(x: u32) -> u32 {
    k: u32 = 8;
    r: u32 = x + k;
    return r;
}
fn f2(x: u32) -> u32 {
    k: u32 = 2;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(6);          // 14
    b: u32 = f2(7);          // 9
    p: u32 = a * b;          // 126
    return p;
}
