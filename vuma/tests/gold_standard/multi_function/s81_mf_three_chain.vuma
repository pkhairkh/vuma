// s81_mf_three_chain.vuma — f3(f2(f1(60))) = f3(f2(67)) = f3(77) = 98
// Expected exit code: 98
//
// Three single-arg helpers chained. f1(x) = x + 7; f2(x) = x +
// 10; f3(x) = x + 21. main calls f3(f2(f1(60))) -> 60 + 7 + 10
// + 21 = 98. Distinct from s78_mf_three_chain (5),
// s77_mf_three_chain (119) and s76_mf_three_chain (101).
fn f1(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 10;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 21;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(60);          // 67
    b: u32 = f2(a);            // 77
    c: u32 = f3(b);            // 98
    return c;
}
