// s35_mf_two_helpers_mul.vuma — add_three(50) + mul_two(40) = 53 + 80 = 133
// Expected exit code: 133
//
// Two single-arg helpers, each called once from main, results
// added. add_three(x) = x + 3; mul_two(x) = x * 2. main calls
// add_three(50) -> 53 and mul_two(40) -> 80; sum = 133. Distinct
// from s34_mf_two_helpers_sum (add4+mul3 = 105) and s30_mf_two_
// helpers_sum (add+mul).

fn add_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x + n;
    return r;
}
fn mul_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = add_three(50);   // 53
    b: u32 = mul_two(40);     // 80
    r: u32 = a + b;           // 133
    return r;
}
