// s82_mf_two_helpers_add.vuma — f1(40) + f2(10) = 65 + 40 = 105
// Expected exit code: 105
//
// Two single-arg helpers. f1(x) = x + 25; f2(y) = y + 30. main
// calls both and adds: f1(40) + f2(10) = 65 + 40 = 105.
// Distinct from s78_mf_two_helpers_add (4), s74_mf_two_helpers_
// add (130) and s72_mf_two_helpers_add (155).
fn f1(x: u32) -> u32 {
    k: u32 = 25;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 30;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(40);         // 65
    b: u32 = f2(10);         // 40
    s: u32 = a + b;          // 105
    return s;
}
