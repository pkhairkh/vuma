// s47_mf_two_helpers_sub.vuma — sub_five(50) + sub_three(20) = 45 + 17 = 62
// Expected exit code: 62
//
// Two single-arg helpers, each called once from main, results added.
// sub_five(x) = x - 5; sub_three(x) = x - 3. main calls sub_five(50)
// -> 45 and sub_three(20) -> 17; sum = 62. Distinct from s46_mf_
// two_helpers_add (70) and s42_mf_two_helpers_sub (82).

fn sub_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x - n;
    return r;
}
fn sub_three(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = sub_five(50);    // 45
    b: u32 = sub_three(20);   // 17
    r: u32 = a + b;           // 62
    return r;
}
