// mf_chain_5.vuma — chain of 5 calls, each adds 1
// Expected exit code: 5
//
// Tests a 5-function chain where each function adds 1 to its argument
// and calls the next function. Starting from 0, the final result is 5.
// Uses intermediate variables because VUMA miscompiles nested call
// expressions used directly as arguments.

fn step5(x: u32) -> u32 {
    return x + 1;
}
fn step4(x: u32) -> u32 {
    r: u32 = x + 1;
    s: u32 = step5(r);
    return s;
}
fn step3(x: u32) -> u32 {
    r: u32 = x + 1;
    s: u32 = step4(r);
    return s;
}
fn step2(x: u32) -> u32 {
    r: u32 = x + 1;
    s: u32 = step3(r);
    return s;
}
fn step1(x: u32) -> u32 {
    r: u32 = x + 1;
    s: u32 = step2(r);
    return s;
}

fn main() -> i32 {
    v: u32 = step1(0);
    return v;
}
