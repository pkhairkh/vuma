// s12_mf_square_pair_sum.vuma — square(3) + square(4) = 9 + 16 = 25
// Expected exit code: 25
//
// Helper square(x) = x * x, called twice with different arguments
// (3 and 4). Results summed: 9 + 16 = 25. Tests that one helper
// can be called twice with distinct arguments and the results
// combined via addition. Distinct from s13_fn_square_diff
// (subtracts instead of sums) and s10_fn_square_then_add
// (square-then-add-constant).

fn square(x: u32) -> u32 {
    r: u32 = x * x;
    return r;
}

fn main() -> i32 {
    a: u32 = square(3);   // 9
    b: u32 = square(4);   // 16
    s: u32 = a + b;       // 25
    return s;
}
