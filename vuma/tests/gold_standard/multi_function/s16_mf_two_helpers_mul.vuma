// s16_mf_two_helpers_mul.vuma — outer(inner(5)) = (5 + 7) * 3 = 36
// Expected exit code: 36
//
// Two single-arg helpers chained: inner(x) = x + 7, outer(x) = x * 3.
// main calls inner(5) -> 12, then outer(12) -> 36. Each call uses an
// intermediate local. Distinct from s14_mf_two_helpers_chain (add10 then
// mul2 = 30) and s7_mf_double_then_inc (double then inc).

fn inner(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn outer(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    a: u32 = inner(5);    // 12
    b: u32 = outer(a);    // 36
    return b;
}
