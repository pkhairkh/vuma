// s64_mf_double_then_sub.vuma — double(50)=100, sub_fifteen(50)=35; 100-35=65
// Expected exit code: 65
//
// Two single-arg helpers called on the same literal then differenced:
// double(x) = x * 2; sub_fifteen(x) = x - 15. main calls double(50)
// -> 100 and sub_fifteen(50) -> 35; diff = 65. Distinct from s62_mf_
// double_then_add (115), s62_mf_three_chain (80) and s62_mf_two_
// helpers_add (150).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}
fn sub_fifteen(x: u32) -> u32 {
    n: u32 = 15;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    a: u32 = double(50);        // 100
    b: u32 = sub_fifteen(50);   // 35
    r: u32 = a - b;             // 65
    return r;
}
