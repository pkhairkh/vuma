// s28_mf_three_chain.vuma — f3(f2(f1(10))) = f3(f2(11)) = f3(13) = 16
// Expected exit code: 16
//
// Three single-arg helpers composed in a chain. f1(x) = x + 1;
// f2(x) = x + 2; f3(x) = x + 3. main calls f3(f2(f1(10))) -> 16.
// Distinct from s26_mf_three_chain (add-dbl-sub, 19) and
// s22_mf_three_chain (different chain).

fn f1(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 3;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(10);      // 11
    b: u32 = f2(a);       // 13
    r: u32 = f3(b);       // 16
    return r;
}
