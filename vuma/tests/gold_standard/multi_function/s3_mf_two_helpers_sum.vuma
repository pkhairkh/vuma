// s3_mf_two_helpers_sum.vuma — two helpers each add a value, main sums
// Expected exit code: 25  (10 + 15)
//
// Helper A returns 10, helper B returns 15. main calls both and returns
// the sum. Straight-line, no branches, no shared state.

fn helper_a() -> u32 {
    return 10;
}

fn helper_b() -> u32 {
    return 15;
}

fn main() -> i32 {
    a: u32 = helper_a();
    b: u32 = helper_b();
    s: u32 = a + b;
    return s;
}
