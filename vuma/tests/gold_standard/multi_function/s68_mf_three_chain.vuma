// s68_mf_three_chain.vuma — f3(f2(f1(50))) = f3(f2(57)) = f3(70) = 93
// Expected exit code: 93
//
// Three single-arg helpers chained. f1(x) = x + 7; f2(x) = x + 13;
// f3(x) = x + 23. main calls f3(f2(f1(50))) -> 50 + 7 + 13 + 23
// = 93. Distinct from s66_mf_three_chain (85), s62_mf_three_chain
// (80) and s58_mf_three_chain (50).
fn f1(x: u32) -> u32 {
    n: u32 = 7;
    r: u32 = x + n;
    return r;
}
fn f2(x: u32) -> u32 {
    n: u32 = 13;
    r: u32 = x + n;
    return r;
}
fn f3(x: u32) -> u32 {
    n: u32 = 23;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(50);            // 57
    b: u32 = f2(a);             // 70
    c: u32 = f3(b);             // 93
    return c;
}
