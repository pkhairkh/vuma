// s98_mf_two_helpers_mul.vuma — f1(2) * f2(5) = 7 * 9 = 63
// Expected exit code: 63
//
// Two single-arg helpers. f1(x) = x + 5; f2(y) = y + 4. main calls
// both and multiplies: f1(2) * f2(5) = 7 * 9 = 63. Distinct from
// s94_mf_two_helpers_mul (96), s90_mf_two_helpers_sub (2) and
// s86_mf_two_helpers_add (150).
fn f1(x: u32) -> u32 {
    k: u32 = 5;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 4;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(2);          // 7
    b: u32 = f2(5);          // 9
    p: u32 = a * b;          // 63
    return p;
}
