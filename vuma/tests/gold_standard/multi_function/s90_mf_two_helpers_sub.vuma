// s90_mf_two_helpers_sub.vuma — f1(50) - f2(48) = 51 - 49 = 2
// Expected exit code: 2
//
// Two single-arg helpers. f1(x) = x + 1; f2(y) = y + 1. main calls
// both and subtracts: f1(50) - f2(48) = 51 - 49 = 2. Distinct from
// s86_mf_two_helpers_add (150), s82_mf_two_helpers_add (105) and
// s78_mf_two_helpers_add (4).
fn f1(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}
fn f2(y: u32) -> u32 {
    k: u32 = 1;
    r: u32 = y + k;
    return r;
}

fn main() -> i32 {
    a: u32 = f1(50);         // 51
    b: u32 = f2(48);         // 49
    d: u32 = a - b;          // 2
    return d;
}
