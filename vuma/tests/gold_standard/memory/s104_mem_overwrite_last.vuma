// s104_mem_overwrite_last.vuma — overwrite c3 to 62, load = 62
// Expected exit code: 62
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c3 to 62. Load c3 -> 62 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_mem_overwrite_last (1), s102_mem_three_cell_diff (197), s102_mem_two_cell_sum (4).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c3 = 62;
    v: u64 = *c3;          // 62
    free(c1);
    free(c2);
    free(c3);
    return v;
}
