// s70_mem_two_cell_sum.vuma — two cells, sum = 105 (60 + 45)
// Expected exit code: 105
//
// Two 8-byte cells. Store 60/45 via `*ptr = literal`, load
// both, sum -> 105. Uses `*ptr = literal` form. Distinct from
// s66_mem_two_cell_sum (225), s65_mem_two_cell_sum (225) and
// s62_mem_two_cell_diff (130).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 60;
    *c2 = 45;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 105
    free(c1);
    free(c2);
    return s;
}
