// s16_mem_two_cell_diff.vuma — two cells, diff = 40 (80 - 40)
// Expected exit code: 40
//
// Two 8-byte cells. Store 40/80 via `*ptr = literal`, load both, compute
// the difference (larger - smaller) -> 40. Uses `*ptr = literal` form
// (no offsets). Distinct from s14_mem_two_cell_sum (sum, not diff) and
// s6_mem_two_buf_diff (different operands).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 40;
    *p2 = 80;
    a: u64 = *p1;
    b: u64 = *p2;
    d: u64 = b - a;       // 80 - 40 = 40
    free(p1);
    free(p2);
    return d;
}
