// s71_mem_two_cell_diff.vuma — two cells, diff = 160 (250 - 90)
// Expected exit code: 160
//
// Two 8-byte cells. Store 250/90 via `*ptr = literal`, load both,
// diff -> 160. Uses `*ptr = literal` form. Distinct from s69_mem_
// two_cell_sum (215), s70_mem_two_cell_sum (105) and s66_mem_two_
// cell_sum (225).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 250;
    *c2 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 160
    free(c1);
    free(c2);
    return d;
}
