// s13_mem_overwrite_then_double.vuma — store 7, overwrite 14, double = 28
// Expected exit code: 28
//
// 8-byte cell. Store literal 7 via `*p = 7`, overwrite with 14, load
// it back into a local, multiply by 2 -> 28. Tests that an overwritten
// load can drive a multiply. Uses `*p = literal` form (no offsets).
// Distinct from s9_mem_load_then_double (no overwrite) and
// s10_mem_overwrite_middle (3-cell overwrite, no multiply).

fn main() -> i32 {
    buf = allocate(8);
    *buf = 7;
    *buf = 14;
    v: u64 = *buf;
    two: u64 = 2;
    r: u64 = v * two;
    free(buf);
    return r;
}
