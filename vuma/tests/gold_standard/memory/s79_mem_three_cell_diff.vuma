// s79_mem_three_cell_diff.vuma — three cells, diff = 47 (50 - 2 - 1)
// Expected exit code: 47
//
// Three 8-byte cells. Store 50/2/1 via `*ptr = literal`,
// load all three, a - b - c -> 47. Uses `*ptr = literal` form.
// Distinct from s78_mem_three_cell_diff (148),
// s77_mem_three_cell_diff (172) and s76_mem_three_cell_diff
// (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 2;
    *c3 = 1;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 47
    free(c1);
    free(c2);
    free(c3);
    return r;
}
