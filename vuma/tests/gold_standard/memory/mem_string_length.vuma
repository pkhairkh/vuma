// mem_string_length.vuma — compute string length in memory
// Expected exit code: 5
//
// Treats a buffer as a null-terminated string. Scans until 0 byte and
// returns the length. String = "Hello\0" → length 5.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 72;   // 'H'
    *(buf + 1) = 101;  // 'e'
    *(buf + 2) = 108;  // 'l'
    *(buf + 3) = 108;  // 'l'
    *(buf + 4) = 111;  // 'o'
    *(buf + 5) = 0;    // null terminator
    len: u32 = 0;
    i: u32 = 0;
    while i < 8 {
        v: u32 = *(buf + i);
        if v == 0 {
            // Found terminator
            i = 8;
        } else {
            len = len + 1;
            i = i + 1;
        }
    }
    free(buf);
    return len;
}
