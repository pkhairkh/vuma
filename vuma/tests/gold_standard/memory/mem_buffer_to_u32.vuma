// mem_buffer_to_u32.vuma — read 4 bytes as u32
// Expected exit code: 18
//
// Stores 4 bytes [0x12, 0x34, 0x56, 0x78] in a buffer, reads them as a
// big-endian u32 (0x12345678), and returns the top byte (0x12 = 18).

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 0x12;
    *(buf + 1) = 0x34;
    *(buf + 2) = 0x56;
    *(buf + 3) = 0x78;
    b0: u32 = *(buf + 0);
    b1: u32 = *(buf + 1);
    b2: u32 = *(buf + 2);
    b3: u32 = *(buf + 3);
    // Big-endian assembly
    val: u32 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
    free(buf);
    return val >> 24;
}
