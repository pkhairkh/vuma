// s65_mem_three_cell_xor.vuma — three cells, xor = 102 (195 ^ 90 ^ 255)
// Expected exit code: 102
//
// Three 8-byte cells. Store 195/90/255 via `*ptr = literal`, load all
// three, XOR -> 102 (0x66). Uses `*ptr = literal` form (no offsets).
// Distinct from s51_mem_three_cell_xor (192), s58_mem_three_cell_or
// (112) and s62_mem_three_cell_xor (72).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 195;             // 0xC3
    *p2 = 90;              // 0x5A
    *p3 = 255;             // 0xFF
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;        // 0x99 = 153
    s: u64 = t ^ c;        // 0x66 = 102
    free(p1);
    free(p2);
    free(p3);
    return s;
}
