// s11_mem_load_chain_sum.vuma — three cells, sum = 30 (5 + 10 + 15)
// Expected exit code: 30
//
// Three independent 8-byte cells. Each receives a distinct literal via
// `*ptr = literal` (deterministic). All three loaded back and summed
// -> 5 + 10 + 15 = 30. Distinct from s10_mem_quad_buf_sum (4 buffers)
// and s5_mem_load_chain (3 cells, different vals).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *a = 5;
    *b = 10;
    *c = 15;
    va: u64 = *a;
    vb: u64 = *b;
    vc: u64 = *c;
    t1: u64 = va + vb;
    s: u64 = t1 + vc;
    free(a);
    free(b);
    free(c);
    return s;
}
