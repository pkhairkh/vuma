// mem2_reuse_after_free — allocate, free, allocate a new buffer, store/load
// Expected exit code: 42
//
// Validates the basic allocation-reuse lifecycle: a buffer is allocated
// and freed, then a fresh buffer is allocated (which the allocator may
// place at the same address).  Stores 42 in the new buffer and loads it
// back, confirming the freed memory is properly re-initialized.  No
// use-after-free; the first buffer is never accessed after free.
// Straight-line code only.

fn main() -> i32 {
    b1 = allocate(16);
    free(b1);
    b2 = allocate(16);
    *(b2 + 0) = 42;
    val: u32 = *(b2 + 0);
    free(b2);
    return val;
}
