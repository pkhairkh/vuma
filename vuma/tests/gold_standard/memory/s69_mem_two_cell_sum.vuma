// s69_mem_two_cell_sum.vuma -- two cells, sum = 215 (125 + 90)
// Expected exit code: 215
//
// Two 8-byte cells. Store 125/90 via `*ptr = literal`, load both,
// sum -> 215. Uses `*ptr = literal` form. Distinct from s66_mem_two_
// cell_sum (225), s65_mem_two_cell_sum (225) and s64_mem_two_cell_
// sum (209).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 125;
    *c2 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 215
    free(c1);
    free(c2);
    return s;
}
