// s74_mem_overwrite_first.vuma — overwrite c1 to 59, load = 59
// Expected exit code: 59
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c1 to 59. Load c1 -> 59 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s70_mem_overwrite_first (235),
// s66_mem_overwrite_first (220) and s62_mem_overwrite_first (180).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c1 = 59;
    v: i32 = *c1;          // 59
    free(c1);
    free(c2);
    free(c3);
    return v;
}
