// s17_mem_two_buf_product.vuma — two buffers, 8 * 9 = 72
// Expected exit code: 72
//
// Two 8-byte cells. Store 8/9 via `*p = literal`, load both, multiply
// -> 72. Uses `*p = literal` form. Distinct from s14_mem_two_cell_sum
// (sum, not product) and s11_mem_two_buf_xor (XOR).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 8;
    *p2 = 9;
    a: u64 = *p1;
    b: u64 = *p2;
    r: u64 = a * b;       // 72
    free(p1);
    free(p2);
    return r;
}
