// mem2_overwrite_literal — store 42, overwrite with 99, load
// Expected exit code: 99
//
// Verifies that a second store to the same offset supersedes the first
// (i.e., the most-recent store wins).  Straight-line code only.

fn main() -> i32 {
    buf = allocate(8);
    *(buf + 0) = 42;
    *(buf + 0) = 99;     // overwrite
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
