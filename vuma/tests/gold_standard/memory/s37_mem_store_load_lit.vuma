// s37_mem_store_load_lit.vuma — store 165, load = 165
// Expected exit code: 165
//
// Deterministic test in the memory category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_mem_store_load_lit (value 195) and s30_mem_store_load_lit (value 175).
fn main() -> i32 {
    p = allocate(8);
    *p = 165;
    r: i32 = *p;
    free(p);
    return r;
}
