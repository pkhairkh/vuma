// s59_mem_two_cell_sum.vuma — two cells, sum = 195 (160 + 35)
// Expected exit code: 195
//
// Two 8-byte cells. Store 160/35 via `*ptr = literal`, load both,
// sum -> 195. Uses `*ptr = literal` form (no offsets). Distinct from
// s58_mem_two_cell_sum (230), s58_mem_three_cell_or (112) and s58_mem_
// overwrite_last (180).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 160;
    *p2 = 35;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 195
    free(p1);
    free(p2);
    return s;
}
