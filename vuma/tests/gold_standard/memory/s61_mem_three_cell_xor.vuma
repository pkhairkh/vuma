// s61_mem_three_cell_xor.vuma — three cells, xor = 0xAA ^ 0x55 ^ 0x0F = 0xF0 = 240
// Expected exit code: 240
// 
// Three 8-byte cells. Store 170/85/15 via `*ptr = literal`, load
// all three, 170 ^ 85 ^ 15 = 240 (0xF0). Uses `*ptr = literal`
// form (no offsets). Distinct from s58_mem_two_cell_sum (230),
// s58_mem_three_cell_or (112) and s58_mem_overwrite_last (180).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 170;
    *p2 = 85;
    *p3 = 15;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;
    r: u64 = t ^ c;        // 240
    free(p1);
    free(p2);
    free(p3);
    return r;
}
