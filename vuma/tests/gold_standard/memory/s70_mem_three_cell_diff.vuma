// s70_mem_three_cell_diff.vuma — three cells, diff = 150 (200 - 30 - 20)
// Expected exit code: 150
//
// Three 8-byte cells. Store 200/30/20 via `*ptr = literal`,
// load all three, diff -> 200 - 30 - 20 = 150. Uses `*ptr =
// literal` form. Distinct from s66_mem_three_cell_xor (204),
// s65_mem_three_cell_xor (102) and s62_mem_three_cell_xor (72).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 30;
    *c3 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a - b;        // 170
    d: u64 = t - c;        // 150
    free(c1);
    free(c2);
    free(c3);
    return d;
}
