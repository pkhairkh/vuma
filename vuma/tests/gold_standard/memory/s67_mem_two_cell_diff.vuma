// s67_mem_two_cell_diff.vuma — two cells, diff = 90 (220 - 130)
// Expected exit code: 90
//
// Two 8-byte cells. Store 220/130 via `*ptr = literal`, load
// both, diff -> 90. Uses `*ptr = literal` form. Distinct from
// s66_mem_two_cell_sum (225), s62_mem_two_cell_diff (130) and
// s58_mem_two_cell_sum (230).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 220;
    *c2 = 130;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 90
    free(c1);
    free(c2);
    return d;
}
