// s27_mem_overwrite_first.vuma — overwrite first of two, sum = 180 (100 + 80)
// Expected exit code: 180
//
// Two 8-byte cells. Store 50/80, then overwrite the first cell with 100.
// Load both, sum -> 180. Uses `*ptr = literal` form (no offsets).
// Distinct from s26_mem_overwrite_middle (three cells, overwrite middle)
// and s22_mem_overwrite_first (different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 50;
    *p2 = 80;
    *p1 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;       // 180
    free(p1);
    free(p2);
    return s;
}
