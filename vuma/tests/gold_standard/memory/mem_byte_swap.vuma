// mem_byte_swap.vuma — byte-swap u32 in memory
// Expected exit code: 18
//
// Stores a u32 (0x12345678) as 4 little-endian bytes, then reads them
// back in reverse order to byte-swap. The swapped value is 0x78563412.
// Exit code is the low byte (0x12 = 18).

fn main() -> i32 {
    buf = allocate(8);
    // Store 0x12345678 little-endian: bytes are 0x78, 0x56, 0x34, 0x12
    *(buf + 0) = 0x78;
    *(buf + 1) = 0x56;
    *(buf + 2) = 0x34;
    *(buf + 3) = 0x12;
    // Byte-swap: read in reverse to construct 0x78563412
    b0: u32 = *(buf + 3);  // 0x12
    b1: u32 = *(buf + 2);  // 0x34
    b2: u32 = *(buf + 1);  // 0x56
    b3: u32 = *(buf + 0);  // 0x78
    // Assemble little-endian: 0x78563412
    swapped: u32 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    free(buf);
    return swapped;
}
