// s46_mem_two_cell_xor.vuma — two cells, xor = 255 (0xF0 ^ 0x0F)
// Expected exit code: 255
//
// Two 8-byte cells. Store 240/15 (0xF0/0x0F) via `*ptr = literal`,
// load both, xor -> 255 (0xFF). Uses `*ptr = literal` form (no
// offsets). Distinct from s42_mem_two_cell_sum (200) and s38_mem_
// two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 240;             // 0xF0
    *p2 = 15;              // 0x0F
    a: u64 = *p1;
    b: u64 = *p2;
    r: u64 = a ^ b;        // 0xFF = 255
    free(p1);
    free(p2);
    return r;
}
