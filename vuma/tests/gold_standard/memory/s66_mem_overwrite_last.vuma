// s66_mem_overwrite_last.vuma — overwrite c2 to 200, load = 200
// Expected exit code: 200
//
// Two 8-byte cells. Store 90 at c1, store 40 at c2 then overwrite
// c2 to 200. Load c2 -> 200 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s62_mem_overwrite_middle (170),
// s58_mem_overwrite_last (180) and s55_mem_overwrite_last (220).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 90;
    *c2 = 40;
    *c2 = 200;
    v: u64 = *c2;          // 200
    free(c1);
    free(c2);
    return v;
}
