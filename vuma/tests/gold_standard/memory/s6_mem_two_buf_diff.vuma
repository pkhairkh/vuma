// s6_mem_two_buf_diff.vuma — two buffers, sum loads = 70 (30 + 40)
// Expected exit code: 70
//
// Two independent 8-byte buffers. Each gets a different literal at
// offset 0. Both loaded and summed. Distinct from s5_mem_triple_buf_sum
// (three buffers) and s4_mem_two_buf_sum (different values).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    *(a + 0) = 30;
    *(b + 0) = 40;
    va: u64 = *(a + 0);
    vb: u64 = *(b + 0);
    s: u64 = va + vb;
    free(a);
    free(b);
    return s;
}
