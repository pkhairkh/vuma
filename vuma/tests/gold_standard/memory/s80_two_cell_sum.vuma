// s80_mem_two_cell_sum.vuma — two cells, sum = 32 (16 + 16)
// Expected exit code: 32
//
// Two 8-byte cells. Store 16/16 via `*ptr = literal`, load
// both, sum -> 32. Uses `*ptr = literal` form. Distinct from
// s78_mem_two_cell_sum (2), s74_mem_two_cell_sum (95) and
// s73_mem_two_cell_sum (116).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 16;
    *c2 = 16;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 32
    free(c1);
    free(c2);
    return s;
}
