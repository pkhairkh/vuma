// s65_mem_two_cell_sum.vuma — two cells, sum = 225 (130 + 95)
// Expected exit code: 225
//
// Two 8-byte cells. Store 130/95 via `*ptr = literal`, load both,
// sum -> 225. Uses `*ptr = literal` form (no offsets). Distinct from
// s51_mem_two_cell_diff (90), s58_mem_two_cell_sum (230) and s62_mem_
// two_cell_diff (130).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 130;
    *p2 = 95;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 225
    free(p1);
    free(p2);
    return s;
}
