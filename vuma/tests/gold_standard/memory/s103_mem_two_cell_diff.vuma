// s103_mem_two_cell_diff.vuma — store 100, 1 in 2 cells, load and diff = 100-1 = 99
// Expected exit code: 99
//
// Two 8-byte cells. Store 100 at c1, store 1 at c2, load each and return the difference (99). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s100_mem_two_cell_diff (14).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 1;
    a: u64 = *c1;          // 100
    b: u64 = *c2;          // 1
    d: u64 = a - b;        // 99
    free(c1);
    free(c2);
    return d;
}
