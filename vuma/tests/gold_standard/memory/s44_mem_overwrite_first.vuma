// s44_mem_overwrite_first.vuma — overwrite first to 100, sum = 240 (100 + 55 + 85)
// Expected exit code: 240
//
// Three 8-byte cells. Store 25/55/85 via `*ptr = literal`, then
// overwrite the first cell with 100. Load all three, sum -> 240. Uses
// `*ptr = literal` form (no offsets). Distinct from s42_mem_overwrite_
// middle (210) and s38_mem_overwrite_first (215).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 25;
    *p2 = 55;
    *p3 = 85;
    *p1 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 240
    free(p1);
    free(p2);
    free(p3);
    return s;
}
