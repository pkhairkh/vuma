// s15_mem_two_cell_product.vuma — two cells, product = 42 (7 * 6)
// Expected exit code: 42
//
// Two 8-byte cells. Store 7/6 via `*ptr = literal`, load both, multiply ->
// 42. Uses `*ptr = literal` form (no offsets). Distinct from
// s14_mem_two_cell_sum (sum framing, 35+55 = 90) and
// s13_mem_two_buf_product (two-buf product framing).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 7;
    *p2 = 6;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a * b;
    free(p1);
    free(p2);
    return s;
}
