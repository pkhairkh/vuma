// s73_mem_overwrite_first.vuma — overwrite c1 to 137, load = 137
// Expected exit code: 137
//
// Two 8-byte cells. Store 50 at c1, store 40 at c2, then
// overwrite c1 to 137. Load c1 -> 137 (the overwritten value).
// Uses `*ptr = literal` form. Distinct from s70_mem_overwrite_
// first (235), s69_mem_overwrite_first (110) and s66_mem_
// overwrite_last (200).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 50;
    *c2 = 40;
    *c1 = 137;
    v: u64 = *c1;          // 137
    free(c1);
    free(c2);
    return v;
}
