// s42_mem_three_cell_xor.vuma — three cells, xor = 195 (0xA5 ^ 0x3C ^ 0x5A)
// Expected exit code: 195
//
// Three 8-byte cells. Store 165/60/90 via `*ptr = literal`, load all,
// xor -> 195 (0xC3). Uses `*ptr = literal` form (no offsets). Distinct
// from s38_mem_two_cell_sum (220) and s34_mem_two_cell_sum (195, same
// total but two cells + sum vs three cells + xor).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 165;             // 0xA5
    *p2 = 60;              // 0x3C
    *p3 = 90;              // 0x5A
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;
    r: u64 = t ^ c;        // 0xC3 = 195
    free(p1);
    free(p2);
    free(p3);
    return r;
}
