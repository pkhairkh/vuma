// mem_arena_alloc.vuma — arena allocator (bump pointer)
// Expected exit code: 0
//
// Implements a simple bump allocator. A 16-byte arena with a bump offset.
// Allocates 3 chunks (4 bytes each), writes to them, verifies the offsets
// advance correctly and the values round-trip.

fn main() -> i32 {
    arena = allocate(16);
    offset: u64 = 0;
    // Alloc 4 bytes at offset 0
    *(arena + offset) = 11;
    *(arena + offset + 1) = 12;
    *(arena + offset + 2) = 13;
    *(arena + offset + 3) = 14;
    offset = offset + 4;
    // Alloc 4 bytes at offset 4
    *(arena + offset) = 21;
    *(arena + offset + 1) = 22;
    *(arena + offset + 2) = 23;
    *(arena + offset + 3) = 24;
    offset = offset + 4;
    // Alloc 4 bytes at offset 8
    *(arena + offset) = 31;
    *(arena + offset + 1) = 32;
    *(arena + offset + 2) = 33;
    *(arena + offset + 3) = 34;
    offset = offset + 4;
    // Verify
    v00: u32 = *(arena + 0);
    v10: u32 = *(arena + 4);
    v20: u32 = *(arena + 8);
    free(arena);
    if v00 == 11 {
        if v10 == 21 {
            if v20 == 31 { return 0; }
        }
    }
    return 1;
}
