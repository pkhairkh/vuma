// s92_mem_three_cell_diff.vuma — three cells, diff = 70 (250 - 120 - 60)
// Expected exit code: 70
//
// Three 8-byte cells. Store 250/120/60 via `*ptr = literal`, load
// all three, a - b - c -> 70. Uses `*ptr = literal` form (no
// offsets). Distinct from s90_mem_three_cell_diff (29),
// s86_mem_three_cell_diff (60) and s82_mem_three_cell_diff (110).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 120;
    *c3 = 60;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 70
    free(c1);
    free(c2);
    free(c3);
    return r;
}
