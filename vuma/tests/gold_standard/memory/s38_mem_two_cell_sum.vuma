// s38_mem_two_cell_sum.vuma — two cells, sum = 220 (125 + 95)
// Expected exit code: 220
//
// Two 8-byte cells. Store 125/95 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form (no offsets). Distinct
// from s34_mem_two_cell_sum (195) and s30_mem_two_cell_and.

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 125;
    *p2 = 95;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
