// s85_mem_two_cell_sum.vuma — two cells, sum = 195 (120 + 75)
// Expected exit code: 195
//
// Two 8-byte cells. Store 120/75 via `*ptr = literal`, load
// both, sum -> 195. Uses `*ptr = literal` form (no offsets).
// Distinct from s82_mem_two_cell_sum, s78_mem_two_cell_sum
// and s74_mem_two_cell_sum.
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 120;
    *c2 = 75;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 195
    free(c1);
    free(c2);
    return s;
}
