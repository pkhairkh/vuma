// s66_mem_three_cell_xor.vuma — three cells, xor = 204 (51 ^ 85 ^ 170)
// Expected exit code: 204
//
// Three 8-byte cells. Store 51/85/170 via `*ptr = literal`,
// load all three, xor -> 51 ^ 85 = 102; 102 ^ 170 = 204 (0xCC).
// Uses `*ptr = literal` form. Distinct from s62_mem_three_cell_
// xor (72), s58_mem_three_cell_or (112) and s55_mem_three_cell_
// xor (85).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 51;              // 0x33
    *c2 = 85;              // 0x55
    *c3 = 170;             // 0xAA
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    t: u64 = a ^ b;        // 0x66 = 102
    r: u64 = t ^ c;        // 0xCC = 204
    free(c1);
    free(c2);
    free(c3);
    return r;
}
