// Hello Memory - the simplest VUMA program
// Expected exit code: 42
// Demonstrates: allocate, write, read, free with VUMA verification
//
// This is the "Hello World" of VUMA. It shows the four fundamental
// memory operations that VUMA's IVE (Invariant Verification Engine)
// can verify automatically:
//
//   1. allocate  - Reserve a memory region
//   2. write (*) - Store a value into a region
//   3. read  (*) - Load a value from a region
//   4. free      - Release a memory region
//
// VUMA Key Concepts:
//   - `region` is of type Address, an opaque handle to a memory region
//   - `*region` dereferences the address for read or write
//   - IVE proves all 5 invariants (LIVE) for every pointer operation
//   - No `unsafe` keyword exists in VUMA — verification is always on

fn main() -> i32 {
    // Allocate a region for one integer
    // IVE verifies: the region is live after allocation (Liveness)
    region = allocate(8);
    
    // Write a value
    // IVE verifies: region is exclusively owned (Exclusivity)
    // IVE verifies: write is to a valid allocated region (Interpretation)
    *region = 42;
    
    // Read it back
    // IVE verifies: region is still live (Liveness)
    // IVE verifies: the data at this address originated from a write (Origin)
    value: i32 = *region;
    
    // Free the region
    // IVE verifies: all allocations are cleaned up (Cleanup)
    free(region);
    
    return value;
}
// IVE verification: Liveness ✓, Exclusivity ✓, Interpretation ✓, Origin ✓, Cleanup ✓
