// s14_mem_overwrite_load.vuma — store 5 then 95, load = 95
// Expected exit code: 95
//
// Single 8-byte cell. Store literal 5, then overwrite with literal
// 95 (last write wins). Load and return 95. Uses `*p = literal`
// form. Distinct from s9_mem_overwrite_then_load (10 then 90) and
// s10_mem_overwrite_middle (uses broken *(p+N) form).

fn main() -> i32 {
    p = allocate(8);
    *p = 5;
    *p = 95;
    v: u64 = *p;
    free(p);
    return v;
}
