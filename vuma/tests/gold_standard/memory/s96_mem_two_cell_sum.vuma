// s96_mem_two_cell_sum.vuma — two cells, sum = 165 (85 + 80)
// Expected exit code: 165
//
// Two 8-byte cells. Store 85/80 via `*ptr = literal`, load both,
// a + b -> 165. Uses `*ptr = literal` form. Distinct from
// s94_mem_two_cell_sum (160), s90_mem_two_cell_diff (7) and
// s86_mem_two_cell_sum (205).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 85;
    *c2 = 80;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 165
    free(c1);
    free(c2);
    return s;
}
