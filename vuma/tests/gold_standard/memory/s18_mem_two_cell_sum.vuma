// s18_mem_two_cell_sum.vuma — two cells, sum = 80 (31 + 49)
// Expected exit code: 80
//
// Two 8-byte cells. Store 31/49 via `*ptr = literal`, load both,
// sum -> 80. Uses `*ptr = literal` form (no offsets). Distinct from
// s14_mem_two_cell_sum (35/55 = 90) and s9_mem_two_buf_sum (uses
// broken *(buf+N) form).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 31;
    *p2 = 49;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;
    free(p1);
    free(p2);
    return s;
}
