// s100_mem_overwrite_first.vuma — overwrite c1 to 71, load = 71
// Expected exit code: 71
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2,
// store 50 at c3, then overwrite c1 to 71. Load c1 -> 71
// (the overwritten value). Uses `*ptr = literal` form.
// Distinct from s97_mem_overwrite_last (46), s94_mem_overwrite_first (67), s90_mem_overwrite_middle (31).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 71;
    v: u64 = *c1;          // 71
    free(c1);
    free(c2);
    free(c3);
    return v;
}
