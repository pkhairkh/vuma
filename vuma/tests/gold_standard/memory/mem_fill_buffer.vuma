// mem_fill_buffer.vuma — fill buffer with pattern
// Expected exit code: 0
//
// Fills a 16-byte buffer with the pattern byte 0xAB, then verifies that
// all bytes match. Returns 0 on success, 1 on mismatch.

fn main() -> i32 {
    buf = allocate(16);
    i: u32 = 0;
    while i < 16 {
        *(buf + i) = 0xAB;
        i = i + 1;
    }
    // Verify
    ok: u32 = 1;
    j: u32 = 0;
    while j < 16 {
        v: u32 = *(buf + j);
        if v != 0xAB { ok = 0; }
        j = j + 1;
    }
    free(buf);
    if ok == 1 { return 0; }
    return 1;
}
