// s43_mem_overwrite_first.vuma — overwrite first cell 100 -> 200, sum with 30 = 230
// Expected exit code: 230
//
// Two 8-byte cells. Store 100 in p1 via `*ptr = literal`, then
// overwrite p1 to 200 via `*ptr = literal`. Store 30 in p2. Load
// both, sum -> 230. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_mem_overwrite_middle (170) and s38_mem_overwrite_first
// (130).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 100;
    *p1 = 200;
    *p2 = 30;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 230
    free(p1);
    free(p2);
    return s;
}
