// s12_mem_overwrite_first.vuma — overwrite first cell, sum = 120
// Expected exit code: 120  (70 + 20 + 30)
//
// Three independent 8-byte buffers. Store 10/20/30 via `*ptr =
// literal` form, then overwrite the first buffer (a) with 70. Load
// all three, sum -> 70 + 20 + 30 = 120. Deterministic on the
// current backend. Distinct from s10_mem_overwrite_middle
// (overwrites middle, values 10/20/30/99 = 139) and
// s7_mem_overwrite_first_then_sum.

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *a = 10;
    *b = 20;
    *c = 30;
    *a = 70;
    va: u64 = *a;
    vb: u64 = *b;
    vc: u64 = *c;
    s: u64 = va + vb + vc;
    free(a);
    free(b);
    free(c);
    return s;
}
