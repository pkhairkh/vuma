// s88_mem_overwrite_first.vuma — overwrite c1 to 225, load = 225
// Expected exit code: 225
//
// Three 8-byte cells. Store 50 at c1, store 100 at c2, then
// overwrite c1 to 225, store 200 at c3. Load c1 -> 225 (the
// overwritten value). Uses `*ptr = literal` form. Distinct
// from s86_mem_overwrite_middle (235), s82_mem_overwrite_
// last (245) and s78_mem_overwrite_first (3).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c1 = 225;
    *c3 = 200;
    v: u64 = *c1;          // 225
    free(c1);
    free(c2);
    free(c3);
    return v;
}
