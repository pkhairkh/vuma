// s105_mem_two_cell_sum.vuma — store 31 + 45 in 2 cells, load and sum = 76
// Expected exit code: 76
// 
// Two 8-byte cells. Store 31 at c1, store 45 at c2, load each and return the sum (76). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s102_mem_two_cell_sum (4), s101_mem_two_cell_sum (155), s100_mem_two_cell_diff (14).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 31;
    *c2 = 45;
    a: u64 = *c1;          // 31
    b: u64 = *c2;          // 45
    s: u64 = a + b;        // 76
    free(c1);
    free(c2);
    return s;
}
