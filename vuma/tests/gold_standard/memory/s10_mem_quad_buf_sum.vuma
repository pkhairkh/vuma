// s10_mem_quad_buf_sum.vuma — 4 buffers, sum loads = 100 (10+20+30+40)
// Expected exit code: 100
//
// Four independent 8-byte buffers each receive a distinct literal via
// the `*ptr = literal` form (deterministic on the current backend).
// All four loaded back and summed. Distinct from s5_mem_triple_buf_sum
// (3 buffers, uses `*(p+0)` form which is non-deterministic) and
// s6_mem_two_buf_diff (2 bufs).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    d = allocate(8);
    *a = 10;
    *b = 20;
    *c = 30;
    *d = 40;
    va: u64 = *a;
    vb: u64 = *b;
    vc: u64 = *c;
    vd: u64 = *d;
    t1: u64 = va + vb;
    t2: u64 = t1 + vc;
    s: u64 = t2 + vd;
    free(a);
    free(b);
    free(c);
    free(d);
    return s;
}
