// s81_mem_overwrite_first.vuma — store 100, overwrite with 205, load = 205
// Expected exit code: 205
//
// Single 8-byte cell. Store 100 via `*ptr = literal`, overwrite
// with 205 via `*ptr = literal`, load and return 205. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s78_mem_overwrite_first (3), s77_mem_overwrite_middle (157) and
// s76_mem_overwrite_first (44).
fn main() -> i32 {
    c1 = allocate(8);
    *c1 = 100;
    *c1 = 205;
    r: u64 = *c1;          // 205
    free(c1);
    return r;
}
