// s30_mem_store_load_lit.vuma — store 175, load = 175
// Expected exit code: 175
//
// Single 8-byte cell. Store the literal 175 via `*ptr = literal`, load
// it back, return. Uses `*ptr = literal` form (no offsets). Distinct
// from s26_mem_store_load_lit (different value) and
// s22_mem_store_load_lit (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 175;
    r: i32 = *p;
    free(p);
    return r;
}
