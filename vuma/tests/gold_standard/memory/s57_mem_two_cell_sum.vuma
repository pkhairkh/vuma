// s57_mem_two_cell_sum.vuma — two cells, sum = 220 (95 + 125)
// Expected exit code: 220
//
// Two 8-byte cells. Store 95/125 via `*ptr = literal`, load both,
// sum -> 220. Uses `*ptr = literal` form (no offsets). Distinct from
// s54_mem_two_cell_sum (250) and s50_mem_two_cell_sum (245).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 95;
    *p2 = 125;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 220
    free(p1);
    free(p2);
    return s;
}
