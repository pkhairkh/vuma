// s41_mem_overwrite_first.vuma - overwrite cell to 205, load = 205
// Expected exit code: 205
//
// Single 8-byte cell. Store 50 via `*ptr = literal`, then overwrite
// to 205 via `*ptr = literal`. Load and return 205. Uses `*ptr =
// literal` form (no offsets). Distinct from s38_mem_overwrite_first
// (195) and s34_mem_overwrite_first (210).

fn main() -> i32 {
    p = allocate(8);
    *p = 50;
    *p = 205;
    v: u64 = *p;
    free(p);
    return v;
}
