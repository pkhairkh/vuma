// s7_mem_overwrite_first_then_sum.vuma — overwrite slot 0, sum = 99 + 22 = 121
// Expected exit code: 121
//
// 16-byte buffer treated as two 8-byte slots. Store 11/22 in slots
// 0/8, then overwrite slot 0 with 99. Load both, sum -> 99 + 22 = 121.
// Uses pointer-arithmetic aliases. Distinct from
// s5_mem_overwrite_at_diff_offsets (overwrites all three offsets) and
// s6_mem_overwrite_3x (overwrites single offset 3 times).

fn main() -> i32 {
    buf = allocate(16);
    p0 = buf;
    p8 = buf + 8;
    *p0 = 11;
    *p8 = 22;
    *p0 = 99;
    a: u64 = *p0;
    b: u64 = *p8;
    s: u64 = a + b;
    free(buf);
    return s;
}
