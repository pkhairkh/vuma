// s50_mem_overwrite_middle.vuma — overwrite middle to 110, sum = 250 (50 + 110 + 90)
// Expected exit code: 250
//
// Three 8-byte cells. Store 50/70/90 via `*ptr = literal`, then
// overwrite the middle cell with 110. Load all three, sum -> 250.
// Uses `*ptr = literal` form (no offsets). Distinct from
// s46_mem_overwrite_last (210) and s43_mem_overwrite_first (230).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 50;
    *p2 = 70;
    *p3 = 90;
    *p2 = 110;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 250
    free(p1);
    free(p2);
    free(p3);
    return s;
}
