// s20_mem_two_cell_sum.vuma — two cells, sum = 120 (55 + 65)
// Expected exit code: 120
//
// Two 8-byte cells. Store 55/65 via `*p = literal`, load both, sum ->
// 120. Uses `*ptr = literal` form (no offsets). Distinct from
// s18_mem_two_cell_sum (two cells, different values) and
// s14_mem_two_cell_sum (33+44=77).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 55;
    *c2 = 65;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;
    free(c1);
    free(c2);
    return s;
}
