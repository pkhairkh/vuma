// s60_mem_two_cell_sum.vuma — two cells, sum = 235 (135 + 100)
// Expected exit code: 235
//
// Two 8-byte cells. Store 135/100 via `*ptr = literal`, load both,
// sum -> 235. Uses `*ptr = literal` form (no offsets). Distinct
// from s58_mem_two_cell_sum (230) and s57_mem_two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 135;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 235
    free(p1);
    free(p2);
    return s;
}
