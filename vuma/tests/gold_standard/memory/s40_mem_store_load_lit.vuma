// s40_mem_store_load_lit.vuma — store 205, load = 205
// Expected exit code: 205
//
// Single 8-byte cell. Store 205 via `*ptr = literal`, load and
// return 205. Uses `*ptr = literal` form (no offsets). Distinct from
// s38_mem_store_load_lit (175) and s34_mem_store_load_lit (187).

fn main() -> i32 {
    p = allocate(8);
    *p = 205;
    v: u64 = *p;
    free(p);
    return v;
}
