// s53_mem_three_cell_sum.vuma — three cells, sum = 180 (60 + 70 + 50)
// Expected exit code: 180
//
// Three 8-byte cells. Store 60/70/50 via `*ptr = literal`, load all,
// sum -> 180. Uses `*ptr = literal` form (no offsets). Distinct from
// s49_mem_three_cell_xor (160) and s50_mem_three_cell_sum (195).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 60;
    *p2 = 70;
    *p3 = 50;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 180
    free(p1);
    free(p2);
    free(p3);
    return s;
}
