// s58_mem_overwrite_last.vuma — overwrite last to 100, sum = 180 (30 + 50 + 100)
// Expected exit code: 180
// 
// Three 8-byte cells. Store 30/50/70 via `*ptr = literal`, then
// overwrite the last cell with 100. Load all three, sum -> 180.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_mem_two_
// cell_diff (90), s51_mem_three_cell_xor (192) and s51_mem_overwrite_
// first (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 30;
    *p2 = 50;
    *p3 = 70;
    *p3 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 180
    free(p1);
    free(p2);
    free(p3);
    return s;
}
