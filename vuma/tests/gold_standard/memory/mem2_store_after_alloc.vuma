// mem2_store_after_alloc ‚Äî allocate, then store, then load
// Expected exit code: 42
//
// Validates that the canonical allocate‚Üístore‚Üíload sequence works on a
// freshly-allocated buffer (the cell is writable immediately after
// allocation returns).  Straight-line code only.

fn main() -> i32 {
    buf = allocate(16);
    *(buf + 0) = 42;
    val: u32 = *(buf + 0);
    free(buf);
    return val;
}
