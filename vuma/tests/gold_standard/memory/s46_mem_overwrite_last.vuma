// s46_mem_overwrite_last.vuma — overwrite last to 100, sum = 210 (50 + 60 + 100)
// Expected exit code: 210
//
// Three 8-byte cells. Store 50/60/70 via `*ptr = literal`, then
// overwrite the last cell with 100. Load all three, sum -> 210.
// Uses `*ptr = literal` form (no offsets). Distinct from s42_mem_
// overwrite_middle (210, same total but middle overwrite) and s38_
// mem_overwrite_first (215).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 50;
    *p2 = 60;
    *p3 = 70;
    *p3 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 210
    free(p1);
    free(p2);
    free(p3);
    return s;
}
