// s29_mem_store_load_lit.vuma — store 177, load = 177
// Expected exit code: 177
//
// Single 8-byte cell. Store the literal 177 via `*ptr = literal`, load it back, return. Uses `*ptr = literal` form (no offsets). Distinct from s26_mem_store_load_lit (value 200) and s22_mem_store_load_lit (different value).

fn main() -> i32 {
    p1 = allocate(8);
    *p1 = 177;
    a: u64 = *p1;
    free(p1);
    return a;
}
