// s96_mem_three_cell_diff.vuma — three cells, diff = 130 (248 - 100 - 18)
// Expected exit code: 130
//
// Three 8-byte cells. Store 248/100/18 via `*ptr = literal`, load
// all three, 248 - 100 - 18 -> 130. Uses `*ptr = literal` form.
// Distinct from s94_mem_three_cell_sum (109),
// s90_mem_three_cell_diff (29) and s86_mem_three_cell_diff (140).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 248;
    *c2 = 100;
    *c3 = 18;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    d: u64 = a - b - c;    // 130
    free(c1);
    free(c2);
    free(c3);
    return d;
}
