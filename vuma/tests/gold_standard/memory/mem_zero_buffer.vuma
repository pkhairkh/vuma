// mem_zero_buffer.vuma — zero-fill a buffer
// Expected exit code: 0
//
// Allocates a buffer, fills it with non-zero values, then zeros it out,
// and verifies all bytes are 0.

fn main() -> i32 {
    buf = allocate(16);
    // Fill with non-zero
    i: u32 = 0;
    while i < 16 {
        *(buf + i) = 0xFF;
        i = i + 1;
    }
    // Zero out
    j: u32 = 0;
    while j < 16 {
        *(buf + j) = 0;
        j = j + 1;
    }
    // Verify all zero
    ok: u32 = 1;
    k: u32 = 0;
    while k < 16 {
        v: u32 = *(buf + k);
        if v != 0 { ok = 0; }
        k = k + 1;
    }
    free(buf);
    if ok == 1 { return 0; }
    return 1;
}
