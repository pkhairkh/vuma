// s18_mem_overwrite_load.vuma — store 8 then 92, load = 92
// Expected exit code: 92
//
// Single 8-byte cell. Store literal 8, then overwrite with literal
// 92 (last write wins). Load and return 92. Uses `*p = literal`
// form. Distinct from s14_mem_overwrite_load (5 then 95) and
// s9_mem_overwrite_then_load (10 then 90).

fn main() -> i32 {
    p = allocate(8);
    *p = 8;
    *p = 92;
    v: u64 = *p;
    free(p);
    return v;
}
