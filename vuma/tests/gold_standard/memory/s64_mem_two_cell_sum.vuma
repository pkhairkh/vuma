// s64_mem_two_cell_sum.vuma — two cells, sum = 205 (134 + 71)
// Expected exit code: 205
//
// Two 8-byte cells. Store 134/71 via `*ptr = literal`, load both,
// sum -> 205. Uses `*ptr = literal` form (no offsets). Distinct from
// s62_mem_overwrite_middle (170), s62_mem_three_cell_xor (72) and
// s62_mem_two_cell_diff (130).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 134;
    *p2 = 71;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 205
    free(p1);
    free(p2);
    return s;
}
