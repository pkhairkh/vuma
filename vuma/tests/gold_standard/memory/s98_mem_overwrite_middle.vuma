// s98_mem_overwrite_middle.vuma — overwrite c2 to 59, load = 59
// Expected exit code: 59
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at
// c3, then overwrite c2 to 59. Load c2 -> 59 (the overwritten
// value). Uses `*ptr = literal` form. Distinct from
// s94_mem_overwrite_first (67), s90_mem_overwrite_middle (31) and
// s86_mem_overwrite_middle (235).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c2 = 59;
    v: u64 = *c2;          // 59
    free(c1);
    free(c2);
    free(c3);
    return v;
}
