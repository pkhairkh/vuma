// s17_mem_overwrite_middle.vuma — c1=10, c2: 20->200, c3=30, sum = 240
// Expected exit code: 240  (10 + 200 + 30)
//
// Three 8-byte cells. Store 10 in c1, 20 then overwrite 200 in c2,
// 30 in c3. Load all three, sum -> 240. Uses `*p = literal` form.
// Distinct from s14_mem_overwrite_load (single-cell overwrite) and
// s10_mem_overwrite_middle (uses broken *(p+N) form).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c2 = 200;
    *c3 = 30;
    a: u64 = *c1;         // 10
    b: u64 = *c2;         // 200
    c: u64 = *c3;         // 30
    s: u64 = a + b + c;   // 240
    free(c1);
    free(c2);
    free(c3);
    return s;
}
