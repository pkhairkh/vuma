// s28_mem_two_cell_sum.vuma — two cells, sum = 136 (51 + 85)
// Expected exit code: 136
//
// Two 8-byte cells. Store 0x33/0x55 via `*ptr = literal`, load both,
// sum -> 136. Uses `*ptr = literal` form (no offsets). All operands
// loaded into typed locals before the add. Distinct from
// s26_mem_two_cell_xor (xor, 102) and s22_mem_two_cell_sum (sum,
// different values).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 51;            // 0x33
    *p2 = 85;            // 0x55
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;       // 136
    free(p1);
    free(p2);
    return s;
}
