// s12_mem_load_then_add.vuma — store 30, load, add 25 = 55
// Expected exit code: 55
//
// Single 8-byte cell. Store 30 via `*ptr = literal`, load into a
// local, add 25 (constant loaded into a variable first), return 55.
// Tests that a loaded value can drive a follow-up arithmetic op.
// Deterministic on the current backend. Distinct from
// s9_mem_load_then_double (mul by 2) and s4_mem_load_then_store
// (load-then-store).

fn main() -> i32 {
    p = allocate(8);
    *p = 30;
    v: u64 = *p;
    c: u64 = 25;
    r: u64 = v + c;       // 55
    free(p);
    return r;
}
