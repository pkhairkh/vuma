// s29_mem_overwrite_first.vuma — overwrite first cell, sum = 140 (90 + 20 + 30)
// Expected exit code: 140
//
// Three 8-byte cells. Store 10/20/30, then overwrite the first cell with 90. Load all three, sum -> 140. Uses `*ptr = literal` form (no offsets). Distinct from s26_mem_overwrite_middle (overwrites the middle cell, 90) and s22_mem_overwrite_middle (different values).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 10;
    *c2 = 20;
    *c3 = 30;
    *c1 = 90;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    s: u64 = a + b + c;
    free(c1);
    free(c2);
    free(c3);
    return s;
}
