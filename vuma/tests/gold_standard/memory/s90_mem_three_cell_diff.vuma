// s90_mem_three_cell_diff.vuma — three cells, diff = 29 (250 - 200 - 21)
// Expected exit code: 29
//
// Three 8-byte cells. Store 250/200/21 via `*ptr = literal`, load
// all three, a - b - c -> 29. Uses `*ptr = literal` form (no
// offsets). Distinct from s86_mem_three_cell_diff (60),
// s82_mem_three_cell_diff (110) and s78_mem_three_cell_diff (148).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 250;
    *c2 = 200;
    *c3 = 21;
    a: u64 = *c1;
    b: u64 = *c2;
    c: u64 = *c3;
    r: u64 = a - b - c;    // 29
    free(c1);
    free(c2);
    free(c3);
    return r;
}
