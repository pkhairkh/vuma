// s91_mem_overwrite_middle.vuma — overwrite c2 to 28, load = 28
// Expected exit code: 28
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at
// c3, then overwrite c2 to 28. Load c2 -> 28 (the overwritten
// value). Uses `*ptr = literal` form. Distinct from s90_mem_
// overwrite_middle (31), s86_mem_overwrite_middle (60) and
// s82_mem_overwrite_middle (220).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c2 = 28;
    v: u64 = *c2;          // 28
    free(c1);
    free(c2);
    free(c3);
    return v;
}
