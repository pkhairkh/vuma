// s100_mem_two_cell_diff.vuma — two cells, diff = 14 (33 - 19)
// Expected exit code: 14
//
// Two 8-byte cells. Store 33/19 via `*ptr = literal`, load
// both, a - b -> 14. Uses `*ptr = literal` form (no
// offsets).
// Distinct from s97_mem_overwrite_last (46), s94_mem_overwrite_first (67), s90_mem_two_cell_diff (7).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 33;
    *c2 = 19;
    a: u64 = *c1;
    b: u64 = *c2;
    d: u64 = a - b;        // 14
    free(c1);
    free(c2);
    return d;
}
