// s35_mem_store_load_lit.vuma — store 173, load = 173
// Expected exit code: 173
//
// Single 8-byte cell. Store 173 via `*ptr = literal`, load and
// return 173. Uses `*ptr = literal` form (no offsets). Distinct
// from s34_mem_store_load_lit (187) and s30_mem_store_load_lit
// (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 173;
    v: u64 = *p;
    free(p);
    return v;
}
