// s34_mem_store_load_lit.vuma — store 187, load = 187
// Expected exit code: 187
//
// Single 8-byte cell. Store 187 via `*ptr = literal`, load and
// return 187. Uses `*ptr = literal` form (no offsets). Distinct
// from s30_mem_store_load_lit (different value) and s27_mem_store_
// load_lit (different value).

fn main() -> i32 {
    p = allocate(8);
    *p = 187;
    v: u64 = *p;
    free(p);
    return v;
}
