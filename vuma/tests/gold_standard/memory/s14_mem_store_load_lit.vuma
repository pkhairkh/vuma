// s14_mem_store_load_lit.vuma — store 64, load 64
// Expected exit code: 64
//
// Single 8-byte cell. Store literal 64 via `*p = 64`, load it back,
// return 64. Most basic store-load round trip via pointer.
// Distinct from s9_mem_load_then_double (load-then-double,
// value 50) and s10_mem_load_then_double (value 50).

fn main() -> i32 {
    p = allocate(8);
    *p = 64;
    v: u64 = *p;
    free(p);
    return v;
}
