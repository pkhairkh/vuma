// s27_mem_two_cell_sum.vuma — two cells, sum = 200 (90 + 110)
// Expected exit code: 200
//
// Two 8-byte cells. Store 90/110 via `*ptr = literal`, load both, sum
// -> 200. Uses `*ptr = literal` form (no offsets). Distinct from
// s26_mem_two_cell_xor (xor, 51^85=102) and s22_mem_two_cell_diff
// (sub).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 90;
    *p2 = 110;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;       // 200
    free(p1);
    free(p2);
    return s;
}
