// mem2_alloc_sizes — allocate buffers of sizes 8, 16, 32, 64; store in
// the 64-byte buffer and load it back
// Expected exit code: 42
//
// Confirms that allocation of multiple buffers of varying sizes (with
// the largest allocated last) does not corrupt the ability to store to
// and load from the largest buffer.  Straight-line code only.

fn main() -> i32 {
    b8  = allocate(8);
    b16 = allocate(16);
    b32 = allocate(32);
    b64 = allocate(64);
    *(b64 + 0) = 42;
    val: u32 = *(b64 + 0);
    free(b8);
    free(b16);
    free(b32);
    free(b64);
    return val;
}
