// s6_mem_overwrite_3x.vuma — same cell overwritten 3x, last wins = 25
// Expected exit code: 25
//
// One 8-byte cell. Store 10, then 20, then 25. Final load should
// observe 25 (last write wins). Distinct from s5_mem_overwrite_at_diff_offsets
// (overwrites at different offsets, not same).

fn main() -> i32 {
    p = allocate(8);
    *(p + 0) = 10;
    *(p + 0) = 20;
    *(p + 0) = 25;
    v: u64 = *(p + 0);
    free(p);
    return v;
}
