// s42_mem_overwrite_middle.vuma — overwrite middle to 110, sum = 210 (30 + 110 + 70)
// Expected exit code: 210
//
// Three 8-byte cells. Store 30/50/70 via `*ptr = literal`, then
// overwrite the middle cell with 110. Load all three, sum -> 210.
// Uses `*ptr = literal` form (no offsets). Distinct from s38_mem_
// overwrite_first (215) and s34_mem_overwrite_first (190).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 30;
    *p2 = 50;
    *p3 = 70;
    *p2 = 110;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 210
    free(p1);
    free(p2);
    free(p3);
    return s;
}
