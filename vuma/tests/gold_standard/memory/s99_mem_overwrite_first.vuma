// s99_mem_overwrite_first.vuma — overwrite c1 to 131, load = 131
// Expected exit code: 131
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at
// c3, then overwrite c1 to 131. Load c1 -> 131 (the overwritten
// value). Uses `*ptr = literal` form. Distinct from
// s95_mem_overwrite_middle (56), s91_mem_overwrite_middle (28) and
// s87_mem_overwrite_middle (215).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c1 = 131;
    v: u64 = *c1;          // 131
    free(c1);
    free(c2);
    free(c3);
    return v;
}
