// s81_mem_two_cell_sum.vuma — two cells, sum = 185 (100 + 85)
// Expected exit code: 185
//
// Two 8-byte cells. Store 100/85 via `*ptr = literal`, load
// both, sum -> 185. Uses `*ptr = literal` form. Distinct from
// s78_mem_two_cell_sum (2), s77_mem_two_cell_sum (159) and
// s76_mem_two_cell_sum (151).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 100;
    *c2 = 85;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 185
    free(c1);
    free(c2);
    return s;
}
