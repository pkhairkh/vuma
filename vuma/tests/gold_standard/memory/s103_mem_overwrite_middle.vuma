// s103_mem_overwrite_middle.vuma — overwrite c2 to 2, load = 2
// Expected exit code: 2
//
// Three 8-byte cells. Store 100 at c1, store 200 at c2, store 50 at c3, then overwrite c2 to 2. Load c2 -> 2 (the overwritten value). Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_mem_overwrite_middle (33).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 100;
    *c2 = 200;
    *c3 = 50;
    *c2 = 2;
    v: u64 = *c2;          // 2
    free(c1);
    free(c2);
    free(c3);
    return v;
}
