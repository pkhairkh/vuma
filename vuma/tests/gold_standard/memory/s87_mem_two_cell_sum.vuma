// s87_mem_two_cell_sum.vuma — two cells, sum = 195 (125 + 70)
// Expected exit code: 195
//
// Two 8-byte cells. Store 125/70 via `*ptr = literal`, load
// both, sum -> 195. Uses `*ptr = literal` form (no offsets).
// Distinct from s86_mem_two_cell_sum (205), s82_mem_two_cell_
// sum (145) and s78_mem_two_cell_sum (2).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 125;
    *c2 = 70;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 195
    free(c1);
    free(c2);
    return s;
}
