// s23_mem_store_load_lit.vuma — store 84, load 84
// Expected exit code: 84
//
// Single 8-byte cell. Store literal 84 via `*p = 84`, load it back,
// return 84. Most basic store-load round trip via pointer. Distinct
// from s22_mem_store_load_lit (value 95) and s24_mem_store_load_lit
// (value 81).

fn main() -> i32 {
    p = allocate(8);
    *p = 84;
    v: u64 = *p;
    free(p);
    return v;
}

