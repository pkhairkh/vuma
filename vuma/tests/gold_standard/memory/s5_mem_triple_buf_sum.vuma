// s5_mem_triple_buf_sum.vuma — three buffers, sum loads = 180
// Expected exit code: 180  (30 + 60 + 90)
//
// Three independent 8-byte buffers. Each gets a different literal
// value at offset 0. All three are loaded back and summed. Distinct
// from s4_mem_two_buf_sum (only two buffers).

fn main() -> i32 {
    a = allocate(8);
    b = allocate(8);
    c = allocate(8);
    *(a + 0) = 30;
    *(b + 0) = 60;
    *(c + 0) = 90;
    va: u64 = *(a + 0);
    vb: u64 = *(b + 0);
    vc: u64 = *(c + 0);
    s: u64 = va + vb + vc;
    free(a);
    free(b);
    free(c);
    return s;
}
