// s16_mem_overwrite_then_load.vuma — store 7 then 200, load = 200
// Expected exit code: 200
//
// Single 8-byte cell. Store literal 7, then overwrite with literal 200
// (last write wins). Load and return 200. Uses `*p = literal` form.
// Distinct from s14_mem_overwrite_load (5 then 95) and s9_mem_overwrite_then_load
// (10 then 90).

fn main() -> i32 {
    p = allocate(8);
    *p = 7;
    *p = 200;
    v: u64 = *p;
    free(p);
    return v;
}
