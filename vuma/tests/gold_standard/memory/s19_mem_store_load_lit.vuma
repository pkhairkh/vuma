// s19_mem_store_load_lit.vuma — store 123, load, return 123
// Expected exit code: 123
//
// Single 8-byte cell. Store 123 via `*ptr = literal`, load it back,
// return 123. Round-trip a single literal through memory. Uses
// `*ptr = literal` form (no offsets). Distinct from
// s18_mem_store_load_lit (value 64) and s14_mem_store_load_val
// (value 200).

fn main() -> i32 {
    p = allocate(8);
    *p = 123;
    a: u64 = *p;
    free(p);
    return a;
}
