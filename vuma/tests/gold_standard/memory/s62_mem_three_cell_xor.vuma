// s62_mem_three_cell_xor.vuma — three cells, xor = 72 (100 ^ 50 ^ 30)
// Expected exit code: 72
// 
// Three 8-byte cells. Store 100/50/30 via `*ptr = literal`, load
// all three, xor -> 72. 100 ^ 50 = 86 (0x56); 86 ^ 30 = 72 (0x48).
// Uses `*ptr = literal` form (no offsets). Distinct from s51_mem_
// three_cell_xor (192), s58_mem_three_cell_or (112) and s55_mem_
// three_cell_xor (192).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 100;
    *p2 = 50;
    *p3 = 30;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a ^ b;        // 0x56 = 86
    s: u64 = t ^ c;        // 0x48 = 72
    free(p1);
    free(p2);
    free(p3);
    return s;
}
