// mem_scatter.vuma — scatter values to non-contiguous locations
// Expected exit code: 0
//
// Scatters 4 values from a contiguous source buffer to non-contiguous
// locations in a destination buffer (offsets 0, 4, 8, 12). Verifies the
// scattered values are at the correct offsets.

fn main() -> i32 {
    src = allocate(4);
    dst = allocate(16);
    // Source: [10, 20, 30, 40]
    *(src + 0) = 10;
    *(src + 1) = 20;
    *(src + 2) = 30;
    *(src + 3) = 40;
    // Scatter to dst at offsets 0, 4, 8, 12
    s0: u32 = *(src + 0); *(dst + 0) = s0;
    s1: u32 = *(src + 1); *(dst + 4) = s1;
    s2: u32 = *(src + 2); *(dst + 8) = s2;
    s3: u32 = *(src + 3); *(dst + 12) = s3;
    // Verify
    d0: u32 = *(dst + 0);
    d4: u32 = *(dst + 4);
    d8: u32 = *(dst + 8);
    d12: u32 = *(dst + 12);
    free(src);
    free(dst);
    if d0 == 10 {
        if d4 == 20 {
            if d8 == 30 {
                if d12 == 40 { return 0; }
            }
        }
    }
    return 1;
}
