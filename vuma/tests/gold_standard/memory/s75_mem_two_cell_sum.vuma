// s75_mem_two_cell_sum.vuma — two cells, sum = 115 (95 + 20)
// Expected exit code: 115
//
// Two 8-byte cells. Store 95/20 via `*ptr = literal`, load
// both, sum -> 115. Uses `*ptr = literal` form. Distinct from
// s74_mem_two_cell_sum (199), s70_mem_two_cell_sum (105) and
// s66_mem_two_cell_sum (225).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 95;
    *c2 = 20;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 115
    free(c1);
    free(c2);
    return s;
}
