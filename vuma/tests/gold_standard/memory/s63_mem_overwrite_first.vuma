// s63_mem_overwrite_first.vuma — overwrite first to 110, sum = 210 (110 + 40 + 60)
// Expected exit code: 210
//
// Three 8-byte cells. Store 10/40/60 via `*ptr = literal`, then
// overwrite the first cell with 110. Load all three, sum -> 210.
// Uses `*ptr = literal` form (no offsets). Distinct from s51_mem_
// overwrite_first (220), s58_mem_overwrite_last (180) and s55_mem_
// overwrite_last (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 10;
    *p2 = 40;
    *p3 = 60;
    *p1 = 110;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 210
    free(p1);
    free(p2);
    free(p3);
    return s;
}
