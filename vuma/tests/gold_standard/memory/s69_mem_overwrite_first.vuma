// s69_mem_overwrite_first.vuma -- overwrite c1 to 30, sum = 110 (30 + 80)
// Expected exit code: 110
//
// Two 8-byte cells. Store 60/80 via `*ptr = literal`, overwrite c1
// to 30 via `*ptr = literal`, load both, sum -> 30 + 80 = 110. Uses
// `*ptr = literal` form. Distinct from s66_mem_overwrite_last (200),
// s65_mem_overwrite_first (190) and s64_mem_overwrite_first (210).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 60;
    *c2 = 80;
    *c1 = 30;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 110
    free(c1);
    free(c2);
    return s;
}
