// s76_mem_overwrite_first.vuma — overwrite c1 to 44, load = 44
// Expected exit code: 44
//
// Three independent 8-byte cells. Store 50/100/80 then overwrite
// c1 to 44. Load c1 -> 44 (the overwritten value). Uses `*ptr
// = literal` form. Distinct from s74_mem_overwrite_first (59),
// s73_mem_overwrite_first (137) and s72_mem_overwrite_middle (185).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 50;
    *c2 = 100;
    *c3 = 80;
    *c1 = 44;
    v: i32 = *c1;          // 44
    free(c1);
    free(c2);
    free(c3);
    return v;
}
