// mem_copy_buffer.vuma — copy from one buffer to another
// Expected exit code: 0
//
// Fills src with a known pattern, copies to dst, then verifies dst matches.
// Returns 0 on success, 1 on mismatch.

fn main() -> i32 {
    src = allocate(16);
    dst = allocate(16);
    // Fill src with pattern
    i: u32 = 0;
    while i < 16 {
        *(src + i) = (i + 1) & 255;
        i = i + 1;
    }
    // Copy src to dst
    j: u32 = 0;
    while j < 16 {
        v: u32 = *(src + j);
        *(dst + j) = v;
        j = j + 1;
    }
    // Verify
    ok: u32 = 1;
    k: u32 = 0;
    while k < 16 {
        sv: u32 = *(src + k);
        dv: u32 = *(dst + k);
        if sv != dv { ok = 0; }
        k = k + 1;
    }
    free(src);
    free(dst);
    if ok == 1 { return 0; }
    return 1;
}
