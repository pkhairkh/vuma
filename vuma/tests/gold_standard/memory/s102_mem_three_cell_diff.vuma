// s102_mem_three_cell_diff.vuma — store 200,1,2 in 3 cells, 200-1-2 = 197
// Expected exit code: 197
//
// Three 8-byte cells. Store 200, 1, 2; load each, return 200 - 1 - 2 = 197. Uses `*ptr = literal` form. Straight-line code only.
// Distinct from s101_mem_overwrite_middle (33), s101_mem_three_cell_diff (100), s101_mem_two_cell_sum (155).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    c3 = allocate(8);
    *c1 = 200;
    *c2 = 1;
    *c3 = 2;
    a: u64 = *c1;          // 200
    b: u64 = *c2;          // 1
    c: u64 = *c3;          // 2
    d: u64 = a - b - c;    // 197
    free(c1);
    free(c2);
    free(c3);
    return d;
}
