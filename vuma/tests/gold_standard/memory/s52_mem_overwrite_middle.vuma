// s52_mem_overwrite_middle.vuma — store 100, overwrite to 200, load = 200
// Expected exit code: 200
//
// Single 8-byte cell. Store 100 via `*ptr = literal`, then overwrite
// the cell with 200. Load and return 200. Uses `*ptr = literal` form.
// Distinct from s50_mem_overwrite_middle (250) and s46_mem_two_cell_
// xor (255).

fn main() -> i32 {
    p = allocate(8);
    *p = 100;
    *p = 200;
    v: u64 = *p;           // 200
    free(p);
    return v;
}
