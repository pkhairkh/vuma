// s55_mem_two_cell_sum.vuma — two cells, sum = 245 (105 + 140)
// Expected exit code: 245
//
// Two 8-byte cells. Store 105/140 via `*ptr = literal`, load both,
// sum -> 245. Uses `*ptr = literal` form (no offsets). Distinct from
// s54_mem_two_cell_sum (250) and s53_mem_two_cell_diff (150).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 105;
    *p2 = 140;
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a + b;        // 245
    free(p1);
    free(p2);
    return s;
}
