// s30_mem_two_cell_and.vuma — two cells, and = 15 (0xFF & 0x0F)
// Expected exit code: 15
//
// Two 8-byte cells. Store 0xFF/0x0F via `*ptr = literal`, load both,
// AND -> 0x0F = 15. Uses `*ptr = literal` form (no offsets). All
// operands loaded into typed locals before the AND. Distinct from
// s26_mem_two_cell_xor (xor, 102) and s22_mem_two_cell_diff (sub, 35).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    *p1 = 255;            // 0xFF
    *p2 = 15;             // 0x0F
    a: u64 = *p1;
    b: u64 = *p2;
    s: u64 = a & b;       // 0x0F = 15
    free(p1);
    free(p2);
    return s;
}
