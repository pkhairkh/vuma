// s47_mem_overwrite_middle.vuma — overwrite middle to 100, sum = 190 (35 + 100 + 55)
// Expected exit code: 190
//
// Three 8-byte cells. Store 35/45/55 via `*ptr = literal`, then
// overwrite the middle cell with 100. Load all three, sum -> 190.
// Uses `*ptr = literal` form (no offsets). Distinct from s46_mem_
// overwrite_last (210) and s42_mem_overwrite_middle (210, same
// total but different addends).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 35;
    *p2 = 45;
    *p3 = 55;
    *p2 = 100;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 190
    free(p1);
    free(p2);
    free(p3);
    return s;
}
