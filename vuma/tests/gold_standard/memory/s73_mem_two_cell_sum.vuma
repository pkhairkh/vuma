// s73_mem_two_cell_sum.vuma — two cells, sum = 116 (78 + 38)
// Expected exit code: 116
//
// Two 8-byte cells. Store 78/38 via `*ptr = literal`, load
// both, sum -> 116. Uses `*ptr = literal` form. Distinct from
// s70_mem_two_cell_sum (105), s69_mem_two_cell_sum (215) and
// s66_mem_two_cell_sum (225).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 78;
    *c2 = 38;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 116
    free(c1);
    free(c2);
    return s;
}
