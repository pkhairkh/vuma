// s61_mem_overwrite_last.vuma — store 30, overwrite to 175, load = 175
// Expected exit code: 175
// 
// Single 8-byte cell. Store 30 via `*ptr = literal`, then overwrite
// with 175. Load and return 175. Uses `*ptr = literal` form (no
// offsets). Distinct from s58_mem_two_cell_sum (230), s58_mem_three
// _cell_or (112) and s58_mem_overwrite_last (180).

fn main() -> i32 {
    p = allocate(8);
    *p = 30;
    *p = 175;
    v: u64 = *p;
    free(p);
    return v;
}
