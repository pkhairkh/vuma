// s46_mem_three_cell_sum.vuma — three cells, sum = 255 (40 + 85 + 130)
// Expected exit code: 255
//
// Three 8-byte cells. Store 40/85/130 via `*ptr = literal`, load all,
// sum -> 255. Uses `*ptr = literal` form (no offsets). Distinct
// from s42_mem_three_cell_xor (195) and s38_mem_two_cell_sum (220).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 40;
    *p2 = 85;
    *p3 = 130;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    t: u64 = a + b;
    s: u64 = t + c;        // 255
    free(p1);
    free(p2);
    free(p3);
    return s;
}
