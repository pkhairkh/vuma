// s78_mem_two_cell_sum.vuma — two cells, sum = 2 (1 + 1)
// Expected exit code: 2
//
// Two 8-byte cells. Store 1/1 via `*ptr = literal`, load
// both, sum -> 2. Uses `*ptr = literal` form. Distinct from
// s74_mem_two_cell_sum (95), s73_mem_two_cell_sum (116) and
// s72_mem_two_cell_sum (220).
fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 1;
    *c2 = 1;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 2
    free(c1);
    free(c2);
    return s;
}
