// s15_mem_overwrite_middle.vuma — overwrite middle cell, sum = 244 (11 + 200 + 33)
// Expected exit code: 244
//
// Three 8-byte cells. Store 11/22/33 in p1/p2/p3, then overwrite p2 (the
// middle cell) with 200. Load all three, sum -> 244. Uses `*ptr = literal`
// form (no offsets). Distinct from s14_mem_overwrite_load (single-cell
// overwrite) and s10_mem_overwrite_middle (uses broken *(p+N) form).

fn main() -> i32 {
    p1 = allocate(8);
    p2 = allocate(8);
    p3 = allocate(8);
    *p1 = 11;
    *p2 = 22;
    *p3 = 33;
    *p2 = 200;
    a: u64 = *p1;
    b: u64 = *p2;
    c: u64 = *p3;
    s: u64 = a + b + c;
    free(p1);
    free(p2);
    free(p3);
    return s;
}
