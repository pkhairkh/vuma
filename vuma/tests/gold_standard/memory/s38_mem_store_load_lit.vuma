// s38_mem_store_load_lit.vuma — store 175, load = 175
// Expected exit code: 175
//
// Single 8-byte cell. Store 175 via `*ptr = literal`, load and
// return 175. Uses `*ptr = literal` form (no offsets). Distinct
// from s34_mem_store_load_lit (187) and s30_mem_two_cell_and.

fn main() -> i32 {
    p = allocate(8);
    *p = 175;
    v: u64 = *p;
    free(p);
    return v;
}
