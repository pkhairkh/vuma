// s77_mem_two_cell_sum.vuma — two cells, sum = 159 (120 + 39)
// Expected exit code: 159
//
// Two 8-byte cells. Store 120/39 via `*ptr = literal`, load
// both, sum -> 159. Uses `*ptr = literal` form. Distinct from
// s70_mem_two_cell_sum (105), s66_mem_two_cell_sum (225) and
// s74_mem_two_cell_sum (199).

fn main() -> i32 {
    c1 = allocate(8);
    c2 = allocate(8);
    *c1 = 120;
    *c2 = 39;
    a: u64 = *c1;
    b: u64 = *c2;
    s: u64 = a + b;        // 159
    free(c1);
    free(c2);
    return s;
}
