// mem_memmove.vuma — memmove (overlapping copy)
// Expected exit code: 0
//
// Performs an overlapping memmove: copies bytes [1, 2, 3, 4, 0, 0, 0, 0]
// starting at offset 0 to offset 2, resulting in [1, 2, 1, 2, 3, 4, 0, 0].
// To avoid overlap corruption, copy high-to-low when dst > src.
// Verifies the result.

fn main() -> i32 {
    buf = allocate(8);
    // Initialize
    *(buf + 0) = 1;
    *(buf + 1) = 2;
    *(buf + 2) = 3;
    *(buf + 3) = 4;
    *(buf + 4) = 0;
    *(buf + 5) = 0;
    *(buf + 6) = 0;
    *(buf + 7) = 0;
    // memmove(buf+2, buf+0, 4 bytes). Since dst > src, copy high-to-low.
    // i.e., copy byte 3 first, then 2, then 1, then 0.
    b3: u32 = *(buf + 3);
    b2: u32 = *(buf + 2);
    b1: u32 = *(buf + 1);
    b0: u32 = *(buf + 0);
    *(buf + 5) = b3;
    *(buf + 4) = b2;
    *(buf + 3) = b1;
    *(buf + 2) = b0;
    // Verify: should be [1, 2, 1, 2, 3, 4, 0, 0]
    v0: u32 = *(buf + 0);
    v1: u32 = *(buf + 1);
    v2: u32 = *(buf + 2);
    v3: u32 = *(buf + 3);
    v4: u32 = *(buf + 4);
    v5: u32 = *(buf + 5);
    free(buf);
    if v0 == 1 {
        if v1 == 2 {
            if v2 == 1 {
                if v3 == 2 {
                    if v4 == 3 {
                        if v5 == 4 { return 0; }
                    }
                }
            }
        }
    }
    return 1;
}
