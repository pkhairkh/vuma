// s101_nl_4x15_count.vuma — 4x15 nested loop, count = 60
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 4 iterations, inner loop 15 iterations each ->
// 4*15 = 60 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s98_nl_8x9_count (72), s97_nl_4x29_count (116)
// and s94_nl_7x8_count (56).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..4 {
        for j in 0..15 {
            count = count + 1;
        }
    }
    return count;
}
