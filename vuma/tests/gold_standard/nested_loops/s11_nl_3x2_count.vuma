// s11_nl_3x2_count.vuma — 3x2 nested loop, count = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 2 iterations each -> 6 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s10_nl_2x4_count (2x4) and s8_nl_3x2_sum_i (3x2 with i-sum).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..2 {
            count = count + 1;
        }
    }
    return count;
}
