// s14_nl_2x5_sum.vuma — 2x5 nested loop, count = 10
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 5 iterations each -> 2*5 = 10
// total iterations. Counter is a scalar accumulator updated inside
// the inner loop body. Known "for-body assignments don't propagate"
// bug keeps count at 0. Distinct from s9_nl_2x4_count (2x4 = 8) and
// s10_nl_5x1_count (5x1 = 5).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..5 {
            count = count + 1;
        }
    }
    return count;
}
