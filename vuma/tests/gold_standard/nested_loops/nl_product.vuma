// nl_product.vuma — product of squared factors (1*1)*(2*2)*(3*3) = 36
// Expected exit code: 36
// Expected exit code (current buggy backend): 1 (initial value, never updated)
//
// Outer loop i runs 0..3 (factor i+1 = 1,2,3); inner loop j runs 0..2 (two
// iterations). Each inner iteration multiplies `prod` by (i+1), so each
// factor gets squared: prod = 1*1 * 2*2 * 3*3 = 1 * 4 * 9 = 36.
// NOW PASSING until the for-body assignment propagation bug is fixed.

fn main() -> i32 {
    prod: u32 = 1;
    for i in 0..3 {
        one: u32 = 1;
        factor: u32 = i + one;
        for j in 0..2 {
            prod = prod * factor;
        }
    }
    return prod;
}
