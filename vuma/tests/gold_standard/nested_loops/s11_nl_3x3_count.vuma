// s11_nl_3x3_count.vuma — 3x3 nested loop, count = 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 3 iterations each -> 9 total.
// Counter increments by 1 each inner iteration. Known "for-body
// assignments don't propagate" bug keeps count at 0. Distinct from
// s10_nl_3x4_count (3x4) and s8_nl_4x1_count (4x1).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
