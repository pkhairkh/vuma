// s79_nl_11x13_count.vuma — 11x13 nested loop, count = 143
// Observed on current x86_64 backend: 0 (FAIL — known bug: for-body assignments don't propagate)
//
// Outer loop 11 iterations, inner loop 13 iterations each ->
// 11*13 = 143 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug
// keeps count at 0. Distinct from s78_nl_5x19_count (95),
// s77_nl_5x19_count (8) and s76_nl_5x19_count (5).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..11 {
        for j in 0..13 {
            count = count + 1;
        }
    }
    return count;
}
