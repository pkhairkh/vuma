// s82_nl_9x3_count.vuma — 9x3 nested loop, count = 27
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 9 iterations, inner loop 3 iterations each ->
// 9*3 = 27 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s78_nl_5x19_count (95), s74_nl_3x13_count
// (39) and s72_nl_5x5_count (25).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..9 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
