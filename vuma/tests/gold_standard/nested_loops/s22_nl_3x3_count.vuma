// s22_nl_3x3_count.vuma — 3x3 nested loop, count = 9
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 3 iterations each -> 3*3 = 9
// total iterations. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s18_nl_3x3_count (same dims, different operand framing)
// and s14_nl_3x3_count (same dims, s14 framing).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
