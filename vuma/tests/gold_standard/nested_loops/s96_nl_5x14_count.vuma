// s96_nl_5x14_count.vuma — 5x14 nested loop, count = 70
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 14 iterations each ->
// 5*14 = 70 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_5x7_count (35), s90_nl_5x22_count (110)
// and s86_nl_5x5_count (25).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..14 {
            count = count + 1;
        }
    }
    return count;
}
