// s78_nl_3x23_count.vuma — 3x23 nested loop, count = 69
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 3 iterations, inner loop 23 iterations each ->
// 3*23 = 69 total. Counter increments by 1 each inner
// iteration. Known "for-body assignments don't propagate" bug keeps
// count at 0. Distinct from s74_nl_4x13_count (52), s73_nl_3x17_count
// (51) and s72_nl_3x9_count (27).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..3 {
        for j in 0..23 {
            count = count + 1;
        }
    }
    return count;
}
