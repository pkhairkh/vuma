// s8_nl_2x3_count.vuma — 2x3 nested loop, count iterations = 6
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 3 iterations. Each inner
// iteration adds 1 to count. Total iterations = 2 * 3 = 6. Known
// "for-body assignments don't propagate" bug keeps count at 0.
// Distinct from s6_nl_2x2_count_diff (2x2).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..3 {
            count = count + 1;
        }
    }
    return count;
}
