// s20_nl_2x4_count.vuma — 2x4 nested loop, count = 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 4 iterations each -> 2*4 = 8 total
// iterations. Counter increments by 1 each inner iteration. Known
// "for-body assignments don't propagate" bug keeps count at 0. Distinct
// from s18_nl_3x2_count (3x2=6) and s14_nl_2x5_count (2x5=10).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
