// s99_nl_5x17_count.vuma — 5x17 nested loop, count = 85
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 17 iterations each ->
// 5*17 = 85 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s95_nl_9x9_count (81), s91_nl_6x13_count (78)
// and s87_nl_5x7_count (35).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..17 {
            count = count + 1;
        }
    }
    return count;
}
