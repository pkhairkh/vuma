// s77_nl_5x14_count.vuma — 5x14 nested loop, count = 70
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 14 iterations each ->
// 5*14 = 70 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_5x8_count (40), s66_nl_5x6_count
// (30) and s74_nl_6x9_count (54).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..14 {
            count = count + 1;
        }
    }
    return count;
}
