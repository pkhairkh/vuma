// s72_nl_5x11_count.vuma — 5x11 nested loop, count = 55
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 11 iterations each ->
// 5*11 = 55 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count
// at 0. Distinct from s70_nl_5x8_count (40), s69_nl_6x7_count
// (42) and s66_nl_5x6_count (30).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..11 {
            count = count + 1;
        }
    }
    return count;
}
