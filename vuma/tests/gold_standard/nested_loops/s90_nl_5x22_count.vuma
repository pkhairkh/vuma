// s90_nl_5x22_count.vuma — 5x22 nested loop, count = 110
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 5 iterations, inner loop 22 iterations each ->
// 5*22 = 110 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s86_nl_4x8_count (32), s82_nl_6x9_count (54)
// and s78_nl_5x17_count (85).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..5 {
        for j in 0..22 {
            count = count + 1;
        }
    }
    return count;
}
