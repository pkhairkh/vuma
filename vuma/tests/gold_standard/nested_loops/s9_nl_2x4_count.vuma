// s9_nl_2x4_count.vuma — 2x4 nested loop, count iterations = 8
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 2 iterations, inner loop 4 iterations each -> 2*4 = 8
// total iterations. Counter is a scalar accumulator updated inside
// the inner loop body. Known "for-body assignments don't propagate"
// bug keeps count at 0. Distinct from s4_nl_2x3_count (2x3 = 6)
// and s6_nl_2x2_count_diff (2x2 = 4).

fn main() -> i32 {
    count: u32 = 0;
    for i in 0..2 {
        for j in 0..4 {
            count = count + 1;
        }
    }
    return count;
}
