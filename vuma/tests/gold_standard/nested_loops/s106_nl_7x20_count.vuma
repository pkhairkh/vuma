// s106_nl_7x20_count.vuma — 7x20 nested loop, count = 7*20 = 140
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop runs 7 iterations, inner loop runs 20 iterations each -> 7*20 = 140 total. Counter is a scalar accumulator updated inside the inner loop. Known "for-body assignments don't propagate" bug keeps count at 0 -> exit 0. Will exit 140 once fixed.
// Distinct from s102_nl_5x25_count (125), s101_nl_3x17_count (51), s100_nl_3x36_count (108).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..20 {
            count = count + 1;
        }
    }
    return count;
}
