// s98_nl_7x10_count.vuma — 7x10 nested loop, count = 70
// Observed on current x86_64 backend: 0 (FAIL — known bug)
//
// Outer loop 7 iterations, inner loop 10 iterations each ->
// 7*10 = 70 total. Counter increments by 1 each inner iteration.
// Known "for-body assignments don't propagate" bug keeps count at
// 0. Distinct from s94_nl_4x13_count (52), s90_nl_3x44_count (132)
// and s86_nl_2x15_count (30).
fn main() -> i32 {
    count: u32 = 0;
    for i in 0..7 {
        for j in 0..10 {
            count = count + 1;
        }
    }
    return count;
}
