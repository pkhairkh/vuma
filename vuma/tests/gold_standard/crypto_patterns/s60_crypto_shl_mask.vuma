// s60_crypto_shl_mask.vuma — (1 << 4) & 0xF0 = 0x10 & 0xF0 = 0x10 = 16
// Expected exit code: 16
//
// Shift 1 left by 4 to build the low-nibble-bit 0x10, then mask
// with 0xF0 to keep only the high half of the result. (1 << 4) =
// 16 (0x10); 16 & 240 = 16 (0x10). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s58_crypto_shr_extract (12) and s57_crypto_shl_
// mask (20).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 240;          // 0xF0
    x: u64 = a << b;       // 0x10 = 16
    r: u64 = x & c;        // 0x10 = 16
    return r;
}
