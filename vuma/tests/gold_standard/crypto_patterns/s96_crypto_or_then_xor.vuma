// s96_crypto_or_then_xor.vuma — (0x60 | 0x1C) ^ 0x03 = 0x7C ^ 0x03 = 0x7F = 127
// Expected exit code: 127
//
// Two-stage crypto mix: OR then XOR. (96 | 28) = 124 (0x7C);
// 124 ^ 3 = 127 (0x7F). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_or_then_and (48), s90_crypto_and_then_xor (27) and
// s86_crypto_and_then_xor (63).
fn main() -> i32 {
    a: u32 = 96;           // 0x60
    b: u32 = 28;           // 0x1C
    c: u32 = 3;            // 0x03
    x: u32 = a | b;        // 0x7C = 124
    r: u32 = x ^ c;        // 0x7F = 127
    return r;
}
