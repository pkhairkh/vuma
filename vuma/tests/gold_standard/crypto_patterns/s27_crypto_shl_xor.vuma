// s27_crypto_shl_xor.vuma — (0x07 << 3) ^ 0x55 = 0x38 ^ 0x55 = 0x6D = 109
// Expected exit code: 109
//
// SHL then XOR. (7 << 3) = 56 (0x38); 56 ^ 85 = 109 (0x6D). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s26_crypto_shl_then_mask (shl-then-and)
// and s22_crypto_shl_mask_high (shl-then-and, different mask).

fn main() -> i32 {
    a: u64 = 7;           // 0x07
    b: u64 = 3;
    c: u64 = 85;          // 0x55
    x: u64 = a << b;      // 0x38 = 56
    r: u64 = x ^ c;       // 0x6D = 109
    return r;
}
