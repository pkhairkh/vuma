// s6_crypto_xor_chain_3.vuma — 0x0F ^ 0x33 ^ 0x55 = 0x69 = 105
// Expected exit code: 105
//
// Three-byte XOR chain. 15 ^ 51 = 60 (0x3C). 60 ^ 85 = 105 (0x69).
// All operands loaded into variables first to dodge the immediate-RHS
// bitwise drop bug. Distinct from s5_bit_xor_then_not (XOR-then-NOT).

fn main() -> i32 {
    a: u64 = 15;     // 0x0F
    b: u64 = 51;     // 0x33
    c: u64 = 85;     // 0x55
    t1: u64 = a ^ b; // 0x3C
    t2: u64 = t1 ^ c;// 0x69 = 105
    return t2;
}
