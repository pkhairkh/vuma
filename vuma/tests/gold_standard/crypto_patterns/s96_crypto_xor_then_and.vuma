// s96_crypto_xor_then_and.vuma — (0x99 ^ 0x18) & 0xF0 = 0x81 & 0xF0 = 0x80 = 128
// Expected exit code: 128
//
// Two-stage crypto mix: XOR then AND. (153 ^ 24) = 129 (0x81);
// 129 & 240 = 128 (0x80). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_xor_then_or (255), s90_crypto_xor_then_shr (17) and
// s86_crypto_xor_pair (153).
fn main() -> i32 {
    a: u32 = 153;          // 0x99
    b: u32 = 24;           // 0x18
    c: u32 = 240;          // 0xF0
    x: u32 = a ^ b;        // 0x81 = 129
    r: u32 = x & c;        // 0x80 = 128
    return r;
}
