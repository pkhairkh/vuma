// s48_crypto_shl_mask.vuma — (0x03 << 5) & 0xE0 = 0x60 & 0xE0 = 0x60 = 96
// Expected exit code: 96
//
// Shift-then-mask to build a bit pattern. (3 << 5) = 96 (0x60);
// 96 & 224 = 96 (0x60). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_crypto_shr_extract (11) and s42_crypto_shl_xor (47).

fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 5;
    c: u64 = 224;          // 0xE0
    x: u64 = a << b;       // 0x60 = 96
    r: u64 = x & c;        // 0x60 = 96
    return r;
}
