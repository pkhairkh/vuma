// s87_crypto_and_then_xor.vuma — (0xFF & 0x33) ^ 0x0F = 0x33 ^ 0x0F = 0x3C = 60
// Expected exit code: 60
//
// AND 0xFF with 0x33 -> 0x33 = 51, then XOR with 0x0F -> 0x3C
// = 60. All operands loaded into u32 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s86_crypto_
// and_then_xor (63), s82_crypto_and_then_or (60) and s78_crypto_
// and_then_xor (200).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 51;           // 0x33
    c: u32 = 15;           // 0x0F
    x: u32 = a & b;        // 0x33 = 51
    r: u32 = x ^ c;        // 0x3C = 60
    return r;
}
