// s52_crypto_or_mask.vuma — 0xF0 | 0x06 = 0xF6 = 246
// Expected exit code: 246
//
// Bitwise OR of high-nibble mask (0xF0) with low-bits 0x06 yields
// 0xF6 = 246. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s47_crypto_or_mask (240) and s50_crypto_xor_pair (255).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 6;            // 0x06
    r: u64 = a | b;        // 0xF6 = 246
    return r;
}
