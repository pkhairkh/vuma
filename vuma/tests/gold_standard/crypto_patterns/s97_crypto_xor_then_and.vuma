// s97_crypto_xor_then_and.vuma — (0xAA ^ 0x55) & 0x35 = 0xFF & 0x35 = 0x35 = 53
// Expected exit code: 53
//
// Two-stage crypto mix: XOR then AND. (170 ^ 85) = 255
// (0xFF); 255 & 53 = 53 (0x35). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug
// workaround).
// Distinct from s94_crypto_and_then_shr (30), s90_crypto_and_then_xor (27), s86_crypto_and_then_xor (63).
fn main() -> i32 {
    a: u32 = 170;          // 0xAA
    b: u32 = 85;           // 0x55
    c: u32 = 53;           // 0x35
    x: u32 = a ^ b;        // 0xFF = 255
    r: u32 = x & c;        // 0x35 = 53
    return r;
}
