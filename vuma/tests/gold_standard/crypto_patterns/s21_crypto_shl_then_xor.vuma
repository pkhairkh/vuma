// s21_crypto_shl_then_xor.vuma — (0x09 << 4) ^ 0x0F = 0x90 ^ 0x0F = 0x9F = 159
// Expected exit code: 159
//
// Shift a small value into the high nibble then XOR the low nibble.
// (9 << 4) = 144 (0x90); 144 ^ 15 = 159 (0x9F). The shift amount and
// key are loaded into variables first to dodge the immediate-RHS bitwise
// drop bug. Distinct from s18_crypto_shl_mask (shl-then-and) and
// s14_crypto_shl_then_xor (different values).

fn main() -> i32 {
    v: u64 = 9;           // 0x09
    s: u64 = 4;
    k: u64 = 15;          // 0x0F
    x: u64 = v << s;      // 0x90 = 144
    r: u64 = x ^ k;       // 0x9F = 159
    return r;
}
