// s37_crypto_nibble_clear.vuma — clear low nibble of 0x6E: 0x6E & 0xF0 = 0x60 = 96
// Expected exit code: 96
//
// Deterministic test in the crypto_patterns category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s33_crypto_nibble_swap (swap, 58) and s30_crypto_nibble_clear (clears nibble).
fn main() -> i32 {
    a: u64 = 110;          // 0x6E
    mask: u64 = 240;       // 0xF0
    r: u64 = a & mask;     // 0x60 = 96
    return r;
}
