// s32_crypto_xor_pair.vuma - 0x96 ^ 0x69 = 0xFF = 255
// Expected exit code: 255
//
// 0x96 ^ 0x69 = 0xFF = 255. All operands loaded into typed variables before
// any bitwise op (immediate-RHS drop workaround where applicable); stores
// use the `*ptr = literal` (or `*ptr = variable + 0`) form with no `*(ptr +
// offset)` indexing. Distinct from s30_crypto_xor_pair (0xC3 ^ 0x3C = 0xFF)
// and s26_crypto_xor_pair (0xA5 ^ 0x5A).

fn main() -> i32 {
    a: u64 = 150;         // 0x96
    b: u64 = 105;         // 0x69
    r: u64 = a ^ b;       // 0xFF = 255
    return r;
}
