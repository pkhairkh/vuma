// s85_crypto_shr_then_xor.vuma — (0xF0 >> 2) ^ 0x11 = 0x3C ^ 0x11 = 0x2D = 45
// Expected exit code: 45
//
// Two-stage crypto-style bitwise: shift right then XOR.
// (240 >> 2) = 60 (0x3C); 60 ^ 17 = 45 (0x2D). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s82_crypto_shl_then_xor,
// s78_crypto_shr_then_xor and s74_crypto_shr_then_xor.
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 2;            // shift amount
    c: u64 = 17;           // 0x11
    x: u64 = a >> b;       // 0x3C = 60
    r: u64 = x ^ c;        // 0x2D = 45
    return r;
}
