// s50_crypto_shr_extract.vuma — 0xF0 >> 4 = 0x0F = 15
// Expected exit code: 15
//
// Extract the high nibble by shifting right by 4. 240 (0xF0) >> 4 =
// 15 (0x0F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s46_crypto_shr_extract (0xB4 >> 4 = 11) and s43_crypto_shl_xor
// (60).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 4;
    r: u64 = a >> b;       // 0x0F = 15
    return r;
}
