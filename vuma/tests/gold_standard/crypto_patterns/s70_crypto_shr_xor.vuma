// s70_crypto_shr_xor.vuma — (0xFF >> 1) ^ 0x98 = 0x7F ^ 0x98 = 0xE7 = 231
// Expected exit code: 231
//
// Two-stage crypto op: shift right then XOR. (255 >> 1) = 127
// (0x7F); 127 ^ 152 = 231 (0xE7). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_crypto_shr_extract (10), s65_crypto_or_then_
// xor (104) and s62_crypto_shr_extract (11).
fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 1;
    c: u64 = 152;          // 0x98
    x: u64 = a >> b;       // 0x7F = 127
    r: u64 = x ^ c;        // 0xE7 = 231
    return r;
}
