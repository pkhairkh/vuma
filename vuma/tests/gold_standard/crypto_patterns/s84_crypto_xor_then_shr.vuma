// s84_crypto_xor_then_shr.vuma — (0x88 ^ 0x44) >> 3 = 0xCC >> 3 = 0x19 = 25
// Expected exit code: 25
//
// Two-stage crypto-style bitwise: XOR then shift right.
// (136 ^ 68) = 204 (0xCC); 204 >> 3 = 25 (0x19). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s82_crypto_shl_then_xor (65),
// s78_crypto_xor_then_shr (1) and s74_crypto_xor_then_shr (39).
fn main() -> i32 {
    a: u64 = 136;          // 0x88
    b: u64 = 68;           // 0x44
    c: u64 = 3;            // shift amount
    x: u64 = a ^ b;        // 0xCC = 204
    r: u64 = x >> c;       // 0x19 = 25
    return r;
}
