// s87_crypto_shl_mask.vuma — (0x0B << 4) & 0xF0 = 0xB0 & 0xF0 = 0xB0 = 176
// Expected exit code: 176
//
// Shift 0x0B left by 4 -> 0xB0, then mask with 0xF0 -> 0xB0 =
// 176. All operands loaded into u32 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s86_crypto_
// shl_mask (112), s82_crypto_shl_then_xor (120) and s78_crypto_
// shl_mask (176).
fn main() -> i32 {
    a: u32 = 11;           // 0x0B
    b: u32 = 4;            // shift amount
    c: u32 = 240;          // 0xF0
    x: u32 = a << b;       // 0xB0 = 176
    r: u32 = x & c;        // 0xB0 = 176
    return r;
}
