// s96_crypto_shl_then_and.vuma — (0x09 << 3) & 0x78 = 0x48 & 0x78 = 0x48 = 72
// Expected exit code: 72
//
// Two-stage crypto mix: shift-left then AND. (9 << 3) = 72 (0x48);
// 72 & 120 = 72 (0x48). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_and_then_shr (30), s90_crypto_shl_then_or (18) and
// s86_crypto_shl_mask (112).
fn main() -> i32 {
    a: u32 = 9;            // 0x09
    s: u32 = 3;
    c: u32 = 120;          // 0x78
    x: u32 = a << s;       // 0x48 = 72
    r: u32 = x & c;        // 0x48 = 72
    return r;
}
