// s90_crypto_and_then_xor.vuma — (0xF0 & 0x10) ^ 0x0B = 0x10 ^ 0x0B = 0x1B = 27
// Expected exit code: 27
//
// Two-stage crypto mix: AND then XOR. (240 & 16) = 16 (0x10);
// 16 ^ 11 = 27 (0x1B). All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s86_crypto_and_then_xor (232), s82_crypto_and_then_or (120) and
// s78_crypto_and_then_shl (4).
fn main() -> i32 {
    a: u32 = 240;          // 0xF0
    b: u32 = 16;           // 0x10
    c: u32 = 11;           // 0x0B
    x: u32 = a & b;        // 0x10 = 16
    r: u32 = x ^ c;        // 0x1B = 27
    return r;
}
