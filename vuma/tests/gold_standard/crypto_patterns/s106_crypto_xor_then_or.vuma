// s106_crypto_xor_then_or.vuma — (0xC0 ^ 0x80) | 0x05 = 0x40 | 0x05 = 0x45 = 69
// Expected exit code: 69
//
// Two-stage crypto mix: XOR then OR. (192 ^ 128) = 64 (0x40); 64 | 5 = 69 (0x45). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s102_crypto_xor_then_and (55), s101_crypto_xor_then_or (241), s100_crypto_shr_then_xor (57).
fn main() -> i32 {
    a: u32 = 192;         // 0xC0
    b: u32 = 128;         // 0x80
    c: u32 = 5;           // 0x05
    x: u32 = a ^ b;        // 0x40 = 64
    r: u32 = x | c;        // 0x45 = 69
    return r;
}
