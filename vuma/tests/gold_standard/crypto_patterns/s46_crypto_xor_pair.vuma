// s46_crypto_xor_pair.vuma — 0x66 ^ 0x99 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 102 ^ 153 = 255 (0xFF). Bit-complement-style pair
// (0x66 / 0x99 are bitwise complements within a byte) produces an
// all-ones bit pattern. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_crypto_xor_pair (0xC3 ^ 0x3C = 255) and s38_crypto_xor_pair
// (0xA5 ^ 0x3C = 153).

fn main() -> i32 {
    a: u64 = 102;          // 0x66
    b: u64 = 153;          // 0x99
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
