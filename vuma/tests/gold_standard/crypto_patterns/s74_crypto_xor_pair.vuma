// s74_crypto_xor_pair.vuma — 0xAB ^ 0x37 = 0x9C = 156
// Expected exit code: 156
//
// Two-byte XOR. 171 ^ 55 = 156 (0x9C). Mid-bit pair (0xAB / 0x37)
// produces the byte 0x9C. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s70_crypto_xor_pair (42), s66_crypto_xor_pair (249) and
// s62_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 55;           // 0x37
    r: u64 = a ^ b;        // 0x9C = 156
    return r;
}
