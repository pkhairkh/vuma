// s18_crypto_high_nibble_extract.vuma — (0xAB >> 4) = 0x0A = 10
// Expected exit code: 10
//
// Extract the high nibble of 0xAB (171) by shifting right 4. The
// shift amount is loaded into a variable first to dodge the
// immediate-RHS bitwise drop bug. Distinct from
// s10_crypto_high_nibble_only (uses >> then & mask, different value)
// and s14_crypto_low_nibble (low-nibble extract via & 0x0F).

fn main() -> i32 {
    v: u64 = 171;         // 0xAB
    s: u64 = 4;
    r: u64 = v >> s;      // 0x0A = 10
    return r;
}
