// s31_crypto_shl_mask.vuma — (0x05 << 4) & 0xF0 = 0x50 & 0xF0 = 0x50 = 80
// Expected exit code: 80
//
// SHL then AND mask. (5 << 4) = 80 (0x50); 80 & 240 = 80 (0x50). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s30_crypto_shl_then_mask
// (shl-then-mask) and s28_crypto_shl_xor (shl-xor, 79).

fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 4;
    c: u64 = 240;          // 0xF0
    x: u64 = a << b;       // 0x50 = 80
    r: u64 = x & c;        // 0x50 = 80
    return r;
}
