// s23_crypto_xor_then_or.vuma — (0x55 ^ 0x0F) | 0xC0 = 0x5A | 0xC0 = 0xDA = 218
// Expected exit code: 218
//
// XOR then OR. (85 ^ 15) = 90 (0x5A); 90 | 192 = 218 (0xDA). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s22_crypto_or_xor_chain (or-then-xor,
// value 83) and s24_crypto_xor_or_chain (xor-then-or-then-xor).

fn main() -> i32 {
    a: u64 = 85;          // 0x55
    b: u64 = 15;          // 0x0F
    c: u64 = 192;         // 0xC0
    x: u64 = a ^ b;       // 0x5A = 90
    r: u64 = x | c;       // 0xDA = 218
    return r;
}

