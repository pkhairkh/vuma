// s79_crypto_xor_then_and.vuma — (0x33 ^ 0x11) & 0x3F = 0x22 & 0x3F = 0x22 = 34
// Expected exit code: 34
//
// Two-stage crypto op: XOR then AND. (51 ^ 17) = 34 (0x22);
// 34 & 63 = 34 (0x22). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_crypto_or_then_xor (9), s77_crypto_xor_then_and (1)
// and s76_crypto_xor_then_and (2).
fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 17;           // 0x11
    c: u64 = 63;           // 0x3F
    x: u64 = a ^ b;        // 0x22 = 34
    r: u64 = x & c;        // 0x22 = 34
    return r;
}
