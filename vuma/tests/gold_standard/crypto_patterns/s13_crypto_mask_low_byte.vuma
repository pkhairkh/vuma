// s13_crypto_mask_low_byte.vuma — 0xAB & 0x0F = 0x0B = 11
// Expected exit code: 11
//
// Mask the low nibble of a byte. 0xAB & 0x0F = 0x0B = 11. Models the
// nibble-extraction step used in some hash and cipher routines. All
// operands loaded into u64 variables first. Distinct from
// s9_u32_and_mask (u32, 0xFF & 0x0F) and s5_crypto_mask_high_nibble
// (high nibble, not low).

fn main() -> i32 {
    v: u64 = 171;         // 0xAB
    m: u64 = 15;          // 0x0F
    r: u64 = v & m;       // 0x0B = 11
    return r;
}
