// s85_crypto_xor_then_or.vuma — (0xF0 ^ 0x3C) | 0x08 = 0xCC | 0x08 = 0xCC = 204
// Expected exit code: 204
//
// Two-stage crypto-style bitwise: XOR then OR. (240 ^ 60) =
// 204 (0xCC); 204 | 8 = 204 (0xCC). All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s82_crypto_xor_then_and (85),
// s78_crypto_xor_then_or and s74_crypto_xor_then_or.
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 60;           // 0x3C
    c: u64 = 8;            // 0x08
    x: u64 = a ^ b;        // 0xCC = 204
    r: u64 = x | c;        // 0xCC = 204
    return r;
}
