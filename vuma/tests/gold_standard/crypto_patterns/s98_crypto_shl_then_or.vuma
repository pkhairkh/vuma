// s98_crypto_shl_then_or.vuma — (0x05 << 3) | 0x01 = 0x28 | 0x01 = 0x29 = 41
// Expected exit code: 41
//
// Two-stage crypto-style bitwise: shift-left then OR. 5 << 3 = 40
// (0x28); 40 | 1 = 41 (0x29). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s94_crypto_or_then_and (48), s90_crypto_shl_then_or (18) and
// s86_crypto_shl_mask (112).
fn main() -> i32 {
    a: u64 = 5;           // 0x05
    s: u64 = 3;
    c: u64 = 1;           // 0x01
    x: u64 = a << s;      // 0x28 = 40
    r: u64 = x | c;       // 0x29 = 41
    return r;
}
