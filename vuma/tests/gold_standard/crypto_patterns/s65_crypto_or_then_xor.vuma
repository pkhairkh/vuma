// s65_crypto_or_then_xor.vuma — (0x40 | 0x20) ^ 0x08 = 0x60 ^ 0x08 = 0x68 = 104
// Expected exit code: 104
//
// Two-stage bitwise: OR then XOR. (64 | 32) = 96 (0x60);
// 96 ^ 8 = 104 (0x68). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_
// crypto_and_then_xor (195), s58_crypto_or_then_xor (127) and s62_
// crypto_or_then_and (170).

fn main() -> i32 {
    a: u64 = 64;           // 0x40
    b: u64 = 32;           // 0x20
    c: u64 = 8;            // 0x08
    x: u64 = a | b;        // 0x60 = 96
    r: u64 = x ^ c;        // 0x68 = 104
    return r;
}
