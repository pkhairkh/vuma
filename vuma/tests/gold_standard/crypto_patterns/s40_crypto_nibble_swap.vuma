// s40_crypto_nibble_swap.vuma — swap nibbles of 0x6C -> 0xC6 = 198
// Expected exit code: 198
//
// Nibble-swap mixing step. v=108 (0x6C); low nibble = 12, high
// nibble = 96; (low << 4) | (high >> 4) = 192 | 6 = 198 (0xC6). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s38_crypto_nibble_clear (192)
// and s34_crypto_nibble_clear (11).

fn main() -> i32 {
    v: u64 = 108;          // 0x6C
    mlow: u64 = 15;        // 0x0F
    mhigh: u64 = 240;      // 0xF0
    sh: u64 = 4;
    low: u64 = v & mlow;   // 0x0C = 12
    high: u64 = v & mhigh; // 0x60 = 96
    lsh: u64 = low << sh;  // 0xC0 = 192
    hsh: u64 = high >> sh; // 0x06 = 6
    r: u64 = lsh | hsh;    // 0xC6 = 198
    return r;
}
