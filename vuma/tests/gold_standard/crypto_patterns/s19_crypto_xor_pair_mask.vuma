// s19_crypto_xor_pair_mask.vuma — (0xB4 ^ 0x18) & 0xF0 = 0xAC & 0xF0 = 0xA0 = 160
// Expected exit code: 160
//
// XOR two bytes then mask off the low nibble. (180 ^ 24) = 172
// (0xAC); 172 & 240 = 160 (0xA0). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s18_crypto_xor_pair (plain two-byte XOR, no mask)
// and s14_crypto_xor_two_keys (three-way XOR).

fn main() -> i32 {
    v: u64 = 180;         // 0xB4
    k: u64 = 24;          // 0x18
    m: u64 = 240;         // 0xF0
    x: u64 = v ^ k;       // 0xAC = 172
    r: u64 = x & m;       // 0xA0 = 160
    return r;
}
