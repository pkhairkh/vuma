// s24_crypto_shl_mask_low.vuma — (0x03 << 4) & 0x7F = 0x30 & 0x7F = 0x30 = 48
// Expected exit code: 48
//
// Shift then low-7-bit mask. 3 << 4 = 48 (0x30); 48 & 127 = 48 (0x30,
// since bit 7 is clear). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s22_crypto_shl_mask_high (shl-then-high-nibble-mask, value 0) and
// s14_crypto_shl_then_xor (shl-then-xor).

fn main() -> i32 {
    a: u64 = 3;
    s: u64 = 4;
    m: u64 = 127;         // 0x7F
    x: u64 = a << s;      // 0x30 = 48
    r: u64 = x & m;       // 0x30 = 48
    return r;
}
