// s13_crypto_xor_pair.vuma — 0xA5 ^ 0x5A = 0xFF = 255
// Expected exit code: 255
//
// XOR of a byte with its bitwise complement-ish partner (0xA5 ^ 0x5A
// = 0xFF). Models the basic XOR-combine step used in stream ciphers.
// All operands loaded into u64 variables first. Distinct from
// s9_crypto_xor_self (self-cancellation -> 0) and s10_crypto_xor_chain_4
// (four-way XOR chain).

fn main() -> i32 {
    a: u64 = 165;         // 0xA5
    b: u64 = 90;          // 0x5A
    r: u64 = a ^ b;       // 0xFF = 255
    return r;
}
