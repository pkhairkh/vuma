// s45_crypto_shr_xor.vuma — (0xC0 >> 4) ^ 0x0F = 12 ^ 15 = 3
// Expected exit code: 3
//
// Two-stage mix: shift right then XOR. (192 >> 4) = 12 (0x0C);
// 12 ^ 15 = 3 (0x03). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_crypto_shl_xor (shl-then-xor, 47) and s34_crypto_shr_extract.

fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    b: u64 = 4;
    c: u64 = 15;           // 0x0F
    s: u64 = a >> b;       // 0x0C = 12
    r: u64 = s ^ c;        // 0x03 = 3
    return r;
}
