// s7_crypto_xor_fold_5.vuma — 0x01 ^ 0x02 ^ 0x04 ^ 0x08 ^ 0x10 = 0x1F = 31
// Expected exit code: 31
//
// Five-byte XOR fold. Each operand has exactly one bit set (bits
// 0,1,2,3,4); XOR-folding them sets all five bits, giving 0x1F = 31.
// A simple parity/checksum-style fold over independent single-bit
// values. All operands loaded into variables first to dodge the
// immediate-RHS bitwise drop bug. Distinct from s5_crypto_parity_xor
// (4-byte fold, different values) and s6_crypto_xor_chain_3 (3-byte
// fold).

fn main() -> i32 {
    a: u64 = 1;     // 0x01
    b: u64 = 2;     // 0x02
    c: u64 = 4;     // 0x04
    d: u64 = 8;     // 0x08
    e: u64 = 16;    // 0x10
    t1: u64 = a ^ b;     // 0x03
    t2: u64 = t1 ^ c;    // 0x07
    t3: u64 = t2 ^ d;    // 0x0F
    r: u64 = t3 ^ e;     // 0x1F = 31
    return r;
}
