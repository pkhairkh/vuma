// s17_crypto_xor_pair_then_mask.vuma — (0xA5 ^ 0x3C) & 0xFF = 0x99 = 153
// Expected exit code: 153
//
// XOR two bytes then mask to a single byte. (165 ^ 60) = 153 (0x99);
// 153 & 255 = 153. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s14_crypto_xor_two_keys (two-key XOR, no mask) and
// s10_crypto_xor_inverse (XOR-then-XOR-back).

fn main() -> i32 {
    a: u64 = 165;         // 0xA5
    b: u64 = 60;          // 0x3C
    m: u64 = 255;         // 0xFF
    x: u64 = a ^ b;       // 0x99 = 153
    r: u64 = x & m;       // 0x99 = 153
    return r;
}
