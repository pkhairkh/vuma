// s48_crypto_xor_pair.vuma — 0xA5 ^ 0x5A = 0xFF = 255
// Expected exit code: 255
//
// Classic XOR-pair complement. 165 ^ 90 = 255 (0xFF). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s46_crypto_xor_pair and s42_crypto_xor_
// chain_4.

fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 90;           // 0x5A
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
