// s94_crypto_and_then_shr.vuma — (0xFF & 0x78) >> 2 = 0x78 >> 2 = 0x1E = 30
// Expected exit code: 30
//
// Two-stage crypto mix: AND then shift-right. (255 & 120) = 120
// (0x78); 120 >> 2 = 30 (0x1E). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s90_crypto_shl_then_or (18), s86_crypto_shl_mask
// (112) and s82_crypto_shl_then_xor (65).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 120;          // 0x78
    s: u32 = 2;
    x: u32 = a & b;        // 0x78 = 120
    r: u32 = x >> s;       // 0x1E = 30
    return r;
}
