// s81_crypto_and_then_shl.vuma — (0xFF & 0x07) << 4 = 0x07 << 4 = 0x70 = 112
// Expected exit code: 112
//
// Two-stage crypto op: AND then shift left. 255 & 7 = 7 (0x07);
// 7 << 4 = 112 (0x70). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s78_crypto_and_then_shl (4), s77_crypto_shl_then_and (36)
// and s76_crypto_xor_then_shr (31).
fn main() -> i32 {
    a: u64 = 255;          // 0xFF
    b: u64 = 7;            // 0x07
    c: u64 = 4;
    x: u64 = a & b;        // 0x07 = 7
    r: u64 = x << c;       // 0x70 = 112
    return r;
}
