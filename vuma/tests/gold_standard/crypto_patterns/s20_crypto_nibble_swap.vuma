// s20_crypto_nibble_swap.vuma — swap nibbles of 0x2A -> 0xA2 = 162
// Expected exit code: 162
//
// Classic nibble-swap on a single byte: ((v & 0x0F) << 4) | ((v & 0xF0)
// >> 4). With v = 0x2A (42): low nibble 0x0A -> 0xA0 (160); high nibble
// 0x20 -> 0x02 (2); 160 | 2 = 162 (0xA2). All operands loaded into u64
// variables first. Distinct from s18_crypto_high_nibble_extract (extract
// only) and s12_crypto_nibble_swap (different input byte).

fn main() -> i32 {
    v: u64 = 42;          // 0x2A
    mlo: u64 = 15;        // 0x0F
    mhi: u64 = 240;       // 0xF0
    sh: u64 = 4;
    lo: u64 = v & mlo;    // 0x0A = 10
    hi: u64 = v & mhi;    // 0x20 = 32
    los: u64 = lo << sh;  // 0xA0 = 160
    his: u64 = hi >> sh;  // 0x02 = 2
    r: u64 = los | his;   // 0xA2 = 162
    return r;
}
