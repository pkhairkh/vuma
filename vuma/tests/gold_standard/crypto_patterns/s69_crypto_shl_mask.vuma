// s69_crypto_shl_mask.vuma -- (0x06 << 5) & 0xE0 = 0xC0 & 0xE0 = 0xC0 = 192
// Expected exit code: 192
//
// Shift-then-mask: (6 << 5) = 192 (0xC0); 192 & 224 = 192 (0xC0).
// All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s66_crypto_shr_extract
// (10), s65_crypto_shl_mask (144) and s64_crypto_shl_mask (80).
fn main() -> i32 {
    a: u64 = 6;            // 0x06
    b: u64 = 5;            // shift amount
    c: u64 = 224;          // 0xE0
    x: u64 = a << b;       // 0xC0 = 192
    r: u64 = x & c;        // 0xC0 = 192
    return r;
}
