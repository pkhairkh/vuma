// s6_crypto_nibble_swap.vuma — swap nibbles of 0xAB -> 0xBA = 186
// Expected exit code: 186
//
// Take 0xAB (171). Swap high/low nibbles -> 0xBA = 186. Equivalent to
// an 8-bit rotate left or right by 4. Computed via shifts and OR with
// 0xFF mask. All operands loaded into variables first. Distinct from
// s5_crypto_rotate_left_4 (uses 0x2B, different result).

fn main() -> i32 {
    v: u64 = 171;       // 0xAB
    four: u64 = 4;
    mask: u64 = 255;    // 0xFF
    hi_part: u64 = v << four;           // 0xAB0
    lo_part: u64 = v >> four;           // 0x0A
    combined: u64 = hi_part | lo_part;  // 0xABA
    r: u64 = combined & mask;           // 0xBA = 186
    return r;
}
