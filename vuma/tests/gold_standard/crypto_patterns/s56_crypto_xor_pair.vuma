// s56_crypto_xor_pair.vuma — 0x3C ^ 0xC3 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 60 ^ 195 = 255 (0xFF). Complement-style pair (0x3C /
// 0xC3 are bitwise complements within a byte) produces an all-ones
// bit pattern. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_crypto_xor_pair (0x5A ^ 0xA5 = 255) and s50_crypto_xor_pair
// (0x69 ^ 0x96 = 255).

fn main() -> i32 {
    a: u64 = 60;           // 0x3C
    b: u64 = 195;          // 0xC3
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
