// s61_crypto_xor_pair.vuma — 0x3C ^ 0x5A = 0x66 = 102
// Expected exit code: 102
// 
// Two-byte XOR. 60 ^ 90 = 102 (0x66). Bit pattern pair (0x3C /
// 0x5A) produces a non-trivial XOR result. All operands loaded
// into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s58_crypto_xor_pair (255), s58_crypto_
// shr_extract (12) and s58_crypto_or_then_xor (127).

fn main() -> i32 {
    a: u64 = 60;           // 0x3C
    b: u64 = 90;           // 0x5A
    r: u64 = a ^ b;        // 0x66 = 102
    return r;
}
