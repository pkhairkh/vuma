// s10_crypto_high_nibble_only.vuma — (0xCD >> 4) & 0x0F = 0x0C = 12
// Expected exit code: 12
//
// Extract only the high nibble of 0xCD (205). (205 >> 4) = 12 (0x0C);
// 12 & 15 = 12. Distinct from s5_crypto_nibble_extract (returns sum of
// both nibbles) and s6_crypto_nibble_swap (swaps nibbles).

fn main() -> i32 {
    v: u64 = 205;         // 0xCD
    sh: u64 = 4;
    mask: u64 = 15;       // 0x0F
    shifted: u64 = v >> sh;   // 0x0C
    r: u64 = shifted & mask;  // 0x0C = 12
    return r;
}
