// s38_crypto_nibble_clear.vuma — 0xCD & 0xF0 = 0xC0 = 192
// Expected exit code: 192
//
// Clear the low nibble. 205 (0xCD) & 240 (0xF0) = 192 (0xC0). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s34_crypto_nibble_clear
// (0xAB & 0x0F = 11) and s30_crypto_nibble_clear.

fn main() -> i32 {
    a: u64 = 205;          // 0xCD
    b: u64 = 240;          // 0xF0
    r: u64 = a & b;        // 0xC0 = 192
    return r;
}
