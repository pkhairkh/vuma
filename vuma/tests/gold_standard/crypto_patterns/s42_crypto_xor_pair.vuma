// s42_crypto_xor_pair.vuma — 0xC3 ^ 0x3C = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 195 ^ 60 = 255 (0xFF). Complement-style pair
// produces an all-ones bit pattern. All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s38_crypto_xor_pair (0xA5 ^ 0x3C = 0x99 = 153) and
// s34_crypto_xor_pair (0x96 ^ 0x69 = 0xFF).

fn main() -> i32 {
    a: u64 = 195;          // 0xC3
    b: u64 = 60;           // 0x3C
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
