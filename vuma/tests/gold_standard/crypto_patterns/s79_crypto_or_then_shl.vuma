// s79_crypto_or_then_shl.vuma — (0x03 | 0x01) << 3 = 0x03 << 3 = 0x18 = 24
// Expected exit code: 24
//
// Two-stage crypto op: OR then shift left. (3 | 1) = 3
// (0x03); 3 << 3 = 24 (0x18). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s78_crypto_and_then_shl (4),
// s77_crypto_or_then_shl (1) and s76_crypto_or_then_shl (2).
fn main() -> i32 {
    a: u64 = 3;            // 0x03
    b: u64 = 1;            // 0x01
    c: u64 = 3;
    x: u64 = a | b;        // 0x03 = 3
    r: u64 = x << c;       // 0x18 = 24
    return r;
}
