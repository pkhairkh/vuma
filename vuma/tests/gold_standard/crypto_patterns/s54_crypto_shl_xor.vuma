// s54_crypto_shl_xor.vuma — (1 << 4) ^ 0xC3 = 16 ^ 195 = 211
// Expected exit code: 211
//
// Shift-then-XOR mix. 1 << 4 = 16; 16 ^ 195 = 211 (0xD3). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s50_crypto_shr_extract (15)
// and s49_crypto_shl_xor (211).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 195;          // 0xC3
    x: u64 = a << b;       // 16
    r: u64 = x ^ c;        // 0xD3 = 211
    return r;
}
