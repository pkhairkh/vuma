// crypto2_gray.vuma — Gray code of 7 = 7 ^ (7 >> 1) = 7 ^ 3 = 4
// Expected exit code: 4
//
// The binary-reflected Gray code of n is n ^ (n >> 1). Gray codes are
// used in K-maps, rotary encoders, and any setting where single-bit
// transitions between consecutive values matter. gray(7) = 7 ^ 3 = 4.
//
// Note: an earlier draft of the task header listed the exit code as 5
// but the description said "Gray code of 7" — 7^3 is 4, not 5, so the
// exit code is 4. (gray(6)=5 is exercised by the existing
// crypto_gray_code.vuma test.)
//
// VUMA codegen workaround: the shift amount is loaded into a named
// variable (immediate RHS of a bitwise op would be dropped).

fn main() -> i32 {
    n: u64 = 7;
    one: u64 = 1;
    shifted: u64 = n >> one;       // 3
    gray: u64 = n ^ shifted;       // 7 ^ 3 = 4
    return gray;
}
