// s62_crypto_shr_extract.vuma — 0xB0 >> 4 = 0x0B = 11
// Expected exit code: 11
// 
// Shift the high-nibble constant 0xB0 right by 4 to extract the
// nibble into the low position. 176 >> 4 = 11 (0x0B). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s51_crypto_shl_mask (176), s58_crypto_
// shr_extract (12) and s55_crypto_shr_extract (12).

fn main() -> i32 {
    a: u64 = 176;          // 0xB0
    b: u64 = 4;
    r: u64 = a >> b;       // 0x0B = 11
    return r;
}
