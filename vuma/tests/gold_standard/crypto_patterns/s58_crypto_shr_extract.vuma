// s58_crypto_shr_extract.vuma — 0xC0 >> 4 = 0x0C = 12
// Expected exit code: 12
// 
// Shift the high-nibble constant 0xC0 right by 4 to extract the
// nibble into the low position. 192 >> 4 = 12 (0x0C). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s51_crypto_xor_pair (85), s51_crypto_
// shl_mask (176) and s51_crypto_and_then_xor (195).

fn main() -> i32 {
    a: u64 = 192;          // 0xC0
    b: u64 = 4;
    r: u64 = a >> b;       // 0x0C = 12
    return r;
}
