// s73_crypto_and_then_or.vuma — (0xF0 & 0x33) | 0x08 = 0x30 | 0x08 = 0x38 = 56
// Expected exit code: 56
//
// Two-stage crypto op: AND then OR. (240 & 51) = 48 (0x30);
// 48 | 8 = 56 (0x38). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_crypto_xor_then_and (99), s69_crypto_and_then_xor
// (159) and s66_crypto_or_mask (253).
fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 51;           // 0x33
    c: u64 = 8;            // 0x08
    x: u64 = a & b;        // 0x30 = 48
    r: u64 = x | c;        // 0x38 = 56
    return r;
}
