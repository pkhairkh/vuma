// s21_crypto_xor_pair.vuma — 0x5A ^ 0xA5 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR with complementary nibbles. (90 ^ 165) = 255 (0xFF).
// The key is loaded into a variable first to dodge the immediate-RHS
// bitwise drop bug. Distinct from s18_crypto_xor_pair (0xA5 ^ 0x3C = 153)
// and s14_crypto_xor_two_keys (three-way XOR).

fn main() -> i32 {
    v: u64 = 90;          // 0x5A
    k: u64 = 165;         // 0xA5
    r: u64 = v ^ k;       // 0xFF = 255
    return r;
}
