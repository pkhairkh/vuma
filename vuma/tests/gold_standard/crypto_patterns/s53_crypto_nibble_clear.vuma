// s53_crypto_nibble_clear.vuma — 0xD7 & 0xF0 = 0xD0 = 208
// Expected exit code: 208
//
// Mask off the low nibble to clear it. 215 (0xD7) & 240 (0xF0) =
// 208 (0xD0). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s49_crypto_nibble_clear (160) and s50_crypto_high_nibble (160).

fn main() -> i32 {
    a: u64 = 215;          // 0xD7
    b: u64 = 240;          // 0xF0
    r: u64 = a & b;        // 0xD0 = 208
    return r;
}
