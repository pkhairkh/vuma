// s54_crypto_nibble_clear.vuma — 0xF7 & 0x0F = 0x07 = 7
// Expected exit code: 7
//
// Clear the high nibble. 247 & 15 = 7 (0x07). All operands loaded
// into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s50_crypto_high_nibble (240) and
// s49_crypto_nibble_clear (7).

fn main() -> i32 {
    a: u64 = 247;          // 0xF7
    b: u64 = 15;           // 0x0F
    r: u64 = a & b;        // 0x07 = 7
    return r;
}
