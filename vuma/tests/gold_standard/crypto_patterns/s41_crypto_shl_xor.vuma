// s41_crypto_shl_xor.vuma - (1 << 6) ^ 0x0B = 64 ^ 11 = 75
// Expected exit code: 75
//
// Shift-then-XOR mixing step. (1 << 6) = 64 (0x40); 64 ^ 11 = 75
// (0x4B). All operands loaded into u64 variables first (immediate-
// RHS bitwise drop bug workaround). Distinct from s38_crypto_shl_
// xor ((1<<5)^5 = 37) and s34_crypto_shl_then_xor.

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 6;
    c: u64 = 11;           // 0x0B
    s: u64 = a << b;       // 64
    r: u64 = s ^ c;        // 75
    return r;
}
