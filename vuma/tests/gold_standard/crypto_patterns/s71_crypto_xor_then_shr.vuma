// s71_crypto_xor_then_shr.vuma — (0xA5 ^ 0x3C) >> 2 = 0x99 >> 2 = 0x26 = 38
// Expected exit code: 38
//
// Two-stage crypto op: XOR then shift right. (165 ^ 60) = 153
// (0x99); 153 >> 2 = 38 (0x26). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s69_crypto_xor_pair (163), s70_crypto_shr_xor
// (99) and s66_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 60;           // 0x3C
    s: u64 = 2;
    x: u64 = a ^ b;        // 0x99 = 153
    r: u64 = x >> s;       // 0x26 = 38
    return r;
}
