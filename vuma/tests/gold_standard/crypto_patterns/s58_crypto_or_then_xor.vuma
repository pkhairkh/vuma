// s58_crypto_or_then_xor.vuma — (0xF0 | 0x0F) ^ 0x80 = 0xFF ^ 0x80 = 0x7F = 127
// Expected exit code: 127
// 
// Two-stage crypto mix: OR the nibble masks to build 0xFF, then XOR
// the high bit to flip it. (240 | 15) = 255 (0xFF); 255 ^ 128 =
// 127 (0x7F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from s51_
// crypto_xor_pair (85), s51_crypto_shl_mask (176) and s51_crypto_
// and_then_xor (195).

fn main() -> i32 {
    a: u64 = 240;          // 0xF0
    b: u64 = 15;           // 0x0F
    c: u64 = 128;          // 0x80
    x: u64 = a | b;        // 0xFF = 255
    r: u64 = x ^ c;        // 0x7F = 127
    return r;
}
