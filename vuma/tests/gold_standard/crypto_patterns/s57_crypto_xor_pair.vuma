// s57_crypto_xor_pair.vuma — 0x33 ^ 0xCC = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 51 ^ 204 = 255 (0xFF). Complement-style pair
// (0x33 / 0xCC are bitwise complements within a byte) produces an
// all-ones bit pattern. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s54_crypto_xor_pair (0x5A ^ 0xA5 = 255) and s50_crypto_xor_pair
// (0x3C ^ 0xC3 = 255).

fn main() -> i32 {
    a: u64 = 51;           // 0x33
    b: u64 = 204;          // 0xCC
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
