// s45_crypto_xor_pair.vuma — 0x99 ^ 0x66 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 153 ^ 102 = 255 (0xFF). Complement-style pair
// produces an all-ones bit pattern. All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s42_crypto_xor_pair (0xC3 ^ 0x3C = 0xFF) and s38_
// crypto_xor_pair (0xA5 ^ 0x3C = 0x99 = 153).

fn main() -> i32 {
    a: u64 = 153;          // 0x99
    b: u64 = 102;          // 0x66
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
