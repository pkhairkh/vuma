// s71_crypto_or_then_and.vuma — (0x55 | 0x88) & 0xF0 = 0xDD & 0xF0 = 0xD0 = 208
// Expected exit code: 208
//
// Two-stage crypto op: OR then AND. (85 | 136) = 221 (0xDD);
// 221 & 240 = 208 (0xD0). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s69_crypto_and_then_xor (159), s70_crypto_xor_then_and (99) and
// s66_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 85;           // 0x55
    b: u64 = 136;          // 0x88
    m: u64 = 240;          // 0xF0
    x: u64 = a | b;        // 0xDD = 221
    r: u64 = x & m;        // 0xD0 = 208
    return r;
}
