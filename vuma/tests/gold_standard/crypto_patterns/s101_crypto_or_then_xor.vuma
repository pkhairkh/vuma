// s101_crypto_or_then_xor.vuma — (0xA0 | 0x0A) ^ 0x05 = 0xAA ^ 0x05 = 0xAF = 175
// Expected exit code: 175
//
// Two-stage crypto mix: OR then XOR. (160 | 10) = 170 (0xAA);
// 170 ^ 5 = 175 (0xAF). All operands loaded into u32 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s98_crypto_shl_then_or (41), s97_crypto_or_then_shl (53) and
// s94_crypto_or_then_and (48).
fn main() -> i32 {
    a: u32 = 160;          // 0xA0
    b: u32 = 10;           // 0x0A
    c: u32 = 5;            // 0x05
    x: u32 = a | b;        // 0xAA = 170
    r: u32 = x ^ c;        // 0xAF = 175
    return r;
}
