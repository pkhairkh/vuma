// s68_crypto_and_then_or.vuma — (0x3C & 0x0F) | 0x50 = 0x0C | 0x50 = 0x5C = 92
// Expected exit code: 92
//
// AND then OR. (60 & 15) = 12 (0x0C); 12 | 80 = 92 (0x5C). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s66_crypto_or_mask (253),
// s62_crypto_or_then_and (170) and s58_crypto_shl_mask (192).
fn main() -> i32 {
    a: u64 = 60;           // 0x3C
    b: u64 = 15;           // 0x0F
    c: u64 = 80;           // 0x50
    x: u64 = a & b;        // 0x0C = 12
    r: u64 = x | c;        // 0x5C = 92
    return r;
}
