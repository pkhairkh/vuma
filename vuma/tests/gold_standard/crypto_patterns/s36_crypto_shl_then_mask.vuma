// s36_crypto_shl_then_mask.vuma — (0x05 << 4) & 0xF0 = 0x50 = 80
// Expected exit code: 80
//
// Shift a nibble into the high position, then mask to
// isolate it. (5 << 4) & 0xF0 = 0x50 = 80. All operands
// loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround).
// Distinct from s30_crypto_shl_then_mask (shl-then-mask, 0) and s27_crypto_shl_mask (different values).

fn main() -> i32 {
    a: u64 = 5;            // 0x05
    b: u64 = 4;
    m: u64 = 240;          // 0xF0
    x: u64 = a << b;       // 0x50 = 80
    r: u64 = x & m;        // 0x50 = 80
    return r;
}
