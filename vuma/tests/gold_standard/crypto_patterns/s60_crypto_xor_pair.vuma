// s60_crypto_xor_pair.vuma — 0xA5 ^ 0x3C = 0x99 = 153
// Expected exit code: 153
//
// Two-byte XOR. 165 ^ 60 = 153 (0x99). Non-complementary-bit pair
// (0xA5 / 0x3C) produces the 0x99 pattern. All operands loaded
// into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s58_crypto_xor_pair (255) and
// s57_crypto_xor_pair (255).

fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 60;           // 0x3C
    r: u64 = a ^ b;        // 0x99 = 153
    return r;
}
