// s7_crypto_shift_mask.vuma — (0xFF >> 4) & 0x07 = 0x0F & 0x07 = 0x07 = 7
// Expected exit code: 7
//
// Shift 0xFF right by 4 to get 0x0F, then mask with 0x07 to keep
// only the low 3 bits -> 0x07 = 7. All operands loaded into
// variables first to dodge the immediate-RHS bitwise drop bug.
// Distinct from s5_crypto_rotate_left_4 (rotate, not shift+mask)
// and s5_bit_shr_mask (different shift and mask values, bitwise
// category).

fn main() -> i32 {
    v: u64 = 255;    // 0xFF
    sh: u64 = 4;
    mask: u64 = 7;   // 0x07
    shifted: u64 = v >> sh;     // 0x0F = 15
    r: u64 = shifted & mask;    // 0x07 = 7
    return r;
}
