// s12_crypto_or_low_high.vuma — (0x0F << 4) | 0x05 = 0xF0 | 0x05 = 245
// Expected exit code: 245
//
// Compose a byte from two nibbles: high nibble 0x0F shifted into
// position 4-7, OR'd with low nibble 0x05. (0x0F << 4) = 0xF0 = 240;
// 240 | 5 = 245 (0xF5). All operands loaded into u64 variables first.
// Distinct from s12_crypto_nibble_swap (decomposes a byte) and
// s6_bit_or_chain_3 (pure OR chain, no shift).

fn main() -> i32 {
    hi_nib: u64 = 15;     // 0x0F
    lo_nib: u64 = 5;      // 0x05
    sh: u64 = 4;
    hi: u64 = hi_nib << sh;  // 0xF0 = 240
    r: u64 = hi | lo_nib;    // 0xF5 = 245
    return r;
}
