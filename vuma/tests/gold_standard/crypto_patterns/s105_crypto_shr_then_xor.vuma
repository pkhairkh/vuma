// s105_crypto_shr_then_xor.vuma — (0xE0 >> 2) ^ 0x80 = 0x38 ^ 0x80 = 0xB8 = 184
// Expected exit code: 184
// 
// Two-stage crypto mix: shift-right then XOR. (224 >> 2) = 56 (0x38); 56 ^ 128 = 184 (0xB8). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Operands nonzero & distinct.
// Distinct from s102_crypto_shr_then_xor (59), s101_crypto_shr_then_and (25), s100_crypto_shr_then_xor (57).
fn main() -> i32 {
    a: u32 = 224;          // 0xE0
    n: u32 = 2;
    c: u32 = 128;          // 0x80
    s: u32 = a >> n;       // 0x38 = 56
    r: u32 = s ^ c;        // 0xB8 = 184
    return r;
}
