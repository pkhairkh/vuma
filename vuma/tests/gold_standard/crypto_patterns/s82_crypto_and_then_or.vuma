// s82_crypto_and_then_or.vuma — (0x66 & 0x3C) | 0x01 = 0x24 | 0x01 = 0x25 = 37
// Expected exit code: 37
//
// Two-stage crypto-style bitwise: AND then OR. (102 & 60) =
// 36 (0x24); 36 | 1 = 37 (0x25). All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_crypto_or_then_xor (9),
// s74_crypto_and_then_or (60) and s72_crypto_or_then_and (120).
fn main() -> i32 {
    a: u64 = 102;          // 0x66
    b: u64 = 60;           // 0x3C
    c: u64 = 1;            // 0x01
    x: u64 = a & b;        // 0x24 = 36
    r: u64 = x | c;        // 0x25 = 37
    return r;
}
