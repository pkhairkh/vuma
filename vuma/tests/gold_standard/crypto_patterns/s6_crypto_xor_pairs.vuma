// s6_crypto_xor_pairs.vuma — 0xAB ^ 0xCD = 0x66 = 102
// Expected exit code: 102
//
// Two-byte XOR: 171 (0xAB) ^ 205 (0xCD) = 102 (0x66). All operands
// loaded into variables first. Distinct from s5_crypto_xor_two_bytes
// (different operand pair) and s5_crypto_parity_xor.

fn main() -> i32 {
    a: u64 = 171;   // 0xAB
    b: u64 = 205;   // 0xCD
    r: u64 = a ^ b; // 0x66 = 102
    return r;
}
