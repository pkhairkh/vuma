// s12_crypto_xor_pair_complement.vuma — 0xAA ^ 0x55 ^ 0xFF = 0xFF ^ 0xFF = 0
// Expected exit code: 0
//
// XOR of complementary bit patterns (0xAA ^ 0x55) yields 0xFF (all
// ones); XORing with 0xFF again cancels to 0. Tests the XOR identity
// x ^ ~x = all-ones and ~all-ones = 0. All operands loaded into u64
// variables first. Distinct from s7_crypto_xor_self_zero (a^a=0) and
// s9_crypto_xor_with_key (two-operand XOR to all-ones).

fn main() -> i32 {
    a: u64 = 170;         // 0xAA
    b: u64 = 85;          // 0x55
    c: u64 = 255;         // 0xFF
    t: u64 = a ^ b;       // 0xFF
    r: u64 = t ^ c;       // 0x00 = 0
    return r;
}
