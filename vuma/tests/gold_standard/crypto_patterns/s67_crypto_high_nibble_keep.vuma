// s67_crypto_high_nibble_keep.vuma — 0xE7 & 0xF0 = 0xE0 = 224
// Expected exit code: 224
//
// Mask the byte 0xE7 with 0xF0 to keep only the high nibble.
// 231 & 240 = 224 (0xE0). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s66_crypto_or_mask (253), s62_crypto_or_then_
// and (170) and s58_crypto_or_then_xor (127).
fn main() -> i32 {
    a: u64 = 231;          // 0xE7
    m: u64 = 240;          // 0xF0
    r: u64 = a & m;        // 0xE0 = 224
    return r;
}
