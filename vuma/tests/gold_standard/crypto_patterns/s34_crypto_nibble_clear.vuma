// s34_crypto_nibble_clear.vuma — 0xAB & 0x0F = 0x0B = 11 (clear high nibble)
// Expected exit code: 11
//
// Clear-high-nibble mask. 171 & 15 = 11 (0x0B). All operands loaded
// into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s30_crypto_nibble_clear (different
// values) and s27_crypto_high_nibble_keep (keep-high).

fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 15;           // 0x0F
    r: u64 = a & b;        // 0x0B = 11
    return r;
}
