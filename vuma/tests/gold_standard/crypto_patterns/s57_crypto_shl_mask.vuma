// s57_crypto_shl_mask.vuma — (7 << 2) & 0x55 = 28 & 85 = 20
// Expected exit code: 20
//
// Two-stage crypto-pattern: shift then mask. 7 << 2 = 28 (0x1C);
// 28 & 0x55 = 20 (0x14). Mask 0x55 = 0b01010101 keeps every other
// bit. All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s54_crypto_shl_xor
// (211) and s50_crypto_shr_extract (15).

fn main() -> i32 {
    a: u64 = 7;
    b: u64 = 2;
    c: u64 = 85;           // 0x55
    x: u64 = a << b;       // 28
    r: u64 = x & c;        // 20
    return r;
}
