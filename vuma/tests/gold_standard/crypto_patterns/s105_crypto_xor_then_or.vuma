// s105_crypto_xor_then_or.vuma — (0x80 ^ 0x20) | 0x01 = 0xA0 | 0x01 = 0xA1 = 161
// Expected exit code: 161
// 
// Two-stage crypto mix: XOR then OR. (128 ^ 32) = 160 (0xA0); 160 | 1 = 161 (0xA1). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround). Operands nonzero & distinct.
// Distinct from s102_crypto_xor_then_and (55), s101_crypto_xor_then_or (241), s100_crypto_and_then_xor (54).
fn main() -> i32 {
    a: u32 = 128;          // 0x80
    b: u32 = 32;           // 0x20
    c: u32 = 1;            // 0x01
    x: u32 = a ^ b;        // 0xA0 = 160
    r: u32 = x | c;        // 0xA1 = 161
    return r;
}
