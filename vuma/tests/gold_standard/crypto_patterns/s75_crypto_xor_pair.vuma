// s75_crypto_xor_pair.vuma — 0xC9 ^ 0x5A = 0x93 = 147
// Expected exit code: 147
//
// Two-byte XOR. 201 ^ 90 = 147 (0x93). Mid-bit pair (0xC9 / 0x5A)
// produces the byte 0x93. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s74_crypto_xor_pair (156), s70_crypto_xor_pair (42) and
// s66_crypto_xor_pair (249).
fn main() -> i32 {
    a: u64 = 201;          // 0xC9
    b: u64 = 90;           // 0x5A
    r: u64 = a ^ b;        // 0x93 = 147
    return r;
}
