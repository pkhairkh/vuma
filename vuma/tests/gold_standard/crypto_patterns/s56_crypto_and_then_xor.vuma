// s56_crypto_and_then_xor.vuma — (0xF8 & 0x7E) ^ 0x03 = 0x78 ^ 0x03 = 123
// Expected exit code: 123
//
// AND-then-XOR mix. 248 & 126 = 120 (0x78); 120 ^ 3 = 123 (0x7B).
// All operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s54_crypto_nibble_clear (7) and
// s50_crypto_high_nibble (240).

fn main() -> i32 {
    a: u64 = 248;          // 0xF8
    b: u64 = 126;          // 0x7E
    c: u64 = 3;            // 0x03
    x: u64 = a & b;        // 0x78 = 120
    r: u64 = x ^ c;        // 0x7B = 123
    return r;
}
