// s78_crypto_xor_then_shr.vuma — (0x00 ^ 0x01) >> 0 = 0x01 >> 0 = 0x01 = 1
// Expected exit code: 1
//
// Two-stage crypto op: XOR then shift right. (0 ^ 1) = 1
// (0x01); 1 >> 0 = 1 (0x01). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s74_crypto_xor_then_shr (39),
// s73_crypto_shl_then_xor (65) and s72_crypto_xor_then_and (50).
fn main() -> i32 {
    a: u64 = 0;            // 0x00
    b: u64 = 1;            // 0x01
    c: u64 = 0;
    x: u64 = a ^ b;        // 0x01 = 1
    r: u64 = x >> c;       // 0x01 = 1
    return r;
}
