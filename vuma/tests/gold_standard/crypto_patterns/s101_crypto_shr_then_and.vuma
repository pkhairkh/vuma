// s101_crypto_shr_then_and.vuma — (200 >> 3) & 0x1F = 25 & 0x1F = 25
// Expected exit code: 25
//
// Two-stage crypto mix: shift-right then AND. 200 >> 3 = 25;
// 25 & 31 = 25 (low-5-bit extract). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s98_crypto_and_then_xor (42),
// s97_crypto_shr_then_xor (67) and s94_crypto_and_then_shr (30).
fn main() -> i32 {
    a: u32 = 200;
    s: u32 = 3;
    b: u32 = 31;           // 0x1F
    x: u32 = a >> s;       // 25
    r: u32 = x & b;        // 0x19 = 25
    return r;
}
