// s42_crypto_nibble_clear.vuma — 0xAB & 0x0F = 0x0B = 11
// Expected exit code: 11
//
// Mask off the high nibble. 171 & 15 = 11. All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s38_crypto_nibble_clear and s34_crypto_nibble_clear.

fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    m: u64 = 15;           // 0x0F
    r: u64 = a & m;        // 0x0B = 11
    return r;
}
