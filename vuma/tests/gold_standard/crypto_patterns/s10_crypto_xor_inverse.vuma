// s10_crypto_xor_inverse.vuma — 0xAA ^ 0x55 ^ 0xAA = 0x55 = 85
// Expected exit code: 85
//
// XOR is its own inverse. 170 ^ 85 = 255 (0xFF); 255 ^ 170 = 85 (0x55).
// The first and third operands are equal, so they cancel. All operands
// loaded into u64 variables first. Distinct from s6_crypto_xor_chain_3
// (three distinct operands) and s6_crypto_xor_pairs (two operands).

fn main() -> i32 {
    a: u64 = 170;         // 0xAA
    b: u64 = 85;          // 0x55
    c: u64 = 170;         // 0xAA (same as a)
    t1: u64 = a ^ b;      // 0xFF
    r: u64 = t1 ^ c;      // 0x55 = 85
    return r;
}
