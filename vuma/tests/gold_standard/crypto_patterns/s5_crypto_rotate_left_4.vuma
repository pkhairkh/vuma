// s5_crypto_rotate_left_4.vuma — rotate 0x2B left by 4 = 0xB2 = 178
// Expected exit code: 178
//
// Rotate left by 4 of an 8-bit value 0x2B (43). High nibble 0x2
// moves to low, low nibble 0xB moves to high -> 0xB2 = 178.
// Computed as ((v << 4) | (v >> 4)) & 0xFF. All operands loaded
// into variables first.

fn main() -> i32 {
    v: u64 = 43;       // 0x2B
    four: u64 = 4;
    mask: u64 = 255;   // 0xFF
    hi_part: u64 = v << four;           // 0x2B0
    lo_part: u64 = v >> four;           // 0x02
    combined: u64 = hi_part | lo_part;  // 0x2B2
    r: u64 = combined & mask;           // 0xB2 = 178
    return r;
}
