// s98_crypto_and_then_xor.vuma — (0xF0 & 0x70) ^ 0x5A = 0x70 ^ 0x5A = 0x2A = 42
// Expected exit code: 42
//
// Two-stage crypto-style bitwise: AND then XOR. (240 & 112) = 112
// (0x70); 112 ^ 90 = 42 (0x2A). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s94_crypto_and_then_shr (30),
// s90_crypto_and_then_xor (27) and s86_crypto_and_then_xor (63).
fn main() -> i32 {
    a: u64 = 240;         // 0xF0
    b: u64 = 112;         // 0x70
    c: u64 = 90;          // 0x5A
    x: u64 = a & b;       // 0x70 = 112
    r: u64 = x ^ c;       // 0x2A = 42
    return r;
}
