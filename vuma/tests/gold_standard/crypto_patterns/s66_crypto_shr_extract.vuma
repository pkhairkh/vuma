// s66_crypto_shr_extract.vuma — (0xAB >> 4) & 0x0F = 0x0A = 10
// Expected exit code: 10
//
// Shift the high-nibble constant 0xAB right by 4 then mask 0x0F
// to extract the high nibble. (171 >> 4) = 10; 10 & 15 = 10. All
// operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s62_crypto_shr_
// extract (11), s58_crypto_shr_extract (12) and s55_crypto_shr_
// extract (15).
fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 4;
    m: u64 = 15;           // 0x0F
    x: u64 = a >> b;       // 0x0A = 10
    r: u64 = x & m;        // 0x0A = 10
    return r;
}
