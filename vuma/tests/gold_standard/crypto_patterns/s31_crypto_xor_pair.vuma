// s31_crypto_xor_pair.vuma — 0x6A ^ 0x19 = 0x73 = 115
// Expected exit code: 115
//
// Two-byte XOR. 106 ^ 25 = 115 (0x73). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround). Distinct
// from s30_crypto_xor_pair (0xC3 ^ 0x3C = 0xFF) and s28_crypto_xor_pair
// (0xA5 ^ 0x5A = 0xFF).

fn main() -> i32 {
    a: u64 = 106;         // 0x6A
    b: u64 = 25;          // 0x19
    r: u64 = a ^ b;       // 0x73 = 115
    return r;
}
