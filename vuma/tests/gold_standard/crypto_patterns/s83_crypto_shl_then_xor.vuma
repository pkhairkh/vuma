// s83_crypto_shl_then_xor.vuma — (1 << 7) ^ 0x1E = 0x80 ^ 0x1E = 0x9E = 158
// Expected exit code: 158
//
// Two-stage crypto-style bitwise: shift left then XOR.
// (1 << 7) = 128 (0x80); 128 ^ 30 = 158 (0x9E). All operands
// loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s78_crypto_shl_then_and (3),
// s74_crypto_shl_then_xor (98) and s72_crypto_shl_pair (204).
fn main() -> i32 {
    a: u64 = 1;            // 0x01
    b: u64 = 7;            // shift amount
    c: u64 = 30;           // 0x1E
    x: u64 = a << b;       // 0x80 = 128
    r: u64 = x ^ c;        // 0x9E = 158
    return r;
}
