// s39_crypto_xor_pair.vuma — 0x99 ^ 0x55 = 0xCC = 204
// Expected exit code: 204
//
// Two-byte XOR. 153 ^ 85 = 204 (0xCC). Non-complement pair produces
// a mixed bit pattern. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_crypto_xor_pair (0xA5 ^ 0x3C = 0x99 = 153) and s34_crypto_
// xor_pair (0x96 ^ 0x69 = 0xFF).

fn main() -> i32 {
    a: u64 = 153;          // 0x99
    b: u64 = 85;           // 0x55
    r: u64 = a ^ b;        // 0xCC = 204
    return r;
}
