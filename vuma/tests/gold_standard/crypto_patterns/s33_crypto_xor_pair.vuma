// s33_crypto_xor_pair.vuma — 0xA5 ^ 0x3C = 0x99 = 153, | 0x40 = 0xD9 = 217
// Expected exit code: 217
//
// Deterministic test in the crypto_patterns category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_crypto_xor_pair (0xC3^0x3C=255) and s26_crypto_xor_pair (0xA5^0x5A=255).
fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 60;           // 0x3C
    c: u64 = 64;           // 0x40
    x: u64 = a ^ b;        // 0x99 = 153
    r: u64 = x | c;        // 0xD9 = 217
    return r;
}
