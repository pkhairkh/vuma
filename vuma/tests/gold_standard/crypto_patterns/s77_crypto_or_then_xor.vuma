// s77_crypto_or_then_xor.vuma — (0xAA | 0x44) ^ 0x08 = 0xEE ^ 0x08 = 0xE6 = 230
// Expected exit code: 230
//
// Two-stage crypto op: OR then XOR. 170 | 68 = 238 (0xEE);
// 238 ^ 8 = 230 (0xE6). All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct
// from s70_crypto_xor_pair (42), s66_crypto_or_mask (180) and
// s74_crypto_xor_then_and (203).

fn main() -> i32 {
    a: u64 = 170;          // 0xAA
    b: u64 = 68;           // 0x44
    c: u64 = 8;            // 0x08
    x: u64 = a | b;        // 0xEE = 238
    r: u64 = x ^ c;        // 0xE6 = 230
    return r;
}
