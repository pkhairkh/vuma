// s15_crypto_shl_xor_mask.vuma — ((0x05 << 4) ^ 0x33) = 0x63 = 99
// Expected exit code: 99
//
// Two-stage crypto-style mix. (5 << 4) = 80 (0x50); 80 ^ 51 = 99 (0x63).
// All operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s14_crypto_shl_then_xor (shl-then-XOR,
// different operands) and s8_crypto_rotate_left_3 (rotate framing).

fn main() -> i32 {
    v: u64 = 5;           // 0x05
    sh: u64 = 4;
    k: u64 = 51;          // 0x33
    x: u64 = v << sh;     // 0x50 = 80
    r: u64 = x ^ k;       // 0x63 = 99
    return r;
}
