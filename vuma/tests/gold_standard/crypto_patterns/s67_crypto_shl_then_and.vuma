// s67_crypto_shl_then_and.vuma — (0x07 << 4) & 0x60 = 0x70 & 0x60 = 0x60 = 96
// Expected exit code: 96
//
// Shift the low-nibble constant 0x07 left by 4 then mask 0x60
// to keep the upper bits. (7 << 4) = 112 (0x70); 112 & 96 =
// 96 (0x60). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s66_crypto_shr_extract (10), s62_crypto_shl_mask (16) and
// s58_crypto_shr_extract (12).
fn main() -> i32 {
    a: u64 = 7;            // 0x07
    b: u64 = 4;
    m: u64 = 96;           // 0x60
    x: u64 = a << b;       // 0x70 = 112
    r: u64 = x & m;        // 0x60 = 96
    return r;
}
