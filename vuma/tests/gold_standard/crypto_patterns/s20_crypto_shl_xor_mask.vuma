// s20_crypto_shl_xor_mask.vuma — (0x0B << 3) ^ 0x21 = 0x58 ^ 0x21 = 0x79 = 121
// Expected exit code: 121
//
// Shift-left, then XOR with a key byte. (11 << 3) = 88 (0x58); 88 ^ 33
// = 121 (0x79). All operands loaded into u64 variables first. Distinct
// from s18_crypto_shl_mask (shl-then-mask, no XOR) and
// s17_crypto_rotate_left_3 (rotation).

fn main() -> i32 {
    a: u64 = 11;          // 0x0B
    sh: u64 = 3;
    k: u64 = 33;          // 0x21
    x: u64 = a << sh;     // 0x58 = 88
    r: u64 = x ^ k;       // 0x79 = 121
    return r;
}
