// crypto2_byte_swap.vuma — extract the byte that ends up at the high
// position after swapping the bytes of 0x12345678 (= 0x78)
// Expected exit code: 120  (0x78)
//
// A true byte swap of 0x12345678 reverses the byte order to
// 0x78563412. The byte that ends up in the HIGH position of the
// swapped value is the original LOW byte of the input — that is,
// 0x78. Exit codes are 0..255 so we cannot return the full 32-bit
// swapped word; we return the byte that moves to the high position
// (0x78 = 120). The full byte decomposition (b0..b3) is computed
// explicitly to demonstrate the swap structure.
//
// VUMA codegen workaround: every mask and every shift amount is
// loaded into a named variable (immediate RHS of a bitwise op would
// be dropped).

fn main() -> i32 {
    val: u64 = 0x12345678;
    mFF: u64 = 0xFF;
    eight: u64 = 8;
    sixteen: u64 = 16;
    twentyfour: u64 = 24;
    // Decompose input into 4 bytes (little-endian byte numbering).
    s1: u64 = val >> eight;          // 0x123456
    s2: u64 = val >> sixteen;        // 0x1234
    s3: u64 = val >> twentyfour;     // 0x12
    b0: u64 = val & mFF;             // 0x78 (low byte)
    b1: u64 = s1 & mFF;              // 0x56
    b2: u64 = s2 & mFF;              // 0x34
    b3: u64 = s3 & mFF;              // 0x12
    // After a byte swap, b0 moves to the high position. Return it.
    return b0;
}
