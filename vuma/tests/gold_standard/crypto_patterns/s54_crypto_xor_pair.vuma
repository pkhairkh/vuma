// s54_crypto_xor_pair.vuma — 0x5A ^ 0xA5 = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 90 ^ 165 = 255 (0xFF). Complement-style pair
// (0x5A / 0xA5 are bitwise complements within a byte) produces an
// all-ones bit pattern. All operands loaded into u64 variables
// first (immediate-RHS bitwise drop bug workaround). Distinct from
// s50_crypto_xor_pair (0x3C ^ 0xC3 = 255) and s49_crypto_xor_pair
// (0x4B ^ 0xB4 = 255).

fn main() -> i32 {
    a: u64 = 90;           // 0x5A
    b: u64 = 165;          // 0xA5
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
