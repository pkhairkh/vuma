// s9_crypto_xor_with_key.vuma — 0x55 ^ 0xAA = 0xFF = 255
// Expected exit code: 255
//
// Plaintext byte 0x55 (85) XORed with key byte 0xAA (170) yields
// 0xFF (255). Complementary-bit pattern XOR to all-ones. All
// operands loaded into variables first to dodge the immediate-RHS
// bitwise drop bug. Distinct from s6_crypto_xor_pairs (0xAB ^ 0xCD).

fn main() -> i32 {
    a: u64 = 85;      // 0x55
    b: u64 = 170;     // 0xAA
    r: u64 = a ^ b;   // 0xFF = 255
    return r;
}
