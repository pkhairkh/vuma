// crypto_nibble_swap.vuma — swap nibbles of 0xF0 -> 0x0F
// Expected exit code: 15 (0x0F)
//
// Nibble-swap (4-bit half-byte rotation) is used in some hash and
// permutation primitives. For an 8-bit value 0xF0, swapping the high
// and low nibbles yields 0x0F. Computed by isolating each nibble with
// a mask, shifting the high nibble right by 4, shifting the low nibble
// left by 4, and ORing the results. All masks and shift amounts are
// loaded into named variables per the bitwise-immediate-RHS workaround.

fn main() -> i32 {
    v: u64 = 0xF0;
    four: u64 = 4;
    mLow: u64 = 0x0F;
    mHigh: u64 = 0xF0;
    low: u64 = v & mLow;           // 0x00
    high: u64 = v & mHigh;         // 0xF0
    highShr: u64 = high >> four;   // 0x0F
    lowShl: u64 = low << four;     // 0x00
    result: u64 = highShr | lowShl; // 0x0F
    return result;
}
