// s82_crypto_xor_then_and.vuma — (0xC3 ^ 0x3C) & 0x55 = 0xFF & 0x55 = 0x55 = 85
// Expected exit code: 85
//
// Two-stage crypto-style bitwise: XOR then AND. (195 ^ 60) =
// 255 (0xFF); 255 & 85 = 85 (0x55). All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug
// workaround). Distinct from s78_crypto_xor_then_shr (1),
// s74_crypto_xor_then_and (98) and s72_crypto_xor_pair (204).
fn main() -> i32 {
    a: u64 = 195;          // 0xC3
    b: u64 = 60;           // 0x3C
    c: u64 = 85;           // 0x55
    x: u64 = a ^ b;        // 0xFF = 255
    r: u64 = x & c;        // 0x55 = 85
    return r;
}
