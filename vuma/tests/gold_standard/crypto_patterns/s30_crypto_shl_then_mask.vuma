// s30_crypto_shl_then_mask.vuma — (1 << 6) & 0x7F = 0x40 & 0x7F = 0x40 = 64
// Expected exit code: 64
//
// Two-stage crypto op: SHL then mask. (1 << 6) = 64 (0x40); 64 & 127 =
// 64 (0x40). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s26_crypto_shl_then_mask (16) and s22_crypto_shl_mask_high (shl-mask).

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 6;
    c: u64 = 127;         // 0x7F
    x: u64 = a << b;      // 0x40 = 64
    r: u64 = x & c;       // 0x40 = 64
    return r;
}
