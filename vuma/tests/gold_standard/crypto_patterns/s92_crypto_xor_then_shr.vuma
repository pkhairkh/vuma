// s92_crypto_xor_then_shr.vuma — (0x88 ^ 0x44) >> 2 = 0xCC >> 2 = 0x33 = 51
// Expected exit code: 51
//
// Two-stage crypto mix: XOR then shift-right. (136 ^ 68) = 204
// (0xCC); 204 >> 2 = 51 (0x33). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s90_crypto_xor_then_shr (17), s86_crypto_xor_pair
// (230) and s82_crypto_xor_then_and (130).
fn main() -> i32 {
    a: u32 = 136;          // 0x88
    b: u32 = 68;           // 0x44
    s: u32 = 2;
    x: u32 = a ^ b;        // 0xCC = 204
    r: u32 = x >> s;       // 0x33 = 51
    return r;
}
