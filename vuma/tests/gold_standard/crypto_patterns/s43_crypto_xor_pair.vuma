// s43_crypto_xor_pair.vuma — 0xA5 ^ 0x5A = 0xFF = 255
// Expected exit code: 255
//
// Two-byte XOR. 165 ^ 90 = 255 (0xFF). Complement-style pair
// produces an all-ones bit pattern. All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s42_crypto_xor_pair (0xC3 ^ 0x3C = 255) and
// s38_crypto_xor_pair (0xA5 ^ 0x3C = 153).

fn main() -> i32 {
    a: u64 = 165;          // 0xA5
    b: u64 = 90;           // 0x5A
    r: u64 = a ^ b;        // 0xFF = 255
    return r;
}
