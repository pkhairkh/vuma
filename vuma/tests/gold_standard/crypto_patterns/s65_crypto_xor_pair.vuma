// s65_crypto_xor_pair.vuma — 0xC3 ^ 0x6E = 0xAD = 173
// Expected exit code: 173
//
// Two-byte XOR. 195 ^ 110 = 173 (0xAD). Distinct-bit pair (0xC3 /
// 0x6E) produces the byte pattern 0xAD. All operands loaded into
// u64 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s51_crypto_xor_pair (85), s58_crypto_xor_pair (255)
// and s62_crypto_xor_pair (204).

fn main() -> i32 {
    a: u64 = 195;          // 0xC3
    b: u64 = 110;          // 0x6E
    r: u64 = a ^ b;        // 0xAD = 173
    return r;
}
