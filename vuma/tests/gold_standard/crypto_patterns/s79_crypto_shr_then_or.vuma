// s79_crypto_shr_then_or.vuma — (0x40 >> 1) | 0x01 = 0x20 | 0x01 = 0x21 = 33
// Expected exit code: 33
//
// Two-stage crypto op: shift right then OR. (64 >> 1) = 32
// (0x20); 32 | 1 = 33 (0x21). All operands loaded into u64
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s78_crypto_xor_then_shr (1),
// s77_crypto_shr_then_or (2) and s76_crypto_shr_then_or (3).
fn main() -> i32 {
    a: u64 = 64;           // 0x40
    b: u64 = 1;
    c: u64 = 1;            // 0x01
    x: u64 = a >> b;       // 0x20 = 32
    r: u64 = x | c;        // 0x21 = 33
    return r;
}
