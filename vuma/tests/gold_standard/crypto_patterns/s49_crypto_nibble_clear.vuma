// s49_crypto_nibble_clear.vuma — 0xAB & 0xF0 = 0xA0 = 160
// Expected exit code: 160
//
// Clear the low nibble of a byte. 171 & 240 = 160 (0xA0). All
// operands loaded into u64 variables first (immediate-RHS bitwise
// drop bug workaround). Distinct from s46_crypto_nibble_clear
// (0xCD & 0xF0 = 192) and s42_crypto_nibble_clear (11, different
// mask op).

fn main() -> i32 {
    a: u64 = 171;          // 0xAB
    b: u64 = 240;          // 0xF0
    r: u64 = a & b;        // 0xA0 = 160
    return r;
}
