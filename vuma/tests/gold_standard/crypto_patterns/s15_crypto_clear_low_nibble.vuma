// s15_crypto_clear_low_nibble.vuma — 0xCD & 0xF0 = 0xC0 = 192
// Expected exit code: 192
//
// Mask off the low nibble of 0xCD, leaving 0xC0 = 192. Single AND with a
// high-nibble mask. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s12_crypto_clear_high_nibble (clears the high nibble instead) and
// s14_crypto_low_nibble (extracts the low nibble).

fn main() -> i32 {
    v: u64 = 205;         // 0xCD
    m: u64 = 240;         // 0xF0
    r: u64 = v & m;       // 0xC0 = 192
    return r;
}
