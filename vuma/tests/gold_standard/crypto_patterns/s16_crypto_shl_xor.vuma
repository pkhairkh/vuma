// s16_crypto_shl_xor.vuma — (1 << 4) ^ 0x0F = 16 ^ 15 = 31
// Expected exit code: 31
//
// Shift-left then XOR. (1 << 4) = 16 (0x10); 16 ^ 15 = 31 (0x1F). All
// operands loaded into u64 variables first (immediate-RHS bitwise drop
// bug workaround). Distinct from s14_crypto_shl_then_xor (uses 0x55
// operand, different result) and s11_crypto_xor_then_shl (XOR-then-SHL).

fn main() -> i32 {
    v: u64 = 1;
    sh: u64 = 4;
    k: u64 = 15;           // 0x0F
    l: u64 = v << sh;      // 16
    r: u64 = l ^ k;        // 31
    return r;
}
