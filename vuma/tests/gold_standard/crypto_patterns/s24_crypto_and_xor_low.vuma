// s24_crypto_and_xor_low.vuma — (0xFF & 0x0F) ^ 0x05 = 0x0F ^ 0x05 = 0x0A = 10
// Expected exit code: 10
//
// AND then XOR with a low-nibble mask. (255 & 15) = 15 (0x0F); 15 ^ 5 =
// 10 (0x0A). All operands loaded into u64 variables first (immediate-RHS
// bitwise drop bug workaround). Distinct from s22_crypto_xor_three
// (three-byte xor, value 105) and s14_crypto_or_low_high (or low/high).

fn main() -> i32 {
    a: u64 = 255;         // 0xFF
    b: u64 = 15;          // 0x0F
    c: u64 = 5;           // 0x05
    x: u64 = a & b;       // 0x0F = 15
    r: u64 = x ^ c;       // 0x0A = 10
    return r;
}
