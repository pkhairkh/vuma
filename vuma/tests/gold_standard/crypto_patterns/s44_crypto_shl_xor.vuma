// s44_crypto_shl_xor.vuma — (1 << 4) ^ 0x0F = 16 ^ 15 = 31
// Expected exit code: 31
//
// Two-stage mix: shift left then XOR. (1 << 4) = 16 (0x10);
// 16 ^ 15 = 31 (0x1F). All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s42_crypto_shl_xor (1<<5 ^ 0x0F = 47) and s38_crypto_shl_xor.

fn main() -> i32 {
    a: u64 = 1;
    b: u64 = 4;
    c: u64 = 15;           // 0x0F
    s: u64 = a << b;       // 16
    r: u64 = s ^ c;        // 31
    return r;
}
