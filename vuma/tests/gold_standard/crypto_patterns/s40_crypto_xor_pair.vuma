// s40_crypto_xor_pair.vuma — 0x6C ^ 0x3C = 0x50 = 80
// Expected exit code: 80
//
// Two-byte XOR. 108 ^ 60 = 80 (0x50). Non-complement pair produces
// a mixed bit pattern. All operands loaded into u64 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct from
// s38_crypto_xor_pair (153) and s34_crypto_xor_pair (255).

fn main() -> i32 {
    a: u64 = 108;          // 0x6C
    b: u64 = 60;           // 0x3C
    r: u64 = a ^ b;        // 0x50 = 80
    return r;
}
