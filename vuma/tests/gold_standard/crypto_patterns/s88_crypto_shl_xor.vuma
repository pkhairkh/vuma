// s88_crypto_shl_xor.vuma — (0x07 << 3) ^ 0x20 = 0x38 ^ 0x20 = 0x18 = 24
// Expected exit code: 24
//
// Shift 0x07 left by 3 -> 0x38, then XOR with 0x20 -> 0x18
// = 24. All operands loaded into u32 variables first
// (immediate-RHS bitwise drop bug workaround). Distinct
// from s86_crypto_shl_mask (112), s82_crypto_shl_then_xor
// (65) and s78_crypto_and_then_shl (4).
fn main() -> i32 {
    a: u32 = 7;            // 0x07
    b: u32 = 3;            // shift amount
    c: u32 = 32;           // 0x20
    x: u32 = a << b;       // 0x38 = 56
    r: u32 = x ^ c;        // 0x18 = 24
    return r;
}
