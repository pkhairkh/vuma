// s10_crypto_xor_chain_4.vuma — 0xAB ^ 0xCD ^ 0x12 ^ 0x34 = 0x40 = 64
// Expected exit code: 64
//
// Four-byte XOR chain. 171 ^ 205 = 102 (0x66); 102 ^ 18 = 116 (0x74);
// 116 ^ 52 = 64 (0x40). All operands loaded into u64 variables first.
// Distinct from s6_crypto_xor_chain_3 (three operands) and
// s10_crypto_xor_inverse (self-cancelling pair).

fn main() -> i32 {
    a: u64 = 171;         // 0xAB
    b: u64 = 205;         // 0xCD
    c: u64 = 18;          // 0x12
    d: u64 = 52;          // 0x34
    t1: u64 = a ^ b;      // 0x66 = 102
    t2: u64 = t1 ^ c;     // 0x74 = 116
    r: u64 = t2 ^ d;      // 0x40 = 64
    return r;
}
