// s102_crypto_xor_then_and.vuma — (0x01 ^ 0x36) & 0x37 = 0x37 & 0x37 = 0x37 = 55
// Expected exit code: 55
//
// Two-stage crypto mix: XOR then AND. (1 ^ 54) = 55 (0x37); 55 & 55 = 55 (0x37). All operands loaded into u32 variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s101_crypto_or_then_xor (175), s101_crypto_shr_then_and (25), s101_crypto_xor_then_or (241).
fn main() -> i32 {
    a: u32 = 1;          // 0x01
    b: u32 = 54;          // 0x36
    c: u32 = 55;          // 0x37
    x: u32 = a ^ b;        // 0x37 = 55
    r: u32 = x & c;        // 0x37 = 55
    return r;
}
