// s93_crypto_xor_then_shr.vuma — (0xFF ^ 0xA3) >> 1 = 0x5C >> 1 = 0x2E = 46
// Expected exit code: 46
//
// Two-stage crypto mix: XOR then shift-right. (255 ^ 163) = 92
// (0x5C); 92 >> 1 = 46 (0x2E). All operands loaded into u32
// variables first (immediate-RHS bitwise drop bug workaround).
// Distinct from s90_crypto_xor_then_shr (17), s82_crypto_xor_then_and (85) and s78_crypto_xor_then_shr (1).
fn main() -> i32 {
    a: u32 = 255;          // 0xFF
    b: u32 = 163;          // 0xA3
    s: u32 = 1;
    x: u32 = a ^ b;        // 0x5C = 92
    r: u32 = x >> s;       // 0x2E = 46
    return r;
}
