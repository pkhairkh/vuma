// s83_fn_two_args_sub.vuma — sub(200, 9) = 200 - 9 = 191
// Expected exit code: 191
//
// Helper sub(x, y) = x - y. main calls sub(200, 9) -> 191.
// Two-arg function that subtracts. Distinct from s78_fn_two_
// args_sub (3), s74_fn_two_args_mul (132) and s72_fn_two_args_
// sub (60).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(200, 9);
    return v;
}
