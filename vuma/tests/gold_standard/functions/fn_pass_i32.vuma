// fn_pass_i32.vuma — pass i32 to function, return it
// Expected exit code: 42
//
// Tests passing a 32-bit signed integer parameter and returning it
// unchanged. Verifies i32 parameter passing round-trip.

fn echo_i32(x: i32) -> i32 {
    return x;
}

fn main() -> i32 {
    v: i32 = echo_i32(42);
    return v;
}
