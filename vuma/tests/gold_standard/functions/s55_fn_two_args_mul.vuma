// s55_fn_two_args_mul.vuma — mul(8, 15) = 120
// Expected exit code: 120
//
// Helper mul(x, y) = x * y. main calls mul(8, 15) -> 120. Two-arg
// function returning the product. Distinct from s54_fn_two_args_add
// (125) and s53_fn_two_args_add (195).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(8, 15);
    return v;
}
