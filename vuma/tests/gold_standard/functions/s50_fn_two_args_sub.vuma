// s50_fn_two_args_sub.vuma — sub(150, 65) = 85
// Expected exit code: 85
//
// Helper sub(x, y) = x - y. main calls sub(150, 65) -> 85. Two-arg
// function returning the difference. Distinct from s46_fn_two_args_
// mul (99) and s43_fn_two_args_sub (80).

fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(150, 65);
    return v;
}
