// fn_address_param.vuma — function takes Address param, stores 42, returns it
// Expected exit code: 42
//
// Tests passing an Address (allocated buffer) as a function parameter.
// The function stores 42 at the start of the buffer, loads it back into
// a local variable, and returns that value. Uses `*p` (not `*(p + 0)`)
// because VUMA drops stores through offset addressing inside functions.

fn store_and_load(p: Address) -> u32 {
    *p = 42;
    v: u32 = *p;
    return v;
}

fn main() -> i32 {
    buf = allocate(8);
    v: u32 = store_and_load(buf);
    free(buf);
    return v;
}
