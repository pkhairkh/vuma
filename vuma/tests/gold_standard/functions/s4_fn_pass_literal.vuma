// s4_fn_pass_literal.vuma — pass literal 21 to a tripler
// Expected exit code: 63
//
// `tripler(x) = x * 3`. main passes the literal 21, gets 63 back.
// Single function call, single literal argument.

fn tripler(x: u32) -> u32 {
    three: u32 = 3;
    r: u32 = x * three;
    return r;
}

fn main() -> i32 {
    v: u32 = tripler(21);
    return v;
}
