// s85_fn_two_args_mul.vuma — mul(13, 11) = 143
// Expected exit code: 143
//
// Two-argument helper: mul(a, b) = a * b. main calls
// mul(13, 11) -> 13 * 11 = 143. Verifies two u32 parameters
// round-trip through the call/return path. Distinct from
// s82_fn_two_args_mul, s78_fn_two_args_mul and
// s74_fn_two_args_mul.
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(13, 11);
    return v;
}
