// s99_fn_two_args_sub.vuma — sub(75, 25) = 75 - 25 = 50
// Expected exit code: 50
//
// Helper sub(a, b) = a - b. main calls sub(75, 25) -> 50. Two-arg
// function subtracting its arguments. Distinct from
// s95_fn_two_args_mul (64), s91_fn_two_args_mul (27) and
// s87_fn_two_args_sub (155).
fn sub(a: u32, b: u32) -> u32 {
    r: u32 = a - b;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(75, 25);    // 50
    return v;
}
