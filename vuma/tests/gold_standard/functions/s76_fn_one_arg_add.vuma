// s76_fn_one_arg_add.vuma — add_thirty_seven(50) = 87
// Expected exit code: 87
//
// Helper add_thirty_seven(x) = x + 37. main calls
// add_thirty_seven(50) -> 87. Single-arg function that adds a
// literal. Distinct from s74_fn_one_arg_add (167), s73_fn_one_
// arg_add (103) and s72_fn_one_arg_add (156).
fn add_thirty_seven(x: u32) -> u32 {
    n: u32 = 37;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_thirty_seven(50);
    return v;
}
