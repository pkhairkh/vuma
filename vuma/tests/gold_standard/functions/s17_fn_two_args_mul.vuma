// s17_fn_two_args_mul.vuma — mul(7, 6) = 42
// Expected exit code: 42
//
// Helper mul(a, b) = a * b. main calls mul(7, 6) -> 42. Two-argument
// helper, multiplication. Distinct from s14_fn_two_args_diff (a - b)
// and s9_fn_two_args_prod (different values).

fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(7, 6);
    return v;
}
