// s80_fn_one_arg_add.vuma — add(26) = 26 + 1 = 27
// Expected exit code: 27
//
// Helper add(x) = x + 1. main calls add(26) -> 26 + 1 = 27.
// One-arg function that adds a constant. Distinct from s78_fn_one_
// arg_add (2), s74_fn_one_arg_add (95) and s73_fn_one_arg_add (108).
fn add(x: u32) -> u32 {
    k: u32 = 1;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = add(26);
    return v;
}
