// s47_fn_one_arg_add.vuma — add_eight(72) = 80
// Expected exit code: 80
//
// Helper add_eight(x) = x + 8. main calls add_eight(72) -> 80.
// Single-arg function that adds a literal. Distinct from s46_fn_
// one_arg_sub (sub_seven(80) = 73) and s42_fn_one_arg_add (58).

fn add_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_eight(72);
    return v;
}
