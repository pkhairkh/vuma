// s34_fn_one_arg_add.vuma — add_five(60) = 65
// Expected exit code: 65
//
// Helper add_five(x) = x + 5. main calls add_five(60) -> 65.
// Single function call, one literal argument, addition. Distinct
// from s30_fn_one_arg_add (add_one(50) = 51) and s27_fn_one_arg_
// double (double(40) = 80).

fn add_five(x: u32) -> u32 {
    n: u32 = 5;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_five(60);
    return v;
}
