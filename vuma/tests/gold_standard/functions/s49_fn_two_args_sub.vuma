// s49_fn_two_args_sub.vuma — sub(200, 75) = 125
// Expected exit code: 125
//
// Helper sub(x, y) = x - y. main calls sub(200, 75) -> 125. Two-arg
// function returning the difference. Distinct from s46_fn_two_args_
// mul (mul(9, 11) = 99) and s42_fn_two_args_sub (sub(80, 25) = 55).

fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(200, 75);
    return v;
}
