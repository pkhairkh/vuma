// s40_fn_one_arg_double.vuma — dbl(35) = 70
// Expected exit code: 70
//
// Helper dbl(x) = x * 2. main calls dbl(35) -> 70. Single-arg
// function that doubles its input. Distinct from s38_fn_one_arg_sub
// (47) and s34_fn_one_arg_add (65).

fn dbl(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = dbl(35);
    return v;
}
