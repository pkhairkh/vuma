// s59_fn_two_args_mul.vuma — mul(15, 9) = 135
// Expected exit code: 135
//
// Helper mul(x, y) = x * y. main calls mul(15, 9) -> 135. Two-arg
// function returning the product. Distinct from s58_fn_zero_arg_lit
// (150), s58_fn_one_arg_sub (92) and s58_fn_two_args_add (155).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(15, 9);
    return v;
}
