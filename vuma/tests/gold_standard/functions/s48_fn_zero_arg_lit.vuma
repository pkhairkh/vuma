// s48_fn_zero_arg_lit.vuma — get_const() = 200
// Expected exit code: 200
//
// Helper get_const() returns the literal 200. main calls get_const()
// -> 200. Zero-arg function returning a literal. Distinct from s46_
// fn_zero_arg_lit (115) and s42_fn_zero_arg_lit (95).

fn get_const() -> u32 {
    v: u32 = 200;
    return v;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
