// fn_two_params.vuma — add(3, 4) = 7
// Expected exit code: 7
//
// Tests passing two parameters to a function and returning their sum.
// Verifies the calling convention for two-argument leaf functions.

fn add(a: u32, b: u32) -> u32 {
    return a + b;
}

fn main() -> i32 {
    v: u32 = add(3, 4);
    return v;
}
