// s33_fn_two_args_sub.vuma — sub_vals(150, 70) = 80
// Expected exit code: 80
//
// Deterministic test in the functions category. All operands loaded into typed
// variables before any bitwise op; all stores use `*ptr = literal` (or the
// `*ptr = variable + 0` workaround). Result lands in 0-255.
// Distinct from s30_fn_two_args_mul (mul_two(10,15)=150) and s26_fn_two_args_mod (mod_vals(50,7)=1).
fn sub_vals(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_vals(150, 70);
    return v;
}
