// s16_fn_inc_by_two.vuma — inc_by_two(40) = 42
// Expected exit code: 42
//
// Helper inc_by_two(x) = x + 2. main calls inc_by_two(40) -> 42. Single
// helper, single literal argument, addition by 2. Distinct from
// s13_fn_inc_by (inc by 1) and s14_fn_one_arg_add (add_one helper).

fn inc_by_two(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = inc_by_two(40);
    return v;
}
