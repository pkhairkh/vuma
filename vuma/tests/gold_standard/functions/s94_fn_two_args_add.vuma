// s94_fn_two_args_add.vuma — add(50, 38) = 50 + 38 = 88
// Expected exit code: 88
//
// Helper add(a, b) = a + b. main calls add(50, 38) -> 88. Two-arg
// function adding its arguments. Distinct from s90_fn_two_args_mul
// (16), s86_fn_two_args_sub (150) and s82_fn_two_args_mul (56).
fn add(a: u32, b: u32) -> u32 {
    r: u32 = a + b;
    return r;
}

fn main() -> i32 {
    v: u32 = add(50, 38);    // 88
    return v;
}
