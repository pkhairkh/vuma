// s60_fn_one_arg_add.vuma — add_six(100) = 106
// Expected exit code: 106
//
// Helper add_six(x) = x + 6. main calls add_six(100) -> 106.
// Single-arg function that adds a literal. Distinct from s58_fn_
// one_arg_sub (92) and s57_fn_one_arg_add (108).

fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_six(100);
    return v;
}
