// s27_fn_two_args_mod.vuma — mod_pair(200, 7) = 4
// Expected exit code: 4
//
// Helper mod_pair(x, y) = x % y. main calls mod_pair(200, 7) -> 4
// (7*28=196, remainder 4). Two literal arguments, modulo. Distinct from
// s26_fn_two_args_div (div, 60/4=15) and s22_fn_two_args_mul (mul).

fn mod_pair(x: u32, y: u32) -> u32 {
    r: u32 = x % y;
    return r;
}

fn main() -> i32 {
    v: u32 = mod_pair(200, 7);
    return v;
}
