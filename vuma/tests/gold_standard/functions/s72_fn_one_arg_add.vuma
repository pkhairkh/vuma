// s72_fn_one_arg_add.vuma — add_six(150) = 156
// Expected exit code: 156
//
// Helper add_six(x) = x + 6. main calls add_six(150) -> 156.
// Single-arg function that adds a literal. Distinct from
// s70_fn_one_arg_add (165), s69_fn_one_arg_add (125) and
// s66_fn_one_arg_sub (80).
fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_six(150);
    return v;
}
