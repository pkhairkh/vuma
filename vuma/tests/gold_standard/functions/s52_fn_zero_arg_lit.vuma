// s52_fn_zero_arg_lit.vuma — get_const() = 200
// Expected exit code: 200
//
// Helper get_const() returns the literal 200. main calls get_const()
// -> 200. Zero-arg function returning a literal. Distinct from
// s50_fn_zero_arg_lit (128) and s46_fn_zero_arg_lit (150).

fn get_const() -> u32 {
    r: u32 = 200;
    return r;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
