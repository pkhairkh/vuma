// s100_fn_one_arg_add.vuma — inc(26) = 26 + 11 = 37
// Expected exit code: 37
//
// Helper inc(x) = x + 11. main calls inc(26) -> 37. Single-
// arg function adding a constant.
// Distinct from s97_fn_one_arg_add (23), s94_fn_one_arg_sub (41), s90_fn_one_arg_add (14).
fn inc(x: u32) -> u32 {
    k: u32 = 11;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = inc(26);        // 37
    return v;
}
