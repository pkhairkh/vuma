// fn_four_params.vuma — add4(1, 2, 3, 4) = 10
// Expected exit code: 10
//
// Tests passing four parameters to a function and returning their sum.
// Four arguments stress the register-vs-stack split in the calling convention.

fn add4(a: u32, b: u32, c: u32, d: u32) -> u32 {
    return a + b + c + d;
}

fn main() -> i32 {
    v: u32 = add4(1, 2, 3, 4);
    return v;
}
