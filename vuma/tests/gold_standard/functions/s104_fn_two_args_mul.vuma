// s104_fn_two_args_mul.vuma — mul(6, 19) = 6 * 19 = 114
// Expected exit code: 114
//
// Helper mul(a, b) = a * b. main calls mul(6, 19) -> 114. Two-arg function multiplying.
// Distinct from s102_fn_zero_arg_lit (6), s102_fn_one_arg_add (19), s102_fn_two_args_mul (26).
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(6, 19);   // 114
    return v;
}
