// s98_fn_two_args_add.vuma — add(30, 22) = 30 + 22 = 52
// Expected exit code: 52
//
// Helper add(a, b) = a + b. main calls add(30, 22) -> 52. Two-arg
// function adding its arguments. Distinct from s94_fn_two_args_add
// (88), s90_fn_two_args_mul (16) and s86_fn_two_args_sub (150).
fn add(a: u32, b: u32) -> u32 {
    r: u32 = a + b;
    return r;
}

fn main() -> i32 {
    v: u32 = add(30, 22);    // 52
    return v;
}
