// s65_fn_two_args_mul.vuma — mul(13, 7) = 91
// Expected exit code: 91
//
// Helper mul(x, y) = x * y. main calls mul(13, 7) -> 91. Two-arg
// function returning the product. Distinct from s51_fn_two_args_mul
// (135), s58_fn_two_args_add (155) and s62_fn_two_args_mul (180).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(13, 7);
    return v;
}
