// s47_fn_two_args_add.vuma — add(60, 50) = 110
// Expected exit code: 110
//
// Helper add(x, y) = x + y. main calls add(60, 50) -> 110. Two-arg
// function returning the sum. Distinct from s46_fn_two_args_mul
// (mul(9, 11) = 99) and s42_fn_two_args_sub (sub(80, 25) = 55).

fn add(x: u32, y: u32) -> u32 {
    r: u32 = x + y;
    return r;
}

fn main() -> i32 {
    v: u32 = add(60, 50);
    return v;
}
