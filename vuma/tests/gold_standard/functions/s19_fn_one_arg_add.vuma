// s19_fn_one_arg_add.vuma — add_one(54) = 55
// Expected exit code: 55
//
// Helper add_one(x) = x + 1. main calls add_one(54) -> 55. Single
// function call, single literal argument, addition. Distinct from
// s18_fn_one_arg_mul (triple(14) = 42, multiplication) and
// s14_fn_one_arg_add (add_one(41) = 42).

fn add_one(x: u32) -> u32 {
    n: u32 = 1;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_one(54);
    return v;
}
