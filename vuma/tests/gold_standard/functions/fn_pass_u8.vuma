// fn_pass_u8.vuma — pass u8 max (255) to function, return it
// Expected exit code: 255
//
// Tests passing an 8-bit unsigned integer parameter and returning it
// unchanged. Verifies u8 parameter passing round-trip.

fn echo_u8(x: u8) -> u8 {
    return x;
}

fn main() -> i32 {
    v: u8 = echo_u8(255);
    return v;
}
