// s17_fn_one_arg_double.vuma — double(21) = 42
// Expected exit code: 42
//
// Helper double(x) = x * 2. main calls double(21) -> 42. Single
// function call, single literal argument, multiplication. Distinct from
// s14_fn_one_arg_add (add_one(41) = 42) and s9_fn_one_arg_sub
// (sub5(100) = 95).

fn double(x: u32) -> u32 {
    n: u32 = 2;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = double(21);
    return v;
}
