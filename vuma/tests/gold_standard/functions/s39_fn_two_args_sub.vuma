// s39_fn_two_args_sub.vuma — sub(80, 35) = 45
// Expected exit code: 45
//
// Helper sub(x, y) = x - y. main calls sub(80, 35) -> 45. Two-arg
// function returning the difference. Distinct from s38_fn_two_args_
// mul (63) and s34_fn_two_args_div.

fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(80, 35);
    return v;
}
