// s90_fn_two_args_mul.vuma — mul(2, 8) = 2 * 8 = 16
// Expected exit code: 16
//
// Helper mul(a, b) = a * b. main calls mul(2, 8) -> 16. Two-arg
// function multiplying its arguments. Distinct from s86_fn_two_
// args_sub (242), s82_fn_two_args_mul (197) and s78_fn_two_args_
// sub (3).
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(2, 8);      // 16
    return v;
}
