// s56_fn_zero_arg_lit.vuma — constant() returns 155
// Expected exit code: 155
//
// Helper takes no args and returns the constant 155. main calls it
// and returns 155. Zero-arg function returning a literal. Distinct
// from s54_fn_zero_arg_lit (175) and s50_fn_zero_arg_lit (135).

fn constant() -> u32 {
    r: u32 = 155;
    return r;
}

fn main() -> i32 {
    v: u32 = constant();
    return v;
}
