// s57_fn_two_args_mul.vuma — mul(8, 13) = 104
// Expected exit code: 104
//
// Helper mul(x, y) = x * y. main calls mul(8, 13) -> 104. Two-arg
// function returning the product. Distinct from s54_fn_two_args_add
// (125) and s50_fn_two_args_sub (40).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(8, 13);
    return v;
}
