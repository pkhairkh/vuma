// s5_fn_three_args_sum.vuma — sum3(10, 20, 30) = 60
// Expected exit code: 60
//
// Helper takes three u32 params, sums them, returns the result.
// main calls sum3(10, 20, 30) -> 60. Distinct from fn_two_params /
// fn_three_params (which compute different expressions).

fn sum3(a: u32, b: u32, c: u32) -> u32 {
    t: u32 = a + b;
    r: u32 = t + c;
    return r;
}

fn main() -> i32 {
    v: u32 = sum3(10, 20, 30);
    return v;
}
