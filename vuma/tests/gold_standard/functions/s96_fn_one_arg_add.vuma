// s96_fn_one_arg_add.vuma — add_nine(60) = 60 + 9 = 69
// Expected exit code: 69
//
// Helper add_nine(x) = x + 9. main calls add_nine(60) -> 69.
// Single-arg function adding a constant. Distinct from
// s94_fn_one_arg_sub (41), s90_fn_one_arg_add (14) and
// s86_fn_one_arg_add (210).
fn add_nine(x: u32) -> u32 {
    k: u32 = 9;
    r: u32 = x + k;
    return r;
}

fn main() -> i32 {
    v: u32 = add_nine(60);  // 69
    return v;
}
