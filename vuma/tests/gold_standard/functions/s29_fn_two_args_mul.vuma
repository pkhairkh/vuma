// s29_fn_two_args_mul.vuma — mul_pair(13, 5) = 65
// Expected exit code: 65
//
// Helper mul_pair(x, y) = x * y. main calls mul_pair(13, 5) -> 65. Two literal arguments, multiplication. Distinct from s26_fn_two_args_div (div_pair(60, 4) = 15) and s22_fn_two_args_mul (mul(7, 6) = 42).

fn mul_pair(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul_pair(13, 5);
    return v;
}
