// s95_fn_two_args_mul.vuma — mul(8, 8) = 8 * 8 = 64
// Expected exit code: 64
//
// Helper mul(a, b) = a * b. main calls mul(8, 8) -> 64. Two-arg
// function multiplying its arguments. Distinct from
// s94_fn_two_args_add (88), s90_fn_two_args_mul (16) and
// s82_fn_two_args_mul (56).
fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(8, 8);     // 64
    return v;
}
