// s62_fn_two_args_mul.vuma — mul(10, 18) = 180
// Expected exit code: 180
// 
// Helper mul(x, y) = x * y. main calls mul(10, 18) -> 180. Two-arg
// function returning the product. Distinct from s51_fn_two_args_mul
// (135), s58_fn_two_args_add (155) and s55_fn_two_args_mul (135).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(10, 18);
    return v;
}
