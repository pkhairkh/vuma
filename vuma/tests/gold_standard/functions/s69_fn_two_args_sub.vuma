// s69_fn_two_args_sub.vuma -- sub(200, 95) = 105
// Expected exit code: 105
//
// Helper sub(x, y) = x - y. main calls sub(200, 95) -> 105. Two-arg
// function returning the difference. Distinct from s66_fn_two_args_
// add (175), s65_fn_two_args_mul (91) and s64_fn_two_args_sub (135).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(200, 95);
    return v;
}
