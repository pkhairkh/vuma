// s65_fn_one_arg_add.vuma — add_thirty(110) = 140
// Expected exit code: 140
//
// Helper add_thirty(x) = x + 30. main calls add_thirty(110) ->
// 140. Single-arg function that adds a literal. Distinct from
// s51_fn_one_arg_add (62), s58_fn_one_arg_sub (92) and s62_fn_one_
// arg_add (115).

fn add_thirty(x: u32) -> u32 {
    n: u32 = 30;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_thirty(110);
    return v;
}
