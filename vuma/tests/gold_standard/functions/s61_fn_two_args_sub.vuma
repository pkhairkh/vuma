// s61_fn_two_args_sub.vuma — sub(180, 70) = 180 - 70 = 110
// Expected exit code: 110
// 
// Helper sub(x, y) = x - y. main calls sub(180, 70) -> 110. Two-arg
// function returning the difference. Distinct from s58_fn_zero_arg_
// lit (150), s58_fn_one_arg_sub (92) and s58_fn_two_args_add (155).

fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(180, 70);
    return v;
}
