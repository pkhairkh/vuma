// s6_fn_pass_intermediate.vuma — double(double(5)) = 20
// Expected exit code: 20
//
// Helper double(x) = x * 2. main calls double(5) -> 10, then passes
// that result back into double -> 20. Single-helper nested call.
// Distinct from s5_fn_call_chain_diff_funcs (different helpers).

fn double(x: u32) -> u32 {
    two: u32 = 2;
    r: u32 = x * two;
    return r;
}

fn main() -> i32 {
    a: u32 = double(5);   // 10
    b: u32 = double(a);   // 20
    return b;
}
