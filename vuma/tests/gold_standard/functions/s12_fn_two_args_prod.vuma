// s12_fn_two_args_prod.vuma — prod(6, 7) = 42
// Expected exit code: 42
//
// Helper prod(a, b) = a * b. main calls prod(6, 7) -> 42. Two-
// argument helper with a single multiplication. Distinct from
// s6_fn_two_args_mul (mul, values 5/6) and s7_fn_two_args_sub
// (subtract).

fn prod(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = prod(6, 7);
    return v;
}
