// s9_fn_zero_arg_const.vuma — get_const() returns 33
// Expected exit code: 33
//
// Helper takes no parameters and returns a constant 33. Tests
// that the codegen can compile and call a zero-argument function
// that returns a function-local constant. Distinct from
// s5_fn_return_constant (helper takes an unused parameter).

fn get_const() -> u32 {
    c: u32 = 33;
    return c;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
