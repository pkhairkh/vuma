// s36_fn_one_arg_mul.vuma — mul_six(15) = 90
// Expected exit code: 90
//
// One-argument helper mul_six(x) = x * 6. main calls
// mul_six(15) -> 90. Verifies single-arg multiplication
// calling convention.
// Distinct from s30_fn_one_arg_add (one-arg-add, 0) and s27_fn_one_arg_mul (different value).

fn mul_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x * n;
    return r;
}

fn main() -> i32 {
    v: u32 = mul_six(15);
    return v;
}
