// s11_fn_three_args_diff.vuma — sub3(100, 30, 20) = 50
// Expected exit code: 50
//
// Helper sub3(a, b, c) = a - b - c. main calls sub3(100, 30, 20)
// -> 100 - 30 - 20 = 50. Three-arg function with chained sub.
// Distinct from s5_fn_three_args_sum (three-arg sum) and
// s9_fn_two_args_add (two-arg add).

fn sub3(a: u32, b: u32, c: u32) -> u32 {
    t: u32 = a - b;
    r: u32 = t - c;
    return r;
}

fn main() -> i32 {
    v: u32 = sub3(100, 30, 20);   // 50
    return v;
}
