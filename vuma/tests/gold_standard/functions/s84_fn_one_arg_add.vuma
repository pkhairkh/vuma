// s84_fn_one_arg_add.vuma — add_sixteen(13) = 13 + 16 = 29
// Expected exit code: 29
//
// Helper add_sixteen(x) = x + 16. main calls add_sixteen(13)
// -> 29. Single-arg function that adds a literal. Distinct
// from s82_fn_one_arg_add (170), s78_fn_one_arg_add (2)
// and s74_fn_one_arg_add (167).
fn add_sixteen(x: u32) -> u32 {
    n: u32 = 16;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_sixteen(13);
    return v;
}
