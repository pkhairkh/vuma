// s76_fn_two_args_mul.vuma — mul(3, 41) = 123
// Expected exit code: 123
//
// Helper mul(x, y) = x * y. main calls mul(3, 41) -> 123.
// Two-arg function returning the product. Distinct from
// s74_fn_two_args_mul (122), s73_fn_two_args_mul (132) and
// s72_fn_two_args_mul (182).
fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(3, 41);
    return v;
}
