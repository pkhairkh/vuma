// s30_fn_two_args_mul.vuma — mul_two(7, 9) = 63
// Expected exit code: 63
//
// Helper mul_two(x, y) = x * y. main calls mul_two(7, 9) -> 63. Single
// function call, two literal arguments, multiplication. Distinct from
// s26_fn_two_args_div (div_pair(180, 12) = 15) and s22_fn_two_args_mul
// (different values).

fn mul_two(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul_two(7, 9);
    return v;
}
