// s84_fn_two_args_sub.vuma — sub(80, 50) = 80 - 50 = 30
// Expected exit code: 30
//
// Helper sub(x, y) = x - y. main calls sub(80, 50) -> 30.
// Two-arg function that subtracts. Distinct from s82_fn_two_
// args_mul (56), s78_fn_two_args_sub (3) and s74_fn_two_args_
// mul (122).
fn sub(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub(80, 50);
    return v;
}
