// s55_fn_zero_arg_lit.vuma — get_const() = 160
// Expected exit code: 160
//
// Helper get_const() returns the literal 160. main calls get_const()
// -> 160. Zero-arg function returning a literal. Distinct from
// s54_fn_zero_arg_lit (145) and s53_fn_zero_arg_lit (137).

fn get_const() -> u32 {
    v: u32 = 160;
    return v;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
