// s38_fn_two_args_mul.vuma — mul(7, 9) = 63
// Expected exit code: 63
//
// Helper mul(x, y) = x * y. main calls mul(7, 9) -> 63. Two-arg
// function returning the product. Distinct from s34_fn_two_args_mul
// (72) and s30_fn_two_args_mul (different values).

fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(7, 9);
    return v;
}
