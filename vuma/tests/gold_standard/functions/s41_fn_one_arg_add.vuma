// s41_fn_one_arg_add.vuma - add_eight(60) = 68
// Expected exit code: 68
//
// Helper add_eight(x) = x + 8. main calls add_eight(60) -> 68.
// Single-arg function that adds a literal. Distinct from s38_fn_
// one_arg_sub (47) and s34_fn_one_arg_add (65).

fn add_eight(x: u32) -> u32 {
    n: u32 = 8;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_eight(60);
    return v;
}
