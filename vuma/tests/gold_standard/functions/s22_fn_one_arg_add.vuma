// s22_fn_one_arg_add.vuma — add_six(36) = 42
// Expected exit code: 42
//
// Helper add_six(x) = x + 6. main calls add_six(36) -> 42. Single
// function call, single literal argument, addition. Distinct from
// s18_fn_one_arg_mul (triple(14) = 42, mul) and s14_fn_one_arg_add
// (add_one(41) = 42).

fn add_six(x: u32) -> u32 {
    n: u32 = 6;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_six(36);
    return v;
}
