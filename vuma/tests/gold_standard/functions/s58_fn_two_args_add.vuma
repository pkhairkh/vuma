// s58_fn_two_args_add.vuma — add(70, 85) = 155
// Expected exit code: 155
// 
// Helper add(x, y) = x + y. main calls add(70, 85) -> 155. Two-arg
// function returning the sum. Distinct from s51_fn_zero_arg_lit
// (134), s51_fn_one_arg_add (62) and s51_fn_two_args_mul (135).

fn add(x: u32, y: u32) -> u32 {
    r: u32 = x + y;
    return r;
}

fn main() -> i32 {
    v: u32 = add(70, 85);
    return v;
}
