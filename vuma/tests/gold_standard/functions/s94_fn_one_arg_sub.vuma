// s94_fn_one_arg_sub.vuma — dec(50) = 50 - 9 = 41
// Expected exit code: 41
//
// Helper dec(x) = x - 9. main calls dec(50) -> 41. Single-arg
// function subtracting a constant. Distinct from s90_fn_one_arg_add
// (14), s86_fn_one_arg_add (210) and s82_fn_one_arg_add (170).
fn dec(x: u32) -> u32 {
    k: u32 = 9;
    r: u32 = x - k;
    return r;
}

fn main() -> i32 {
    v: u32 = dec(50);        // 41
    return v;
}
