// s86_fn_one_arg_add.vuma — add_thirty(180) = 180 + 30 = 210
// Expected exit code: 210
//
// Helper add_thirty(x) = x + 30. main calls add_thirty(180)
// -> 210. Single-arg function that adds a literal. Distinct
// from s82_fn_one_arg_add (170), s78_fn_one_arg_add (2) and
// s74_fn_one_arg_add (95).
fn add_thirty(x: u32) -> u32 {
    n: u32 = 30;
    r: u32 = x + n;
    return r;
}

fn main() -> i32 {
    v: u32 = add_thirty(180);
    return v;
}
