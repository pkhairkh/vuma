// s21_fn_two_args_diff.vuma — diff(120, 45) = 75
// Expected exit code: 75
//
// Helper diff(a, b) = a - b. main calls diff(120, 45) -> 75. Two-arg
// function with subtraction. Distinct from s18_fn_two_args_add
// (add(37, 48) = 85, addition) and s14_fn_two_args_diff (diff(80, 35)
// = 45).

fn diff(a: u32, b: u32) -> u32 {
    r: u32 = a - b;
    return r;
}

fn main() -> i32 {
    v: u32 = diff(120, 45);
    return v;
}
