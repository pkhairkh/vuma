// fn2_pass_u32.vuma — pass 42 as u32, return it
// Expected exit code: 42
//
// Tests passing a 32-bit unsigned integer parameter (42) and returning
// it unchanged. Verifies u32 parameter passing round-trip.

fn echo_u32(x: u32) -> u32 {
    return x;
}

fn main() -> i32 {
    v: u32 = echo_u32(42);
    return v;
}
