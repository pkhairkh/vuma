// s36_fn_two_args_sub.vuma — sub_vals(200, 80) = 120
// Expected exit code: 120
//
// Two-argument helper sub_vals(x, y) = x - y. main calls
// sub_vals(200, 80) -> 120. Verifies two-arg subtraction
// calling convention.
// Distinct from s30_fn_two_args_mul (mul_two(10,15)=150) and s27_fn_two_args_sub (different values).

fn sub_vals(x: u32, y: u32) -> u32 {
    r: u32 = x - y;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_vals(200, 80);
    return v;
}
