// s4_fn_nested_call.vuma — f(g(7)) with intermediate variable
// Expected exit code: 22
//
// `g(x) = x + 3`, `f(x) = x + 12`. main calls g(7) → 10 into a
// local, then passes that local to f → 22. Uses intermediate
// variable because VUMA miscompiles nested call expressions used
// directly as arguments.

fn g(x: u32) -> u32 {
    three: u32 = 3;
    r: u32 = x + three;
    return r;
}
fn f(x: u32) -> u32 {
    twelve: u32 = 12;
    r: u32 = x + twelve;
    return r;
}

fn main() -> i32 {
    inner: u32 = g(7);
    outer: u32 = f(inner);
    return outer;
}
