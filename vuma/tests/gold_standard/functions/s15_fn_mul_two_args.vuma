// s15_fn_mul_two_args.vuma — mul(7, 6) = 42
// Expected exit code: 42
//
// Helper mul(a, b) = a * b. main calls mul(7, 6) -> 42. Two-arg function
// with multiplication. Distinct from s12_fn_two_args_prod (prod(6, 7) = 42,
// swapped order) and s14_fn_two_args_diff (diff(80, 35) = 45, subtraction).

fn mul(a: u32, b: u32) -> u32 {
    r: u32 = a * b;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(7, 6);
    return v;
}
