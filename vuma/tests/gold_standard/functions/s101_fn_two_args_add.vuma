// s101_fn_two_args_add.vuma — add(25, 50) = 25 + 50 = 75
// Expected exit code: 75
//
// Helper add(a, b) = a + b. main calls add(25, 50) -> 75. Two-arg
// function adding its arguments. Distinct from s98_fn_two_args_add
// (52), s97_fn_two_args_mul (8) and s94_fn_two_args_add (88).
fn add(a: u32, b: u32) -> u32 {
    r: u32 = a + b;
    return r;
}

fn main() -> i32 {
    v: u32 = add(25, 50);   // 75
    return v;
}
