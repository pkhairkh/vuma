// s63_fn_one_arg_sub.vuma — sub_twenty(190) = 170
// Expected exit code: 170
//
// Helper sub_twenty(x) = x - 20. main calls sub_twenty(190) ->
// 170. Single-arg function that subtracts a literal. Distinct from
// s51_fn_one_arg_add (62), s58_fn_one_arg_sub (92) and s55_fn_one_
// arg_add (62).

fn sub_twenty(x: u32) -> u32 {
    n: u32 = 20;
    r: u32 = x - n;
    return r;
}

fn main() -> i32 {
    v: u32 = sub_twenty(190);
    return v;
}
