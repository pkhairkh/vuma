// s54_fn_two_args_add.vuma — add(50, 75) = 125
// Expected exit code: 125
//
// Helper add(x, y) = x + y. main calls add(50, 75) -> 125.
// Two-arg function returning the sum. Distinct from s50_fn_two_
// args_sub (40) and s49_fn_two_args_sub (45).

fn add(x: u32, y: u32) -> u32 {
    r: u32 = x + y;
    return r;
}

fn main() -> i32 {
    v: u32 = add(50, 75);
    return v;
}
