// s26_fn_zero_arg_lit.vuma — get_const() returns 99
// Expected exit code: 99
//
// Helper get_const() takes no args and returns the literal 99. main
// calls get_const() -> 99. Distinct from s22_fn_zero_arg_lit (returns
// 42) and s18_fn_zero_arg_lit (returns 17).

fn get_const() -> u32 {
    r: u32 = 99;
    return r;
}

fn main() -> i32 {
    v: u32 = get_const();
    return v;
}
