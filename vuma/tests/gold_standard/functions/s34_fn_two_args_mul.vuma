// s34_fn_two_args_mul.vuma — mul_two(8, 9) = 72
// Expected exit code: 72
//
// Helper mul_two(x, y) = x * y. main calls mul_two(8, 9) -> 72.
// Single function call, two literal arguments, multiplication.
// Distinct from s30_fn_two_args_mul (mul(7, 9) = 63) and s27_fn_
// two_args_mod (mod(50, 7) = 1).

fn mul_two(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul_two(8, 9);
    return v;
}
