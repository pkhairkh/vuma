// s15_fn_sq_pair_sub.vuma — sq(8) - sq(3) = 64 - 9 = 55
// Expected exit code: 55
//
// Helper sq(x) = x * x. main calls sq(8) -> 64 and sq(3) -> 9, then
// subtracts -> 55. Single helper, two calls with different arguments.
// Distinct from s13_fn_square_diff (sq(10) - sq(4) = 84) and
// s7_fn_square (single sq call).

fn sq(x: u32) -> u32 {
    r: u32 = x * x;
    return r;
}

fn main() -> i32 {
    a: u32 = sq(8);       // 64
    b: u32 = sq(3);       // 9
    d: u32 = a - b;       // 55
    return d;
}
