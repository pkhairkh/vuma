// s70_fn_two_args_mul.vuma — mul(20, 11) = 220
// Expected exit code: 220
//
// Helper mul(x, y) = x * y. main calls mul(20, 11) -> 220.
// Two-arg function returning the product. Distinct from
// s66_fn_two_args_add (175), s65_fn_two_args_mul (91) and
// s62_fn_two_args_mul (180).
fn mul(x: u32, y: u32) -> u32 {
    r: u32 = x * y;
    return r;
}

fn main() -> i32 {
    v: u32 = mul(20, 11);
    return v;
}
